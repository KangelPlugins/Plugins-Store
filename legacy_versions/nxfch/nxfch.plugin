def _safe_int(x, default=0):
    try:
        if x is None: return default
        return int(x)
    except Exception:
        return default


def is_saved_chat(fragment):
    try:
        if fragment:
            dialog_id = _safe_int(fragment.getDialogId())
            if dialog_id == 0: return False
            UserConfig = find_class("org.telegram.messenger.UserConfig")
            if UserConfig:
                account = _safe_int(fragment.getCurrentAccount())
                me = _safe_int(UserConfig.getInstance(account).getClientUserId())
                if dialog_id == me:
                    return True
            if hasattr(fragment, "getChatMode") and _safe_int(fragment.getChatMode()) == 4:
                return True
    except Exception: pass
    return False


def is_typing(subtitle):
    try:
        if not subtitle: return False
        txt = ""
        if hasattr(subtitle, "getText"):
            t = subtitle.getText()
            if t: txt = str(t).lower()
        elif hasattr(subtitle, "toString"):
            txt = str(subtitle).lower()
        
        keywords = ["печатат", "записыв", "отправл", "выбира", "игра", "typing", "recording", "sending", "choosing", "playing"]
        return any(kw in txt for kw in keywords)
    except Exception:
        return False


def should_center(fragment):
    try:
        if not fragment: return False
        try:
            cls_name = fragment.getClass().getName()
            if "Feed" in cls_name or "Folder" in cls_name:
                return False
        except Exception: pass
        
        dialog_id = _safe_int(fragment.getDialogId())
        if dialog_id == 0:
            return False
            
        UserConfig = find_class("org.telegram.messenger.UserConfig")
        me = 0
        if UserConfig:
            account = _safe_int(fragment.getCurrentAccount())
            me = _safe_int(UserConfig.getInstance(account).getClientUserId())
            
        is_saved = (dialog_id == me) or (hasattr(fragment, "getChatMode") and _safe_int(fragment.getChatMode()) == 4)
            
        chat = None
        for name in ["getCurrentChat", "getChat"]:
            if hasattr(fragment, name):
                try:
                    chat = getattr(fragment, name)()
                    if chat: break
                except Exception: pass
        
        if not chat and dialog_id < 0:
            MessagesController = find_class("org.telegram.messenger.MessagesController")
            if MessagesController and UserConfig:
                account = _safe_int(fragment.getCurrentAccount())
                chat = MessagesController.getInstance(account).getChat(-dialog_id)
        
        is_forum = False
        if chat:
            try:
                if get_private_field(chat, "forum") or (hasattr(chat, "isForum") and chat.isForum()):
                    is_forum = True
            except Exception: pass
        
        topic_id = 0
        for name in ["topicId", "threadId", "currentTopicId", "getTopicId", "getCurrentTopicId", "getThreadId"]:
            try:
                if hasattr(fragment, name):
                    val = getattr(fragment, name)
                    topic_id = _safe_int(val() if callable(val) else val)
                    if topic_id != 0:
                        break
            except Exception: pass
        
        if is_forum or is_saved:
            if topic_id == 0:
                return False
            return True
            
        return True
    except Exception:
        return False


def set_fade_width(v, width_px):
    if not v: return
    try:
        if hasattr(v, "setFadeWidth"):
            v.setFadeWidth(width_px)
        set_private_field(v, "fadeWidth", width_px)
    except Exception: pass


def get_tight_width(v, AndroidUtilities):
    if not v: return 0
    tw = 0
    try:
        if hasattr(v, "getTextWidth"):
            tw = _safe_int(v.getTextWidth())
    except Exception: pass

    if tw <= 0:
        txt_str = ""
        try:
            if hasattr(v, "getText"):
                t = v.getText()
                if t: txt_str = str(t)
            if not txt_str:
                drawable = get_private_field(v, "drawable")
                if drawable and hasattr(drawable, "getText"):
                    t = drawable.getText()
                    if t: txt_str = str(t)
        except Exception: pass

        if txt_str:
            try:
                tp = get_private_field(v, "textPaint")
                if not tp:
                    drawable = get_private_field(v, "drawable")
                    if drawable:
                        tp = get_private_field(drawable, "textPaint") or get_private_field(drawable, "paint")
                if tp:
                    tw = _safe_int(tp.measureText(txt_str))
            except Exception: pass

    icons_w = 0
    pad = AndroidUtilities.dp(4)
    for dr_name in ["leftDrawable", "rightDrawable", "rightDrawable2", "rightDrawableOuter"]:
        try:
            dr = get_private_field(v, dr_name)
            if dr:
                icons_w += AndroidUtilities.dp(20) + pad
        except Exception: pass
        
    return tw + icons_w


class _CtorHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def after_hooked_method(self, param):
        if not self.plugin.get_setting("enabled", True):
            return
        try:
            this = param.thisObject
            title = get_private_field(this, "titleTextView")
            subtitle = get_private_field(this, "subtitleTextView")
            
            if title:
                title.setRightDrawableOutside(False)
        except Exception: pass


class _SetTitleHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def after_hooked_method(self, param):
        if not self.plugin.get_setting("enabled", True):
            return
        try:
            this = param.thisObject
            this.requestLayout()
            this.invalidate()
        except Exception: pass


class _UpdateSubtitleHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def after_hooked_method(self, param):
        if not self.plugin.get_setting("enabled", True):
            return
        try:
            this = param.thisObject
            this.requestLayout()
            this.invalidate()
        except Exception: pass


class _OnMeasureHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def after_hooked_method(self, param):
        if not self.plugin.get_setting("enabled", True):
            return
        try:
            this = param.thisObject
            parentFragment = get_private_field(this, "parentFragment")
            if not should_center(parentFragment): return

            widthMeasureSpec = param.args[0]
            MeasureSpec = find_class("android.view.View$MeasureSpec")
            AndroidUtilities = find_class("org.telegram.messenger.AndroidUtilities")
            if not MeasureSpec or not AndroidUtilities: return

            widthBase = _safe_int(MeasureSpec.getSize(widthMeasureSpec))
            height = _safe_int(this.getMeasuredHeight())

            width = widthBase + AndroidUtilities.dp(40)
            this.setMeasuredDimension(width, height)
        except Exception: pass


class _OnLayoutHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def after_hooked_method(self, param):
        if not self.plugin.get_setting("enabled", True):
            return
        try:
            this = param.thisObject
            parentFragment = get_private_field(this, "parentFragment")
            if not should_center(parentFragment): return

            OFFSET_RIGHT_DP = -4
            SAFE_LEFT_DP = 16
            SAFE_RIGHT_MARGIN_DP = 16
            
            AndroidUtilities = find_class("org.telegram.messenger.AndroidUtilities")
            ActionBar = find_class("org.telegram.ui.ActionBar.ActionBar")
            MeasureSpec = find_class("android.view.View$MeasureSpec")
            if not AndroidUtilities or not ActionBar or not MeasureSpec: return

            avatar = get_private_field(this, "avatarImageView")
            title = get_private_field(this, "titleTextView")
            subtitle = get_private_field(this, "subtitleTextView")

            w = _safe_int(this.getWidth())
            height = _safe_int(this.getHeight())
            if w <= 0 or height <= 0: return

            parentW = w
            try:
                p = this.getParent()
                if p and p.getWidth() > 0: 
                    parentW = _safe_int(p.getWidth())
            except Exception: pass

            real_w = min(w, parentW) if parentW > 0 else w

            actionBarHeight = _safe_int(ActionBar.getCurrentActionBarHeight())
            statusBarHeight = _safe_int(AndroidUtilities.statusBarHeight)
            occupyStatusBar = get_private_field(this, "occupyStatusBar")
            occupyStatusBar = bool(occupyStatusBar) if occupyStatusBar is not None else True
            viewTop = (actionBarHeight - AndroidUtilities.dp(42)) // 2 + (statusBarHeight if occupyStatusBar else 0)

            is_saved = is_saved_chat(parentFragment)
            is_typing_active = is_typing(subtitle)
            dp42 = AndroidUtilities.dp(42)
            
            avatarLeft = real_w - AndroidUtilities.dp(OFFSET_RIGHT_DP) - dp42
            if avatar is not None and avatar.getVisibility() != 8:
                avatar.setVisibility(4 if (is_saved or is_typing_active) else 0)
                
                inset = AndroidUtilities.dp(OFFSET_RIGHT_DP)
                avatarRight = real_w - inset
                avatarLeft = avatarRight - dp42
                
                avatarTop = viewTop
                avatar.layout(avatarLeft, avatarTop, avatarRight, avatarTop + dp42)

            if parentFragment:
                headerItem = get_private_field(parentFragment, "headerItem")
                if headerItem:
                    if avatar and avatar.getVisibility() == 0:
                        headerItem.setAlpha(0.0)
                    else:
                        headerItem.setAlpha(1.0)
                
                if is_saved:
                    try:
                        searchItem = get_private_field(parentFragment, "searchItem")
                        if searchItem:
                            searchItem.setTranslationY(-1000.0)
                            searchItem.setAlpha(0.0)
                            searchItem.setVisibility(8)
                            searchItem.setEnabled(False)
                    except Exception: pass

            safeLeft = AndroidUtilities.dp(SAFE_LEFT_DP)
            
            if avatar and avatar.getVisibility() == 0:
                safeRight = avatarLeft - AndroidUtilities.dp(SAFE_RIGHT_MARGIN_DP)
            else:
                safeRight = real_w - AndroidUtilities.dp(16)

            max_available = (safeRight - safeLeft) - AndroidUtilities.dp(4)

            def layout_tight_box(v, top_y):
                if not v or v.getVisibility() == 8: return
                if max_available <= 0: return

                tight_w = get_tight_width(v, AndroidUtilities)
                layout_w = max_available
                ideal_left = safeLeft
                scrolling_enabled = self.plugin.get_setting("scrolling_enabled", True)
                fits = tight_w <= max_available

                if fits:
                    if hasattr(v, "setGravity"):
                        v.setGravity(1)
                    set_fade_width(v, 0)
                    try:
                        if hasattr(v, "setScrollNonFitText"): v.setScrollNonFitText(False)
                        if hasattr(v, "setScrolling"): v.setScrolling(False)
                    except Exception: pass
                else:
                    if hasattr(v, "setGravity"):
                        v.setGravity(3)
                    if scrolling_enabled:
                        set_fade_width(v, AndroidUtilities.dp(10))
                        try:
                            if hasattr(v, "setScrollNonFitText"): v.setScrollNonFitText(True)
                            if hasattr(v, "setScrolling"): v.setScrolling(True)
                        except Exception: pass
                    else:
                        set_fade_width(v, 0)
                        try:
                            if hasattr(v, "setScrollNonFitText"): v.setScrollNonFitText(False)
                            if hasattr(v, "setScrolling"): v.setScrolling(False)
                        except Exception: pass

                try:
                    v.measure(
                        MeasureSpec.makeMeasureSpec(int(layout_w), MeasureSpec.EXACTLY),
                        MeasureSpec.makeMeasureSpec(height, MeasureSpec.AT_MOST)
                    )
                except Exception: pass

                v.layout(int(ideal_left), int(top_y), int(ideal_left + layout_w), int(top_y) + v.getMeasuredHeight())

            if title and title.getVisibility() != 8:
                sub_visible = subtitle and subtitle.getVisibility() != 8
                titleTop = viewTop + AndroidUtilities.dp(4) - title.getPaddingTop()
                layout_tight_box(title, titleTop)
                if sub_visible:
                    layout_tight_box(subtitle, viewTop + AndroidUtilities.dp(24))

        except Exception: pass


class _OnAvatarClickReplacement(MethodReplacement):
    def __init__(self, plugin):
        self.plugin = plugin

    def replace_hooked_method(self, param):
        if not self.plugin.get_setting("enabled", True):
            return False
        try:
            this = param.thisObject  
            parent = get_private_field(this, "parentFragment")  
            if parent and should_center(parent):
                headerItem = get_private_field(parent, "headerItem")
                if headerItem:
                    headerItem.toggleSubMenu()
                    return True
            return False
        except Exception: 
            return False


class _UnreadBadgeHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def after_hooked_method(self, param):
        mode = _safe_int(self.plugin.get_setting("counter_mode", 0))
        if mode == 0:
            return

        try:
            chat_activity = param.thisObject
            action_bar = chat_activity.getActionBar()
            if action_bar is None:
                return
            back_button = getattr(action_bar, 'backButtonImageView', None)
            if back_button is None:
                try:
                    back_button = action_bar.getBackButton()
                except Exception:
                    back_button = None
            if back_button is None:
                return

            account = _safe_int(chat_activity.getCurrentAccount())
            messages_controller = chat_activity.getMessagesController()
            
            unread_count = 0
            if mode in (5, 6):
                dialog_id = 0
                try:
                    if hasattr(chat_activity, "getDialogId"):
                        dialog_id = _safe_int(chat_activity.getDialogId())
                except Exception:
                    pass
                if messages_controller and dialog_id != 0:
                    try:
                        if hasattr(messages_controller, "dialogs_dict"):
                            d_dict = messages_controller.dialogs_dict
                            if d_dict:
                                dialog = d_dict.get(dialog_id)
                                if dialog and hasattr(dialog, "unread_count"):
                                    unread_count = _safe_int(dialog.unread_count)
                    except Exception:
                        pass
                    if unread_count <= 0:
                        try:
                            for attr_name in ["dialogs", "allDialogs"]:
                                if hasattr(messages_controller, attr_name):
                                    dialogs_list = getattr(messages_controller, attr_name)
                                    if dialogs_list:
                                        size = dialogs_list.size() if hasattr(dialogs_list, "size") else len(dialogs_list)
                                        for i in range(size):
                                            d = dialogs_list.get(i) if hasattr(dialogs_list, "get") else dialogs_list[i]
                                            if d and hasattr(d, "id") and _safe_int(d.id) == dialog_id:
                                                if hasattr(d, "unread_count"):
                                                    unread_count = _safe_int(d.unread_count)
                                                    break
                        except Exception:
                            pass
            elif mode in (3, 4):
                if messages_controller:
                    for attr_name in ["dialogs", "allDialogs"]:
                        if hasattr(messages_controller, attr_name):
                            dialogs_list = getattr(messages_controller, attr_name)
                            if dialogs_list:
                                try:
                                    size = dialogs_list.size() if hasattr(dialogs_list, "size") else len(dialogs_list)
                                    for i in range(size):
                                        dialog = dialogs_list.get(i) if hasattr(dialogs_list, "get") else dialogs_list[i]
                                        if dialog and hasattr(dialog, "unread_count"):
                                            unread_count += _safe_int(dialog.unread_count)
                                except Exception:
                                    pass
                    if unread_count <= 0 and hasattr(messages_controller, "dialogs_dict"):
                        d_dict = messages_controller.dialogs_dict
                        if d_dict:
                            try:
                                size = d_dict.size()
                                for i in range(size):
                                    dialog = d_dict.valueAt(i)
                                    if dialog and hasattr(dialog, "unread_count"):
                                        unread_count += _safe_int(dialog.unread_count)
                            except Exception:
                                pass
                if unread_count <= 0:
                    try:
                        MessagesStorage = find_class("org.telegram.messenger.MessagesStorage")
                        if MessagesStorage:
                            storage_inst = MessagesStorage.getInstance(account)
                            if hasattr(storage_inst, "getMainUnreadCount"):
                                unread_count = _safe_int(storage_inst.getMainUnreadCount())
                    except Exception:
                        pass
            else:
                if messages_controller:
                    for m_name in ["getTotalUnreadCount", "getUnreadDialogsCount"]:
                        if hasattr(messages_controller, m_name):
                            val = getattr(messages_controller, m_name)()
                            if val is not None:
                                unread_count = _safe_int(val)
                                if unread_count > 0:
                                    break
                    if unread_count <= 0 and hasattr(messages_controller, "totalUnreadCount"):
                        unread_count = _safe_int(messages_controller.totalUnreadCount)
                if unread_count <= 0:
                    try:
                        MessagesStorage = find_class("org.telegram.messenger.MessagesStorage")
                        if MessagesStorage:
                            storage_inst = MessagesStorage.getInstance(account)
                            if hasattr(storage_inst, "getMainUnreadCount"):
                                unread_count = _safe_int(storage_inst.getMainUnreadCount())
                    except Exception:
                        pass

            if getattr(self.plugin, "current_back_button", None) != back_button:
                self._hook_back_button(back_button, action_bar)
                self.plugin.current_back_button = back_button

            self.plugin.unread_count = unread_count
            try:
                back_button.invalidate()
            except Exception:
                pass
        except Exception:
            pass

    def _hook_back_button(self, back_button, action_bar):
        try:
            back_button_class = back_button.getClass()
            Canvas = find_class("android.graphics.Canvas")
            if not Canvas: return
            on_draw_method = back_button_class.getDeclaredMethod("onDraw", Canvas)
            on_draw_method.setAccessible(True)
            draw_hook = _BackButtonDrawHook(self.plugin, action_bar)
            self.plugin.hook_back_button_draw_ref = self.plugin.hook_method(on_draw_method, draw_hook)
        except Exception:
            pass


class _BackButtonDrawHook(MethodHook):
    def __init__(self, plugin, action_bar):
        self.plugin = plugin
        self.action_bar = action_bar
        RectF = find_class("android.graphics.RectF")
        self.rect = RectF() if RectF else None

    def after_hooked_method(self, param):
        mode = _safe_int(self.plugin.get_setting("counter_mode", 0))
        if mode == 0:
            return

        try:
            current_view = param.thisObject
            if current_view != getattr(self.plugin, "current_back_button", None):
                return
            canvas = param.args[0]
            if canvas is None or getattr(self.plugin, "unread_count", 0) <= 0:
                return
            try:
                parent_view = current_view.getParent()
                while parent_view is not None:
                    if parent_view.getClass().getSimpleName() == "ActionBar":
                        if parent_view.isActionModeShowed():
                            return
                        break
                    parent_view = parent_view.getParent()
            except Exception:
                pass

            Theme = find_class("org.telegram.ui.ActionBar.Theme")
            AndroidUtilities = find_class("org.telegram.messenger.AndroidUtilities")
            if not Theme or not AndroidUtilities:
                return

            paint = getattr(Theme, "dialogs_countPaint", None)
            text_paint = getattr(Theme, "dialogs_countTextPaint", None)
            if not paint or not text_paint:
                return

            count_val = getattr(self.plugin, "unread_count", 0)
            
            unlimited_active = mode in (2, 4, 6)
            if unlimited_active:
                count_text = str(count_val)
            else:
                count_text = "99+" if count_val > 99 else str(count_val)

            original_text_size = text_paint.getTextSize()
            try:
                text_width = int(text_paint.measureText(count_text))
                max_badge_width = current_view.getMeasuredWidth() - AndroidUtilities.dp(4)
                desired_text_width = max_badge_width - AndroidUtilities.dp(8)
                
                if text_width > desired_text_width and desired_text_width > 0:
                    new_size = original_text_size * (desired_text_width / text_width)
                    text_paint.setTextSize(new_size)
                    text_width = int(text_paint.measureText(count_text))

                badge_width = max(AndroidUtilities.dp(18), text_width + AndroidUtilities.dp(8))
                badge_height = AndroidUtilities.dp(18)
                badge_left = current_view.getMeasuredWidth() - badge_width - AndroidUtilities.dp(4)
                badge_top = AndroidUtilities.dp(8)

                if self.rect:
                    self.rect.set(badge_left, badge_top, badge_left + badge_width, badge_top + badge_height)
                    canvas.drawRoundRect(self.rect, AndroidUtilities.dp(9), AndroidUtilities.dp(9), paint)

                text_x = badge_left + (badge_width - text_width) / 2
                text_y = badge_top + AndroidUtilities.dp(13)
                canvas.drawText(count_text, text_x, text_y, text_paint)
            finally:
                text_paint.setTextSize(original_text_size)
        except Exception:
            pass


class _ChatActivityCreateViewHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def after_hooked_method(self, param):
        try:
            this = param.thisObject
            if not self.plugin.get_setting("enabled", True):
                return

            if not should_center(this):
                return
            
            avatarContainer = get_private_field(this, "avatarContainer")
            if avatarContainer:
                lp = avatarContainer.getLayoutParams()
                if lp:
                    lp.rightMargin = 0
                    avatarContainer.setLayoutParams(lp)
        except Exception: pass


def _get_java_class(class_name):
    try:
        return Class.forName(class_name)
    except Exception:
        return find_class(class_name)


class CenteredHeaderPlugin(BasePlugin):
    def __init__(self):
        super().__init__()
        self.current_back_button = None
        self.unread_count = 0
        self.hook_back_button_draw_ref = None

    def _get_counter_mode(self):
        if self.get_setting("navbar_counter", False): return 1
        if self.get_setting("navbar_unlimited", False): return 2
        if self.get_setting("factual_counter", False): return 3
        if self.get_setting("factual_unlimited", False): return 4
        if self.get_setting("chat_counter", False): return 5
        if self.get_setting("chat_unlimited", False): return 6
        return 0

    def on_plugin_load(self):
        ChatAvatarContainer = _get_java_class("org.telegram.ui.Components.ChatAvatarContainer")
        if ChatAvatarContainer:
            self.hook_all_constructors(ChatAvatarContainer, _CtorHook(self), priority=50)
            self.hook_all_methods(ChatAvatarContainer, "setTitle", _SetTitleHook(self), priority=50)
            self.hook_all_methods(ChatAvatarContainer, "setTopic", _SetTitleHook(self), priority=50)
            self.hook_all_methods(ChatAvatarContainer, "setSubtitle", _SetTitleHook(self), priority=50)
            self.hook_all_methods(ChatAvatarContainer, "updateSubtitle", _UpdateSubtitleHook(self), priority=50)
            self.hook_all_methods(ChatAvatarContainer, "onMeasure", _OnMeasureHook(self), priority=50)
            self.hook_all_methods(ChatAvatarContainer, "onLayout", _OnLayoutHook(self), priority=50)
            self.hook_all_methods(ChatAvatarContainer, "onAvatarClick", _OnAvatarClickReplacement(self), priority=100)

        ChatActivity = _get_java_class("org.telegram.ui.ChatActivity")
        if ChatActivity:
            self.hook_all_methods(ChatActivity, "createView", _ChatActivityCreateViewHook(self), priority=50)
            
            badge_hook = _UnreadBadgeHook(self)
            for method_name in ["onResume", "onStart", "onBecomeFullyVisible", "updateTitle", "updateSubtitle"]:
                try:
                    self.hook_all_methods(ChatActivity, method_name, badge_hook, priority=50)
                except Exception:
                    pass

        if self.get_setting("counter_mode", None) is None:
            self.set_setting("counter_mode", self._get_counter_mode())

    def create_settings(self):
        lang = Locale.getDefault().getLanguage()
        current_mode = _safe_int(self.get_setting("counter_mode", 0))
        
        if lang.startswith("ru"):
            return [
                Header(text="Настройки Nagram XF Centered Header"),
                Switch(key="scrolling_enabled", text="Бегущая строка", default=True),
                Selector(
                    key="counter_mode",
                    text="Счетчик уведомлений",
                    items=["Откл", "Навбар", "Навбар неогр", "Фактически", "Фактически неогр", "В текущем чате", "В текущем чате неогр"],
                    default=current_mode
                ),
                Divider(text="Обычный — до 99, неогр — бесконечно"),
                Divider(text="Версия: 1.0.6")
            ]
        return [
            Header(text="Centered Header Settings"),
            Switch(key="scrolling_enabled", text="Marquee text", default=True),
            Selector(
                key="counter_mode",
                text="Notification Counter",
                items=["Off", "Navbar", "Navbar Unlimited", "Factual", "Factual Unlimited", "Current Chat", "Current Chat Unlimited"],
                default=current_mode
            ),
            Divider(text="Normal — up to 99, unlimited — no limit"),
