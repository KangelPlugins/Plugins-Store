# ─────────────────────────────────────────────────────────────
# Self-Test Diagnostic System
# ─────────────────────────────────────────────────────────────

SELFTEST_TIMEOUT = 300
PERSISTENCE_CHECKPOINT_FILE = "utilities_pro_persistence_checkpoint.json"
VERIFIED_STATUS_FILE = "utilities_pro_verified_status.json"

_self_test = None
_peer_info_saver_ok = False


def _load_verified_status():
    try:
        d = get_backup_dir()
        path = os.path.join(d, VERIFIED_STATUS_FILE)
        if os.path.isfile(path):
            with open(path, "r") as f:
                return json.load(f)
    except Exception:
        logger.error("Failed to load verified status:", exc_info=True)
    return {}


def _save_verified_status(status):
    try:
        d = get_backup_dir()
        os.makedirs(d, exist_ok=True)
        path = os.path.join(d, VERIFIED_STATUS_FILE)
        with open(path, "w") as f:
            json.dump(status, f, indent=2)
    except Exception:
        logger.error("Failed to save verified status:", exc_info=True)


def _check_storage_verified():
    status = _load_verified_status()
    if not status.get("storage_verified"):
        return False
    try:
        if status.get("plugin_version") != __version__:
            return False
        di = _collect_device_info()
        if status.get("telegram_build") != di.get("telegram_build"):
            return False
        if status.get("sdk_int") != di.get("sdk_int"):
            return False
    except Exception:
        return False
    return True


def _generate_report_id():
    ts = datetime.now().strftime("%Y%m%d-%H%M%S")
    h = hashlib.sha256(ts.encode()).hexdigest()[:8].upper()
    return f"{ts}-{h}"


def _collect_device_info():
    info = {"plugin_version": __version__}
    try:
        from android.os import Build
        info["device_manufacturer"] = str(Build.MANUFACTURER)
        info["device_model"] = str(Build.MODEL)
        info["sdk_int"] = int(str(Build.VERSION.SDK_INT))
        abis = list(Build.SUPPORTED_ABIS) if hasattr(Build, "SUPPORTED_ABIS") else [str(Build.CPU_ABI)]
        info["abis"] = abis
    except Exception:
        pass
    try:
        from org.telegram.messenger import BuildVars
        info["telegram_version"] = str(getattr(BuildVars, "BUILD_VERSION_STRING", ""))
        info["telegram_build"] = str(getattr(BuildVars, "BUILD_VERSION", ""))
    except Exception:
        pass
    return info


class SelfTestContext:
    def __init__(self, quick=True):
        self.quick = quick
        self.started_at = datetime.now().isoformat(timespec="seconds")
        self.phases = {}
        self.cancelled = False
        self.hooks_status = {}
        self.storage_status = {}
        self.profile_count = 0
        self.sorted_dialog_ids = []
        self.profile_sha256 = ""
        self.corrupt_ids = []
        self.live = {
            "updateRowsInternal": False,
            "getPeerSettings": False,
            "resolve_peer_settings": False,
            "merge": False,
            "has_precious": False,
            "onBindViewHolder": False,
        }
        self.live_reasons = {}
        self.bind_dialog_id = False
        self.persistence = None
        self.persistence_reasons = []
        self.display = None
        self.device_info = {}
        self.report_path = None
        self.report_id = None
        self.timeout_timer = None


class SelfTestUpdateRowsHook(MethodHook):
    def before_hooked_method(self, param):
        if _self_test is None:
            return
        try:
            _self_test.live["updateRowsInternal"] = True
        except Exception:
            pass


def self_test_show_diagnostics_options():
    verified = _check_storage_verified()
    lines = [
        "Выберите режим диагностики:",
        "",
        "Быстрая (~5 с) — проверка хуков,",
        "цепочки загрузки и отображения.",
        "" if verified else "⚠ Включает полную проверку хранилища.",
    ]
    if verified:
        lines.append("Хранилище уже проверено — полная проверка не требуется.")

    def run_quick():
        self_test_start(quick=True)

    def run_extended():
        self_test_start(quick=False)

    buttons = [
        ("positive", "Быстрая", lambda _, __: run_quick()),
    ]
    if not verified:
        buttons.append(("neutral", "Полная (~30 с)", lambda _, __: run_extended()))
    else:
        buttons.append(("neutral", "Полная (~30 с)", lambda _, __: run_extended()))

    run_ui(lambda: show_alert(
        "Диагностика",
        "\n".join(lines),
        buttons=buttons + [("negative", "Отмена", lambda _, __: None)],
        cancelable=True,
    ))


def self_test_start(quick=True):
    global _self_test
    if _self_test is not None:
        return
    try:
        ctx = SelfTestContext(quick=quick)
        _self_test = ctx
        ctx.phases["phase1"] = {"started_at": datetime.now().isoformat(timespec="seconds")}
        ctx.device_info = _collect_device_info()
        self_test_phase1(ctx)
        p1 = ctx.phases["phase1"]
        p1["finished_at"] = datetime.now().isoformat(timespec="seconds")
        d1 = datetime.fromisoformat(p1["started_at"])
        d2 = datetime.fromisoformat(p1["finished_at"])
        p1["duration_ms"] = int((d2 - d1).total_seconds() * 1000)
        show_self_test_live_prompt(ctx)
    except Exception:
        logger.error("Self-test failed:", exc_info=True)
        _self_test = None
        notify_error("Диагностика прервана из-за ошибки")


def self_test_phase1(ctx):
    mc = ensure_messages_controller_class()
    ctx.hooks_status["MessagesController"] = "PASS" if mc else "FAIL"
    if not mc:
        ctx.live_reasons["MessagesController"] = "Класс MessagesController не найден"
    ctx.hooks_status["getPeerSettings"] = "PASS" if _peer_info_saver_ok else "FAIL"
    ctx.hooks_status["savePeerSettings"] = "PASS" if _peer_info_saver_ok else "FAIL"
    try:
        back_dir = get_backup_dir()
        ctx.storage_status["directory"] = "PASS" if os.path.isdir(back_dir) else "FAIL"
        if not os.path.isdir(back_dir):
            ctx.live_reasons["storage_directory"] = f"Директория не существует: {back_dir}"
        peer_storage.ensure_loaded()
        sp = peer_storage.path()
        ctx.storage_status["file_exists"] = "PASS" if (sp and os.path.isfile(sp)) else "FAIL"
        if not sp or not os.path.isfile(sp):
            ctx.live_reasons["storage_file"] = "Файл хранилища не найден"
        if ctx.quick and _check_storage_verified():
            ctx.storage_status["write_temp"] = "SKIP"
            ctx.storage_status["read_temp"] = "SKIP"
            ctx.storage_status["cleanup"] = "SKIP"
        else:
            try:
                test_key = "999999999999"
                test_val = {"test": datetime.now().isoformat()}
                with peer_storage._lock:
                    peer_storage.content[test_key] = test_val
                w_ok = peer_storage.write()
                if w_ok and peer_storage.content.get(test_key) == test_val:
                    ctx.storage_status["write_temp"] = "PASS"
                else:
                    ctx.storage_status["write_temp"] = "FAIL"
                    ctx.live_reasons["write_temp"] = "Не удалось записать тестовую запись"
                peer_storage.read()
                read_val = peer_storage.content.get(test_key)
                if read_val == test_val:
                    ctx.storage_status["read_temp"] = "PASS"
                else:
                    ctx.storage_status["read_temp"] = "FAIL"
                    ctx.live_reasons["read_temp"] = "Тестовая запись не совпадает после чтения"
                with peer_storage._lock:
                    if test_key in peer_storage.content:
                        del peer_storage.content[test_key]
                cleanup_ok = peer_storage.write()
                if not cleanup_ok:
                    logger.error("Failed to save peer settings for dialog %s", test_key, exc_info=True)
                ctx.storage_status["cleanup"] = "PASS" if cleanup_ok else "FAIL"
            except Exception as e:
                ctx.storage_status["write_temp"] = "FAIL"
                ctx.storage_status.setdefault("read_temp", "FAIL")
                ctx.storage_status.setdefault("cleanup", "FAIL")
                ctx.live_reasons["storage_write_test"] = str(e)
    except Exception as e:
        for k in ("directory", "file_exists", "write_temp", "read_temp", "cleanup"):
            ctx.storage_status.setdefault(k, "FAIL")
        ctx.live_reasons["storage_check"] = str(e)
    raw = {}
    try:
        peer_storage.ensure_loaded()
        raw = normalize_peer_dump(peer_storage.content)
        ctx.profile_count = len(raw)
        ctx.sorted_dialog_ids = sorted(raw.keys(), key=int)
        ctx.profile_sha256 = hashlib.sha256(
            json.dumps(raw, sort_keys=True, ensure_ascii=False).encode('utf-8')
        ).hexdigest()
    except Exception:
        ctx.profile_count = -1
        ctx.sorted_dialog_ids = []
        ctx.profile_sha256 = ""
    corrupt = []
    try:
        for did, rec in raw.items():
            if not isinstance(rec, dict):
                corrupt.append(did)
                continue
            if rec.get("registration_month") is None and rec.get("phone_country") is None:
                if not is_meaningful_peer_dump(rec):
                    corrupt.append(did)
    except Exception:
        pass
    ctx.corrupt_ids = corrupt


def show_self_test_live_prompt(ctx):
    lines = ["═ Фаза 1: Самодиагностика ═\n"]
    lines.append("Хуки:")
    for name, st in sorted(ctx.hooks_status.items()):
        m = "✓" if st == "PASS" else "✗"
        lines.append(f"  {m} {name}: {st}")
    lines.append("")
    lines.append("Хранилище:")
    for name, st in sorted(ctx.storage_status.items()):
        if st == "PASS":
            m = "✓"
        elif st == "SKIP":
            m = "➖"
        else:
            m = "✗"
        lines.append(f"  {m} {name}: {st}")
    lines.append("")
    lines.append(f"Сохранено профилей: {ctx.profile_count}")
    if ctx.corrupt_ids:
        lines.append(f"Повреждено записей: {len(ctx.corrupt_ids)}")
        for cid in ctx.corrupt_ids[:5]:
            lines.append(f"  {cid}")
    lines.append("")
    lines.append("═ Фаза 2: Проверка цепочки ═")
    lines.append("")
    lines.append("Откройте любой чат с сохранёнными данными.")
    lines.append("Плагин автоматически проверит всю цепочку.")

    def on_cancel():
        global _self_test
        ctx = _self_test
        if ctx:
            ctx.cancelled = True
            if ctx.timeout_timer:
                try:
                    ctx.timeout_timer.cancel()
                except Exception:
                    pass
            ctx.phases["live"] = {"status": "NOT_PERFORMED", "reason": "Отменено пользователем"}
            self_test_generate_report(ctx)
            self_test_show_result(ctx)
        _self_test = None

    try:
        ctx.timeout_timer = threading.Timer(SELFTEST_TIMEOUT, lambda: self_test_timeout(ctx))
        ctx.timeout_timer.daemon = True
        ctx.timeout_timer.start()
    except Exception:
        logger.error("Failed to start self-test timeout timer:", exc_info=True)

    run_ui(lambda: show_alert(
        "Диагностика",
        "\n".join(lines),
        buttons=[("negative", "Отмена", lambda _, __: on_cancel())],
        cancelable=True,
    ))


def self_test_timeout(ctx):
    if ctx is None or ctx.cancelled:
        return
    try:
        ctx.live_reasons["timeout"] = "Истекло время ожидания: чат не был открыт"
        run_ui(lambda: self_test_finish_live())
    except Exception:
        logger.error("Self-test timeout UI dispatch failed:", exc_info=True)


def self_test_on_bind(dialog_id):
    ctx = _self_test
    if ctx is None or ctx.cancelled:
        return
    ctx.live["onBindViewHolder"] = True
    ctx.bind_dialog_id = dialog_id
    if ctx.timeout_timer:
        try:
            ctx.timeout_timer.cancel()
        except Exception:
            pass
    if not ctx.live["getPeerSettings"]:
        ctx.live_reasons["getPeerSettings"] = "Хук getPeerSettings не сработал"
    if not ctx.live["resolve_peer_settings"]:
        ctx.live_reasons["resolve_peer_settings"] = "resolve_peer_settings не была вызвана"
    if not ctx.live["merge"]:
        ctx.live_reasons["merge"] = "Слияние сохранённых данных не выполнено"
    if not ctx.live["updateRowsInternal"]:
        ctx.live_reasons["updateRowsInternal"] = "Хук updateRowsInternal не сработал"
    run_ui(self_test_finish_live)


def self_test_finish_live():
    global _self_test
    ctx = _self_test
    if ctx is None or ctx.cancelled:
        return
    ctx.phases["live"] = {
        "started_at": "",
        "finished_at": datetime.now().isoformat(timespec="seconds"),
    }
    if not ctx.live["onBindViewHolder"]:
        live_pass = all(v for k, v in ctx.live.items() if k != "has_precious")
        ctx.phases["live"]["status"] = "FAIL" if not live_pass else "PASS"
        ctx.phases["live"]["reason"] = ctx.live_reasons.get("timeout", "Чат не был открыт")
        self_test_show_persistence_prompt(ctx)
        return
    live_pass = all(v for k, v in ctx.live.items() if k != "has_precious")
    ctx.phases["live"]["status"] = "PASS" if live_pass else "FAIL"
    issues = [ctx.live_reasons[k] for k in ctx.live if not ctx.live[k] and k in ctx.live_reasons]
    ctx.phases["live"]["reason"] = "; ".join(issues) if issues else ""
    self_test_show_persistence_prompt(ctx)


def self_test_show_persistence_prompt(ctx):
    checkpoint_path = _write_checkpoint(ctx)
    lines = ["═ Фаза 2: Цепочка загрузки ═\n"]
    lines.append(f"Результат: {ctx.phases['live'].get('status', 'UNKNOWN')}")
    rsn = ctx.phases["live"].get("reason", "")
    if rsn:
        lines.append(f"Подробности: {rsn}")
    lines.append("")
    lines.append("═ Фаза 3: Проверка сохранения ═")
    lines.append("")
    lines.append("Для полной проверки:")
    lines.append("1. Нажмите «Продолжить»")
    lines.append("2. Перезапустите Telegram")
    lines.append("3. Откройте Настройки → UtilitiesPro")
    lines.append("4. Нажмите «Продолжить проверку»")
    if checkpoint_path:
        lines.append("")
        lines.append("✓ Контрольная точка сохранена.")

    def on_continue():
        dismiss_active_dialogs()
        notify_info("Перезапустите Telegram и откройте настройки плагина")

    def on_later():
        global _self_test
        _self_test = None
        dismiss_active_dialogs()
        notify_info("Контрольная точка сохранена. Перезапустите Telegram для продолжения.")

    def on_stop():
        global _self_test
        ctx = _self_test
        if ctx:
            ctx.cancelled = True
            _clear_checkpoint()
            self_test_generate_report(ctx)
            self_test_show_result(ctx)
        _self_test = None

    run_ui(lambda: show_alert(
        "Диагностика",
        "\n".join(lines),
        buttons=[
            ("positive", "Продолжить", lambda _, __: on_continue()),
            ("neutral", "Позже", lambda _, __: on_later()),
            ("negative", "Завершить", lambda _, __: on_stop()),
        ],
        cancelable=True,
    ))


def _write_checkpoint(ctx):
    try:
        d = get_backup_dir()
        os.makedirs(d, exist_ok=True)
        peer_storage.ensure_loaded()
        raw = normalize_peer_dump(peer_storage.content)
        sample = None
        for did, rec in sorted(raw.items()):
            sample = {"dialog_id": did, "fields": dict(rec)}
            break
        raw_json = json.dumps(raw, sort_keys=True)
        storage_hash = str(zlib.adler32(raw_json.encode()))
        checkpoint = {
            "stage": "live_complete",
            "plugin_version": __version__,
            "device_info": ctx.device_info,
            "hooks_status": ctx.hooks_status,
            "storage_status": ctx.storage_status,
            "profile_count": ctx.profile_count,
            "sorted_dialog_ids": ctx.sorted_dialog_ids,
            "profile_sha256": ctx.profile_sha256,
            "corrupt_ids": ctx.corrupt_ids,
            "live": dict(ctx.live),
            "live_reasons": dict(ctx.live_reasons),
            "bind_dialog_id": ctx.bind_dialog_id,
            "phase1_timings": ctx.phases.get("phase1", {}),
            "live_timings": ctx.phases.get("live", {}),
            "persistence_checkpoint": {
                "profile_count": len(raw),
                "storage_hash": storage_hash,
                "sample_record": sample,
            },
            "created_at": datetime.now().isoformat(),
        }
        path = os.path.join(d, PERSISTENCE_CHECKPOINT_FILE)
        peer_storage._diag.trace_event("CHECKPOINT_WRITE_BEGIN", path=path, extra_info=f"profile_count={len(raw)} storage_hash={storage_hash}")
        with open(path, "w", encoding="utf-8") as f:
            json.dump(checkpoint, f, ensure_ascii=False, indent=2)
        peer_storage._diag.trace_event("CHECKPOINT_WRITE_END", path=path)
        return path
    except Exception:
        logger.error("Failed to write checkpoint:", exc_info=True)
        peer_storage._diag.trace_event("CHECKPOINT_WRITE_END", path=os.path.join(get_backup_dir(), PERSISTENCE_CHECKPOINT_FILE), extra_info="FAILED: exception")
        return None


def _load_checkpoint():
    try:
        d = get_backup_dir()
        path = os.path.join(d, PERSISTENCE_CHECKPOINT_FILE)
        if os.path.isfile(path):
            peer_storage._diag.trace_event("CHECKPOINT_READ_BEGIN", path=path)
            with open(path, "r", encoding="utf-8") as f:
                data = json.load(f)
            peer_storage._diag.trace_event("CHECKPOINT_READ_END", path=path, extra_info=f"stage={data.get('stage', 'unknown')}")
            return data
    except Exception:
        peer_storage._diag.trace_event("CHECKPOINT_READ_END", path=os.path.join(get_backup_dir(), PERSISTENCE_CHECKPOINT_FILE), extra_info="FAILED: exception")
        logger.error("Failed to load checkpoint:", exc_info=True)
    return None


def _clear_checkpoint():
    try:
        d = get_backup_dir()
        path = os.path.join(d, PERSISTENCE_CHECKPOINT_FILE)
        if os.path.isfile(path):
            peer_storage._diag.trace_event("CHECKPOINT_CLEAR", path=path)
            os.remove(path)
    except Exception:
        logger.error("Failed to clear checkpoint:", exc_info=True)


def _diagnostics_continue_entries():
    try:
        cp = _load_checkpoint()
        if cp and cp.get("stage") == "live_complete":
            return [Text(
                text="Продолжить проверку сохранения",
                subtext="Найдена незавершённая проверка. Нажмите для продолжения.",
                icon="msg_stats",
                accent=True,
                on_click=lambda _: self_test_continue_persistence(),
            )]
    except Exception:
        logger.error("Failed to get continue entries:", exc_info=True)
    return []


def self_test_continue_persistence():
    global _self_test
    checkpoint = _load_checkpoint()
    if not checkpoint or checkpoint.get("stage") != "live_complete":
        notify_info("Не найдено незавершённых проверок")
        return
    try:
        ctx = SelfTestContext()
        ctx.started_at = checkpoint.get("created_at", datetime.now().isoformat())
        ctx.device_info = checkpoint.get("device_info", {})
        ctx.hooks_status = checkpoint.get("hooks_status", {})
        ctx.storage_status = checkpoint.get("storage_status", {})
        ctx.profile_count = checkpoint.get("profile_count", -1)
        ctx.sorted_dialog_ids = checkpoint.get("sorted_dialog_ids", [])
        ctx.profile_sha256 = checkpoint.get("profile_sha256", "")
        ctx.corrupt_ids = checkpoint.get("corrupt_ids", [])
        ctx.live = checkpoint.get("live", {k: False for k in ctx.live})
        ctx.live_reasons = checkpoint.get("live_reasons", {})
        ctx.bind_dialog_id = checkpoint.get("bind_dialog_id", False)
        ctx.phases["phase1"] = checkpoint.get("phase1_timings", {})
        ctx.phases["live"] = checkpoint.get("live_timings", {})
        _self_test = ctx

        pers_check = checkpoint.get("persistence_checkpoint", {})
        peer_storage._diag.trace_event("PERSISTENCE_CHECK_BEGIN", path=peer_storage.path(), extra_info=f"saved_count={pers_check.get('profile_count', -1)} saved_hash={pers_check.get('storage_hash', '')}")
        peer_storage.ensure_loaded()
        raw = normalize_peer_dump(peer_storage.content)
        current_count = len(raw)
        current_raw_json = json.dumps(raw, sort_keys=True)
        current_hash = str(zlib.adler32(current_raw_json.encode()))
        saved_count = pers_check.get("profile_count", -1)
        saved_hash = pers_check.get("storage_hash", "")
        saved_sample = pers_check.get("sample_record", {})
        issues = []
        pers_pass = True

        if current_count == saved_count:
            count_check = "PASS"
        else:
            count_check = "FAIL"
            pers_pass = False
            issues.append(f"Количество профилей: было {saved_count}, стало {current_count}")

        if current_hash == saved_hash:
            hash_check = "PASS"
        else:
            hash_check = "FAIL"
            pers_pass = False
            issues.append("Хеш хранилища изменился после перезапуска")

        sample_check = "SKIP"
        if saved_sample and saved_sample.get("dialog_id"):
            sample_did = str(saved_sample["dialog_id"])
            sample_fields = saved_sample.get("fields", {})
            current_record = raw.get(sample_did)
            if current_record:
                field_ok = all(current_record.get(k) == v for k, v in sample_fields.items())
                if field_ok and len(current_record) == len(sample_fields):
                    sample_check = "PASS"
                else:
                    sample_check = "FAIL"
                    pers_pass = False
                    for k, v in sample_fields.items():
                        cv = current_record.get(k)
                        if cv != v:
                            issues.append(f"Поле '{k}' в записи {sample_did}: было '{v}', стало '{cv}'")
            else:
                sample_check = "FAIL"
                pers_pass = False
                issues.append(f"Запись {sample_did} не найдена после перезапуска")

        peer_storage._diag.trace_event("PERSISTENCE_CHECK_END", path=peer_storage.path(), extra_info=f"count_check={count_check} hash_check={hash_check} sample_check={sample_check} pers_pass={pers_pass}")
        ctx.persistence = "PASS" if pers_pass else "FAIL"
        ctx.persistence_reasons = issues
        ctx.phases["persistence"] = {
            "started_at": "",
            "finished_at": datetime.now().isoformat(timespec="seconds"),
            "status": ctx.persistence,
            "reason": "; ".join(issues) if issues else "",
            "details": {
                "count_check": count_check,
                "hash_check": hash_check,
                "sample_check": sample_check,
            },
        }
        ctx.display = "PASS" if ctx.live.get("onBindViewHolder") else "FAIL"
        ctx.cancelled = False
        _clear_checkpoint()
        self_test_generate_report(ctx)
        self_test_show_result(ctx)
        _self_test = None
    except Exception:
        logger.error("Persistence stage 2 failed:", exc_info=True)
        _self_test = None
        notify_error("Ошибка проверки сохранения")


def _compute_shared_verdict_state(ctx):
    hook_pass = all(v == "PASS" for v in ctx.hooks_status.values())
    stor_pass = all(v in ("PASS", "SKIP") for v in ctx.storage_status.values())
    live_status = ctx.phases.get("live", {}).get("status", "NOT_PERFORMED")
    live_pass = live_status == "PASS"
    pers_status = ctx.phases.get("persistence", {}).get("status", "NOT_PERFORMED")
    pers_pass = pers_status == "PASS"
    disp_pass = ctx.display == "PASS" if ctx.display else False
    pers_attempted = ctx.persistence is not None
    sm_failure = StorageStateMachine._first_failure
    sm_frozen = StorageStateMachine._frozen
    root_cause_user = None
    if sm_frozen and sm_failure:
        rc_map = {
            "WRITE_LAYER": "Ошибка записи хранилища. Данные могут не сохраниться на диск.",
            "READ_LAYER": "Ошибка чтения хранилища. Ранее сохранённые данные могут быть потеряны после перезапуска.",
            "POST_READ_OVERWRITE": "Данные хранилища были неожиданно изменены после загрузки.",
            "PATH_MISMATCH": "Обнаружено несоответствие пути хранилища.",
            "MULTIPLE_STORAGE_INSTANCES": "Обнаружено несколько экземпляров хранилища.",
            "HASH_MISMATCH_EMPTY_DIFF": "Проверка целостности хранилища не пройдена (несовпадение хеша).",
        }
        root_cause_user = rc_map.get(sm_failure["root_cause"],
            f"Нарушение инварианта хранилища: {sm_failure['root_cause']}")
    live_attempted = live_status != "NOT_PERFORMED"
    all_pass = hook_pass and stor_pass and live_pass and pers_pass and disp_pass and not ctx.corrupt_ids and not sm_frozen
    return {
        "hook_pass": hook_pass, "stor_pass": stor_pass, "live_pass": live_pass,
        "pers_pass": pers_pass, "disp_pass": disp_pass,
        "live_status": live_status, "pers_status": pers_status,
        "pers_attempted": pers_attempted, "live_attempted": live_attempted,
        "sm_frozen": sm_frozen, "sm_failure": sm_failure,
        "root_cause_user": root_cause_user, "all_pass": all_pass,
    }


def self_test_generate_report(ctx):
    try:
        d = get_backup_dir()
        os.makedirs(d, exist_ok=True)
        now_ts = datetime.now().isoformat(timespec="seconds")
        ctx.phases.setdefault("phase1", {})
        ctx.phases.setdefault("live", {"status": "NOT_PERFORMED"})
        ctx.phases.setdefault("persistence", {"status": "NOT_PERFORMED"})

        vs = _compute_shared_verdict_state(ctx)
        hook_pass = vs["hook_pass"]
        stor_pass = vs["stor_pass"]
        live_pass = vs["live_pass"]
        pers_pass = vs["pers_pass"]
        disp_pass = vs["disp_pass"]
        live_status = vs["live_status"]
        pers_status = vs["pers_status"]
        pers_attempted = vs["pers_attempted"]
        live_attempted = vs["live_attempted"]
        sm_frozen = vs["sm_frozen"]
        sm_failure = vs["sm_failure"]
        all_pass = vs["all_pass"]

        # StorageStateMachine verdict
        sm_conclusion = None
        if sm_failure:
            sm_conclusion = {
                "root_cause": sm_failure["root_cause"],
                "first_operation": sm_failure["first_operation"],
                "first_timestamp": sm_failure["first_timestamp"],
                "first_caller": sm_failure["first_caller"],
                "first_storage_instance": sm_failure["first_storage_instance"],
                "first_path": sm_failure["first_path"],
                "details": sm_failure["details"],
            }

        # Single snapshot of normalized content for all summary fields
        snapshot_raw = {}
        try:
            peer_storage.ensure_loaded()
            snapshot_raw = normalize_peer_dump(peer_storage.content)
        except Exception:
            logger.error("Failed to snapshot storage content:", exc_info=True)
        snapshot_profiles = len(snapshot_raw)
        snapshot_sorted_ids = sorted(snapshot_raw.keys(), key=int) if snapshot_profiles > 0 else []
        snapshot_sha = hashlib.sha256(
            json.dumps(snapshot_raw, sort_keys=True, ensure_ascii=False).encode('utf-8')
        ).hexdigest() if snapshot_raw else ""

        storage_path = ""
        storage_file_size = -1
        storage_file_mtime = 0.0
        storage_sha256 = ""
        try:
            storage_path = peer_storage.path()
            if os.path.exists(storage_path):
                storage_file_size = os.path.getsize(storage_path)
                storage_file_mtime = os.path.getmtime(storage_path)
            storage_sha256 = snapshot_sha
        except Exception:
            logger.error("Failed to stat storage file:", exc_info=True)

        issues = []
        if not hook_pass:
            issues.append("Некоторые хуки не зарегистрированы")
        if not stor_pass:
            issues.append("Проблемы с хранилищем")
        if sm_frozen:
            issues.append(f"STORAGE_STATE_MACHINE: {sm_failure['root_cause']}")
        if live_status == "NOT_PERFORMED":
            issues.append("Проверка цепочки не выполнена")
        elif not live_pass:
            r = ctx.phases["live"].get("reason", "")
            if r:
                issues.append(r)
        if ctx.persistence == "FAIL":
            issues.extend(ctx.persistence_reasons)
        if ctx.display == "FAIL":
            issues.append("onBindViewHolder не достигнут")
        if ctx.corrupt_ids:
            issues.append(f"Повреждено записей: {len(ctx.corrupt_ids)}")

        if all_pass:
            result = "PASS"
        elif not live_attempted and not pers_attempted:
            result = "INCOMPLETE"
        elif hook_pass and stor_pass and not live_attempted:
            result = "INCOMPLETE"
        else:
            result = "FAIL"

        phases_report = {}
        for pname in ("phase1", "live", "persistence"):
            pd = ctx.phases.get(pname, {})
            entry = {"status": pd.get("status", "NOT_PERFORMED")}
            for k in ("started_at", "finished_at", "duration_ms", "reason"):
                if pd.get(k):
                    entry[k] = pd[k]
            if pd.get("details"):
                entry["details"] = pd["details"]
            phases_report[pname] = entry

        pipeline = {k: "PASS" if v else "FAIL" for k, v in ctx.live.items()}
        for k, v in ctx.live_reasons.items():
            if k not in pipeline:
                pipeline[k + "_reason"] = v
            elif not ctx.live.get(k):
                pipeline[k + "_reason"] = v

        diag = {
            "result": result,
            "plugin_version": __version__,
            "telegram_version": ctx.device_info.get("telegram_version", ""),
            "telegram_build": ctx.device_info.get("telegram_build", ""),
            "sdk_int": ctx.device_info.get("sdk_int", -1),
            "android_sdk": ctx.device_info.get("sdk_int", -1),
            "abis": ctx.device_info.get("abis", []),
            "device_manufacturer": ctx.device_info.get("device_manufacturer", ""),
            "device_model": ctx.device_info.get("device_model", ""),
            "started_at": ctx.started_at,
            "finished_at": now_ts,
            "profiles": snapshot_profiles,
            "sorted_dialog_ids": snapshot_sorted_ids,
            "normalized_storage_sha256": snapshot_sha,
            "hooks": dict(ctx.hooks_status),
            "storage_status": dict(ctx.storage_status),
            "pipeline": pipeline,
            "persistence": ctx.persistence or "SKIP",
            "persistence_details": ctx.phases["persistence"].get("details", {}),
            "persistence_reasons": list(ctx.persistence_reasons),
            "display_boundary": ctx.display or "SKIP",
            "corrupt_records": list(ctx.corrupt_ids),
            "phases": phases_report,
            "reason": "; ".join(issues) if issues else "",
            # StorageStateMachine diagnostic
            "storage_diagnostic": sm_conclusion,
            "storage_sha256": storage_sha256,
            "storage_path": storage_path,
            "storage_file_path": storage_path,
            "storage_file_size": storage_file_size,
            "storage_file_mtime": storage_file_mtime,
        }
        if EXTENDED_DIAGNOSTIC:
            diag["read_trace"] = peer_storage.read_trace
        ts = datetime.now().strftime("%Y%m%d_%H%M%S")
        report_id = _generate_report_id()
        diag["report_id"] = report_id
        zname = f"utilities_pro_diagnostic_{ts}.zip"
        zpath = os.path.join(d, zname)
        with zipfile.ZipFile(zpath, "w", zipfile.ZIP_DEFLATED) as zf:
            zf.writestr("diagnostic.json", json.dumps(diag, ensure_ascii=False, indent=2))
            if EXTENDED_DIAGNOSTIC:
                trace_path = getattr(ctx, "_trace_path", None) or _diag_file_path
                if trace_path and os.path.isfile(trace_path):
                    zf.write(trace_path, "diag_trace.log")
        ctx.report_path = zpath
        ctx.report_id = report_id
        # Update verification status if PASS
        if result == "PASS":
            vstatus = _load_verified_status()
            plugin_v = vstatus.get("plugin_version", "")
            tg_build = vstatus.get("telegram_build", "")
            sdk = vstatus.get("sdk_int", -1)
            cur_tg = ctx.device_info.get("telegram_build", "")
            cur_sdk = ctx.device_info.get("sdk_int", -1)
            if plugin_v == __version__ and tg_build == cur_tg and sdk == cur_sdk:
                vstatus["pass_count"] = vstatus.get("pass_count", 0) + 1
            else:
                vstatus = {
                    "plugin_version": __version__,
                    "telegram_build": cur_tg,
                    "sdk_int": cur_sdk,
                    "pass_count": 1,
                    "storage_verified": False,
                }
            if vstatus.get("pass_count", 0) >= 3:
                vstatus["storage_verified"] = True
            vstatus["last_pass_timestamp"] = datetime.now().isoformat()
            _save_verified_status(vstatus)
        ctx.diag_data = diag
    except Exception:
        logger.error("Report generation failed:", exc_info=True)


def self_test_show_result(ctx):
    vs = _compute_shared_verdict_state(ctx)
    hook_pass = vs["hook_pass"]
    stor_pass = vs["stor_pass"]
    live_pass = vs["live_pass"]
    pers_pass = vs["pers_pass"]
    disp_pass = vs["disp_pass"]
    live_status = vs["live_status"]
    pers_attempted = vs["pers_attempted"]
    live_attempted = vs["live_attempted"]
    sm_frozen = vs["sm_frozen"]
    sm_failure = vs["sm_failure"]
    root_cause_user = vs["root_cause_user"]
    all_pass = vs["all_pass"]

    # Regression status lines
    reg_lines = []
    reg_lines.append("Статус:")
    reg_lines.append("")
    if not ctx.quick:
        if stor_pass and not sm_frozen:
            reg_lines.append("Хранилище     ✔ PASS")
        elif sm_frozen:
            reg_lines.append(f"Хранилище     ✗ FAIL — {root_cause_user}")
        else:
            reg_lines.append(f"Хранилище     ✗ FAIL")
    else:
        verified = _check_storage_verified()
        if verified:
            reg_lines.append("Хранилище     ✔ PASS (ранее верифицировано)")
        else:
            reg_lines.append("Хранилище     ⚠ SKIP (не верифицировано, требуется полная диагностика)")
    pipeline_ok = all(ctx.live.get(k) for k in ("updateRowsInternal", "getPeerSettings", "resolve_peer_settings", "merge"))
    if pipeline_ok:
        reg_lines.append("Цепочка       ✔ PASS")
    elif live_status == "NOT_PERFORMED":
        reg_lines.append("Цепочка       ⚠ Не проверено")
    else:
        reg_lines.append("Цепочка       ✗ FAIL")
    if pers_pass:
        reg_lines.append("Сохранение    ✔ PASS")
    elif pers_attempted:
        reg_lines.append("Сохранение    ✗ FAIL")
    else:
        reg_lines.append("Сохранение    ⚠ Не проверено")
    if disp_pass:
        reg_lines.append("Отображение   ✔ PASS")
    elif ctx.display == "FAIL":
        reg_lines.append("Отображение   ✗ FAIL")
    else:
        reg_lines.append("Отображение   ⚠ Не проверено")

    if all_pass:
        icon, verdict = "🟢", "PASS"
        user_title = "Всё работает корректно."
        detail = ""
    elif hook_pass and stor_pass and live_pass and not pers_attempted:
        icon, verdict = "🟡", "INCOMPLETE"
        user_title = "Live-тест пройден. Сохранение после перезапуска не проверено."
        detail = "Перезапустите Telegram для проверки сохранения."
    elif hook_pass and stor_pass and live_status == "NOT_PERFORMED" and not pers_attempted:
        icon, verdict = "🟡", "INCOMPLETE"
        user_title = "Live-тест не был завершён."
        detail = "Откройте чат с сохранёнными данными для продолжения."
    elif hook_pass and stor_pass and live_pass and pers_pass and ctx.corrupt_ids:
        icon, verdict = "🟡", "INCOMPLETE"
        user_title = f"Профили частично повреждены ({len(ctx.corrupt_ids)} записей)."
        detail = ""
    elif sm_frozen:
        icon, verdict = "🔴", "FAIL"
        user_title = root_cause_user or "Диагностика хранилища не пройдена."
        detail = ""
    else:
        icon, verdict = "🔴", "FAIL"
        issues_list = []
        if not hook_pass:
            issues_list.append("Хуки не зарегистрированы")
        if sm_frozen:
            issues_list.append(root_cause_user or "Диагностика хранилища не пройдена")
        elif not stor_pass:
            issues_list.append("Проверка хранилища не пройдена")
        if not live_pass and live_attempted:
            issues_list.append(ctx.phases.get("live", {}).get("reason", "Цепочка не пройдена"))
        if ctx.persistence == "FAIL":
            issues_list.extend(ctx.persistence_reasons)
        if ctx.display == "FAIL":
            issues_list.append("Привязка отображения не пройдена")
        user_title = "; ".join(issues_list[:3])
        detail = ""

    lines = [
        f"ВЕРДИКТ: {verdict} {icon}",
        "",
        user_title,
    ]
    if detail:
        lines.extend(["", detail])
    lines.extend(["", "─" * 30, ""])
    lines.extend(reg_lines)
    if ctx.report_id:
        lines.extend(["", "─" * 30, "", f"ID отчёта: {ctx.report_id}"])
    if ctx.report_path:
        lines.extend(["", "Отчёт:", ctx.report_path])

    def copy_report_id():
        if ctx.report_id:
            try:
                from android_utils import copy_to_clipboard
                copy_to_clipboard(ctx.report_id)
                notify_success("ID отчёта скопирован")
            except Exception:
                notify_error("Не удалось скопировать ID отчёта")

    def save_report():
        if ctx.report_path:
            notify_success(f"Отчёт:\n{ctx.report_path}")

    buttons = [
        ("positive", "Сохранить отчёт", lambda _, __: save_report()),
    ]
    if ctx.report_id:
        buttons.insert(0, ("neutral", "Копировать ID отчёта", lambda _, __: copy_report_id()))
    buttons.append(("negative", "Закрыть", lambda _, __: None))

    run_ui(lambda: show_alert(
        "Результат диагностики",
        "\n".join(lines),
        buttons=buttons,
        cancelable=True,
    ))


def setup_self_test_hooks(plugin_instance):
    hook_method = plugin_instance.hook_method
    clazz = _find_list_adapter_class()
    if clazz:
        try:
            ok = hook_all_matching_methods(clazz, "updateRowsInternal", SelfTestUpdateRowsHook, hook_method)
            logger.info("[SelfTest] updateRowsInternal hook: %s", "OK" if ok else "FAIL")
        except Exception:
            logger.error("[SelfTest] Failed to hook updateRowsInternal:", exc_info=True)


# ─────────────────────────────────────────────────────────────
# Final resolution trace (diagnostic)
# ─────────────────────────────────────────────────────────────


def _adapter_dialog_id(adapter):
    try:
        f = adapter.getClass().getDeclaredField("this$0")
        f.setAccessible(True)
        chat = f.get(adapter)
        return str(get_private_field(chat, "dialog_id"))
    except Exception:
        return "?"


class DiagOnBindTraceHook(MethodHook):
    def before_hooked_method(self, param):
        try:
            adapter = param.thisObject
            position = int(param.args[1]) if len(param.args) > 1 else -1
            dialog_id = _adapter_dialog_id(adapter)
            user_info_row = -5
            try:
                val = get_private_field(adapter, "userInfoRow")
                user_info_row = int(val) if val is not None else -5
            except Exception:
                logger.debug("userInfoRow not found on adapter %s", type(adapter).__name__)
            if position != user_info_row:
                return
            if EXTENDED_DIAGNOSTIC:
                _diag_trace[0] = f"{dialog_id}:onBind"
                line = "[DIAG_TRACE] trace=%s tag=BIND_HIT position=%s" % (_diag_trace[0], position)
                logger.info("%s", line)
                _diag_file_write(line)
            if _self_test is not None:
                self_test_on_bind(dialog_id)
        except Exception:
            logger.error("DiagOnBindTraceHook failed:", exc_info=True)


def _find_list_adapter_class():
    chat_class = ensure_chat_activity_class()
    if not chat_class:
        return None
    for inner in chat_class.getDeclaredClasses():
        try:
            for method in inner.getDeclaredMethods():
                mn = method.getName()
                if mn in ("updateRowsInternal", "updateRowsSafe", "onBindViewHolder"):
                    return inner
        except Exception:
            logger.debug("Skipping inner class %s during adapter search", inner.getName())
            continue
    return None


def setup_final_resolution_trace(plugin_instance):
    hook_method = plugin_instance.hook_method
    list_adapter_class = _find_list_adapter_class()
    if list_adapter_class:
        try:
            ok = hook_all_matching_methods(list_adapter_class, "onBindViewHolder", DiagOnBindTraceHook, hook_method)
            logger.info("[DIAG] onBindViewHolder trace hook: %s", "OK" if ok else "FAIL")
        except Exception:
            logger.error("[DIAG] Failed to hook onBindViewHolder trace:", exc_info=True)
    else:
        logger.warning("[DIAG] ListAdapter class not found")


# ─────────────────────────────────────────────────────────────
# Selection Limit Diagnostics
# ─────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────
# Main plugin
# ─────────────────────────────────────────────────────────────

class UtilitiesPro(BasePlugin):
    def on_plugin_load(self):
        global current_plugin, MessagesControllerClass, MessagesControllerClassSource, _peer_info_saver_ok
        current_plugin = self
        MessagesControllerClass = None
        MessagesControllerClassSource = None
        S.load()
        reset_storage_diagnostics()
        peer_storage.ensure_loaded()
        try:
            setup_forward_limit_bypass(self)
        except Exception:
            logger.error("Forward bypass setup failed:", exc_info=True)
        try:
            _peer_info_saver_ok = setup_peer_info_saver(self)
        except Exception:
            _peer_info_saver_ok = False
            logger.error("Peer info saver setup failed:", exc_info=True)
        try:
            setup_final_resolution_trace(self)
        except Exception:
            logger.error("Final resolution trace setup failed:", exc_info=True)
        try:
            setup_self_test_hooks(self)
        except Exception:
            logger.error("Self-test hook setup failed:", exc_info=True)
        self.add_hook("TL_messages_forwardMessages")
        try:
            if S.auto_update_enabled:
                threading.Thread(target=lambda: start_auto_update(), daemon=True).start()
        except Exception:
            logger.error("Auto-update init failed:", exc_info=True)
        logger.info("Loaded.")

    def on_plugin_unload(self):
        global current_plugin, _self_test
        stop_auto_update()
        selector_hook.clear_message_storage()
        dismiss_active_dialogs()
        _self_test = None
        current_plugin = None
        logger.info("Unloaded.")

    def on_app_event(self, event_type):
        global _last_update_check
        try:
            from base_plugin import AppEvent
            if event_type == AppEvent.RESUME:
                if S.auto_update_enabled:
                    idx = S.auto_update_interval
                    if 0 <= idx < len(_UPDATE_INTERVALS):
                        elapsed = time.monotonic() - _last_update_check
                        interval_s = _UPDATE_INTERVALS[idx] * 3600
                        if elapsed >= interval_s:
                            threading.Thread(target=lambda: _do_check_update(), daemon=True).start()
        except Exception:
            logger.error("Auto-update resume check failed:", exc_info=True)

    def create_settings(self):
        global current_plugin
        current_plugin = self
        return create_settings()

    def pre_request_hook(self, req_name, account, req):
        if req_name == "TL_messages_forwardMessages" and S.enable_forward_bypass:
            selector_hook.clear_message_storage()
        return HookResult()
