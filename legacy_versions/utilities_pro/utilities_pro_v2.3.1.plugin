def get_downloads_dir():
    try:
        return Environment.getExternalStoragePublicDirectory(Environment.DIRECTORY_DOWNLOADS).getAbsolutePath()
    except Exception:
        return os.path.join(Environment.getExternalStorageDirectory().getAbsolutePath(), "Download")


def get_backup_dir():
    return os.path.join(get_downloads_dir(), "exteraGram", __id__)


def get_activity_context():
    fragment = get_last_fragment()
    if not fragment:
        return None
    return fragment.getParentActivity()


def show_alert(title, message, buttons=None, cancelable=True):
    context = get_activity_context()
    if not context:
        notify_error("Не удалось открыть диалог: нет активного окна")
        return None
    builder = AlertDialogBuilder(context, AlertDialogBuilder.ALERT_TYPE_MESSAGE)
    builder.set_title(title)
    builder.set_message(message)
    builder.create()
    builder.set_cancelable(cancelable)
    builder.set_canceled_on_touch_outside(cancelable)
    for kind, text, callback in buttons or []:
        if kind == "positive":
            builder.set_positive_button(text, callback)
        elif kind == "negative":
            builder.set_negative_button(text, callback)
        elif kind == "neutral":
            builder.set_neutral_button(text, callback)
    builder.show()
    register_dialog(builder)
    return builder


def register_dialog(builder):
    compact_active_dialogs()
    if builder and builder not in active_dialogs:
        active_dialogs.append(builder)
    return builder


def dismiss_active_dialogs():
    for builder in list(active_dialogs):
        try:
            builder.dismiss()
        except Exception:
            pass
    active_dialogs.clear()


def compact_active_dialogs():
    alive = []
    for builder in list(active_dialogs):
        try:
            dialog = builder.get_dialog() if hasattr(builder, "get_dialog") else None
            if dialog and dialog.isShowing():
                alive.append(builder)
        except Exception:
            pass
    active_dialogs[:] = alive


def divider_lines(lines):
    return [Divider(line) for line in lines]


def open_settings_page(target_page):
    return lambda: create_settings(target_page)


def main_status_badge(health):
    if health["status"] == "ok":
        return "Всё работает нормально"
    if health["status"] == "problem":
        return "Обнаружена проблема"
    return "Требуется внимание"


def main_status_text(health):
    if health["status"] == "ok":
        return "Хранилище исправно, данные сохраняются локально и готовы к восстановлению."
    return health["description"]


def _format_backup_filename(name):
    try:
        ts = datetime.strptime(name, BACKUP_PREFIX + "%Y%m%d_%H%M%S.json")
        return ts.strftime("Резервная копия от %d.%m.%Y %H:%M:%S")
    except (ValueError, IndexError):
        return name


def backup_overview_lines():
    backup_files = list_backup_files()
    latest_label = _format_backup_filename(backup_files[0]) if backup_files else "ещё не создавались"
    return [
        f"Последняя копия: {latest_label}",
        f"Профилей сохранено: {peer_storage.count()}",
    ]


# ─────────────────────────────────────────────────────────────
# Settings
# ─────────────────────────────────────────────────────────────

class S:
    enable_forward_bypass = True
    enable_peer_info_saver = True
    auto_update_enabled = False
    auto_update_interval = 3
    auto_update_url = "https://t.me/VibeSPluginS/19"
    _loaded = False

    @classmethod
    def get(cls, key, default=None):
        plugin = current_plugin
        if not plugin:
            return default
        return plugin.get_setting(key, default)

    @classmethod
    def set(cls, key, value):
        plugin = current_plugin
        if not plugin:
            return
        try:
            plugin.set_setting(key, value, reload_settings=False)
        except Exception:
            logger.error("Failed to save setting %s", key, exc_info=True)
        cls._loaded = False
        cls.load()

    @classmethod
    def load(cls):
        if cls._loaded:
            return
        cls.enable_forward_bypass = bool(cls.get("enable_forward_bypass", True))
        cls.enable_peer_info_saver = bool(cls.get("enable_peer_info_saver", True))
        cls.auto_update_enabled = bool(cls.get("auto_update_enabled", False))
        cls.auto_update_interval = int(cls.get("auto_update_interval", 3))
        cls.auto_update_url = str(cls.get("auto_update_url", "https://t.me/VibeSPluginS/19"))
        cls._loaded = True


def on_forward_toggle(enabled):
    S.set("enable_forward_bypass", enabled)


def on_peer_saver_toggle(enabled):
    S.set("enable_peer_info_saver", enabled)


def handle_auto_update_toggle(enabled):
    S.set("auto_update_enabled", enabled)
    if enabled:
        start_auto_update()
    else:
        stop_auto_update()


def handle_update_interval_change(index):
    S.set("auto_update_interval", index)
    if S.auto_update_enabled:
        stop_auto_update()
        start_auto_update()


# ─────────────────────────────────────────────────────────────
# Storage State Machine — Automatic Root-Cause Localization
# ─────────────────────────────────────────────────────────────

class StorageStateMachine:
    """Per-instance diagnostic that checks invariants after every storage operation.
    
    Automatically detects and reports the FIRST root cause:
      WRITE_LAYER, READ_LAYER, POST_READ_OVERWRITE, PATH_MISMATCH, MULTIPLE_STORAGE_INSTANCES, HASH_MISMATCH_EMPTY_DIFF
    
    Freezes after first failure — never overwrites ROOT_CAUSE.
    Differentiates expected mutations (write, transaction, migration, import, wipe)
    from unexpected mutations (ensure_loaded, _pick_existing_data).
    """
    _instances = []
    _first_failure = None
    _conclusion_printed = False
    _frozen = False

    def __init__(self, storage):
        self.storage = storage
        self.instance_id = hex(id(storage))
        self.op_counter = 0
        self.last_content_hash = None
        self.last_content = None
        self.last_content_keys = None
        self.observed_paths = set()
        self._committed_path = None
        self._last_path = None
        self._creation_stack = self._get_stack()
        StorageStateMachine._instances.append(self)
        self._check_multiple_instances()

    def _get_stack(self):
        return ''.join(traceback.format_stack()[-6:-1])

    def _check_multiple_instances(self):
        pass

    def _content_hash(self, content):
        if not isinstance(content, dict):
            return "non-dict"
        stable = json.dumps(content, sort_keys=True, ensure_ascii=False)
        return hashlib.sha256(stable.encode('utf-8')).hexdigest()

    def _content_keys(self, content):
        if not isinstance(content, dict):
            return set()
        return set(str(k) for k in content.keys())

    def _compute_diff(self, old_content, new_content):
        """Compute added, removed, and changed keys between two dicts."""
        if old_content is None:
            return {"added": set(), "removed": set(), "changed": set()}
        old_keys = set(str(k) for k in old_content.keys())
        new_keys = set(str(k) for k in new_content.keys())
        added = new_keys - old_keys
        removed = old_keys - new_keys
        common = old_keys & new_keys
        if not isinstance(old_content, dict) or not isinstance(new_content, dict):
            changed = set()
        else:
            changed = set()
            for k in common:
                ov = old_content.get(k)
                nv = new_content.get(k)
                if json.dumps(ov, sort_keys=True, default=str) != json.dumps(nv, sort_keys=True, default=str):
                    changed.add(k)
        return {"added": added, "removed": removed, "changed": changed}

    def _print_diff(self, diff):
        if diff["added"]:
            print(f"    added_keys({len(diff['added'])}): {sorted(diff['added'])[:10]}", flush=True)
        if diff["removed"]:
            print(f"    removed_keys({len(diff['removed'])}): {sorted(diff['removed'])[:10]}", flush=True)
        if diff["changed"]:
            print(f"    changed_keys({len(diff['changed'])}): {sorted(diff['changed'])[:10]}", flush=True)

    def _fail(self, root_cause, caller="", details=""):
        if StorageStateMachine._frozen:
            return
        StorageStateMachine._frozen = True
        StorageStateMachine._first_failure = {
            "root_cause": root_cause,
            "first_operation": self.op_counter,
            "first_timestamp": datetime.now().strftime("%Y-%m-%d %H:%M:%S.%f")[:-3],
            "first_caller": caller,
            "first_storage_instance": self.instance_id,
            "first_path": self._last_path or "N/A",
            "details": details,
        }
        self._print_conclusion()

    def _print_conclusion(self):
        if StorageStateMachine._conclusion_printed:
            return
        StorageStateMachine._conclusion_printed = True
        f = StorageStateMachine._first_failure
        if f:
            rc = f["root_cause"]
            if rc in ("WRITE_LAYER", "READ_LAYER", "POST_READ_OVERWRITE", "PATH_MISMATCH", "MULTIPLE_STORAGE_INSTANCES"):
                confidence = "HIGH"
            elif rc == "HASH_MISMATCH_EMPTY_DIFF":
                confidence = "MEDIUM"
            else:
                confidence = "HIGH"
            conclusion = (
                f"\n{'='*60}\n"
                f"ROOT_CAUSE = {rc}\n"
                f"CONFIDENCE = {confidence}\n"
                f"EVIDENCE = [op #{f['first_operation']}]\n"
                f"first_timestamp = {f['first_timestamp']}\n"
                f"first_caller = {f['first_caller']}\n"
                f"first_storage_instance = {f['first_storage_instance']}\n"
                f"first_path = {f['first_path']}\n"
                f"{f['details']}\n"
                f"{'='*60}\n"
            )
        else:
            conclusion = (
                f"\n{'='*60}\n"
                f"ROOT_CAUSE = UNKNOWN\n"
                f"CONFIDENCE = LOW\n"
                f"EVIDENCE = none\n"
                f"{'='*60}\n"
            )
        print(conclusion, flush=True)
        logger.error(conclusion)

    @classmethod
    def has_failed(cls):
        return cls._frozen

    def op(self, event_name):
        if StorageStateMachine._frozen:
            return self.op_counter
        self.op_counter += 1
        print(f"op={self.op_counter} storage={self.instance_id} event={event_name}", flush=True)
        return self.op_counter

    def check_path(self, path):
        if not path or StorageStateMachine._frozen:
            return
        abs_path = os.path.abspath(path)
        self._last_path = abs_path
        self.observed_paths.add(abs_path)

    def commit_path(self, path):
        if not path or StorageStateMachine._frozen:
            return
        abs_path = os.path.abspath(path)
        self._last_path = abs_path
        if self._committed_path is not None and abs_path != self._committed_path:
            self._fail("PATH_MISMATCH", caller="commit_path",
                details=f"Committed path changed: was '{self._committed_path}', now '{abs_path}'")
        self._committed_path = abs_path
        self.observed_paths.add(abs_path)

    def verify_write_end(self, path, compress):
        if StorageStateMachine._frozen:
            return False
        ap = os.path.abspath(path)
        self._last_path = ap
        self.commit_path(ap)
        print(f"  path={ap}", flush=True)
        try:
            exists = os.path.exists(ap)
            print(f"  exists={str(exists).lower()}", flush=True)
            if not exists:
                self._fail("WRITE_LAYER", caller="verify_write_end",
                    details=f"File does not exist after write: {ap}")
                return False
            size = os.path.getsize(ap)
            print(f"  size={size}", flush=True)
            try:
                if compress:
                    with gzip.open(ap, "rt", encoding="utf-8") as f:
                        data = json.load(f)
                else:
                    with open(ap, "r", encoding="utf-8") as f:
                        data = json.load(f)
                print(f"  gzip_readable=true  json_valid=true", flush=True)
            except Exception as e:
                print(f"  gzip_readable=false  json_valid=false  error={e}", flush=True)
                self._fail("WRITE_LAYER", caller="verify_write_end",
                    details=f"Cannot parse file as JSON: {e}")
                return False
            entries = len(data) if isinstance(data, (dict, list)) else 1
            print(f"  entries={entries}", flush=True)
            sjson = json.dumps(data, sort_keys=True, ensure_ascii=False)
            sha256_content = hashlib.sha256(sjson.encode('utf-8')).hexdigest()
            with open(ap, "rb") as f:
                file_bytes = f.read()
            sha256_file = hashlib.sha256(file_bytes).hexdigest()
            print(f"  sha256_file={sha256_file}", flush=True)
            print(f"  sha256_content={sha256_content}", flush=True)
            return True
        except Exception as e:
            self._fail("WRITE_LAYER", caller="verify_write_end",
                details=f"Verification exception: {e}")
            return False

    def verify_read_end(self, path, loaded_content, normalize_fn=None):
        if StorageStateMachine._frozen:
            return False
        ap = os.path.abspath(path) if path else ""
        self._last_path = ap
        self.check_path(ap)
        try:
            file_entries = 0
            file_hash = "N/A"
            if os.path.exists(ap):
                size = os.path.getsize(ap)
                is_gzip = False
                if size > 2:
                    with open(ap, "rb") as f:
                        magic = f.read(2)
                        is_gzip = (magic == b'\x1f\x8b')
                if is_gzip:
                    with gzip.open(ap, "rt", encoding="utf-8") as f:
                        file_data = json.load(f)
                else:
                    with open(ap, "r", encoding="utf-8") as f:
                        file_data = json.load(f)
                if normalize_fn:
                    file_data = normalize_fn(file_data)
                file_entries = len(file_data) if isinstance(file_data, (dict, list)) else 1
                sjson = json.dumps(file_data, sort_keys=True, ensure_ascii=False)
                file_hash = hashlib.sha256(sjson.encode('utf-8')).hexdigest()
            loaded_entries = len(loaded_content) if isinstance(loaded_content, dict) else 0
            loaded_hash = self._content_hash(loaded_content)
            print(f"  entries_in_file={file_entries}  entries_loaded={loaded_entries}", flush=True)
            if file_entries != loaded_entries:
                self._fail("READ_LAYER", caller="verify_read_end",
                    details=f"File has {file_entries} entries, read loaded {loaded_entries}\n"
                    f"File hash={file_hash} loaded hash={loaded_hash}\n"
                    f"Path={ap}")
                return False
            if file_hash != loaded_hash and file_hash != "N/A":
                self._fail("READ_LAYER", caller="verify_read_end",
                    details=f"Content hash mismatch: file={file_hash} loaded={loaded_hash}\n"
                    f"Path={ap}")
                return False
            print(f"  read_verified=true", flush=True)
            return True
        except Exception as e:
            self._fail("READ_LAYER", caller="verify_read_end",
                details=f"Verification exception: {e}")
            return False

    def record_expected_mutation(self, caller, content):
        """Expected mutation: write, transaction, wipe, migration, import.
        
        Establishes new baseline hash. Logs structural diff.
        Never triggers POST_READ_OVERWRITE.
        """
        if StorageStateMachine._frozen:
            return
        current_hash = self._content_hash(content)
        if self.last_content_hash is not None and current_hash != self.last_content_hash:
            diff = self._compute_diff(self.last_content, content)
            print(f"  mutation: caller={caller}", flush=True)
            self._print_diff(diff)
            if not diff["added"] and not diff["removed"] and not diff["changed"]:
                self._fail("HASH_MISMATCH_EMPTY_DIFF", caller=caller,
                    details=f"Hash changed but structural diff is empty for {caller}")
        self.last_content_hash = current_hash
        self.last_content_keys = self._content_keys(content)
        self.last_content = content

    def check_unexpected_mutation(self, caller, content):
        """Unexpected mutation: ensure_loaded, _pick_existing_data.
        
        Triggers POST_READ_OVERWRITE on any content change.
        """
        if StorageStateMachine._frozen:
            return
        current_hash = self._content_hash(content)
        if self.last_content_hash is not None and current_hash != self.last_content_hash:
            diff = self._compute_diff(self.last_content, content)
            print(f"  unexpected_content_change: caller={caller}", flush=True)
            self._print_diff(diff)
            if not diff["added"] and not diff["removed"] and not diff["changed"]:
                self._fail("HASH_MISMATCH_EMPTY_DIFF", caller=caller,
                    details=f"Hash changed but structural diff is empty for {caller}")
                return
            zeroed = (len(self._content_keys(content)) == 0 and self.last_content_keys and len(self.last_content_keys) > 0)
            if zeroed:
                summary = f"Entries went to zero after {caller}: was {len(self.last_content_keys)}, now 0"
            else:
                summary = (f"Content changed unexpectedly after {caller}: "
                           f"+{len(diff['added'])} -{len(diff['removed'])} ~{len(diff['changed'])}")
            self._fail("POST_READ_OVERWRITE", caller=caller,
                details=summary + f"\nPrevious entries: {len(self.last_content_keys or [])}")
            return
        self.last_content_hash = current_hash
        self.last_content_keys = self._content_keys(content)
        self.last_content = content

    def trace_event(self, event, path=None, extra_info=None):
        if StorageStateMachine._frozen:
            return
        self.op_counter += 1
        if path:
            self._last_path = os.path.abspath(path)
        info = extra_info or ""
        print(f"op={self.op_counter} storage={self.instance_id} event={event} path={path or 'N/A'} {info}".strip(), flush=True)
def reset_storage_diagnostics():
    """Reset diagnostics for testing."""
    StorageStateMachine._instances.clear()
    StorageStateMachine._first_failure = None
    StorageStateMachine._conclusion_printed = False
    StorageStateMachine._frozen = False


# ─────────────────────────────────────────────────────────────
# Storage
# ─────────────────────────────────────────────────────────────

class JsonStorage:
    def __init__(self, name, default=None, compress=True, legacy_specs=None):
        self.name = name
        self.default = default if default is not None else {}
        self.compress = compress
        self.legacy_specs = legacy_specs
        self.content = self._copy_default()
        self._lock = threading.RLock()
        self.loaded = False
        self.selected_path = None
        self.selected_source = "current"
        self.last_scan = []
        self._cached_path = None
        self.storage_instance_id = hex(id(self))
        self.read_trace = []
        self._read_seq = 0
        self._read_trigger = "unknown"
        self._diag = StorageStateMachine(self)

    def _copy_default(self):
        return dict(self.default) if isinstance(self.default, dict) else self.default

    def path(self):
        if self._cached_path:
            return self._cached_path
        base = get_app_files_dir_path()
        suffix = ".jsonz" if self.compress else ".json"
        path = os.path.join(base, "plugins_data", self.name + suffix)
        if "cache" not in path:
            self._cached_path = path
            self._diag.commit_path(path)
        return path

    def legacy_paths(self):
        if self.legacy_specs is not None:
            return list(self.legacy_specs)
        files_dir = get_app_files_dir_path()
        return [
            ("legacy_utilities_root_jsonz", os.path.join(files_dir, self.name + ".jsonz"), "gzip_json"),
            ("legacy_utilities_root_json", os.path.join(files_dir, self.name + ".json"), "json"),
            ("user_info_saver_root", os.path.join(files_dir, OLD_PEER_STORAGE_NAME), "zlib_json"),
        ]

    def candidate_paths(self):
        candidates = [("current", self.path(), "gzip_json" if self.compress else "json")]
        candidates.extend(self.legacy_paths())
        old_cache_path = get_old_cache_path()
        if self.name == PEER_STORAGE_NAME and old_cache_path:
            candidates.append(("user_info_saver_cache", old_cache_path, "zlib_json"))
        return candidates

    def _trace_read(self, stage, **kwargs):
        if not EXTENDED_DIAGNOSTIC:
            return
        entry = {"stage": stage, "timestamp": datetime.now().isoformat(),
            "read_seq": self._read_seq, "trigger": self._read_trigger}
        entry.update(kwargs)
        self.read_trace.append(entry)

    def _read_payload_by_format(self, path, fmt):
        if fmt == "gzip_json":
            try:
                with gzip.open(path, "rt", encoding="utf-8") as file:
                    data = json.load(file)
                self._trace_read("gzip_open", path=path, success=True)
                self._trace_read("json_load", path=path, type=type(data).__name__,
                    keys=len(data) if isinstance(data, dict) else "N/A")
                return data
            except Exception as e:
                self._trace_read("gzip_open", path=path, success=False,
                    exception=type(e).__name__, traceback=traceback.format_exc())
                raise
        if fmt == "json":
            try:
                with open(path, "r", encoding="utf-8") as file:
                    data = json.load(file)
                self._trace_read("json_open", path=path, success=True)
                self._trace_read("json_load", path=path, type=type(data).__name__,
                    keys=len(data) if isinstance(data, dict) else "N/A")
                return data
            except Exception as e:
                self._trace_read("json_open", path=path, success=False,
                    exception=type(e).__name__, traceback=traceback.format_exc())
                raise
        if fmt == "zlib_json":
            try:
                data = read_maybe_zlib_json(path)
                self._trace_read("zlib_open", path=path, success=True)
                self._trace_read("zlib_json_load", path=path, type=type(data).__name__,
                    keys=len(data) if isinstance(data, dict) else "N/A")
                return data
            except Exception as e:
                self._trace_read("zlib_open", path=path, success=False,
                    exception=type(e).__name__, traceback=traceback.format_exc())
                raise
        raise ValueError(f"unknown_storage_format:{fmt}")

    def _read_candidate(self, path, fmt):
        data = self._read_payload_by_format(path, fmt)
        if not isinstance(data, dict):
            self._trace_read("normalize", path=path, input_type=type(data).__name__,
                input_count="N/A", output_count=0, removed=[], reason="not_a_dict")
            return {}
        input_count = len(data)
        normalized = {}
        removed_keys = []
        for key, value in data.items():
            if not isinstance(value, dict):
                removed_keys.append(f"{key}:value_not_dict")
                continue
            key_str = str(key)
            try:
                if int(key_str) <= 0:
                    removed_keys.append(f"{key}:non_positive_int")
                    continue
            except (ValueError, TypeError):
                removed_keys.append(f"{key}:int_conversion_failed")
                continue
            normalized[key_str] = value
        output_count = len(normalized)
        self._trace_read("normalize", path=path, input_count=input_count,
            output_count=output_count, removed=removed_keys,
            reason="ok" if not removed_keys else f"removed_{len(removed_keys)}_keys")
        return normalized

    def inspect_candidates(self):
        diagnostics = []
        for source, path, fmt in self.candidate_paths():
            entry = {
                "source": source,
                "path": path,
                "format": fmt,
                "exists": bool(path and os.path.exists(path)),
                "count": 0,
                "error": None,
            }
            if entry["exists"]:
                try:
                    data = self._read_candidate(path, fmt)
                    entry["count"] = len(data)
                    entry["_data"] = data
                except Exception:
                    entry["error"] = "read_failed"
                    logger.error("Failed to inspect storage candidate %s:", path, exc_info=True)
            diagnostics.append(entry)
        self.last_scan = diagnostics
        return diagnostics

    def _pick_existing_data(self):
        self._diag.op("_pick_existing_data")
        diagnostics = self.inspect_candidates()
        merged = {}
        selected_source = "current"
        selected_path = self.path()
        precedence = [entry for entry in diagnostics if entry["exists"] and not entry["error"] and entry["count"] > 0]
        merge_order = list(reversed(precedence))
        for entry in merge_order:
            try:
                data = entry.get("_data")
                if data is None:
                    data = self._read_candidate(entry["path"], entry["format"])
                merged.update(data)
            except Exception:
                logger.error("Failed to merge storage candidate %s:", entry["path"], exc_info=True)
        if precedence:
            selected_source = precedence[0]["source"]
            selected_path = precedence[0]["path"]
        self._diag.check_unexpected_mutation("_pick_existing_data", merged)
        return merged, selected_source, selected_path, diagnostics

    def read(self, trigger="explicit_reload"):
        self._read_trigger = trigger
        self._read_seq += 1
        self._diag.op("read")
        try:
            data, selected_source, selected_path, diagnostics = self._pick_existing_data()
            with self._lock:
                self.content = data if isinstance(data, dict) and data else self._copy_default()
                self.selected_source = selected_source
                self.selected_path = selected_path
            self.last_scan = diagnostics
            self._diag.verify_read_end(selected_path, self.content, normalize_fn=normalize_peer_dump)
            self.loaded = True
            content_len = len(self.content) if isinstance(self.content, dict) else -1
            first_keys = list(self.content.keys())[:10] if isinstance(self.content, dict) else []
            self._trace_read("assign_content", selected_path=selected_path,
                len=content_len, first_keys=first_keys)
            return bool(self.content)
        except Exception as e:
            self._trace_read("read_exception", exception=type(e).__name__,
                traceback=traceback.format_exc())
            with self._lock:
                self.content = self._copy_default()
                self.selected_source = "current"
                self.selected_path = self.path()
            self._diag.verify_read_end(self.path(), self.content, normalize_fn=normalize_peer_dump)
            return False

    def ensure_loaded(self):
        if not self.loaded:
            self._diag.op("ensure_loaded")
            self.read(trigger="initial_load")
            self._diag.check_unexpected_mutation("ensure_loaded", self.content)
        elif self._cached_path and self.selected_path and "cache" in self.selected_path:
            self._diag.op("ensure_loaded(reload)")
            self.read(trigger="ensure_loaded_cache_reread")
            self._diag.record_expected_mutation("reload_from_cache_path", self.content)

    def write(self):
        if not self.loaded and not self.content:
            logger.error("Refusing to write empty content: storage never successfully loaded")
            return False
        with self._lock:
            content_snapshot = dict(self.content)
        path = self.path()
        temp_path = path + ".tmp"
        self._diag.op("write")
        try:
            os.makedirs(os.path.dirname(path), exist_ok=True)
            if self.compress:
                with gzip.open(temp_path, "wt", encoding="utf-8") as file:
                    json.dump(content_snapshot, file, ensure_ascii=False, separators=(",", ":"))
            else:
                with open(temp_path, "w", encoding="utf-8") as file:
                    json.dump(content_snapshot, file, ensure_ascii=False, separators=(",", ":"))
            os.replace(temp_path, path)
            self.loaded = True
            self.selected_path = path
            self.selected_source = "current"
            self._diag.verify_write_end(path, self.compress)
            self._diag.record_expected_mutation("write", content_snapshot)
            return True
        except Exception:
            logger.error("Failed to write storage %s:", path, exc_info=True)
            try:
                if os.path.exists(temp_path):
                    os.remove(temp_path)
            except Exception:
                pass
            return False

    def count(self):
        self.ensure_loaded()
        return len(self.content) if isinstance(self.content, dict) else 0

    def diagnostics(self):
        self.ensure_loaded()
        return {
            "selected_source": self.selected_source,
            "selected_path": self.selected_path or self.path(),
            "current_path": self.path(),
            "entries": self.inspect_candidates(),
        }


peer_storage = JsonStorage(PEER_STORAGE_NAME, default={}, compress=True)


def normalize_peer_dump(data):
    if not isinstance(data, dict):
        return {}
    normalized = {}
    for key, value in data.items():
        if not isinstance(value, dict):
            continue
        key_str = str(key)
        if not is_user_dialog(key_str):
            continue
        normalized[key_str] = value
    return normalized


# ─────────────────────────────────────────────────────────────
# Migration and backup
# ─────────────────────────────────────────────────────────────

def get_old_cache_path():
    try:
        return os.path.join(get_plugins_dir(), "cache", OLD_PEER_STORAGE_NAME)
    except Exception:
        return None


def read_maybe_zlib_json(path):
    with open(path, "rb") as file:
        raw = file.read()
    if not raw:
        return {}
    is_zlib = len(raw) >= 2 and (raw[0] & 0x0F) == 8 and (raw[0] * 256 + raw[1]) % 31 == 0
    if is_zlib:
        raw = zlib.decompress(raw)
    return normalize_peer_dump(json.loads(raw.decode("utf-8", errors="replace")))


def _pluralize_records(n):
    n100 = abs(n) % 100
    if 11 <= n100 <= 19:
        return f"{n} записей"
    n10 = n100 % 10
    if n10 == 1:
        return f"{n} запись"
    if 2 <= n10 <= 4:
        return f"{n} записи"
    return f"{n} записей"


def import_peer_dump(data):
    normalized = normalize_peer_dump(data)
    normalized = {key: value for key, value in normalized.items() if is_meaningful_peer_dump(value)}
    if not normalized:
        return 0
    peer_storage.ensure_loaded()
    if not peer_storage._lock.acquire(blocking=False):
        logger.warning("Storage locked, skipping import")
        return 0
    try:
        old_values = {k: peer_storage.content[k] for k in normalized if k in peer_storage.content}
        peer_storage.content.update(normalized)
    finally:
        peer_storage._lock.release()
    try:
        if not peer_storage.write():
            raise RuntimeError("storage_write_failed")
    except Exception:
        with peer_storage._lock:
            for k in normalized:
                if k in old_values:
                    peer_storage.content[k] = old_values[k]
                else:
                    peer_storage.content.pop(k, None)
        raise
    return len(normalized)


def is_meaningful_peer_dump(dumped):
    if not isinstance(dumped, dict):
        return False
    if any(dumped.get(field) not in (None, "", 0, False) for field in PRECIOUS_PEER_FIELDS):
        return True
    for field in IMPORTANT_PEER_STATE_FIELDS:
        value = dumped.get(field)
        if isinstance(value, bool) and value:
            return True
        if value not in (None, "", 0, False):
            return True
    for key, value in dumped.items():
        if key in PRECIOUS_PEER_FIELDS or key in IMPORTANT_PEER_STATE_FIELDS:
            continue
        if isinstance(value, bool) and value:
            return True
        if value not in (None, "", 0, False):
            return True
    return False


def is_user_dialog(dialog_id):
    try:
        return int(dialog_id) > 0
    except Exception:
        return False


def get_user_peer_settings_map(msg_controller):
    try:
        return get_private_field(msg_controller, FIELD_USER_PEER_SETTINGS)
    except Exception:
        return None


def cache_restored_peer_settings(msg_controller, dialog_id, settings):
    if not msg_controller or not settings or not is_user_dialog(dialog_id):
        return False
    try:
        user_peer_settings = get_user_peer_settings_map(msg_controller)
        if not user_peer_settings:
            return False
        user_peer_settings.put(dialog_id, settings)
        return True
    except Exception:
        logger.error("Failed to cache restored peer settings for %s", dialog_id, exc_info=True)
        return False


def migrate_old_storage(delete_after_success=True):
    old_path = get_old_cache_path()
    if not old_path or not os.path.exists(old_path):
        peer_storage._diag.op("MIGRATION_OLD_STORAGE_SKIPPED")
        return 0
    peer_storage._diag.op("MIGRATION_OLD_STORAGE")
    peer_storage._diag.check_path(old_path)
    data = read_maybe_zlib_json(old_path)
    count = import_peer_dump(data)
    if count and delete_after_success:
        try:
            os.remove(old_path)
            peer_storage._diag.op("MIGRATION_OLD_STORAGE_DELETE")
        except Exception:
            logger.error("Failed to delete old storage after migration:", exc_info=True)
    peer_storage._diag.record_expected_mutation("migrate_old_storage", peer_storage.content)
    return count


def inspect_old_storage():
    old_path = get_old_cache_path()
    try:
        if not old_path or not os.path.exists(old_path):
            peer_storage._diag.op("INSPECT_OLD_STORAGE_NOT_EXISTS")
            return {"exists": False, "count": 0, "path": old_path, "error": None}
        count = len(read_maybe_zlib_json(old_path))
        peer_storage._diag.op("INSPECT_OLD_STORAGE")
        peer_storage._diag.check_path(old_path)
        return {"exists": True, "count": count, "path": old_path, "error": None}
    except Exception:
        logger.error("Failed to inspect old storage:", exc_info=True)
        return {"exists": False, "count": 0, "path": old_path, "error": "inspect_failed"}


def migrate_resolved_legacy_storage():
    peer_storage._diag.op("MIGRATION_RESOLVED_LEGACY")
    peer_storage.ensure_loaded()
    selected_path = peer_storage.selected_path
    if not selected_path or selected_path == peer_storage.path():
        peer_storage._diag.op("MIGRATION_RESOLVED_LEGACY_SKIPPED_NO_LEGACY")
        return 0
    if not peer_storage.count():
        peer_storage._diag.op("MIGRATION_RESOLVED_LEGACY_SKIPPED_ZERO")
        return 0
    if not peer_storage.write():
        raise RuntimeError("storage_write_failed")
    peer_storage._diag.record_expected_mutation("migrate_resolved_legacy_storage", peer_storage.content)
    return peer_storage.count()


def migrate_detected_legacy_now():
    try:
        migrated = migrate_resolved_legacy_storage()
        if migrated > 0:
            notify_success(f"Перенесено {_pluralize_records(migrated)} в текущее хранилище")
        else:
            notify_info("Активное хранилище уже текущее или перенос не требуется")
    except Exception:
        logger.error("Resolved legacy migration failed:", exc_info=True)
        notify_error("Ошибка переноса в текущее хранилище")


def import_old_storage_now():
    try:
        imported = migrate_old_storage(delete_after_success=False)
        if imported > 0:
            notify_success(f"Импортировано {_pluralize_records(imported)}")
        else:
            notify_info("Старые данные не найдены или уже пусты")
    except Exception:
        logger.error("Migration failed:", exc_info=True)
        notify_error("Ошибка миграции старых данных")


def build_backup_payload():
    snapshot = storage_snapshot()
    return {
        "plugin": __id__,
        "version": __version__,
        "created_at": datetime.now().isoformat(timespec="seconds"),
        "records": snapshot["peer_records"],
    }


def write_backup_payload(payload, filename=None):
    backup_dir = get_backup_dir()
    os.makedirs(backup_dir, exist_ok=True)
    filename = filename or (BACKUP_PREFIX + datetime.now().strftime("%Y%m%d_%H%M%S") + ".json")
    path = os.path.join(backup_dir, filename)
    peer_storage._diag.trace_event("BACKUP_WRITE_BEGIN", path=path, extra_info=f"peer_count={len(payload.get('records', {}))}")
    with open(path, "w", encoding="utf-8") as file:
        json.dump(payload, file, ensure_ascii=False, indent=2)
    peer_storage._diag.trace_event("BACKUP_WRITE_END", path=path)
    return path, filename


def export_backup(silent=False, filename=None, payload=None):
    try:
        payload = payload or build_backup_payload()
        peer_storage._diag.trace_event("EXPORT_BACKUP_BEGIN", path=backup_file_path(filename) if filename else "N/A", extra_info=f"peer_count={len(payload.get('records', {}))}")
        _path, written_name = write_backup_payload(payload, filename=filename)
        peer_storage._diag.trace_event("EXPORT_BACKUP_END", path=_path, extra_info=f"written={written_name}")
        if not silent:
            run_ui(lambda: notify_success(f"Резервная копия создана\n{written_name}"))
        return written_name
    except Exception:
        logger.error("Export failed:", exc_info=True)
        if not silent:
            run_ui(lambda: notify_error("Ошибка экспорта"))
        raise


def list_backup_files():
    backup_dir = get_backup_dir()
    if not os.path.exists(backup_dir):
        return []
    files = [name for name in os.listdir(backup_dir) if name.startswith(BACKUP_PREFIX) and name.endswith(".json")]
    return sorted(files, reverse=True)


def backup_file_path(filename):
    return os.path.join(get_backup_dir(), filename)


def read_backup_file(path):
    peer_storage._diag.trace_event("BACKUP_READ_BEGIN", path=path)
    with open(path, "r", encoding="utf-8") as file:
        payload = json.load(file)
    peer_records = {}
    if isinstance(payload, dict):
        if isinstance(payload.get("records"), dict):
            peer_records = normalize_peer_dump(payload["records"])
        else:
            peer_records = normalize_peer_dump(payload)
    else:
        peer_records = normalize_peer_dump(payload)
    peer_storage._diag.trace_event("BACKUP_READ_END", path=path, extra_info=f"peer_count={len(peer_records)}")
    return {
        "peer_records": peer_records,
        "raw": payload,
    }


def backup_file_summary(filename):
    path = backup_file_path(filename)
    try:
        stat = os.stat(path)
    except FileNotFoundError:
        return {"filename": filename, "path": path, "size_bytes": 0, "size_label": "0 B",
                "created_at": "", "created_label": "файл не найден",
                "peer_count": 0, "version": "", "plugin": __id__}
    backup = read_backup_file(path)
    raw = backup["raw"] if isinstance(backup.get("raw"), dict) else {}
    return {
        "filename": filename,
        "path": path,
        "size_bytes": stat.st_size,
        "size_label": human_size(stat.st_size),
        "created_at": raw.get("created_at") or datetime.fromtimestamp(stat.st_mtime).isoformat(timespec="seconds"),
        "created_label": human_date_from_iso(raw.get("created_at")) if raw.get("created_at") else datetime.fromtimestamp(stat.st_mtime).strftime("%d.%m.%Y %H:%M"),
        "peer_count": len(backup["peer_records"]),
        "version": raw.get("version") or "неизвестно",
        "plugin": raw.get("plugin") or __id__,
    }


def merge_peer_records(current, incoming):
    merged = normalize_peer_dump(current)
    for key, value in normalize_peer_dump(incoming).items():
        existing = merged.get(key)
        if not isinstance(existing, dict):
            merged[key] = clone_data(value)
            continue
        combined = clone_data(existing)
        combined.update(value)
        for field in PRECIOUS_PEER_FIELDS:
            if not combined.get(field):
                old_value = existing.get(field)
                if old_value not in (None, "", 0, False):
                    combined[field] = old_value
        if is_meaningful_peer_dump(combined):
            merged[key] = combined
    return {key: value for key, value in merged.items() if is_meaningful_peer_dump(value)}


def verify_storage_state(expected_peer):
    try:
        fmt = "gzip_json" if peer_storage.compress else "json"
        data = peer_storage._read_candidate(peer_storage.path(), fmt)
    except Exception:
        return False
    return normalize_peer_dump(data) == normalize_peer_dump(expected_peer)


def apply_storage_transaction(peer_content, safety_prefix=None):
    snapshot = storage_snapshot()
    safety_name = None
    peer_storage._diag.trace_event("TRANSACTION_BEGIN", path=peer_storage.path(), extra_info=f"mode={safety_prefix or 'none'} incoming_keys={len(normalize_peer_dump(peer_content))} snapshot_keys={len(snapshot.get('peer_records', {}))}")
    try:
        if safety_prefix:
            safety_name = export_backup(
                silent=True,
                filename=BACKUP_PREFIX + safety_prefix + "_" + datetime.now().strftime("%Y%m%d_%H%M%S") + ".json",
            )
        final_peer = normalize_peer_dump(peer_content)
        set_storage_content(peer_storage, final_peer)
        peer_storage._diag.record_expected_mutation("apply_storage_transaction:after_set_content", peer_storage.content)
        if not peer_storage.write():
            peer_storage._diag.trace_event("TRANSACTION_END", path=peer_storage.path(), extra_info="FAILED: write_failed")
            raise RuntimeError("write_failed")
        if not verify_storage_state(final_peer):
            peer_storage._diag.trace_event("TRANSACTION_END", path=peer_storage.path(), extra_info="FAILED: verify_failed")
            raise RuntimeError("verify_failed")
        peer_storage._diag.record_expected_mutation("apply_storage_transaction", peer_storage.content)
        peer_storage._diag.trace_event("TRANSACTION_END", path=peer_storage.path(), extra_info=f"SUCCESS safety_backup={safety_name} final_keys={len(final_peer)}")
        return {
            "peer": final_peer,
            "safety_backup": safety_name,
            "snapshot": snapshot,
        }
    except Exception:
        peer_storage._diag.trace_event("TRANSACTION_END", path=peer_storage.path(), extra_info="EXCEPTION: restore_snapshot")
        rollback_ok = restore_snapshot(snapshot)
        if not rollback_ok:
            logger.error("Rollback write failed during apply_storage_transaction")
        raise


def import_backup_payload(backup_data, mode="replace"):
    snapshot = storage_snapshot()
    incoming_peer = backup_data["peer_records"]
    peer_storage._diag.trace_event("IMPORT_BACKUP_PAYLOAD_BEGIN", path=peer_storage.path(), extra_info=f"mode={mode} incoming_keys={len(incoming_peer)} current_keys={len(snapshot.get('peer_records', {}))}")
    if mode == "replace":
        final_peer = normalize_peer_dump(incoming_peer)
    else:
        final_peer = merge_peer_records(snapshot["peer_records"], incoming_peer)
    peer_storage._diag.trace_event("IMPORT_BACKUP_PAYLOAD_MERGED", path=peer_storage.path(), extra_info=f"final_keys={len(final_peer)}")
    result = apply_storage_transaction(final_peer, safety_prefix="autosave")
    peer_storage._diag.trace_event("IMPORT_BACKUP_PAYLOAD_END", path=peer_storage.path(), extra_info=f"peer_count={len(result['peer'])} safety_backup={result['safety_backup']}")
    return {
        "peer_count": len(result["peer"]),
        "safety_backup": result["safety_backup"],
    }


def import_backup_file(filename, mode):
    path = backup_file_path(filename)
    peer_storage._diag.trace_event("IMPORT_BACKUP_FILE_BEGIN", path=path, extra_info=f"mode={mode}")
    try:
        backup_data = read_backup_file(path)
        result = import_backup_payload(backup_data, mode)
        peer_storage._diag.trace_event("IMPORT_BACKUP_FILE_END", path=path, extra_info=f"SUCCESS peer_count={result['peer_count']} safety_backup={result['safety_backup']}")
        run_ui(lambda: notify_success(
            f"Импорт завершён: {result['peer_count']} профилей\nСтраховочная копия: {result['safety_backup']}"
        ))
        return result
    except Exception:
        logger.error("Import failed:", exc_info=True)
        peer_storage._diag.trace_event("IMPORT_BACKUP_FILE_END", path=path, extra_info="FAILED: exception rollback")
        run_ui(lambda: notify_error("Ошибка импорта, выполнен откат"))
        return None


def wipe_saved_peer_data():
    def confirm(_, __):
        try:
            peer_storage._diag.trace_event("WIPE_BEGIN", path=peer_storage.path())
            result = apply_storage_transaction({}, safety_prefix="wipe")
            peer_storage._diag.record_expected_mutation("wipe_saved_peer_data", peer_storage.content)
            peer_storage._diag.trace_event("WIPE_END", path=peer_storage.path(), extra_info=f"SUCCESS safety_backup={result['safety_backup']}")
            notify_success(f"Сохранённые данные очищены\nСтраховочная копия: {result['safety_backup']}")
        except Exception:
            logger.error("Wipe failed:", exc_info=True)
            peer_storage._diag.trace_event("WIPE_END", path=peer_storage.path(), extra_info="FAILED: exception rollback")
            notify_error("Не удалось очистить данные, выполнен откат")

    show_alert(
        "Очистить данные?",
        "Будут удалены только данные UtilitiesPro. Файлы резервных копий и старые плагины не затрагиваются.",
        buttons=[
            ("positive", "Очистить", confirm),
            ("negative", "Отмена", lambda _, __: None),
        ],
        cancelable=True,
    )


def clean_empty_profiles():
    def confirm(_, __):
        try:
            peer_storage.ensure_loaded()
            with peer_storage._lock:
                before = len(peer_storage.content)
                empty_keys = [k for k, v in peer_storage.content.items()
                              if not is_meaningful_peer_dump(v)]
                old_entries = {k: peer_storage.content[k] for k in empty_keys}
                for k in empty_keys:
                    del peer_storage.content[k]
                write_ok = peer_storage.write()
                if not write_ok:
                    for k, v in old_entries.items():
                        peer_storage.content[k] = v
                    notify_error("Не удалось записать изменения, данные восстановлены")
                    return
            notify_success(f"Удалено пустых профилей: {len(empty_keys)} из {before}")
        except Exception:
            logger.error("Clean empty profiles failed:", exc_info=True)
            peer_storage.ensure_loaded()
            notify_error("Не удалось очистить пустые профили")

    peer_storage.ensure_loaded()
    empty_count = sum(1 for v in peer_storage.content.values()
                      if not is_meaningful_peer_dump(v))
    if empty_count == 0:
        notify_info("Пустых профилей не найдено")
        return
    show_alert(
        "Очистить пустые профили?",
        f"Найдено {empty_count} {decline_word(empty_count)}, в которых нет полезных данных. "
        "Будут удалены только пустые профили — все ценные данные сохранятся.",
        buttons=[
            ("positive", "Очистить", confirm),
            ("negative", "Отмена", lambda _, __: None),
        ],
        cancelable=True,
    )


def delete_saved_peer_data(dialog_id):
    if not is_user_dialog(dialog_id):
        return False
    peer_storage.ensure_loaded()
    dialog_key = str(dialog_id)
    with peer_storage._lock:
        if dialog_key not in peer_storage.content:
            return False
        old_value = peer_storage.content.get(dialog_key)
        del peer_storage.content[dialog_key]
    ok = peer_storage.write()
    if ok:
        notify_success(f"Данные профиля {dialog_id} удалены")
    else:
        with peer_storage._lock:
            if old_value is not None:
                peer_storage.content[dialog_key] = old_value
        notify_error("Ошибка при удалении данных профиля")
    return ok


