PAGE_MAIN = "main"
PAGE_FEATURES = "features"
PAGE_DATA = "data"
PAGE_BACKUP_IMPORT = "backup_import"
PAGE_REPAIR = "repair"
PAGE_SUPPORT = "support"
PAGE_DETAILS = "details"
PAGE_ABOUT = "about"


def create_settings(page_id=PAGE_MAIN):
    S.load()
    health = get_storage_health()
    subpage = open_settings_page

    if isinstance(page_id, tuple) and len(page_id) == 2 and page_id[0] == "backup_file":
        filename = page_id[1]
        summary = backup_file_summary(filename)
        return [
            Header("Резервная копия"),
            Divider("Выберите, как восстановить данные из этой копии."),
            Divider(f"Размер: {summary['size_label']}"),
            Divider(f"Дата: {summary['created_label']}"),
            Divider(f"Профилей: {summary['peer_count']}"),
            Text(
                text="Заменить",
                subtext="Полностью заменить текущие данные. Перед импортом автоматически создаётся страховочная копия, при ошибке выполняется откат.",
                icon="msg_delete",
                red=True,
                on_click=lambda _: confirm_backup_import(filename, "replace"),
            ),
            Text(
                text="Объединить",
                subtext="Сохранить текущие данные и аккуратно объединить их с резервной копией без дублей.",
                icon="msg_download",
                accent=True,
                on_click=lambda _: confirm_backup_import(filename, "merge"),
            ),
            Header("Технические сведения"),
            Divider(f"Файл: {summary['filename']}"),
            Divider(f"Версия плагина: {summary['version']}"),
            Divider(f"Источник: {summary['plugin']}"),
            Divider(f"Путь: {summary['path']}"),
        ]

    if page_id == PAGE_FEATURES:
        return [
            Header("Защита и лимиты"),
            Divider("Два основных модуля, без лишних технических деталей."),
            Switch(
                key="enable_forward_bypass",
                text="Снять лимит выделения и удаления",
                subtext="Позволяет работать с большими пачками сообщений без лимита 100.",
                default=S.enable_forward_bypass,
                icon="msg_share",
                on_change=on_forward_toggle,
            ),
            Switch(
                key="enable_peer_info_saver",
                text="Сохранять данные профиля",
                subtext="Сохраняет полезные поля профиля и восстанавливает их, если Telegram перестал их отдавать.",
                default=S.enable_peer_info_saver,
                icon="msg_openprofile",
                on_change=on_peer_saver_toggle,
            ),
            Header("Что входит"),
            Divider("Страна телефона, месяц регистрации, даты изменения имени и фото."),
            Divider("Если используются похожие старые плагины, лучше выключить их, чтобы избежать конфликтов."),
        ]

    if page_id == PAGE_DATA:
        return [
            Header("Данные и резервные копии"),
            Divider("Здесь собраны действия для сохранения, восстановления и очистки данных."),
            *divider_lines(backup_overview_lines()),
            Text(
                text="Создать резервную копию",
                subtext="Сохраняет текущее состояние плагина для безопасного восстановления.",
                icon="msg_share",
                accent=True,
                on_click=lambda _: export_backup(),
            ),
            Text(
                text="Импортировать резервную копию",
                subtext="Открывает список копий с режимами замены и объединения.",
                icon="msg_download",
                accent=True,
                create_sub_fragment=subpage(PAGE_BACKUP_IMPORT),
            ),
            Text(
                text="Восстановить последнюю копию",
                subtext="Быстро вернуть последнее сохранённое состояние. Перед заменой создаётся страховочная копия.",
                icon="msg_restore",
                on_click=lambda _: confirm_restore_latest_backup(),
            ),
            Text(
                text="Очистить локальные данные",
                subtext="Удаляет только данные UtilitiesPro. Резервные копии остаются нетронутыми.",
                icon="msg_delete",
                red=True,
                on_click=lambda _: wipe_saved_peer_data(),
            ),
        ]

    if page_id == PAGE_BACKUP_IMPORT:
        files = list_backup_files()
        entries = [Header("Импорт резервной копии"), Divider("Выберите копию для восстановления или объединения.")]
        if not files:
            entries.append(Divider("Резервные копии пока не найдены."))
            return entries
        entries.append(Divider(f"Найдено копий: {len(files)}"))
        for filename in files:
            summary = backup_file_summary(filename)
            entries.append(Text(
                text=summary["created_label"],
                subtext=f"Профилей: {summary['peer_count']} · Размер: {summary['size_label']}",
                icon="msg_download",
                create_sub_fragment=subpage(("backup_file", filename)),
            ))
        return entries

    if page_id == PAGE_REPAIR:
        old_info = health["old_info"]
        entries = [
            Header("Исправление проблем"),
            Divider(main_status_badge(health)),
            Divider(main_status_text(health)),
            Text(
                text="Проверить",
                subtext="Проверяет данные и показывает понятный статус без технического шума.",
                icon="msg_stats",
                accent=True,
                on_click=lambda _: run_health_check_now(),
            ),
            Text(
                text="Исправить автоматически",
                subtext="Сам выполняет основные шаги восстановления и проверяет результат.",
                icon="msg_download_settings",
                accent=True,
                on_click=lambda _: auto_fix_now(),
            ),
            Text(
                text="Оптимизировать",
                subtext="Аккуратно пересобирает локальные данные и оставляет страховочную копию.",
                icon="msg_settings",
                on_click=lambda _: optimize_storage_now(),
            ),
        ]
        if old_info.get("exists"):
            entries.append(Text(
                text="Импортировать старые сохранения",
                subtext=f"Найдено записей: {old_info['count']}. Оригинал останется нетронутым.",
                icon="msg_download",
                on_click=lambda _: import_old_storage_now(),
            ))
        if has_resolved_legacy_storage():
            entries.append(Text(
                text="Перенести в текущее хранилище",
                subtext="Помогает закрепить найденные старые данные в актуальном месте хранения.",
                icon="files_storage",
                on_click=lambda _: migrate_detected_legacy_now(),
            ))
        entries.extend(divider_lines([
            f"Профилей сохранено: {health['peer_count']}",
        ]))
        return entries

    if page_id == PAGE_SUPPORT:
        return [
            Header("Поддержка и диагностика"),
            Divider("Если всё работает нормально, сюда обычно заходить не нужно."),
            *divider_lines(support_summary_lines()),
            Text(
                text="Экспортировать отчёт",
                subtext="Сохраняет файл для диагностики и отправки разработчику при проблеме.",
                icon="msg_share",
                accent=True,
                on_click=lambda _: export_debug_logs(),
            ),
            Text(
                text="Очистить логи",
                subtext="Удаляет накопленные диагностические события из памяти плагина.",
                icon="msg_delete",
                red=True,
                on_click=lambda _: clear_debug_logs(),
            ),
            Text(
                text="Технические сведения",
                subtext="Показывает пути, источники хранения и расширенный технический отчёт отдельно от основного экрана.",
                icon="msg_info",
                create_sub_fragment=subpage(PAGE_DETAILS),
            ),
        ]

    if page_id == PAGE_DETAILS:
        return [
            Header("Технический отчёт"),
            Divider("Раздел для расширенной диагностики. Здесь собраны внутренние детали, пути и статусы hooks."),
            Switch(
                key="enable_debug_logs",
                text="Подробные логи",
                subtext=f"Сейчас {'включены' if S.enable_debug_logs else 'выключены'} · событий в памяти: {len(debug_events)}",
                default=S.enable_debug_logs,
                icon="msg_stats",
                on_change=on_debug_logs_toggle,
            ),
            *divider_lines(advanced_diagnostics_lines()),
        ]

    if page_id == PAGE_ABOUT:
        return [
            Header("О плагине"),
            Divider("UtilitiesPro объединяет обход лимитов, сохранение полезных данных профиля и безопасные резервные копии."),
            Divider(f"Версия: {__version__}"),
            Divider("Главный автор форка: @VibeSPluginS"),
            Divider("Помощь с кодом: @kvuco"),
            Divider("Автор исходной идеи: @zwylair"),
            Header("Что умеет"),
            Divider("Работает локально и не требует внешних библиотек."),
            Divider("Сохраняет данные профиля и помогает восстановить их, если Telegram перестал их отдавать."),
            Divider("Поддерживает безопасное резервное копирование и восстановление со страховочной копией."),
        ]

    return [
        Header("UtilitiesPro"),
        Divider(main_status_badge(health)),
        Divider(main_status_text(health)),
        Header("Быстрые действия"),
        Text(
            text="Проверить",
            subtext="Быстро проверяет состояние данных и показывает понятный результат.",
            icon="msg_stats",
            accent=True,
            on_click=lambda _: run_health_check_now(),
        ),
        Text(
            text="Исправить автоматически",
            subtext="Сам выполняет основные шаги восстановления, если что-то пошло не так.",
            icon="msg_download_settings",
            accent=True,
            on_click=lambda _: auto_fix_now(),
        ),
        Text(
            text="Создать резервную копию",
            subtext="Сохраняет текущее состояние плагина для безопасного восстановления.",
            icon="msg_share",
            on_click=lambda _: export_backup(),
        ),
        Text(
            text="Восстановить последнюю копию",
            subtext="Возвращает последнее сохранённое состояние в пару нажатий.",
            icon="msg_restore",
            on_click=lambda _: confirm_restore_latest_backup(),
        ),
        Header("Разделы"),
        Text(
            text="Основные функции",
            subtext=f"Лимиты: {'включены' if S.enable_forward_bypass else 'выключены'} · Профиль: {'включён' if S.enable_peer_info_saver else 'выключен'}",
            icon="msg_openprofile",
            accent=True,
            create_sub_fragment=subpage(PAGE_FEATURES),
        ),
        Text(
            text="Данные и резервные копии",
            subtext="Импорт, экспорт, очистка и восстановление сохранённых данных.",
            icon="files_storage",
            accent=True,
            create_sub_fragment=subpage(PAGE_DATA),
        ),
        Text(
            text="Исправление проблем",
            subtext=health["description"],
            icon="msg_download_settings",
            accent=True,
            create_sub_fragment=subpage(PAGE_REPAIR),
        ),
        Text(
            text="Поддержка и диагностика",
            subtext="Отчёты и технические детали вынесены отдельно, чтобы не перегружать основной экран.",
            icon="msg_info",
            create_sub_fragment=subpage(PAGE_SUPPORT),
        ),
        Text(
            text="О плагине",
            subtext="Авторы, возможности и краткая справка.",
            icon="msg_info",
            create_sub_fragment=subpage(PAGE_ABOUT),
        ),
    ]


# ─────────────────────────────────────────────────────────────
# Main plugin
# ─────────────────────────────────────────────────────────────

class UtilitiesPro(BasePlugin):
    def on_plugin_load(self):
        global current_plugin, MessagesControllerClass, MessagesControllerClassSource
        current_plugin = self
        MessagesControllerClass = None
        MessagesControllerClassSource = None
        S.load()
        hook_setup_diag.clear()
        bypass_setup_diag.clear()
        update_runtime_diag(
            hook_setup_time=None,
            hook_setup_summary=None,
            bypass_setup_status=None,
            bypass_setup_summary=None,
            messages_controller_class_source=None,
            messages_controller_method_count=None,
        )
        debug_log(
            "plugin_loaded",
            force=True,
            version=__version__,
            debug_enabled=S.enable_debug_logs,
            peer_saver_enabled=S.enable_peer_info_saver,
            forward_enabled=S.enable_forward_bypass,
        )
        peer_storage.ensure_loaded()
        forward_ok = setup_forward_limit_bypass(self)
        peer_ok = setup_peer_info_saver(self)
        self.add_hook("TL_messages_forwardMessages")
        debug_log(
            "plugin_setup_status",
            force=True,
            forward_ok=forward_ok,
            peer_ok=peer_ok,
            peer_count=peer_storage.count(),
            hook_summary=runtime_diag.get("hook_setup_summary"),
        )
        logger.info("Setup status: forward=%s peer=%s", forward_ok, peer_ok)
        logger.info("Loaded.")

    def on_plugin_unload(self):
        global current_plugin
        selector_hook.clear_message_storage()
        dismiss_active_dialogs()
        current_plugin = None
        logger.info("Unloaded.")

    def create_settings(self):
        global current_plugin
        current_plugin = self
        return create_settings()

    def pre_request_hook(self, req_name, account, req):
        if req_name == "TL_messages_forwardMessages" and S.enable_forward_bypass:
            selector_hook.clear_message_storage()
        return HookResult()
