def notify_info(message):
    fragment = get_last_fragment()
    BulletinHelper.show_info(f"{PLUGIN_PREFIX}: {message}", fragment)


def notify_success(message):
    fragment = get_last_fragment()
    BulletinHelper.show_success(f"{PLUGIN_PREFIX}: {message}", fragment)


def notify_error(message):
    fragment = get_last_fragment()
    BulletinHelper.show_error(f"{PLUGIN_PREFIX}: {message}", fragment)


def run_ui(fn):
    run_on_ui_thread(fn)


def arraylist_to_list(value):
    return list(value.toArray()) if value and value.size() > 0 else []


def iterable_to_arraylist(items):
    result = ArrayList()
    for item in items:
        result.add(item)
    return result


def split_list_into_chunks(items, chunk_size):
    return [items[i:i + chunk_size] for i in range(0, len(items), chunk_size)]


def now_label():
    return datetime.now().strftime("%Y-%m-%d %H:%M:%S")


def update_runtime_diag(**kwargs):
    runtime_diag.update(kwargs)


def compact_value(value, max_len=140):
    text = str(value)
    return text if len(text) <= max_len else text[:max_len] + "..."


def peer_field_snapshot(dumped):
    if not isinstance(dumped, dict):
        return {}
    keys = list(dumped.keys())
    important = {}
    for field in PRECIOUS_PEER_FIELDS + IMPORTANT_PEER_STATE_FIELDS:
        if field in dumped:
            important[field] = dumped.get(field)
    return {
        "count": len(keys),
        "keys": keys[:24],
        "important": important,
    }


def debug_log(event, force=False, **data):
    if not force and not getattr(S, "enable_debug_logs", False):
        return
    record = {
        "time": now_label(),
        "event": event,
    }
    for key, value in data.items():
        if isinstance(value, dict):
            record[key] = value
        elif isinstance(value, (list, tuple)):
            record[key] = [compact_value(item, 80) for item in value[:30]]
        else:
            record[key] = compact_value(value)
    debug_events.append(record)
    if len(debug_events) > MAX_DEBUG_EVENTS:
        del debug_events[:len(debug_events) - MAX_DEBUG_EVENTS]


def format_method_signature(method):
    try:
        params = []
        for param_type in method.getParameterTypes():
            try:
                params.append(param_type.getName())
            except Exception:
                params.append(str(param_type))
        return f"{method.getName()}({', '.join(params)})"
    except Exception:
        return str(method)


def get_declared_method_signatures(clazz, limit=40):
    try:
        methods = list(clazz.getDeclaredMethods())
    except Exception:
        return None, []
    signatures = [format_method_signature(method) for method in methods]
    return len(signatures), signatures[:limit]


def get_named_method_signatures(clazz, method_name, limit=20):
    if not clazz:
        return []
    try:
        methods = [method for method in clazz.getDeclaredMethods() if method.getName() == method_name]
    except Exception:
        return []
    return [format_method_signature(method) for method in methods[:limit]]


def get_method_signatures_by_tokens(clazz, tokens, limit=40):
    if not clazz:
        return []
    token_list = [str(token).lower() for token in tokens if token]
    if not token_list:
        return []
    try:
        methods = list(clazz.getDeclaredMethods())
    except Exception:
        return []
    matches = []
    for method in methods:
        try:
            method_name = method.getName()
        except Exception:
            continue
        method_name_lower = method_name.lower()
        if any(token in method_name_lower for token in token_list):
            matches.append(format_method_signature(method))
            if len(matches) >= limit:
                break
    return matches


def record_hook_setup(method_name, found, attached, failures, signatures):
    hook_setup_diag[method_name] = {
        "found": found,
        "attached": attached,
        "failures": failures,
        "signatures": list(signatures),
    }
    update_runtime_diag(
        hook_setup_time=now_label(),
        hook_setup_summary=", ".join(
            f"{name}:{diag.get('attached', 0)}/{diag.get('found', 0)}"
            for name, diag in sorted(hook_setup_diag.items())
        ) or None,
    )
    debug_log(
        "hook_attach_result",
        force=True,
        method=method_name,
        found=found,
        attached=attached,
        failures=failures,
        signatures=signatures,
    )


def record_bypass_setup(step_name, ok, details=None):
    bypass_setup_diag[step_name] = {
        "ok": bool(ok),
        "details": details or {},
    }
    summary_parts = []
    failed_steps = []
    for name, diag in bypass_setup_diag.items():
        state = "ok" if diag.get("ok") else "fail"
        summary_parts.append(f"{name}:{state}")
        if not diag.get("ok"):
            failed_steps.append(name)
    update_runtime_diag(
        bypass_setup_status="ok" if not failed_steps else "failed",
        bypass_setup_summary=", ".join(summary_parts) or None,
    )
    debug_log(
        "bypass_setup_step",
        force=True,
        step=step_name,
        ok=bool(ok),
        details=details or {},
    )


def describe_runtime_class(clazz):
    if not clazz:
        return None
    try:
        return clazz.getName()
    except Exception:
        try:
            return str(clazz)
        except Exception:
            return None


def clone_data(value):
    if isinstance(value, dict):
        return {str(key): clone_data(item) for key, item in value.items()}
    if isinstance(value, list):
        return [clone_data(item) for item in value]
    return value


def set_storage_content(storage, content):
    storage.ensure_loaded()
    storage.content = clone_data(content if isinstance(content, dict) else {})


def storage_snapshot():
    peer_storage.ensure_loaded()
    return {
        "peer_records": normalize_peer_dump(peer_storage.content),
    }


def restore_snapshot(snapshot):
    set_storage_content(peer_storage, snapshot.get("peer_records"))
    peer_ok = peer_storage.write()
    return peer_ok


def human_date_from_iso(value):
    if not value:
        return "неизвестно"
    try:
        return datetime.fromisoformat(value).strftime("%d.%m.%Y %H:%M")
    except Exception:
        return str(value)


def human_size(num_bytes):
    try:
        value = float(num_bytes)
    except Exception:
        return "неизвестно"
    for unit in ("B", "KB", "MB", "GB"):
        if value < 1024.0 or unit == "GB":
            return f"{value:.1f} {unit}" if unit != "B" else f"{int(value)} B"
        value /= 1024.0


def hook_all_matching_methods(clazz, method_name, hook_factory, hook_method, preferred_param_counts=None):
    try:
        methods = [m for m in clazz.getDeclaredMethods() if m.getName() == method_name]
        if not methods:
            record_hook_setup(method_name, 0, 0, 0, [])
            logger.warning("Method not found: %s", method_name)
            return False
        preferred_param_counts = tuple(preferred_param_counts or ())
        if preferred_param_counts:
            preferred = [m for m in methods if m.getParameterCount() in preferred_param_counts]
            fallback = [m for m in methods if m.getParameterCount() not in preferred_param_counts]
            methods = preferred + fallback
        attached = 0
        failures = 0
        signatures = []
        for method in methods:
            signatures.append(format_method_signature(method))
            try:
                method.setAccessible(True)
                hook_instance = hook_factory()
                hook_method(method, hook_instance)
                attached += 1
            except Exception:
                failures += 1
                logger.error("Failed to hook overload %s:", format_method_signature(method), exc_info=True)
        record_hook_setup(method_name, len(methods), attached, failures, signatures)
        return attached > 0
    except Exception:
        logger.error("Failed to hook %s:", method_name, exc_info=True)
        record_hook_setup(method_name, 0, 0, 1, [])
        return False


def get_declared_method(clazz, method_name, *param_types):
    if not clazz:
        return None
    try:
        method = clazz.getDeclaredMethod(method_name, *param_types)
        method.setAccessible(True)
        return method
    except Exception:
        logger.error("Failed to resolve %s.%s:", clazz.getName() if hasattr(clazz, "getName") else clazz, method_name, exc_info=True)
        return None


def ensure_chat_activity_class():
    global ChatActivityClass
    if ChatActivityClass:
        return ChatActivityClass
    class_source = None
    try:
        ChatActivityClass = RuntimeChatActivity.getClass()
        class_source = "direct_import"
    except Exception:
        logger.error("Failed to resolve ChatActivity via direct import:", exc_info=True)
    if not ChatActivityClass:
        try:
            ChatActivityClass = jclass("org.telegram.ui.ChatActivity").getClass()
            class_source = "jclass"
        except Exception:
            logger.error("Failed to resolve ChatActivity via jclass:", exc_info=True)
    if not ChatActivityClass:
        try:
            ChatActivityClass = find_class("org.telegram.ui.ChatActivity")
            class_source = "find_class"
        except Exception:
            logger.error("Failed to resolve ChatActivity via find_class:", exc_info=True)
    method_count = None
    if ChatActivityClass:
        try:
            method_count = len(list(ChatActivityClass.getDeclaredMethods()))
        except Exception:
            method_count = None
    update_runtime_diag(
        chat_activity_class_source=class_source,
        chat_activity_method_count=method_count,
    )
    return ChatActivityClass


def ensure_messages_controller_class():
    global MessagesControllerClass, MessagesControllerClassSource
    if MessagesControllerClass:
        return MessagesControllerClass
    try:
        controller = get_messages_controller()
        if controller is not None:
            MessagesControllerClass = controller.getClass()
            MessagesControllerClassSource = "instance_class"
    except Exception:
        logger.error("Failed to resolve MessagesController from runtime instance:", exc_info=True)
    if not MessagesControllerClass:
        try:
            MessagesControllerClass = jclass("org.telegram.messenger.MessagesController").getClass()
            MessagesControllerClassSource = "jclass"
        except Exception:
            logger.error("Failed to resolve MessagesController via jclass:", exc_info=True)
    if not MessagesControllerClass:
        try:
            MessagesControllerClass = find_class("org.telegram.messenger.MessagesController")
            MessagesControllerClassSource = "find_class"
        except Exception:
            logger.error("Failed to resolve MessagesController via find_class:", exc_info=True)
    if not MessagesControllerClass:
        MessagesControllerClassSource = None
        logger.warning("MessagesController class not found")
    return MessagesControllerClass


def ensure_message_object_class():
    global MessageObjectClass
    if MessageObjectClass:
        return MessageObjectClass
    MessageObjectClass = find_class("org.telegram.messenger.MessageObject")
