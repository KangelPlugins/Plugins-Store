# =============================
# Общие утилиты
# =============================


def safe_str(value: Any, default: str = "") -> str:
    if value is None:
        return default
    try:
        text = str(value)
    except Exception:
        return default
    text = text.strip()
    return text if text else default


def normalize_key(*parts: str) -> str:
    text = " ".join([safe_str(p) for p in parts if safe_str(p)])
    text = text.lower()
    text = re.sub(r"\([^)]*\)|\[[^]]*\]", " ", text)
    text = re.sub(r"feat\.?|ft\.?", " ", text, flags=re.I)
    text = re.sub(r"[^\wа-яё]+", " ", text, flags=re.IGNORECASE)
    return re.sub(r"\s+", " ", text).strip()


def _trigram_similarity(a: str, b: str) -> float:
    """Сходство двух строк через триграммы по 3 символа без пробелов.
    Строки склеиваются (пробелы удаляются) и делятся на все триграммы по 3 символа:
    'code10 whitehammer' → 'code10whitehammer' → cod+ode+de1+e10+10w+0wh+whi+...
    code10whitehammer vs code80whitehammer: 12/15 совпадений ≈ 0.80 (>0.70 — подходит).

    Слабое место: чувствителен к ВСТАВКЕ/УДАЛЕНИЮ символа (не только замене).
    Одна пропущенная буква сдвигает все позиции после неё, и почти все триграммы
    после места опечатки больше не совпадают вообще — для коротких строк (типичная
    длина названия трека) это может обрушить сходство с 1.0 до 0.3-0.4 за одну
    опечатку. См. levenshtein_ratio ниже, который этого не делает.
    """
    if not a and not b:
        return 1.0
    if not a or not b:
        return 0.0
    if a == b:
        return 1.0

    def get_trigrams(s: str):
        # Убираем все пробелы — название и автор сливаются в одну строку
        s = s.replace(" ", "")
        if len(s) < 3:
            return {s} if s else set()
        return {s[i:i + 3] for i in range(len(s) - 2)}

    set_a = get_trigrams(a)
    set_b = get_trigrams(b)
    if not set_a and not set_b:
        return 1.0
    if not set_a or not set_b:
        return 0.0
    intersection = len(set_a & set_b)
    denom = max(len(set_a), len(set_b))
    if denom == 0:
        return 0.0
    return intersection / denom


def levenshtein_ratio(a: str, b: str) -> float:
    """Сходство через расстояние Левенштейна, нормализованное по длине.
    В отличие от триграмм, одна вставленная/пропущенная буква стоит ровно
    одну "правку" независимо от её позиции в строке — без каскадного эффекта
    на весь хвост строки. Поэтому это сходство устойчиво именно к типичным
    опечаткам пользователя (лишняя/пропущенная/перепутанная буква).

    Пробелы убираются (как и в _trigram_similarity), чтобы 'the devil' и
    'thedevil' считались одинаковыми.
    """
    a = a.replace(" ", "")
    b = b.replace(" ", "")
    if not a and not b:
        return 1.0
    if not a or not b:
        return 0.0
    if a == b:
        return 1.0

    len_a, len_b = len(a), len(b)
    # Классический DP расстояния Левенштейна (без кириллицы/латиницы спец-случаев —
    # normalize_key уже привела строки к нижнему регистру и убрала пунктуацию).
    prev_row = list(range(len_b + 1))
    for i in range(1, len_a + 1):
        curr_row = [i] + [0] * len_b
        char_a = a[i - 1]
        for j in range(1, len_b + 1):
            cost_sub = prev_row[j - 1] + (0 if char_a == b[j - 1] else 1)
            cost_del = prev_row[j] + 1
            cost_ins = curr_row[j - 1] + 1
            curr_row[j] = min(cost_sub, cost_del, cost_ins)
        prev_row = curr_row

    distance = prev_row[len_b]
    # ВАЖНО: нормализуем на min(len), а не max(len). При нормализации на max
    # короткая строка против длинной получает обманчиво высокое сходство просто
    # потому что знаменатель большой — например, 'playastation' (12) и 'auditt' (6)
    # отличаются на 9 правок, что огромно относительно короткой строки (9/6 > 100%),
    # но даёт 0.25 при делении на 12. Настоящая опечатка — это всегда МАЛО правок
    # относительно более короткой из двух строк (обычно 1-2), поэтому min(len) —
    # правильная база для отличия "опечатка" от "просто другое слово".
    shorter = min(len_a, len_b)
    if shorter == 0:
        return 0.0
    return max(0.0, 1.0 - (distance / shorter))


def ngram_similarity(a: str, b: str, n: int = 3) -> float:
    """Итоговое сходство двух строк — берём максимум из триграммного сходства
    и сходства по Левенштейну.

    Почему максимум, а не среднее: у методов разные слабые места.
    - Триграммы плохо переживают вставку/удаление символа (см. _trigram_similarity).
    - Левенштейн плохо переживает изменение порядка слов/частей строки
      (например, 'Artist - Title' vs 'Title - Artist' даёт большое расстояние,
      хотя по сути это та же пара).
    Беря максимум, мы засчитываем совпадение, если хотя бы один метод его видит —
    это безопаснее в сторону "не отбросить правильный трек из-за опечатки",
    а не наоборот (ложные срабатывания всё равно дополнительно отсекаются
    проверкой по duration и artist в _choose_best_candidate).
    """
    return max(_trigram_similarity(a, b), levenshtein_ratio(a, b))


def dp(context: Any, value: int) -> int:
    try:
        density = context.getResources().getDisplayMetrics().density
        return int(value * density + 0.5)
    except Exception:
        return value


def _decode_bitmap_bounded(path: str, max_dimension: int) -> Optional["Bitmap"]:
    """Декодирует файл в Bitmap, ограничивая итоговый размер по большей стороне
    через inSampleSize. Без этого decodeFile грузит картинку в её исходном
    разрешении (обложки треков из Telegram нередко 2000-3000px+), что на
    нативной графической куче легко даёт OutOfMemoryError/SIGSEGV — крэш,
    который убивает процесс полностью и не долетает до Python/Java
    exception-перехватчиков."""
    try:
        bounds = BitmapFactory.Options()
        bounds.inJustDecodeBounds = True
        BitmapFactory.decodeFile(path, bounds)
        src_w = int(bounds.outWidth)
        src_h = int(bounds.outHeight)
        if src_w <= 0 or src_h <= 0:
            return None

        sample = 1
        largest_side = max(src_w, src_h)
        while largest_side // (sample * 2) >= max_dimension:
            sample *= 2

        options = BitmapFactory.Options()
        options.inPreferredConfig = Bitmap.Config.ARGB_8888
        options.inSampleSize = sample
        return BitmapFactory.decodeFile(path, options)
    except BaseException as e:
        _log_safe("_decode_bitmap_bounded", e)
        return None


def _safe_pil_source(src_path: str, max_dimension: int) -> Optional[str]:
    """Готовит гарантированно небольшой JPEG-файл из обложки произвольного
    размера/формата, чтобы PIL (Image.open) никогда не видел оригинал.

    Почему это нужно: PIL.Image.draft() уменьшает память при декодировании
    ТОЛЬКО для JPEG. Если обложка PNG (частый случай для Telegram), draft()
    молча ничего не делает, и Image.open(...).convert("RGB") декодирует
    картинку в её исходном разрешении (обложки нередко 2000-3000px+) целиком
    в Python-память — это тот же класс краша (OOM/SIGSEGV, убивает процесс
    целиком, минуя любые try/except), от которого _decode_bitmap_bounded уже
    защищает нативный Android-путь, но не PIL-путь (_make_blurred_cache,
    _extract_ambient_palette).

    Решение: всегда сначала прогоняем исходник через тот же нативный
    bounded-декодер (inSampleSize, никогда не держит полное разрешение в
    памяти), сохраняем уменьшенный результат во временный JPEG, и только
    этот маленький файл отдаём дальше в PIL — независимо от формата исходника.
    """
    try:
        if not src_path or not os.path.exists(src_path):
            return None
        cache_dir = os.path.join(Plugin.dir_path(), "cover_cache")
        os.makedirs(cache_dir, exist_ok=True)
        suffix = hashlib.md5(
            "{}|{}".format(src_path, max_dimension).encode("utf-8", "ignore")
        ).hexdigest()[:16]
        out_path = os.path.join(cache_dir, "pil_safe_{}.jpg".format(suffix))

        try:
            if os.path.exists(out_path) and os.path.getmtime(out_path) >= os.path.getmtime(src_path):
                return out_path
        except Exception:
            pass

        bmp = _decode_bitmap_bounded(src_path, max_dimension)
        if bmp is None:
            return None
        fos = FileOutputStream(out_path)
        try:
            bmp.compress(Bitmap.CompressFormat.JPEG, 90, fos)
            fos.flush()
        finally:
            fos.close()
        return out_path
    except BaseException as e:
        _log_safe("_safe_pil_source", e)
        return None


def _draw_play_icon(canvas: "Canvas", size: int, color: int) -> None:
    paint = Paint()
    paint.setAntiAlias(True)
    paint.setColor(color)
    paint.setStyle(Paint.Style.FILL)
    path = Path()
    pad_x = size * 0.30
    pad_y = size * 0.18
    path.moveTo(pad_x, pad_y)
    path.lineTo(size - pad_x * 0.85, size * 0.5)
    path.lineTo(pad_x, size - pad_y)
    path.close()
    canvas.drawPath(path, paint)


def _draw_pause_icon(canvas: "Canvas", size: int, color: int) -> None:
    paint = Paint()
    paint.setAntiAlias(True)
    paint.setColor(color)
    paint.setStyle(Paint.Style.FILL)
    bar_w = size * 0.16
    gap = size * 0.14
    top = size * 0.2
    bottom = size * 0.8
    cx = size / 2.0
    left_x = cx - gap / 2.0 - bar_w
    right_x = cx + gap / 2.0
    r = size * 0.03
    canvas.drawRoundRect(RectF(left_x, top, left_x + bar_w, bottom), r, r, paint)
    canvas.drawRoundRect(RectF(right_x, top, right_x + bar_w, bottom), r, r, paint)


def _draw_heart_icon(canvas: "Canvas", size: int, color: int, filled: bool) -> None:
    paint = Paint()
    paint.setAntiAlias(True)
    paint.setColor(color)
    if filled:
        paint.setStyle(Paint.Style.FILL)
    else:
        paint.setStyle(Paint.Style.STROKE)
        paint.setStrokeWidth(size * 0.085)
        paint.setStrokeJoin(Paint.Join.ROUND)
        paint.setStrokeCap(Paint.Cap.ROUND)
    w = float(size)
    h = float(size)
    path = Path()
    path.moveTo(w * 0.5, h * 0.82)
    path.cubicTo(w * 0.05, h * 0.55, w * 0.08, h * 0.16, w * 0.32, h * 0.16)
    path.cubicTo(w * 0.46, h * 0.16, w * 0.5, h * 0.30, w * 0.5, h * 0.30)
    path.cubicTo(w * 0.5, h * 0.30, w * 0.54, h * 0.16, w * 0.68, h * 0.16)
    path.cubicTo(w * 0.92, h * 0.16, w * 0.95, h * 0.55, w * 0.5, h * 0.82)
    path.close()
    canvas.drawPath(path, paint)


def make_icon_drawable(context: Any, size_dp: int, color: int, draw_fn) -> Optional["BitmapDrawable"]:
    """Рисует иконку на Bitmap и возвращает BitmapDrawable с явно заданными bounds."""
    size_px = max(1, dp(context, size_dp))
    for cfg in [Bitmap.Config.ARGB_8888, Bitmap.Config.ARGB_4444, Bitmap.Config.RGB_565]:
        try:
            bmp = Bitmap.createBitmap(size_px, size_px, cfg)
            cv = Canvas(bmp)
            draw_fn(cv, size_px, color)
            d = BitmapDrawable(context.getResources(), bmp)
            d.setBounds(0, 0, size_px, size_px)
            return d
        except BaseException as e:
            _log_safe("make_icon_drawable cfg=" + str(cfg), e)
    return None


def float_safe(value: Any, default: float = 0.0) -> float:
    try:
        return float(value)
    except Exception:
        return default


def clamp_int(value: int, minimum: int, maximum: int) -> int:
    return max(minimum, min(maximum, int(value)))


def setting_int(plugin: Any, key: str, default: int, minimum: int, maximum: int) -> int:
    try:
        raw = plugin.get_setting(key, str(default)) if plugin else str(default)
        return clamp_int(int(float(str(raw).replace(',', '.').strip())), minimum, maximum)
    except Exception:
        return clamp_int(default, minimum, maximum)


def setting_float(plugin: Any, key: str, default: float, minimum: float, maximum: float) -> float:
    try:
        raw = plugin.get_setting(key, str(default)) if plugin else str(default)
        value = float(str(raw).replace(',', '.').strip())
        return max(minimum, min(maximum, value))
    except Exception:
        return max(minimum, min(maximum, float(default)))


def setting_bool(plugin: Any, key: str, default: bool) -> bool:
    try:
        raw = plugin.get_setting(key, default) if plugin else default
        if isinstance(raw, bool):
            return raw
        return str(raw).strip().lower() in ("1", "true", "yes", "да", "on")
    except Exception:
        return default


def argb_gray(alpha: int, value: int) -> int:
    return Color.argb(clamp_int(alpha, 0, 255), clamp_int(value, 0, 255), clamp_int(value, 0, 255), clamp_int(value, 0, 255))


def _log_safe(tag: str, e: BaseException) -> None:
    """Логирует ошибку, но никогда сама не бросает исключение наружу."""
    try:
        inst = Plugin.get_instance()
        if inst:
            inst.log(f"[{tag}] " + str(e))
            inst.log(traceback.format_exc())
    except BaseException:
        pass



class ViewClickListener(dynamic_proxy(View.OnClickListener)):
    def __init__(self, callback):
        super().__init__()
        self.callback = callback

    def onClick(self, view):
        try:
            self.callback(view)
        except BaseException as e:
            _log_safe("ViewClickListener", e)


class DoubleTapLineClickListener(dynamic_proxy(View.OnClickListener)):
    """Лёгкий double-tap без GestureDetector: два клика по строке за короткое время."""
    def __init__(self, callback, threshold_sec: float = 0.34):
        super().__init__()
        self.callback = callback
        self.threshold_sec = threshold_sec
        self.last_click_at = 0.0

    def onClick(self, view):
        try:
            now = time.time()
            if now - self.last_click_at <= self.threshold_sec:
                self.last_click_at = 0.0
                self.callback(view)
            else:
                self.last_click_at = now
        except BaseException as e:
            _log_safe("DoubleTapLineClickListener", e)


class TelegramUtils:
    @staticmethod
    def get_icon_id(name: str) -> int:
        context = get_last_fragment().getContext()
        return context.getResources().getIdentifier(name, "drawable", context.getPackageName())

    @staticmethod
    def get_locale_id(name: str) -> int:
        context = get_last_fragment().getContext()
        return context.getResources().getIdentifier(name, "string", context.getPackageName())

    @classmethod
    def locale_string(cls, name: str) -> str:
        try:
            return TGLocale.getString(cls.get_locale_id(name))
        except Exception:
            return name


# =============================
# Данные трека / текста
# =============================


class TrackInfo:
    def __init__(self, title: str, artist: str, duration: float, query_fallback: str = ""):
        self.title = title
        self.artist = artist
        self.duration = duration
        self.query_fallback = query_fallback

    @property
    def display_title(self) -> str:
        return self.title or self.query_fallback or "Неизвестный трек"

    @property
    def display_artist(self) -> str:
        return self.artist or "Неизвестный артист"

    @property
    def query(self) -> str:
        if self.artist and self.title:
            return f"{self.artist} {self.title}"
        if self.title:
            return self.title
        return self.query_fallback

    @property
    def cache_key(self) -> str:
        # В ключ добавлен провайдер и версия обработки строк, чтобы старый кэш
        # без музыкальных пауз не подмешивался к новой разметке.
        return normalize_key("lrclib", "gapnotes_v1", self.artist, self.title, self.query_fallback)


class LyricsResult:
    def __init__(
        self,
        lines: List[Dict[str, Any]],
        synced: bool,
        source: str = "LRCLIB",
        source_url: Optional[str] = None,
        matched_title: str = "",
        matched_artist: str = "",
    ):
        self.lines = lines
        self.synced = synced
        self.source = source
        self.source_url = source_url
        self.matched_title = matched_title
        self.matched_artist = matched_artist

    def to_cache(self) -> Dict[str, Any]:
        return {
            "lines": self.lines,
            "synced": self.synced,
            "source": self.source,
            "source_url": self.source_url,
            "matched_title": self.matched_title,
            "matched_artist": self.matched_artist,
            "saved_at": int(time.time()),
        }

    @classmethod
    def from_cache(cls, item: Dict[str, Any]) -> Optional["LyricsResult"]:
        try:
            lines = item.get("lines") or []
            if not lines:
                return None
            return cls(
                lines=lines,
                synced=bool(item.get("synced", False)),
                source=safe_str(item.get("source"), "LRCLIB"),
                source_url=item.get("source_url"),
                matched_title=safe_str(item.get("matched_title")),
                matched_artist=safe_str(item.get("matched_artist")),
            )
        except Exception:
            return None


# =============================
# LRCLIB provider
# =============================


class LrclibLyricsProvider:
    def __init__(self, plugin: "Plugin"):
        self.plugin = plugin

    def get_lyrics(self, track: TrackInfo) -> LyricsResult:
        cached = self.plugin.cache_get(track.cache_key)
        if cached:
            result = LyricsResult.from_cache(cached)
            if result:
                search_log("=== Трек: '{}' - '{}' (длительность {:.0f}с) | результат взят из КЭША -> '{}' - '{}' ===".format(
                    safe_str(track.title), safe_str(track.artist), track.duration,
                    result.matched_title, result.matched_artist))
                return result

        if not track.query:
            raise Exception("Не удалось определить название трека")

        data = self._get_exact(track)
        if data:
            search_log("=== Трек: '{}' - '{}' (длительность {:.0f}с) | НАЙДЕНО ТОЧНЫМ запросом /api/get -> '{}' - '{}' ===".format(
                safe_str(track.title), safe_str(track.artist), track.duration,
                safe_str(data.get("trackName")), safe_str(data.get("artistName"))))
        if not data:
            data = self._search_best(track)
        if not data:
            raise Exception("LRCLIB не нашёл подходящий текст")

        result = self._record_to_result(data, track)
        self.plugin.cache_put(track.cache_key, result.to_cache())
        return result

    def _headers(self) -> Dict[str, str]:
        return {
            "User-Agent": LRCLIB_USER_AGENT,
            "Accept": "application/json",
        }

    def _get_exact(self, track: TrackInfo) -> Optional[Dict[str, Any]]:
        if not track.title:
            return None

        params: Dict[str, Any] = {"track_name": track.title}
        if track.artist:
            params["artist_name"] = track.artist
        if track.duration > 0:
            # LRCLIB API принимает duration в секундах.
            params["duration"] = int(round(track.duration))

        try:
            response = requests.get(LRCLIB_GET_URL, params=params, headers=self._headers(), timeout=(3.0, NETWORK_TIMEOUT))
            if response.status_code == 404:
                return None
            response.raise_for_status()
            data = response.json()
            if isinstance(data, dict) and (data.get("syncedLyrics") or data.get("plainLyrics") or data.get("instrumental")):
                return data
        except Exception as e:
            self.plugin.log("LRCLIB exact get failed: " + str(e))
        return None

    def _search_best(self, track: TrackInfo) -> Optional[Dict[str, Any]]:
        searches: List[Dict[str, Any]] = []

        # 1. Точный поиск по полям title + artist
        if track.title:
            by_fields: Dict[str, Any] = {"track_name": track.title}
            if track.artist:
                by_fields["artist_name"] = track.artist
            searches.append(by_fields)

        # 2. Полнотекстовый поиск по query (artist + title вместе)
        if track.query:
            searches.append({"q": track.query})

        # 3. Только по названию — на случай если артист неизвестен или написан иначе
        if track.title:
            searches.append({"q": track.title})

        # 4. Только по артисту — берём первые результаты и фильтруем через N-gram
        if track.artist:
            searches.append({"q": track.artist})

        # 5. Очищенное название без цифр и спецсимволов — ловит случаи типа "CocaCola" → "coca cola"
        if track.title:
            clean_title = re.sub(r"[^a-zа-яё\s]", " ", normalize_key(track.title), flags=re.I).strip()
            if clean_title and clean_title != normalize_key(track.title):
                q = (clean_title + " " + normalize_key(track.artist)).strip() if track.artist else clean_title
                searches.append({"q": q})

        seen_queries: set = set()
        unique_searches: List[Dict[str, Any]] = []
        for params in searches:
            key = str(sorted(params.items()))
            if key not in seen_queries:
                seen_queries.add(key)
                unique_searches.append(params)

        candidates: List[Dict[str, Any]] = []
        lock = threading.Lock()

        def do_search(params):
            # Запросы только по артисту без названия помечаем флагом artist_only=True.
            artist_only = list(params.keys()) == ["q"] and track.artist and normalize_key(params["q"]) == normalize_key(track.artist)
            try:
                response = requests.get(LRCLIB_SEARCH_URL, params=params, headers=self._headers(), timeout=(3.0, NETWORK_TIMEOUT))
                response.raise_for_status()
                data = response.json()
                self.plugin.log("LRCLIB search " + str(params) + " → " + str(len(data) if isinstance(data, list) else 0) + " results")
                if isinstance(data, list):
                    with lock:
                        for item in data:
                            if isinstance(item, dict):
                                if artist_only:
                                    item = dict(item)
                                    item["_artist_only_query"] = True
                                candidates.append(item)
            except Exception as e:
                self.plugin.log("LRCLIB search failed: " + str(e))

        # Запускаем не более 3 потоков одновременно батчами — баланс скорости и нагрузки.
        # Сначала самые важные запросы (точный + по query), потом остальные если не нашли.
        BATCH_SIZE = 3
        target_title_key = normalize_key(track.title)
        for batch_start in range(0, len(unique_searches), BATCH_SIZE):
            batch = unique_searches[batch_start:batch_start + BATCH_SIZE]
            threads = [threading.Thread(target=do_search, args=(p,), daemon=True) for p in batch]
            for t in threads:
                t.start()
            for t in threads:
                t.join(timeout=NETWORK_TIMEOUT + 1)
            # Ранняя остановка если уже нашли точное совпадение по названию
            if candidates and any(normalize_key(c.get("trackName", "")) == target_title_key for c in candidates):
                self.plugin.log("LRCLIB: found exact title match, stopping early")
                break

        if not candidates:
            self.plugin.log("LRCLIB: no candidates at all for: " + safe_str(track.query))
            search_log("LRCLIB: кандидатов не найдено для запроса '{}'".format(safe_str(track.query)))
            return None
        self.plugin.log("LRCLIB: total candidates: " + str(len(candidates)) + " for: " + safe_str(track.query))
        search_log("=== Трек: '{}' - '{}' (длительность {:.0f}с) | LRCLIB кандидатов: {} ===".format(
            safe_str(track.title), safe_str(track.artist), track.duration, len(candidates)))
        try:
            result = self._choose_best_candidate(track, candidates)
            if result:
                self.plugin.log("LRCLIB: best match: " + safe_str(result.get("trackName")) + " - " + safe_str(result.get("artistName")))
                search_log("LRCLIB: ПОБЕДИТЕЛЬ -> '{}' - '{}'".format(
                    safe_str(result.get("trackName")), safe_str(result.get("artistName"))))
            else:
                self.plugin.log("LRCLIB: _choose_best_candidate returned None")
                search_log("LRCLIB: ни один кандидат не прошёл порог отсечения")
            return result
        except Exception as e:
            self.plugin.log("LRCLIB: _choose_best_candidate crashed: " + str(e))
            import traceback as _tb
            self.plugin.log(_tb.format_exc())
            return None

    def _choose_best_candidate(self, track: TrackInfo, candidates: List[Dict[str, Any]]) -> Optional[Dict[str, Any]]:
        target_title = normalize_key(track.title)
        target_artist = normalize_key(track.artist)
        target_duration = track.duration

        best_score = -99999.0
        best_item = None
        seen_ids = set()

        for item in candidates:
            item_id = safe_str(item.get("id"))
            if item_id and item_id in seen_ids:
                continue
            if item_id:
                seen_ids.add(item_id)

            title = normalize_key(item.get("trackName"))
            artist = normalize_key(item.get("artistName"))
            duration = float_safe(item.get("duration"), 0.0)
            has_synced = bool(item.get("syncedLyrics"))
            has_plain = bool(item.get("plainLyrics"))
            instrumental = bool(item.get("instrumental"))

            if not has_synced and not has_plain and not instrumental:
                continue

            score = 0.0
            if has_synced:
                score += 40
            elif has_plain:
                score += 12
            if instrumental:
                score += 3

            # Скоринг по названию: точное совпадение > вхождение (пропорционально длине) > N-gram fuzzy
            if target_title and title:
                if title == target_title:
                    score += 32
                elif target_title in title or title in target_title:
                    # ВАЖНО: раньше тут был флэт +22 независимо от того, какую долю
                    # длинной строки покрывает совпадение. Из-за этого "cocacola" как
                    # подстрока в "rum and cocacola" получала почти те же баллы, что и
                    # настоящее почти-совпадение названия — и "CocaCola" - "CODE10"
                    # уверенно матчился на "Rum and Cocacola" - "The Andrews Sisters"
                    # (см. lyrics_search.log от 2026-06-28, gen=7). Теперь вхождение
                    # короткой строки в заметно более длинную даёт пропорционально
                    # меньше очков — точное совпадение коротких названий не страдает,
                    # а "случайное" совпадение хвоста длинной фразы — резко слабее.
                    coverage = min(len(target_title), len(title)) / max(len(target_title), len(title), 1)
                    score += 10 + 22 * coverage
                else:
                    sim = ngram_similarity(target_title, title)
                    # Линейно: 0.8+ sim = почти совпадение, 0.4 = слабое сходство
                    score += sim * 28

            # Скоринг по артисту: точное > вхождение > N-gram fuzzy
            if target_artist and artist:
                if artist == target_artist:
                    score += 28
                elif target_artist in artist or artist in target_artist:
                    score += 18
                else:
                    sim = ngram_similarity(target_artist, artist)
                    score += sim * 24

            # Длительность — самый надёжный якорь при fuzzy-совпадениях
            if target_duration > 0 and duration > 0:
                diff = abs(duration - target_duration)
                if diff <= 2:
                    score += 22
                elif diff <= 5:
                    score += 14
                elif diff <= 12:
                    score += 5
                else:
                    score -= min(20.0, diff / 3.0)

            # Мягкий штраф если оба поля совсем не похожи (ngram < 0.2)
            title_sim = ngram_similarity(target_title, title) if target_title and title else 0.5
            artist_sim = ngram_similarity(target_artist, artist) if target_artist and artist else 0.5
            if title_sim < 0.2 and artist_sim < 0.2:
                score -= 20

            duration_exact = (target_duration > 0 and duration > 0 and abs(duration - target_duration) <= 2)
            # Мягкое совпадение по длительности (до 10с) — используется только вместе с
            # точным артистом как резервный якорь для треков, зарегистрированных в LRCLIB
            # под другим именем. В остальных случаях применяется только duration_exact (≤2с).
            # Снижено с 15 до 10с: при 15с window трек "RoseWine" (122с) неверно
            # матчился на "Lamb" (108с, diff=14с) только потому что artist совпал.
            duration_close = (target_duration > 0 and duration > 0 and abs(duration - target_duration) <= 10)

            # Жёсткий штраф если название совсем не совпадает (title_sim < 0.25).
            # Исключение: если артист совпадает ТОЧНО (строгое равенство или кандидат
            # содержит target_artist как полное слово) И длительность совпадает с точностью
            # до 2с — трек, скорее всего, выпущен под другим названием (EP, альтернативное
            # имя и т.п.). Проверка artist_sim >= 0.85 исключает случай "data404 arlekin 40 000"
            # (другой трек того же артиста с коллабом), где artist_sim будет ~0.56.
            artist_exact = bool(
                target_artist and artist and (
                    artist == target_artist or artist_sim >= 0.85
                )
            )
            if target_title and title and title_sim < 0.25:
                if not (artist_exact and duration_close):
                    score -= 150

            # Симметричный жёсткий штраф: если совсем не совпадает АРТИСТ (а не
            # название) — например, частичное совпадение в названии вроде "show" /
            # "the show" не должно прокатывать мимо проверки, если артист при этом
            # вообще не тот ("CODE10 & RILEY BABY" vs "Lenka"). Без этого трек с
            # обычным/коротким названием мог найти совпадение у совершенно другого
            # артиста только за счёт slight title overlap.
            artist_contains = bool(
                target_artist and artist and (target_artist in artist or artist in target_artist)
            )
            if target_artist and artist and artist_sim < 0.25 and not artist_contains:
                score -= 150

            # Кандидаты из запроса "только по артисту" без совпадения по названию
            # штрафуем сильно — иначе побеждает первый синхронизированный трек артиста.
            # Исключение: точный артист (sim >= 0.85) + точная длительность — надёжный
            # якорь, скорее всего трек под другим именем (согласовано с логикой выше).
            if item.get("_artist_only_query") and title_sim < 0.25:
                if not (artist_exact and duration_close):
                    score -= 35

            if score > best_score:
                best_score = score
                best_item = item
            self.plugin.log("LRCLIB candidate: '{}' - '{}' score={:.1f} (title_sim={:.2f} artist_sim={:.2f})".format(
                title, artist, score, title_sim, artist_sim))
            search_log(
                "  кандидат: '{}' - '{}' | score={:.1f} title_sim={:.2f} artist_sim={:.2f} "
                "duration={:.0f}с (точно={}) synced={}".format(
                    title, artist, score, title_sim, artist_sim, duration,
                    duration_exact, has_synced,
                ))

        # Минимальный порог: если лучший кандидат слишком непохож — не возвращаем его.
        # Порог 45: синхронный трек (40) + хоть какое-то сходство по названию (>0).
        # Поднят с 25 до 45: score=54 при title_sim=0.00 не должен проходить
        # (пример: "Heeey Chiki Chiki" → "BULDOJKE RAGE SECURITY" только за артиста).
        MIN_SCORE_THRESHOLD = 45.0
        if best_item is not None and best_score < MIN_SCORE_THRESHOLD:
            self.plugin.log("LRCLIB: best score {:.1f} is below threshold, rejecting".format(best_score))
            return None

        # Дополнительная проверка: если победитель имеет нулевое сходство по названию
        # И не является исключением (точный артист + точная длительность) — отклоняем.
        # Это отсекает треки вида "любой трек этого артиста с подходящей длиной".
        if best_item is not None:
            best_title_sim = ngram_similarity(
                normalize_key(best_item.get("trackName", "")),
                target_title
            ) if target_title else 0.5
            best_artist_sim = ngram_similarity(
                normalize_key(best_item.get("artistName", "")),
                target_artist
            ) if target_artist else 0.5
            best_duration = float_safe(best_item.get("duration"), 0.0)
            best_duration_exact = (target_duration > 0 and best_duration > 0 and abs(best_duration - target_duration) <= 2)
            best_artist_exact = best_artist_sim >= 0.85
            if target_title and best_title_sim < 0.15 and not (best_artist_exact and best_duration_exact):
                self.plugin.log("LRCLIB: winner title_sim={:.2f} too low without duration_exact, rejecting".format(best_title_sim))
                search_log("LRCLIB: победитель отклонён — title_sim={:.2f} < 0.15 без точной длительности".format(best_title_sim))
                return None

        return best_item

    def _record_to_result(self, data: Dict[str, Any], track: Optional[TrackInfo] = None) -> LyricsResult:
        source_url = None
        try:
            if data.get("id") is not None:
                source_url = "https://lrclib.net/api/get/" + str(data.get("id"))
        except Exception:
            source_url = None

        if bool(data.get("instrumental")) and not data.get("plainLyrics") and not data.get("syncedLyrics"):
            return LyricsResult(
                lines=[{"time": 0.0, "text": "Инструментал"}],
                synced=True,
                source="LRCLIB",
                source_url=source_url,
                matched_title=safe_str(data.get("trackName")),
                matched_artist=safe_str(data.get("artistName")),
            )

        synced_text = safe_str(data.get("syncedLyrics"))
        if synced_text:
            duration = float_safe(data.get("duration"), 0.0)
            if duration <= 0 and track is not None:
                duration = float_safe(track.duration, 0.0)
            lines = self._parse_lrc(synced_text, duration)
            if lines:
                return LyricsResult(
                    lines=lines,
                    synced=True,
                    source="LRCLIB",
                    source_url=source_url,
                    matched_title=safe_str(data.get("trackName")),
                    matched_artist=safe_str(data.get("artistName")),
                )

        plain_text = safe_str(data.get("plainLyrics"))
        if plain_text:
            return LyricsResult(
                lines=self._plain_to_lines(plain_text),
                synced=False,
                source="LRCLIB",
                source_url=source_url,
                matched_title=safe_str(data.get("trackName")),
                matched_artist=safe_str(data.get("artistName")),
            )

        raise Exception("LRCLIB вернул запись, но без текста")

    def _parse_lrc(self, synced_lyrics: str, duration: float = 0.0) -> List[Dict[str, Any]]:
        lyric_events: List[Dict[str, Any]] = []
        empty_events: List[float] = []
        time_pattern = re.compile(r"\[(\d{1,3}):(\d{2})(?:[.:](\d{1,3}))?\]")

        for raw_line in synced_lyrics.replace("\r", "\n").split("\n"):
            raw_line = raw_line.strip()
            if not raw_line:
                continue

            matches = list(time_pattern.finditer(raw_line))
            if not matches:
                continue

            text = time_pattern.sub("", raw_line).strip()
            if re.match(r"^\[.+\]$", text):
                continue

            for match in matches:
                minutes = int(match.group(1))
                seconds = int(match.group(2))
                fraction_raw = match.group(3) or "0"
                if len(fraction_raw) == 1:
                    fraction = int(fraction_raw) / 10.0
                elif len(fraction_raw) == 2:
                    fraction = int(fraction_raw) / 100.0
                else:
                    fraction = int(fraction_raw[:3]) / 1000.0
                time_value = minutes * 60 + seconds + fraction

                # Пустые LRC-строки не показываем как пустоту, но сохраняем их как
                # точный момент окончания предыдущей вокальной строки/начала паузы.
                if not text:
                    empty_events.append(time_value)
                else:
                    lyric_events.append({"time": time_value, "text": text})

        lyric_events.sort(key=lambda item: float_safe(item.get("time"), 0.0))
        empty_events.sort()
        return self._inject_music_gap_markers(lyric_events, empty_events, duration)

    def _inject_music_gap_markers(
        self,
        lines: List[Dict[str, Any]],
        empty_times: List[float],
        duration: float = 0.0,
    ) -> List[Dict[str, Any]]:
        if not lines:
            return lines

        threshold = float(MUSIC_GAP_THRESHOLD_SEC)
        output: List[Dict[str, Any]] = []

        first_time = float_safe(lines[0].get("time"), 0.0)
        if first_time >= threshold:
            output.append({"time": 0.0, "text": MUSIC_GAP_MARKER, "pause": True})

        for index, line in enumerate(lines):
            output.append(line)
            current_start = float_safe(line.get("time"), 0.0)
            next_start = None
            if index + 1 < len(lines):
                next_start = float_safe(lines[index + 1].get("time"), 0.0)
            elif duration and duration > 0:
                next_start = float_safe(duration, 0.0)

            if next_start is None or next_start <= current_start:
                continue

            line_end = self._estimate_line_end_time(line, current_start, next_start, empty_times)
            if next_start - line_end >= threshold:
                # Если подряд уже есть такая же пауза на том же времени, не дублируем.
                if not output or safe_str(output[-1].get("text")) != MUSIC_GAP_MARKER or abs(float_safe(output[-1].get("time"), -9999.0) - line_end) > 0.05:
                    output.append({"time": line_end, "text": MUSIC_GAP_MARKER, "pause": True})

        output.sort(key=lambda item: float_safe(item.get("time"), 0.0))
        return output

    def _estimate_line_end_time(
        self,
        line: Dict[str, Any],
        current_start: float,
        next_start: float,
        empty_times: List[float],
    ) -> float:
        # Лучший вариант: LRCLIB иногда содержит пустую строку с таймкодом.
        # Считаем её настоящим концом предыдущей фразы.
        for empty_time in empty_times:
            if current_start < empty_time < next_start:
                return max(current_start, min(next_start, empty_time))

        # Если точного окончания строки нет, аккуратно оцениваем длительность по длине текста.
        text = safe_str(line.get("text"))
        estimated = len(text) / float(ESTIMATED_CHARS_PER_SEC) if text else ESTIMATED_MIN_LINE_DURATION_SEC
        estimated = max(float(ESTIMATED_MIN_LINE_DURATION_SEC), min(float(ESTIMATED_MAX_LINE_DURATION_SEC), estimated))
        return max(current_start, min(next_start, current_start + estimated))

    def _plain_to_lines(self, lyrics: str) -> List[Dict[str, Any]]:
        result: List[Dict[str, Any]] = []
        lyrics = lyrics.replace("\r", "\n")
        for raw_line in lyrics.split("\n"):
            line = raw_line.strip()
            if re.match(r"^\[.+\]$", line):
                continue
            result.append({"time": None, "text": line})
        while result and not safe_str(result[0].get("text")):
            result.pop(0)
        while result and not safe_str(result[-1].get("text")):
            result.pop()
        return result or [{"time": None, "text": "Текст пустой"}]



# =============================
# Lyrics Genius совместимость
# =============================
# Плагин пробует сначала LRCLIB (синхронизированные тексты с таймкодами).
# Если LRCLIB не нашёл текст, пробует lyrics_genius API как запасной вариант.
# Это обеспечивает совместимость с плагином lyrics_genius без конфликтов.

GENIUS_API_URL = "https://api.genius.com"

def _genius_search_candidates(query: str, per_page: int = 5, target_title: str = "") -> List[Dict[str, Any]]:
    """Ищет кандидатов через неофициальный поисковый эндпоинт сайта Genius
    (без токенов и официального API).

    Раньше использовался genius.com/api/search/multi — это общий эндпоинт,
    который мешает в одну выдачу песни, альбомы, страницы артистов и статьи.
    Топ-10 такой смешанной выдачи легко занимают популярные/мейнстримные
    результаты (например, реклама или официальные паблики "Coca-Cola"), и
    нишевый трек нужного исполнителя может просто не попасть в окно top_N —
    независимо от того, насколько хорошо или плохо совпадает написание имени
    артиста. Поэтому при опечатке вида 'CODE10' вместо 'CODE80' дело не в
    нашем локальном сравнении строк (Левенштейн и так спокойно переживает
    одну заменённую букву), а в том, что нужный трек даже не попадает к нам
    в список кандидатов для сравнения.

    Используем search/song — эндпоинт, отдающий только песни (без артистов/
    альбомов/статей), и при необходимости запрашиваем вторую страницу, чтобы
    окно поиска было шире top_10."""
    hits = _genius_search_song_endpoint(query, page=1, per_page=per_page)
    if not _has_strong_hit(hits, target_title):
        # Первая страница не дала близкого по названию совпадения — пробуем
        # вторую, вместо того чтобы полагаться только на ранжирование Genius.
        hits += _genius_search_song_endpoint(query, page=2, per_page=per_page)
    if not hits:
        # Запасной путь — старый смешанный эндпоинт, вдруг song-эндпоинт
        # недоступен/изменился, а multi всё ещё работает.
        hits = _genius_search_multi_endpoint(query, per_page=per_page)
    return hits


def _has_strong_hit(hits: List[Dict[str, Any]], target_title: str = "") -> bool:
    """Проверяет, есть ли среди уже найденных кандидатов хоть один с близким
    названием — если да, вторую страницу не запрашиваем, чтобы не тратить
    лишний запрос и время на типичный случай без опечаток. Сравнение через
    ngram_similarity (Левенштейн), а не точное равенство — оно переживает
    типичную опечатку в названии и не заставляет долбить вторую страницу там,
    где первая уже дала хороший кандидат."""
    if not hits:
        return False
    if not target_title:
        return len(hits) >= 3
    for h in hits:
        title = normalize_key(h.get("title", ""))
        if title and ngram_similarity(target_title, title) >= 0.6:
            return True
    return False


def _genius_request(url: str, query: str, page: int, per_page: int) -> Optional[Dict[str, Any]]:
    try:
        # Кодируем запрос вручную чтобы избежать ошибки latin-1 при наличии
        # кириллицы, спецсимволов (♰, ♱ и т.п.) в названии трека или артиста.
        try:
            encoded_q = requests.utils.quote(query, safe="")
        except Exception:
            # Запасной вариант: убираем всё что не ASCII
            encoded_q = query.encode("ascii", "ignore").decode("ascii")
        full_url = "{}?q={}&per_page={}&page={}".format(url, encoded_q, per_page, page)
        resp = requests.get(
            full_url,
            headers={
                "User-Agent": "Mozilla/5.0 (Linux; Android 10) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0 Mobile Safari/537.36",
                "X-Requested-With": "XMLHttpRequest",
                "Accept": "application/json",
                "Referer": "https://genius.com/search",
            },
            timeout=(3.0, NETWORK_TIMEOUT),
        )
        if resp.status_code != 200:
            search_log("Genius search: HTTP {} для '{}' (стр. {}, тело: {})".format(
                resp.status_code, query, page, safe_str(resp.text)[:200]))
            return None
        return resp.json()
    except Exception as e:
        search_log("Genius search упал для '{}' (стр. {}): {}".format(query, page, str(e)))
        return None


def _genius_search_song_endpoint(query: str, page: int = 1, per_page: int = 5) -> List[Dict[str, Any]]:
    """search/song — выдача только песен, без артистов/альбомов/статей."""
    hits: List[Dict[str, Any]] = []
    data = _genius_request("https://genius.com/api/search/song", query, page, per_page)
    if not data:
        return hits
    for hit in ((data.get("response") or {}).get("hits") or []):
        result = hit.get("result") or hit
        if result:
            hits.append(result)
    if not hits:
        search_log("Genius search/song: 0 кандидатов для '{}' (стр. {})".format(query, page))
    return hits


def _genius_search_multi_endpoint(query: str, per_page: int = 5) -> List[Dict[str, Any]]:
    """Старый смешанный эндпоинт — запасной вариант."""
    hits: List[Dict[str, Any]] = []
    data = _genius_request("https://genius.com/api/search/multi", query, 1, per_page)
    if not data:
        return hits
    sections = (data.get("response") or {}).get("sections") or []
    for sec in sections:
        for hit in (sec.get("hits") or []):
            if hit.get("type") == "song":
                result = hit.get("result") or {}
                if result:
                    hits.append(result)
    if not hits:
        search_log("Genius search/multi: 0 кандидатов для '{}'".format(query))
    return hits


def _genius_scrape_lyrics(url: str) -> Optional[str]:
    """Скрейпит текст песни со страницы Genius."""
    try:
        resp = requests.get(
            url,
            headers={"User-Agent": "Mozilla/5.0 (Linux; Android 10) AppleWebKit/537.36"},
            timeout=(3.0, NETWORK_TIMEOUT),
        )
        if resp.status_code != 200:
            return None
        html = resp.text

        # Genius хранит текст в JSON внутри страницы: window.__NUXT__ или data-lyrics-container
        # Метод 1: data-lyrics-container атрибут (с правильной обработкой вложенных <div>)
        lines = []
        import re as _re

        def _extract_genius_containers(html_text):
            """Находит все data-lyrics-container блоки, учитывая вложенные теги."""
            results = []
            pos = 0
            marker = 'data-lyrics-container="true"'
            while True:
                start = html_text.find(marker, pos)
                if start == -1:
                    break
                tag_end = html_text.find('>', start)
                if tag_end == -1:
                    pos = start + 1
                    continue
                depth = 1
                i = tag_end + 1
                while i < len(html_text) and depth > 0:
                    open_m = html_text.find('<div', i)
                    close_m = html_text.find('</div>', i)
                    if close_m == -1:
                        break
                    if open_m != -1 and open_m < close_m:
                        depth += 1
                        i = open_m + 4
                    else:
                        depth -= 1
                        if depth == 0:
                            results.append(html_text[tag_end + 1:close_m])
                            pos = close_m + 6
                            break
                        i = close_m + 6
                else:
                    pos = start + 1
            return results

        containers = _extract_genius_containers(html)
        for container in containers:
            # Убираем HTML теги, оставляем переносы строк
            text = _re.sub(r'<br\s*/?>', '\n', container, flags=_re.IGNORECASE)
            text = _re.sub(r'<[^>]+>', '', text)
            text = text.replace('&amp;', '&').replace('&quot;', '"').replace('&#x27;', "'").replace('&lt;', '<').replace('&gt;', '>').replace('&#39;', "'")
            for line in text.split('\n'):
                line = line.strip()
                lines.append(line)

        if lines:
            # Убираем теги секций вида [Аутро], [Verse 1], [Chorus] и т.п.
            import re as _sre2
            _sp = _sre2.compile(r'^\[[^\]]{1,80}\]$', _sre2.UNICODE)
            lines = [l for l in lines if not _sp.match(l.strip())]
            # Убираем строки-заголовки которые Genius вставляет в контейнер:
            # «Текст песни «TrackName»» или «Lyrics[Текст песни «TrackName»]»
            _hdr = _sre2.compile(
                r'^(?:Lyrics|Текст\s+песни|[A-Za-z0-9].{0,60}Lyrics\s*\[|.{0,10}\[Текст\s+песни)',
                _sre2.IGNORECASE | _sre2.UNICODE
            )
            lines = [l for l in lines if not _hdr.search(l.strip())]
            # Убираем пустые строки в начале и конце
            while lines and not lines[0]:
                lines.pop(0)
            while lines and not lines[-1]:
                lines.pop()
            return '\n'.join(lines) if lines else None

        # Метод 2: JSON в теге script
        match = _re.search(r'"lyrics":\{"body":\{"plain":"(.*?)"', html)
        if match:
            text = match.group(1).encode('utf-8').decode('unicode_escape')
            return text if text.strip() else None

    except Exception as e:
        try:
            Plugin.get_instance().log("Genius scrape failed: " + str(e))
        except Exception:
            pass
    return None


def _try_get_genius_plugin_lyrics(track) -> "Optional[LyricsResult]":
    """Ищет текст через Genius с fuzzy N-gram поиском по нескольким запросам."""
    try:
        if not track.query:
            return None

        inst = Plugin.get_instance()
        target_title = normalize_key(track.title)
        target_artist = normalize_key(track.artist)

        all_hits: List[Dict[str, Any]] = []
        lock = threading.Lock()

        def search_query(q, artist_only=False):
            hits = _genius_search_candidates(q, per_page=5, target_title=target_title)
            with lock:
                for h in hits:
                    h = dict(h)
                    if artist_only:
                        h["_artist_only_query"] = True
                    all_hits.append(h)

        queries = [(track.query, False)]
        if track.title:
            queries.append((track.title, False))
        if track.artist:
            queries.append((track.artist, True))

        # Максимум 2 потока одновременно
        BATCH_SIZE = 2
        for batch_start in range(0, len(queries), BATCH_SIZE):
            batch = queries[batch_start:batch_start + BATCH_SIZE]
            threads = [threading.Thread(target=search_query, args=q, daemon=True) for q in batch]
            for t in threads:
                t.start()
            for t in threads:
                t.join(timeout=NETWORK_TIMEOUT + 1)
            if any(normalize_key(h.get("title", "")) == target_title for h in all_hits):
                break

        if not all_hits:
            if inst:
                inst.log("Genius: no hits for: " + safe_str(track.query))
            return None

        # N-gram скоринг — тот же подход что и в LRCLIB
        best_score = -99999.0
        best_hit = None
        seen_ids: set = set()

        for hit in all_hits:
            hit_id = safe_str(hit.get("id"))
            if hit_id and hit_id in seen_ids:
                continue
            if hit_id:
                seen_ids.add(hit_id)

            title = normalize_key(hit.get("title", ""))
            artist = normalize_key((hit.get("primary_artist") or {}).get("name", ""))

            score = 0.0
            if target_title and title:
                if title == target_title:
                    score += 32
                elif target_title in title or title in target_title:
                    # См. тот же фикс в LrclibLyricsProvider._choose_best_candidate —
                    # вхождение пропорционально длине, а не флэт +22.
                    coverage = min(len(target_title), len(title)) / max(len(target_title), len(title), 1)
                    score += 10 + 22 * coverage
                else:
                    score += ngram_similarity(target_title, title) * 28

            if target_artist and artist:
                if artist == target_artist:
                    score += 28
                elif target_artist in artist or artist in target_artist:
                    score += 18
                else:
                    score += ngram_similarity(target_artist, artist) * 24

            title_sim = ngram_similarity(target_title, title) if target_title and title else 0.5
            artist_sim = ngram_similarity(target_artist, artist) if target_artist and artist else 0.5
            artist_contains = bool(
                target_artist and artist and (target_artist in artist or artist in target_artist)
            )

            # В LRCLIB-провайдере уже был жёсткий отказ при title_sim/artist_sim < 0.25,
            # а здесь, в Genius, его не было вовсе — тот же класс ложных срабатываний
            # был возможен и тут, просто реже триггерился логом.
            if target_title and title and title_sim < 0.25:
                score -= 150
            if target_artist and artist and artist_sim < 0.25 and not artist_contains:
                score -= 150

            if hit.get("_artist_only_query") and title_sim < 0.25:
                score -= 35
            if title_sim < 0.2 and artist_sim < 0.2:
                score -= 20

            if score > best_score:
                best_score = score
                best_hit = hit

        if not best_hit:
            return None

        # Минимальный порог для Genius — аналогичен LRCLIB
        GENIUS_MIN_SCORE = 45.0
        if best_score < GENIUS_MIN_SCORE:
            if inst:
                inst.log("Genius: best score {:.1f} below threshold, rejecting".format(best_score))
            return None

        # Дополнительная проверка title_sim для Genius (аналог LRCLIB)
        if best_hit:
            g_title_sim = ngram_similarity(
                normalize_key(best_hit.get("title", "")), target_title
            ) if target_title else 0.5
            g_artist_sim = ngram_similarity(
                normalize_key((best_hit.get("primary_artist") or {}).get("name", "")), target_artist
            ) if target_artist else 0.5
            if target_title and g_title_sim < 0.15 and not (g_artist_sim >= 0.85):
                if inst:
                    inst.log("Genius: winner title_sim={:.2f} too low, rejecting".format(g_title_sim))
                return None

        matched_title = safe_str(best_hit.get("title"))
        matched_artist = safe_str((best_hit.get("primary_artist") or {}).get("name"))
        song_url = safe_str(best_hit.get("url"))

        if inst:
            inst.log(f"Genius best match: {matched_title} — {matched_artist} (score={best_score:.1f})")

        if not song_url:
            return None

        # Скрейпим реальный текст
        raw_text = _genius_scrape_lyrics(song_url)
        if not raw_text or not raw_text.strip():
            if inst:
                inst.log("Genius: scrape returned empty for: " + song_url)
            return None

        import re as _sre
        _sec_pat = _sre.compile(r'^\[[^\]]{1,80}\]$', _sre.UNICODE)
        lines = []
        for line in raw_text.split('\n'):
            stripped = line.strip()
            # Пропускаем теги секций вида [Аутро], [Verse 1], [Chorus] и т.п.
            if _sec_pat.match(stripped):
                continue
            lines.append({"time": None, "text": stripped})

        # Убираем пустые строки по краям
        while lines and not safe_str(lines[0].get("text")):
            lines.pop(0)
        while lines and not safe_str(lines[-1].get("text")):
            lines.pop()

        if not lines:
            return None

        if inst:
            inst.log(f"Genius: got {len(lines)} lines for {matched_title}")

        return LyricsResult(
            lines=lines,
            synced=False,
            source="Genius",
            source_url=song_url,
            matched_title=matched_title,
            matched_artist=matched_artist,
        )

    except Exception as e:
        try:
            Plugin.get_instance().log("Genius fallback failed: " + str(e))
        except Exception:
            pass
        return None


def _try_get_lyricsovh(track) -> "Optional[LyricsResult]":
    """Резервный источник lyrics.ovh — простой публичный API, часто доступен там где lrclib/genius заблокированы."""
    try:
        if not track.title:
            return None

        inst = Plugin.get_instance()
        target_title = normalize_key(track.title)
        target_artist = normalize_key(track.artist)

        # Пробуем сначала точный запрос artist+title, потом только title
        attempts = []
        if track.artist and track.title:
            attempts.append((track.artist, track.title))
        if track.title:
            attempts.append(("", track.title))

        for artist_q, title_q in attempts:
            try:
                if artist_q:
                    url = "https://api.lyrics.ovh/v1/{}/{}".format(
                        requests.utils.quote(artist_q),
                        requests.utils.quote(title_q),
                    )
                else:
                    url = "https://api.lyrics.ovh/v1/{}/{}".format(
                        requests.utils.quote(title_q),
                        requests.utils.quote(title_q),
                    )
                resp = requests.get(
                    url,
                    headers={"User-Agent": "Mozilla/5.0"},
                    timeout=(3.0, NETWORK_TIMEOUT),
                )
                if resp.status_code != 200:
                    continue
                data = resp.json()
                lyrics_text = safe_str(data.get("lyrics"))
                if not lyrics_text.strip():
                    continue

                lines = []
                for line in lyrics_text.replace("\r", "\n").split("\n"):
                    lines.append({"time": None, "text": line.strip()})
                while lines and not safe_str(lines[0].get("text")):
                    lines.pop(0)
                while lines and not safe_str(lines[-1].get("text")):
                    lines.pop()

                if not lines:
                    continue

                if inst:
                    inst.log("lyrics.ovh: got {} lines for {} - {}".format(len(lines), artist_q or "?", title_q))

                return LyricsResult(
                    lines=lines,
                    synced=False,
                    source="lyrics.ovh",
                    source_url=url,
                    matched_title=title_q,
                    matched_artist=artist_q,
                )
            except Exception as e:
                if inst:
                    inst.log("lyrics.ovh attempt failed: " + str(e))
                continue

        return None
    except Exception as e:
        try:
            Plugin.get_instance().log("lyrics.ovh fallback failed: " + str(e))
        except Exception:
            pass
        return None



def _try_get_musixmatch(track) -> "Optional[LyricsResult]":
    """Резервный источник — Musixmatch через публичный веб-поиск без токена."""
    try:
        if not track.title:
            return None

        inst = Plugin.get_instance()
        title = track.title.strip()
        artist = track.artist.strip()

        queries = []
        if artist and title:
            queries.append("{} {}".format(artist, title))
        if title:
            queries.append(title)

        best_url = None
        target_title = normalize_key(title)
        target_artist = normalize_key(artist)

        for q in queries:
            try:
                resp = requests.get(
                    "https://www.musixmatch.com/search/{}/tracks".format(
                        requests.utils.quote(q)
                    ),
                    headers={
                        "User-Agent": "Mozilla/5.0 (Linux; Android 10) AppleWebKit/537.36",
                        "Accept-Language": "en-US,en;q=0.9",
                    },
                    timeout=(3.0, NETWORK_TIMEOUT),
                )
                if resp.status_code != 200:
                    continue

                import re as _re
                links = _re.findall(r'href="(/lyrics/[^"]+)"', resp.text)
                if not links:
                    continue

                seen = set()
                for link in links:
                    if link in seen:
                        continue
                    seen.add(link)
                    parts = link.strip("/").split("/")
                    if len(parts) < 3:
                        continue
                    link_artist = normalize_key(parts[1].replace("-", " "))
                    link_title = normalize_key(parts[2].replace("-", " "))
                    title_sim = ngram_similarity(target_title, link_title) if target_title and link_title else 0.0
                    artist_sim = ngram_similarity(target_artist, link_artist) if target_artist and link_artist else 0.5
                    if title_sim >= 0.55 and artist_sim >= 0.40:
                        best_url = "https://www.musixmatch.com" + link
                        if inst:
                            inst.log("Musixmatch: found candidate {} (title_sim={:.2f} artist_sim={:.2f})".format(link, title_sim, artist_sim))
                        break

                if best_url:
                    break
            except Exception as e:
                if inst:
                    inst.log("Musixmatch search failed: " + str(e))
                continue

        if not best_url:
            if inst:
                inst.log("Musixmatch: no suitable link found for: " + safe_str(track.query))
            return None

        try:
            resp = requests.get(
                best_url,
                headers={
                    "User-Agent": "Mozilla/5.0 (Linux; Android 10) AppleWebKit/537.36",
                    "Accept-Language": "en-US,en;q=0.9",
                },
                timeout=(3.0, NETWORK_TIMEOUT),
            )
            if resp.status_code != 200:
                if inst:
                    inst.log("Musixmatch: page returned {}".format(resp.status_code))
                return None

            import re as _re
            html = resp.text
            raw_lines = []

            spans = _re.findall(r'data-testid="lyrics-line"[^>]*>(.*?)</span>', html, _re.DOTALL)
            if spans:
                for span in spans:
                    text = _re.sub(r'<[^>]+>', '', span).strip()
                    text = text.replace('&amp;', '&').replace('&quot;', '"')                               .replace('&#x27;', "'").replace('&lt;', '<')                               .replace('&gt;', '>').replace('&#39;', "\'")
                    raw_lines.append(text)

            if not raw_lines:
                blocks = _re.findall(r'class="[^"]*lyrics__content[^"]*"[^>]*>(.*?)</span>', html, _re.DOTALL)
                for block in blocks:
                    text = _re.sub(r'<br\s*/?>', '\n', block, flags=_re.IGNORECASE)
                    text = _re.sub(r'<[^>]+>', '', text)
                    text = text.replace('&amp;', '&').replace('&quot;', '"')                               .replace('&#x27;', "'").replace('&lt;', '<')                               .replace('&gt;', '>').replace('&#39;', "\'")
                    for line in text.split('\n'):
                        raw_lines.append(line.strip())

            if not raw_lines:
                if inst:
                    inst.log("Musixmatch: could not extract lyrics from page")
                return None

            lines = [{"time": None, "text": l} for l in raw_lines]
            while lines and not safe_str(lines[0].get("text")):
                lines.pop(0)
            while lines and not safe_str(lines[-1].get("text")):
                lines.pop()

            if not lines:
                return None

            if inst:
                inst.log("Musixmatch: got {} lines for {}".format(len(lines), safe_str(track.query)))

            return LyricsResult(
                lines=lines,
                synced=False,
                source="Musixmatch",
                source_url=best_url,
                matched_title=title,
                matched_artist=artist,
            )
        except Exception as e:
            if inst:
                inst.log("Musixmatch scrape failed: " + str(e))
            return None

    except Exception as e:
        try:
            Plugin.get_instance().log("Musixmatch fallback failed: " + str(e))
        except Exception:
            pass
        return None


def _match_confidence(track: "TrackInfo", result: Optional["LyricsResult"]) -> float:
    """Считает, насколько результат действительно похож на запрошенный трек,
    сравнивая matched_title/matched_artist с исходными метаданными через ту
    же триграммную схожесть, что и в скоринге LRCLIB/Genius. Используется,
    чтобы решить, можно ли доверять первому найденному результату, или нужно
    сравнить его с альтернативой от другого провайдера (актуально при
    опечатках в исходных тегах трека, когда LRCLIB иногда уверенно цепляется
    за "похожий, но не тот" трек раньше, чем успевает сработать Genius)."""
    if result is None or not result.lines:
        return -1.0
    target_title = normalize_key(track.title)
    target_artist = normalize_key(track.artist)
    matched_title = normalize_key(result.matched_title)
    matched_artist = normalize_key(result.matched_artist)

    title_sim = ngram_similarity(target_title, matched_title) if target_title and matched_title else 0.5
    artist_sim = ngram_similarity(target_artist, matched_artist) if target_artist and matched_artist else 0.5
    confidence = title_sim * 0.6 + artist_sim * 0.4
    if result.synced:
        confidence += 0.05  # синхронизированный текст чуть предпочтительнее при близкой уверенности
    return confidence


# Выше этого порога результату первого провайдера доверяем сразу, не тратя
# время и трафик на запрос ко второму провайдеру.
HIGH_CONFIDENCE_THRESHOLD = 0.82


class CombinedLyricsProvider:
    """Провайдер с каскадом: LRCLIB → Genius-совместимый API.
    Если оба провайдера не нашли текст, пробует базовый поиск по query.
    Совместим с lyrics_genius: не конфликтует, а дополняет.
    """
    def __init__(self, plugin: "Plugin"):
        self.plugin = plugin
        self.lrclib = LrclibLyricsProvider(plugin)

    def get_lyrics(self, track: "TrackInfo") -> "LyricsResult":
        # 1. LRCLIB — приоритет (синхронизированные тексты с таймкодами)
        lrclib_result = None
        try:
            candidate = self.lrclib.get_lyrics(track)
            if candidate and candidate.lines:
                lrclib_result = candidate
        except Exception as e:
            self.plugin.log("LRCLIB failed, trying Genius fallback: " + str(e))

        lrclib_confidence = _match_confidence(track, lrclib_result)

        # Если LRCLIB сразу уверенно совпал с запросом — не тратим время на Genius.
        if lrclib_result and lrclib_confidence >= HIGH_CONFIDENCE_THRESHOLD:
            return lrclib_result

        # 2. Genius-совместимый резервный вариант. Запрашиваем его и в случае,
        # когда LRCLIB вообще не нашёл текст, и в случае, когда нашёл что-то
        # слабо похожее (типично при опечатках в исходных тегах трека —
        # LRCLIB иногда уверенно цепляется за "похожий, но не тот" трек).
        genius_result = None
        try:
            genius_result = _try_get_genius_plugin_lyrics(track)
        except Exception as e:
            self.plugin.log("Genius fallback crashed: " + str(e))
        genius_confidence = _match_confidence(track, genius_result)
        # Если Genius вернул подозрительно мало строк — значит scraping не смог
        # извлечь весь текст (paywalled или структура изменилась). Штрафуем confidence,
        # чтобы не выбирать Genius с 4 строками вместо нормального LRCLIB результата.
        if genius_result and genius_result.lines and len(genius_result.lines) < 8:
            genius_confidence = max(0.0, genius_confidence - 0.35)
            self.plugin.log("Genius: мало строк ({}), занижаем confidence до {:.2f}".format(
                len(genius_result.lines), genius_confidence))

        if genius_result and genius_result.lines:
            if not lrclib_result:
                return genius_result
            # Оба провайдера что-то нашли — берём тот, что реально больше похож
            # на исходные title/artist трека, а не просто первый успешный ответ.
            # Если ради этого придётся терять синхронизацию (LRCLIB synced,
            # Genius — plain text), требуем более заметный перевес в точности,
            # чтобы не жертвовать таймкодами из-за небольшой разницы в скоре.
            required_margin = 0.15 if (lrclib_result.synced and not genius_result.synced) else 0.05
            search_log("Сравнение итоговых результатов: LRCLIB confidence={:.2f} ('{}' - '{}') vs Genius confidence={:.2f} ('{}' - '{}')".format(
                lrclib_confidence, lrclib_result.matched_title, lrclib_result.matched_artist,
                genius_confidence, genius_result.matched_title, genius_result.matched_artist))
            if genius_confidence > lrclib_confidence + required_margin:
                self.plugin.log(
                    "Confidence: Genius {:.2f} > LRCLIB {:.2f} — выбран Genius".format(
                        genius_confidence, lrclib_confidence))
                search_log("ИТОГ: выбран Genius (перевес {:.2f} > требуемых {:.2f})".format(
                    genius_confidence - lrclib_confidence, required_margin))
                return genius_result
            search_log("ИТОГ: выбран LRCLIB (Genius не дал достаточного перевеса)")

        if lrclib_result:
            return lrclib_result

        # 3-4. lyrics.ovh и Musixmatch — оба запасные варианты на случай, если
        # LRCLIB и Genius недоступны или не нашли трек. Раньше запускались по
        # очереди (lyrics.ovh, потом Musixmatch), и если первый зависал на
        # таймауте, второй даже не начинал работу — отсюда лишние секунды в
        # худшем случае (см. лог от 2026-06-28, gen=3: 39 сек на полный каскад).
        # Запускаем оба сразу в потоках и берём тот, что ответит первым успешно.
        fallback_results: Dict[str, Optional["LyricsResult"]] = {"lyricsovh": None, "musixmatch": None}

        def _run_lyricsovh():
            try:
                fallback_results["lyricsovh"] = _try_get_lyricsovh(track)
            except Exception as e:
                self.plugin.log("lyrics.ovh thread failed: " + str(e))

        def _run_musixmatch():
            try:
                fallback_results["musixmatch"] = _try_get_musixmatch(track)
            except Exception as e:
                self.plugin.log("Musixmatch thread failed: " + str(e))

        t_ovh = threading.Thread(target=_run_lyricsovh, daemon=True)
        t_mxm = threading.Thread(target=_run_musixmatch, daemon=True)
        t_ovh.start()
        t_mxm.start()
        t_ovh.join(timeout=NETWORK_TIMEOUT + 2)
        t_mxm.join(timeout=NETWORK_TIMEOUT + 2)

        lyricsovh_result = fallback_results["lyricsovh"]
        if lyricsovh_result and lyricsovh_result.lines:
            return lyricsovh_result

        musixmatch_result = fallback_results["musixmatch"]
        if musixmatch_result and musixmatch_result.lines:
            return musixmatch_result

        raise Exception("Ни LRCLIB, ни Genius, ни lyrics.ovh, ни Musixmatch не нашли текст для: " + safe_str(track.query))

# =============================
# UI просмотра текста
# =============================


class LyricsViewer:
    def __init__(self, plugin: "Plugin", track: TrackInfo):
        self.plugin = plugin
        self.track = track
        self.provider = CombinedLyricsProvider(plugin)  # LRCLIB + Genius fallback
        self.context = get_last_fragment().getContext()
        self.dialog: Optional[Dialog] = None
        self.frame_root: Optional[FrameLayout] = None
        self.background_image: Optional[ImageView] = None
        self.background_fade_image: Optional[ImageView] = None
        self.dim_overlay: Optional[View] = None
        self.ambient_container: Optional[FrameLayout] = None
        self.ambient_blob_views: List[View] = []
        self.ambient_blob_states: List[Dict[str, Any]] = []
        self.ambient_palette: List[Tuple[int, int, int]] = []
        self.ambient_loop_started = False
        self.bg_bitmap: Optional[Bitmap] = None
        self.bg_path: Optional[str] = None
        self.root: Optional[LinearLayout] = None
        self.scroll: Optional[ScrollView] = None
        self.lines_container: Optional[LinearLayout] = None
        self.status_text: Optional[TextView] = None
        self.source_text: Optional[TextView] = None
        self.line_views: List[TextView] = []
        self.line_click_listeners: List[Any] = []
        self.lines: List[str] = []
        self.line_times: List[Optional[float]] = []
        # index строки -> текущий активный ValueAnimator этой строки.
        # Нужен, чтобы перед стартом новой анимации явно отменять предыдущую
        # (раньше scale/alpha и цвет были двумя независимыми аниматорами без
        # единой точки отмены — при частых сменах строки они расходились по
        # кадрам и анимация выглядела как рывок вместо плавного перехода).
        self._line_animators: Dict[int, Any] = {}
        self.has_synced = False
        self.current_index = -1
        self.running = False
        self.sync_loop_started = False
        self.load_generation = 0
        self.loading_started_at = 0.0
        self.source_url: Optional[str] = None
        self.last_scroll_target: int = -1
        self.scroll_animator = None
        self.mini_player: Optional[FrameLayout] = None
        self.mini_cover: Optional[ImageView] = None
        self.mini_title: Optional[TextView] = None
        self.mini_artist: Optional[TextView] = None
        self.mini_player_loop_started = False
        # Лок защищает line_views / lines / line_times от гонки между
        # _show_lyrics (UI-поток, пересоздаёт списки) и _update_current_line
        # (_sync_tick, читает их ~12 раз/сек на том же UI-потоке, но также
        # вызывается из колбэков фоновых потоков через run_on_ui_thread_safe).
        self._ui_lock = threading.Lock()
        # Счётчик для отмены устаревших фоновых загрузок обложки.
        # Инкрементируется в _reload_for_track и close() — worker, стартовавший
        # со старым значением, прерывается до тяжёлых операций (PIL-блюр,
        # BitmapFactory, сетевое скачивание). Это предотвращает нативный краш
        # (SIGSEGV/OOM), когда bitmap применяется к уже закрытому диалогу.
        self._cover_gen = 0

    def show(self):
        plog("Viewer", "show() начат: трек='{}' - '{}'".format(
            safe_str(self.track.title), safe_str(self.track.artist)))
        try:
            self.dialog = Dialog(self.context)
            self.dialog.requestWindowFeature(Window.FEATURE_NO_TITLE)
            self.dialog.setCancelable(True)
            plog("Viewer", "Dialog создан")
        except Exception as e:
            plog_crash("Viewer", "Dialog создать не удалось", e)
            raise

        # FrameLayout нужен, чтобы под всем интерфейсом лежала размытая обложка,
        # а сам интерфейс оставался обычной редактируемой Python-оболочкой.
        try:
            self.frame_root = FrameLayout(self.context)
            self.frame_root.setBackgroundColor(COLOR_BG)

            self.background_image = ImageView(self.context)
            self.background_image.setScaleType(ImageView.ScaleType.CENTER_CROP)
            self.background_image.setBackgroundColor(COLOR_BG)
            self.background_image.setAlpha(1.0)
            self.frame_root.addView(self.background_image, FrameLayout.LayoutParams(-1, -1))

            # Второй слой нужен для плавной смены обложек.
            # Старая обложка остаётся на фоне, пока новая подгружается и мягко проявляется сверху.
            self.background_fade_image = ImageView(self.context)
            self.background_fade_image.setScaleType(ImageView.ScaleType.CENTER_CROP)
            self.background_fade_image.setBackgroundColor(Color.TRANSPARENT)
            self.background_fade_image.setAlpha(0.0)
            self.frame_root.addView(self.background_fade_image, FrameLayout.LayoutParams(-1, -1))

            self.dim_overlay = View(self.context)
            self.dim_overlay.setBackgroundColor(self._dim_overlay_color())
            self.frame_root.addView(self.dim_overlay, FrameLayout.LayoutParams(-1, -1))
            plog("Viewer", "frame_root + фон + dim_overlay OK")
        except Exception as e:
            plog_crash("Viewer", "frame_root/фон создать не удалось", e)
            raise

        try:
            # Ambient Overlay: полупрозрачные плавные цветные пятна поверх фона,
            # но ниже текста и верхней плашки. Делает фон живее, не мешая чтению.
            self.ambient_container = FrameLayout(self.context)
            self.ambient_container.setBackgroundColor(Color.TRANSPARENT)
            self.frame_root.addView(self.ambient_container, FrameLayout.LayoutParams(-1, -1))
            self._rebuild_ambient_blobs(None)
            self._ensure_ambient_loop()
            plog("Viewer", "ambient_container OK")
        except Exception as e:
            plog_crash("Viewer", "ambient_container создать не удалось", e)
            raise

        try:
            self.root = LinearLayout(self.context)
            self.root.setOrientation(LinearLayout.VERTICAL)
            self.root.setBackgroundColor(Color.TRANSPARENT)
            self.root.setLayoutParams(LinearLayout.LayoutParams(-1, -1))
            self.frame_root.addView(self.root, FrameLayout.LayoutParams(-1, -1))

            self._build_header()
            self._build_body_loading()
            plog("Viewer", "root + header + loading OK")
        except Exception as e:
            plog_crash("Viewer", "root/header/loading создать не удалось", e)
            raise

        self.running = True

        try:
            # Мини-плеер поверх всего, прикреплён к низу
            self._build_mini_player()
            lp_mini = FrameLayout.LayoutParams(-1, -2)
            lp_mini.gravity = Gravity.BOTTOM
            margin_side = dp(self.context, 12)
            margin_bottom = dp(self.context, 16)
            lp_mini.setMargins(margin_side, 0, margin_side, margin_bottom)
            self.frame_root.addView(self.mini_player, lp_mini)
            plog("Viewer", "mini_player OK")
        except Exception as e:
            plog_crash("Viewer", "mini_player создать не удалось", e)
            raise

        try:
            self.dialog.setContentView(self.frame_root)
            self.dialog.show()
            plog("Viewer", "dialog.show() OK")
        except Exception as e:
            plog_crash("Viewer", "dialog.show() упал", e)
            raise

        try:
            window = self.dialog.getWindow()
            window.setLayout(-1, -1)
            window.setBackgroundDrawable(self._round_rect(Color.TRANSPARENT, 0))
        except Exception as e:
            plog("Viewer", "window layout/background failed (некритично): " + str(e), level="W")

        self._ensure_sync_loop()
        self._reload_for_track(self.track, clear_background=False)
        plog("Viewer", "show() завершён, sync_loop и reload запущены")

    def _build_header(self):
        header = LinearLayout(self.context)
        header.setOrientation(LinearLayout.HORIZONTAL)
        header.setGravity(Gravity.CENTER_VERTICAL)
        header.setPadding(dp(self.context, 4), 0, dp(self.context, 4), 0)
        header.setBackgroundColor(self._header_bg_color())
        self.root.addView(header, LinearLayout.LayoutParams(-1, dp(self.context, self._header_height_dp())))

        close = TextView(self.context)
        close.setText("×")
        close.setGravity(Gravity.CENTER)
        close.setTextColor(Color.WHITE)
        close.setTextSize(28)
        close.setTypeface(Typeface.DEFAULT)
        close.setOnClickListener(ViewClickListener(lambda _: self.close()))
        header.addView(close, LinearLayout.LayoutParams(dp(self.context, 44), -1))

    def _build_mini_player(self) -> None:
        ctx = self.context
        COVER_SIZE_DP = 44
        MINI_HEIGHT_DP = COVER_SIZE_DP + 8
        PADDING_DP = 10
        BTN_SIZE_DP = 36
        CORNER_DP = 18

        try:
            bg = GradientDrawable()
            bg.setColor(Color.rgb(18, 18, 18))
            bg.setCornerRadius(dp(ctx, CORNER_DP))
            container = FrameLayout(ctx)
            container.setBackground(bg)
            container.setClipToOutline(True)
            container.setPadding(dp(ctx, PADDING_DP), dp(ctx, 6), dp(ctx, PADDING_DP), dp(ctx, 6))
            self.mini_player = container
            self.plugin.log("[mini_player] container ok")
        except BaseException as e:
            _log_safe("mini_player container", e)
            return

        try:
            row = LinearLayout(ctx)
            row.setOrientation(LinearLayout.HORIZONTAL)
            row.setGravity(Gravity.CENTER_VERTICAL)
            container.addView(row, FrameLayout.LayoutParams(-1, dp(ctx, MINI_HEIGHT_DP)))
            self.plugin.log("[mini_player] row ok")
        except BaseException as e:
            _log_safe("mini_player row", e)
            return

        try:
            self.mini_cover = ImageView(ctx)
            self.mini_cover.setScaleType(ImageView.ScaleType.CENTER_CROP)
            cover_size = dp(ctx, COVER_SIZE_DP)
            cover_bg = GradientDrawable()
            cover_bg.setColor(Color.argb(80, 255, 255, 255))
            cover_bg.setCornerRadius(dp(ctx, 10))
            self.mini_cover.setBackground(cover_bg)
            self.mini_cover.setClipToOutline(True)
            lp_cover = LinearLayout.LayoutParams(cover_size, cover_size)
            lp_cover.setMargins(0, 0, dp(ctx, 12), 0)
            row.addView(self.mini_cover, lp_cover)
            self.plugin.log("[mini_player] cover ok")
        except BaseException as e:
            _log_safe("mini_player cover", e)

        try:
            text_box = LinearLayout(ctx)
            text_box.setOrientation(LinearLayout.VERTICAL)
            text_box.setGravity(Gravity.CENTER_VERTICAL)
            row.addView(text_box, LinearLayout.LayoutParams(0, -2, 1.0))

            self.mini_title = TextView(ctx)
            self.mini_title.setText(self.track.display_title)
            self.mini_title.setTextColor(Color.WHITE)
            self.mini_title.setTextSize(self._title_text_size())
            self.mini_title.setTypeface(Typeface.DEFAULT_BOLD)
            self.mini_title.setSingleLine(True)
            self.mini_title.setEllipsize(TextUtils.TruncateAt.END)
            text_box.addView(self.mini_title, LinearLayout.LayoutParams(-1, -2))

            self.mini_artist = TextView(ctx)
            self.mini_artist.setText(self.track.display_artist)
            self.mini_artist.setTextColor(Color.argb(180, 255, 255, 255))
            self.mini_artist.setTextSize(self._subtitle_text_size())
            self.mini_artist.setSingleLine(True)
            self.mini_artist.setEllipsize(TextUtils.TruncateAt.END)
            lp_artist = LinearLayout.LayoutParams(-1, -2)
            lp_artist.setMargins(0, dp(ctx, 2), 0, 0)
            text_box.addView(self.mini_artist, lp_artist)
            self.plugin.log("[mini_player] text ok")
        except BaseException as e:
            _log_safe("mini_player text", e)

        try:
            # Кнопки лайка и play/pause убраны — теперь тап по любому месту
            # мини-плеера переключает воспроизведение/паузу.
            container.setClickable(True)
            container.setFocusable(True)
            container.setOnClickListener(ViewClickListener(lambda _: self._on_play_pause_click()))
            self.plugin.log("[mini_player] tap-to-toggle ok")
        except BaseException as e:
            _log_safe("mini_player tap_to_toggle", e)

        self._load_mini_cover_async()
        self._ensure_mini_player_loop()

    def _load_mini_cover_async(self, generation: Optional[int] = None, cover_gen: Optional[int] = None) -> None:
        if generation is None:
            generation = self.load_generation
        if cover_gen is None:
            cover_gen = self._cover_gen
        track_snapshot = self.track

        def worker():
            try:
                cover_path = self._extract_album_art_path()
                if cover_gen != self._cover_gen:
                    return
                if not cover_path:
                    cover_path = self._fetch_cover_online(track_snapshot.title, track_snapshot.artist)
                if cover_gen != self._cover_gen:
                    return
                if cover_path and os.path.exists(cover_path):
                    # 200px достаточно даже для 44dp на самом плотном экране (xxxhdpi).
                    bmp = _decode_bitmap_bounded(cover_path, 200)
                    if cover_gen != self._cover_gen:
                        try:
                            if bmp is not None and not bmp.isRecycled():
                                bmp.recycle()
                        except Exception:
                            pass
                        return
                    if bmp is not None:
                        def _safe_mini_apply(b=bmp, g=generation):
                            try:
                                self._apply_mini_cover(b, g)
                            except Exception as _e:
                                _log_safe("_apply_mini_cover UI callback", _e)
                        run_on_ui_thread_safe(_safe_mini_apply)
                        return
                # У нового трека нет обложки — не оставляем висеть обложку от старого.
                def _safe_mini_clear(g=generation):
                    try:
                        self._clear_mini_cover(g)
                    except Exception as _e:
                        _log_safe("_clear_mini_cover UI callback", _e)
                run_on_ui_thread_safe(_safe_mini_clear)
            except BaseException as e:
                _log_safe("mini cover load", e)
        threading.Thread(target=worker, name="LyricsMiniCover", daemon=True).start()

    def _apply_mini_cover(self, bmp: Bitmap, generation: Optional[int] = None) -> None:
        try:
            # Поздний ответ от уже неактуального трека — игнорируем, чтобы не
            # перезаписать обложку трека, на который успели переключиться.
            if generation is not None and generation != self.load_generation:
                if bmp is not None and not bmp.isRecycled():
                    bmp.recycle()
                return
            if self.mini_cover and not bmp.isRecycled():
                drawable = BitmapDrawable(self.context.getResources(), bmp)
                self.mini_cover.setImageDrawable(drawable)
        except BaseException as e:
            _log_safe("_apply_mini_cover", e)

    def _clear_mini_cover(self, generation: Optional[int] = None) -> None:
        try:
            if generation is not None and generation != self.load_generation:
                return
            if self.mini_cover:
                self.mini_cover.setImageDrawable(None)
        except BaseException as e:
            _log_safe("_clear_mini_cover", e)

    def _is_currently_playing(self) -> bool:
        try:
            controller = get_media_controller().getInstance()
        except BaseException:
            return False
        # isMessagePaused — стандартный метод MediaController в Telegram/ExteraGram.
        paused = call_any(controller, ["isMessagePaused"], None, [tuple()])
        if paused is not None:
            return not bool(paused)
        # Запасные варианты для других сборок/форков.
        playing = call_any(controller, ["isPlayingAudio", "isPlaying", "isAudioPlaying"], None, [tuple()])
        return bool(playing) if playing is not None else False

    def _on_play_pause_click(self) -> None:
        try:
            controller = get_media_controller().getInstance()
            msg = get_playing_message_object()
            if msg is None:
                return
            if self._is_currently_playing():
                ok = try_call_any(controller, ["pauseMessage"], [(msg,), tuple()])
            else:
                ok = try_call_any(controller, ["playMessage"], [(msg,), tuple()])
            if not ok:
                # Доп. варианты на случай других сборок/форков.
                try_call_any(controller, ["playOrPause", "togglePause", "pause", "playAudio"], [tuple(), (msg,)])
        except BaseException as e:
            _log_safe("_on_play_pause_click", e)

    def _ensure_mini_player_loop(self) -> None:
        if self.mini_player_loop_started:
            return
        self.mini_player_loop_started = True

        def worker():
            while self.running:
                time.sleep(0.5)
                try:
                    def _safe_mini_update():
                        try:
                            self._update_mini_player_info()
                        except Exception as _e:
                            _log_safe("_update_mini_player_info UI callback", _e)
                    run_on_ui_thread_safe(_safe_mini_update)
                except BaseException as e:
                    _log_safe("mini player loop", e)
            self.mini_player_loop_started = False

        threading.Thread(target=worker, name="LyricsMiniPlayer", daemon=True).start()

    def _update_mini_player_info(self) -> None:
        try:
            if self.mini_title:
                self.mini_title.setText(self.track.display_title)
            if self.mini_artist:
                self.mini_artist.setText(self.track.display_artist)
        except BaseException as e:
            _log_safe("_update_mini_player_info", e)

    def _build_body_loading(self):
        container = FrameLayout(self.context)
        self.root.addView(container, LinearLayout.LayoutParams(-1, 0, 1.0))

        box = LinearLayout(self.context)
        box.setOrientation(LinearLayout.VERTICAL)
        box.setGravity(Gravity.CENTER)
        box.setPadding(dp(self.context, 24), dp(self.context, 24), dp(self.context, 24), dp(self.context, 24))
        container.addView(box, FrameLayout.LayoutParams(-1, -1))

        progress = ProgressBar(self.context)
        box.addView(progress, LinearLayout.LayoutParams(dp(self.context, 42), dp(self.context, 42)))

        self.status_text = TextView(self.context)
        self.status_text.setText("Ищу текст (LRCLIB / Genius)…")
        self.status_text.setTextColor(self._muted_text_color())
        self.status_text.setTextSize(16)
        self._apply_inactive_text_shadow(self.status_text)
        self.status_text.setGravity(Gravity.CENTER)
        lp = LinearLayout.LayoutParams(-1, -2)
        lp.setMargins(0, dp(self.context, 18), 0, 0)
        box.addView(self.status_text, lp)

    def _ensure_sync_loop(self) -> None:
        if self.sync_loop_started:
            return
        self.sync_loop_started = True
        run_on_queue(self._sync_loop)

    def _reload_for_track(self, track: TrackInfo, clear_background: bool = True):
        if not self.root:
            plog("Viewer", "_reload_for_track: root отсутствует, пропускаем", level="W")
            return

        plog("Viewer", "_reload_for_track: '{}' - '{}' длительность={:.0f}с gen={}".format(
            safe_str(track.title), safe_str(track.artist), track.duration, self.load_generation + 1))

        self.track = track
        self.load_generation += 1
        self._cover_gen += 1
        cover_gen = self._cover_gen
        generation = self.load_generation
        self.loading_started_at = time.time()
        self.current_index = -1
        # Сбрасываем под локом — _update_current_line может читать эти списки
        # на UI-потоке в любой момент через _sync_tick.
        with self._ui_lock:
            self.lines = []
            self.line_times = []
            self.line_views = []
            self.line_click_listeners = []
            self._line_animators = {}
        self.has_synced = False
        self.last_scroll_target = -1
        self.scroll_animator = None

        # Обновляем мини-плеер сразу, не дожидаясь следующего тика фонового
        # цикла (а заодно подстраховка: если цикл по какой-то причине не
        # запущен, перезапускаем его, чтобы title/artist не зависали).
        self._update_mini_player_info()
        self._ensure_mini_player_loop()

        self.root.removeAllViews()
        self._build_header()
        self._build_body_loading()

        if clear_background:
            self._clear_cover_background()

        self._load_cover_background_async(generation, cover_gen)
        self._load_mini_cover_async(generation, cover_gen)
        threading.Thread(
            target=lambda: self._load_lyrics_background(generation, track),
            name="LyricsLRCLIBLoad",
            daemon=True,
        ).start()

    def _check_track_changed(self) -> bool:
        try:
            # Если музыка остановлена или Telegram на мгновение ещё не отдал данные нового трека,
            # не сбрасываем текущий экран в ошибку. Ждём следующего тика.
            if not is_music():
                return False
            new_track = get_current_track_info()
            if not new_track.query:
                return False
            if new_track.cache_key != self.track.cache_key:
                plog("Viewer", "Трек сменился: '{}' - '{}' → '{}' - '{}'".format(
                    safe_str(self.track.title), safe_str(self.track.artist),
                    safe_str(new_track.title), safe_str(new_track.artist)))
                # Не очищаем старую обложку сразу: держим её как placeholder,
                # пока новая не подгрузится и не проявится плавно.
                self._reload_for_track(new_track, clear_background=False)
                return True
        except Exception as e:
            self.plugin.log("track change check failed: " + str(e))
            plog_exc("Viewer", "_check_track_changed упал", e)
        return False

    def _load_lyrics_background(self, generation: int, track: TrackInfo):
        plog("Search", "Поиск начат: '{}' - '{}' длительность={:.0f}с gen={}".format(
            safe_str(track.title), safe_str(track.artist), track.duration, generation))
        try:
            result = self.provider.get_lyrics(track)
            plog("Search", "Найдено: source={} synced={} lines={} matched='{}' - '{}' gen={}".format(
                result.source, result.synced, len(result.lines),
                safe_str(result.matched_title), safe_str(result.matched_artist), generation))
            def _safe_show(r=result, g=generation):
                try:
                    self._show_lyrics(r, g)
                except Exception as _e:
                    self.plugin.log("_show_lyrics crashed inside UI callback: " + str(_e))
                    self.plugin.log(traceback.format_exc())
                    plog_crash("Viewer", "_show_lyrics упал в UI callback gen={}".format(g), _e)
                    try:
                        self._show_error("Не удалось отрисовать текст: " + str(_e), g)
                    except Exception:
                        pass
            run_on_ui_thread_safe(_safe_show)
        except Exception as e:
            self.plugin.log("Lyrics load failed: " + str(e))
            self.plugin.log(traceback.format_exc())
            plog_crash("Search", "Поиск упал gen={}".format(generation), e)
            def _safe_err(err=str(e), g=generation):
                try:
                    self._show_error(err, g)
                except Exception as _e2:
                    self.plugin.log("_show_error crashed inside UI callback: " + str(_e2))
                    plog_crash("Viewer", "_show_error упал в UI callback gen={}".format(g), _e2)
            run_on_ui_thread_safe(_safe_err)

    def _show_error(self, message: str, generation: Optional[int] = None):
        if not self.running:
            return
        if generation is not None and generation != self.load_generation:
            return
        if not self.root:
            return
        try:
            if not self.dialog or not self.dialog.isShowing():
                return
        except Exception:
            return
        plog("Viewer", "_show_error: gen={} msg={}".format(generation, message), level="W")
        try:
            self.loading_started_at = 0.0
            self.root.removeAllViews()
            self._build_header()

            box = LinearLayout(self.context)
            box.setOrientation(LinearLayout.VERTICAL)
            box.setGravity(Gravity.CENTER)
            box.setPadding(dp(self.context, 24), dp(self.context, 24), dp(self.context, 24), dp(self.context, 24))
            self.root.addView(box, LinearLayout.LayoutParams(-1, 0, 1.0))

            title = TextView(self.context)
            title.setText("Текст не найден :<")
            title.setGravity(Gravity.CENTER)
            title.setTextColor(COLOR_TEXT_ERROR)
            title.setTextSize(22)
            title.setTypeface(Typeface.DEFAULT_BOLD)
            self._apply_active_text_shadow(title)
            box.addView(title, LinearLayout.LayoutParams(-1, -2))

            msg = TextView(self.context)
            msg.setText(message)
            msg.setGravity(Gravity.CENTER)
            msg.setTextColor(self._muted_text_color())
            msg.setTextSize(15)
            self._apply_inactive_text_shadow(msg)
            lp = LinearLayout.LayoutParams(-1, -2)
            lp.setMargins(0, dp(self.context, 12), 0, 0)
            box.addView(msg, lp)

            retry = TextView(self.context)
            retry.setText("Повторить поиск")
            retry.setGravity(Gravity.CENTER)
            retry.setTextColor(Color.WHITE)
            retry.setTextSize(16)
            retry.setTypeface(Typeface.DEFAULT_BOLD)
            self._apply_active_text_shadow(retry)
            retry.setPadding(dp(self.context, 18), dp(self.context, 12), dp(self.context, 18), dp(self.context, 12))
            retry.setBackground(self._round_rect(Color.rgb(32, 32, 32), 18))
            retry.setOnClickListener(ViewClickListener(lambda _: self._retry()))
            lp_retry = LinearLayout.LayoutParams(-2, -2)
            lp_retry.setMargins(0, dp(self.context, 22), 0, 0)
            box.addView(retry, lp_retry)
        except Exception as e:
            # Вызывается из UI-колбэка (run_on_ui_thread_safe) — без try/except
            # любое исключение здесь крашило бы весь хост-процесс.
            self.plugin.log("_show_error crashed (caught): " + str(e))
            self.plugin.log(traceback.format_exc())
            plog_crash("Viewer", "_show_error упал", e)

    def _retry(self):
        if not self.root:
            return
        plog("Viewer", "_retry: повторный поиск")
        track = get_current_track_info()
        try:
            self.plugin.cache_delete(track.cache_key)
        except Exception as e:
            self.plugin.log("cache_delete on retry failed: " + str(e))
        self._reload_for_track(track, clear_background=False)

    def _show_lyrics(self, result: LyricsResult, generation: Optional[int] = None):
        if not self.running:
            return
        if generation is not None and generation != self.load_generation:
            return
        if not self.root:
            return
        try:
            if not self.dialog or not self.dialog.isShowing():
                return
        except Exception:
            return
        plog("Viewer", "_show_lyrics: gen={} source={} synced={} lines={}".format(
            generation, result.source, result.synced, len(result.lines)))
        try:
            self.loading_started_at = 0.0
            self.source_url = result.source_url
            self.root.removeAllViews()
            self._build_header()

            self.has_synced = result.synced
            self.scroll = ScrollView(self.context)
            self.scroll.setFillViewport(True)
            self.scroll.setClipToPadding(False)
            self.scroll.setPadding(0, dp(self.context, SCROLL_TOP_PADDING_DP), 0, dp(self.context, SCROLL_BOTTOM_PADDING_DP))
            self.root.addView(self.scroll, LinearLayout.LayoutParams(-1, 0, 1.0))

            self.lines_container = LinearLayout(self.context)
            self.lines_container.setOrientation(LinearLayout.VERTICAL)
            self.lines_container.setGravity(Gravity.CENTER_HORIZONTAL)
            self.lines_container.setPadding(dp(self.context, SIDE_PADDING_DP), 0, dp(self.context, SIDE_PADDING_DP), 0)
            self.scroll.addView(self.lines_container, ScrollView.LayoutParams(-1, -2))

            # Сбрасываем списки под локом, чтобы _update_current_line /
            # _sync_tick не увидели наполовину пересозданный line_views.
            with self._ui_lock:
                self.lines = []
                self.line_times = []
                self.line_views = []
                self.line_click_listeners = []
                self._line_animators = {}

            # Строим временные списки локально, не трогая self.line_views пока
            # все TextView не готовы — это исключает гонку с _update_current_line,
            # которая читает self.line_views на каждом тике ~12 раз/сек.
            _local_lines: List[str] = []
            _local_times: List[Optional[float]] = []
            _local_views: List[TextView] = []
            _local_listeners: List[Any] = []

            for index, item in enumerate(result.lines):
                # item может прийти кривым из парсинга LRC/Genius — не дадим этому
                # обрушить весь хост-процесс.
                if not isinstance(item, dict):
                    continue
                line = safe_str(item.get("text"))
                time_value = item.get("time")
                _local_lines.append(line)
                _local_times.append(None if time_value is None else float_safe(time_value, None))

                tv = TextView(self.context)
                tv.setGravity(Gravity.CENTER)
                tv.setTextColor(self._inactive_text_color())
                # Реальный размер шрифта всегда фиксирован как "активный" — перенос строк
                # считается один раз и больше никогда не пересчитывается при смене активности.
                # Видимый маленький размер неактивной строки — это просто scaleX/scaleY,
                # а не настоящий textSize, поэтому высота строки не скачет.
                tv.setTextSize(self._active_line_text_size())
                tv.setTypeface(Typeface.DEFAULT_BOLD)
                self._apply_inactive_text_shadow(tv)
                tv.setIncludeFontPadding(True)
                tv.setText(line if line else " ")
                inactive_ratio = self._inactive_scale_ratio()
                tv.setScaleX(inactive_ratio)
                tv.setScaleY(inactive_ratio)
                # ВАЖНО: НЕ ставим LAYER_TYPE_HARDWARE здесь. HW-слой ускоряет
                # только чистые трансформации (scale/alpha/translation) без
                # изменения содержимого отрисовки. Мы же на каждом кадре
                # анимации ещё и меняем setTextColor() — это инвалидирует
                # содержимое, и Android вынужден заново растеризовывать весь
                # слой на CPU + заливать на GPU КАЖДЫЙ кадр анимации. Получается
                # не ускорение, а лишняя растеризация ровно в момент смены
                # строки — то самое "дёргается при смене строк".

                # Двойное нажатие по строке с таймкодом перематывает трек к этой строке.
                # Для plainLyrics без таймкодов действие не навешиваем, чтобы не было случайных прыжков.
                if time_value is not None:
                    try:
                        listener = DoubleTapLineClickListener(lambda _view, i=index: self._seek_to_line_index(i))
                        tv.setClickable(True)
                        tv.setOnClickListener(listener)
                        _local_listeners.append(listener)
                    except Exception:
                        pass

                lp = LinearLayout.LayoutParams(-1, -2 if line else dp(self.context, EMPTY_LINE_HEIGHT_DP))
                lp.setMargins(0, dp(self.context, LINE_MARGIN_VERTICAL_DP), 0, dp(self.context, LINE_MARGIN_VERTICAL_DP))
                self.lines_container.addView(tv, lp)
                _local_views.append(tv)

            # Атомарно публикуем готовые списки — _update_current_line увидит
            # либо старый полный набор, либо новый полный набор, но никогда не
            # частично заполненный, что раньше давало IndexError / обращение к
            # уже detached View и нативный краш.
            with self._ui_lock:
                self.lines = _local_lines
                self.line_times = _local_times
                self.line_views = _local_views
                self.line_click_listeners = _local_listeners

            self.source_text = TextView(self.context)
            self.source_text.setGravity(Gravity.CENTER)
            self.source_text.setTextColor(self._muted_text_color())
            self.source_text.setTextSize(12)
            self._apply_inactive_text_shadow(self.source_text)
            source_label = safe_str(result.source, "LRCLIB")
            if result.synced:
                self.source_text.setText(f"Источник текста: {source_label} ♪")
            else:
                self.source_text.setText(f"Источник текста: {source_label} • без таймкодов")
            lp_source = LinearLayout.LayoutParams(-1, -2)
            lp_source.setMargins(0, dp(self.context, 24), 0, dp(self.context, 30))
            self.lines_container.addView(self.source_text, lp_source)

            # Синхронизированным LRC-текстам сразу выбираем актуальную строку.
            # Для plainLyrics без таймкодов не подсвечиваем белую строку вообще:
            # весь текст остаётся серым и не "живет своей жизнью".
            if result.synced:
                self._update_current_line(force=True, instant_scroll=True)
                self._schedule_initial_scroll(generation)
            else:
                self.current_index = -1
            plog("Viewer", "_show_lyrics: отрисовано {} строк OK".format(len(self.line_views)))
        except Exception as e:
            # Вызывается из UI-колбэка сразу после завершения поиска — без try/except
            # любая ошибка здесь (например, кривой формат строки из LRC/Genius)
            # крашила весь хост-процесс, а не только показывала ошибку поиска.
            self.plugin.log("_show_lyrics crashed (caught): " + str(e))
            self.plugin.log(traceback.format_exc())
            plog_crash("Viewer", "_show_lyrics упал при отрисовке gen={}".format(generation), e)
            self._show_error("Не удалось отрисовать текст песни", generation)

    def _sync_loop(self):
        # predicted_index — локальная (только для этого потока) копия индекса
        # строки, не зависящая от того, успел ли UI-поток обработать предыдущий
        # тик. Раньше планирование следующего сна читало self.current_index
        # сразу после run_on_ui_thread_safe(...) — а post() асинхронный, UI ещё
        # не обновил индекс, "remaining" снова получался ~0, и цикл начинал
        # слать тики пачками каждые 16мс, забивая UI-поток дублями прямо в
        # момент старта анимации (отсюда "скачки"). Реальная подсветка строки
        # всё равно всегда считается в _update_current_line из настоящего
        # прогресса трека — predicted_index влияет только на то, сколько спать,
        # а не на то, какая строка покажется.
        predicted_index = self.current_index
        while self.running:
            delay, predicted_index = self._next_tick_delay(predicted_index)
            time.sleep(delay)
            try:
                if not self.dialog or not self.dialog.isShowing():
                    self.running = False
                    break
                def _safe_tick():
                    try:
                        self._sync_tick()
                    except Exception as _e:
                        self.plugin.log("_sync_tick crashed in UI callback: " + str(_e))
                run_on_ui_thread_safe(_safe_tick)
            except Exception:
                self.running = False
                break
        self.sync_loop_started = False

    def _next_tick_delay(self, predicted_index: int):
        """Возвращает (задержка_сек, новый_predicted_index).

        Если синхро-текста нет или следующая строка далеко — обычный poll
        SYNC_INTERVAL_SEC, как раньше (нужен и для перемотки/паузы). Если
        близко — спим ровно столько, сколько осталось (с нижней границей
        MIN_SYNC_INTERVAL_SEC), и локально продвигаем predicted_index, чтобы
        следующая итерация целилась в СЛЕДУЮЩУЮ границу, а не пересчитывала
        ту же самую по ещё не обновившемуся self.current_index.
        """
        try:
            real_index = self.current_index
            if predicted_index < real_index:
                predicted_index = real_index  # реальный индекс ушёл вперёд — досинхронизируемся

            if not self.has_synced or not self.line_times:
                return SYNC_INTERVAL_SEC, real_index

            next_index = predicted_index + 1
            if next_index >= len(self.line_times):
                return SYNC_INTERVAL_SEC, predicted_index

            next_time = self.line_times[next_index]
            if next_time is None:
                return SYNC_INTERVAL_SEC, predicted_index

            progress = max(0.0, get_current_progress_sec() + self._sync_offset_sec())
            remaining = float(next_time) - progress
            if remaining <= 0:
                return MIN_SYNC_INTERVAL_SEC, next_index
            return max(MIN_SYNC_INTERVAL_SEC, min(SYNC_INTERVAL_SEC, remaining)), predicted_index
        except Exception:
            return SYNC_INTERVAL_SEC, self.current_index

    def _sync_tick(self):
        # ВАЖНО: этот метод выполняется на UI-потоке через run_on_ui_thread_safe,
        # и если из него вылетит необработанное исключение — крашится весь хост
        # (Telegram/exteraGram), а не только плагин. run_on_ui_thread_safe ловит
        # ошибки только при ПОСТАНОВКЕ колбэка в очередь, а не при его исполнении.
        # Поэтому здесь обязателен свой try/except, тем более вызывается ~12 раз/сек.
        try:
            if self._check_track_changed():
                return
            if self._check_loading_timeout():
                return
            self._update_current_line()
        except Exception as e:
            self.plugin.log("_sync_tick crashed (caught): " + str(e))
            self.plugin.log(traceback.format_exc())
            plog_crash("SyncTick", "_sync_tick упал", e)

    def _check_loading_timeout(self) -> bool:
        try:
            if self.loading_started_at <= 0:
                return False
            # Если текст уже показан или открыт экран ошибки, таймер больше не нужен.
            if self.line_views:
                return False
            if time.time() - self.loading_started_at < SEARCH_UI_TIMEOUT_SEC:
                return False
            generation = self.load_generation
            # Инвалидируем поздний ответ старого потока, чтобы он не перерисовал экран после таймаута.
            self.load_generation += 1
            self.loading_started_at = 0.0
            self._show_error(SEARCH_TIMEOUT_MESSAGE, None)
            self.plugin.log("LRCLIB search timed out on UI after " + str(SEARCH_UI_TIMEOUT_SEC) + " sec, generation " + str(generation))
            plog("Search", "ТАЙМАУТ поиска через {}с gen={}".format(SEARCH_UI_TIMEOUT_SEC, generation), level="W")
            return True
        except Exception as e:
            self.plugin.log("loading timeout check failed: " + str(e))
            return False

    def _seek_to_line_index(self, index: int) -> None:
        try:
            if index < 0 or index >= len(self.line_times):
                return
            time_value = self.line_times[index]
            if time_value is None:
                return

            seconds = max(0.0, float_safe(time_value, 0.0))
            ok = seek_current_track_to_sec(seconds, self.track.duration)
            if ok:
                self.current_index = -1
                self._update_current_line(force=True, instant_scroll=False)
                try:
                    view = self.line_views[index]
                    view.animate().cancel()
                    view.setScaleX(0.97)
                    view.setScaleY(0.97)
                    view.animate().scaleX(1.0).scaleY(1.0).setDuration(120).start()
                except Exception:
                    pass
            else:
                self.plugin.log("seek failed for lyric line at " + str(seconds) + " sec")
        except Exception as e:
            self.plugin.log("line double-tap seek failed: " + str(e))

    def _update_current_line(self, force: bool = False, instant_scroll: bool = False):
        # Берём снимок line_views под локом, чтобы не словить частично
        # пересозданный список из _show_lyrics (гонка приводила к нативному
        # крашу при обращении к detached/recycled View).
        with self._ui_lock:
            if not self.line_views:
                return
            line_views_snapshot = list(self.line_views)

        if not line_views_snapshot:
            return

        try:
            # У plainLyrics нет реальных таймкодов, поэтому не выделяем "активную"
            # белую строку по примерному прогрессу трека. Весь текст остаётся серым.
            if not self.has_synced:
                if self.current_index != -1:
                    self.current_index = -1
                    for line_idx, line_view in enumerate(line_views_snapshot):
                        try:
                            prev_anim = self._line_animators.pop(line_idx, None)
                            if prev_anim is not None:
                                prev_anim.cancel()
                            line_view.animate().cancel()
                            line_view.setTextColor(self._inactive_text_color())
                            line_view.setTextSize(self._line_text_size())
                            line_view.setTypeface(Typeface.DEFAULT_BOLD)
                            self._apply_inactive_text_shadow(line_view)
                            line_view.setScaleX(1.0)
                            line_view.setScaleY(1.0)
                            line_view.setAlpha(1.0)
                        except Exception:
                            pass
                return

            index = self._calculate_current_index()
            # Защита от рассинхронизации: line_views мог быть пересоздан
            # (_show_lyrics) между вызовом _calculate_current_index и этой строкой.
            if index < 0 or index >= len(line_views_snapshot):
                return
            if not force and index == self.current_index:
                return

            old_index = self.current_index
            self.current_index = index

            if 0 <= old_index < len(line_views_snapshot):
                old = line_views_snapshot[old_index]
                self._apply_inactive_text_shadow(old)
                self._animate_line_state(old, old_index, is_active=False)

            current = line_views_snapshot[index]
            self._apply_active_text_shadow(current)
            self._animate_line_state(current, index, is_active=True, force=force)

            self._scroll_to_index(index, instant=instant_scroll)
        except Exception as e:
            # Любое исключение здесь раньше крашило весь хост-процесс, так как
            # этот метод вызывается из UI-колбэка (_sync_tick) ~12 раз/сек.
            self.plugin.log("_update_current_line crashed (caught): " + str(e))
            self.plugin.log(traceback.format_exc())


    def _lerp_color(self, from_color: int, to_color: int, t: float) -> int:
        """Линейная интерполяция двух ARGB цветов."""
        fa = (from_color >> 24) & 0xFF
        fr = (from_color >> 16) & 0xFF
        fg = (from_color >> 8) & 0xFF
        fb = from_color & 0xFF
        ta = (to_color >> 24) & 0xFF
        tr = (to_color >> 16) & 0xFF
        tg = (to_color >> 8) & 0xFF
        tb = to_color & 0xFF
        a = int(fa + (ta - fa) * t)
        r = int(fr + (tr - fr) * t)
        g = int(fg + (tg - fg) * t)
        b = int(fb + (tb - fb) * t)
        return Color.argb(
            max(0, min(255, a)),
            max(0, min(255, r)),
            max(0, min(255, g)),
            max(0, min(255, b)),
        )

    def _animate_interpolated(self, duration_ms: int, value_fn, apply_fn) -> None:
        """Fallback-анимация через поток с шагом ~16мс (≈60fps), используется
        только если ValueAnimator недоступен на устройстве."""
        frame_ms = 16
        steps = max(8, duration_ms // frame_ms)
        sleep_sec = duration_ms / 1000.0 / steps

        def worker():
            for i in range(1, steps + 1):
                t = i / float(steps)
                v = value_fn(t)
                def _safe_apply(val=v):
                    try:
                        apply_fn(val)
                    except Exception:
                        pass
                run_on_ui_thread_safe(_safe_apply)
                time.sleep(sleep_sec)

        threading.Thread(target=worker, name="LyricsTextAnim", daemon=True).start()

    def _apply_line_frame(self, view: TextView, scale: float, color: int) -> None:
        view.setScaleX(scale)
        view.setScaleY(scale)
        view.setAlpha(1.0)
        view.setTextColor(int(color))

    def _animate_line_state(self, view: TextView, line_index: int, is_active: bool, force: bool = False) -> None:
        """Единая анимация строки: scale и цвет двигаются в ОДНОМ ValueAnimator
        с одним update-листенером, оба свойства обновляются строго в одном
        кадре. Раньше это были два независимых аниматора (ViewPropertyAnimator
        для scale/alpha + отдельный ValueAnimator для цвета) без единой точки
        отмены — при частых сменах строки они расходились по кадрам, и
        переход выглядел как рывок вместо плавного движения. Alpha всегда
        остаётся 1.0 — "затемнение" неактивной строки делается только цветом
        и масштабом, текст никогда не просвечивает/не исчезает."""
        if not self.running:
            return

        ratio = self._inactive_scale_ratio()
        active_color = COLOR_TEXT_ACTIVE
        inactive_color = self._inactive_text_color()
        target_scale = 1.0 if is_active else ratio
        target_color = active_color if is_active else inactive_color

        # Отменяем предыдущую анимацию ИМЕННО этой строки, если она ещё идёт.
        prev = self._line_animators.pop(line_index, None)
        if prev is not None:
            try:
                prev.cancel()
            except Exception:
                pass
        try:
            view.animate().cancel()
        except Exception:
            pass

        if not self._animate_lines_enabled() or force:
            try:
                view.setScaleX(target_scale)
                view.setScaleY(target_scale)
                view.setAlpha(1.0)
                view.setTextColor(target_color)
            except Exception:
                pass
            return

        try:
            from_scale = float(view.getScaleX())
        except Exception:
            from_scale = target_scale
        try:
            from_color = int(view.getCurrentTextColor())
        except Exception:
            from_color = inactive_color if is_active else active_color

        # DecelerateInterpolator стартует с максимальной скоростью и сразу
        # тормозит — глаз видит "рывок в начале + затухание", это и читается
        # как резкий прыжок. AccelerateDecelerateInterpolator разгоняется
        # плавно и плавно тормозит — настоящий "глайд" без скачка в начале.
        # Плюс увеличена сама длительность — раньше смена была короче, чем
        # глаз успевал распознать как плавную, а не мгновенную.
        duration_ms = int(self._animation_ms() * 1.1) if is_active else int(self._animation_ms() * 1.3)

        if not ANIMATOR_AVAILABLE:
            self._animate_interpolated(
                duration_ms,
                lambda t: (from_scale + (target_scale - from_scale) * t,
                           self._lerp_color(from_color, target_color, t)),
                lambda v: self._apply_line_frame(view, v[0], v[1]),
            )
            return

        try:
            viewer_self = self  # явный захват внешнего self для замыкания листенера
            animator = ValueAnimator.ofFloat(0.0, 1.0)
            animator.setDuration(duration_ms)
            animator.setInterpolator(AccelerateDecelerateInterpolator())

            class LineFrameListener(dynamic_proxy(ValueAnimator.AnimatorUpdateListener)):
                def onAnimationUpdate(self, anim):
                    try:
                        t = float(anim.getAnimatedValue())
                        scale = from_scale + (target_scale - from_scale) * t
                        color = viewer_self._lerp_color(from_color, target_color, t)
                        view.setScaleX(scale)
                        view.setScaleY(scale)
                        view.setAlpha(1.0)
                        view.setTextColor(color)
                    except Exception:
                        pass

            animator.addUpdateListener(LineFrameListener())
            animator.start()
            self._line_animators[line_index] = animator
        except Exception:
            try:
                view.setScaleX(target_scale)
                view.setScaleY(target_scale)
                view.setAlpha(1.0)
                view.setTextColor(target_color)
            except Exception:
                pass

    def _calculate_current_index(self) -> int:
        progress = max(0.0, get_current_progress_sec() + self._sync_offset_sec())

        if self.has_synced and self.line_times:
            best_index = 0
            found = False
            for i, time_value in enumerate(self.line_times):
                if time_value is None:
                    continue
                if float_safe(time_value) <= progress:
                    best_index = i
                    found = True
                else:
                    break
            if found:
                return max(0, min(len(self.line_views) - 1, best_index))
            # До первой LRC-строки держим первую строку, а не прыгаем по всему тексту.
            return 0

        # Fallback для plainLyrics без таймкодов.
        duration = self.track.duration if self.track.duration > 0 else get_current_duration_sec()
        non_empty_indices = [i for i, line in enumerate(self.lines) if line.strip()]
        if not non_empty_indices:
            return 0
        if duration <= 0:
            return non_empty_indices[0]

        ratio = max(0.0, min(1.0, progress / duration))
        pos = int(round(ratio * (len(non_empty_indices) - 1)))
        return non_empty_indices[max(0, min(len(non_empty_indices) - 1, pos))]

    def _schedule_initial_scroll(self, generation: Optional[int] = None):
        # Два прохода: первый — мгновенный (layout ещё может не быть готов),
        # второй — через 200мс страхует случай когда шрифт/обложка догрузились позже.
        # Больше попыток не делаем — каждый instant-scrollTo выглядит как дёрганье.
        def worker():
            time.sleep(0.05)
            def _s1(g=generation):
                try:
                    self._scroll_to_current_after_layout(g, instant=True)
                except Exception:
                    pass
            run_on_ui_thread_safe(_s1)
            time.sleep(0.20)
            def _s2(g=generation):
                try:
                    self._scroll_to_current_after_layout(g, instant=True)
                except Exception:
                    pass
            run_on_ui_thread_safe(_s2)

        try:
            threading.Thread(target=worker, name="LyricsInitialScroll", daemon=True).start()
        except Exception:
            pass

    def _scroll_to_current_after_layout(self, generation: Optional[int] = None, instant: bool = True):
        if generation is not None and generation != self.load_generation:
            return
        if not self.scroll or not self.line_views:
            return
        try:
            index = self._calculate_current_index()
            self._scroll_to_index(index, instant=instant)
        except Exception:
            pass

    def _scroll_to_index(self, index: int, instant: bool = False):
        if not self.running:
            return
        if not self.scroll or index < 0 or index >= len(self.line_views):
            return
        try:
            line_view = self.line_views[index]
            top = line_view.getTop()
            height = line_view.getHeight()
            scroll_height = self.scroll.getHeight()
            padding_top = self.scroll.getPaddingTop()

            if scroll_height <= 0 or height <= 0:
                return

            target_y = max(0, int(top - scroll_height / 2 + height / 2 + padding_top))

            if instant:
                # Отменяем текущую анимацию если была
                try:
                    if self.scroll_animator is not None:
                        self.scroll_animator.cancel()
                        self.scroll_animator = None
                except Exception:
                    pass
                self.last_scroll_target = target_y
                self.scroll.scrollTo(0, target_y)
                return

            if target_y == self.last_scroll_target:
                return
            self.last_scroll_target = target_y

            # ObjectAnimator даёт 60fps через Choreographer — плавнее smoothScrollTo
            if ANIMATOR_AVAILABLE:
                try:
                    if self.scroll_animator is not None:
                        self.scroll_animator.cancel()
                    current_y = self.scroll.getScrollY()
                    distance = abs(target_y - current_y)
                    # Раньше distance // 3 с полом 220 почти всегда упирался в
                    # пол (для обычного перехода на одну строку дистанция
                    # маленькая), и текст реально проезжал весь путь за ~220мс
                    # с резким стартом (DecelerateInterpolator) — глаз видел
                    # это как прыжок, а не уход текста вверх. Теперь длительность
                    # ощутимее зависит от дистанции и интерполятор тот же
                    # ease-in-out, что у смены цвета/масштаба строки — скролл и
                    # смена строки визуально завершаются примерно вместе.
                    duration = max(260, min(480, distance // 2))
                    animator = ObjectAnimator.ofInt(self.scroll, "scrollY", current_y, target_y)
                    animator.setDuration(duration)
                    animator.setInterpolator(AccelerateDecelerateInterpolator())
                    animator.start()
                    self.scroll_animator = animator
                    return
                except Exception:
                    pass

            # Fallback если ObjectAnimator недоступен
            self.scroll.smoothScrollTo(0, target_y)
        except Exception:
            pass

    def _setting_int(self, key: str, default: int, minimum: int, maximum: int) -> int:
        return setting_int(self.plugin, key, default, minimum, maximum)

    def _setting_float(self, key: str, default: float, minimum: float, maximum: float) -> float:
        return setting_float(self.plugin, key, default, minimum, maximum)

    def _header_height_dp(self) -> int:
        return self._setting_int("header_height_dp", DEFAULT_HEADER_HEIGHT_DP, 32, 64)

    def _header_bg_color(self) -> int:
        return Color.argb(245, 10, 10, 10)

    def _dim_overlay_color(self) -> int:
        return Color.argb(self._setting_int("dim_alpha", DEFAULT_DIM_ALPHA, 0, 230), 0, 0, 0)

    def _inactive_alpha(self) -> int:
        return self._setting_int("inactive_alpha", DEFAULT_INACTIVE_ALPHA, 70, 230)

    def _inactive_text_color(self) -> int:
        return argb_gray(self._inactive_alpha(), 185)

    def _muted_text_color(self) -> int:
        return argb_gray(self._inactive_alpha(), 185)

    def _title_text_size(self) -> int:
        return self._setting_int("title_text_size", DEFAULT_TITLE_TEXT_SIZE, 11, 18)

    def _subtitle_text_size(self) -> int:
        return self._setting_int("subtitle_text_size", DEFAULT_SUBTITLE_TEXT_SIZE, 9, 15)

    def _line_text_size(self) -> int:
        return self._setting_int("line_text_size", DEFAULT_LINE_TEXT_SIZE, 18, 42)

    def _active_line_text_size(self) -> int:
        return self._setting_int("active_line_text_size", DEFAULT_ACTIVE_LINE_TEXT_SIZE, 20, 50)

    def _inactive_scale_ratio(self) -> float:
        """Во сколько раз неактивная строка визуально меньше активной.
        Реальный textSize у всех строк всегда равен active_line_text_size,
        а "уменьшение" неактивных строк делается только через scaleX/scaleY,
        чтобы перенос строк никогда не пересчитывался заново."""
        active = float(self._active_line_text_size())
        inactive = float(self._line_text_size())
        if active <= 0:
            return 1.0
        ratio = inactive / active
        return max(0.3, min(1.0, ratio))

    def _active_text_shadow_radius(self) -> float:
        return float(self._setting_int("active_text_shadow_radius", int(round(DEFAULT_ACTIVE_TEXT_SHADOW_RADIUS)), 0, 10))

    def _inactive_text_shadow_radius(self) -> float:
        return float(self._setting_int("inactive_text_shadow_radius", int(round(DEFAULT_INACTIVE_TEXT_SHADOW_RADIUS)), 0, 10))

    def _blur_radius(self) -> int:
        return self._setting_int("blur_radius", DEFAULT_BLUR_RADIUS, 0, 32)

    def _animate_lines_enabled(self) -> bool:
        return setting_bool(self.plugin, "animate_lines", DEFAULT_ANIMATE_LINES)

    def _animation_ms(self) -> int:
        return self._setting_int("animation_ms", DEFAULT_ANIMATION_MS, 60, 450)

    def _sync_offset_sec(self) -> float:
        return self._setting_float("sync_offset_sec", DEFAULT_SYNC_OFFSET_SEC, -5.0, 5.0)

    def close(self):
        self.running = False
        self._cover_gen += 1  # отменяем все висящие фоновые загрузки обложки
        # Останавливаем ObjectAnimator скролла — он тикает через Choreographer и
        # после dismiss() продолжает вызывать scroll.scrollY на мёртвом View → SIGSEGV.
        try:
            if self.scroll_animator is not None:
                self.scroll_animator.cancel()
                self.scroll_animator = None
        except Exception:
            pass
        # Останавливаем все анимации строк по той же причине.
        try:
            with self._ui_lock:
                views = list(self.line_views)
            for v in views:
                try:
                    v.animate().cancel()
                except Exception:
                    pass
        except Exception:
            pass
        try:
            if self.dialog and self.dialog.isShowing():
                self.dialog.dismiss()
        except Exception:
            pass
        try:
            if self.bg_bitmap is not None and not self.bg_bitmap.isRecycled():
                self.bg_bitmap.recycle()
        except Exception:
            pass
        self.bg_bitmap = None
        # Убираем ссылку на себя из плагина, чтобы следующий present_viewer
        # не пытался закрыть уже закрытый вьюер (защита от двойного вызова).
        try:
            if getattr(self.plugin, '_active_viewer', None) is self:
                self.plugin._active_viewer = None
        except Exception:
            pass

    def _apply_active_text_shadow(self, text_view: TextView) -> None:
        try:
            text_view.setShadowLayer(self._active_text_shadow_radius(), TEXT_SHADOW_DX, TEXT_SHADOW_DY, TEXT_SHADOW_COLOR)
        except Exception:
            pass

    def _apply_inactive_text_shadow(self, text_view: TextView) -> None:
        try:
            text_view.setShadowLayer(self._inactive_text_shadow_radius(), TEXT_SHADOW_DX, TEXT_SHADOW_DY, TEXT_SHADOW_COLOR)
        except Exception:
            pass

    def _clear_cover_background(self) -> None:
        try:
            if self.background_fade_image:
                self.background_fade_image.animate().cancel()
                self.background_fade_image.setAlpha(0.0)
                self.background_fade_image.setImageDrawable(None)
                self.background_fade_image.setBackgroundColor(Color.TRANSPARENT)
        except Exception:
            pass
        try:
            if self.background_image:
                self.background_image.animate().cancel()
                self.background_image.setAlpha(1.0)
                self.background_image.setImageDrawable(None)
                self.background_image.setBackgroundColor(COLOR_BG)
        except Exception:
            pass
        try:
            if self.bg_bitmap is not None and not self.bg_bitmap.isRecycled():
                self.bg_bitmap.recycle()
        except Exception:
            pass
        self.bg_bitmap = None
        self.bg_path = None

    def _cover_fade_ms(self) -> int:
        # Пока без отдельной настройки, чтобы не раздувать меню: значение подобрано так,
        # чтобы обложка появлялась мягко, но не ощущалась медленной.
        return DEFAULT_COVER_FADE_MS

    def _ambient_enabled(self) -> bool:
        return setting_bool(self.plugin, "ambient_enabled", DEFAULT_AMBIENT_ENABLED)

    def _ambient_alpha(self) -> int:
        return self._setting_int("ambient_alpha", DEFAULT_AMBIENT_ALPHA, 0, 180)

    def _ambient_blob_count(self) -> int:
        return self._setting_int("ambient_blobs", DEFAULT_AMBIENT_BLOBS, 2, 12)

    def _ambient_blob_size_dp(self) -> int:
        return self._setting_int("ambient_blob_size_dp", DEFAULT_AMBIENT_BLOB_SIZE_DP, 160, 720)

    def _ambient_speed_sec(self) -> int:
        return self._setting_int("ambient_speed_sec", DEFAULT_AMBIENT_SPEED_SEC, 4, 28)

    def _ambient_saturation(self) -> int:
        return self._setting_int("ambient_saturation", DEFAULT_AMBIENT_SATURATION, 50, 220)

    def _fallback_ambient_palette(self) -> List[Tuple[int, int, int]]:
        return [(146, 83, 255), (51, 154, 255), (255, 84, 162), (255, 190, 92), (92, 255, 214)]

    def _extract_ambient_palette(self, src_path: str) -> Optional[List[Tuple[int, int, int]]]:
        """Берём цвета именно из обложки, без сильного искусственного перекраса.

        Предыдущая версия слишком сильно вытягивала насыщенность и яркость, поэтому
        ambient-слой иногда выглядел "не от этой обложки". Здесь логика мягче:
        - используем реальные доминирующие цвета;
        - не превращаем серые/тёмные оттенки в кислотные;
        - добавляем средний цвет обложки, чтобы палитра лучше совпадала с общей гаммой.
        """
        if not PIL_AVAILABLE or not src_path or not os.path.exists(src_path):
            return None
        try:
            safe_path = _safe_pil_source(src_path, 400)
            if not safe_path:
                # Не рискуем отдавать PIL необработанный оригинал (см. _safe_pil_source) —
                # без палитры ambient-слой просто не появится, это не критично.
                return None
            im = Image.open(safe_path)
            try:
                im.draft("RGB", (80, 80))
            except Exception:
                pass
            im = im.convert("RGB")
            im.thumbnail((80, 80))

            pixels = list(im.getdata())
            if not pixels:
                return None

            avg_r = sum(p[0] for p in pixels) // len(pixels)
            avg_g = sum(p[1] for p in pixels) // len(pixels)
            avg_b = sum(p[2] for p in pixels) // len(pixels)

            try:
                pal_img = im.convert("P", palette=Image.ADAPTIVE, colors=18)
            except Exception:
                pal_img = im.convert("P", colors=18)
            palette_raw = pal_img.getpalette() or []
            colors = pal_img.getcolors(80 * 80) or []

            candidates: List[Tuple[float, Tuple[int, int, int]]] = []
            saturation_mul = self._ambient_saturation() / 100.0

            for count, idx in colors:
                base = int(idx) * 3
                if base + 2 >= len(palette_raw):
                    continue
                r, g, b = int(palette_raw[base]), int(palette_raw[base + 1]), int(palette_raw[base + 2])
                h, sat, val = colorsys.rgb_to_hsv(r / 255.0, g / 255.0, b / 255.0)

                # Почти чёрные цвета оставляем только если они реально заметны, иначе пятна будут грязными.
                if val < 0.08:
                    continue

                # Очень аккуратная коррекция: цвет остаётся цветом обложки, а настройка насыщенности
                # только слегка усиливает/ослабляет его, не перепридумывая палитру.
                if sat > 0.06:
                    sat = max(0.04, min(1.0, sat * saturation_mul))
                val = max(0.16, min(0.98, val))
                rr, gg, bb = colorsys.hsv_to_rgb(h, sat, val)
                rgb = (int(rr * 255), int(gg * 255), int(bb * 255))

                # Балансируем частотность и выразительность. Так палитра не становится случайным
                # набором редких ярких пикселей, но и не уходит в один серый/чёрный цвет.
                score = float(count) * (0.55 + sat) * (0.55 + val)
                candidates.append((score, rgb))

            # Средний цвет помогает ambient-слою совпасть с общей гаммой обложки.
            avg_h, avg_s, avg_v = colorsys.rgb_to_hsv(avg_r / 255.0, avg_g / 255.0, avg_b / 255.0)
            if avg_v >= 0.08:
                avg_s = max(0.04, min(1.0, avg_s * saturation_mul)) if avg_s > 0.06 else avg_s
                rr, gg, bb = colorsys.hsv_to_rgb(avg_h, avg_s, max(0.16, min(0.98, avg_v)))
                candidates.append((len(pixels) * 0.35, (int(rr * 255), int(gg * 255), int(bb * 255))))

            candidates.sort(reverse=True, key=lambda item: item[0])

            output: List[Tuple[int, int, int]] = []
            for _, rgb in candidates:
                too_close = False
                for old in output:
                    if abs(old[0] - rgb[0]) + abs(old[1] - rgb[1]) + abs(old[2] - rgb[2]) < 44:
                        too_close = True
                        break
                if not too_close:
                    output.append(rgb)
                if len(output) >= 8:
                    break

            # Если обложка почти монохромная, всё равно даём несколько близких вариантов,
            # чтобы пятна не выглядели одинаковыми.
            if len(output) == 1:
                r, g, b = output[0]
                h, sat, val = colorsys.rgb_to_hsv(r / 255.0, g / 255.0, b / 255.0)
                for delta in (-0.035, 0.028, 0.055):
                    rr, gg, bb = colorsys.hsv_to_rgb((h + delta) % 1.0, sat, max(0.14, min(0.98, val * random.uniform(0.86, 1.10))))
                    output.append((int(rr * 255), int(gg * 255), int(bb * 255)))

            return output or None
        except Exception as e:
            self.plugin.log("ambient palette failed: " + str(e))
            return None

    def _ambient_blob_drawable(self, rgb: Tuple[int, int, int], size_px: int) -> GradientDrawable:
        r, g, b = rgb
        drawable = GradientDrawable()
        try:
            drawable.setShape(GradientDrawable.OVAL)
            drawable.setGradientType(GradientDrawable.RADIAL_GRADIENT)
            drawable.setGradientCenter(0.5, 0.5)
            drawable.setGradientRadius(float(size_px) * 0.56)
            # Центр чуть прозрачнее, чем раньше: цвета мягче слипаются и меньше выбиваются из обложки.
            drawable.setColors([
                Color.argb(210, r, g, b),
                Color.argb(88, r, g, b),
                Color.argb(0, r, g, b),
            ])
        except Exception:
            try:
                drawable.setShape(GradientDrawable.OVAL)
                drawable.setColor(Color.argb(72, r, g, b))
            except Exception:
                pass
        return drawable

    def _shift_ambient_color(self, rgb: Tuple[int, int, int], state: Dict[str, Any]) -> Tuple[int, int, int]:
        """Лёгкая смена оттенка без ухода от палитры обложки."""
        try:
            r, g, b = rgb
            h, sat, val = colorsys.rgb_to_hsv(r / 255.0, g / 255.0, b / 255.0)
            phase = float_safe(state.get("phase"), 0.0)
            # Максимум около ±3.5% круга оттенка — ощущается живо, но цвет всё ещё "из обложки".
            hue_shift = math.sin(phase) * 0.035
            sat_mul = 0.92 + 0.14 * math.sin(phase * 0.73 + 1.7)
            val_mul = 0.92 + 0.16 * math.cos(phase * 0.61 + 0.9)
            rr, gg, bb = colorsys.hsv_to_rgb((h + hue_shift) % 1.0, max(0.0, min(1.0, sat * sat_mul)), max(0.12, min(1.0, val * val_mul)))
            return (int(rr * 255), int(gg * 255), int(bb * 255))
        except Exception:
            return rgb

    def _rebuild_ambient_blobs(self, palette: Optional[List[Tuple[int, int, int]]] = None) -> None:
        try:
            if not self.ambient_container:
                return
            had_blobs = bool(self.ambient_blob_views)
            self.ambient_container.removeAllViews()
            self.ambient_blob_views = []
            self.ambient_blob_states = []

            if not self._ambient_enabled() or self._ambient_alpha() <= 0:
                try:
                    self.ambient_container.setVisibility(View.GONE)
                except Exception:
                    pass
                return

            try:
                self.ambient_container.setVisibility(View.VISIBLE)
            except Exception:
                pass
            target_alpha = max(0.0, min(1.0, self._ambient_alpha() / 255.0))
            # При смене палитры мягко проявляем новый слой, чтобы цвета не прыгали резко.
            self.ambient_container.setAlpha(0.0 if (had_blobs or palette) else target_alpha)

            self.ambient_palette = palette or self._fallback_ambient_palette()
            count = self._ambient_blob_count()
            size_px = dp(self.context, self._ambient_blob_size_dp())
            w, h = self._ambient_screen_size()
            for i in range(count):
                color = self.ambient_palette[i % len(self.ambient_palette)]
                blob = View(self.context)
                blob.setBackground(self._ambient_blob_drawable(color, size_px))
                try:
                    blob.setAlpha(random.uniform(0.62, 0.95))
                except Exception:
                    pass
                lp = FrameLayout.LayoutParams(size_px, size_px)
                self.ambient_container.addView(blob, lp)
                self.ambient_blob_views.append(blob)

                state = {
                    "base_color": color,
                    "phase": random.uniform(0.0, 6.28318),
                    "angle": random.uniform(0.0, 6.28318),
                    "x": random.uniform(-size_px * 0.42, max(1.0, w - size_px * 0.58)),
                    "y": random.uniform(-size_px * 0.36, max(1.0, h - size_px * 0.48)),
                    "scale": random.uniform(0.82, 1.22),
                    "alpha": random.uniform(0.58, 0.96),
                }
                self.ambient_blob_states.append(state)

            self._animate_ambient_step(first=True)
            try:
                self.ambient_container.animate().alpha(target_alpha).setDuration(max(180, self._cover_fade_ms())).start()
            except Exception:
                self.ambient_container.setAlpha(target_alpha)
        except Exception as e:
            self.plugin.log("ambient rebuild failed: " + str(e))

    def _ensure_ambient_loop(self) -> None:
        if self.ambient_loop_started:
            return
        self.ambient_loop_started = True

        def worker():
            try:
                # Небольшая задержка нужна, чтобы FrameLayout успел получить размеры.
                time.sleep(0.20)
                while self.running and self.dialog and self.dialog.isShowing():
                    if self._ambient_enabled() and self.ambient_blob_views:
                        def _safe_ambient():
                            try:
                                self._animate_ambient_step(first=False)
                            except Exception as _e:
                                _log_safe("ambient step UI callback", _e)
                        run_on_ui_thread_safe(_safe_ambient)
                    # Частые маленькие шаги лучше длинных переходов: нет ощущения, что круги
                    # доехали до точки и остановились.
                    time.sleep(max(0.45, min(2.2, self._ambient_speed_sec() / 9.0)))
            except Exception:
                pass
            self.ambient_loop_started = False

        try:
            threading.Thread(target=worker, name="LyricsAmbientOverlay", daemon=True).start()
        except Exception:
            self.ambient_loop_started = False

    def _ambient_screen_size(self) -> Tuple[int, int]:
        try:
            if self.frame_root:
                w = self.frame_root.getWidth()
                h = self.frame_root.getHeight()
                if w > 0 and h > 0:
                    return int(w), int(h)
        except Exception:
            pass
        try:
            dm = self.context.getResources().getDisplayMetrics()
            return int(dm.widthPixels), int(dm.heightPixels)
        except Exception:
            return dp(self.context, 390), dp(self.context, 780)

    def _ambient_linear_interpolator(self) -> Any:
        try:
            return jclass("android.view.animation.LinearInterpolator")()
        except Exception:
            return None

    def _animate_ambient_step(self, first: bool = False) -> None:
        try:
            if not self.ambient_container or not self.ambient_blob_views or not self._ambient_enabled():
                return
            w, h = self._ambient_screen_size()
            size_px = dp(self.context, self._ambient_blob_size_dp())
            step_delay = max(0.45, min(2.2, self._ambient_speed_sec() / 9.0))
            duration = 0 if first else int(step_delay * 1450)
            interpolator = None if first else self._ambient_linear_interpolator()

            # Если по какой-то причине состояний меньше, чем view, восстанавливаем их без падения.
            while len(self.ambient_blob_states) < len(self.ambient_blob_views):
                color = self.ambient_palette[len(self.ambient_blob_states) % max(1, len(self.ambient_palette))] if self.ambient_palette else self._fallback_ambient_palette()[0]
                self.ambient_blob_states.append({
                    "base_color": color,
                    "phase": random.uniform(0.0, 6.28318),
                    "angle": random.uniform(0.0, 6.28318),
                    "x": random.uniform(-size_px * 0.42, max(1.0, w - size_px * 0.58)),
                    "y": random.uniform(-size_px * 0.36, max(1.0, h - size_px * 0.48)),
                    "scale": random.uniform(0.82, 1.22),
                    "alpha": random.uniform(0.58, 0.96),
                })

            for i, blob in enumerate(self.ambient_blob_views):
                state = self.ambient_blob_states[i]
                min_x = -int(size_px * 0.48)
                max_x = max(min_x + 1, w - int(size_px * 0.52))
                min_y = -int(size_px * 0.42)
                max_y = max(min_y + 1, h - int(size_px * 0.48))

                if first:
                    x = float_safe(state.get("x"), random.uniform(min_x, max_x))
                    y = float_safe(state.get("y"), random.uniform(min_y, max_y))
                    scale = float_safe(state.get("scale"), random.uniform(0.82, 1.22))
                    alpha = float_safe(state.get("alpha"), random.uniform(0.58, 0.96))
                else:
                    # Хаотичная, но плавная траектория: random-walk + синусоидальные микросмещения.
                    phase = float_safe(state.get("phase"), 0.0) + random.uniform(0.22, 0.62)
                    angle = float_safe(state.get("angle"), 0.0) + random.uniform(-1.35, 1.35)
                    speed_factor = max(0.42, min(1.45, 11.0 / max(4.0, float(self._ambient_speed_sec()))))
                    step = size_px * random.uniform(0.045, 0.13) * speed_factor
                    swirl_x = math.sin(phase * 1.31 + i * 0.77) * size_px * random.uniform(0.010, 0.032)
                    swirl_y = math.cos(phase * 1.17 + i * 0.91) * size_px * random.uniform(0.010, 0.032)
                    x = float_safe(state.get("x"), random.uniform(min_x, max_x)) + math.cos(angle) * step + swirl_x
                    y = float_safe(state.get("y"), random.uniform(min_y, max_y)) + math.sin(angle) * step + swirl_y

                    # Мягкий отскок от краёв, чтобы круги не зависали снаружи и не телепортировались.
                    if x < min_x or x > max_x:
                        angle = math.pi - angle + random.uniform(-0.55, 0.55)
                        x = max(min_x, min(max_x, x))
                    if y < min_y or y > max_y:
                        angle = -angle + random.uniform(-0.55, 0.55)
                        y = max(min_y, min(max_y, y))

                    scale = max(0.72, min(1.36, float_safe(state.get("scale"), 1.0) + random.uniform(-0.055, 0.055) + math.sin(phase * 0.7 + i) * 0.018))
                    alpha = max(0.48, min(1.0, float_safe(state.get("alpha"), 0.8) + random.uniform(-0.045, 0.045)))
                    state["phase"] = phase
                    state["angle"] = angle
                    state["x"] = x
                    state["y"] = y
                    state["scale"] = scale
                    state["alpha"] = alpha

                    shifted = self._shift_ambient_color(state.get("base_color", self.ambient_palette[i % len(self.ambient_palette)] if self.ambient_palette else (255, 255, 255)), state)
                    try:
                        blob.setBackground(self._ambient_blob_drawable(shifted, size_px))
                    except Exception:
                        pass

                if first:
                    blob.setTranslationX(float(x))
                    blob.setTranslationY(float(y))
                    blob.setScaleX(scale)
                    blob.setScaleY(scale)
                    blob.setAlpha(alpha)
                    try:
                        shifted = self._shift_ambient_color(state.get("base_color", self.ambient_palette[i % len(self.ambient_palette)] if self.ambient_palette else (255, 255, 255)), state)
                        blob.setBackground(self._ambient_blob_drawable(shifted, size_px))
                    except Exception:
                        pass
                else:
                    try:
                        blob.animate().cancel()
                    except Exception:
                        pass
                    try:
                        animator = blob.animate().translationX(float(x)).translationY(float(y)).scaleX(scale).scaleY(scale).alpha(alpha).setDuration(duration)
                        if interpolator is not None:
                            animator.setInterpolator(interpolator)
                        animator.start()
                    except Exception:
                        blob.setTranslationX(float(x))
                        blob.setTranslationY(float(y))
                        blob.setScaleX(scale)
                        blob.setScaleY(scale)
                        blob.setAlpha(alpha)
        except Exception as e:
            self.plugin.log("ambient animate failed: " + str(e))

    def _load_cover_background_async(self, generation: Optional[int] = None, cover_gen: Optional[int] = None) -> None:
        if not self.background_image:
            return
        if generation is None:
            generation = self.load_generation
        if cover_gen is None:
            cover_gen = self._cover_gen
        track_snapshot = self.track

        def worker():
            bitmap = None
            bg_path = None
            try:
                # Шаг 1: ищем обложку локально (может ждать скачки у Telegram ~1.2с)
                cover_path = self._extract_album_art_path()

                # Проверяем актуальность до тяжёлых операций
                if cover_gen != self._cover_gen:
                    return

                if not cover_path:
                    cover_path = self._fetch_cover_online(track_snapshot.title, track_snapshot.artist)

                # Проверяем ещё раз — сетевое скачивание могло занять 5-7 секунд
                if cover_gen != self._cover_gen:
                    return

                if cover_path and os.path.exists(cover_path):
                    if PIL_AVAILABLE:
                        bg_path = self._make_blurred_cache(cover_path, track_snapshot)
                    else:
                        bg_path = cover_path

                # PIL-блюр мог занять время — снова проверяем
                if cover_gen != self._cover_gen:
                    return

                palette = None
                if cover_path and os.path.exists(cover_path):
                    palette = self._extract_ambient_palette(cover_path)
                elif bg_path and os.path.exists(bg_path):
                    palette = self._extract_ambient_palette(bg_path)

                if cover_gen != self._cover_gen:
                    return

                if bg_path and os.path.exists(bg_path):
                    # 1080px по большей стороне более чем достаточно для blur-фона на весь экран.
                    bitmap = _decode_bitmap_bounded(bg_path, 1080)

                # Последняя проверка перед передачей bitmap в UI
                if cover_gen != self._cover_gen:
                    try:
                        if bitmap is not None and not bitmap.isRecycled():
                            bitmap.recycle()
                    except Exception:
                        pass
                    return

                if bitmap is not None:
                    def _safe_apply(p=bg_path, b=bitmap, g=generation, pal=palette):
                        try:
                            self._apply_cover_bitmap(p, b, g, pal)
                        except Exception as _e:
                            _log_safe("_apply_cover_bitmap UI callback", _e)
                            try:
                                if b is not None and not b.isRecycled():
                                    b.recycle()
                            except Exception:
                                pass
                    run_on_ui_thread_safe(_safe_apply)
                else:
                    def _safe_fade(g=generation):
                        try:
                            self._fade_to_empty_cover(g)
                        except Exception as _e:
                            _log_safe("_fade_to_empty_cover UI callback", _e)
                    run_on_ui_thread_safe(_safe_fade)
            except Exception as e:
                self.plugin.log("cover background failed: " + str(e))
                try:
                    if bitmap is not None and not bitmap.isRecycled():
                        bitmap.recycle()
                except Exception:
                    pass

        threading.Thread(target=worker, name="LyricsCoverBG", daemon=True).start()

    def _apply_cover_bitmap(self, path: Optional[str], bitmap: Bitmap, generation: Optional[int] = None, palette: Optional[List[Tuple[int, int, int]]] = None) -> None:
        try:
            if generation is not None and generation != self.load_generation:
                if bitmap is not None and not bitmap.isRecycled():
                    bitmap.recycle()
                return
            try:
                dialog_alive = self.dialog and self.dialog.isShowing()
            except Exception:
                dialog_alive = False
            if not dialog_alive or not self.background_image:
                if bitmap is not None and not bitmap.isRecycled():
                    bitmap.recycle()
                return
            if bitmap is None or bitmap.isRecycled():
                return

            self._rebuild_ambient_blobs(palette)

            old_bitmap = self.bg_bitmap
            drawable = BitmapDrawable(self.context.getResources(), bitmap)
            self.bg_bitmap = bitmap
            self.bg_path = path

            # Если фон уже есть, новая обложка проявляется отдельным слоем поверх старой.
            # Так нет момента с пустым/чёрным фоном и нет резкого скачка картинки.
            if self.background_fade_image and old_bitmap is not None and old_bitmap is not bitmap:
                try:
                    self.background_fade_image.animate().cancel()
                except Exception:
                    pass
                self.background_fade_image.setBackgroundColor(Color.TRANSPARENT)
                self.background_fade_image.setImageDrawable(drawable)
                self.background_fade_image.setAlpha(0.0)
                try:
                    self.background_fade_image.setVisibility(View.VISIBLE)
                except Exception:
                    pass
                try:
                    self.background_fade_image.animate().alpha(1.0).setDuration(self._cover_fade_ms()).start()
                except Exception:
                    self.background_fade_image.setAlpha(1.0)
                self._finish_cover_crossfade_later(drawable, old_bitmap, generation)
            else:
                try:
                    self.background_image.animate().cancel()
                except Exception:
                    pass
                self.background_image.setImageDrawable(drawable)
                self.background_image.setBackgroundColor(Color.TRANSPARENT)
                self.background_image.setAlpha(0.0)
                try:
                    self.background_image.animate().alpha(1.0).setDuration(self._cover_fade_ms()).start()
                except Exception:
                    self.background_image.setAlpha(1.0)
                if old_bitmap is not None and old_bitmap is not bitmap:
                    self._recycle_bitmap_later(old_bitmap, self._cover_fade_ms())
        except Exception:
            try:
                if bitmap is not None and bitmap is not self.bg_bitmap and not bitmap.isRecycled():
                    bitmap.recycle()
            except Exception:
                pass

    def _finish_cover_crossfade_later(self, drawable: BitmapDrawable, old_bitmap: Optional[Bitmap], generation: Optional[int]) -> None:
        delay = max(0.05, (self._cover_fade_ms() + 80) / 1000.0)

        def worker():
            time.sleep(delay)
            def _safe_finish(d=drawable, ob=old_bitmap, g=generation):
                try:
                    self._finish_cover_crossfade(d, ob, g)
                except Exception as _e:
                    _log_safe("_finish_cover_crossfade UI callback", _e)
            run_on_ui_thread_safe(_safe_finish)

        threading.Thread(target=worker, name="LyricsCoverFadeFinish", daemon=True).start()

    def _finish_cover_crossfade(self, drawable: BitmapDrawable, old_bitmap: Optional[Bitmap], generation: Optional[int]) -> None:
        try:
            if generation is not None and generation != self.load_generation:
                return
            if not self.dialog or not self.dialog.isShowing() or not self.background_image:
                return
            self.background_image.setImageDrawable(drawable)
            self.background_image.setBackgroundColor(Color.TRANSPARENT)
            self.background_image.setAlpha(1.0)
            if self.background_fade_image:
                try:
                    self.background_fade_image.animate().cancel()
                except Exception:
                    pass
                self.background_fade_image.setAlpha(0.0)
                self.background_fade_image.setImageDrawable(None)
                self.background_fade_image.setBackgroundColor(Color.TRANSPARENT)
        finally:
            if old_bitmap is not None and old_bitmap is not self.bg_bitmap:
                try:
                    if not old_bitmap.isRecycled():
                        old_bitmap.recycle()
                except Exception:
                    pass

    def _fade_to_empty_cover(self, generation: Optional[int] = None) -> None:
        try:
            if generation is not None and generation != self.load_generation:
                return
            if not self.background_image:
                return
            old_bitmap = self.bg_bitmap
            self.bg_bitmap = None
            self.bg_path = None
            self._rebuild_ambient_blobs(None)

            if self.background_fade_image and old_bitmap is not None:
                try:
                    self.background_fade_image.animate().cancel()
                except Exception:
                    pass
                self.background_fade_image.setImageDrawable(None)
                self.background_fade_image.setBackgroundColor(COLOR_BG)
                self.background_fade_image.setAlpha(0.0)
                try:
                    self.background_fade_image.animate().alpha(1.0).setDuration(self._cover_fade_ms()).start()
                except Exception:
                    self.background_fade_image.setAlpha(1.0)

                def finish():
                    time.sleep((self._cover_fade_ms() + 80) / 1000.0)
                    def _safe_empty(g=generation, ob=old_bitmap):
                        try:
                            self._finish_empty_cover(g, ob)
                        except Exception as _e:
                            _log_safe("_finish_empty_cover UI callback", _e)
                    run_on_ui_thread_safe(_safe_empty)
                threading.Thread(target=finish, name="LyricsCoverEmptyFade", daemon=True).start()
            else:
                self._finish_empty_cover(generation, old_bitmap)
        except Exception:
            pass

    def _finish_empty_cover(self, generation: Optional[int], old_bitmap: Optional[Bitmap]) -> None:
        try:
            if generation is not None and generation != self.load_generation:
                return
            if self.background_image:
                try:
                    self.background_image.animate().cancel()
                except Exception:
                    pass
                self.background_image.setImageDrawable(None)
                self.background_image.setBackgroundColor(COLOR_BG)
                self.background_image.setAlpha(1.0)
            if self.background_fade_image:
                try:
                    self.background_fade_image.animate().cancel()
                except Exception:
                    pass
                self.background_fade_image.setAlpha(0.0)
                self.background_fade_image.setImageDrawable(None)
                self.background_fade_image.setBackgroundColor(Color.TRANSPARENT)
        finally:
            if old_bitmap is not None:
                try:
                    if not old_bitmap.isRecycled():
                        old_bitmap.recycle()
                except Exception:
                    pass

    def _recycle_bitmap_later(self, bitmap: Optional[Bitmap], delay_ms: int) -> None:
        if bitmap is None:
            return

        def worker():
            time.sleep(max(0.05, (delay_ms + 80) / 1000.0))
            try:
                if bitmap is not self.bg_bitmap and not bitmap.isRecycled():
                    bitmap.recycle()
            except Exception:
                pass

        threading.Thread(target=worker, name="LyricsCoverRecycle", daemon=True).start()

    def _make_blurred_cache(self, src_path: str, track: Optional[TrackInfo] = None) -> Optional[str]:
        if not PIL_AVAILABLE:
            return None
        try:
            cache_dir = os.path.join(Plugin.dir_path(), "cover_cache")
            os.makedirs(cache_dir, exist_ok=True)
            track = track or self.track
            raw_key = f"{track.artist}|{track.title}|{track.duration}|{src_path}|blur={self._blur_radius()}"
            suffix = hashlib.md5(raw_key.encode("utf-8", "ignore")).hexdigest()[:16]
            out_path = os.path.join(cache_dir, f"cover_blur_{suffix}.jpg")

            # Если уже есть готовый размытый фон — не пересоздаём.
            if os.path.exists(out_path) and os.path.getmtime(out_path) >= os.path.getmtime(src_path):
                return out_path

            max_side = 720
            safe_path = _safe_pil_source(src_path, max_side)
            if not safe_path:
                # Не рискуем отдавать PIL необработанный оригинал (см. _safe_pil_source) —
                # без блюра фон просто останется пустым/обычной обложкой, это не критично.
                return None
            im = Image.open(safe_path)
            try:
                # Для JPEG draft() декодирует уже уменьшенную версию вместо полного
                # разрешения — экономит память на крупных обложках (часто 2000px+).
                # safe_path уже гарантированно небольшой (см. _safe_pil_source), это
                # дополнительная экономия для JPEG-конкретно.
                im.draft("RGB", (max_side, max_side))
            except Exception:
                pass
            im = im.convert("RGB")
            w, h = im.size
            scale = max(w, h) / float(max_side)
            if scale > 1.0:
                resample = getattr(Image, "LANCZOS", getattr(Image, "BICUBIC", 3))
                im = im.resize((max(1, int(w / scale)), max(1, int(h / scale))), resample)
            im = im.filter(ImageFilter.GaussianBlur(radius=self._blur_radius()))
            im.save(out_path, "JPEG", quality=68, optimize=True)
            return out_path
        except Exception as e:
            self.plugin.log("make blurred cover failed: " + str(e))
            return None

    def _extract_album_art_path(self) -> Optional[str]:
        try:
            mc = get_media_controller().getInstance()

            # Основной вариант из miniPlayer+: MediaController.getAudioInfo().getCoverFile()
            try:
                ai = mc.getAudioInfo()
                if ai is not None:
                    cf = ai.getCoverFile()
                    if cf is not None and cf.exists():
                        return cf.getAbsolutePath()
            except Exception:
                pass

            mo = mc.getPlayingMessageObject()
            if mo is None:
                return None
            try:
                doc = mo.getDocument()
            except Exception:
                doc = None
            if doc is None:
                return None

            best_thumb = None
            max_area = -1
            thumbs = getattr(doc, "thumbs", None)
            if thumbs:
                iterator = None
                try:
                    iterator = thumbs.iterator()
                except Exception:
                    iterator = None

                if iterator is not None:
                    while iterator.hasNext():
                        t = iterator.next()
                        area = self._thumb_area(t)
                        if area > max_area:
                            max_area = area
                            best_thumb = t
                else:
                    try:
                        for t in thumbs:
                            area = self._thumb_area(t)
                            if area > max_area:
                                max_area = area
                                best_thumb = t
                    except Exception:
                        pass

            if best_thumb is None:
                return None

            FileLoader = jclass("org.telegram.messenger.FileLoader")
            UserConfig = jclass("org.telegram.messenger.UserConfig")
            fl = FileLoader.getInstance(UserConfig.selectedAccount)
            pf = fl.getPathToAttach(best_thumb, True)
            if pf is not None and pf.exists():
                return pf.getAbsolutePath()

            # Если обложка ещё не скачана, просим Telegram её подгрузить
            # и несколько раз быстро проверяем кэш. Это убирает ситуацию,
            # когда фон появляется только при повторном открытии окна.
            try:
                fl.loadFile(best_thumb, True, False)
            except Exception:
                pass
            for _ in range(8):
                try:
                    time.sleep(0.15)
                    pf = fl.getPathToAttach(best_thumb, True)
                    if pf is not None and pf.exists():
                        return pf.getAbsolutePath()
                except Exception:
                    break
        except Exception as e:
            self.plugin.log("extract album art failed: " + str(e))
        return None

    def _thumb_area(self, thumb: Any) -> int:
        try:
            return int(getattr(thumb, "w", 0)) * int(getattr(thumb, "h", 0))
        except Exception:
            return 0

    def _fetch_cover_online(self, title: str, artist: str) -> Optional[str]:
        # Запасной вариант из miniPlayer+: если Telegram/файл не отдал обложку,
        # пробуем взять artwork из iTunes Search API.
        query = f"{artist} {title}".strip()
        if not query:
            return None
        try:
            resp = requests.get(
                "https://itunes.apple.com/search",
                params={"term": query, "media": "music", "limit": 1},
                timeout=5.0
            )
            if resp.status_code != 200:
                return None
            data = resp.json()
            results = data.get("results") or []
            if not results:
                return None
            art = results[0].get("artworkUrl100")
            if not art:
                return None
            # Просим 600x600 вместо 1200 — достаточно для blur-фона, OOM не словим.
            art = art.replace("100x100bb", "600x600bb")
            img_resp = requests.get(art, timeout=7.0)
            if img_resp.status_code != 200:
                return None
            cache_dir = os.path.join(Plugin.dir_path(), "cover_cache")
            os.makedirs(cache_dir, exist_ok=True)
            suffix = hashlib.md5(query.encode("utf-8", "ignore")).hexdigest()[:16]
            path = os.path.join(cache_dir, f"cover_online_{suffix}.jpg")
            with open(path, "wb") as f:
                f.write(img_resp.content)
            return path
        except Exception as e:
            self.plugin.log("fetch online cover failed: " + str(e))
            return None

    def _round_rect(self, color: int, radius_dp: int) -> GradientDrawable:
        drawable = GradientDrawable()
        drawable.setColor(color)
        drawable.setCornerRadius(dp(self.context, radius_dp))
        return drawable


# =============================
# Plugin / кэш / hooks
# =============================


class Plugin(BasePlugin):
    instance = None

    def on_plugin_load(self) -> None:
        Plugin.instance = self
        self._cache_lock = threading.Lock()
        self._ensure_dir()
        plog("Plugin", "=== Lyrics+ v{} загружен (сессия {}) ===".format(__version__, _plog_session_id))
        try:
            self.hook_method(AudioPlayerAlert.getClass().getDeclaredConstructors()[0], AudioPlayerAlertHook())
            plog("Plugin", "hook AudioPlayerAlert constructor OK")
        except Exception as e:
            plog_exc("Plugin", "hook AudioPlayerAlert constructor FAILED", e)
        try:
            self.hook_method(AudioPlayerAlert.getClass().getDeclaredMethod("updateTitle", Boolean.TYPE), UpdateHook())
            plog("Plugin", "hook updateTitle OK")
        except Exception as e:
            plog_exc("Plugin", "hook updateTitle FAILED", e)
        try:
            self.hook_method(AudioPlayerAlert.getClass().getDeclaredMethod("onSubItemClick", Integer.TYPE), SubItemClickHook(self))
            plog("Plugin", "hook onSubItemClick OK")
        except Exception as e:
            plog_exc("Plugin", "hook onSubItemClick FAILED", e)
        self.log("LRCLIB Lyrics Editable loaded")

    @staticmethod
    def get_instance() -> "Plugin":
        return Plugin.instance

    @staticmethod
    def dir_path() -> str:
        directory = File(ApplicationLoader.applicationContext.getExternalCacheDir(), __id__)
        if not directory.exists():
            directory.mkdirs()
        return directory.getAbsolutePath()

    def _ensure_dir(self):
        try:
            os.makedirs(self.dir_path(), exist_ok=True)
        except Exception:
            pass

    def create_settings(self) -> List[Any]:
        if not SETTINGS_UI_AVAILABLE:
            return []
        return [
            Header(text="Внешний вид"),
            Input(
                key="blur_radius",
                text="Размытие обложки",
                default=str(DEFAULT_BLUR_RADIUS),
                subtext="0–32. Чем меньше число, тем чётче фон. По умолчанию: 4.",
                icon="msg_photo_settings",
            ),
            Input(
                key="dim_alpha",
                text="Затемнение фона",
                default=str(DEFAULT_DIM_ALPHA),
                subtext="0–230. Больше число = темнее фон и выше читаемость текста.",
                icon="msg_theme",
            ),
            Divider(),
            Header(text="Ambient Overlay"),
            Switch(
                key="ambient_enabled",
                text="Живое переливание фона",
                default=DEFAULT_AMBIENT_ENABLED,
                subtext="Мягкие полупрозрачные цветные пятна поверх обложки, но под текстом.",
                icon="msg_theme",
            ),
            Input(
                key="ambient_alpha",
                text="Прозрачность переливания",
                default=str(DEFAULT_AMBIENT_ALPHA),
                subtext="0–180. Больше число = эффект заметнее.",
                icon="msg_photo_settings",
            ),
            Input(
