                text="Скачать полный лог (в Downloads)",
                icon="msg_download",
                accent=True,
                on_click=self._on_export_plog_click,
            ),
            Text(
                text="Очистить полный лог",
                icon="msg_delete",
                on_click=self._on_clear_plog_click,
            ),
            Text(
                text="Очистить кэш найденных текстов",
                icon="msg_delete",
                on_click=self._on_clear_lyrics_cache_click,
            ),
            Text(
                text="Поддержать",
                on_click=self._on_support_click,
            ),
        ]

    def _on_export_search_log_click(self, view) -> None:
        try:
            file_name = export_search_log_to_downloads()
            BulletinHelper.show_success("Сохранено в Downloads: " + file_name)
        except Exception as e:
            self.log("export search log failed: " + str(e))
            BulletinHelper.show_error("Не удалось сохранить лог: " + str(e))

    def _on_clear_search_log_click(self, view) -> None:
        try:
            clear_search_log()
            BulletinHelper.show_success("Лог поиска очищен")
        except Exception as e:
            self.log("clear search log failed: " + str(e))
            BulletinHelper.show_error("Не удалось очистить лог: " + str(e))

    def _on_export_plog_click(self, view) -> None:
        try:
            file_name = export_plog_to_downloads()
            BulletinHelper.show_success("Сохранено в Downloads: " + file_name)
        except Exception as e:
            self.log("export plog failed: " + str(e))
            BulletinHelper.show_error("Не удалось сохранить полный лог: " + str(e))

    def _on_clear_plog_click(self, view) -> None:
        try:
            clear_plog()
            BulletinHelper.show_success("Полный лог очищен")
        except Exception as e:
            self.log("clear plog failed: " + str(e))
            BulletinHelper.show_error("Не удалось очистить полный лог: " + str(e))

    def _on_clear_lyrics_cache_click(self, view) -> None:
        """Полностью очищает кэш найденных текстов. Полезно после обновления
        логики поиска — без этого старые (возможно неверные) результаты
        продолжали бы отдаваться из кэша до истечения CACHE_TTL_DAYS."""
        try:
            path = self.cache_path()
            if os.path.exists(path):
                os.remove(path)
            BulletinHelper.show_success("Кэш текстов очищен")
        except Exception as e:
            self.log("clear lyrics cache failed: " + str(e))
            BulletinHelper.show_error("Не удалось очистить кэш: " + str(e))

    def _on_support_click(self, view) -> None:
        try:
            from android.content import Intent
            from android.net import Uri
            from org.telegram.messenger import ApplicationLoader
            intent = Intent(Intent.ACTION_VIEW, Uri.parse("tg://resolve?domain=fantikrsbot&start=lyricsplus_support"))
            intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)
            ApplicationLoader.applicationContext.startActivity(intent)
        except Exception as e:
            self.log("support link failed: " + str(e))

    def cache_path(self) -> str:
        return os.path.join(self.dir_path(), "lrclib_lyrics_cache.json")

    def cache_get(self, key: str) -> Optional[Dict[str, Any]]:
        if not key:
            return None
        lock = getattr(self, "_cache_lock", None)
        try:
            if lock:
                lock.acquire()
            path = self.cache_path()
            if not os.path.exists(path):
                return None
            with open(path, "r", encoding="utf-8") as f:
                data = json.load(f)
            item = data.get(key)
            if not item:
                return None
            saved_at = int(item.get("saved_at", 0))
            if time.time() - saved_at > CACHE_TTL_DAYS * 24 * 60 * 60:
                return None
            if not item.get("lines"):
                return None
            return item
        except Exception as e:
            self.log("cache_get failed: " + str(e))
            return None
        finally:
            try:
                if lock:
                    lock.release()
            except Exception:
                pass

    def cache_put(self, key: str, item: Dict[str, Any]) -> None:
        if not key:
            return
        lock = getattr(self, "_cache_lock", None)
        try:
            if lock:
                lock.acquire()
            path = self.cache_path()
            data: Dict[str, Any] = {}
            if os.path.exists(path):
                with open(path, "r", encoding="utf-8") as f:
                    data = json.load(f)
            data[key] = item

            # Лёгкая чистка старого кэша.
            now = time.time()
            ttl = CACHE_TTL_DAYS * 24 * 60 * 60
            data = {k: v for k, v in data.items() if now - int(v.get("saved_at", 0)) <= ttl}

            tmp_path = path + ".tmp"
            with open(tmp_path, "w", encoding="utf-8") as f:
                json.dump(data, f, ensure_ascii=False)
            os.replace(tmp_path, path)
        except Exception as e:
            self.log("cache_put failed: " + str(e))
        finally:
            try:
                if lock:
                    lock.release()
            except Exception:
                pass

    def cache_delete(self, key: str) -> None:
        """Удаляет одну запись кэша по ключу. Используется при повторном
        поиске текста — если кэш хранит старый неверный результат (например,
        найденный до улучшения логики сравнения LRCLIB/Genius), повторный
        поиск должен реально сходить в сеть заново, а не вернуть то же самое."""
        if not key:
            return
        lock = getattr(self, "_cache_lock", None)
        try:
            if lock:
                lock.acquire()
            path = self.cache_path()
            if not os.path.exists(path):
                return
            with open(path, "r", encoding="utf-8") as f:
                data = json.load(f)
            if key in data:
                del data[key]
                tmp_path = path + ".tmp"
                with open(tmp_path, "w", encoding="utf-8") as f:
                    json.dump(data, f, ensure_ascii=False)
                os.replace(tmp_path, path)
        except Exception as e:
            self.log("cache_delete failed: " + str(e))
        finally:
            try:
                if lock:
                    lock.release()
            except Exception:
                pass

    def present_viewer(self):
        # Закрываем предыдущий вьюер если он ещё открыт.
        # Без этого два LyricsViewer существуют одновременно, каждый со своим
        # набором фоновых потоков (sync_loop, mini_player_loop, ambient_loop,
        # cover workers), которые параллельно пишут в Android UI без синхронизации
        # → нативный краш (SIGSEGV/IllegalStateException), убивающий весь процесс.
        prev = getattr(self, '_active_viewer', None)
        if prev is not None:
            try:
                prev.close()
            except Exception:
                pass
            self._active_viewer = None

        track = get_current_track_info()
        plog("Viewer", "Открытие текста: '{}' - '{}' длительность={:.0f}с".format(
            safe_str(track.title), safe_str(track.artist), track.duration))
        try:
            viewer = LyricsViewer(self, track)
            self._active_viewer = viewer
            viewer.show()
            plog("Viewer", "LyricsViewer.show() вызван успешно")
        except Exception as e:
            self._active_viewer = None
            plog_crash("Viewer", "present_viewer упал", e)
            raise


# =============================
# Telegram / ExteraGram helpers
# =============================


def run_on_ui_thread_safe(callback):
    try:
        from android_utils import run_on_ui_thread
        run_on_ui_thread(callback)
    except Exception:
        try:
            callback()
        except Exception:
            pass


def get_playing_message_object() -> Optional[MessageObject]:
    try:
        return get_media_controller().getInstance().getPlayingMessageObject()
    except Exception:
        return None


def is_music() -> bool:
    msg = get_playing_message_object()
    if not msg:
        return False
    try:
        return bool(msg.isMusic())
    except Exception:
        return False


def java_field(obj: Any, name: str, default: Any = None) -> Any:
    if obj is None:
        return default
    try:
        return getattr(obj, name)
    except Exception:
        pass
    try:
        return get_private_field(obj, name)
    except Exception:
        return default


def call_any(obj: Any, names: List[str], default: Any = None, args_variants: Optional[List[Tuple[Any, ...]]] = None) -> Any:
    if obj is None:
        return default
    if args_variants is None:
        args_variants = [tuple(), (False,), (True,)]
    for name in names:
        try:
            method = getattr(obj, name)
        except Exception:
            continue
        for args in args_variants:
            try:
                value = method(*args)
                if value is not None:
                    return value
            except Exception:
                continue
    return default


def try_call_any(obj: Any, names: List[str], args_variants: List[Tuple[Any, ...]]) -> bool:
    """Вызывает Java-метод и считает успехом даже void-методы, если не было исключения."""
    if obj is None:
        return False
    for name in names:
        try:
            method = getattr(obj, name)
        except Exception:
            continue
        for args in args_variants:
            try:
                method(*args)
                return True
            except Exception:
                continue
    return False


def seek_current_track_to_sec(seconds: float, duration_hint: float = 0.0) -> bool:
    """Перемотка текущего трека. Основной путь Telegram: MediaController.seekToProgress(msg, progress_0_1)."""
    try:
        msg = get_playing_message_object()
        if not msg:
            return False

        duration = float_safe(duration_hint, 0.0)
        if duration <= 0:
            duration = get_current_duration_sec()
        if duration <= 0:
            return False

        seconds = max(0.0, min(float_safe(seconds, 0.0), duration))
        progress = max(0.0, min(1.0, seconds / duration))

        try:
            controller = get_media_controller().getInstance()
        except Exception:
            controller = None

        # Telegram обычно использует progress 0..1. Остальные варианты оставлены как страховка
        # для форков/других версий ExteraGram, где метод мог называться иначе.
        return try_call_any(controller, [
            "seekToProgress",
            "seekTo",
            "seekToTime",
            "setPlaybackPosition",
        ], [
            (msg, float(progress)),
            (msg, float(progress), False),
            (float(progress),),
            (int(seconds * 1000),),
            (float(seconds),),
        ])
    except Exception:
        return False


def get_current_track_info() -> TrackInfo:
    msg = get_playing_message_object()

    title = safe_str(call_any(msg, ["getMusicTitle", "getTitle", "getDocumentName"], ""))
    artist = safe_str(call_any(msg, ["getMusicAuthor", "getAuthorName", "getPerformer"], ""))
    duration = float_safe(call_any(msg, ["getDuration", "getAudioDuration"], 0, [tuple()]))

    if duration <= 0:
        duration = get_current_duration_sec()

    fallback = ""
    if not title:
        fallback = safe_str(call_any(msg, ["getDocumentName", "getFileName"], "", [tuple()]))
    if not title and fallback:
        title = cleanup_filename(fallback)

    return TrackInfo(title=title, artist=artist, duration=duration, query_fallback=fallback)


def cleanup_filename(name: str) -> str:
    name = safe_str(name)
    name = re.sub(r"\.(mp3|flac|wav|m4a|ogg|opus|aac)$", "", name, flags=re.I)
    name = name.replace("_", " ").replace("-", " ")
    return re.sub(r"\s+", " ", name).strip()


def get_current_progress_sec() -> float:
    msg = get_playing_message_object()
    value = java_field(msg, "audioProgressSec", None)
    if value is not None:
        return float_safe(value)

    value = java_field(msg, "audioProgress", None)
    duration = get_current_duration_sec()
    if value is not None and duration > 0:
        progress = float_safe(value)
        if 0 <= progress <= 1.2:
            return progress * duration
        return progress

    # Запасные варианты на случай другой версии Telegram/ExteraGram.
    controller = None
    try:
        controller = get_media_controller().getInstance()
    except Exception:
        controller = None
    value = call_any(controller, ["getProgress", "getPlayingProgress"], 0, [tuple()])
    return float_safe(value)


def get_current_duration_sec() -> float:
    msg = get_playing_message_object()
    duration = float_safe(call_any(msg, ["getDuration", "getAudioDuration"], 0, [tuple()]))
    if duration > 0:
        return duration
    duration = float_safe(java_field(msg, "duration", 0))
    return duration


class AudioPlayerAlertHook(MethodHook):
    """Добавляет пункт меню в плеер."""

    def after_hooked_method(self, param):
        try:
            options_button: ActionBarMenuItem = get_private_field(param.thisObject, "optionsButton")
            options_button.addSubItem(
                SHOW_LYRICS_ITEM_ID,
                TelegramUtils.get_icon_id("msg_photo_text2"),
                "Показать текст"
            )
            options_button.setSubItemShown(SHOW_LYRICS_ITEM_ID, is_music())
            plog("Hook", "AudioPlayerAlert меню добавлено, is_music={}".format(is_music()))
        except Exception as e:
            inst = Plugin.get_instance()
            if inst:
                inst.log("AudioPlayerAlertHook failed: " + str(e))
            plog_exc("Hook", "AudioPlayerAlertHook.after_hooked_method", e)


class UpdateHook(MethodHook):
    """Показывает кнопку только для музыки."""

    def after_hooked_method(self, param):
        try:
            options_button: ActionBarMenuItem = get_private_field(param.thisObject, "optionsButton")
            options_button.setSubItemShown(SHOW_LYRICS_ITEM_ID, is_music())
        except Exception as e:
            plog_exc("Hook", "UpdateHook.after_hooked_method", e)


class SubItemClickHook(MethodHook):
    """Открывает наш крутой Python-интерфейс текста."""

    def __init__(self, plugin: Plugin):
        self.plugin = plugin

    def before_hooked_method(self, param):
        if param.args[0] != SHOW_LYRICS_ITEM_ID:
            return
        param.setResult(None)
        plog("Hook", "SubItemClick: пользователь нажал 'Показать текст', is_music={}".format(is_music()))
        if not is_music():
            BulletinHelper.show_error("Это не музыкальный трек")
            plog("Hook", "SubItemClick: отклонено — не музыка")
            return
        try:
            self.plugin.present_viewer()
        except Exception as e:
            self.plugin.log("present_viewer failed: " + str(e))
            self.plugin.log(traceback.format_exc())
            plog_crash("Hook", "present_viewer упал в SubItemClickHook", e)
            BulletinHelper.show_error("Не удалось открыть текст")
