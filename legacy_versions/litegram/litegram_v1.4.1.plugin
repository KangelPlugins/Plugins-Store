            plugin.hook_all_methods(SettingsActivity, "fillItems", SettingsActivityFillItemsHook(plugin))
        except Exception:
            pass
        try:
            plugin.hook_all_methods(SettingsActivity, "onClick", SettingsActivityOnClickHook(plugin))
        except Exception:
            pass

