                mark_stats.setTypeface(AndroidUtilities.getTypeface("fonts/rmedium.ttf"))
                mark_stats.setTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText)))
            except Exception:
                pass
            try:
                cb_stats.addView(mark_stats, LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT))
            except Exception:
                cb_stats.addView(mark_stats)
            lp_cb_stats = LinearLayout.LayoutParams(AndroidUtilities.dp(24), AndroidUtilities.dp(24))
            lp_cb_stats.leftMargin = AndroidUtilities.dp(10)
            row_stats.addView(cb_stats, lp_cb_stats)

            root.addView(row_stats, LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT))
            popup = PopupWindow(root, LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT, True)
            try:
                popup.setOutsideTouchable(True)
                popup.setFocusable(True)
            except Exception:
                pass

            def _toggle(_v=None):
                try:
                    nv = not bool(self.get_setting("tlite_debug_logs", False))
                    self.set_setting("tlite_debug_logs", nv)
                    if nv:
                        try:
                            BulletinHelper.show_success(";)")
                        except Exception:
                            pass
                    try:
                        self.reload_settings()
                    except Exception:
                        pass
                    try:
                        run_on_ui_thread(self._refresh_settings_screen)
                    except Exception:
                        pass
                except Exception as e:
                    self._dlog(f"debug toggle fail: {e}")
                try:
                    popup.dismiss()
                except Exception:
                    pass

            class _Click(dynamic_proxy(View.OnClickListener)):
                def onClick(self_obj, v):
                    _toggle()
            row.setOnClickListener(_Click())

            def _toggle_stats(_v=None):
                try:
                    nv = not bool(self._stats_enabled())
                    self.set_setting("tlite_stats_enabled", nv)
                    try:
                        BulletinHelper.show_info(self._tr("bulletin_stats_enabled") if nv else self._tr("bulletin_stats_disabled"))
                    except Exception:
                        pass
                    if nv:
                        try:
                            self._telemetry_queue_event("session_start", feature="", count=1, force_flush=True)
                            if not bool(self.get_setting("tlite_stats_install_event_sent_v1", False)):
                                self._telemetry_queue_event("install", feature="", count=1, force_flush=True)
                                self.set_setting("tlite_stats_install_event_sent_v1", True)
                        except Exception:
                            pass
                except Exception as e:
                    self._dlog(f"stats toggle fail: {e}")
                try:
                    popup.dismiss()
                except Exception:
                    pass

            class _StatsClick(dynamic_proxy(View.OnClickListener)):
                def onClick(self_obj, v):
                    _toggle_stats()
            row_stats.setOnClickListener(_StatsClick())

            def _download_resources(_v=None):
                try:
                    popup.dismiss()
                except Exception:
                    pass
                try:
                    self._download_translations_async(ctx=ctx, close_dialog=None, bulletin_key="resources_header_bulletin")
                except Exception as e:
                    self._dlog(f"resources menu fail: {e}")

            class _ResourcesClick(dynamic_proxy(View.OnClickListener)):
                def onClick(self_obj, v):
                    _download_resources()
            row_resources.setOnClickListener(_ResourcesClick())

            try:
                popup.showAsDropDown(anchor_view, 0, AndroidUtilities.dp(8), Gravity.START)
            except Exception:
                try:
                    popup.showAsDropDown(anchor_view, 0, AndroidUtilities.dp(8))
                except Exception:
                    popup.showAsDropDown(anchor_view)
        except Exception as e:
            self._dlog(f"debug popup fail: {e}")

    def _refresh_settings_screen(self):
        try:
            activity = self.get_last_fragment()
            if not activity:
                return
            for name in ("rebuildAllItems", "updateRows", "updateVisibleRows", "notifyDataSetChanged"):
                try:
                    m = activity.getClass().getDeclaredMethod(name)
                    m.setAccessible(True)
                    m.invoke(activity)
                    self._dlog(f"settings refresh via {name}")
                    return
                except Exception:
                    pass
                try:
                    methods = activity.getClass().getDeclaredMethods()
                    for m in methods:
                        try:
                            if str(m.getName()) != name:
                                continue
                            ptypes = m.getParameterTypes()
                            if not ptypes or len(ptypes) != 1:
                                continue
                            m.setAccessible(True)
                            try:
                                m.invoke(activity, False)
                            except Exception:
                                m.invoke(activity, True)
                            self._dlog(f"settings refresh via {name}(bool)")
                            return
                        except Exception:
                            pass
                except Exception:
                    pass
            try:
                adapter = _get_private_field_silent(activity, "adapter")
                if adapter:
                    m = adapter.getClass().getMethod("notifyDataSetChanged")
                    m.invoke(adapter)
                    self._dlog("settings refresh via adapter.notifyDataSetChanged")
                    return
            except Exception:
                pass
        except Exception as e:
            self._dlog(f"settings refresh fail: {e}")

    def _setup_settings_header_hook(self):
        try:
            PSA = find_class("com.exteragram.messenger.plugins.ui.PluginSettingsActivity")
            if not PSA:
                return
            arr_cls = find_class("java.util.ArrayList")
            ua_cls = find_class("org.telegram.ui.Components.UniversalAdapter")
            if not arr_cls or not ua_cls:
                return
            m = PSA.getClass().getDeclaredMethod("fillItems", arr_cls, ua_cls)
            m.setAccessible(True)
            self._settings_header_hook = self.hook_method(m, TLLiteSettingsHeaderHook(self))
            self._dlog("settings header hook ok")
        except Exception as e:
            self._dlog(f"settings header hook fail: {e}")

    def _show_about_sheet(self, ctx_override=None):
        try:
            try:
                log("[TranslaticaLite] about sheet open requested")
            except Exception:
                pass
            ctx = ctx_override
            if ctx is None:
                frag = self.get_last_fragment()
                ctx = frag.getParentActivity() if frag and frag.getParentActivity() else None
            if ctx is None:
                ctx = ApplicationLoader.applicationContext
            if not ctx:
                try:
                    log("[TranslaticaLite] about sheet open aborted: no BottomSheet or context")
                except Exception:
                    pass
                return
            try:
                self._dismiss_keyboard_focus(ctx)
            except Exception:
                pass

            sheet = BottomSheet(ctx, True)
            outer = LinearLayout(ctx)
            outer.setOrientation(LinearLayout.VERTICAL)
            outer.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(8), AndroidUtilities.dp(12), AndroidUtilities.dp(12))

            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12))
            try:
                root_bg = GradientDrawable()
                root_bg.setCornerRadius(float(AndroidUtilities.dp(14)))
                root_bg.setColor(int(Theme.getColor(Theme.key_dialogBackground)))
                root.setBackground(root_bg)
            except Exception:
                pass

            row = LinearLayout(ctx)
            row.setOrientation(LinearLayout.HORIZONTAL)
            row.setGravity(Gravity.CENTER_VERTICAL)
            row.setPadding(AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8))
            try:
                row_bg = GradientDrawable()
                row_bg.setCornerRadius(float(AndroidUtilities.dp(14)))
                row_bg.setColor(int(Theme.getColor(Theme.key_dialogBackground)))
                row.setBackground(row_bg)
            except Exception:
                pass

            avatar = ImageView(ctx)
            try:
                avatar.setScaleType(ImageView.ScaleType.CENTER_CROP)
                av_bg = GradientDrawable()
                av_bg.setCornerRadius(float(AndroidUtilities.dp(14)))
                av_bg.setColor(0x00000000)
                avatar.setBackground(av_bg)
                avatar.setClipToOutline(True)
                avatar.setOutlineProvider(ViewOutlineProvider.BACKGROUND)
                if os.path.exists(ABOUT_AVATAR_CACHE_FILE):
                    bmp = BitmapFactory.decodeFile(ABOUT_AVATAR_CACHE_FILE)
                    if bmp:
                        avatar.setImageBitmap(bmp)
                avatar.setCameraDistance(float(AndroidUtilities.dp(800)))
                avatar.setAlpha(0.0)
                avatar.setTranslationY(float(AndroidUtilities.dp(26)))
                avatar.setRotationY(-120.0)
            except Exception:
                pass
            row.addView(avatar, LinearLayout.LayoutParams(AndroidUtilities.dp(72), AndroidUtilities.dp(72)))

            desc = TextView(ctx)
            desc.setText(self._tr("about_desc"))
            desc.setTextSize(15)
            try:
                desc.setTextColor(int(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText)))
            except Exception:
                pass
            lp_desc = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
            lp_desc.leftMargin = AndroidUtilities.dp(10)
            row.addView(desc, lp_desc)
            root.addView(row, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            btn = TextView(ctx)
            btn.setText(self._tr("about_button"))
            btn.setGravity(Gravity.CENTER)
            btn.setTextSize(16)
            try:
                btn.setTextColor(int(Theme.getColor(Theme.key_featuredStickers_buttonText)))
                btn_bg = GradientDrawable()
                btn_bg.setCornerRadius(float(AndroidUtilities.dp(12)))
                btn_bg.setColor(int(Theme.getColor(Theme.key_featuredStickers_addButton)))
                btn.setBackground(btn_bg)
                btn.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(10), AndroidUtilities.dp(12), AndroidUtilities.dp(10))
            except Exception:
                pass

            extended_btn = ImageView(ctx)
            try:
                extended_btn.setScaleType(ImageView.ScaleType.CENTER_INSIDE)
                is_dark = bool(Theme.isCurrentThemeDark())
                icon_path = EXTENDED_ICON_CACHE_FILE_DARK if is_dark else EXTENDED_ICON_CACHE_FILE_LIGHT
                if os.path.exists(icon_path):
                    bmp = BitmapFactory.decodeFile(icon_path)
                    if bmp:
                        extended_btn.setImageBitmap(bmp)
                extended_btn.setPadding(AndroidUtilities.dp(4), AndroidUtilities.dp(4), AndroidUtilities.dp(4), AndroidUtilities.dp(4))
            except Exception:
                pass

            class _AboutOpen(dynamic_proxy(View.OnClickListener)):
                def onClick(self_obj, v):
                    try:
                        log("[TranslaticaLite] about button click -> AGeekApple")
                    except Exception:
                        pass
                    try:
                        from client_utils import get_messages_controller, get_last_fragment
                        get_messages_controller().openByUserName("AGeekApple", get_last_fragment(), 1)
                    except Exception:
                        try:
                            self.open_url("https://t.me/AGeekApple")
                        except Exception:
                            pass
                    try:
                        sheet.dismiss()
                    except Exception:
                        pass

            btn.setOnClickListener(_AboutOpen())
            class _ExtendedOpen(dynamic_proxy(View.OnClickListener)):
                def onClick(self_obj, v):
                    try:
                        self.open_url("tg://resolve?domain=ApplesBio&post=4")
                    except Exception:
                        try:
                            from client_utils import get_messages_controller, get_last_fragment
                            get_messages_controller().openByUserName("ApplesBio", get_last_fragment(), 1)
                        except Exception:
                            try:
                                self.open_url("https://t.me/ApplesBio/4")
                            except Exception:
                                pass

            extended_btn.setOnClickListener(_ExtendedOpen())

            actions = LinearLayout(ctx)
            actions.setOrientation(LinearLayout.HORIZONTAL)
            actions.setGravity(Gravity.END | Gravity.CENTER_VERTICAL)
            lp_actions = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_actions.topMargin = AndroidUtilities.dp(10)

            lp_ext = LinearLayout.LayoutParams(AndroidUtilities.dp(36), AndroidUtilities.dp(36))
            lp_ext.rightMargin = AndroidUtilities.dp(8)
            actions.addView(extended_btn, lp_ext)

            lp_btn = LinearLayout.LayoutParams(AndroidUtilities.dp(120), LinearLayout.LayoutParams.WRAP_CONTENT)
            actions.addView(btn, lp_btn)
            root.addView(actions, lp_actions)
            try:
                max_w = int(AndroidUtilities.displaySize.x) - AndroidUtilities.dp(36)
            except Exception:
                max_w = LinearLayout.LayoutParams.MATCH_PARENT
            lp_root = LinearLayout.LayoutParams(max_w, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_root.gravity = Gravity.CENTER_HORIZONTAL
            outer.addView(root, lp_root)

            sheet.setCustomView(outer)
            try:
                run_on_ui_thread(sheet.show)
            except Exception:
                sheet.show()
            try:
                avatar.post(lambda: avatar.animate().translationY(0.0).alpha(1.0).rotationY(0.0).setDuration(620).start())
            except Exception:
                try:
                    avatar.animate().translationY(0.0).alpha(1.0).rotationY(0.0).setDuration(620).start()
                except Exception:
                    pass
            try:
                log("[TranslaticaLite] about sheet shown")
            except Exception:
                pass
        except Exception as e:
            try:
                log(f"[TranslaticaLite] about sheet fail: {e}")
            except Exception:
                pass

    def _open_plugin_settings(self):
        try:
            plugin = None
            fragment = None
            try:
                from client_utils import get_last_fragment
                fragment = get_last_fragment()
            except Exception:
                fragment = None
            try:
                controller = PluginsController.getInstance()
                plugin = controller.plugins.get(self.id) if controller else None
            except Exception:
                plugin = None
            if plugin is None or fragment is None:
                self._dlog("open settings skipped: plugin/fragment unavailable")
                return
            fragment.presentFragment(PluginSettingsActivity(plugin))
            self._dlog("open settings ok")
        except Exception as e:
            self._dlog(f"open settings fail: {e}")

    def _add_menu_items(self):
        try:
            self._chat_menu_item = self.add_menu_item(
                MenuItemData(
                    menu_type=MenuItemType.CHAT_ACTION_MENU,
                    text="Translatica Lite",
                    icon="msg_translate",
                    priority=5,
                    on_click=lambda _ctx: run_on_ui_thread(self._open_plugin_settings),
                )
            )
        except Exception as e:
            self._dlog(f"add menu item fail: {e}")

    def _on_about_click(self, _view=None):
        try:
            log("[TranslaticaLite] about item clicked")
        except Exception:
            pass
        ctx = None
        try:
            if _view is not None and hasattr(_view, "getContext"):
                ctx = _view.getContext()
        except Exception:
            ctx = None
        try:
            run_on_ui_thread(lambda: self._show_about_sheet(ctx))
        except Exception:
            self._show_about_sheet(ctx)

    def _global_target_lang(self):
        try:
            raw = self.get_setting("tlite_target_lang", 0)
            idx = int(raw)
            if 0 <= idx < len(LANG_CODES):
                return LANG_CODES[idx]
        except Exception:
            pass
        return "en"

    def _extract_dialog_id(self, params=None, fragment=None):
        try:
            if fragment is None:
                try:
                    from client_utils import get_last_fragment
                    fragment = get_last_fragment()
                except Exception:
                    fragment = None
            if fragment is not None and hasattr(fragment, "getDialogId"):
                try:
                    return int(fragment.getDialogId() or 0)
                except Exception:
                    pass
            if params is not None:
                for key in ("dialog_id", "dialogId", "peer", "peer_id"):
                    try:
                        v = getattr(params, key, None)
                        if v is not None:
                            iv = int(v)
                            if iv != 0:
                                return iv
                    except Exception:
                        pass
                try:
                    if isinstance(params, dict):
                        for key in ("dialog_id", "dialogId", "peer", "peer_id"):
                            v = params.get(key)
                            if v is not None:
                                iv = int(v)
                                if iv != 0:
                                    return iv
                except Exception:
                    pass
        except Exception:
            pass
        try:
            if int(getattr(self, "_chat_dialog_id_ref", 0) or 0) != 0:
                return int(self._chat_dialog_id_ref)
        except Exception:
            pass
        return 0

    def _chat_prefs(self):
        try:
            raw = self.get_setting("tlite_chat_prefs", {}) or {}
            if isinstance(raw, dict):
                return raw
        except Exception:
            pass
        return {}

    def _save_chat_prefs(self, prefs):
        try:
            self.set_setting("tlite_chat_prefs", prefs if isinstance(prefs, dict) else {})
        except Exception:
            pass

    def _chat_config(self, dialog_id):
        prefs = self._chat_prefs()
        key = str(int(dialog_id or 0))
        cfg = prefs.get(key) or {}
        if not isinstance(cfg, dict):
            cfg = {}
        enabled = bool(cfg.get("enabled", True))
        lang = str(cfg.get("lang", self._global_target_lang()) or self._global_target_lang())
        if lang not in LANG_CODES:
            lang = self._global_target_lang()
        return {"enabled": enabled, "lang": lang}

    def _set_chat_config(self, dialog_id, enabled=None, lang=None):
        try:
            did = int(dialog_id or 0)
            if did == 0:
                return
            prefs = self._chat_prefs()
            key = str(did)
            cfg = prefs.get(key) or {}
            if not isinstance(cfg, dict):
                cfg = {}
            if enabled is not None:
                cfg["enabled"] = bool(enabled)
            if lang is not None and str(lang or "") in LANG_CODES:
                cfg["lang"] = str(lang)
            prefs[key] = cfg
            self._save_chat_prefs(prefs)
        except Exception as e:
            self._dlog(f"set chat config fail: {e}")

    def _build_apple_icon(self, ctx):
        icon = ImageView(ctx)
        loaded_custom = False
        try:
            if os.path.exists(CHAT_ICON_CACHE_FILE):
                bmp = BitmapFactory.decodeFile(CHAT_ICON_CACHE_FILE)
                if bmp:
                    icon.setImageBitmap(bmp)
                    loaded_custom = True
        except Exception:
            pass
        if not loaded_custom:
            try:
                from client_utils import run_on_queue
                def _dl():
                    try:
                        self._load_chat_icon_remote()
                        if os.path.exists(CHAT_ICON_CACHE_FILE):
                            bmp2 = BitmapFactory.decodeFile(CHAT_ICON_CACHE_FILE)
                            if bmp2:
                                def _apply():
                                    try:
                                        icon.setImageBitmap(bmp2)
                                        self._refresh_apple_button()
                                    except Exception:
                                        pass
                                run_on_ui_thread(_apply)
                    except Exception as e:
                        self._dlog(f"chat icon async load fail: {e}")
                run_on_queue(_dl)
            except Exception:
                pass
            try:
                rid = ApplicationLoader.applicationContext.getResources().getIdentifier("msg_translate", "drawable", ApplicationLoader.applicationContext.getPackageName())
                if rid:
                    icon.setImageResource(rid)
            except Exception:
                pass
        try:
            icon.setScaleType(ImageView.ScaleType.CENTER_INSIDE)
        except Exception:
            pass
        return icon

    def _apply_apple_icon_state(self, fragment, icon_view):
        try:
            did = self._extract_dialog_id(fragment=fragment)
            cfg = self._chat_config(did)
            if cfg["enabled"]:
                try:
                    color = int(Theme.getColor(Theme.key_featuredStickers_addButton))
                except Exception:
                    color = 0xFF38A8FF
            else:
                try:
                    color = int(Theme.getColor(Theme.key_chat_messagePanelIcons))
                except Exception:
                    color = 0xFF8A8A8A
            icon_view.setColorFilter(color)
        except Exception:
            pass

    def _refresh_apple_button(self):
        try:
            if self._chat_apple_btn is None or self._chat_fragment_ref is None or self._chat_apple_icon is None:
                return
            self._apply_apple_icon_state(self._chat_fragment_ref, self._chat_apple_icon)
        except Exception:
            pass

    def _schedule_apple_attach_retry(self, fragment, reason="retry"):
        try:
            if fragment is None:
                return
            key = str(id(fragment))
            if key in self._attach_retry_keys:
                return
            self._attach_retry_keys.add(key)
            from client_utils import run_on_queue
            def _worker():
                try:
                    for _ in range(5):
                        time.sleep(0.22)
                        done = {"ok": False}
                        def _try():
                            try:
                                self._attach_apple_button(fragment, from_retry=True)
                                done["ok"] = self._chat_apple_btn is not None
                            except Exception:
                                pass
                        run_on_ui_thread(_try)
                        if done["ok"]:
                            break
                finally:
                    try:
                        self._attach_retry_keys.discard(key)
                    except Exception:
                        pass
            run_on_queue(_worker)
            self._dlog(f"attach retry scheduled: {reason}")
        except Exception as e:
            self._dlog(f"attach retry fail: {e}")

    def _schedule_apple_reorder(self, host, btn):
        try:
            if host is None or btn is None:
                return
            if not isinstance(host, LinearLayout):
                return
            def _once():
                try:
                    if btn.getParent() is not host:
                        return
                    lp = btn.getLayoutParams()
                    host.removeView(btn)
                    try:
                        host.addView(btn, lp)
                    except Exception:
                        host.addView(btn)
                    try:
                        btn.bringToFront()
                    except Exception:
                        pass
                except Exception:
                    pass
            run_on_ui_thread(_once)
            from client_utils import run_on_queue
            def _retry():
                for _ in range(4):
                    time.sleep(0.24)
                    run_on_ui_thread(_once)
            run_on_queue(_retry)
        except Exception as e:
            self._dlog(f"apple reorder fail: {e}")

    def _schedule_apple_stabilize(self, fragment):
        try:
            if fragment is None:
                return
            from client_utils import run_on_queue
            def _worker():
                for _ in range(5):
                    time.sleep(0.28)
                    run_on_ui_thread(lambda: self._attach_apple_button(fragment, from_retry=True))
            run_on_queue(_worker)
        except Exception as e:
            self._dlog(f"apple stabilize fail: {e}")

    def _show_language_dialog(self, fragment=None, dialog_id=0):
        try:
            ctx = fragment.getParentActivity() if fragment and fragment.getParentActivity() else ApplicationLoader.applicationContext
            if not ctx:
                return
            try:
                self._dismiss_keyboard_focus(ctx)
            except Exception:
                pass
            did = int(dialog_id or 0)
            if did == 0:
                did = self._extract_dialog_id(fragment=fragment)
            if did == 0:
                return
            cfg = self._chat_config(did)
            current = str(cfg.get("lang", self._global_target_lang()))
            builder = AlertDialogBuilder(ctx)
            builder.set_title(self._tr("sheet_title_chat_language"))
            root = LinearLayout(ctx)
            root.setOrientation(LinearLayout.VERTICAL)
            try:
                root.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(8), AndroidUtilities.dp(12), AndroidUtilities.dp(8))
            except Exception:
                pass

            for i, label in enumerate(LANG_LABELS):
                code = LANG_CODES[i]
                row = TextView(ctx)
                row.setText(f"{label}{'' if code != current else ' [x]'}")
                try:
                    row.setTextSize(16)
                    row.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
                    row.setPadding(AndroidUtilities.dp(8), AndroidUtilities.dp(10), AndroidUtilities.dp(8), AndroidUtilities.dp(10))
                except Exception:
                    pass

                class _Click(dynamic_proxy(View.OnClickListener)):
                    def __init__(self_obj, picked_code, picked_label):
                        super().__init__()
                        self_obj.picked_code = picked_code
                        self_obj.picked_label = picked_label
                    def onClick(self_obj, v):
                        try:
                            self._set_chat_config(did, enabled=True, lang=self_obj.picked_code)
                            self._refresh_apple_button()
                            try:
                                self._telemetry_queue_event("feature_use", feature=f"lang_select_{self_obj.picked_code}", count=1, force_flush=False)
                            except Exception:
                                pass
                            BulletinHelper.show_success(
                                (self._tr("bulletin_chat_lang_saved")).replace("%s", self_obj.picked_label.split(" (")[0])
                            )
                        except Exception:
                            pass
                        try:
                            if self._lang_dialog:
                                self._lang_dialog.dismiss()
                        except Exception:
                            pass

                row.setOnClickListener(_Click(code, label))
                root.addView(row)

            builder.set_view(root)
            builder.set_negative_button(self._tr("dialog_close"), lambda d, w: d.dismiss() if d else None)
            self._lang_dialog = builder.show()
        except Exception as e:
            self._dlog(f"language dialog fail: {e}")

    def _on_target_lang_changed(self, index):
        try:
            idx = int(index or 0)
        except Exception:
            idx = 0
        if idx < 0 or idx >= len(LANG_CODES):
            idx = 0
        try:
            self.set_setting("tlite_target_lang", idx)
        except Exception:
            pass
        try:
            self._telemetry_queue_event("feature_use", feature=f"lang_select_{LANG_CODES[idx]}", count=1, force_flush=False)
        except Exception:
            pass

    def _on_plugin_lang_selector_changed(self, index):
        try:
            idx = int(index or 0)
        except Exception:
            idx = 0
        if idx < 0 or idx >= len(PLUGIN_LANG_OPTIONS):
            idx = 0
        try:
            self.set_setting("tlite_plugin_lang", idx)
        except Exception:
            pass
        try:
            code = str(PLUGIN_LANG_OPTIONS[idx][1] or "system")
            self._telemetry_queue_event("feature_use", feature=f"ui_lang_{code}", count=1, force_flush=False)
        except Exception:
            pass

    def _dismiss_keyboard_focus(self, ctx):
        try:
            if ctx is None:
                return
            try:
                focused = ctx.getCurrentFocus()
            except Exception:
                focused = None
            try:
                if focused is not None:
                    focused.clearFocus()
            except Exception:
                pass
            imm = None
            try:
                imm = ctx.getSystemService("input_method")
            except Exception:
                imm = None
            if imm is None:
                return
            token = None
            try:
                w = ctx.getWindow()
                dv = w.getDecorView() if w is not None else None
                token = dv.getWindowToken() if dv is not None else None
            except Exception:
                token = None
            if token is None:
                try:
                    focused = ctx.getCurrentFocus()
                    token = focused.getWindowToken() if focused is not None else None
                except Exception:
                    token = None
            if token is not None:
                try:
                    imm.hideSoftInputFromWindow(token, 0)
                except Exception:
                    pass
        except Exception as e:
            self._dlog(f"dismiss keyboard fail: {e}")

    def _attach_apple_button(self, fragment, from_retry=False):
        try:
            if not fragment:
                return
            enter_view = None
            try:
                enter_view = _get_private_field_silent(fragment, "chatActivityEnterView")
            except Exception:
                pass
            if enter_view is None:
                if not from_retry:
                    self._schedule_apple_attach_retry(fragment, "no_enter_view")
                return

            host = None
            try:
                host = _get_private_field_silent(enter_view, "attachLayout")
            except Exception:
                pass
            if host is None:
                try:
                    host = _get_private_field_silent(enter_view, "sendButtonContainer")
                except Exception:
                    pass
            if host is None:
                try:
                    host = _get_private_field_silent(enter_view, "textFieldContainer")
                except Exception:
                    pass
            if host is None:
                try:
                    host = _get_private_field_silent(enter_view, "messageEditTextContainer")
                except Exception:
                    pass
            if host is None:
                try:
                    for fname in ("attachLayout", "sendButtonContainer", "textFieldContainer", "messageEditTextContainer", "messageContainer", "topView", "parentView"):
                        try:
                            cand = _get_private_field_silent(enter_view, fname)
                            if cand is not None and isinstance(cand, ViewGroup):
                                host = cand
                                break
                        except Exception:
                            pass
                except Exception:
                    pass
            if host is None:
                if not from_retry:
                    self._schedule_apple_attach_retry(fragment, "no_host")
                return
            try:
                self._dlog(f"apple host={host.__class__.__name__} retry={from_retry}")
            except Exception:
                pass

            existing = None
            try:
                existing = host.findViewWithTag("__tlite_apple_btn__")
            except Exception:
                pass

            if existing is not None:
                self._chat_apple_btn = existing
                try:
                    self._chat_apple_icon = existing.getChildAt(0)
                except Exception:
                    self._chat_apple_icon = None
                self._chat_fragment_ref = fragment
                try:
                    self._chat_dialog_id_ref = int(self._extract_dialog_id(fragment=fragment) or 0)
                except Exception:
                    self._chat_dialog_id_ref = 0
                self._refresh_apple_button()
                self._attach_compose_assist_button(fragment, host)
                return

            btn = FrameLayout(host.getContext())
            try:
                btn.setTag("__tlite_apple_btn__")
            except Exception:
                pass
            icon = self._build_apple_icon(host.getContext())
            try:
                btn.addView(icon, FrameLayout.LayoutParams(AndroidUtilities.dp(24), AndroidUtilities.dp(24), Gravity.CENTER))
            except Exception:
                btn.addView(icon)

            try:
                if isinstance(host, LinearLayout):
                    lp = LinearLayout.LayoutParams(AndroidUtilities.dp(28), AndroidUtilities.dp(28))
                    lp.gravity = Gravity.CENTER_VERTICAL
                    lp.leftMargin = AndroidUtilities.dp(2)
                    lp.rightMargin = AndroidUtilities.dp(2)
                    host.addView(btn, lp)
                else:
                    host.addView(btn)
            except Exception:
                host.addView(btn)

            class _Click(dynamic_proxy(View.OnClickListener)):
                def onClick(self_obj, v):
                    try:
                        did = self._extract_dialog_id(fragment=fragment)
                        cfg = self._chat_config(did)
                        new_state = not bool(cfg["enabled"])
                        self._set_chat_config(did, enabled=new_state)
                        self._refresh_apple_button()
                        if new_state:
                            BulletinHelper.show_success(self._tr("bulletin_chat_enabled_saved"))
                        else:
                            BulletinHelper.show_success(self._tr("bulletin_chat_disabled_saved"))
                    except Exception as e:
                        self._dlog(f"apple click fail: {e}")

            class _Long(dynamic_proxy(View.OnLongClickListener)):
                def onLongClick(self_obj, v):
                    try:
                        self._show_language_dialog(fragment)
                    except Exception:
                        pass
                    return True

            btn.setOnClickListener(_Click())
            btn.setOnLongClickListener(_Long())
            self._chat_apple_btn = btn
            self._chat_apple_icon = icon
            self._chat_fragment_ref = fragment
            try:
                self._chat_dialog_id_ref = int(self._extract_dialog_id(fragment=fragment) or 0)
            except Exception:
                self._chat_dialog_id_ref = 0
            self._refresh_apple_button()
            self._attach_compose_assist_button(fragment, host)
            self._schedule_apple_reorder(host, btn)
            self._dlog("apple button attached")
        except Exception as e:
            self._dlog(f"attach apple fail: {e}")

    def _detach_apple_button(self):
        try:
            if self._chat_apple_btn is not None and self._chat_apple_btn.getParent() is not None:
                self._chat_apple_btn.getParent().removeView(self._chat_apple_btn)
        except Exception:
            pass
        self._chat_apple_btn = None
        self._chat_apple_icon = None
        self._chat_fragment_ref = None
        self._chat_dialog_id_ref = 0

    def _detach_assist_button(self):
        try:
            self._stop_assist_position_tracker()
        except Exception:
            pass
        try:
            if self._chat_assist_btn is not None and self._chat_assist_btn.getParent() is not None:
                self._chat_assist_btn.getParent().removeView(self._chat_assist_btn)
        except Exception:
            pass
        try:
            if self._chat_assist_fab is not None and self._chat_assist_fab.getParent() is not None:
                self._chat_assist_fab.getParent().removeView(self._chat_assist_fab)
        except Exception:
            pass
        self._chat_assist_btn = None
        self._chat_assist_icon = None
        self._chat_assist_fab = None
        self._chat_assist_fab_icon = None

    def _start_assist_position_tracker(self, fragment):
        try:
            self._stop_assist_position_tracker()
            stop_evt = threading.Event()
            self._assist_pos_stop = stop_evt

            def _worker():
                while not stop_evt.is_set():
                    try:
                        run_on_ui_thread(lambda: self._refresh_assist_button(fragment))
                    except Exception:
                        pass
                    stop_evt.wait(0.28)

            th = threading.Thread(target=_worker, daemon=True)
            self._assist_pos_thread = th
            th.start()
        except Exception as e:
            self._dlog(f"start assist tracker fail: {e}")

    def _stop_assist_position_tracker(self):
        try:
            evt = getattr(self, "_assist_pos_stop", None)
            if evt is not None:
                evt.set()
        except Exception:
            pass
        self._assist_pos_stop = None
        self._assist_pos_thread = None

    def _count_compose_chars(self, text):
        try:
            return len(str(text or ""))
        except Exception:
            return 0

    def _should_show_assist_button(self, text):
        return False

    def _has_meaningful_word(self, text):
        try:
            t = str(text or "").strip()
            if not t:
                return False
            t = re.sub(r"(https?://\S+|www\.\S+)", " ", t, flags=re.IGNORECASE)
            return bool(re.search(r"[^\W\d_]+", t, flags=re.UNICODE))
        except Exception:
            return False

    def _assist_can_open_for_text(self, text):
        try:
            t = str(text or "").strip()
            if not t:
                return False
            if self._is_emoji_only(t):
                return False
            return self._has_meaningful_word(t)
        except Exception:
            return False

    def _is_assist_ai_configured(self):
        try:
            base = str(self.get_setting("tlite_ai_custom_url", "") or "").strip().rstrip("/")
            model = str(self.get_setting("tlite_ai_custom_model", "") or "").strip()
            return bool(base and model)
        except Exception:
            return False

    def _should_show_assist_fab(self, text):
        try:
            t = str(text or "").strip()
            if not t:
                return False
            return self._count_compose_chars(t) > 0
        except Exception:
            return False

    def _is_assist_allowed_for_chat(self, fragment=None):
        try:
            if not bool(self.get_setting("tlite_ai_assist_enabled", True)):
                return False
        except Exception:
            return False
        did = 0
        try:
            did = int(self._extract_dialog_id(fragment=fragment) or 0)
        except Exception:
            did = 0
        if did == 0:
            return True
        try:
            cfg = self._chat_config(did)
            return bool(cfg.get("enabled", True))
        except Exception:
            return True

    def _get_enter_view(self, fragment=None):
        try:
            target = fragment if fragment is not None else self._chat_fragment_ref
            if target is None:
                return None
            return _get_private_field_silent(target, "chatActivityEnterView")
        except Exception:
            return None

    def _get_compose_text(self, fragment=None):
        try:
            enter_view = self._get_enter_view(fragment)
            if enter_view is None:
                return ""
            try:
                edit = enter_view.getEditField()
                if edit is not None:
                    return str(edit.getText() or "")
            except Exception:
                pass
            try:
                return str(enter_view.getFieldText() or "")
            except Exception:
                return ""
        except Exception:
            return ""

    def _set_compose_text(self, fragment, text):
        try:
            enter_view = self._get_enter_view(fragment)
            if enter_view is None:
                return False
            value = str(text or "")
            try:
                enter_view.setFieldText(value)
            except Exception:
                try:
                    enter_view.setFieldText(value, False)
                except Exception:
                    try:
                        edit = enter_view.getEditField()
                        if edit is not None:
                            edit.setText(value)
                    except Exception:
                        return False
            try:
                edit = enter_view.getEditField()
                if edit is not None:
                    edit.setSelection(edit.getText().length())
            except Exception:
                pass
            self._refresh_assist_button(fragment)
            return True
        except Exception as e:
            self._dlog(f"set compose text fail: {e}")
            return False

    def _trigger_compose_send(self, fragment):
        try:
            enter_view = self._get_enter_view(fragment)
            if enter_view is None:
                return False
            for fname in ("sendButton", "audioVideoSendButton", "doneButton", "sendButtonContainer"):
                try:
                    view = _get_private_field_silent(enter_view, fname)
                    if view is not None and hasattr(view, "performClick"):
                        if bool(view.performClick()):
                            return True
                        try:
                            view.callOnClick()
                            return True
                        except Exception:
                            pass
                except Exception:
                    pass
            for mname in ("sendMessage", "processSendingText", "checkRoundVideo", "doneEditingMessage"):
                try:
                    meth = enter_view.getClass().getDeclaredMethod(mname)
                    meth.setAccessible(True)
                    meth.invoke(enter_view)
                    return True
                except Exception:
                    pass
            return False
        except Exception as e:
            self._dlog(f"trigger compose send fail: {e}")
            return False

    def _build_assist_icon(self, ctx):
        icon = ImageView(ctx)
        try:
            rid = ApplicationLoader.applicationContext.getResources().getIdentifier("ai_chat_remix", "drawable", ApplicationLoader.applicationContext.getPackageName())
            if rid:
                icon.setImageResource(rid)
            else:
                rid = ApplicationLoader.applicationContext.getResources().getIdentifier("msg_translate", "drawable", ApplicationLoader.applicationContext.getPackageName())
                if rid:
                    icon.setImageResource(rid)
        except Exception:
            pass
        try:
            icon.setScaleType(ImageView.ScaleType.CENTER_INSIDE)
        except Exception:
            pass
        return icon

    def _style_assist_chip(self, view, force_circle=False):
        try:
            if force_circle:
                bg = GradientDrawable(
                    GradientDrawable.Orientation.TL_BR,
                    [_ji(0xFF6C5CE7), _ji(0xFF3B82F6), _ji(0xFF00CEC9)]
                )
            else:
                bg = GradientDrawable()
            if force_circle:
                bg.setShape(GradientDrawable.OVAL)
            else:
                bg.setCornerRadius(float(AndroidUtilities.dp(20)))
                try:
                    bg.setColor(int(Theme.getColor(Theme.key_featuredStickers_addButton)))
                except Exception:
                    bg.setColor(_ji(0xFF2EA6FF))
            view.setBackground(bg)
        except Exception:
            pass

    def _ripple_bg(self, drawable, color=0x30FFFFFF):
        try:
            return RippleDrawable(ColorStateList.valueOf(_ji(color)), drawable, None)
        except Exception:
            return drawable

    def _refresh_assist_button(self, fragment=None):
        try:
            if fragment is None:
                fragment = self._chat_fragment_ref
            try:
                from client_utils import get_last_fragment
                current_fragment = get_last_fragment()
            except Exception:
                current_fragment = None
            if fragment is None or current_fragment is None or fragment != current_fragment:
                if self._chat_assist_btn is not None:
                    self._chat_assist_btn.setVisibility(View.GONE)
                if self._chat_assist_fab is not None:
                    self._chat_assist_fab.setVisibility(View.GONE)
                return
            btn = self._chat_assist_btn
            icon = self._chat_assist_icon
            source_text = self._get_compose_text(fragment)
            allowed = self._is_assist_allowed_for_chat(fragment)
            compose_visible = bool(allowed and self._should_show_assist_button(source_text))
            fab_visible = bool(allowed and self._should_show_assist_fab(source_text))
            assist_active = bool(allowed and self._assist_can_open_for_text(source_text))
            if btn is not None and icon is not None:
                btn.setVisibility(View.VISIBLE if compose_visible else View.GONE)
                try:
                    btn.setAlpha(1.0 if assist_active and compose_visible else (0.42 if compose_visible else 0.0))
                    btn.setEnabled(bool(assist_active and compose_visible))
                    btn.setClickable(bool(assist_active and compose_visible))
                except Exception:
                    pass
                if compose_visible:
                    self._position_compose_assist_button(fragment)
            fab = self._chat_assist_fab
            fab_icon = self._chat_assist_fab_icon
            if fab is not None and fab_icon is not None:
                fab.setVisibility(View.VISIBLE if fab_visible else View.GONE)
                try:
                    fab.setAlpha(1.0 if assist_active and fab_visible else (0.42 if fab_visible else 0.0))
                    fab.setEnabled(bool(assist_active and fab_visible))
                    fab.setClickable(bool(assist_active and fab_visible))
                except Exception:
                    pass
                if fab_visible:
                    self._position_assist_fab(fragment)
        except Exception as e:
            self._dlog(f"refresh assist fail: {e}")

    def _position_compose_assist_button(self, fragment):
        try:
            if fragment is None or self._chat_assist_btn is None:
                return
            enter_view = self._get_enter_view(fragment)
            if enter_view is None:
                return
            target = None
            try:
                target = _get_private_field_silent(enter_view, "textFieldContainer")
            except Exception:
                target = None
            root_host = None
            try:
                root_host = self._chat_assist_btn.getParent()
            except Exception:
                root_host = None
            if target is None or root_host is None:
                return
            loc_target = [0, 0]
            loc_root = [0, 0]
            try:
                target.getLocationOnScreen(loc_target)
                root_host.getLocationOnScreen(loc_root)
            except Exception:
                return
            try:
                target_w = int(target.getWidth() or 0)
                btn_w = int(self._chat_assist_btn.getWidth() or AndroidUtilities.dp(44))
            except Exception:
                target_w = 0
                btn_w = AndroidUtilities.dp(44)
            x = (int(loc_target[0]) - int(loc_root[0])) + target_w - btn_w - AndroidUtilities.dp(58)
            y = (int(loc_target[1]) - int(loc_root[1])) + AndroidUtilities.dp(6)
            try:
                self._chat_assist_btn.setX(float(x))
                self._chat_assist_btn.setY(float(y))
                self._chat_assist_btn.bringToFront()
            except Exception:
                pass
        except Exception as e:
            self._dlog(f"position compose assist fail: {e}")

    def _position_assist_fab(self, fragment):
        try:
            if fragment is None or self._chat_assist_fab is None:
                return
            enter_view = self._get_enter_view(fragment)
            if enter_view is None:
                return
            target = None
            send_host = None
            try:
                target = _get_private_field_silent(enter_view, "textFieldContainer")
            except Exception:
                target = None
            if target is None:
                try:
                    target = _get_private_field_silent(enter_view, "messageEditTextContainer")
                except Exception:
                    target = None
            try:
                send_host = _get_private_field_silent(enter_view, "sendButtonContainer")
            except Exception:
                send_host = None
            root_host = None
            try:
                root_host = self._chat_assist_fab.getParent()
            except Exception:
                root_host = None
            if target is None or root_host is None:
                return
            loc_target = [0, 0]
            loc_root = [0, 0]
            try:
                target.getLocationOnScreen(loc_target)
                root_host.getLocationOnScreen(loc_root)
            except Exception:
                return
            try:
                target_w = int(target.getWidth() or 0)
                fab_w = int(self._chat_assist_fab.getWidth() or AndroidUtilities.dp(46))
                fab_h = int(self._chat_assist_fab.getHeight() or AndroidUtilities.dp(46))
            except Exception:
                target_w = 0
                fab_w = AndroidUtilities.dp(46)
                fab_h = AndroidUtilities.dp(46)
            if send_host is not None:
                send_loc = [0, 0]
                try:
                    send_host.getLocationOnScreen(send_loc)
                    x = (int(send_loc[0]) - int(loc_root[0])) + int(send_host.getWidth() or 0) - fab_w - AndroidUtilities.dp(2)
                except Exception:
                    x = (int(loc_target[0]) - int(loc_root[0])) + target_w - fab_w - AndroidUtilities.dp(2)
            else:
                x = (int(loc_target[0]) - int(loc_root[0])) + target_w - fab_w - AndroidUtilities.dp(2)
            y = (int(loc_target[1]) - int(loc_root[1])) - fab_h - AndroidUtilities.dp(8)
            min_y = AndroidUtilities.dp(72)
            if y < min_y:
                y = min_y
            try:
                self._chat_assist_fab.setX(float(max(0, x)))
                self._chat_assist_fab.setY(float(max(0, y)))
                self._chat_assist_fab.bringToFront()
            except Exception:
                pass
        except Exception as e:
            self._dlog(f"position assist fab fail: {e}")

    def _ensure_assist_watcher(self, fragment, enter_view):
        try:
            if fragment is None or enter_view is None:
                return
            edit = None
            try:
                edit = enter_view.getEditField()
            except Exception:
                edit = None
            if edit is None:
                return
            frag_key = id(fragment)
            if frag_key in self._compose_watchers:
                return

            class _ComposeWatcher(dynamic_proxy(TextWatcher)):
                def beforeTextChanged(self_watcher, s, start, count, after):
                    pass

                def onTextChanged(self_watcher, s, start, before, count):
                    pass

                def afterTextChanged(self_watcher, editable):
                    try:
                        self._refresh_assist_button(fragment)
                    except Exception:
                        pass

            watcher = _ComposeWatcher()
            edit.addTextChangedListener(watcher)
            self._compose_watchers[frag_key] = watcher
        except Exception as e:
            self._dlog(f"ensure assist watcher fail: {e}")

    def _attach_compose_assist_button(self, fragment, host):
        try:
            if fragment is None:
                return
            enter_view = self._get_enter_view(fragment)
            if enter_view is None:
                return
            activity = None
            try:
                activity = fragment.getParentActivity()
            except Exception:
                activity = None
            overlay_host = None
            if activity is not None:
                try:
                    overlay_host = activity.findViewById(16908290)
                except Exception:
                    overlay_host = None
            if overlay_host is None:
                try:
                    overlay_host = fragment.getFragmentView()
                except Exception:
                    overlay_host = None
            if overlay_host is None:
                return
            existing = None
            try:
                existing = overlay_host.findViewWithTag("__tlite_assist_btn__")
            except Exception:
                pass
            if existing is not None:
                self._chat_assist_btn = existing
                try:
                    self._chat_assist_icon = existing.getChildAt(0)
                except Exception:
                    self._chat_assist_icon = None
                self._ensure_assist_watcher(fragment, enter_view)
                self._attach_assist_fab(fragment)
                self._refresh_assist_button(fragment)
                return

            btn = FrameLayout(overlay_host.getContext())
            try:
                btn.setTag("__tlite_assist_btn__")
            except Exception:
                pass
            try:
                btn.setClipChildren(False)
                btn.setClipToPadding(False)
            except Exception:
                pass
            try:
                btn.setClickable(True)
            except Exception:
                pass
            self._style_assist_chip(btn, force_circle=True)
            icon = self._build_assist_icon(overlay_host.getContext())
            try:
                icon.setColorFilter(int(Theme.getColor(Theme.key_featuredStickers_buttonText)))
            except Exception:
                pass
            try:
                btn.addView(icon, FrameLayout.LayoutParams(AndroidUtilities.dp(22), AndroidUtilities.dp(22), Gravity.CENTER))
            except Exception:
                btn.addView(icon)

            try:
                try:
                    overlay_host.setClipChildren(False)
                    overlay_host.setClipToPadding(False)
                except Exception:
                    pass
                lp = FrameLayout.LayoutParams(AndroidUtilities.dp(44), AndroidUtilities.dp(44))
                lp.gravity = Gravity.TOP | Gravity.LEFT
                overlay_host.addView(btn, lp)
            except Exception:
                overlay_host.addView(btn)

            class _AssistClick(dynamic_proxy(View.OnClickListener)):
                def onClick(self_obj, v):
                    try:
                        if not self._is_assist_ai_configured():
                            try:
                                BulletinHelper.show_error(self._tr("ai_sheet_missing_config"))
                            except Exception:
                                pass
                            return
                        if not self._assist_can_open_for_text(self._get_compose_text(fragment)):
                            try:
                                BulletinHelper.show_info(self._tr("ai_sheet_need_words"))
                            except Exception:
                                pass
                            return
                        self._show_compose_assist_sheet(fragment)
                    except Exception as e:
                        self._dlog(f"assist click fail: {e}")

            btn.setOnClickListener(_AssistClick())
            self._chat_assist_btn = btn
            self._chat_assist_icon = icon
            self._ensure_assist_watcher(fragment, enter_view)
            self._attach_assist_fab(fragment)
            self._refresh_assist_button(fragment)
            self._position_compose_assist_button(fragment)
        except Exception as e:
            self._dlog(f"attach assist fail: {e}")

    def _attach_assist_fab(self, fragment):
        try:
            if fragment is None:
                return
            activity = None
            try:
                activity = fragment.getParentActivity()
            except Exception:
                activity = None
            root_host = None
            if activity is not None:
                try:
                    root_host = activity.findViewById(16908290)
                except Exception:
                    root_host = None
            if root_host is None:
                try:
                    root_host = fragment.getFragmentView()
                except Exception:
                    root_host = None
            if root_host is None:
                try:
                    root_host = _get_private_field_silent(fragment, "fragmentView")
                except Exception:
                    root_host = None
            if root_host is None:
                return
            existing = None
            try:
                existing = root_host.findViewWithTag("__tlite_assist_fab__")
            except Exception:
                pass
            if existing is not None:
                self._chat_assist_fab = existing
                try:
                    self._chat_assist_fab_icon = existing.getChildAt(0)
                except Exception:
                    self._chat_assist_fab_icon = None
                self._refresh_assist_button(fragment)
                return

            if not isinstance(root_host, ViewGroup):
                return
            fab_ctx = activity if activity is not None else root_host.getContext()
            btn = FrameLayout(fab_ctx)
            try:
                btn.setTag("__tlite_assist_fab__")
            except Exception:
                pass
            try:
                btn.setClickable(True)
            except Exception:
                pass
            try:
                btn.setFocusable(True)
            except Exception:
                pass
            self._style_assist_chip(btn, force_circle=True)

            icon = self._build_assist_icon(root_host.getContext())
            try:
                icon.setColorFilter(int(Theme.getColor(Theme.key_featuredStickers_buttonText)))
            except Exception:
                pass
            try:
                btn.addView(icon, FrameLayout.LayoutParams(AndroidUtilities.dp(20), AndroidUtilities.dp(20), Gravity.CENTER))
            except Exception:
                btn.addView(icon)

            lp = FrameLayout.LayoutParams(AndroidUtilities.dp(46), AndroidUtilities.dp(46), Gravity.BOTTOM | Gravity.RIGHT)
            try:
                lp.setMargins(0, 0, AndroidUtilities.dp(16), AndroidUtilities.dp(96))
            except Exception:
                pass
            try:
                root_host.addView(btn, lp)
            except Exception:
                try:
                    root_host.addView(btn)
                except Exception:
                    return
            try:
                btn.bringToFront()
            except Exception:
                pass

            class _AssistFabClick(dynamic_proxy(View.OnClickListener)):
                def onClick(self_obj, v):
                    try:
                        if not self._is_assist_ai_configured():
                            try:
                                BulletinHelper.show_error(self._tr("ai_sheet_missing_config"))
                            except Exception:
                                pass
                            return
                        if not self._assist_can_open_for_text(self._get_compose_text(fragment)):
                            try:
                                BulletinHelper.show_info(self._tr("ai_sheet_need_words"))
                            except Exception:
                                pass
                            return
                        self._show_compose_assist_sheet(fragment)
                    except Exception as e:
                        self._dlog(f"assist fab click fail: {e}")

            btn.setOnClickListener(_AssistFabClick())
            self._chat_assist_fab = btn
            self._chat_assist_fab_icon = icon
            self._chat_fragment_ref = fragment
            self._refresh_assist_button(fragment)
            self._position_assist_fab(fragment)
            self._start_assist_position_tracker(fragment)
        except Exception as e:
            self._dlog(f"attach assist fab fail: {e}")

    def _request_ai_correction(self, original_text, current_text, mode_key=None, emojify=False):
        try:
            return self._request_ai_rewrite(original_text, current_text, "correction", mode_key, emojify)
        except Exception as e:
            self._dlog(f"ai correction fail: {e}")
            return None

    def _request_ai_mode(self, original_text, current_text, mode_key, emojify=False):
        try:
            return self._request_ai_rewrite(original_text, current_text, "mode", mode_key, emojify)
        except Exception as e:
            self._dlog(f"ai mode fail: {e}")
            return None

    def _request_ai_rewrite(self, original_text, current_text, action_kind, mode_key, emojify=False):
        try:
            base = str(self.get_setting("tlite_ai_custom_url", "") or "").strip().rstrip("/")
            model = str(self.get_setting("tlite_ai_custom_model", "") or "").strip()
            api_key = str(self.get_setting("tlite_ai_custom_key", "") or "").strip()
            if not base or not model:
                return None
            target_code = str(self._global_target_lang() or "en")
            target_name = target_code
            try:
                for label, code in LANG_OPTIONS:
                    if str(code) == target_code:
                        target_name = str(label)
                        break
            except Exception:
                pass
            mode_directives = {
                "formal": "Rewrite it in a formal, polished and professional tone. Keep it elegant and natural.",
                "short": "Rewrite it to be shorter, cleaner and more direct without losing the meaning.",
                "natural": "Rewrite it to sound natural, human and smooth, like a native speaker wrote it.",
                "clear": "Rewrite it to be clearer, more organized and easier to understand.",
                "bruto": "Rewrite it in a blunt, raw and straightforward tone. Keep it direct, strong and concise without sounding robotic.",
            }
            selected_mode = str(mode_key or "").strip().lower()
            if str(action_kind) == "mode":
                if selected_mode == "custom":
                    directive = str(self.get_setting("tlite_ai_mode_custom_prompt", "") or "").strip()
                    if not directive:
                        directive = "Rewrite the translated text using the user's custom style request."
                else:
                    directive = mode_directives.get(selected_mode, mode_directives["natural"])
                    directive += " Avoid stylistic hyphens and em dashes. Prefer natural punctuation."
                if bool(emojify):
                    directive += " Add a few fitting emojis in places that make sense. Keep it subtle and never overdo it."
                else:
                    directive += " Do not use decorative emojis. Remove unnecessary emojis if they appear."
                system_prompt = (
                    "You rewrite translated text. Keep the same target language already used in the current translation. "
                    "Respect the meaning of the original text. "
                    "Apply the requested style faithfully and obey the custom instruction exactly when provided. "
                    "Do not explain anything. Return only the rewritten text."
                )
                user_prompt = (
                    f"Target language: {target_name}\n\n"
                    f"Original text:\n{str(original_text or '').strip()}\n\n"
                    f"Current translated text:\n{str(current_text or '').strip()}\n\n"
                    f"Requested style:\n{directive}"
                )
            else:
                if selected_mode == "custom":
                    style_directive = str(self.get_setting("tlite_ai_mode_custom_prompt", "") or "").strip()
                else:
                    style_directive = mode_directives.get(selected_mode, "").strip()
                emoji_directive = (
                    "Keep a few fitting emojis where they make sense and stay subtle."
                    if bool(emojify)
                    else "Do not use decorative emojis. Remove unnecessary emojis if they appear."
                )
                system_prompt = (
                    "You improve translated text. Keep the same target language already used in the current translation. "
                    "Fix mistakes, improve coherence and make it natural while staying faithful to the original meaning. "
                    "Never use stylistic hyphens or em dashes as separators. Prefer natural punctuation. "
                    "Do not explain anything. Return only the improved text."
                )
                extra_style = f"\n\nActive style to preserve:\n{style_directive}" if style_directive else ""
                user_prompt = (
                    f"Target language: {target_name}\n\n"
                    f"Original text:\n{str(original_text or '').strip()}\n\n"
                    f"Current translated text:\n{str(current_text or '').strip()}\n\n"
                    "Fix mistakes and polish the current translated text without changing its meaning. "
                    "Avoid stylistic hyphens and em dashes. "
                    f"{emoji_directive}"
                    f"{extra_style}"
                )
            payload = {
                "model": model,
                "messages": [
                    {"role": "system", "content": system_prompt},
                    {"role": "user", "content": user_prompt},
                ],
                "temperature": 0.55,
                "max_tokens": max(256, min(1600, len(str(current_text or "")) * 3)),
            }
            raw = json.dumps(payload).encode("utf-8")
            headers = {
                "Content-Type": "application/json",
                "Accept": "application/json",
                "User-Agent": "TranslaticaLite/1.0",
            }
            if api_key:
                headers["Authorization"] = f"Bearer {api_key}"
            req = Request(f"{base}/chat/completions", data=raw, headers=headers, method="POST")
            with urlopen(req, timeout=45) as resp:
                response_raw = resp.read().decode("utf-8", errors="replace")
            data = json.loads(response_raw or "{}")
            choices = data.get("choices") or []
            if not choices:
                return None
            msg = (choices[0] or {}).get("message") or {}
            content = msg.get("content")
            if isinstance(content, list):
                chunks = []
                for item in content:
                    if isinstance(item, dict):
                        txt = item.get("text")
                        if txt:
                            chunks.append(str(txt))
                content = "\n".join(chunks)
            out = str(content or "").strip()
            return out or None
        except Exception as e:
            self._dlog(f"ai rewrite fail: {e}")
            return None

    def _show_compose_assist_sheet(self, fragment):
        try:
            if fragment is None:
                try:
                    from client_utils import get_last_fragment
                    fragment = get_last_fragment() or self._chat_fragment_ref
                except Exception:
                    fragment = self._chat_fragment_ref
            source_text = str(self._get_compose_text(fragment) or "").strip()
            if not self._is_assist_allowed_for_chat(fragment):
                return
            if not self._is_assist_ai_configured():
                BulletinHelper.show_error(self._tr("ai_sheet_missing_config"))
                return
            if not (self._should_show_assist_button(source_text) or self._should_show_assist_fab(source_text)):
                BulletinHelper.show_error(self._tr("ai_sheet_need_words"))
                return
            if not self._assist_can_open_for_text(source_text):
                BulletinHelper.show_info(self._tr("ai_sheet_need_words"))
                return
            ctx = None
            try:
                ctx = fragment.getParentActivity() if fragment is not None else None
            except Exception:
                ctx = None
            if ctx is None:
                ctx = ApplicationLoader.applicationContext
            if ctx is None:
                return
            try:
                if hasattr(ctx, "isFinishing") and bool(ctx.isFinishing()):
                    self._dlog("show assist sheet skipped: activity finishing")
                    return
                if hasattr(ctx, "isDestroyed") and bool(ctx.isDestroyed()):
                    self._dlog("show assist sheet skipped: activity destroyed")
                    return
            except Exception:
                pass
            try:
                wnd = ctx.getWindow() if hasattr(ctx, "getWindow") else None
                decor = wnd.getDecorView() if wnd is not None else None
                token = decor.getWindowToken() if decor is not None else None
                if token is None:
                    self._dlog("show assist sheet skipped: null window token")
                    return
            except Exception:
                pass

            sheet = BottomSheet(ctx, False)
            self._ai_sheet = sheet
            is_dark = bool(Theme.isCurrentThemeDark())
            bg_color = _ji(Theme.getColor(Theme.key_dialogBackground))
            card_color = _ji(0xFFF7F8FC) if not is_dark else _ji(Theme.getColor(Theme.key_windowBackgroundWhite))
            primary_text = _ji(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
            secondary_text = _ji(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText2))
            accent = _ji(Theme.getColor(Theme.key_featuredStickers_addButton))
            accent_text = _ji(Theme.getColor(Theme.key_featuredStickers_buttonText))
            chip_idle = _ji(Theme.getColor(Theme.key_actionBarDefaultSubmenuBackground)) if is_dark else _ji(0xFFEDEFF5)
            card_stroke_color = _ji(0x18000000) if is_dark else _ji(0x220F172A)
            toggle_stroke_color = _ji(0x24000000) if is_dark else _ji(0x281E293B)

            outer = LinearLayout(ctx)
            outer.setOrientation(LinearLayout.VERTICAL)
            try:
                outer.setBackgroundColor(bg_color)
            except Exception:
                pass

            scroll = ScrollView(ctx)
            try:
                scroll.setFillViewport(True)
            except Exception:
                pass
            content = LinearLayout(ctx)
            content.setOrientation(LinearLayout.VERTICAL)
            content.setPadding(AndroidUtilities.dp(18), AndroidUtilities.dp(18), AndroidUtilities.dp(18), AndroidUtilities.dp(18))
            scroll.addView(content, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            header = LinearLayout(ctx)
            header.setOrientation(LinearLayout.HORIZONTAL)
            header.setGravity(Gravity.CENTER_VERTICAL)

            title = TextView(ctx)
            title.setText(self._tr("ai_sheet_title"))
            title.setTextColor(primary_text)
            title.setTextSize(1, 18)
            try:
                title.setTypeface(title.getTypeface(), 1)
            except Exception:
                pass
            header.addView(title, LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0))

            close_btn = TextView(ctx)
            close_btn.setText("×")
            close_btn.setTextSize(1, 22)
            close_btn.setTextColor(primary_text)
            close_btn.setGravity(Gravity.CENTER)
            close_btn.setPadding(AndroidUtilities.dp(8), AndroidUtilities.dp(2), AndroidUtilities.dp(8), AndroidUtilities.dp(2))
            class _CloseClick(dynamic_proxy(View.OnClickListener)):
                def onClick(self_obj, v):
                    try:
                        sheet.dismiss()
                    except Exception:
                        pass
            close_btn.setOnClickListener(_CloseClick())
            header.addView(close_btn, LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT))
            content.addView(header, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            toggle_card = LinearLayout(ctx)
            toggle_card.setOrientation(LinearLayout.HORIZONTAL)
            toggle_card.setGravity(Gravity.CENTER_VERTICAL)
            toggle_card.setPadding(AndroidUtilities.dp(10), AndroidUtilities.dp(10), AndroidUtilities.dp(10), AndroidUtilities.dp(10))
            toggle_bg = GradientDrawable()
            toggle_bg.setColor(chip_idle)
            toggle_bg.setCornerRadius(float(AndroidUtilities.dp(18)))
            try:
                toggle_bg.setStroke(AndroidUtilities.dp(1), toggle_stroke_color)
            except Exception:
                pass
            toggle_card.setBackground(toggle_bg)
            lp_toggle = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp_toggle.topMargin = AndroidUtilities.dp(14)
            content.addView(toggle_card, lp_toggle)

            def _make_top_action(text_value, icon_name, weight=1.0, icon_only=False):
                wrap = LinearLayout(ctx)
                wrap.setOrientation(LinearLayout.VERTICAL)
                wrap.setGravity(Gravity.CENTER)
                wrap.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(10), AndroidUtilities.dp(12), AndroidUtilities.dp(10))
                bg = GradientDrawable()
                bg.setCornerRadius(float(AndroidUtilities.dp(16)))
                bg.setColor(card_color)
                try:
                    bg.setStroke(AndroidUtilities.dp(1), card_stroke_color)
                except Exception:
                    pass
                wrap.setBackground(self._ripple_bg(bg))
                icon_view = ImageView(ctx)
                try:
                    rid = ApplicationLoader.applicationContext.getResources().getIdentifier(icon_name, "drawable", ApplicationLoader.applicationContext.getPackageName())
                    if rid:
                        icon_view.setImageResource(rid)
                        icon_view.setColorFilter(primary_text)
                except Exception:
                    pass
                wrap.addView(icon_view, LinearLayout.LayoutParams(AndroidUtilities.dp(22), AndroidUtilities.dp(22)))
                label = None
                if not icon_only:
                    label = TextView(ctx)
                    label.setText(text_value)
                    label.setTextColor(primary_text)
                    label.setTextSize(1, 13)
                    try:
                        label.setTypeface(label.getTypeface(), 1)
                    except Exception:
                        pass
                    label.setPadding(0, AndroidUtilities.dp(6), 0, 0)
                    wrap.addView(label, LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT))
                return wrap, bg, icon_view, label, LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, weight)

