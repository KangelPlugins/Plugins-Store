            root.addView(row, LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT))

            row_resources = LinearLayoutCls(ctx)
            row_resources.setOrientation(LinearLayout.HORIZONTAL)
            row_resources.setGravity(Gravity.CENTER_VERTICAL)
            try:
                row_resources.setPadding(AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8))
            except Exception:
                pass

            tv_resources = TextViewCls(ctx)
            tv_resources.setText(self._tr("resources_menu"))
            try:
