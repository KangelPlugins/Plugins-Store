        except Exception:
            pass
        try:
            _omap, _on, _ost = _build_hook_owner_map()
            _owners = sorted(set(v for v in _omap.values() if v))
            _log(f"Block#4A карта хуков: методов={_on} статус={_ost} владельцы={_owners}")
            _log(f"Block#4A фреймворки хуков: {_probe_hook_frameworks()}")
            _ldrs = _plugin_loaders()
            _log(f"Block#4B classloader-карта(boot): загрузчиков={len(_ldrs)} уникальных={len(set(r for _,r,_ in _ldrs))}")
        except Exception as _e:
