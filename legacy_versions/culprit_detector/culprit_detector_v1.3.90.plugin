def _scope_decl(lib):
    c = ctypes
    if not all(hasattr(lib, n) for n in ("cd_scope_enter", "cd_scope_leave", "cd_scope_current")):
        return False
    lib.cd_scope_enter.argtypes = [c.c_int32]; lib.cd_scope_enter.restype = c.c_int
    lib.cd_scope_leave.argtypes = []; lib.cd_scope_leave.restype = c.c_int
    lib.cd_scope_current.argtypes = []; lib.cd_scope_current.restype = c.c_int32
    global _ARM_OK
    try:
        if all(hasattr(lib, n) for n in ("cd_scope_arm", "cd_scope_arm_clear")):
            lib.cd_scope_arm.argtypes = [c.c_int32]; lib.cd_scope_arm.restype = c.c_int
            lib.cd_scope_arm_clear.argtypes = []; lib.cd_scope_arm_clear.restype = c.c_int
            try:
                lib.cd_scope_arm_window_ns.argtypes = [c.c_int64]; lib.cd_scope_arm_window_ns.restype = c.c_int64
            except Exception: pass
            _ARM_OK = True
    except Exception:
        _ARM_OK = False
    global _PIDCOUNT_OK
    try:
        if hasattr(lib, "cd_reg_set_pid_count"):
            lib.cd_reg_set_pid_count.argtypes = [c.c_int32]; lib.cd_reg_set_pid_count.restype = c.c_int
            _PIDCOUNT_OK = True
            try: lib.cd_reg_set_pid_count(c.c_int32(len(_IDX_PID)))
            except Exception: pass
    except Exception:
        _PIDCOUNT_OK = False
    try:
        lib.cd_scope_depth.argtypes = []; lib.cd_scope_depth.restype = c.c_int32
    except Exception: pass
    try:
        lib.cd_thread_inherited.argtypes = []; lib.cd_thread_inherited.restype = c.c_int64
    except Exception: pass
    return True

def _b4c_init(lib):
    global _B4C_OK
    try:
        _b4c_decl(lib)
    except Exception as e:
        _B4C_OK = False
        _log(f"Block#4C: символы не найдены в .so (старый бинарь?) — #4C отключён: {e}")
        return
    try:
        rc = int(lib.cd_lt_init(int(_LT_SLOTS)))
        ncp = _native_crash_path()
        ncw = None
        try:
            ncw = _aw_mirror_path(ncp) if ncp else None
        except Exception:
            ncw = None
        ncp_install = ncw or ncp
        inst = -1
        if ncp_install:
            inst = int(lib.cd_install_crash_handler(ncp_install.encode("utf-8")))
            if hasattr(lib, "cd_maps_refresh"):
                try:
                    _mc = int(lib.cd_maps_refresh())
                    _log(f"Block#4C +CO maps snapshot: {_mc} modules")
                except Exception as _emr:
                    _log(f"Block#4C +CO cd_maps_refresh err: {_emr}")
        hld = None
        if hasattr(lib, "cd_set_host_lib_dir"):
            try:
                hld = _host_lib_dir()
                lib.cd_set_host_lib_dir((hld or "").encode("utf-8"))
            except Exception as _ehl:
                _log(f"Block#4C: cd_set_host_lib_dir err: {_ehl}"); hld = None
        if rc != 0:
            _B4C_OK = False
            _log(f"Block#4C: cd_lt_init FAIL rc={rc} — #4C отключён (native-crash attribution OFF)")
            return
        if ncp and inst != 0:
            _B4C_OK = False
            _log(f"Block#4C: cd_install_crash_handler FAIL rc={inst} — #4C отключён")
            return
        _B4C_OK = True
        _log(f"Block#4C: lt_init rc={rc} slots={_LT_SLOTS}, crash_handler={'OK' if inst==0 else 'rc=%d' % inst} -> {ncp_install}")
        _log(f"Block#4C +CJ host-native: lib_dir={hld!r} -> {'ON' if hld else 'OFF (старый .so или нет контекста)'}")
        global _SCOPE_OK
        try:
            if _scope_decl(lib):
                lib.cd_scope_enter(-1); lib.cd_scope_leave()
                _SCOPE_OK = True
                _log("Block#10/C scope: cd_scope_enter/leave доступны — _scoped_set/clear через ОДИН нативный вызов")
                try:
                    if hasattr(lib, "cd_thread_inherited"):
                        _log("Block#10/C: cd_thread_inherited=%d (порождённые потоки унаследовали тег)" % int(lib.cd_thread_inherited()))
                except Exception: pass
            else:
                _SCOPE_OK = False
                _log("Block#10/C scope: cd_scope_* нет в .so (старый бинарь) — _scoped_set/clear через legacy (2 вызова)")
        except Exception as _esc:
            _SCOPE_OK = False
            _log("Block#10/C scope: декл/round-trip err: %s" % _esc)
    except Exception as e:
        _B4C_OK = False
        _log(f"Block#4C init err: {e}")

def _load_native():
    global _NLIB, _NATIVE_OK
    if not _CTYPES_OK or _REG_BUF is None:
        _log("Block#3: ctypes/shared-реестр недоступен — натив отключён (tid=Java id)")
        return
    if not _SO_ARM64:
        _log("Block#3: .so не вшит (_SO_ARM64 пуст) — запусти embed_so.py; натив отключён")
        return
    try:
        path = _b3_extract_so()
        if not path:
            return
        try:
            jclass("java.lang.System").load(path)
            _log("Block#3 System.load OK (namespace-load удался)")
        except Exception as e:
            _es = str(e)
            if ("getClassLoader" in _es) or ("null object reference" in _es):
                _log("Block#3 System.load: рефлексивный вызов без Java-caller — ожидаемо, .so грузится через ctypes.CDLL (не ошибка)")
            else:
                _log(f"Block#3 System.load warn: {_es}")
        lib = ctypes.CDLL(path)
        _b3_decl(lib)
        try:
            _abi = int(lib.cd_abi_version()) if hasattr(lib, "cd_abi_version") else None
        except Exception:
            _abi = None
        if _abi != _SO_ABI_EXPECT:
            globals()["_ABI_FAIL"] = True
            _log("Block#3 ABI MISMATCH .so=%s expected %d -- native disabled, plugin inert (+DT)" % (str(_abi), _SO_ABI_EXPECT))
            _NLIB = None; _NATIVE_OK = False
            return
        info = registry_info()
        rc = int(lib.cd_init(ctypes.c_uint64(info["addr"]), int(info["slots"]), int(info["slot_bytes"])))
        if rc != 0:
            _log(f"Block#3 cd_init FAIL rc={rc} — натив отключён")
            return
        hooks = int(lib.cd_start())
        if hooks < 0:
            _log(f"Block#3 cd_start FAIL rc={hooks} — натив отключён")
            try: lib.cd_stop()
            except Exception: pass
            _NLIB = None; _NATIVE_OK = False
            return
        _NLIB = lib; _NATIVE_OK = True
        try:
            if _NA_NATIVE_OK and _NA_SAMPLE_ENABLE and hasattr(lib, "cd_na_enable"):
                lib.cd_na_enable(1, int(_NA_MIN_BYTES))
                _log("Block#3S native alloc-site capture: ON min=%d" % int(_NA_MIN_BYTES))
        except Exception as _ena:
            _log("Block#3S cd_na_enable err: %s" % _ena)
        _b4c_init(lib)
        try:
            _b19_init(lib)
        except Exception as _e19:
            _log(f"Block#19 init err: {_e19}")
        try:
            _b26_init(lib)
        except Exception as _e26:
            _log(f"Block#26 init err: {_e26}")
        try:
            _b30_init(lib)
        except Exception as _e30kg:
            _log(f"Block#30 init err: {_e30kg}")
        try:
            _b31_init(lib)
        except Exception as _e31fg:
            _log(f"Block#31 init err: {_e31fg}")
        _log(f"Block#3 натив загружен: {path}")
        _log(f"Block#3 cd_init OK (reg=0x{info['addr']:x} slots={info['slots']} slot={info['slot_bytes']}B), хуков malloc={hooks}")
        if hooks <= 0:
            _log("Block#3 ⚠ ноль хуков — sh не перехватил libc (проверь sh)")
    except Exception as e:
        _NLIB = None; _NATIVE_OK = False
        _log(f"Block#3 load err: {e}")

def _so_features_str():
    g = globals()
    flags = [("OOM", "_OOM_NATIVE_OK"), ("ANR", "_ANR_NATIVE_OK"),
             ("GREF", "_GREF_NATIVE_OK"), ("OP", "_OP_NATIVE_OK"),
             ("SCOPE", "_SCOPE_OK")]
    try:
        return "  ".join("%s:%s" % (lbl, "on" if g.get(v) else "off") for lbl, v in flags)
    except Exception:
        return ""

def _so_health():
    """Health of native libculprit.so for the 'Show culprits' header.
    state: 'ok' | 'not_loaded' | 'stale' | 'abi_mismatch'."""
    exp = _SO_ABI_EXPECT
    if not _NATIVE_OK or _NLIB is None:
        return {"ok": False, "state": "not_loaded", "abi": None, "expect": exp}
    abi = None
    try:
        if hasattr(_NLIB, "cd_abi_version"):
            abi = int(_NLIB.cd_abi_version())
    except Exception:
        abi = None
    if abi is None:
        return {"ok": False, "state": "stale", "abi": None, "expect": exp}
    if abi != exp:
        return {"ok": False, "state": "abi_mismatch", "abi": abi, "expect": exp}
    return {"ok": True, "state": "ok", "abi": abi, "expect": exp}

def native_mem_snapshot(top=5):
    d = _direct_snapshot()
    if not _NATIVE_OK or _NLIB is None:
        if not d["live_by_pid"] and d["total"] == 0:
            return None
        _pairs_src = dict(d["live_by_pid"])
        if int(d["live_untagged"]) > 0: _pairs_src["⟨untagged⟩"] = int(d["live_untagged"])
        pairs = sorted(_pairs_src.items(), key=lambda kv: kv[1], reverse=True)
        return {
            "total": 0, "untagged": 0, "dropped": 0, "dropped_bytes": -1, "live": 0,
            "direct_total": d["total"], "direct_untagged": d["untagged"],
            "direct_live_total": d["live_total"], "direct_live_untagged": d["live_untagged"],
            "top": pairs[:top],
        }
    try:
        n = len(_IDX_PID)
        arr = (ctypes.c_int64 * max(n, 1))()
        _NLIB.cd_snapshot(arr, n)
        combined = {}
        for i in range(n):
            pid = _resolve_idx(i) or f"idx{i}"
            combined[pid] = combined.get(pid, 0) + int(arr[i])
        for pid, b in d["live_by_pid"].items():
            combined[pid] = combined.get(pid, 0) + int(b)
        _unt = int(d["live_untagged"]) + int(_NLIB.cd_untagged())
        if _unt > 0: combined["⟨untagged⟩"] = combined.get("⟨untagged⟩", 0) + _unt
        pairs = sorted(combined.items(), key=lambda kv: kv[1], reverse=True)
        return {
            "total": int(_NLIB.cd_total()), "untagged": int(_NLIB.cd_untagged()),
            "dropped": int(_NLIB.cd_dropped()), "dropped_bytes": (int(_NLIB.cd_dropped_bytes()) if hasattr(_NLIB,'cd_dropped_bytes') else -1), "live": int(_NLIB.cd_live_count()),
            "direct_total": d["total"], "direct_untagged": d["untagged"],
            "direct_live_total": d["live_total"], "direct_live_untagged": d["live_untagged"],
            "top": pairs[:top],
        }
    except Exception:
        return None

class _CrumbFile:
    NAME = "last_breadcrumb.txt"
    def __init__(self):
        self.path = None; self._lock = threading.Lock()
        try:
            d = File(_DIR)
            if not d.exists(): d.mkdirs()
            self.path = File(d, self.NAME).getAbsolutePath()
        except Exception as e:
            _log(f"crumb init err: {e}")
    def read_prev(self):
        try:
            if self.path and os.path.exists(self.path):
                with open(self.path, "r", encoding="utf-8") as f:
                    return f.read().strip()
        except Exception: pass
        return None
    def write(self, pid, where):
        if not self.path: return
        with self._lock:
            try:
                with open(self.path, "w", encoding="utf-8") as f:
                    f.write(f"{pid}\t{where}\t{int(time.time()*1000)}"); f.flush()
            except Exception: pass
_CRUMB = None

def _known_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _KNOWN_FILE).getAbsolutePath()
    except Exception:
        return None
def _load_known():
    p = _known_path()
    try:
        if p and os.path.exists(p):
            with open(p, "r", encoding="utf-8") as f:
                return list(json.load(f))
    except Exception:
        pass
    return []
def _save_known(pid):
    try:
        cur = set(_load_known())
        if pid in cur: return
        cur.add(pid)
        p = _known_path()
        if not p: return
        _atomic_json_write(p, sorted(cur))
    except Exception:
        pass

def _known_union():
    out = set()
    try:
        out.update(_load_known() or [])
    except Exception:
        pass
    try:
        out.update([n for n in _IDX_PID if isinstance(n, str) and n])
    except Exception:
        pass
    try:
        p = _idxnames_path()
        if p and os.path.exists(p):
            with open(p, "r", encoding="utf-8") as f:
                m = json.load(f)
            if isinstance(m, dict):
                out.update([v for v in m.values() if isinstance(v, str) and v])
    except Exception:
        pass
    return list(out)

def _simple(class_str):
    s = class_str.replace("class ", "").strip()
    for sep in ("$", "."):
        if sep in s: s = s.split(sep)[-1]
    return s
def _tokens(s):
    return set(t for t in re.split(r"[^a-z0-9]+", (s or "").lower()) if len(t) >= 3)
def _is_hook_frame(f):
    if not f: return False
    for m in _HOOK_MARKERS:
        if m in f: return True
    return False
def _is_system_class(cls):
    if not cls: return True
    if "culprit" in cls.lower(): return True
    for p in _SYS_PREFIXES:
        if cls.startswith(p): return True
    return False
def _is_obfuscated(frame):
    parts = (frame or "").split(".")
    if len(parts) < 2: return True
    return all(len(p) <= 2 for p in parts[:-1])
def _short_method(frame):
    parts = (frame or "").split(".")
    return ".".join(parts[-2:]) if len(parts) >= 2 else frame
def _squash(s):
    return re.sub(r"[^a-z0-9]+", "", (s or "").lower())
def _py_module_of(frame):
    if not frame or not frame.startswith(_PY_PREFIX): return None
    rest = frame[len(_PY_PREFIX):]
    if not rest: return None
    return rest.split(".", 1)[0]
def _is_py_runtime_frame(fr):
    if not fr or not fr.startswith(_PY_PREFIX): return False
    low = fr[len(_PY_PREFIX):].lower()
    return any(low == s or low.startswith(s) for s in _PY_SYS_MODS)
def _stack_culprit(frames):
    for fr in frames:
        if _is_system_class(fr): continue
        if _is_hook_frame(fr): continue
        if _is_py_runtime_frame(fr): continue
        if _is_obfuscated(fr): continue
        return fr
    return None
def _pkg_of(frame):
    parts = (frame or "").split(".")
    return ".".join(parts[:3]) if len(parts) >= 3 else frame
def _map_stack_to_id(culprit_frame, known):
    if not culprit_frame or not known: return None
    mod = _py_module_of(culprit_frame)
    sq = _squash(mod) if mod else ""
    if sq:
        for pid in known:
            if _squash(pid) == sq: return pid
        for pid in known:
            ps = _squash(pid)
            if ps and len(ps) >= 4 and (ps in sq or sq in ps): return pid
    ct = _tokens(culprit_frame) - _GENERIC
    if not ct: return None
    best = None; best_score = 0; second = 0
    for pid in known:
        pt = _tokens(pid) - _GENERIC
        score = len(ct & pt)
        if score > best_score:
            second = best_score; best_score = score; best = pid
        elif score > second:
            second = score
    if best_score >= 1 and best_score > second:
        return best
    return None

_REENTRY = threading.local()
_FIRST_LOGGED = False
def _note_first(pid, where):
    global _FIRST_LOGGED
    if _FIRST_LOGGED: return
    _FIRST_LOGGED = True
    _log(f"first breadcrumb captured: pid={pid} where={where!r}")

def _crash_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _CRASH_FILE_NAME).getAbsolutePath()
    except Exception:
        return None
_APP_PRIV_DIR = None
_AW_LOG_SEEN = {}
def _aw_mirror_path(path):
    try:
        pd = _app_priv_dir()
        if not pd: return None
        return os.path.join(pd, os.path.basename(path))
    except Exception:
        return None
def _aw_mirror_list():
    out = []
    try:
        pd = _app_priv_dir()
        if not pd: return out
        names = File(pd).list()
        if names:
            for nm in names:
                try:
                    if nm.endswith(".stage"): continue
                    if not (nm.endswith(".json") or nm.endswith(".txt")): continue
                    out.append(File(pd, nm).getAbsolutePath())
                except Exception: pass
    except Exception: pass
    return out
def _aw_log_once(path, sig, msg):
    try:
        if _AW_LOG_SEEN.get(path) == sig:
            return
        _AW_LOG_SEEN[path] = sig
    except Exception:
        pass
    try: _log(msg)
    except Exception: pass
def _aw_log_clear(path):
    try:
        _AW_LOG_SEEN.pop(path, None)
    except Exception: pass
def _app_priv_dir():
    global _APP_PRIV_DIR
    try:
        if _APP_PRIV_DIR:
            return _APP_PRIV_DIR
    except Exception:
        pass
    d = None
    try:
        ctx = _app_context()
        if ctx is not None:
            base = None
            try: base = ctx.getCacheDir().getAbsolutePath()
            except Exception: base = None
            if not base:
                try: base = ctx.getFilesDir().getAbsolutePath()
                except Exception: base = None
            if base:
                jd = File(base, "culprit_tmp")
                try:
                    if not jd.exists(): jd.mkdirs()
                except Exception: pass
                if jd.exists() and jd.isDirectory():
                    d = jd.getAbsolutePath()
    except Exception:
        d = None
    if d:
        _APP_PRIV_DIR = d
    return d

_FALLBACK_IO_LOCK = threading.Lock()
def _atomic_same_dir_replace(path, text):
    sib = None
    try:
        d = os.path.dirname(path) or "."
        sib = os.path.join(d, os.path.basename(path) + ".fb." + str(os.getpid()) + "." + str(threading.get_ident()))
        with open(sib, "w", encoding="utf-8") as f:
            f.write(text); f.flush()
            try: os.fsync(f.fileno())
            except Exception: pass
        os.replace(sib, path)
        return True
    except Exception:
        if sib:
            try: os.remove(sib)
            except Exception: pass
        return False

def _aw_target_is_precious(path):
    try:
        return os.path.exists(path) and os.path.getsize(path) > 0
    except Exception:
        return False


def _atomic_write_fallback(path, text):
    last_exc = None
    try:
        if _atomic_same_dir_replace(path, text):
            return (True, "sdcard", None)
    except Exception as e:
        last_exc = e
    try:
        if not _aw_target_is_precious(path):
            with open(path, "w", encoding="utf-8") as f3:
                f3.write(text); f3.flush()
                try: os.fsync(f3.fileno())
                except Exception: pass
            return (True, "sdcard", None)
    except Exception as e:
        last_exc = e
    try:
        mp = _aw_mirror_path(path)
        if mp:
            if _atomic_same_dir_replace(mp, text):
                return (True, "app_priv", None)
            if not _aw_target_is_precious(mp):
                with open(mp, "w", encoding="utf-8") as f4:
                    f4.write(text); f4.flush()
                    try: os.fsync(f4.fileno())
                    except Exception: pass
                return (True, "app_priv", None)
    except Exception as e:
        last_exc = e
    return (False, None, last_exc)

def _atomic_json_write(path, data, max_len=None, dedup=False):
    if not path: return False
    try:
        if max_len is not None and isinstance(data, (list, tuple)):
            try:
                if len(data) > max_len: data = data[-max_len:]
            except Exception: pass
    except Exception: pass
    try:
        _text = json.dumps(data, ensure_ascii=False)
    except Exception as e0:
        try: _log("atomic write enc err (%s): %s: %s" % (path, type(e0).__name__, e0))
        except Exception: pass
        return False
    if max_len is not None and not isinstance(data, (list, tuple)):
        try:
            if len(_text) > max_len:
                try: _log("atomic write oversize (%s): %d > %d bytes; skipped" % (path, len(_text), max_len))
                except Exception: pass
                return False
        except Exception: pass
    _vh = None
    if dedup:
        try:
            _vh = hash(_text)
            if _VERDICT_DEDUP.get(path) == _vh:
                return True
        except Exception:
            _vh = None
    try:
        if _VERDICT_NATIVE_OK and _NLIB is not None and _CTYPES_OK and hasattr(_NLIB, "cd_verdict_write"):
            _vb = _text.encode("utf-8")
            _ntmp = path + ".tmp." + str(os.getpid()) + "." + str(threading.get_ident())
            _vrc = int(_NLIB.cd_verdict_write(
                ctypes.c_char_p(_ntmp.encode("utf-8")),
                ctypes.c_char_p(path.encode("utf-8")),
                ctypes.c_char_p(_vb), ctypes.c_int32(len(_vb))))
            if _vrc == 0:
                _aw_log_clear(path)
                if _vh is not None:
                    try: _VERDICT_DEDUP[path] = _vh
                    except Exception: pass
                return True
    except Exception:
        pass
    try:
        tmp = path + ".tmp." + str(os.getpid()) + "." + str(threading.get_ident())
        with open(tmp, "w", encoding="utf-8") as f:
            f.write(_text); f.flush()
            try: os.fsync(f.fileno())
            except Exception: pass
        try:
            os.replace(tmp, path)
        except Exception:
            if _aw_target_is_precious(path):
                try: os.remove(tmp)
                except Exception: pass
                raise
            try:
                with _FALLBACK_IO_LOCK:
                    with open(path, "w", encoding="utf-8") as f2:
                        f2.write(_text); f2.flush()
                        try: os.fsync(f2.fileno())
                        except Exception: pass
            finally:
                try: os.remove(tmp)
                except Exception: pass
        _aw_log_clear(path)
        if _vh is not None:
            try: _VERDICT_DEDUP[path] = _vh
            except Exception: pass
        return True
    except Exception as e1:
        with _FALLBACK_IO_LOCK:
            ok, where, fe = _atomic_write_fallback(path, _text)
        if ok:
            if where == "app_priv":
                _aw_log_once(path, "app_priv", "atomic persist: %s -> app-private mirror (sdcard denied); included in share-logs" % path)
            else:
                _aw_log_clear(path)
            return True
        _aw_log_once(path, "fail", "atomic write err (%s): primary=%s fallback=%s: %s" % (path, type(e1).__name__, (type(fe).__name__ if fe is not None else "n/a"), fe))
        return False

_VW_Q = {}
_VW_LOCK = threading.Lock()
_VW_EVENT = threading.Event()
_VW_THREAD = None
_VW_STOP = None
_VW_FLUSH_S = 0.2
_VW_MAX_PATHS = 256
_VW_STATS = {"enqueued": 0, "coalesced": 0, "sync_fallback": 0, "written": 0, "drained": 0, "max_qlen": 0}

def _vw_stats_snapshot():
    try:
        with _VW_LOCK:
            s = dict(_VW_STATS)
            s["qlen"] = len(_VW_Q)
            s["alive"] = bool(_VW_THREAD is not None and _VW_THREAD.is_alive())
        return s
    except Exception:
        return None

def _enqueue_verdict_write(path, data, max_len=None, dedup=False):
    if not path:
        return False
    t = _VW_THREAD
    if t is None or not t.is_alive():
        with _VW_LOCK:
            _VW_STATS["sync_fallback"] += 1
        return _atomic_json_write(path, data, max_len, dedup)
    try:
        _sat = False
        with _VW_LOCK:
            if path not in _VW_Q and len(_VW_Q) >= _VW_MAX_PATHS:
                _VW_STATS["sync_fallback"] += 1
                _sat = True
            else:
                if path in _VW_Q:
                    _VW_STATS["coalesced"] += 1
                _VW_Q[path] = (data, max_len, dedup)
                _VW_STATS["enqueued"] += 1
                _ql = len(_VW_Q)
                if _ql > _VW_STATS["max_qlen"]:
                    _VW_STATS["max_qlen"] = _ql
        if _sat:
            return _atomic_json_write(path, data, max_len, dedup)
        _VW_EVENT.set()
        return True
    except Exception:
        with _VW_LOCK:
            _VW_STATS["sync_fallback"] += 1
        return _atomic_json_write(path, data, max_len, dedup)

def _vw_drain_once():
    with _VW_LOCK:
        if not _VW_Q:
            return
        batch = list(_VW_Q.items())
        _VW_Q.clear()
        _VW_STATS["drained"] += 1
        _VW_STATS["written"] += len(batch)
    for _p, _args in batch:
        try:
            _atomic_json_write(_p, _args[0], _args[1], _args[2])
        except Exception:
            pass

def _verdict_writer_loop(stop_evt):
    while not stop_evt.is_set():
        try:
            _VW_EVENT.wait(_VW_FLUSH_S)
            _VW_EVENT.clear()
            _vw_drain_once()
        except Exception:
            try: time.sleep(_VW_FLUSH_S)
            except Exception: pass
    _vw_drain_once()

def _vw_start():
    global _VW_THREAD, _VW_STOP
    try:
        if _VW_THREAD is not None and _VW_THREAD.is_alive():
            return
        _VW_STOP = threading.Event()
        _VW_THREAD = threading.Thread(target=_verdict_writer_loop, args=(_VW_STOP,), name="culprit-verdict-writer", daemon=True)
        _VW_THREAD.start()
        try:
            _log("+DJ verdict-writer запущен: thread=culprit-verdict-writer flush=%.1fs max_paths=%d (vw-телеметрия +DM)" % (_VW_FLUSH_S, _VW_MAX_PATHS))
        except Exception:
            pass
    except Exception as e:
        _VW_THREAD = None
        try: _log("verdict-writer start err: %r" % e)
        except Exception: pass

def _vw_stop():
    global _VW_THREAD
    try:
        if _VW_STOP is not None: _VW_STOP.set()
        _VW_EVENT.set()
        t = _VW_THREAD
        if t is not None:
            try: t.join(1.0)
            except Exception: pass
    except Exception:
        pass
    finally:
        try: _vw_drain_once()
        except Exception: pass
        _VW_THREAD = None

def _write_crash_verdict(rec):
    p = _crash_path()
    if not p: return
    try:
        rec.setdefault("event_type", "app_crash"); rec.setdefault("dropbox_tag", "data_app_crash")
        rec.setdefault("tombstone_norm_version", 1); rec.setdefault("persisted", False)
    except Exception: pass
    _atomic_json_write(p, rec)

_LOAD_FILE_NAME = "load_verdict.json"
_LOAD_FAILS_MAX = 20
_LOAD_DEDUP_MS = 4000
_LOAD_SEEN = {}; _LOAD_SEEN_LOCK = threading.Lock()
_PY_PREFIX = "<python>."
_PY_SYS_MODS = ("importlib", "java.chaquopy", "java.", "chaquopy_java",
                "_sdk_version", "encodings.", "<frozen", "base_plugin")

def _load_verdict_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _LOAD_FILE_NAME).getAbsolutePath()
    except Exception:
        return None

def _thr_chain(thr):
    out = []; n = 0; cur = thr
    while cur is not None and n < 12:
        n += 1
        try: cls = cur.getClass().getName()
        except Exception: cls = "?"
        try: msg = cur.getMessage()
        except Exception: msg = None
        out.append((cls, msg, cur))
        try: nxt = cur.getCause()
        except Exception: nxt = None
        if nxt is cur: break
        cur = nxt
    return out

def _py_module_from_throwable(chain):
    for (_c, _m, exc) in chain:
        try: st = exc.getStackTrace()
        except Exception: st = None
        if st is None: continue
        for el in st:
            try:
                cn = el.getClassName() or ""
                mn = el.getMethodName() or ""
                fn = el.getFileName() or ""
                ln = el.getLineNumber()
            except Exception:
                continue
            if not cn.startswith(_PY_PREFIX): continue
            if mn != "<module>": continue
            mod = cn[len(_PY_PREFIX):]
            low = mod.lower()
            if any(low == s or low.startswith(s) for s in _PY_SYS_MODS): continue
            return mod, (fn or (mod + ".py")), (int(ln) if ln is not None else -1)
    return None, None, -1

def _load_reason(chain):
    for (cls, msg, _e) in reversed(chain):
        if msg:
            scls = cls.rsplit(".", 1)[-1] if cls else "?"
            return ("%s: %s" % (scls, msg)) if (scls and scls not in (msg or "")) else msg
    for (cls, _m, _e) in reversed(chain):
        if cls and cls != "?":
            return cls.rsplit(".", 1)[-1]
    return "unknown"

_MEM_PRESSURE_REASON = "🧠 Python MemoryError — процесс исчерпал память (Python-куча); стек мог не сформироваться"
def _is_py_memoryerror(exc_cls, exc_msg):
    try:
        ec = str(exc_cls or ""); em = str(exc_msg or "")
        return ("MemoryError" in ec) or ("MemoryError" in em)
    except Exception:
        return False


def _record_load_fail(scoped_pid, thr, where):
    try: chain = _thr_chain(thr)
    except Exception: chain = []
    py_mod, py_file, py_line = _py_module_from_throwable(chain)
    reason = _load_reason(chain)
    top_cls = chain[0][0] if chain else "?"
    top_msg = chain[0][1] if chain else None
    if where == "loadPlugin" and scoped_pid:
        culprit = scoped_pid; src = "scope/loadPlugin"; conf = "high" if py_mod else "medium"
    elif py_mod:
        culprit = py_mod; src = "py-frame"; conf = "high"
    elif scoped_pid:
        culprit = scoped_pid; src = "scope/" + where; conf = "medium"
    else:
        culprit = "unknown"; src = "none"; conf = "low"
    rec = {"had_load_fail": True, "event_type": "plugin_load_exception", "dropbox_tag": "plugin_load_blocked", "tombstone_norm_version": 1, "culprit": culprit, "src": src, "confidence": conf,
           "where": where, "scoped_pid": scoped_pid, "py_module": py_mod,
           "py_file": py_file, "py_line": py_line, "reason": reason,
           "exc_cls": top_cls, "exc_msg": top_msg, "ts": int(time.time() * 1000)}
    if _is_py_memoryerror(top_cls, top_msg) or ("MemoryError" in (reason or "")):
        rec["mem_pressure"] = True; rec["reason"] = _MEM_PRESSURE_REASON; reason = rec["reason"]
    key = "%s|%s|%s" % (culprit, reason, where); now = rec["ts"]
    with _LOAD_SEEN_LOCK:
        if now - _LOAD_SEEN.get(key, 0) < _LOAD_DEDUP_MS: return
        _LOAD_SEEN[key] = now
    try: _load_verdict_log(rec, "live")
    except Exception: pass
    try: _persist_load_fail(rec)
    except Exception: pass

_PERSIST_IO_LOCK = __import__("threading").Lock()

def _persist_load_fail(rec):
    p = _load_verdict_path()
    if not p: return
    _PERSIST_IO_LOCK.acquire()
    try:
        cur = []
        if os.path.exists(p):
            try:
                with open(p, "r", encoding="utf-8") as f: cur = list(json.load(f))
            except Exception: cur = []
        cur.append(rec)
        _atomic_json_write(p, cur, _LOAD_FAILS_MAX)
    except Exception: pass
    finally:
        try: _PERSIST_IO_LOCK.release()
        except Exception: pass

_RC_PROC_START = time.time()

def _rc_rearm_orphan(base):
    if not base: return
    proc = base + ".processing"
    try:
        if os.path.exists(base): return
        if not os.path.exists(proc): return
        if os.path.getmtime(proc) >= _RC_PROC_START: return
        os.rename(proc, base)
    except Exception:
        pass

def _rc_read_path(p):
    try:
        mp = _aw_mirror_path(p) if p else None
    except Exception:
        mp = None
    _rc_rearm_orphan(p)
    if mp: _rc_rearm_orphan(mp)
    try: pe = bool(p) and os.path.exists(p)
    except Exception: pe = False
    try: me = bool(mp) and os.path.exists(mp)
    except Exception: me = False
    if pe and me:
        try:
            if os.path.getmtime(mp) > os.path.getmtime(p): return mp
        except Exception: pass
        return p
    if pe: return p
    if me: return mp
    return None

def _rc_remove_both(p):
    if not p: return
    try: mp = _aw_mirror_path(p)
    except Exception: mp = None
    for _fp in (p, mp):
        try:
            if _fp and os.path.exists(_fp): os.remove(_fp)
        except Exception: pass

def _rc_take_path(p):
    if not p: return None
    _PERSIST_IO_LOCK.acquire()
    try:
        rp = _rc_read_path(p)
        if not rp: return None
        try: mp = _aw_mirror_path(p)
        except Exception: mp = None
        try: _claim_m = os.path.getmtime(rp)
        except Exception: _claim_m = None
        tmp = rp + ".processing"
        try:
            os.rename(rp, tmp); claimed = tmp
        except Exception:
            return None
        _other = p if rp != p else mp
        if _other and _other != rp:
            try:
                if os.path.exists(_other) and (_claim_m is None or os.path.getmtime(_other) <= _claim_m):
                    os.remove(_other)
            except Exception: pass
        return claimed
    finally:
        try: _PERSIST_IO_LOCK.release()
        except Exception: pass

def _read_and_clear_load_fails():
    p = _load_verdict_path()
    if not p: return []
    out = []
    _rp = _rc_take_path(p)
    try:
        if _rp:
            with open(_rp, "r", encoding="utf-8") as f: out = list(json.load(f))
    except Exception: out = []
    if _rp:
        try: os.remove(_rp)
        except Exception: pass
    return out

def _load_verdict_log(rec, when):
    try:
        _log("============= LOAD/IMPORT VERDICT (%s) =============" % when)
        cul = rec.get("culprit"); conf = rec.get("confidence")
        if cul and cul != "unknown":
            _log("ВИНОВНИК ЗАГРУЗКИ: %r conf=%s where=%s src=%s" % (cul, conf, rec.get("where"), rec.get("src")))
        else:
            _log("ВИНОВНИК ЗАГРУЗКИ: неизвестен (where=%s) — нет имени модуля в стеке" % rec.get("where"))
        _log("  причина: %s" % rec.get("reason"))
        pf = rec.get("py_file")
        if pf: _log("  модуль: %s:%s" % (pf, rec.get("py_line")))
        sp = rec.get("scoped_pid")
        if sp and sp != cul: _log("  scope-плагин(loadPlugin-арг): %s" % sp)
        _log("  исключение: %s: %s" % (rec.get("exc_cls"), rec.get("exc_msg")))
        _log("====================================================")
    except Exception: pass
_HOOK_FILE_NAME = "hook_verdict.json"
_HOOK_FAILS_MAX = 20
_HOOK_DEDUP_MS = 4000
_HOOK_SEEN = {}; _HOOK_SEEN_LOCK = threading.Lock()
_BLOCK9_ON = True

def _hook_verdict_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _HOOK_FILE_NAME).getAbsolutePath()
    except Exception:
        return None

def _hook_scope_pid():
    try:
        c = get_culprit_for_tid(_cur_tid())
        if c and c != "unknown": return c
    except Exception: pass
    return None

def _record_hook_fail(thr, where="executeHook", scoped=None):
    if not _BLOCK9_ON: return
    try: chain = _thr_chain(thr)
    except Exception: chain = []
    if not chain: return
    py_mod, py_file, py_line = _py_module_from_throwable(chain)
    reason = _load_reason(chain)
    top_cls = chain[0][0] if chain else "?"
    top_msg = chain[0][1] if chain else None
    if scoped is None: scoped = _hook_scope_pid()
    if py_mod:
        culprit = py_mod; src = "py-frame"; conf = "high"
    elif scoped:
        culprit = scoped; src = "scope/" + where; conf = "medium"
    else:
        culprit = "unknown"; src = "none"; conf = "low"
    rec = {"had_hook_fail": True, "culprit": culprit, "src": src, "confidence": conf,
           "where": where, "scoped_pid": scoped, "py_module": py_mod,
           "py_file": py_file, "py_line": py_line, "reason": reason,
           "exc_cls": top_cls, "exc_msg": top_msg, "ts": int(time.time() * 1000)}
    key = "%s|%s|%s" % (culprit, reason, where); now = rec["ts"]
    with _HOOK_SEEN_LOCK:
        if now - _HOOK_SEEN.get(key, 0) < _HOOK_DEDUP_MS: return
        _HOOK_SEEN[key] = now
    try: _hook_verdict_log(rec, "live")
    except Exception: pass
    try: _persist_hook_fail(rec)
    except Exception: pass

def _persist_hook_fail(rec):
    p = _hook_verdict_path()
    if not p: return
    _PERSIST_IO_LOCK.acquire()
    try:
        cur = []
        if os.path.exists(p):
            try:
                with open(p, "r", encoding="utf-8") as f: cur = list(json.load(f))
            except Exception: cur = []
        try:
            rec.setdefault("event_type", "hook_exception"); rec.setdefault("dropbox_tag", "data_app_crash"); rec.setdefault("tombstone_norm_version", 1)
        except Exception: pass
        cur.append(rec)
        _atomic_json_write(p, cur, _HOOK_FAILS_MAX)
    except Exception: pass
    finally:
        try: _PERSIST_IO_LOCK.release()
        except Exception: pass

def _read_and_clear_hook_fails():
    p = _hook_verdict_path()
    if not p: return []
    out = []
    _rp = _rc_take_path(p)
    try:
        if _rp:
            with open(_rp, "r", encoding="utf-8") as f: out = list(json.load(f))
    except Exception: out = []
    if _rp:
        try: os.remove(_rp)
        except Exception: pass
    return out

def _hook_verdict_log(rec, when):
    try:
        _log("============= RUNTIME HOOK VERDICT (%s) =============" % when)
        cul = rec.get("culprit"); conf = rec.get("confidence")
        if cul and cul != "unknown":
            _log("ВИНОВНИК ХУКА: %r conf=%s where=%s src=%s" % (cul, conf, rec.get("where"), rec.get("src")))
        else:
            _log("ВИНОВНИК ХУКА: неизвестен (where=%s) — нет имени модуля в стеке" % rec.get("where"))
        _log("  причина: %s" % rec.get("reason"))
        pf = rec.get("py_file")
        if pf: _log("  модуль: %s:%s" % (pf, rec.get("py_line")))
        sp = rec.get("scoped_pid")
        if sp and sp != cul: _log("  scope-плагин(tid): %s" % sp)
        _log("  исключение: %s: %s" % (rec.get("exc_cls"), rec.get("exc_msg")))
        _log("====================================================")
    except Exception: pass
_GATE_FILE_NAME = "gate_verdict.json"
_GATE_FAILS_MAX = 20
_GATE_DEDUP_MS = 60000
_GATE_SEEN = {}; _GATE_SEEN_LOCK = threading.Lock()
_BLOCK11_ON = True
_B11_TIMERS = []
_PC_CLASS = "com.exteragram.messenger.plugins.PluginsController"
_PPE_CLASS = "com.exteragram.messenger.plugins.PythonPluginsEngine"
_XCFG_CLASS = "com.exteragram.messenger.ExteraConfig"

def _b11_jc(name):
    try:
        return jclass(name)
    except BaseException:
        pass
    try:
        return find_class(name)
    except BaseException:
        return None

def _b11_attr(obj, *names):
    for n in names:
        try:
            v = getattr(obj, n)
        except Exception:
            continue
        try:
            return v() if callable(v) else v
        except Exception:
            continue
    return None

def _gate_verdict_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _GATE_FILE_NAME).getAbsolutePath()
    except Exception:
        return None

def _b11_controller():
    jc = _b11_jc(_PC_CLASS)
    if jc is None: return None
    return _b11_attr(jc, "INSTANCE")

def _b11_runtime_sdk():
    jc = _b11_jc(_PPE_CLASS)
    if jc is None: return None
    v = _b11_attr(jc, "getSDK_VERSION", "SDK_VERSION")
    return str(v) if v is not None else None

def _b11_safe_mode():
    jc = _b11_jc(_XCFG_CLASS)
    if jc is None: return None
    v = _b11_attr(jc, "getPluginsSafeMode")
    return bool(v) if v is not None else None

def _b11_plugin_entries():
    ctrl = _b11_controller()
    if ctrl is None: return []
    m = _b11_attr(ctrl, "getPlugins", "plugins")
    if m is None: return []
    last = None
    for _ in range(3):
        try: return list(m.entrySet().toArray())
        except Exception as e: last = e
    try: _log("Block#11: entrySet snapshot failed: %s" % last)
    except Exception: pass
    return []

def _b11_is_loaded(pid):
    try:
        with _REG_LOCK:
            r = _REGISTRY.get(pid)
        if r and r.get("inst"): return True
    except Exception: pass
    return False

def _record_gate_fail(pid, kind, reason, thr=None, extra=None):
    if not _BLOCK11_ON: return
    py_mod = py_file = None; py_line = -1; top_cls = "?"; top_msg = None
    if thr is not None:
        try: chain = _thr_chain(thr)
        except Exception: chain = []
        if chain:
            py_mod, py_file, py_line = _py_module_from_throwable(chain)
            r2 = _load_reason(chain)
            if r2 and r2 != "unknown": reason = r2
            top_cls = chain[0][0]; top_msg = chain[0][1]
    if py_mod:
        culprit = py_mod; src = "py-frame"; conf = "high"
    elif pid:
        culprit = pid; src = "plugins-map/" + kind; conf = "high" if thr is not None else "medium"
    else:
        culprit = "unknown"; src = "none"; conf = "low"
    rec = {"had_gate_fail": True, "event_type": "plugin_gate_blocked", "dropbox_tag": "plugin_gate_blocked", "tombstone_norm_version": 1, "culprit": culprit, "src": src, "confidence": conf,
           "kind": kind, "pid": pid, "py_module": py_mod, "py_file": py_file,
           "py_line": py_line, "reason": reason, "exc_cls": top_cls, "exc_msg": top_msg,
           "extra": extra, "ts": int(time.time() * 1000)}
    key = "%s|%s|%s" % (culprit, reason, kind); now = rec["ts"]
    with _GATE_SEEN_LOCK:
        if now - _GATE_SEEN.get(key, 0) < _GATE_DEDUP_MS: return
        _GATE_SEEN[key] = now
    try: _gate_verdict_log(rec, "live")
    except Exception: pass
    try: _persist_gate_fail(rec)
    except Exception: pass

def _persist_gate_fail(rec):
    p = _gate_verdict_path()
    if not p: return
    _PERSIST_IO_LOCK.acquire()
    try:
        cur = []
        if os.path.exists(p):
            try:
                with open(p, "r", encoding="utf-8") as f: cur = list(json.load(f))
            except Exception: cur = []
        cur.append(rec)
        _atomic_json_write(p, cur, _GATE_FAILS_MAX)
    except Exception: pass
    finally:
        try: _PERSIST_IO_LOCK.release()
        except Exception: pass

def _read_and_clear_gate_fails():
    p = _gate_verdict_path()
    if not p: return []
    out = []
    _rp = _rc_take_path(p)
    try:
        if _rp:
            with open(_rp, "r", encoding="utf-8") as f: out = list(json.load(f))
    except Exception: out = []
    if _rp:
        try: os.remove(_rp)
        except Exception: pass
    return out

def _gate_verdict_log(rec, when):
    try:
        _log("============= PRE-IMPORT/GATE VERDICT (%s) =============" % when)
        cul = rec.get("culprit"); conf = rec.get("confidence")
        if cul and cul != "unknown":
            _log("ВИНОВНИК ВОРОТ ЗАГРУЗКИ: %r conf=%s kind=%s src=%s" % (cul, conf, rec.get("kind"), rec.get("src")))
        else:
            _log("ВИНОВНИК ВОРОТ ЗАГРУЗКИ: неизвестен (kind=%s)" % rec.get("kind"))
        _log("  причина: %s" % rec.get("reason"))
        pf = rec.get("py_file")
        if pf: _log("  модуль: %s:%s" % (pf, rec.get("py_line")))
        ex = rec.get("extra")
        if ex: _log("  детали: %s" % ex)
        ec = rec.get("exc_cls")
        if ec and ec != "?": _log("  исключение: %s: %s" % (ec, rec.get("exc_msg")))
        _log("=======================================================")
    except Exception: pass

def _b11_scan(reason="scan"):
    if not _BLOCK11_ON: return
    try:
        sm = _b11_safe_mode()
        if sm is True:
            _record_gate_fail(None, "safe-mode",
                              "движок в SAFE-MODE -> плагины не загружаются (тихо, без исключения)",
                              extra="ExteraConfig.getPluginsSafeMode()=true")
    except Exception: pass
    rt_sdk = _b11_runtime_sdk()
    entries = _b11_plugin_entries()
    for ent in entries:
        try:
            pid = str(ent.getKey())
            pj = ent.getValue()
        except Exception:
            continue
        if pj is None: continue
        err = _b11_attr(pj, "getError", "error")
        if err is not None:
            try: _intern(pid); _save_known(pid)
            except Exception: pass
            _record_gate_fail(pid, "error",
                              "движок проглотил исключение загрузки (plugins[%s].error)" % pid, thr=err)
            continue
        try:
            if _b11_is_loaded(pid): continue
        except Exception: pass
        psdk = _b11_attr(pj, "getSdkVersion", "sdkVersion")
        psdk = str(psdk) if psdk is not None else ""
        pav = _b11_attr(pj, "getAppVersion", "appVersion")
        pav = str(pav) if pav is not None else ""
        req = _b11_attr(pj, "getRequirements", "requirements")
        try: req = list(req) if req is not None else []
        except Exception: req = []
        if rt_sdk and psdk and psdk != rt_sdk and rt_sdk != "unknown":
            _record_gate_fail(pid, "sdk-version",
                              "несовпадение sdk_version (плагин=%s, рантайм=%s) -> вероятная тихая не-загрузка" % (psdk, rt_sdk),
                              extra="app_version(min)=%s requirements=%s" % (pav or "-", req or "-"))

_B11P_ON = True
_PREIMPORT_DIR = None
_PREIMPORT_FINDER = None
def _b11p_plugins_dir():
    global _PREIMPORT_DIR
    if _PREIMPORT_DIR is not None:
        return _PREIMPORT_DIR
    d = None
    try:
        PC = jclass(_PC_CLASS).getInstance()
        pd = getattr(PC, "pluginsDir", None)
        if pd is not None:
            try: d = str(pd.getAbsolutePath())
            except Exception: d = str(pd)
    except Exception:
        d = None
    if not d:
        try:
            fp = globals().get("__file__")
            if isinstance(fp, str) and fp:
                d = os.path.dirname(fp)
        except Exception:
            d = None
    _PREIMPORT_DIR = d or ""
    return _PREIMPORT_DIR
def _b11p_record(fullname, module, exc):
    if not _BLOCK11_ON or not _B11P_ON: return
    pid = None
    if isinstance(fullname, str) and fullname and fullname != _SELF_ID and fullname != __id__:
        pid = fullname
    if pid is None:
        try:
            cand = getattr(module, "__id__", None)
            if isinstance(cand, str) and cand: pid = cand
        except Exception: pass
    py_file = None; py_line = -1
    try:
        tb = getattr(exc, "__traceback__", None)
        while tb is not None:
            try:
                g = tb.tb_frame.f_globals
                fn = g.get("__file__")
                if fn: py_file = fn
                py_line = tb.tb_lineno
            except Exception: pass
            tb = tb.tb_next
    except Exception: pass
    try: ecls = type(exc).__name__
    except Exception: ecls = "?"
    try: emsg = str(exc)
    except Exception: emsg = None
    reason = "падение во время импорта модуля плагина (до on_plugin_load): %s: %s" % (ecls, emsg)
    extra = "pre-import module=%s" % fullname
    if py_file: extra += " @ %s:%s" % (py_file, py_line)
    try:
        _intern(pid); _save_known(pid)
    except Exception: pass
    _record_gate_fail(pid, "pre-import", reason, thr=None, extra=extra)
    try: _log("Block#11P: поймано падение импорта плагина %r (%s)" % (pid or fullname, ecls))
    except Exception: pass
class _PreImportGuardLoader:
    def __init__(self, real, fullname):
        self._real = real
        self._fullname = fullname
    def create_module(self, spec):
        try:
            return self._real.create_module(spec)
        except Exception:
            return None
    def exec_module(self, module):
        try:
            self._real.exec_module(module)
        except BaseException as e:
            try: _b11p_record(self._fullname, module, e)
            except Exception: pass
            raise
    def __getattr__(self, name):
        if name in ("_real", "_fullname"):
            raise AttributeError(name)
        return getattr(self._real, name)
class _PreImportFinder:
    def find_spec(self, fullname, path=None, target=None):
        if not _B11P_ON: return None
        try:
            pdir = _b11p_plugins_dir()
            if not pdir: return None
            spec = None
            for finder in list(_sys.meta_path):
                if finder is self: continue
                fs = getattr(finder, "find_spec", None)
                if fs is None: continue
                try: spec = fs(fullname, path, target)
                except Exception: spec = None
                if spec is not None: break
            if spec is None: return None
            loader = getattr(spec, "loader", None)
            origin = getattr(spec, "origin", None)
            if loader is None or not isinstance(origin, str): return spec
            if isinstance(loader, _PreImportGuardLoader): return spec
            try: in_pdir = (os.path.dirname(origin) == pdir) or origin.startswith(pdir)
            except Exception: in_pdir = False
            if not in_pdir: return spec
            try:
                spec.loader = _PreImportGuardLoader(loader, fullname)
            except Exception:
                return spec
            return spec
        except Exception:
            return None
def _b11p_install():
    global _PREIMPORT_FINDER
    if not _B11P_ON: return
    if _PREIMPORT_FINDER is not None: return
    try:
        _b11p_plugins_dir()
        f = _PreImportFinder()
        _sys.meta_path.insert(0, f)
        _PREIMPORT_FINDER = f
        _log("Block#11P: pre-import gate installed (dir=%s)" % (_PREIMPORT_DIR or "?"))
    except Exception as e:
        try: _log("Block#11P install err: %s" % e)
        except Exception: pass
def _b11p_uninstall():
    global _PREIMPORT_FINDER
    f = _PREIMPORT_FINDER
    if f is None: return
    try:
        if f in _sys.meta_path: _sys.meta_path.remove(f)
    except Exception: pass
    _PREIMPORT_FINDER = None
def _b11_install_scan():
    for delay in (3.0, 8.0):
        try:
            t = threading.Timer(delay, lambda d=delay: _b11_scan("post-load+%ss" % int(d)))
            t.daemon = True; t.start()
            _B11_TIMERS.append(t)
        except Exception as e:
            try: _log("Block#11: scan timer err: %s" % e)
            except Exception: pass

def _jc(name):
    try:
        return jclass(name)
    except Exception:
        try:
            from java import jclass as _j
            return _j(name)
        except Exception:
            return None

def _oom_path(name=None):
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, name or _OOM_FILE_NAME).getAbsolutePath()
    except Exception:
        return None

def _java_mem():
    ju = -1; jm = -1; nh = -1
    try:
        rt = _jc("java.lang.Runtime").getRuntime()
        jm = int(rt.maxMemory()); ju = int(rt.totalMemory()) - int(rt.freeMemory())
    except Exception:
        pass
    try:
        nh = int(_jc("android.os.Debug").getNativeHeapAllocatedSize())
    except Exception:
        pass
    return ju, jm, nh

_UNTAGGED_LABEL = "⟨untagged⟩"

def _oom_gref_top():
    try:
        if not (_GREF_NATIVE_OK and _NLIB is not None and ctypes is not None):
            return None
        try:
            if not int(_NLIB.cd_gref_running()):
                return None
        except Exception:
            return None
        _cnt = ctypes.c_int64(0)
        idx = int(_NLIB.cd_gref_top1(ctypes.byref(_cnt)))
        top_cnt = int(_cnt.value)
        if idx < 0 or top_cnt <= 0:
            return None
        try: total = int(_NLIB.cd_gref_total())
        except Exception: total = 0
        try: untagged = int(_NLIB.cd_gref_untagged())
        except Exception: untagged = 0
        name = None
        try: name = _resolve_idx(idx)
        except Exception: name = None
        if not name:
            try: name = _resolve_idx_durable(idx)
            except Exception: name = None
        if not name or name == _SELF_ID or name == __id__:
            return None
        return {"culprit": name, "count": top_cnt, "total": total,
                "untagged": untagged, "src": "native"}
    except Exception:
        return None

_NA_HINT_MAX_AGE_MS = 180000
_NA_HINT_MIN_BYTES = 1048576

def _oom_native_site_hint(odump):
    try:
        p = _oom_path(_NA_NAME)
        if not p or not os.path.exists(p):
            return None
        try: _mt = int(os.path.getmtime(p) * 1000)
        except Exception: _mt = None
        try: _ts = int(odump.get("ts") or 0)
        except Exception: _ts = 0
        if _mt is not None and _ts > 0 and abs(_mt - _ts) > _NA_HINT_MAX_AGE_MS:
            return None
        with open(p, "r", encoding="utf-8") as _f:
            d = json.load(_f)
        best = None
        for s in (d.get("sites") or []):
            try:
                if s.get("bucket") == "gfx":
                    continue
                rb = int(s.get("retained_bytes") or 0)
            except Exception:
                continue
            if rb < _NA_HINT_MIN_BYTES:
                continue
            if best is None or rb > best[0]:
                frames = s.get("frames") or []
                mod = None
                if frames:
                    try: mod = str(frames[0]).split("+", 1)[0].split("/")[-1].strip()
                    except Exception: mod = None
                if mod:
                    best = (rb, mod, int(s.get("count") or 0), s.get("bucket"))
        if not best:
            return None
        return {"module": best[1], "bytes": best[0], "count": best[2], "bucket": best[3]}
    except Exception:
        return None

def _oom_verdict(odump):
    try:
        top = list(odump.get("top") or [])
    except Exception:
        top = []
    untagged = 0; real = []; total_attr = 0
    for kv in top:
        try:
            name = kv[0]; b = int(kv[1])
        except Exception:
            continue
        if b < 0: b = 0
        total_attr += b
        if name == _UNTAGGED_LABEL:
            untagged += b
        else:
            real.append((name, b))
    real.sort(key=lambda x: x[1], reverse=True)
    denom = total_attr if total_attr > 0 else 1
    culprit = real[0][0] if real else None
    culprit_bytes = real[0][1] if real else 0
    second_bytes = real[1][1] if len(real) > 1 else 0
    share = float(culprit_bytes) / float(denom)
    untagged_share = float(untagged) / float(denom)
    margin = (float(culprit_bytes - second_bytes) / float(culprit_bytes)) if culprit_bytes > 0 else 0.0
    try:
        rate = float(odump.get("rate_mbps") or 0.0)
    except Exception:
        rate = 0.0
    tagged_total = total_attr - untagged
    tagged_share = (float(culprit_bytes) / float(tagged_total)) if tagged_total > 0 else 0.0
    if culprit is None:
        conf = "low"
        display = _UNTAGGED_LABEL if untagged > 0 else None
        reason_detail = "no_attribution"
    elif untagged > culprit_bytes:
        if rate >= 15.0 and tagged_share >= 0.80 and culprit_bytes > 524288:
            conf = "medium"
            display = culprit
            reason_detail = "async_download_pattern"
        elif rate >= 50.0 and culprit_bytes > 262144:
            conf = "low"
            display = culprit
            reason_detail = "rate_suspect"
        else:
            conf = "low"
            display = _UNTAGGED_LABEL
            reason_detail = "untagged_dominates"
    elif share >= 0.60 and untagged_share <= 0.25 and margin >= 0.50:
        conf = "high"; display = culprit; reason_detail = "clear_leader"
    elif share >= 0.30 and untagged_share <= 0.50:
        conf = "medium"; display = culprit; reason_detail = "probable_leader"
    else:
        conf = "low"; display = culprit; reason_detail = "weak_leader"
    gref_culprit = None; gref_count = 0; gref_total = 0; gref_share = 0.0
    _byte_named = (display != _UNTAGGED_LABEL and display is not None)
    _gref_took_display = False
    _g = None
    try: _g = odump.get("gref")
    except Exception: _g = None
    if not _g:
        try: _g = _oom_gref_top()
        except Exception: _g = None
    if _g:
        try:
            _gn = _g.get("culprit"); _gc = int(_g.get("count") or 0)
            _gt = int(_g.get("total") or 0)
            _gu = int(_g.get("untagged") or 0)
            _named = _gt - _gu
            _gsh = (float(_gc) / float(_named)) if _named > 0 else ((float(_gc) / float(_gt)) if _gt > 0 else 0.0)
            if _gn and _gc >= _B28C_MIN and _gsh >= _B28C_DOMINANCE:
                gref_culprit = _gn; gref_count = _gc
                gref_total = _gt; gref_share = _gsh
                if not _byte_named:
                    display = _gn
                    reason_detail = "globalref_native"
                    conf = "medium"
                    _gref_took_display = True
        except Exception:
            pass
    is_unt = (display == _UNTAGGED_LABEL)
    if _gref_took_display:
        display_bytes = untagged; display_share = untagged_share
    else:
        display_bytes = untagged if is_unt else culprit_bytes
        display_share = untagged_share if is_unt else share
    native_site = None
    if (not _gref_took_display) and (is_unt or display is None):
        try: native_site = _oom_native_site_hint(odump)
        except Exception: native_site = None
    if native_site:
        reason_detail = "native_site_hint"
    return {"culprit": display, "top_named": culprit, "top_named_bytes": culprit_bytes,
            "culprit_bytes": culprit_bytes, "second_bytes": second_bytes,
            "margin": round(margin, 4), "share": round(share, 4),
            "display_bytes": display_bytes, "display_share": round(display_share, 4),
            "untagged_bytes": untagged, "untagged_share": round(untagged_share, 4),
            "rate_mbps": round(rate, 2), "reason": odump.get("reason"),
            "gref_culprit": gref_culprit, "gref_count": gref_count,
            "gref_total": gref_total, "gref_share": round(gref_share, 4),
            "native_site_culprit": (native_site["module"] if native_site else None),
            "native_site_bytes": (native_site["bytes"] if native_site else 0),
            "native_site_count": (native_site["count"] if native_site else 0),
            "native_site_bucket": (native_site["bucket"] if native_site else None),
            "reason_detail": reason_detail, "confidence": conf}

def _oom_verdict_log(odump, where):
    try:
        v = _oom_verdict(odump)
    except Exception as e:
        try: _log(f"OOM verdict err: {e}")
        except Exception: pass
        return None
    cul = v.get("culprit")
    if cul is None:
        return v
    _OOM_RD_TXT = {
        "untagged_dominates": "untagged dominates; named plugin too small to explain OOM",
        "no_attribution": "no attribution; all memory untagged (raw threads / Part A .so)",
        "clear_leader": "clear leader",
        "probable_leader": "probable leader",
        "weak_leader": "weak leader; low confidence",
        "async_download_pattern": "async HTTP/network: plugin dominates tagged; untagged = urllib3/TCP/JNI buffers outside scope",
        "rate_suspect": "fast growth rate with active named plugin; untagged dominates",
        "globalref_native": "native NewGlobalRef counter (Block#28C): one plugin dominates global-ref CREATION rate (churn); NOT a confirmed live leak -- DeleteGlobalRef is not tracked, so this is creation-dominance (cumulative), invisible to malloc tags",
        "native_site_hint": "untagged at OOM, but the native alloc-site sampler names the dominant holder module (large mmap/direct allocs bypass the malloc tagger)",
    }
    rd = v.get("reason_detail")
    _log("================ OOM VERDICT (%s) ================" % where)
    _log("ВИНОВНИК OOM(память): %r conf=%s доля=%.0f%% (%dB) отрыв=%.0f%% rate=%sMB/s untagged=%.0f%% reason=%s" % (
        cul, v["confidence"], v["display_share"]*100.0, v["display_bytes"],
        v["margin"]*100.0, v["rate_mbps"], v["untagged_share"]*100.0, v.get("reason")))
    if cul == _UNTAGGED_LABEL:
        tn = v.get("top_named"); tnb = int(v.get("top_named_bytes") or 0)
        if tn:
            _log("  top_named=%s %dB" % (tn, tnb))
        _nsc = v.get("native_site_culprit")
        if _nsc:
            _log("  native-site(holder)=%s %dB x%s bucket=%s -- держатель нативной памяти по сэмплеру (модульная подсказка; malloc-теги его не видят)" % (
                _nsc, int(v.get("native_site_bytes") or 0), v.get("native_site_count"), v.get("native_site_bucket")))
        _log("  reason: %s" % _OOM_RD_TXT.get(rd, rd))
        _log("  → виновник по памяти не определён достоверно (named-плагин не объясняет OOM)")
    elif rd == "globalref_native":
        gn = v.get("gref_culprit"); gc = int(v.get("gref_count") or 0)
        gt = int(v.get("gref_total") or 0)
        gsh = (float(gc) / float(gt) * 100.0) if gt > 0 else 0.0
        _log("  global-refs(native): %s=%d из %d (%.0f%%) -- атрибуция по нативному счётчику NewGlobalRef (Block#28C)" % (gn, gc, gt, gsh))
        _log("  reason: %s" % _OOM_RD_TXT.get(rd, rd))
        _log("  -> по НАКОПЛЕННОМУ темпу создания JNI global-ref (churn): DeleteGlobalRef не учитывается -> это не подтверждённая утечка, а доминирование по созданию (malloc-теги его не видят); доверие среднее")
    elif rd in ("async_download_pattern", "rate_suspect"):
        tn = v.get("top_named"); tnb = int(v.get("top_named_bytes") or 0)
        unt = int(v.get("untagged_bytes") or 0)
        _async_ratio = round(float(unt) / float(tnb), 1) if tnb > 0 else 0.0
        _named_pct = round(float(tnb) / float(tnb + unt) * 100.0, 1) if (tnb + unt) > 0 else 0.0
        _log("  named=%s %dB untagged=%dB async_ratio=%.1fx named_pct=%.1f%%" % (
            tn, tnb, unt, _async_ratio, _named_pct))
        _log("  reason: %s" % _OOM_RD_TXT.get(rd, rd))
        _log("  → виновник определён по async-паттерну: буферы HTTP-загрузки вне scope падают в untagged")
    else:
        _log("  reason: %s" % _OOM_RD_TXT.get(rd, rd))
    _log("=================================================")
    return v

def _oom_persist(rec):
    try:
        hp = _oom_path("oom_dump_%d.json" % rec["ts"])
        if hp:
            _atomic_json_write(hp, rec)
    except Exception:
        pass
    p = _oom_path()
    if not p: return
    _atomic_json_write(p, rec)

def _oom_log_dump(rec):
    m = rec.get("mem", {})
    pc = m.get("pct"); pcs = round(pc*100,1) if (pc is not None and pc>=0) else -1
    _log("================ PRE-OOM DUMP ================")
    _log(f'PRE-OOM trigger: reason={rec.get("reason")} rate={rec.get("rate_mbps")}MB/s')
    _log(f'  mem: src={m.get("src")} used={m.get("used")}B limit={m.get("limit")}B pct={pcs}%')
    _log(f'  rss={m.get("rss")}B native_heap={m.get("native_heap")}B java={m.get("java_used")}/{m.get("java_max")}B cgroup={m.get("cg_cur")}/{m.get("cg_max")}B')
    _log(f'  tracked: cd_total={m.get("cd_total")}B live={rec.get("native_live")} dropped={rec.get("dropped")}')
    if rec.get("direct_total") is not None:
        _log(f'  direct(NIO off-heap): live={rec.get("direct_live_total")}B cumulative={rec.get("direct_total")}B untagged_live={rec.get("direct_live_untagged")}B')
    _log(f'  TOP-{_OOM_TOPN} consumers (plugin: bytes [native_live+direct_live]):')
    for i, kv in enumerate(rec.get("top", [])):
        try: _log(f'    #{i+1} {kv[0]}: {int(kv[1])}B')
        except Exception: pass
    try: _oom_verdict_log(rec, "live")
    except Exception: pass
    _log("==============================================")

def _read_and_clear_oom_dump():
    p = _oom_path()
    if not p: return None
    rec = None
    _rp = _rc_take_path(p)
    try:
        if _rp:
            with open(_rp, "r", encoding="utf-8") as f:
                rec = json.load(f)
    except Exception:
        rec = None
    if _rp:
        try: os.remove(_rp)
        except Exception: pass
    return rec

import struct as _struct
_OOM_HDR_FMT = "<II12q4i"
_OOM_HDR_LEN = _struct.calcsize(_OOM_HDR_FMT)
_OOM_TOP_FMT = "<iiq"
_OOM_TOP_LEN = _struct.calcsize(_OOM_TOP_FMT)
_OOM_MAGIC = 0x4F4F4D32

def _oom_sentinel_path():
    return _oom_path(_OOM_SENTINEL_NAME)

def _oom_decode_sentinel(blob):
    if not blob or len(blob) < _OOM_HDR_LEN:
        return None
    h = _struct.unpack_from(_OOM_HDR_FMT, blob, 0)
    (magic, ver, ts_ms, used, limit, rate_milli, cd_total, untagged, live_count,
        dropped, dropped_bytes, rss, cg_cur, cg_max, reason, src, topn, _pad) = h
    if magic != _OOM_MAGIC:
        return None
    topn = max(0, min(int(topn), 64))
    tops = []
    off = _OOM_HDR_LEN
    for _ in range(topn):
        if off + _OOM_TOP_LEN > len(blob): break
        idx, _p, b = _struct.unpack_from(_OOM_TOP_FMT, blob, off)
        off += _OOM_TOP_LEN
        if idx >= 0 and b > 0:
            tops.append((int(idx), int(b)))
    return {"ver": int(ver), "ts_ms": int(ts_ms), "used": int(used), "limit": int(limit),
            "rate_mbps": (rate_milli / 1000.0), "cd_total": int(cd_total),
            "untagged": int(untagged), "live_count": int(live_count),
            "dropped": int(dropped), "dropped_bytes": int(dropped_bytes),
            "rss": int(rss), "cg_cur": int(cg_cur), "cg_max": int(cg_max),
            "reason_bits": int(reason), "src_code": int(src), "tops": tops}

def _direct_pm_path():
    return _oom_path(_DIRECT_PM_NAME)

def _direct_premortem_dump():
    try:
        p = _direct_pm_path()
        if not p: return
        d = _direct_snapshot()
        d["ts"] = int(time.time() * 1000)
        _atomic_json_write(p, d)
    except Exception:
        pass

def _direct_premortem_read_and_clear():
    try:
        p = _direct_pm_path()
        if not p: return None
        _rp = _rc_take_path(p)
        if not _rp: return None
        try:
            with open(_rp, "r", encoding="utf-8") as f:
                d = json.load(f)
        finally:
            try: os.remove(_rp)
            except Exception: pass
        return d
    except Exception:
        return None

def _oom_sentinel_to_rec(s, merge_direct=False, direct_snap=None):
    src = {0: "cgroup", 1: "rss", 2: "none", 3: "meminfo"}.get(s["src_code"], "native")
    used = s["used"]; limit = s["limit"]
    pct = (float(used) / float(limit)) if (limit and limit > 0 and used >= 0) else -1.0
    ju, jm, nh = (-1, -1, -1)
    try: ju, jm, nh = _java_mem()
    except Exception: pass
    m = {"used": used, "limit": limit, "src": src, "pct": pct,
         "java_used": ju, "java_max": jm, "native_heap": nh,
         "rss": s["rss"], "cg_cur": s["cg_cur"], "cg_max": s["cg_max"],
         "cd_total": s["cd_total"]}
    top = []
    for idx, b in s["tops"]:
        nm = _resolve_idx(idx) or ("idx%d" % idx)
        top.append([nm, int(b)])
    if s["untagged"] > 0:
        top.append([_UNTAGGED_LABEL, int(s["untagged"])])
    direct_fields = {}
    _ds = direct_snap if direct_snap is not None else (_direct_snapshot() if merge_direct else None)
    if _ds is not None:
        _premortem = direct_snap is not None
        try:
            _by = _ds.get("live_by_pid") or {}; _unt = int(_ds.get("live_untagged", 0) or 0)
            _combined = {}
            for _nm, _b in top:
                _combined[_nm] = _combined.get(_nm, 0) + int(_b)
            for _pid, _b in _by.items():
                _combined[_pid] = _combined.get(_pid, 0) + int(_b)
            if _unt > 0:
                _combined[_UNTAGGED_LABEL] = _combined.get(_UNTAGGED_LABEL, 0) + _unt
            top = [[_k, _v] for _k, _v in _combined.items()]
            direct_fields = {
                "direct_total": int(_ds.get("total", 0) or 0), "direct_untagged": int(_ds.get("untagged", 0) or 0),
                "direct_live_total": int(_ds.get("live_total", 0) or 0), "direct_live_untagged": int(_ds.get("live_untagged", 0) or 0),
                "direct_merged": ("premortem-live" if _premortem else "live"),
            }
        except Exception:
            direct_fields = {}
    top.sort(key=lambda kv: kv[1], reverse=True)
    top = top[:_OOM_TOPN]
    rbits = s["reason_bits"]; hit = []
    if rbits & 1: hit.append("pct>=%d%%" % int(_OOM_PCT*100))
    if rbits & 2: hit.append("rate>=%dMB/s" % int(_OOM_RATE_MBPS))
    if rbits & 4: hit.append("ambient(device)")
    rec = {"had_oom": True, "reason": "+".join(hit) or "native", "ts": s["ts_ms"],
           "mem": m, "rate_mbps": round(s["rate_mbps"], 2),
           "thr_pct": _OOM_PCT, "thr_rate_mbps": _OOM_RATE_MBPS,
           "top": top, "native_total": s["cd_total"], "native_live": s["live_count"],
           "dropped": s["dropped"], "dropped_bytes": s["dropped_bytes"], "src": "native"}
    if direct_fields: rec.update(direct_fields)
    try:
        _g = _oom_gref_top()
        if _g: rec["gref"] = _g
    except Exception: pass
    try: rec["verdict"] = _oom_verdict(rec)
    except Exception: pass
    try:
        if rbits & 4:
            rec["event_type"] = "device_mem_pressure"; rec["dropbox_tag"] = "device_mem_pressure"
            rec["ambient"] = True; rec["scope"] = "device"
            rec["process_scoped"] = False; rec["oom_evidence"] = "device_meminfo_fallback"
        else:
            rec["event_type"] = "client_oom_leak"; rec["dropbox_tag"] = "client_oom_leak"
            rec["ambient"] = False; rec["scope"] = "process"; rec["process_scoped"] = True
        rec["tombstone_norm_version"] = 1
    except Exception: pass
    return rec

def _oom_consume_native(where, do_log=True):
    p = _oom_sentinel_path()
    if not p: return None
    blob = None
    _rp = _rc_take_path(p)
    if not _rp: return None
    try:
        with open(_rp, "rb") as f:
            blob = f.read()
    except Exception:
        blob = None
    try:
        if os.path.exists(_rp): os.remove(_rp)
    except Exception:
        pass
    if not blob: return None
    s = _oom_decode_sentinel(blob)
    if not s: return None
    if where in ("live", "settings"):
        rec = _oom_sentinel_to_rec(s, merge_direct=True)
    elif where == "boot":
        _pm = _direct_premortem_read_and_clear()
        if _pm is not None:
            try:
                if abs(int(_pm.get("ts", 0)) - int(s.get("ts_ms", 0))) > 120000: _pm = None
            except Exception: pass
        rec = _oom_sentinel_to_rec(s, direct_snap=_pm)
    else:
        rec = _oom_sentinel_to_rec(s)
    try: _oom_persist(rec)
    except Exception: pass
    if do_log:
        try: _oom_log_dump(rec)
        except Exception: pass
    return rec

def _oom_consume_loop(stop_evt):
    last_seq = 0
    try:
        if _OOM_NATIVE_OK and _NLIB is not None:
            last_seq = int(_NLIB.cd_oom_seq())
    except Exception:
        last_seq = 0
    while not stop_evt.is_set():
        stop_evt.wait(_OOM_POLL_S)
        if stop_evt.is_set(): break
        _gil_begin(_GIL_B6)
        try:
            _oom_check_java_heap()
        except Exception: pass
        try:
            _oom_check_killcount("live")
        except Exception: pass
        try:
            _leak_check("live")
        except Exception: pass
        _gil_end(_GIL_B6)
        try:
            if not (_OOM_NATIVE_OK and _NLIB is not None): continue
            seq = int(_NLIB.cd_oom_seq())
            if seq != last_seq:
                last_seq = seq
                _oom_consume_native("live", do_log=True)
        except Exception as e:
            try: _log(f"Block#6 consume err: {e}")
            except Exception: pass

_OOM_CLIENT_KILL_STATE = {"last_jheap_ts": 0.0, "trim_proxy": None}

def _proc_oom_score():
    adj = None; score = None
    try:
        with open("/proc/self/oom_score_adj", "r") as f:
            adj = int(f.read().strip())
    except Exception:
        adj = None
    try:
        with open("/proc/self/oom_score", "r") as f:
            score = int(f.read().strip())
    except Exception:
        score = None
    return adj, score

def _oom_killcount_now():
    try:
        if _OOM_NATIVE_OK and _NLIB is not None and hasattr(_NLIB, "cd_oom_killcount"):
            v = int(_NLIB.cd_oom_killcount())
            return v if v >= 0 else None
    except Exception:
        pass
    return None

def _oom_killcount_read_stored():
    try:
        p = _oom_path(_OOM_KILLCOUNT_FILE)
        if p and os.path.exists(p):
            with open(p, "r", encoding="utf-8") as f:
                return int(json.load(f).get("count", -1))
    except Exception:
        pass
    return None

def _oom_killcount_store(n):
    try:
        p = _oom_path(_OOM_KILLCOUNT_FILE)
        if p: _atomic_json_write(p, {"count": int(n), "ts": int(time.time())})
    except Exception:
        pass

def _client_kill_verdict(prev, cur, where):
    try:
        adj, score = _proc_oom_score()
        ju, jm, nh = _java_mem()
        rec = {
            "event_type": "client_oom_killed", "dropbox_tag": "client_oom_killed", "tombstone_norm_version": 1,
            "had_oom": True, "had_client_oom": True, "ts": int(time.time()),
            "culprit": "клиент (хост-процесс)", "culprit_kind": "host", "confidence": "high",
            "reason": "ядро/LMK убило процесс по нехватке памяти (oom_kill %d→%d)" % (prev, cur),
            "where": where,
            "kill_prev": int(prev), "kill_cur": int(cur), "kill_delta": int(cur - prev),
            "oom_score_adj": adj, "oom_score": score,
            "java_used": ju, "java_max": jm, "native_heap": nh,
        }
        p = _oom_path(_OOM_CLIENT_KILL_NAME)
        if p: _atomic_json_write(p, rec)
        _log("================ CLIENT OOM-KILL ================")
        _log("CLIENT OOM-KILL: where=%s oom_kill %d->%d (delta=%d) oom_score_adj=%s oom_score=%s java=%s/%s" % (
            where, prev, cur, cur - prev, adj, score, ju, jm))
        _log("=================================================")
    except Exception as e:
        try: _log("Block#6A client-kill verdict err: %s" % e)
        except Exception: pass

def _oom_check_killcount(where):
    cur = _oom_killcount_now()
    if cur is None: return
    prev = _oom_killcount_read_stored()
    if prev is not None and cur > prev:
        _client_kill_verdict(prev, cur, where + ": cgroup oom_kill")
    if prev is None or cur != prev:
        _oom_killcount_store(cur)

def _client_lowmem_note(source, level, detail):
    try:
        adj, score = _proc_oom_score()
        ju, jm, nh = _java_mem()
        rec = {
            "event_type": "client_mem_pressure", "dropbox_tag": "client_mem_pressure", "tombstone_norm_version": 1,
            "had_client_lowmem": True, "ts": int(time.time()),
            "culprit": "клиент (хост-процесс)", "culprit_kind": "host", "confidence": "medium",
            "reason": detail, "where": source, "trim_level": level,
            "oom_score_adj": adj, "oom_score": score,
            "java_used": ju, "java_max": jm, "native_heap": nh,
        }
        p = _oom_path(_OOM_TRIM_NAME)
        if p: _atomic_json_write(p, rec)
        _log("CLIENT LOW-MEM: src=%s level=%s java=%s/%s oom_score=%s :: %s" % (
            source, level, ju, jm, score, detail))
    except Exception as e:
        try: _log("Block#6BC lowmem note err: %s" % e)
        except Exception: pass

def _oom_check_java_heap():
    try:
        now = time.time()
        if (now - _OOM_CLIENT_KILL_STATE.get("last_jheap_ts", 0.0)) < _OOM_JHEAP_COOLDOWN_S:
            return
        ju, jm, nh = _java_mem()
        if ju > 0 and jm > 0 and (float(ju) / float(jm)) >= _OOM_JHEAP_PCT:
            _OOM_CLIENT_KILL_STATE["last_jheap_ts"] = now
            frac = float(ju) / float(jm)
            _client_lowmem_note("ART/Java-heap", "java_heap",
                "Java-куча у предела: %.0f%% (%d/%d МБ) — близко к OutOfMemoryError" % (
                    frac * 100.0, ju // 1048576, jm // 1048576))
    except Exception:
        pass

def _b6_register_trim_callbacks():
    try:
        ctx = _app_context()
        if ctx is None:
            _log("Block#6C: app context unavailable — trim callbacks disabled")
            return None
        from java import dynamic_proxy
        CB2 = _jc("android.content.ComponentCallbacks2")
        class _TrimCB(dynamic_proxy(CB2)):
            def onTrimMemory(self, level):
                try:
                    lv = int(level)
                    if lv >= 15:
                        _client_lowmem_note("onTrimMemory", lv,
                            "система просит освободить память (onTrimMemory level=%d)" % lv)
                except Exception:
                    pass
            def onLowMemory(self):
                try:
                    _client_lowmem_note("onLowMemory", "low",
                        "система сообщила о критической нехватке памяти (onLowMemory)")
                except Exception:
                    pass
            def onConfigurationChanged(self, cfg):
                pass
        proxy = _TrimCB()
        ctx.registerComponentCallbacks(proxy)
        _OOM_CLIENT_KILL_STATE["trim_proxy"] = proxy
        _log("Block#6C: ComponentCallbacks2 зарегистрирован (onTrimMemory/onLowMemory)")
        return proxy
    except Exception as e:
        try: _log("Block#6C trim register err: %s" % e)
        except Exception: pass
        return None

def _b6_unregister_trim_callbacks():
    try:
        proxy = _OOM_CLIENT_KILL_STATE.get("trim_proxy")
        if proxy is not None:
            ctx = _app_context()
            if ctx is not None:
                ctx.unregisterComponentCallbacks(proxy)
            _OOM_CLIENT_KILL_STATE["trim_proxy"] = None
            _log("Block#6C: ComponentCallbacks2 снят")
    except Exception as e:
        try: _log("Block#6C trim unregister err: %s" % e)
        except Exception: pass

_LEAK_NAME = "client_leak.json"
_NA_NAME = "native_alloc_sites.json"
_NA_SAMPLE_ENABLE = True
_NA_SAMPLE_DIV = 1
_NA_MIN_BYTES = 8192
_NA_NATIVE_OK = False
_LEAK_NATIVE_OK = False
_LEAK_DIM_KEYS = ("rss", "java", "native", "fd", "threads")
_LEAK_DIM_NAMES = {"rss": "RSS", "java": "Java-heap", "native": "native-heap",
                   "fd": "descriptors (fd)", "threads": "threads"}
_LEAK_BYTE_DIMS = ("rss", "java", "native")
_LEAK_SNAP_HEAD = 3
_LEAK_SNAP_PER = 7
_LEAK_STATE = {"last_seq": 0}
_LEAK_SEG_KEYS = ("summary.java-heap", "summary.native-heap", "summary.graphics",
                  "summary.stack", "summary.code", "summary.system",
                  "summary.total-pss", "summary.total-swap")
_LEAK_SEG_LABELS = {"summary.java-heap": "java-heap", "summary.native-heap": "native-heap",
                    "summary.graphics": "graphics", "summary.stack": "stack",
                    "summary.code": "code", "summary.system": "system",
                    "summary.total-pss": "total-pss", "summary.total-swap": "total-swap"}
_LEAK_SEG_TOP_SKIP = ("total-pss", "total-swap")
_LEAK_SEG_RING = []
_LEAK_SEG_MIN_GAP_MS = 25000
_LEAK_SEG_RING_MAX = 160

def _leak_seg_read(g=None, roll=None):
    try:
        if g is None:
            g = _smaps_scan_native()
        if not g:
            return None
        def _p(name):
            v = g.get(name)
            return int(v["pss"]) if v else 0
        java_heap = _p("dalvik-heap")
        native_heap = _p("native-malloc")
        graphics = _p("gfx-gpu") + _p("gfx-dmabuf")
        stack = _p("thread-stack")
        code = _p("code-so") + _p("code-dex-oat-art") + _p("code-apk")
        if roll is None:
            roll = _smaps_rollup_native()
        total_pss = int(roll["pss"]) if roll else sum(int(v["pss"]) for v in g.values())
        total_swap = int(roll["swap"]) if roll else sum(int(v["swap"]) for v in g.values())
        system = total_pss - (java_heap + native_heap + graphics + stack + code)
        if system < 0: system = 0
        return {"summary.java-heap": java_heap, "summary.native-heap": native_heap,
                "summary.graphics": graphics, "summary.stack": stack,
                "summary.code": code, "summary.system": system,
                "summary.total-pss": total_pss, "summary.total-swap": total_swap}
    except Exception:
        return None

def _leak_seg_sample():
    try:
        now = int(time.time() * 1000)
        if _LEAK_SEG_RING and (now - _LEAK_SEG_RING[-1][0]) < _LEAK_SEG_MIN_GAP_MS:
            return
        segs = _leak_seg_read()
        if not segs:
            return
        _LEAK_SEG_RING.append((now, segs))
        if len(_LEAK_SEG_RING) > _LEAK_SEG_RING_MAX:
            del _LEAK_SEG_RING[:len(_LEAK_SEG_RING) - _LEAK_SEG_RING_MAX]
    except Exception:
        pass

def _leak_seg_delta(span_s):
    try:
        if len(_LEAK_SEG_RING) < 2:
            return None
        now, cur = _LEAK_SEG_RING[-1][0], _LEAK_SEG_RING[-1][1]
        target = now - int(float(span_s or 0) * 1000)
        base_t, base = _LEAK_SEG_RING[0][0], _LEAK_SEG_RING[0][1]
        for t, segs in _LEAK_SEG_RING:
            if t <= target:
                base_t, base = t, segs
            else:
                break
        out = {"baseline_age_ms": now - base_t, "n_samples": len(_LEAK_SEG_RING),
               "span_s": (now - base_t) / 1000.0, "segments": {}}
        best_name, best_growth = None, None
        for k in _LEAK_SEG_KEYS:
            f, l = base.get(k), cur.get(k)
            if f is None or l is None:
                continue
            lbl = _LEAK_SEG_LABELS.get(k, k)
            g = l - f
            out["segments"][lbl] = {"first": f, "last": l, "growth": g}
            if lbl not in _LEAK_SEG_TOP_SKIP and (best_growth is None or g > best_growth):
                best_name, best_growth = lbl, g
        if best_name is not None:
            out["top"] = {"segment": best_name, "growth": best_growth}
        return out if out["segments"] else None
    except Exception:
        return None

def _leak_feed_java():
    try:
        if not (_LEAK_NATIVE_OK and _NLIB is not None):
            return
        ju, jm, _nh = _java_mem()
        if ju is None:
            return
        _NLIB.cd_leak_feed_java(ctypes.c_int64(int(ju)),
                                ctypes.c_int64(int(jm) if jm else -1))
    except Exception:
        pass

def _leak_read_native_snap():
    try:
        if not (_LEAK_NATIVE_OK and _NLIB is not None):
            return None
        n = int(_NLIB.cd_leak_slots())
        if n <= 0 or n > 4096:
            return None
        arr = (ctypes.c_int64 * n)()
        got = int(_NLIB.cd_leak_read(arr, ctypes.c_int32(n)))
        if got < _LEAK_SNAP_HEAD:
            return None
        vals = [int(arr[i]) for i in range(got)]
        ts_ms, flags, dimn = vals[0], vals[1], vals[2]
        dims = []
        for d in range(dimn):
            base = _LEAK_SNAP_HEAD + d * _LEAK_SNAP_PER
            if base + _LEAK_SNAP_PER > got:
                break
            key = _LEAK_DIM_KEYS[d] if d < len(_LEAK_DIM_KEYS) else ("dim%d" % d)
            dims.append({"dim": key, "leaking": bool(flags & (1 << d)),
                         "first": vals[base + 0], "last": vals[base + 1],
                         "slope_per_s": vals[base + 2] / 1000.0,
                         "r2": vals[base + 3] / 1000.0,
                         "growth": vals[base + 4], "n": vals[base + 5],
                         "span_s": vals[base + 6] / 1000.0})
        return {"ts_ms": ts_ms, "flags": flags, "dims": dims}
    except Exception as e:
        try: _log("Block#6D snap read err: %s" % e)
        except Exception: pass
        return None

def _leak_fmt_amount(dim, v):
    try:
        if dim in _LEAK_BYTE_DIMS:
            return "%.1f MB" % (float(v) / (1024.0 * 1024.0))
        return str(int(v))
    except Exception:
        return str(v)

def _leak_mem_snapshot():
    snap = {}
    try:
        g = _smaps_scan_native()
        if g:
            def _p(name):
                v = g.get(name)
                return int(v["pss"]) if v else 0
            roll = _smaps_rollup_native()
            dalvik = _p("dalvik-heap")
            native = _p("native-malloc")
            total = int(roll["pss"]) if roll else sum(int(v["pss"]) for v in g.values())
            other = total - dalvik - native
            if other < 0: other = 0
            snap["pss"] = {"dalvik": dalvik, "native": native, "other": other, "total": total}
            seg = _leak_seg_read(g, roll)
            if seg: snap["memstat"] = seg
    except Exception: pass
    try:
        kinds = {}
        base = "/proc/self/fd"
        for name in os.listdir(base):
            try: tgt = os.readlink(os.path.join(base, name))
            except Exception: tgt = ""
            if tgt.startswith("socket:"): kk = "socket"
            elif tgt.startswith("pipe:"): kk = "pipe"
            elif tgt.startswith("anon_inode:"): kk = "anon_inode"
            elif tgt.startswith("/"): kk = "file"
            else: kk = "other"
            kinds[kk] = kinds.get(kk, 0) + 1
        if kinds: snap["fd_by_kind"] = kinds
    except Exception: pass
    return snap

_LEAK_PEAK_NAME = "client_leak_peak.json"
_LEAK_PEAK_MIN_GAP_MS = 60000
_LEAK_PEAK_STATE = {"last_ms": 0}
_SMAPS_NATIVE_GROUPS = ("native-malloc", "gfx-gpu", "gfx-dmabuf", "shmem-ashmem",
                        "code-so", "code-dex-oat-art", "code-apk", "fonts",
                        "dalvik-heap", "thread-stack", "file-other", "anon-other",
                        "anon-private")
_SMAPS_NATIVE_FIELDS = 4

def _smaps_scan_native():
    try:
        if not (_SMAPS_NATIVE_OK and _NLIB is not None):
            return None
        n = len(_SMAPS_NATIVE_GROUPS) * _SMAPS_NATIVE_FIELDS
        arr = (ctypes.c_int64 * n)()
        got = int(_NLIB.cd_smaps_groups(arr, ctypes.c_int32(n)))
        if got < n:
            return None
        out = {}
        for i, name in enumerate(_SMAPS_NATIVE_GROUPS):
            b = i * _SMAPS_NATIVE_FIELDS
            out[name] = {"rss": int(arr[b + 0]), "pss": int(arr[b + 1]),
                         "swap": int(arr[b + 2]), "n": int(arr[b + 3])}
        return out
    except Exception:
        return None

def _smaps_rollup_native():
    try:
        if not (_SMAPS_NATIVE_OK and _NLIB is not None):
            return None
        arr = (ctypes.c_int64 * 3)()
        got = int(_NLIB.cd_smaps_rollup(arr, ctypes.c_int32(3)))
        if got < 3:
            return None
        return {"pss": int(arr[0]), "rss": int(arr[1]), "swap": int(arr[2])}
    except Exception:
        return None

def _smaps_top_groups(limit=14):
    g = _smaps_scan_native()
    if not g:
        return None
    items = [(k, v) for k, v in g.items() if (v["rss"] or v["pss"] or v["swap"] or v["n"])]
    if not items:
        return None
    items.sort(key=lambda kv: kv[1].get("pss", 0), reverse=True)
    return [{"group": k, "rss": v["rss"], "pss": v["pss"], "swap": v["swap"], "maps": v["n"]}
            for k, v in items[:limit]]

def _smaps_rollup_text():
    try:
        with open("/proc/self/smaps_rollup", "r") as f:
            return f.read()[:4096]
    except Exception:
        return None

def _leak_fd_detail():
    out = {"by_kind": {}, "by_target": {}}
    try:
        base = "/proc/self/fd"
        for name in os.listdir(base):
            try: tgt = os.readlink(os.path.join(base, name))
            except Exception: tgt = ""
            if tgt.startswith("socket:"): kk = "socket"
            elif tgt.startswith("pipe:"): kk = "pipe"
            elif tgt.startswith("anon_inode:"): kk = "anon_inode"
            elif tgt.startswith("/"): kk = "file"
            else: kk = "other"
            out["by_kind"][kk] = out["by_kind"].get(kk, 0) + 1
            if tgt.startswith("anon_inode:"):
                tb = "anon_inode:" + tgt[11:].strip("[]").split(":")[0][:24]
            elif tgt.startswith("/dev/"):
                tb = "/dev/" + tgt[5:].split("/")[0]
            elif tgt.startswith("/"):
                dot = tgt.rfind(".")
                tb = ("ext:" + tgt[dot:][:8]) if dot > tgt.rfind("/") else "file-other"
            elif tgt.startswith("socket:") or tgt.startswith("pipe:"):
                tb = kk
            else:
                tb = "other"
            out["by_target"][tb] = out["by_target"].get(tb, 0) + 1
    except Exception:
        pass
    try:
        tt = sorted(out["by_target"].items(), key=lambda kv: kv[1], reverse=True)[:15]
        out["by_target"] = dict(tt)
    except Exception:
        pass
    return out

def _dumpsys_meminfo_text():
    proc = None; rdr = None
    try:
        pid = os.getpid()
        Runtime = jclass("java.lang.Runtime")
        proc = Runtime.getRuntime().exec(["sh", "-c", "dumpsys meminfo %d 2>&1" % pid])
        ins = proc.getInputStream()
        rdr = jclass("java.io.BufferedReader")(jclass("java.io.InputStreamReader")(ins))
        sb = []; n = 0
        while n < 400:
            ln = rdr.readLine()
            if ln is None: break
            sb.append(str(ln)); n += 1
        txt = "\n".join(sb)
        return txt[:8192] if txt.strip() else None
    except Exception:
        return None
    finally:
        if rdr is not None:
            try: rdr.close()
            except Exception: pass
        if proc is not None:
            try: proc.getOutputStream().close()
            except Exception: pass
            try: proc.getErrorStream().close()
            except Exception: pass
            try: proc.destroy()
            except Exception: pass

def _leak_peak_capture(where, rec):
    try:
        now = int(time.time() * 1000)
        if (now - _LEAK_PEAK_STATE.get("last_ms", 0)) < _LEAK_PEAK_MIN_GAP_MS:
            return
        _LEAK_PEAK_STATE["last_ms"] = now
        cap = {"type": "client_leak_peak", "ts": now, "where": where,
               "leaking_dims": rec.get("leaking_dims"),
               "confidence": rec.get("confidence"),
               "rss_top_segment": rec.get("rss_top_segment"),
               "meminfo": _leak_mem_snapshot(),
               "smaps_rollup": _smaps_rollup_text(),
               "smaps_top_groups": _smaps_top_groups(),
               "fd_detail": _leak_fd_detail(),
               "dumpsys_meminfo": _dumpsys_meminfo_text()}
        p = _oom_path(_LEAK_PEAK_NAME)
        if p: _atomic_json_write(p, cap)
        try:
            tg = cap.get("smaps_top_groups") or []
            top = ", ".join("%s=%.1fMB" % (g["group"], g["pss"] / 1048576.0) for g in tg[:5])
            _log("Block#6D peak-capture -> %s | top smaps: %s" % (_LEAK_PEAK_NAME, top))
        except Exception:
            pass
    except Exception as e:
        try: _log("Block#6D peak-capture err: %s" % e)
        except Exception: pass

_NA_CLIENT_LIBS = ("libtmessages", "libetgadblock", "libculprit", "libvosk", "libmaps-mobile", "libimage_processing_util_jni", "liblanguage_id_l2c_jni", "libsurface_util_jni", "libjnidispatch", "libshadowhook", "libdatastore_shared_counter", "libchaquopy", "libpython", "libsqlite3_chaquopy", "libsqlite3_python", "libcrypto_chaquopy", "libcrypto_python", "libssl_chaquopy", "libssl_python")
_NA_GFX_LIBS = ("vulkan", "adreno", "libgsl", "libllvm-glnext", "libEGL", "libGLES", "libvulkan", "libVK", "mali", "libgpu", "powervr", "libhwui", "libskia", "libgui", "librenderengine", "libnativewindow", "libjnigraphics")

def _na_frame_cat(fr):
    try:
        m = fr.split("+", 1)[0]
    except Exception:
        return None
    for pfx in _NA_CLIENT_LIBS:
        if m.startswith(pfx):
            return "app"
    for pfx in _NA_GFX_LIBS:
        if m.startswith(pfx):
            return "gfx"
    return None

_NA_OTHER_TOPN = 40

def _na_filter_client(path):
    try:
        with open(path, "r", encoding="utf-8") as _f:
            d = json.load(_f)
        sites = d.get("sites")
        if not isinstance(sites, list):
            return None
        kept = []; other = []
        for s in sites:
            frames = s.get("frames") or []
            cat = None
            for fr in frames:
                c = _na_frame_cat(fr)
                if c == "app":
                    cat = "app"; break
                if c == "gfx" and cat is None:
                    cat = "gfx"
            if cat:
                s["bucket"] = cat
                kept.append(s)
            else:
                other.append(s)
        def _rb(x):
            try: return int(x.get("retained_bytes") or 0)
            except Exception: return 0
        try:
            kept.sort(key=_rb, reverse=True)
            for _i, _s in enumerate(kept): _s["rank"] = _i + 1
        except Exception: pass
        try:
            other.sort(key=_rb, reverse=True)
            for _i, _s in enumerate(other): _s["rank"] = _i + 1
        except Exception: pass
        kept_bytes = 0
        for _s in kept: kept_bytes += _rb(_s)
        other_bytes = 0
        for _s in other: other_bytes += _rb(_s)
        other_n = len(other)
        other_top = other[:_NA_OTHER_TOPN]
        d["sites"] = kept
        d["other_sites"] = other_top
        _app_n = 0; _gfx_n = 0
        for _s in kept:
            if _s.get("bucket") == "gfx": _gfx_n += 1
            else: _app_n += 1
        d["filtered"] = {"mode": "client_plugin_focused", "kept_sites": len(kept), "kept_app_sites": _app_n, "kept_gfx_sites": _gfx_n, "kept_retained_bytes": kept_bytes, "other_sites": other_n, "other_retained_bytes": other_bytes, "other_sites_listed": len(other_top)}
        _atomic_json_write(path, d)
        return (len(kept), kept_bytes, other_n, other_bytes)
    except Exception as e:
        try: _log("Block#3S na filter err: %s" % e)
        except Exception: pass
        return None

def _na_dump(where):
    try:
        if not (_NA_NATIVE_OK and _NLIB is not None and hasattr(_NLIB, "cd_na_dump")):
            return
        try:
            if not int(_NLIB.cd_na_is_on()):
                return
        except Exception:
            return
        p = _oom_path(_NA_NAME)
        if not p:
            return
        n = int(_NLIB.cd_na_dump(p.encode("utf-8")))
        _flt = _na_filter_client(p)
        try:
            _log("Block#3S native alloc-sites -> %s | live_sampled=%d uniq=%d sampled=%d full_drops=%d" % (
                _NA_NAME, n, int(_NLIB.cd_na_unique()), int(_NLIB.cd_na_sampled_count()), int(_NLIB.cd_na_full_drops())))
        except Exception:
            pass
        if _flt is not None:
            try:
                _log("Block#3S site split: client/plugin=%d (%.2fMB), other/system=%d (%.2fMB) [retained in other_sites]" % (
                    _flt[0], _flt[1] / 1048576.0, _flt[2], _flt[3] / 1048576.0))
            except Exception:
                pass
    except Exception as e:
        try: _log("Block#3S na dump err: %s" % e)
        except Exception: pass

def _leak_emit(decoded, where):
    try:
        dims = decoded.get("dims", [])
        leaking = [d for d in dims if d.get("leaking")]
        if not leaking:
            return
        try: adj, score = _proc_oom_score()
        except Exception: adj, score = None, None
        rss_r2 = max([d["r2"] for d in leaking if d["dim"] == "rss"] or [0.0])
        conf = "high" if rss_r2 >= 0.90 else "medium"
        _gref_attr = None
        try:
            _lk = [d.get("dim") for d in leaking]
            if any(x in ("native", "rss") for x in _lk):
                _g = _oom_gref_top()
                if _g:
                    _gc = int(_g.get("count") or 0); _gt = int(_g.get("total") or 0)
                    _gu = int(_g.get("untagged") or 0); _gnm = _gt - _gu
                    _gsh = (float(_gc) / float(_gnm)) if _gnm > 0 else ((float(_gc) / float(_gt)) if _gt > 0 else 0.0)
                    if _g.get("culprit") and _gc >= _B28C_MIN and _gsh >= _B28C_DOMINANCE:
                        _gref_attr = {"culprit": _g.get("culprit"), "count": _gc,
                                      "total": _gt, "share": round(_gsh, 4),
                                      "untagged": int(_g.get("untagged") or 0)}
        except Exception:
            _gref_attr = None
        if _gref_attr:
            try: _log("Block#6D/A: client leak attributed to native global-ref CREATION/churn (not a confirmed leak; DeleteGlobalRef untracked) -> %s (%d/%d gref, %.0f%%)" % (
                _gref_attr["culprit"], _gref_attr["count"], _gref_attr["total"], _gref_attr["share"] * 100.0))
            except Exception: pass
        rec = {"type": "client_memory_leak",
               "event_type": "client_memory_leak", "dropbox_tag": "client_memory_leak", "tombstone_norm_version": 1,
               "verdict": "CLIENT MEMORY LEAK",
               "where": where,
               "ts": int(time.time() * 1000),
               "confidence": conf,
               "culprit": (_gref_attr["culprit"] if _gref_attr else "client (host process)"),
               "kind": ("plugin-globalref" if _gref_attr else "host"),
               "gref_attribution": _gref_attr,
               "reason_detail": ("globalref_native" if _gref_attr else "host_unattributed"),
               "oom_score_adj": adj, "oom_score": score,
               "dims": dims,
               "leaking_dims": [d["dim"] for d in leaking],
               "mem_snapshot": _leak_mem_snapshot()}
        try:
            _rss_span = max([float(d.get("span_s") or 0) for d in dims] or [0.0])
            _seg = _leak_seg_delta(_rss_span)
            if _seg:
                rec["rss_segments"] = _seg
                if _seg.get("top"): rec["rss_top_segment"] = _seg["top"]
                _order = sorted(_seg.get("segments", {}).items(),
                                key=lambda kv: kv[1].get("growth", 0), reverse=True)
                _slines = ["  RSS segment deltas (window ~%.0fs):" % _seg.get("span_s", 0)]
                for _nm, _v in _order:
                    _slines.append("    %-12s %+.1f MB (%.1f -> %.1f MB)" % (
                        _nm, _v.get("growth", 0) / 1048576.0,
                        _v.get("first", 0) / 1048576.0, _v.get("last", 0) / 1048576.0))
                try: _log("\n".join(_slines))
                except Exception: pass
        except Exception: pass
        lines = ["CLIENT MEMORY LEAK (%s) conf=%s" % (where, conf)]
        for d in dims:
            mark = "LEAK" if d.get("leaking") else "  - "
            nm = _LEAK_DIM_NAMES.get(d["dim"], d["dim"])
            lines.append("  [%s] %-16s %s -> %s growth=%s slope=%.4g/s r2=%.2f n=%d span=%.0fs" % (
                mark, nm, _leak_fmt_amount(d["dim"], d["first"]),
                _leak_fmt_amount(d["dim"], d["last"]),
                _leak_fmt_amount(d["dim"], d["growth"]),
                d["slope_per_s"], d["r2"], d["n"], d["span_s"]))
        try: _log("\n".join(lines))
        except Exception: pass
        p = _oom_path(_LEAK_NAME)
        if p: _atomic_json_write(p, rec, 65536)
        try: _leak_peak_capture(where, rec)
        except Exception: pass
        try: _na_dump(where)
        except Exception: pass
    except Exception as e:
        try: _log("Block#6D leak emit err: %s" % e)
        except Exception: pass

def _leak_check(where):
    try:
        if not (_LEAK_NATIVE_OK and _NLIB is not None):
            return
        _leak_feed_java()
        _leak_seg_sample()
        seq = int(_NLIB.cd_leak_seq())
        if seq == _LEAK_STATE.get("last_seq", 0):
            return
        _LEAK_STATE["last_seq"] = seq
        decoded = _leak_read_native_snap()
        if decoded and decoded.get("flags"):
            _leak_emit(decoded, where)
    except Exception as e:
        try: _log("Block#6D leak check err: %s" % e)
        except Exception: pass

def _read_and_clear_crash_verdict():
    p = _crash_path()
    if not p: return None
    rec = None
    _rp = _rc_take_path(p)
    try:
        if _rp:
            with open(_rp, "r", encoding="utf-8") as f:
                rec = json.load(f)
    except Exception:
        rec = None
    if _rp:
        try: os.remove(_rp)
        except Exception: pass
    return rec

_BLOCK4A_ON = True
_BLOCK4B_ON = True
_XPOSED_BRIDGE_CLASSES = (
    "de.robv.android.xposed.XposedBridge",
    "com.taobao.android.dexposed.DexposedBridge",
)
_HOOK_FRAMEWORK_PROBES = [
    ("de.robv.android.xposed.XposedBridge", "sHookedMethodCallbacks"),
    ("com.taobao.android.dexposed.DexposedBridge", "sHookedMethodCallbacks"),
    ("top.canyie.pine.Pine", "sHookListeners"),
    ("top.canyie.pine.PineConfig", None),
    ("me.weishu.epic.art.Epic", None),
    ("com.swift.sandhook.SandHook", None),
    ("org.lsposed.lsplant.LSPlant", None),
    ("org.lsposed.lspd.core.Main", None),
    ("io.github.libxposed.api.XposedInterface", None),
    ("lab.galaxy.yahfa.HookMain", None),
    ("com.exteragram.messenger.plugins.PythonPluginsEngine", None),
]

def _class_obj(cn):
    try:
        return jclass("java.lang.Class").forName(cn)
    except Exception:
        return None

def _probe_hook_frameworks():
    found = []
    for cn, fld in _HOOK_FRAMEWORK_PROBES:
        cls = _class_obj(cn)
        if cls is None:
            continue
        info = cn
        if fld:
            try:
                f = cls.getDeclaredField(fld); f.setAccessible(True); v = f.get(None)
                try: sz = v.size()
                except Exception:
                    try: sz = len(v)
                    except Exception: sz = "?"
                info += f" [{fld}={sz}]"
            except Exception as e:
                info += f" [{fld}:нет поля]"
        found.append(info)
    return found

def _safe_str(o):
    try: return str(o)
    except Exception:
        try: return o.toString()
        except Exception: return ""

def _plugin_classloaders():
    out = {}
    try:
        PC = jclass("com.exteragram.messenger.plugins.PluginsController")
        controller = PC.getInstance()
        plugins = controller.getPlugins() if controller is not None else None
        if plugins is None: return out
        for e in _entryset_snapshot(plugins):
            try:
                pid = _safe_str(e.getKey()); inst = e.getValue()
                cl = inst.getClass().getClassLoader() if inst is not None else None
                if cl is not None: out[_safe_str(cl)] = pid
            except Exception: pass
    except Exception: pass
    return out

def _entryset_snapshot(m):
    last = None
    for _ in range(4):
        try: return list(m.entrySet().toArray())
        except Exception as e: last = e
    try: _log("entrySet snapshot failed: %s" % last)
    except Exception: pass
    return []

def _xposed_field_value():
    for cn in _XPOSED_BRIDGE_CLASSES:
        try:
            cls = _class_obj(cn)
            if cls is None: continue
            f = cls.getDeclaredField("sHookedMethodCallbacks")
            f.setAccessible(True)
            v = f.get(None)
            if v is not None: return v, cn
        except Exception: continue
    return None, None

def _cb_array(callbacks):
    for getter in ("getSnapshot", "toArray"):
        try:
            a = getattr(callbacks, getter)()
            if a is not None: return a
        except Exception: pass
    return []

def _build_hook_owner_map():
    res = {}
    m, cn = _xposed_field_value()
    if m is None:
        st = "lsplant-no-jmap" if _class_obj("de.robv.android.xposed.XposedBridge") is not None else "no-xposed"
        return res, 0, st
    try:
        clmap = _plugin_classloaders(); known = _load_known()
        for e in _entryset_snapshot(m):
            try:
                member = e.getKey(); callbacks = e.getValue()
                dcl = member.getDeclaringClass().getName()
                try: mname = member.getName()
                except Exception: mname = "<init>"
                key = dcl + "." + mname
                owner = None
                for cb in _cb_array(callbacks):
                    try:
                        cl = cb.getClass().getClassLoader(); rep = _safe_str(cl)
                        if rep in clmap: owner = clmap[rep]; break
                        owner = _map_stack_to_id(rep, known) or _map_stack_to_id(cb.getClass().getName(), known)
                        if owner: break
                    except Exception: pass
                res[key] = owner
            except Exception: pass
    except Exception:
        return res, len(res), "err"
    return res, len(res), "ok"

def _hook_owner_for_frames(frames):
    if not _BLOCK4A_ON: return None, None, None, {"status": "off"}
    omap, n, status = _build_hook_owner_map()
    meta = {"n": n, "status": status}
    if not omap: return None, None, None, meta
    for fr in frames:
        if fr in omap and omap[fr]: return omap[fr], fr, "exact", meta
    simple = {}
    for k, v in omap.items():
        try:
            cls, mth = k.rsplit(".", 1); simple[(_simple(cls), mth)] = (v, k)
        except Exception: pass
    for fr in frames:
        try:
            cls, mth = fr.rsplit(".", 1); t = (_simple(cls), mth)
            if t in simple and simple[t][0]: return simple[t][0], simple[t][1], "simple", meta
        except Exception: pass
    by_method = {}
    for k, v in omap.items():
        if not v: continue
        try: mth = k.rsplit(".", 1)[1]
        except Exception: continue
        by_method.setdefault(mth, set()).add((v, k))
    for fr in frames:
        if not _is_hook_frame(fr): continue
        try: mth = fr.rsplit(".", 1)[1]
        except Exception: continue
        hits = by_method.get(mth)
        if hits and len(hits) == 1:
            v, k = next(iter(hits))
            return v, k, "hook-method", meta
    for fr in frames:
        if fr in omap: return None, fr, "method-only", meta
    return None, None, None, meta

def _plugin_loaders():
    out = []
    try:
        PC = jclass("com.exteragram.messenger.plugins.PluginsController")
        controller = PC.getInstance()
        plugins = controller.getPlugins() if controller is not None else None
        if plugins is None: return out
        for e in _entryset_snapshot(plugins):
            try:
                pid = _safe_str(e.getKey()); inst = e.getValue()
                cl = inst.getClass().getClassLoader() if inst is not None else None
                if cl is not None: out.append((cl, _safe_str(cl), pid))
            except Exception: pass
    except Exception: pass
    return out

def _classloader_culprit(frames):
    if not _BLOCK4B_ON: return None, None, {"status": "off"}
    loaders = _plugin_loaders()
    meta = {"n": len(loaders), "status": ("no-loaders" if not loaders else "ok")}
    if not loaders: return None, None, meta
    repr2pids = {}
    for (cl, rep, pid) in loaders:
        repr2pids.setdefault(rep, set()).add(pid)
    ambig = 0
    for fr in frames:
        cn = fr.rsplit(".", 1)[0] if "." in fr else fr
        if _is_system_class(cn): continue
        for (cl, rep, pid) in loaders:
            try:
                kls = cl.loadClass(cn)
            except Exception:
                continue
            try:
                drep = _safe_str(kls.getClassLoader())
            except Exception:
                drep = None
            if drep is None: continue
            pids = repr2pids.get(drep)
            if not pids: continue
            if len(pids) == 1:
                if ambig: meta["ambiguous"] = ambig
                return next(iter(pids)), fr, meta
            ambig += 1; break
    if ambig: meta["ambiguous"] = ambig
    return None, None, meta

def _b16_push_verdict(kind, rec):
    if not _B16_ON: return
    try:
        conf = rec.get("confidence")
        if conf not in ("high", "medium"): return
        e = {"kind": kind, "culprit": rec.get("culprit"), "confidence": conf,
             "where": rec.get("where"), "exc_cls": rec.get("exc_cls"),
             "exc_msg": rec.get("exc_msg"), "py_file": rec.get("py_file"),
             "py_line": rec.get("py_line"), "ts": rec.get("ts") or int(time.time() * 1000)}
        with _RECENT_VERDICTS_LOCK:
            _RECENT_VERDICTS.append(e)
            if len(_RECENT_VERDICTS) > _RECENT_MAX:
                del _RECENT_VERDICTS[:-_RECENT_MAX]
    except Exception:
        pass

def _b16_disk_candidates():
    out = []
    try:
        srcs = (("cb", _cb_verdict_path), ("bg", _bg_verdict_path), ("ui", _ui_verdict_path), ("fut", _fut_verdict_path), ("async", _async_verdict_path), ("pyerr", _pyerr_verdict_path))
    except Exception:
        srcs = ()
    for kind, pathfn in srcs:
        try:
            p = pathfn()
            _rp = _rc_read_path(p) if p else None
            if not _rp: continue
            with open(_rp, "r", encoding="utf-8") as f:
                arr = list(json.load(f))
            for r in arr[-12:]:
                try:
                    out.append({"kind": kind, "culprit": r.get("culprit"),
                                "confidence": r.get("confidence"), "where": r.get("where"),
                                "exc_cls": r.get("exc_cls"), "exc_msg": r.get("exc_msg"),
                                "py_file": r.get("py_file"), "py_line": r.get("py_line"),
                                "ts": r.get("ts")})
                except Exception: pass
        except Exception:
            pass
    return out

def _b16_exc_match(crash_exc_cls, crash_exc_msg, v_exc_cls, v_exc_msg):
    cm = str(crash_exc_msg or "")
    vm = str(v_exc_msg or "")
    vc = str(v_exc_cls or "")
    if vm and (vm == cm or vm in cm or cm.endswith(vm)):
        return True
    combo = ("%s: %s" % (vc, vm)) if vm else vc
    if combo and (combo == cm or combo in cm or cm.endswith(combo)):
        return True
    return False

def _b16_correlate(rec):
    try:
        if not _B16_ON or not isinstance(rec, dict): return rec
        crash_ts = rec.get("ts") or int(time.time() * 1000)
        cx = rec.get("exc_cls"); cm = rec.get("exc_msg")
        cands = []
        try:
            with _RECENT_VERDICTS_LOCK:
                cands = list(_RECENT_VERDICTS)
        except Exception:
            cands = []
        try:
            cands = cands + _b16_disk_candidates()
        except Exception:
            pass
        top_pid = None
        try:
            nm = rec.get("native_mem")
            if isinstance(nm, dict): top_pid = nm.get("top_pid")
        except Exception:
            top_pid = None
        try:
            frames = rec.get("stack_top") or []
        except Exception:
            frames = []
        best = None; best_ts = -1
        best_py = None; best_py_ts = -1
        for v in cands:
            try:
                if v.get("confidence") != "high": continue
                vts = v.get("ts")
                if vts is None: continue
                if abs(int(crash_ts) - int(vts)) > _B16_CORR_WINDOW_MS: continue
                if _b16_exc_match(cx, cm, v.get("exc_cls"), v.get("exc_msg")):
                    if int(vts) > best_ts:
                        best = v; best_ts = int(vts)
                elif v.get("kind") == "pyerr":
                    if int(vts) > best_py_ts:
                        best_py = v; best_py_ts = int(vts)
            except Exception:
                pass
        if best is None and best_py is not None:
            best = best_py; best_ts = best_py_ts
        if best is None:
            try:
                cms = str(cm or "")
                if "_chaquopyGetDict" in cms or "_chaquopyGetType" in cms:
                    q1 = cms.find("'") + 1
                    q2 = cms.find("'", q1) if q1 > 0 else -1
                    cls_name = cms[q1:q2] if (q1 > 0 and q2 > q1) else None
                    if cls_name:
                        entry = _B14_IFACE_OWNER.get(cls_name)
                        if entry:
                            zowner, zts = entry
                            if abs(int(crash_ts) - int(zts)) < _B16_ZOMBIE_WINDOW_MS:
                                rec["correlated"] = {
                                    "from": "zombie_proxy",
                                    "culprit": zowner,
                                    "confidence": "medium",
                                    "where": "proxy.invoke/fromJava",
                                    "proxy_class": cls_name,
                                    "match": "iface_owner+window",
                                    "age_ms": abs(int(crash_ts) - int(zts))}
                                cur_pid = rec.get("crashed_plugin_id")
                                cur_conf = rec.get("confidence")
                                weak = (
                                    (cur_conf != "high") or (not cur_pid) or
                                    (cur_pid == "unknown") or
                                    (isinstance(cur_pid, str) and
                                     cur_pid.startswith("<python>"))
                                )
                                if weak:
                                    rec["crashed_plugin_id_native"] = cur_pid
                                    rec["crashed_plugin_id"] = zowner
                                    rec["confidence"] = "medium"
                                    rec["src"] = "zombie_proxy/" + cls_name
            except Exception: pass
            return rec
        culprit = best.get("culprit")
        if not culprit or culprit == "unknown": return rec
        sig = ["exc", "window"]
        try:
            if top_pid and top_pid == culprit: sig.append("top_pid")
        except Exception: pass
        try:
            for fr in frames:
                if isinstance(fr, str) and culprit in fr:
                    sig.append("stack"); break
        except Exception: pass
        rec["correlated"] = {
            "from": (best.get("kind") or "cb") + "_verdict", "culprit": culprit,
            "confidence": best.get("confidence"), "where": best.get("where"),
            "py_file": best.get("py_file"), "py_line": best.get("py_line"),
            "match": "+".join(sig), "age_ms": abs(int(crash_ts) - best_ts),
        }
        cur_pid = rec.get("crashed_plugin_id")
        cur_conf = rec.get("confidence")
        weak = (cur_conf != "high") or (not cur_pid) or (cur_pid == "unknown") or (isinstance(cur_pid, str) and cur_pid.startswith("<python>"))
        if weak:
            rec["crashed_plugin_id_native"] = cur_pid
            rec["crashed_plugin_id"] = culprit
            rec["confidence"] = "high"
            rec["src"] = "correlated/" + (best.get("kind") or "cb")
        return rec
    except Exception:
        return rec

def _b16_correlate_boot(rec, cands):
    try:
        if not _B16_ON or not isinstance(rec, dict) or not cands:
            return rec
        cur_pid = rec.get("crashed_plugin_id"); cur_conf = rec.get("confidence")
        weak = (cur_conf != "high") or (not cur_pid) or (cur_pid == "unknown") or (isinstance(cur_pid, str) and cur_pid.startswith("<python>"))
        if not weak:
            return rec
        crash_ts = rec.get("ts") or int(time.time() * 1000)
        cx = rec.get("exc_cls"); cm = rec.get("exc_msg")
        best = None; best_ts = -1; best_py = None; best_py_ts = -1
        for v in cands:
            try:
                if v.get("confidence") != "high":
                    continue
                vts = v.get("ts")
                if vts is None:
                    continue
                if abs(int(crash_ts) - int(vts)) > _B16_CORR_WINDOW_MS:
                    continue
                if _b16_exc_match(cx, cm, v.get("exc_cls"), v.get("exc_msg")):
                    if int(vts) > best_ts:
                        best = v; best_ts = int(vts)
                elif v.get("kind") == "pyerr":
                    if int(vts) > best_py_ts:
                        best_py = v; best_py_ts = int(vts)
            except Exception:
                pass
        if best is None and best_py is not None:
            best = best_py; best_ts = best_py_ts
        if best is None:
            return rec
        culprit = best.get("culprit")
        if not culprit or culprit == "unknown":
            return rec
        rec["crashed_plugin_id_native"] = cur_pid
        rec["crashed_plugin_id"] = culprit
        rec["confidence"] = "high"
        rec["src"] = "correlated-boot/" + (best.get("kind") or "py")
        rec["correlated"] = {"from": (best.get("kind") or "py") + "_verdict", "culprit": culprit,
                             "confidence": best.get("confidence"), "where": best.get("where"),
                             "py_file": best.get("py_file"), "py_line": best.get("py_line"),
                             "match": "boot+window", "age_ms": abs(int(crash_ts) - int(best_ts))}
        return rec
    except Exception:
        return rec

def _capture_crash(thread, ex):
    crash_ts = int(time.time() * 1000)
    tid = None
    if _NATIVE_OK and _NLIB is not None:
        try: tid = int(_NLIB.cd_gettid())
        except Exception: tid = None
    if tid is None:
        try: tid = int(thread.getId())
        except Exception: tid = None
    idx_tid = _reg_get(tid)
    pid_tid = _resolve_idx(idx_tid) if (idx_tid is not None and idx_tid >= 0) else None
    crumb_raw = None
    try:
        crumb_raw = _CRUMB.read_prev() if _CRUMB is not None else None
    except Exception:
        crumb_raw = None
    pid_crumb = None; crumb_fresh = False; crumb_age = None
    if crumb_raw:
        try:
            parts = crumb_raw.split("\t")
            pid_crumb = parts[0]; cts = int(parts[2]); crumb_age = crash_ts - cts
            if 0 <= crumb_age <= _CRUMB_FRESH_MS: crumb_fresh = True
        except Exception:
            pid_crumb = crumb_raw.split("\t")[0] if "\t" in crumb_raw else crumb_raw
    frames = []
    try:
        st = ex.getStackTrace()
        if st is not None:
            for el in st:
                try: frames.append(el.getClassName() + "." + el.getMethodName())
                except Exception: pass
    except Exception:
        pass
    via_hook = any(_is_hook_frame(f) for f in frames)
    hooked_method = None
    if via_hook:
        for f in frames:
            if _is_hook_frame(f) and "LSPHooker_" in f:
                try: hooked_method = f.rsplit(".", 1)[1]
                except Exception: hooked_method = _short_method(f)
                break
        if not hooked_method:
            for f in frames:
                if f.startswith("org.telegram."):
                    hooked_method = _short_method(f); break
    culprit_frame = _stack_culprit(frames)
    pid_stack = _map_stack_to_id(culprit_frame, _known_union()) if culprit_frame else None
    pid_4a = None; hook4a_method = None; hook4a_kind = None; hook4a_meta = {}
    try:
        pid_4a, hook4a_method, hook4a_kind, hook4a_meta = _hook_owner_for_frames(frames)
    except Exception as _e4a:
        hook4a_meta = {"status": "err:%s" % _e4a}
    pid_4b = None; cl4b_frame = None; cl4b_meta = {}
    try:
        pid_4b, cl4b_frame, cl4b_meta = _classloader_culprit(frames)
    except Exception as _e4b:
        cl4b_meta = {"status": "err:%s" % _e4b}
    pid_4c = None; cl4c_frame = None; cl4c_meta = {}
    try:
        pid_4c, cl4c_frame, cl4c_meta = _loader_culprit(frames)
    except Exception as _e4c:
        cl4c_meta = {"status": "err:%s" % _e4c}
    pid_stack_strong = pid_stack if (pid_stack and culprit_frame and not _is_obfuscated(culprit_frame)) else None
    if pid_tid:
        pid = pid_tid; src = "tid"; conf = "high"
    elif pid_stack_strong:
        pid = pid_stack_strong; src = "stack"; conf = "high"
    elif pid_4c:
        pid = pid_4c; src = "loader"; conf = "high"
    elif pid_4b:
        pid = pid_4b; src = "classloader"; conf = "high"
    elif pid_4a:
        pid = pid_4a; src = "hookmap"; conf = "high"
    elif pid_stack:
        pid = pid_stack; src = "stack"; conf = "medium"
    elif culprit_frame:
        pid = _pkg_of(culprit_frame); src = "stack-pkg"; conf = "low"
    elif crumb_fresh and pid_crumb:
        pid = pid_crumb; src = "breadcrumb"; conf = "low"
    else:
        pid = "unknown"; src = ("hook-obfuscated" if via_hook else "none"); conf = "none"
    exc_cls = ""; exc_msg = ""; tname = ""
    try: exc_cls = ex.getClass().getName()
    except Exception: pass
    try:
        m = ex.getMessage(); exc_msg = str(m) if m is not None else ""
    except Exception: pass
    try: tname = thread.getName()
    except Exception: pass
    is_selftest = (_SELFTEST_MARK in (exc_msg or "")) or (tname == _SELFTEST_TNAME)
    nat = None
    if _NATIVE_OK and _NLIB is not None:
        try:
            b = ctypes.c_int64(0)
            ti = int(_NLIB.cd_top1(ctypes.byref(b)))
            nat = {"top_idx": ti, "top_pid": (_resolve_idx(ti) if ti >= 0 else None),
                   "top_bytes": int(b.value), "total": int(_NLIB.cd_total())}
        except Exception:
            nat = None
    rec = {
        "had_crash": True, "crashed_plugin_id": pid, "src": src, "confidence": conf,
        "exc_cls": exc_cls, "exc_msg": exc_msg, "thread": tname,
        "via_hook": via_hook, "hooked_method": hooked_method,
        "pid_tid": pid_tid, "reg_idx": idx_tid, "reg_backend": registry_info()["backend"],
        "pid_stack": pid_stack, "culprit_frame": culprit_frame,
        "pid_4a": pid_4a, "hook4a_method": hook4a_method, "hook4a_kind": hook4a_kind, "hook4a_meta": hook4a_meta,
        "pid_4b": pid_4b, "cl4b_frame": cl4b_frame, "cl4b_meta": cl4b_meta,
        "pid_4c": pid_4c, "cl4c_frame": cl4c_frame, "cl4c_meta": cl4c_meta,
        "pid_crumb": pid_crumb, "crumb_fresh": crumb_fresh, "crumb_age_ms": crumb_age, "crumb": crumb_raw,
        "stack_top": frames[:40], "native_mem": nat, "ts": crash_ts,
    }
    if _is_py_memoryerror(exc_cls, exc_msg):
        rec["mem_pressure"] = True; rec["reason"] = _MEM_PRESSURE_REASON
    rec = _b16_correlate(rec)
    _write_crash_verdict(rec)
    return is_selftest

_UEH_IFACE = None
try:
    _UEH_IFACE = jclass("java.lang.Thread$UncaughtExceptionHandler")
except Exception:
    _UEH_IFACE = None
_HANDLER_CLASS = None
if _UEH_IFACE is not None:
    try:
        from java import dynamic_proxy
        class _CrashHandler(dynamic_proxy(_UEH_IFACE)):
            def __init__(self, prev):
                super().__init__(); self._prev = prev
            def uncaughtException(self, thread, ex):
                swallow = False
                try: swallow = _capture_crash(thread, ex)
                except Exception: swallow = False
                if not swallow:
                    try:
                        if self._prev is not None:
                            self._prev.uncaughtException(thread, ex)
                    except Exception: pass
        _HANDLER_CLASS = _CrashHandler
    except Exception:
        _HANDLER_CLASS = None

_RUNNABLE_IFACE = None
try:
    _RUNNABLE_IFACE = jclass("java.lang.Runnable")
except Exception:
    _RUNNABLE_IFACE = None
_SELFTEST_RUNNABLE_CLASS = None
if _RUNNABLE_IFACE is not None:
    try:
        from java import dynamic_proxy as _dp2
        class _SelfTestRunnable(dynamic_proxy(_RUNNABLE_IFACE)):
