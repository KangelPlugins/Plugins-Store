_MVEL_CTX_CLASS_DENY = ("org.mvel2.", "java.", "javax.", "kotlin.", "sun.", "jdk.", "[")

def _mvel_ctx_learnable(cn):
    if not cn:
        return False
    for _p in _MVEL_CTX_CLASS_DENY:
        if cn.startswith(_p):
            return False
    return True

def _mvel_ctx_class(param):
    try:
        args = list(param.args) if getattr(param, "args", None) is not None else []
    except Exception:
        args = []
    for a in args:
        try:
            if a is None: continue
            nm = a.getClass().getName()
            if nm and _mvel_ctx_learnable(nm):
                return nm
        except Exception:
            continue
    return None

def _mvel_owner_now(param=None):
    global _MVEL_CACHE_LAST
    ow = _gpu_owner_now()
    if ow:
        if param is not None:
            try:
                cn = _mvel_ctx_class(param)
                if cn:
                    if cn not in _MVEL_OWNER_BY_CLASS:
                        if len(_MVEL_OWNER_BY_CLASS) >= _MVEL_OWNER_MAX:
                            try: _MVEL_OWNER_BY_CLASS.pop(next(iter(_MVEL_OWNER_BY_CLASS)))
                            except Exception: _MVEL_OWNER_BY_CLASS.clear()
                        _MVEL_OWNER_BY_CLASS[cn] = ow
                    else:
                        now = int(time.time() * 1000)
                        if now - _MVEL_CACHE_LAST >= _MVEL_FIRE_DEDUP_MS:
                            _MVEL_CACHE_LAST = now
                            _MVEL_OWNER_BY_CLASS[cn] = ow
            except Exception:
                pass
        return ow
    if param is not None:
        try:
            cn = _mvel_ctx_class(param)
            if cn:
                return _MVEL_OWNER_BY_CLASS.get(cn)
        except Exception:
            pass
    return None

_MVEL_FIRE_SEEN = {}
_MVEL_FIRE_LOCK = threading.Lock()
_MVEL_FIRE_DEDUP_MS = 1000
_MVEL_FIRE_N = 0

_MVEL_FIRE_DIAG_ON = False
_MVEL_CACHE_LAST = 0

def _mvel_fire_diag(param, ow):
    global _MVEL_FIRE_N
    try:
        cn = None
        try:
            cn = _mvel_ctx_class(param)
        except Exception:
            cn = None
        a0 = None
        try:
            args = list(param.args) if getattr(param, "args", None) is not None else []
            if args and args[0] is not None:
                a0 = args[0].getClass().getName()
        except Exception:
            a0 = None
        try:
            tname = threading.current_thread().name
        except Exception:
            tname = "?"
        key = (cn or "-", a0 or "-", repr(ow))
        now = int(time.time() * 1000)
        with _MVEL_FIRE_LOCK:
            if now - _MVEL_FIRE_SEEN.get(key, 0) < _MVEL_FIRE_DEDUP_MS:
                return
            _MVEL_FIRE_SEEN[key] = now
            _MVEL_FIRE_N += 1
            n = _MVEL_FIRE_N
        _log("Block#4C +BS(mvel-fire): #%d owner=%r ctx_class=%r arg0=%r thread=%s -- hook fired "
             "(this line proves the engine eval reached a +BN entrypoint regardless of owner)"
             % (n, ow, cn, a0, tname))
    except Exception:
        pass

def _classify_crash_frames(frames):
    try:
        if _gpu_frames_hit_rs(frames) or _frames_hit_gl(frames): return "gpu"
        if _frames_hit_anim(frames): return "anim"
        if _frames_hit_mvel(frames): return "mvel"
        if _frames_hit_camera(frames): return "camera"
        if _frames_hit_mediacodec(frames): return "mediacodec"
        if _frames_hit_binder(frames): return "binder"
    except Exception:
        pass
    return None

