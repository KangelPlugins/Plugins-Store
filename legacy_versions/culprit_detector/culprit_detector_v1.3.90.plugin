_B19_NEXT = 0

def _pyerr_verdict_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _PYERR_FILE_NAME).getAbsolutePath()
    except Exception:
        return None

def _b19_build_struct(maxf, pathmax):
    c = ctypes
    class B19Event(c.Structure):
        _fields_ = [("tid", c.c_int64),
                    ("ts_ms", c.c_int64),
                    ("symbol", c.c_int32),
                    ("nframes", c.c_int32),
                    ("lines", c.c_int32 * maxf),
                    ("files", (c.c_char * pathmax) * maxf)]
    return B19Event

def _b19_init(lib):
    global _B19_OK, _B19Event, _B19_RING_CAP, _B19_REC_SIZE, _B19_MAX_FRAMES, _B19_PATH_MAX, _B19_EVBUF, _B19_EVADDR
    c = ctypes
    needed = ("cd_b19_start", "cd_b19_stop", "cd_b19_ring_addr", "cd_b19_ring_cap",
              "cd_b19_rec_size", "cd_b19_max_frames", "cd_b19_path_max",
              "cd_b19_committed", "cd_b19_running", "cd_b19_read_event")
    if not all(hasattr(lib, n) for n in needed):
        _B19_OK = False
        _log("Block#19: cd_b19_* нет в .so (старый бинарь) — JNI-py-атрибуция отключена")
        return False
    try:
        lib.cd_b19_start.restype = c.c_int
        lib.cd_b19_stop.restype = c.c_int
        lib.cd_b19_ring_addr.restype = c.c_uint64
        lib.cd_b19_ring_cap.restype = c.c_int32
        lib.cd_b19_rec_size.restype = c.c_int32
        lib.cd_b19_max_frames.restype = c.c_int32
        lib.cd_b19_path_max.restype = c.c_int32
        lib.cd_b19_committed.restype = c.c_int64
        lib.cd_b19_running.restype = c.c_int
        lib.cd_b19_read_event.restype = c.c_int
        lib.cd_b19_read_event.argtypes = [c.c_int64, c.c_void_p]
        for opt in ("cd_b19_boundary_hits", "cd_b19_tb_captures", "cd_b19_dropped"):
            try: getattr(lib, opt).restype = c.c_int64
            except Exception: pass
        _B19_MAX_FRAMES = int(lib.cd_b19_max_frames())
        _B19_PATH_MAX = int(lib.cd_b19_path_max())
        _B19_REC_SIZE = int(lib.cd_b19_rec_size())
        _B19_RING_CAP = int(lib.cd_b19_ring_cap())
        if _B19_MAX_FRAMES <= 0 or _B19_PATH_MAX <= 0 or _B19_RING_CAP <= 0:
            _B19_OK = False
            _log("Block#19: невалидные размеры от натива — отключаю")
            return False
        _B19Event = _b19_build_struct(_B19_MAX_FRAMES, _B19_PATH_MAX)
        if c.sizeof(_B19Event) != _B19_REC_SIZE:
            _B19_OK = False
            _log("Block#19: размер записи не совпал (py=%d native=%d) — отключаю" % (c.sizeof(_B19Event), _B19_REC_SIZE))
            return False
        _B19_EVBUF = _B19Event()
        _B19_EVADDR = c.addressof(_B19_EVBUF)
        _B19_OK = True
        _log("Block#19: cd_b19_* ок (cap=%d rec=%dB maxf=%d path=%d)" % (_B19_RING_CAP, _B19_REC_SIZE, _B19_MAX_FRAMES, _B19_PATH_MAX))
        return True
    except Exception as e:
        _B19_OK = False
        _log("Block#19 init err: %s: %s" % (type(e).__name__, e))
        return False

def _b19_cstr(arr):
    try:
        return bytes(arr).split(b"\x00", 1)[0].decode("utf-8", "replace")
    except Exception:
        return ""

def _b19_file_plugin_map():
    m = {}
    try:
        for mod in list(_sys.modules.values()):
            try:
                pid = getattr(mod, "__id__", None)
                fn = getattr(mod, "__file__", None)
                if not (isinstance(pid, str) and pid and isinstance(fn, str) and fn):
                    continue
                if pid == _SELF_ID or pid == __id__:
                    continue
                try: pid = _canon_pid(pid)
                except Exception: pass
                m[fn] = pid
                try: m[os.path.abspath(fn)] = pid
                except Exception: pass
                try: m[os.path.basename(fn)] = pid
                except Exception: pass
            except Exception: pass
    except Exception as e:
        try: _log("Block#19: file->plugin map build err: %s: %s" % (type(e).__name__, e))
        except Exception: pass
    if not m:
        try: _log("Block#19: file->plugin map ПУСТА -- атрибуция Python-ошибок уйдёт в untagged")
        except Exception: pass
    return m

def _b19_culprit_from_event(ev, fmap):
    n = int(ev.nframes)
    if n > _B19_MAX_FRAMES: n = _B19_MAX_FRAMES
    deepest_file = None; deepest_line = -1
    if n > 0:
        deepest_file = _b19_cstr(ev.files[n - 1]); deepest_line = int(ev.lines[n - 1])
    pid = None; pfile = None; pline = -1
    for i in range(n - 1, -1, -1):
        f = _b19_cstr(ev.files[i])
        cand = fmap.get(f)
        if cand is None:
            try: cand = fmap.get(os.path.basename(f))
            except Exception: cand = None
        if isinstance(cand, str) and cand:
            pid = cand; pfile = f; pline = int(ev.lines[i]); break
    return pid, pfile, pline, deepest_file, deepest_line

def _pyerr_verdict_log(rec, when):
    try:
        _log("============= JNI PY-EXC VERDICT (%s) =============" % when)
        cul = rec.get("culprit"); conf = rec.get("confidence")
        if cul and cul != "unknown":
            _log("ВИНОВНИК PY-JNI: %r conf=%s where=%s src=%s" % (cul, conf, rec.get("where"), rec.get("src")))
        else:
            _log("ВИНОВНИК PY-JNI: неизвестен (symbol=%s)" % rec.get("symbol"))
        _log("  причина: %s" % rec.get("reason"))
        pf = rec.get("py_file")
        if pf: _log("  modul: %s:%s" % (pf, rec.get("py_line")))
        df = rec.get("deepest_file")
        if df: _log("  deepest: %s:%s" % (df, rec.get("deepest_line")))
        _log("  granica: %s" % rec.get("symbol"))
        _log("===================================================")
    except Exception: pass

def _persist_pyerr_fail(rec):
    p = _pyerr_verdict_path()
    if not p:
        _log("Block#19 pyerrpersist: нет пути -- пропуск"); return
    _PERSIST_IO_LOCK.acquire()
    try:
        cur = []
        if os.path.exists(p):
            try:
                with open(p, "r", encoding="utf-8") as f: cur = list(json.load(f))
            except Exception: cur = []
        cur.append(rec)
        if len(cur) > _PYERR_FAILS_MAX: cur = cur[-_PYERR_FAILS_MAX:]
        _atomic_json_write(p, cur)
        _log("Block#19 pyerrpersist: zapisano %d zapisej -> %s" % (len(cur), _PYERR_FILE_NAME))
    except Exception as e:
        _log("Block#19 pyerrpersist err: %s: %s" % (type(e).__name__, e))
    finally:
        try: _PERSIST_IO_LOCK.release()
        except Exception: pass

def _read_and_clear_pyerr_fails():
    p = _pyerr_verdict_path()
    if not p: return []
    out = []
    _rp = _rc_take_path(p)
    try:
        if _rp:
            with open(_rp, "r", encoding="utf-8") as f: out = list(json.load(f))
    except Exception: out = []
    if _rp:
        try: os.remove(_rp)
        except Exception: pass
    return out

def _b19_record(ev, fmap):
    if not _BLOCK19_ON: return
    pid, pfile, pline, dfile, dline = _b19_culprit_from_event(ev, fmap)
    sym = _B19_SYM.get(int(ev.symbol), "?")
    if not pid:
        return
    if pid == _SELF_ID or pid == __id__: return
    reason = "py-exception across JNI boundary (%s)" % sym
    now = int(time.time() * 1000)
    _rate_pm, _rate_n = _exc_rate_record(pid)
    key = "%s|%s|%s" % (pid, pline, sym)
    try:
        with _PYERR_SEEN_LOCK:
            if now - _PYERR_SEEN.get(key, 0) < _PYERR_DEDUP_MS: return
            _PYERR_SEEN[key] = now
    except Exception: pass
    rec = {"had_pyerr_fail": True, "event_type": "python_exception", "dropbox_tag": "data_app_crash", "tombstone_norm_version": 1, "culprit": pid, "src": "py-frame/jni-boundary",
           "confidence": "high", "where": "jni-boundary", "symbol": sym,
           "py_module": pid, "py_file": pfile, "py_line": pline,
           "deepest_file": dfile, "deepest_line": dline, "reason": reason,
           "exc_cls": None, "exc_msg": None,
           "throws_per_min": _rate_pm, "throws_in_window": _rate_n,
           "high_rate": bool(_rate_pm >= _EXC_RATE_HOT), "ts": now}
    try: _b16_push_verdict("pyerr", rec)
    except Exception: pass
    try: _pyerr_verdict_log(rec, "live")
    except Exception: pass
    try: _persist_pyerr_fail(rec)
    except Exception: pass

_CD_COMPACT_TS = 0
_CD_COMPACT_MIN_S = 300
_CD_COMPACT_TOMB_HI = 200000
def _b19_poll_loop(stop):
    global _B19_NEXT, _CD_COMPACT_TS
    if not (_B19_OK and _NLIB is not None and _B19Event is not None and _B19_RING_ADDR):
        return
    cap = _B19_RING_CAP; rec_size = _B19_REC_SIZE; base = int(_B19_RING_ADDR)
    fmap = {}; fmap_ts = 0
    while not stop.is_set():
        try:
            committed = int(_NLIB.cd_b19_committed())
            if committed > _B19_NEXT:
                now = int(time.time() * 1000)
                if (now - fmap_ts) > 1500 or not fmap:
                    fmap = _b19_file_plugin_map(); fmap_ts = now
                start = _B19_NEXT
                if committed - start > cap:
                    start = committed - cap
                for seq in range(start, committed):
                    try:
                        if int(_NLIB.cd_b19_read_event(seq, _B19_EVADDR)) == 1:
                            _b19_record(_B19_EVBUF, fmap)
                    except Exception: pass
                _B19_NEXT = committed
        except Exception: pass
        try:
            _nl = _NLIB
            if _nl is not None and hasattr(_nl, "cd_compact") and hasattr(_nl, "cd_tomb_count"):
                _now2 = int(time.time())
                if _now2 - _CD_COMPACT_TS >= _CD_COMPACT_MIN_S and int(_nl.cd_tomb_count()) >= _CD_COMPACT_TOMB_HI:
                    _moved = int(_nl.cd_compact())
                    _CD_COMPACT_TS = _now2
                    _log(f"FIX#15 compact: moved={_moved} (tomb>={_CD_COMPACT_TOMB_HI})")
        except Exception: pass
        stop.wait(_B19_POLL_S)

def _b19_start():
    global _B19_STARTED, _B19_STOP, _B19_THREAD, _B19_RING_ADDR
    if not _BLOCK19_ON:
        _log("Block#19: отключён (_BLOCK19_ON=False)"); return
    if not (_B19_OK and _NATIVE_OK and _NLIB is not None):
        _log("Block#19: натив/символы недоступны -- пропуск"); return
    if _B19_STARTED: return
    try:
        hooks = int(_NLIB.cd_b19_start())
    except Exception as e:
        _log("Block#19 cd_b19_start err: %s" % e); return
    if hooks <= 0:
        _log("Block#19: cd_b19_start вернул %d хуков -- JNI/py граница не зацепилась" % hooks); return
    try: _B19_RING_ADDR = int(_NLIB.cd_b19_ring_addr())
    except Exception: _B19_RING_ADDR = 0
    if not _B19_RING_ADDR:
        _log("Block#19: ring_addr=0 -- отключаю")
        try: _NLIB.cd_b19_stop()
        except Exception: pass
        return
    _B19_STOP = threading.Event()
    _B19_THREAD = threading.Thread(target=_b19_poll_loop, args=(_B19_STOP,), name="culprit-b19", daemon=True)
    _B19_THREAD.start()
    _B19_STARTED = True
    _log("Block#19: установлен (хуков %d/3, ring@0x%x cap=%d) -> %s" % (hooks, _B19_RING_ADDR, _B19_RING_CAP, _PYERR_FILE_NAME))

def _b19_stop():
    global _B19_STARTED
    if not _B19_STARTED: return
    try:
        if _B19_STOP is not None: _B19_STOP.set()
        if _B19_THREAD is not None: _B19_THREAD.join(timeout=2.0)
    except Exception: pass
    try:
        if _NLIB is not None: _NLIB.cd_b19_stop()
    except Exception: pass
    _B19_STARTED = False
    _log("Block#19: снят (cd_b19_stop)")

