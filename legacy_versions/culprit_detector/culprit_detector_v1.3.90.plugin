def _read_and_clear_cxa():
    recs = []
    try:
        p = _cxa_path()
        _rp = _rc_take_path(p) if p else None
        if not _rp: return recs
        try:
            with open(_rp, "r", encoding="utf-8", errors="replace") as f:
                raw = f.read()
        finally:
            try: os.remove(_rp)
            except Exception: pass
        if "CULPRIT_CXA_THROW" not in raw: return recs
        cur = None
        for line in raw.splitlines():
            s = line.strip()
            if s == "CULPRIT_CXA_THROW":
                cur = {"kind": None, "module": None, "owner": None, "conf": None,
                       "type": None, "ts": None, "culprit_frame": None, "frames": []}
                recs.append(cur); continue
            if cur is None: continue
            if s == "END": cur = None; continue
            if s.startswith("kind="):
                for tok in s.split():
                    if tok.startswith("kind="): cur["kind"] = tok.split("=", 1)[1]
                    elif tok.startswith("module="): cur["module"] = tok.split("=", 1)[1]
                    elif tok.startswith("type="): cur["type"] = tok.split("=", 1)[1]
                    elif tok.startswith("ts="):
                        try: cur["ts"] = int(tok.split("=", 1)[1])
                        except Exception: pass
                    elif tok.startswith("culprit_frame="):
                        try: cur["culprit_frame"] = int(tok.split("=", 1)[1])
                        except Exception: pass
                if cur.get("kind") == "plugin" and cur.get("module"):
                    try: cur["owner"], cur["conf"] = _so_owner_from_path(cur["module"])
                    except Exception: cur["owner"], cur["conf"] = None, None
            elif s.startswith("#"):
                cur["frames"].append(s)
        return [r for r in recs if r.get("kind")]
    except Exception:
        return recs

_BLOCK28_ON = True
_B28_WARN_ON = True
_GLOBALREF_FILE_NAME = "globalref_verdict.json"
_GLOBALREF_SEEN_NAME = "globalref_seen.json"
_GLOBALREF_DUMP_NAME = "globalref_dump.txt"
_GLOBALREF_FAILS_MAX = 20
_GLOBALREF_SEEN_MAX = 64
_B28_WARN_PERIOD_S = 60.0
_B28_THREAD = None
_B28_STOP = threading.Event()
_B28_WARNED = set()
_B28_OVERFLOW_MARK = "global reference table overflow"
_PROC_START_MS = int(time.time() * 1000)
_B28_STALE_ECHO_MS = 180000
_B28_TS_RE = re.compile(r"^\s*(\d\d)-(\d\d)\s+(\d\d):(\d\d):(\d\d)\.(\d+)")
_B28_HOOK_REG = {}
_B28_HOOK_REG_LOCK = threading.Lock()
_B28_HOT_METHODS = (
    "addEntitiesToText", "applyEntities", "generateLayout",
    "messageTextToString", "replaceAnimatedEmoji",
)

def _b28_reg_hot_hook(pid, method, persist=False):
    """
    Запоминает, какой плагин зарегистрировал/исполняет хук на горячем render-методе.
    Нужно для Block#28, когда Block#4A не может прочитать Xposed/LSPlant jmap
    и возвращает lsplant-no-jmap.
    """
    try:
        if not pid or not method:
            return False
        try:
            pid = _canon_pid(pid)
        except Exception:
            pass
        if not isinstance(pid, str) or not pid:
            return False
        if pid == _SELF_ID or pid == __id__:
            return False
        if method not in _B28_HOT_METHODS:
            return False
        changed = False
        with _B28_HOOK_REG_LOCK:
            arr = _B28_HOOK_REG.get(pid)
            if arr is None:
                arr = []
                _B28_HOOK_REG[pid] = arr
            if method not in arr:
                arr.append(method)
                changed = True
        if changed:
            try:
                _log("Block#28: hot-hook registered owner=%r method=%s" % (pid, method))
            except Exception:
                pass
            if persist:
                try:
                    _b28_persist_hot_hook(pid, method)
                except Exception:
                    pass
        return True
    except Exception:
        return False
_GLOBALREF_HOOKS_NAME = "globalref_hooks.json"

def _b28_hooks_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _GLOBALREF_HOOKS_NAME).getAbsolutePath()
    except Exception:
        return None

def _b28_persist_hot_hook(pid, method):
    p = _b28_hooks_path()
    if not p:
        return
    _PERSIST_IO_LOCK.acquire()
    try:
        cur = {}
        _rp = _rc_read_path(p)
        if _rp:
            try:
                with open(_rp, "r", encoding="utf-8") as f:
                    cur = dict(json.load(f))
            except Exception:
                cur = {}
        rec = cur.get(pid)
        if not isinstance(rec, dict):
            rec = {"methods": [], "ts": 0}
        methods = list(rec.get("methods") or [])
        if method not in methods:
            methods.append(method)
        rec["methods"] = methods
        rec["ts"] = int(time.time() * 1000)
        cur[pid] = rec
        _atomic_json_write(p, cur)
    except Exception:
        pass
    finally:
        try: _PERSIST_IO_LOCK.release()
        except Exception: pass

def _b28_load_persisted_hooks():
    p = _b28_hooks_path()
    try:
        _rp = _rc_read_path(p) if p else None
        if _rp:
            with open(_rp, "r", encoding="utf-8") as f:
                return dict(json.load(f))
    except Exception:
        pass
    return {}

def _b28_installed_pids():
    out = set()
    try:
        for e in _b11_plugin_entries():
            try:
                k = _safe_str(e.getKey())
                if k: out.add(k)
            except Exception: pass
    except Exception: pass
    return out

def _b28_prune_persisted_hooks():
    try:
        installed = _b28_installed_pids()
        if not installed: return
        cur = _b28_load_persisted_hooks() or {}
        if not cur: return
        pruned = {pid: rec for pid, rec in cur.items() if pid in installed}
        if len(pruned) == len(cur): return
        p = _b28_hooks_path()
        if not p: return
        _PERSIST_IO_LOCK.acquire()
        try:
            _atomic_json_write(p, pruned)
        finally:
            try: _PERSIST_IO_LOCK.release()
            except Exception: pass
        try: _log("Block#28: pruned %d ghost hot-hook owner(s) from globalref_hooks.json" % (len(cur) - len(pruned)))
        except Exception: pass
    except Exception:
        pass

def _b28_combined_hook_owners():
    out = {}
    try:
        with _B28_HOOK_REG_LOCK:
            for pid, methods in _B28_HOOK_REG.items():
                out.setdefault(pid, [])
                for m in (methods or []):
                    if m not in out[pid]:
                        out[pid].append(m)
    except Exception:
        pass
    try:
        for pid, rec in (_b28_load_persisted_hooks() or {}).items():
            ms = rec.get("methods") if isinstance(rec, dict) else rec
            out.setdefault(pid, [])
            for m in (ms or []):
                if m not in out[pid]:
                    out[pid].append(m)
    except Exception:
        pass
    try:
        _inst = _b28_installed_pids()
        if _inst:
            out = {pid: ms for pid, ms in out.items() if pid in _inst}
    except Exception:
        pass
    return out

_B28C_ON = True
_B28C_SAMPLE = 16
_B28C_PERSIST_MS = 3000
_B28C_MIN = 160
_B28C_DOMINANCE = 0.55
_GLOBALREF_PROXY_NAME = "globalref_proxy.json"
_B28C_COUNTS = {}
_B28C_LOCK = threading.Lock()
_GREF_READ_LOCK = threading.Lock()
_B28C_SEEN = 0
_B28C_LAST = int(time.time() * 1000)

def _b28c_proxy_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _GLOBALREF_PROXY_NAME).getAbsolutePath()
    except Exception:
        return None

def _b28c_persist(counts, now):
    p = _b28c_proxy_path()
    if not p: return
    try:
        data = {}
        for pid, n in counts.items():
            if not pid or pid == _SELF_ID or pid == __id__: continue
            data[pid] = {"count": int(n), "ts": int(now)}
        _atomic_json_write(p, data)
    except Exception:
        pass

def _b28c_record(owner, weight=1):
    if not owner: return
    now = int(time.time() * 1000)
    due = False; snap = None
    with _B28C_LOCK:
        _B28C_COUNTS[owner] = _B28C_COUNTS.get(owner, 0) + int(weight)
        global _B28C_LAST
        if (now - _B28C_LAST) >= _B28C_PERSIST_MS:
            _B28C_LAST = now; due = True; snap = dict(_B28C_COUNTS)
    if due and snap is not None:
        _b28c_persist(snap, now)

_B28C_NATIVE_THREAD = None
_B28C_NATIVE_STOP = None

def _b28c_native_flush(now=None):
    if not (_GREF_NATIVE_OK and _NLIB is not None): return False
    try:
        if not int(_NLIB.cd_gref_running()): return False
    except Exception:
        return False
    try:
        n = int(_NLIB.cd_gref_tags())
    except Exception:
        n = 4096
    if n <= 0 or n > 65536: n = 4096
    try:
        arr = (ctypes.c_int64 * n)()
        m = int(_NLIB.cd_gref_snapshot(arr, ctypes.c_int32(n)))
    except Exception:
        return False
    counts = {}
    for idx in range(m):
        try: cnt = int(arr[idx])
        except Exception: continue
        if cnt <= 0: continue
        name = None
        try: name = _resolve_idx(idx)
        except Exception: name = None
        if not name:
            try: name = _resolve_idx_durable(idx)
            except Exception: name = None
        if not name or name == _SELF_ID or name == __id__: continue
        counts[name] = cnt
    if not counts: return False
    _b28c_persist(counts, now if now is not None else int(time.time() * 1000))
    return True

def _b28c_native_loop(stop_evt):
    while not stop_evt.is_set():
        wrote = False
        try: wrote = bool(_b28c_native_flush())
        except Exception: wrote = False
        if wrote:
            try: _b28_reattribute_untagged()
            except Exception: pass
        try: stop_evt.wait(max(0.5, _B28C_PERSIST_MS / 1000.0))
        except Exception: time.sleep(3.0)

def _b28c_start_native_flush():
    global _B28C_NATIVE_THREAD, _B28C_NATIVE_STOP
    if _B28C_NATIVE_THREAD is not None: return False
    if not (_GREF_NATIVE_OK and _NLIB is not None): return False
    try:
        _B28C_NATIVE_STOP = threading.Event()
        t = threading.Thread(target=_b28c_native_loop, args=(_B28C_NATIVE_STOP,), name="CulpritGrefFlush", daemon=True)
        t.start()
        _B28C_NATIVE_THREAD = t
        return True
    except Exception:
        return False

_B28_HOOK_HITS = {}
_B28_HOOK_HITS_LOCK = threading.Lock()
_B28_HITS_LAST = 0
_B28_HITS_PERSIST_MS = 3000
_B28_HITS_NAME = "globalref_hits.json"
def _b28_hits_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _B28_HITS_NAME).getAbsolutePath()
    except Exception:
        return None
def _b28_persist_hits(snap, now):
    p = _b28_hits_path()
    if not p: return
    try:
        data = {}
        for pid, methods in snap.items():
            if not pid or pid == _SELF_ID or pid == __id__: continue
            data[pid] = {"methods": {k: int(v) for k, v in methods.items()}, "ts": int(now)}
        _atomic_json_write(p, data)
    except Exception:
        pass
def _b28_hit(pid, method):
    if not pid or not method: return
    if pid == _SELF_ID or pid == __id__: return
    now = int(time.time() * 1000)
    due = False; snap = None
    global _B28_HITS_LAST
    with _B28_HOOK_HITS_LOCK:
        d = _B28_HOOK_HITS.get(pid)
        if d is None:
            d = {}; _B28_HOOK_HITS[pid] = d
        d[method] = d.get(method, 0) + 1
        if (now - _B28_HITS_LAST) >= _B28_HITS_PERSIST_MS:
            _B28_HITS_LAST = now; due = True
            snap = {p: dict(m) for p, m in _B28_HOOK_HITS.items()}
    if due and snap is not None:
        try: _b28_persist_hits(snap, now)
        except Exception: pass
def _b28_load_hits():
    p = _b28_hits_path()
    try:
        _rp = _rc_read_path(p) if p else None
        if _rp:
            with open(_rp, "r", encoding="utf-8") as f:
                return dict(json.load(f))
    except Exception:
        pass
    return {}
def _b28_hit_winner(method, candidates, ref_ts=None, max_age_ms=None, dominance=0.8):
    if not method: return None
    cset = set(candidates or [])
    mem = {}; disk = {}
    try:
        with _B28_HOOK_HITS_LOCK:
            for pid, m in _B28_HOOK_HITS.items():
                if cset and pid not in cset: continue
                c = int((m or {}).get(method, 0))
                if c > 0: mem[pid] = c
    except Exception:
        pass
    try:
        for pid, rec in (_b28_load_hits() or {}).items():
            if cset and pid not in cset: continue
            if ref_ts is not None and max_age_ms is not None and isinstance(rec, dict):
                try:
                    ts = int(rec.get("ts") or 0)
                    if ts and abs(ts - int(ref_ts)) > int(max_age_ms): continue
                except Exception:
                    pass
            ms = rec.get("methods") if isinstance(rec, dict) else rec
            c = int((ms or {}).get(method, 0))
            if c > 0: disk[pid] = c
    except Exception:
        pass
    tally = {}
    for pid in (set(mem) | set(disk)):
        tally[pid] = max(mem.get(pid, 0), disk.get(pid, 0))
    if not tally: return None
    tot = sum(tally.values()) or 1
    best = max(tally, key=lambda k: tally[k])
    if tally[best] >= dominance * tot:
        return best
    return None

def _b28_proxy_producer(ref_ts=None, max_age_ms=None):
    try:
        p = _b28c_proxy_path()
        _rp = _rc_read_path(p) if p else None
        if not _rp: return None, None
        with open(_rp, "r", encoding="utf-8") as f:
            data = dict(json.load(f))
    except Exception:
        return None, None
    best = None; best_n = 0; total = 0
    for pid, rec in data.items():
        if not pid or pid == _SELF_ID or pid == __id__: continue
        try:
            n = int(rec.get("count") or 0) if isinstance(rec, dict) else int(rec or 0)
            ts = int(rec.get("ts") or 0) if isinstance(rec, dict) else 0
        except Exception:
            continue
        if ref_ts is not None and max_age_ms is not None and ts:
            if abs(ts - int(ref_ts)) > max_age_ms: continue
        total += n
        if n > best_n: best_n = n; best = pid
    if best and best_n >= _B28C_MIN and total > 0 and best_n >= total * _B28C_DOMINANCE:
        return best, "proxy-producer"
    return None, None

class _ProxyCreateHook(MethodHook):
    def after_hooked_method(self, param):
        try:
            if not _B28C_ON: return
            try:
                if param.getThrowable() is not None: return
            except Exception: pass
            global _B28C_SEEN
            _B28C_SEEN += 1
            if (_B28C_SEEN % _B28C_SAMPLE) != 0: return
            owner = None
            try: owner = _direct_pid_now()
            except Exception: owner = None
            if not owner:
                try: owner = _b27_owner_now()
                except Exception: owner = None
            if not owner or owner == _SELF_ID: return
            _b28c_record(owner, _B28C_SAMPLE)
        except Exception: pass

_B28_BRIDGE_TOKENS = (
    "LSPHooker_", "PyMethodHook", "HookCallbackDispatcher", "XposedBridge",
    "Proxy_Object", "chaquopy", "PyObject", "Reflector", "HookInfo",
    "afterHookedMethod", "beforeHookedMethod",
)

_B28_JNISIG_RE = re.compile(r"^L([\w/$]+);$")
_B28_SUMMARY_RE = re.compile(r"^\s*(\d+)\s+of\s+(\S+)")
_B28_MAX_RE = re.compile(r"max\s*=\s*(\d+)")
_B28_FRAME_RE = re.compile(r"([\w$.]+)\.([\w$<>]+)\s*[\(:]")
_B28_ENTRY_RE = re.compile(r"^\d+:")
_B28_PREFIX_RE = re.compile(r"^\s*\d\d-\d\d \d\d:\d\d:\d\d\.\d+\s+\d+\s+\d+\s+\w\s+[^:]*:\s?(.*)$")
_B28_DEBUG_RE = re.compile(r"\bDEBUG\b[^:]*:\s?")

def _globalref_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _GLOBALREF_FILE_NAME).getAbsolutePath()
    except Exception:
        return None

def _b28_seen_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _GLOBALREF_SEEN_NAME).getAbsolutePath()
    except Exception:
        return None

def _b28_load_seen():
    p = _b28_seen_path()
    try:
        _rp = _rc_read_path(p) if p else None
        if _rp:
            with open(_rp, "r", encoding="utf-8") as f:
                return list(json.load(f))
    except Exception:
        pass
    return []

def _b28_save_seen(sigs):
    p = _b28_seen_path()
    if not p: return
    try:
        _atomic_json_write(p, list(sigs)[-_GLOBALREF_SEEN_MAX:], _GLOBALREF_SEEN_MAX)
    except Exception:
        pass

def _b28_strip_prefix(line):
    try:
        m = _B28_DEBUG_RE.search(line)
        if m: return line[m.end():]
        m2 = _B28_PREFIX_RE.match(line)
        if m2: return m2.group(1)
    except Exception:
        pass
    return line

_B28_LOGCAT_TAIL = 8000

_B28_READ_FILTER_ON = True
_B28_MIN_LEVEL = "I"
_B28_KEEP_RE_ERE = "global reference|FATAL EXCEPTION|abort message|signal [0-9]|tombstone|>>> |DEBUG|art::|JNI (DETECTED|ERROR)|ReferenceTable|ANR in"

_B28_LEVELS = ("V", "D", "I", "W", "E")

def _b28_apply_settings(plugin):
    global _B28_READ_FILTER_ON, _B28_MIN_LEVEL, _B28_KEEP_RE_ERE
    try:
        _B28_READ_FILTER_ON = bool(plugin.get_setting("b28_filter_on", True))
    except Exception:
        pass
    try:
        _i = int(plugin.get_setting("b28_min_level", 2) or 2)
        if 0 <= _i < len(_B28_LEVELS):
            _B28_MIN_LEVEL = _B28_LEVELS[_i]
    except Exception:
        pass
    try:
        _rx = plugin.get_setting("b28_keep_re", None)
        if _rx is not None:
            _B28_KEEP_RE_ERE = str(_rx)
    except Exception:
        pass

def _b28_read_logcat(prefilter=True):
    out = []
    lvl = (_B28_MIN_LEVEL if (prefilter and _B28_READ_FILTER_ON) else "V")
    rx  = (_B28_KEEP_RE_ERE if (prefilter and _B28_READ_FILTER_ON) else "")
    cap = 3 * 1024 * 1024
    try:
        bufp = ctypes.create_string_buffer(cap)
    except Exception as e:
        try: _log("Block#28: logcat out-buf alloc err: %s" % e)
        except Exception: pass
        return out
    for buf in ("crash", "main"):
        try:
            n = int(_NLIB.cd_logcat_read_filtered(
                buf.encode("utf-8"), lvl.encode("ascii"), rx.encode("utf-8"),
                ctypes.c_int32(int(_B28_LOGCAT_TAIL)), bufp, ctypes.c_int32(cap)))
        except Exception as e:
            try: _log("Block#28: native logcat(%s) err: %s" % (buf, e))
            except Exception: pass
            continue
        if n > 0:
            try: out.append(bufp.value.decode("utf-8", "replace"))
            except Exception: pass
        elif n < 0:
            try: _log("Block#28: native logcat(%s) rc=%d" % (buf, n))
            except Exception: pass
    if not out:
        try: _log("Block#28: logcat пуст (crash+main) -- abort-message дамп недоступен")
        except Exception: pass
    return out

def _b28_read_drop_files():
    texts = []
    try:
        import glob as _glob
        gref_dump = os.path.join(_DIR, _GLOBALREF_DUMP_NAME)
        cands = [gref_dump]
        try:
            cands += _glob.glob(os.path.join(_DIR, "crash*.txt"))
            cands += _glob.glob(os.path.join(_DIR, "tombstone*"))
        except Exception:
            pass
        seen_p = set()
        for p in cands:
            if p in seen_p: continue
            seen_p.add(p)
            try:
                if not os.path.exists(p):
                    continue
                if os.path.getsize(p) > 15 * 1024 * 1024:
                    continue
                if p == gref_dump:
                    _rp = p + ".processing"
                    try:
                        os.rename(p, _rp)
                    except Exception:
                        continue
                    _hit = False
                    try:
                        with open(_rp, "r", encoding="utf-8", errors="replace") as f:
                            raw = f.read()
                        if _B28_OVERFLOW_MARK in raw:
                            texts.append(raw); _hit = True
                    except Exception:
                        pass
                    try:
                        if _hit: os.remove(_rp)
                        elif not os.path.exists(p): os.rename(_rp, p)
                        else: os.remove(_rp)
                    except Exception:
                        pass
                else:
                    with open(p, "r", encoding="utf-8", errors="replace") as f:
                        raw = f.read()
                    if _B28_OVERFLOW_MARK in raw:
                        texts.append(raw)
            except Exception:
                pass
    except Exception:
        pass
    return texts

def _b28_logcat_event_ts(line):
    try:
        m = _B28_TS_RE.match(line or "")
        if not m: return None
        mo, da, hh, mm, ss = (int(m.group(i)) for i in range(1, 6))
        frac = int((m.group(6) + "000")[:3])
        yr = time.localtime().tm_year
        epoch = time.mktime(time.struct_time((yr, mo, da, hh, mm, ss, 0, 0, -1)))
        if epoch - time.time() > 2 * 86400:
            epoch = time.mktime(time.struct_time((yr - 1, mo, da, hh, mm, ss, 0, 0, -1)))
        return int(epoch * 1000 + frac)
    except Exception:
        return None

def _b28_extract_overflow_block(text):
    if not text or _B28_OVERFLOW_MARK not in text:
        return None, None
    lines = text.splitlines()
    idx = None
    for i in range(len(lines) - 1, -1, -1):
        if _B28_OVERFLOW_MARK in lines[i]:
            idx = i; break
    if idx is None: return None, None
    ev_ts = _b28_logcat_event_ts(lines[idx])
    start = max(0, idx - 2)
    end = min(len(lines), idx + 400)
    return "\n".join(lines[start:end]), ev_ts

def _b28_norm_type(t):
    if not t: return t
    t = t.strip().rstrip(",")
    m = _B28_JNISIG_RE.match(t)
    if m:
        return m.group(1).replace("/", ".")
    return t

def _b28_parse_dump(block):
    res = {"max": None, "types": {}, "alloc_frames": [], "entry_types": {}}
    m = _B28_MAX_RE.search(block)
    if m:
        try: res["max"] = int(m.group(1))
        except Exception: pass
    in_alloc = False
    for raw in block.splitlines():
        s = _b28_strip_prefix(raw).strip()
        if not s:
            in_alloc = False
            continue
        if "Allocated at" in s:
            in_alloc = True
            continue
        ms = _B28_SUMMARY_RE.match(s)
        if ms:
            in_alloc = False
            try:
                cnt = int(ms.group(1)); typ = _b28_norm_type(ms.group(2))
                if typ and ("." in typ):
                    res["types"][typ] = res["types"].get(typ, 0) + cnt
            except Exception:
                pass
            continue
        if _B28_ENTRY_RE.match(s):
            in_alloc = False
            toks = s.split()
            tail = toks[-1] if toks else ""
            typ = _b28_norm_type(tail)
            if typ and ("." in typ):
                res["entry_types"][typ] = res["entry_types"].get(typ, 0) + 1
            continue
        if in_alloc:
            fm = _B28_FRAME_RE.search(s)
            if fm:
                res["alloc_frames"].append("%s.%s" % (fm.group(1), fm.group(2)))
    if res["max"] is None and not res["types"] and not res["alloc_frames"]:
        try: _log("Block#28: parse_dump не распознал дамп (max/types/frames пусты) -- формат изменился?")
        except Exception: pass
    return res

def _b28_dominant_type(parsed):
    types = dict(parsed.get("types") or {})
    if not types:
        types = dict(parsed.get("entry_types") or {})
    if not types:
        return None, 0, 0.0
    total = sum(types.values()) or 1
    dom = max(types.items(), key=lambda kv: kv[1])
    return dom[0], dom[1], float(dom[1]) / float(total)

def _b28_hot_method(parsed):
    frames = parsed.get("alloc_frames") or []
    counts = {}
    for fr in frames:
        mth = fr.rsplit(".", 1)[-1]
        for hm in _B28_HOT_METHODS:
            if mth == hm:
                counts[hm] = counts.get(hm, 0) + 1
    if counts:
        return max(counts.items(), key=lambda kv: kv[1])[0], frames
    for fr in frames:
        if any(tok in fr for tok in _B28_BRIDGE_TOKENS):
            continue
        return fr.rsplit(".", 1)[-1], frames
    return None, frames

def _b28_attribute(parsed, hot_method, event_ts=None):
    owner = None; hook_method = None; hook_match = None; meta = {}
    try:
        frames = list(parsed.get("alloc_frames") or [])
        if hot_method:
            frames = ["LSPHooker_.%s" % hot_method] + frames
        owner, hook_method, hook_match, meta = _hook_owner_for_frames(frames)
    except Exception as e:
        try: _log("Block#28 attribute err: %s" % e)
        except Exception: pass
    if owner is None and hot_method:
        try:
            _rt_cands = []
            for pid, methods in _b28_combined_hook_owners().items():
                if not pid or pid == _SELF_ID or pid == __id__:
                    continue
                if hot_method in methods and pid not in _rt_cands:
                    _rt_cands.append(pid)
            if len(_rt_cands) == 1:
                owner = _rt_cands[0]
                hook_method = hot_method
                hook_match = "reg_time"
                meta = {"n": 0, "status": "reg-time"}
                _log("Block#28 attribution via reg-time: %r -> %s" % (owner, hot_method))
            elif len(_rt_cands) > 1:
                _hw = _b28_hit_winner(hot_method, _rt_cands)
                if _hw:
                    owner = _hw
                    hook_method = hot_method
                    hook_match = "reg-time-hits"
                    meta = {"n": 0, "status": "reg-time-hits", "candidates": _rt_cands}
                    _log("Block#28 attribution via live hot-hook hits: %r -> %s (broke reg-time-multi of %d)" % (owner, hot_method, len(_rt_cands)))
                else:
                    hook_match = "reg-time-multi"
                    meta = {"n": 0, "status": "reg-time-multi", "candidates": _rt_cands}
                    _log("Block#28 reg-time ambiguous (%d owners hooked %s): %r" % (len(_rt_cands), hot_method, _rt_cands))
        except Exception:
            pass
    if owner is None:
        try:
            persisted = _b28_load_persisted_hooks()
            _inst = _b28_installed_pids()
            cand = []
            for pid, rec in (persisted or {}).items():
                if not pid or pid == _SELF_ID or pid == __id__:
                    continue
                if _inst and pid not in _inst:
                    continue
                ms = rec.get("methods") if isinstance(rec, dict) else rec
                ms = [m for m in (ms or []) if m in _B28_HOT_METHODS]
                if ms:
                    ts = int(rec.get("ts") or 0) if isinstance(rec, dict) else 0
                    cand.append((pid, ms, ts))
            if cand:
                cand.sort(key=lambda c: c[2], reverse=True)
                owner = cand[0][0]
                hook_method = hot_method if (hot_method in cand[0][1]) else cand[0][1][0]
                if len(cand) == 1:
                    hook_match = "reg-persist"
                    meta = {"n": 0, "status": "reg-persist"}
                else:
                    hook_match = "reg-persist-multi"
                    meta = {"n": 0, "status": "reg-persist-multi", "candidates": [c[0] for c in cand]}
                _log("Block#28 attribution via persisted reg (%s): %r -> %s" % (hook_match, owner, hook_method))
        except Exception:
            pass
    if owner is None:
        try:
            pp, _pb = _b28_proxy_producer()
            if pp:
                owner = pp; hook_method = None; hook_match = "proxy-producer"
                meta = {"n": 0, "status": "proxy-producer"}
                _log("Block#28 attribution via proxy-producer: %r" % owner)
        except Exception:
            pass
    if owner is None:
        try:
            c_owner, c_basis = _b28_correlate_owner(ref_ts=event_ts or int(time.time() * 1000), max_age_ms=1800000)
            if c_owner:
                owner = c_owner
                hook_method = None
                hook_match = "correlate-%s" % c_basis
                meta = {"n": 0, "status": hook_match, "basis": c_basis}
                _log("Block#28 attribution via correlation (%s): %r" % (hook_match, owner))
        except Exception:
            pass
    return owner, hook_method, hook_match, meta

def _b28_correlate_owner(ref_ts=None, max_age_ms=None):
    try:
        p = _leak_verdict_path()
        _rp = _rc_read_path(p) if p else None
        if not _rp:
            return None, None
        with open(_rp, "r", encoding="utf-8") as f:
            recs = list(json.load(f))
        owners = []
        views_by_owner = {}
        for r in recs:
            if not isinstance(r, dict):
                continue
            c = r.get("culprit"); conf = r.get("confidence")
            if not (c and c != _UNTAGGED_LABEL and c != _SELF_ID and c != __id__
                    and conf in ("high", "medium")):
                continue
            if ref_ts is not None and max_age_ms is not None:
                try:
                    lt = int(r.get("ts") or 0)
                    if lt and abs(lt - int(ref_ts)) > max_age_ms:
                        continue
                except Exception:
                    pass
            if c not in owners:
                owners.append(c)
            try:
                _v = int(r.get("leaked_views") or 0)
            except Exception:
                _v = 0
            if _v <= 0: _v = 1
            views_by_owner[c] = views_by_owner.get(c, 0) + _v
        if len(owners) == 1:
            return owners[0], "view-leak"
        if len(owners) > 1:
            try:
                _tot = sum(views_by_owner.values())
                if _tot > 0:
                    _dom = max(views_by_owner, key=lambda k: views_by_owner[k])
                    if views_by_owner[_dom] >= 0.8 * _tot:
                        return _dom, "view-leak-dominant"
            except Exception:
                pass
    except Exception:
        pass
    return None, None

def _b28_reattribute_untagged():
    _PERSIST_IO_LOCK.acquire()
    try:
        try:
            p = _globalref_path()
            _rp = _rc_read_path(p) if p else None
            if not _rp:
                return
            with open(_rp, "r", encoding="utf-8") as f:
                recs = list(json.load(f))
        except Exception:
            return
        changed = False
        for rec in recs:
            try:
                if not isinstance(rec, dict):
                    continue
                if rec.get("kind") != "jni-globalref-leak":
                    continue
                if rec.get("culprit_kind") != "untagged":
                    continue
                owner = None; basis = None
                try:
                    rec_hm = rec.get("hot_method")
                    cand = []
                    for pid, rr in (_b28_load_persisted_hooks() or {}).items():
                        if not pid or pid == _SELF_ID or pid == __id__:
                            continue
                        ms = rr.get("methods") if isinstance(rr, dict) else rr
                        ms = [m for m in (ms or []) if m in _B28_HOT_METHODS]
                        if rec_hm:
                            if rec_hm in ms:
                                ts = int(rr.get("ts") or 0) if isinstance(rr, dict) else 0
                                cand.append((pid, [rec_hm], ts))
                        elif ms:
                            ts = int(rr.get("ts") or 0) if isinstance(rr, dict) else 0
                            cand.append((pid, ms, ts))
                    if cand:
                        if rec_hm and len(cand) > 1:
                            _hw = _b28_hit_winner(rec_hm, [c[0] for c in cand], ref_ts=rec.get("ts"), max_age_ms=1800000)
                            if _hw:
                                owner = _hw
                                basis = "reg-hits"
                                rec["hook_method"] = rec_hm
                        elif rec_hm or len(cand) == 1:
                            cand.sort(key=lambda c: c[2], reverse=True)
                            owner = cand[0][0]
                            basis = "reg-persist" if rec_hm else "reg-persist-uniq"
                            rec["hook_method"] = cand[0][1][0]
                except Exception:
                    pass
                if owner is None:
                    pp, _pb = _b28_proxy_producer(ref_ts=rec.get("ts"), max_age_ms=1800000)
                    if pp:
                        owner = pp; basis = "proxy-producer"
                if owner is None:
                    c_owner, c_basis = _b28_correlate_owner(ref_ts=rec.get("ts"), max_age_ms=1800000)
                    if c_owner:
                        owner = c_owner; basis = "correlate-%s" % c_basis
                if not owner:
                    continue
                rec["culprit"] = owner
                rec["culprit_kind"] = "plugin:%s" % owner
                rec["hook_owner"] = owner
                rec["hook_match"] = basis
                if rec.get("confidence") == "low":
                    rec["confidence"] = "medium"
                if basis == "proxy-producer":
                    rec["confidence"] = "high"
                    rec["reason"] = ("плагин создаёт/удерживает множество JNI global-ref без освобождения (мост Chaquopy Java<->Python: dynamic_proxy и/или Class/PyObject-ссылки) -> таблица global-ссылок переполнилась (max=%s), ART аварийно завершил процесс [виновник определён прямым нативным трекером создания JNI global-ref (NewGlobalRef)]" % rec.get("max"))
                    rec["where"] = "мост Chaquopy (JNI NewGlobalRef)"
                elif str(basis).startswith("correlate"):
                    rec["reason"] = ("плагин создаёт множество Chaquopy dynamic_proxy объектов (Java<->Python колбэки), каждый удерживает JNI global-ref без освобождения -> таблица global-ссылок переполнилась (max=%s), ART аварийно завершил процесс [виновник по корреляции с одновременной утечкой того же плагина в этом краше]" % rec.get("max"))
                    rec["where"] = "Chaquopy dynamic_proxy (Java<->Python колбэки)"
                changed = True
                try: _log("Block#28 reattribute untagged -> %r (%s)" % (owner, basis))
                except Exception: pass
            except Exception:
                pass
        if changed:
            try: _atomic_json_write(p, recs, _GLOBALREF_FAILS_MAX)
            except Exception: pass
    finally:
        try: _PERSIST_IO_LOCK.release()
        except Exception: pass

def _b28_signature(parsed, dom_type):
    af = (parsed.get("alloc_frames") or [])
    first = af[0] if af else ""
    return "ovf|max=%s|%s|%s" % (parsed.get("max"), dom_type, first)

def _b28_build_verdict(block, event_ts=None):
    parsed = _b28_parse_dump(block)
    dom_type, dom_count, dom_share = _b28_dominant_type(parsed)
    hot_method, frames = _b28_hot_method(parsed)
    is_proxy = bool(dom_type and ("Proxy_Object" in dom_type or "plugins.Proxy" in dom_type))
    owner, hook_method, hook_match, meta = _b28_attribute(parsed, hot_method, event_ts)
    method_for_msg = hook_method or hot_method or "?"
    produced = bool(hook_match == "proxy-producer")
    if owner and (dom_share >= 0.8 or produced):
        conf = "high"
    elif owner:
        conf = "medium"
    elif dom_share >= 0.8:
        conf = "medium"
    else:
        conf = "low"
    if owner:
        culprit = owner
        culprit_kind = "plugin:%s" % owner
    elif hot_method:
        culprit = "хук на %s" % hot_method
        culprit_kind = "untagged"
    else:
        culprit = globals().get("_UNTAGGED_LABEL", "неизвестный плагин")
        culprit_kind = "untagged"
    share_pct = int(round(dom_share * 100))
    correlated = bool(hook_match and str(hook_match).startswith("correlate"))
    proxy_leak = bool(correlated or produced or is_proxy or (owner and not hook_method))
    if proxy_leak:
        reason = ("плагин создаёт множество Chaquopy dynamic_proxy объектов "
                  "(Java<->Python колбэки), каждый удерживает JNI global-ref без "
                  "освобождения -> таблица global-ссылок переполнилась (max=%s), "
                  "ART аварийно завершил процесс" % parsed.get("max"))
        where = "Chaquopy dynamic_proxy (Java<->Python колбэки)"
    elif hook_method or hot_method:
        reason = ("плагин хукнул горячий метод рендера %s и на каждый вызов "
                  "оставляет JNI global-ref (Chaquopy Proxy_Object) без DeleteGlobalRef "
                  "-> таблица global-ссылок переполнилась (max=%s), ART аварийно "
                  "завершил процесс" % (method_for_msg, parsed.get("max")))
        where = "%s (хук плагина, мост Chaquopy)" % method_for_msg
    else:
        reason = ("плагин удерживает JNI global-ref (Chaquopy Proxy_Object/Class) без "
                  "освобождения -> таблица global-ссылок переполнилась (max=%s), ART "
                  "аварийно завершил процесс" % parsed.get("max"))
        where = "мост Chaquopy (JNI NewGlobalRef)"
    if dom_type:
        reason += " — %d%% таблицы заняты %s" % (share_pct, dom_type.rsplit(".", 1)[-1])
    if correlated:
        reason += (" [виновник определён по корреляции с одновременной "
                   "утечкой того же плагина в этом краше]")
    elif produced:
        reason += " [виновник определён прямым трекером создания dynamic_proxy]"
    rec = {
        "had_globalref_overflow": True,
        "culprit": culprit,
        "culprit_kind": culprit_kind,
        "confidence": conf,
        "kind": "jni-globalref-leak",
        "src": "globalref-dump",
        "reason": reason,
        "where": where,
        "exc_cls": "JniGlobalRefTableOverflow",
        "exc_msg": "global reference table overflow (max=%s)" % parsed.get("max"),
        "max": parsed.get("max"),
        "dominant_type": dom_type,
        "dominant_count": dom_count,
        "dominant_share": round(dom_share, 4),
        "is_proxy_object": is_proxy,
        "hot_method": hot_method,
        "hook_owner": owner,
        "hook_method": hook_method,
        "hook_match": hook_match,
        "hook_meta": meta,
        "ts": int(time.time() * 1000),
        "event_ts": event_ts,
    }
    try:
        _ps = globals().get("_PROC_START_MS") or 0
        if event_ts and _ps:
            rec["age_ms"] = max(0, int(_ps) - int(event_ts))
            rec["stale_echo"] = bool((int(_ps) - int(event_ts)) > _B28_STALE_ECHO_MS)
        else:
            rec["age_ms"] = None; rec["stale_echo"] = False
    except Exception:
        rec["age_ms"] = None; rec["stale_echo"] = False
    return rec, parsed

def _b28_write_verdict(rec):
    _PERSIST_IO_LOCK.acquire()
    try:
        p = _globalref_path()
        if not p: return
        try:
            cur = []
            _rp = _rc_read_path(p)
            if _rp:
                try:
                    with open(_rp, "r", encoding="utf-8") as f: cur = list(json.load(f))
                except Exception: cur = []
            try:
                _sig = rec.get("sig"); _mx = rec.get("max"); _tagged = bool(rec.get("hook_owner"))
                def _keep(c):
                    if _sig and c.get("sig") == _sig: return False
                    if _tagged and c.get("culprit_kind") == "untagged" and c.get("max") == _mx: return False
                    return True
                cur = [c for c in cur if _keep(c)]
            except Exception: pass
            cur.append(rec)
            _atomic_json_write(p, cur, _GLOBALREF_FAILS_MAX)
        except Exception:
            pass
        try:
            _log("============ JNI GLOBALREF-OVERFLOW VERDICT (Block#28) ============")
            _log("ВИНОВНИК УТЕЧКИ JNI-ССЫЛОК: %r conf=%s метод=%s тип=%s (%d%%)" % (
                rec.get("culprit"), rec.get("confidence"), rec.get("hot_method"),
                (rec.get("dominant_type") or "?").rsplit(".", 1)[-1],
                int(round((rec.get("dominant_share") or 0) * 100))))
            _log("  max=%s match4A=%s метод4A=%s" % (rec.get("max"), rec.get("hook_match"), rec.get("hook_method")))
            _log("  причина: %s" % rec.get("reason"))
            _log("==================================================================")
        except Exception:
            pass
    finally:
        try: _PERSIST_IO_LOCK.release()
        except Exception: pass

def _b28_prune_stale_verdicts():
    _PERSIST_IO_LOCK.acquire()
    try:
        try:
            p = _globalref_path()
            _rp = _rc_read_path(p) if p else None
            if not _rp: return
            with open(_rp, "r", encoding="utf-8") as f: recs = list(json.load(f))
        except Exception:
            return
        ps = globals().get("_PROC_START_MS") or 0
        keep = []; drop = []
        for rec in recs:
            try:
                if not isinstance(rec, dict) or rec.get("kind") != "jni-globalref-leak":
                    keep.append(rec); continue
                stale = bool(rec.get("stale_echo"))
                if not stale and ps:
                    base = rec.get("event_ts") or rec.get("ts")
                    if base and (int(ps) - int(base)) > _B28_STALE_ECHO_MS:
                        stale = True
                (drop if stale else keep).append(rec)
            except Exception:
                keep.append(rec)
        if not drop: return
        try: _atomic_json_write(p, keep, _GLOBALREF_FAILS_MAX)
        except Exception: pass
        try:
            hp = File(_DIR, "globalref_history.json").getAbsolutePath()
            hist = []
            _hrp = _rc_read_path(hp)
            if _hrp:
                try:
                    with open(_hrp, "r", encoding="utf-8") as f: hist = list(json.load(f))
                except Exception: hist = []
            hist += drop
            _atomic_json_write(hp, hist[-_GLOBALREF_SEEN_MAX:], _GLOBALREF_SEEN_MAX)
        except Exception: pass
    finally:
        try: _PERSIST_IO_LOCK.release()
        except Exception: pass

def _read_globalref_overflow(logcat=True):
    if not _BLOCK28_ON: return None
    _GREF_READ_LOCK.acquire()
    try:
        try: _b28_reattribute_untagged()
        except Exception: pass
        texts = []
        try: texts += _b28_read_drop_files()
        except Exception: pass
        if logcat:
            try: texts += _b28_read_logcat()
            except Exception: pass
        if not texts: return None
        seen = _b28_load_seen()
        new_sigs = list(seen)
        last_rec = None
        changed = False
        seen_changed = False
        for t in texts:
            block, ev_ts = _b28_extract_overflow_block(t)
            if not block: continue
            rec, parsed = _b28_build_verdict(block, event_ts=ev_ts)
            sig = _b28_signature(parsed, rec.get("dominant_type"))
            rec["sig"] = sig
            is_tagged = bool(rec.get("hook_owner"))
            tag_key = sig + "#tagged"
            ev_key = ("evt:%s:%s" % (sig, ev_ts)) if ev_ts else None
            if ev_key and ev_key in new_sigs:
                continue
            if rec.get("stale_echo"):
                try: _log("Block#28: старый logcat-эхо overflow (событие ~%.1f мин до старта) — подавлено, не текущая утечка" % ((rec.get("age_ms") or 0) / 60000.0))
                except Exception: pass
                if ev_key:
                    new_sigs.append(ev_key); seen_changed = True
                continue
            seen_sig = sig in new_sigs
            seen_tagged = tag_key in new_sigs
            if seen_sig and (not is_tagged or seen_tagged):
                continue
            if not seen_sig:
                new_sigs.append(sig); seen_changed = True
            if is_tagged and not seen_tagged:
                new_sigs.append(tag_key); seen_changed = True
            if ev_key and ev_key not in new_sigs:
                new_sigs.append(ev_key); seen_changed = True
            changed = True
            _b28_write_verdict(rec)
            last_rec = rec
        if changed or seen_changed:
            _b28_save_seen(new_sigs)
        try:
            _b28_prune_stale_verdicts()
        except Exception: pass
        return last_rec
    except Exception as e:
        try: _log("Block#28 read err: %s" % e)
        except Exception: pass
        return None
    finally:
        try: _GREF_READ_LOCK.release()
        except Exception: pass

def _b28_hot_hook_owners():
    out = {}
    try:
        omap, n, status = _build_hook_owner_map()
        for key, owner in (omap or {}).items():
            if not owner:
                continue
            try:
                mth = str(key).rsplit(".", 1)[-1]
            except Exception:
                continue
            if mth in _B28_HOT_METHODS:
                out.setdefault(owner, [])
                if mth not in out[owner]:
                    out[owner].append(mth)
    except Exception:
        pass
    try:
        with _B28_HOOK_REG_LOCK:
            reg = dict(_B28_HOOK_REG)
        for owner, methods in reg.items():
            if not owner:
                continue
            out.setdefault(owner, [])
            for mth in methods or []:
                if mth in _B28_HOT_METHODS and mth not in out[owner]:
                    out[owner].append(mth)
    except Exception:
        pass
    return out

def _b28_warn_scan(tag="periodic"):
    if not (_BLOCK28_ON and _B28_WARN_ON): return
    try:
        owners = _b28_hot_hook_owners()
        for owner, methods in owners.items():
            key = "%s|%s" % (owner, ",".join(sorted(methods)))
            if key in _B28_WARNED: continue
            _B28_WARNED.add(key)
            _log("⚠ Block#28 РАННЕЕ ПРЕДУПРЕЖДЕНИЕ (%s): плагин %r держит хук на горячем "
                 "методе рендера %s — каждый вызов рискует оставить JNI global-ref "
                 "(Proxy_Object). При утечке таблица дойдёт до предела (~51200) и ART "
                 "аварийно завершит процесс." % (tag, owner, ", ".join(methods)))
    except Exception as e:
        try: _log("Block#28 warn-scan err: %s" % e)
        except Exception: pass

def _b28_loop(stop):
    try: stop.wait(8.0)
    except Exception: pass
    while not stop.is_set():
        _b28_warn_scan("periodic")
        try:
            if stop.wait(_B28_WARN_PERIOD_S): break
        except Exception: break

def _b28_start():
    global _B28_THREAD
    if not _BLOCK28_ON:
        _log("Block#28: отключён (_BLOCK28_ON=False)"); return
    if _B28_THREAD is not None:
        return
    if not _B28_WARN_ON:
        _log("Block#28: пост-мортем включён, раннее предупреждение выключено"); return
    _B28_STOP.clear()
    _B28_THREAD = threading.Thread(target=_b28_loop, args=(_B28_STOP,), name="culprit-b28", daemon=True)
    _B28_THREAD.start()
    _log("Block#28: JNI globalref-overflow детектор активен (пост-мортем logcat/дамп + раннее предупреждение по хукам: %s)" % (", ".join(_B28_HOT_METHODS)))

def _b28_stop():
    global _B28_THREAD
    try:
        _B28_STOP.set()
        t = _B28_THREAD
        if t is not None:
            try: t.join(timeout=2.0)
            except Exception: pass
        _B28_THREAD = None
        _log("Block#28: остановлен")
    except Exception:
        pass

_B20_ON = True
_B20_PING_MS = 2000
_B20_TIMEOUT_MS = 4500
_B20_IDLE_CPU_MAX = 25.0
_B20_STOP = threading.Event()
_B20_THREAD = None
_B20_UI_TID = None
_B20_INFLIGHT = False
_B20_INFLIGHT_SINCE = 0.0
_B20_REPORTED = False
_B20_HANDLER = None
_B20_PING = None
_B20_LOCK = threading.Lock()
_B20_MAX_PLAUSIBLE_MS = 15000
_B20_CLOCK = None
_B20_NATIVE = False

def _b20_uptime_ms():
    global _B20_CLOCK
    try:
        if _B20_CLOCK is None:
            from java import jclass as _jc
            _B20_CLOCK = _jc("android.os.SystemClock")
        return float(_B20_CLOCK.uptimeMillis())
    except Exception:
        return None

def _b20_now_ms():
    v = _b20_uptime_ms()
    if v is not None:
        return v
    try: return time.monotonic() * 1000.0
    except Exception: return time.time() * 1000.0

def _b20_anr_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _ANR_FILE_NAME).getAbsolutePath()
    except Exception:
        return None

def _b20_ack():
    global _B20_UI_TID, _B20_INFLIGHT, _B20_REPORTED
    try:
        if _B20_UI_TID is None:
            _B20_UI_TID = int(threading.get_ident())
            _log("Block#20: UI thread tid=%s captured" % _B20_UI_TID)
            try:
                native_ui_tid = _cur_tid()
                globals()["_B33_UI_TID"] = native_ui_tid
                if globals().get("_SELF_NATIVE_OK") and _NLIB is not None and hasattr(_NLIB, "cd_self_set_ui_tid"):
                    _NLIB.cd_self_set_ui_tid(ctypes.c_int64(int(native_ui_tid)))
            except Exception as _e33:
                _log("Block#33: UI tid pass err: %s" % _e33)
        _B20_INFLIGHT = False
        _B20_REPORTED = False
        if _B20_NATIVE and _NLIB is not None:
            try: _NLIB.cd_anr_ack()
            except Exception: pass
    except Exception:
        pass

def _b20_setup_handler():
    global _B20_HANDLER, _B20_PING
    try:
        from java import jclass as _jc, dynamic_proxy as _dp
    except Exception as e:
        _log("Block#20: java bridge unavailable: %r" % e); return False
    try:
        Looper = _jc("android.os.Looper")
        Handler = _jc("android.os.Handler")
        main = Looper.getMainLooper()
        if main is None:
            _log("Block#20: getMainLooper() is None"); return False
        _B20_HANDLER = Handler(main)
    except Exception as e:
        _log("Block#20: Handler(mainLooper) build err: %r" % e); return False
    try:
        Runnable = _jc("java.lang.Runnable")
        class _B20Ping(_dp(Runnable)):
            def run(self):
                _b20_ack()
        _B20_PING = _B20Ping()
    except Exception as e:
        _log("Block#20: ping Runnable build err: %r" % e); return False
    return True

def _b20_post_ping():
    global _B20_INFLIGHT, _B20_INFLIGHT_SINCE
    try:
        ok = _B20_HANDLER.post(_B20_PING)
        if ok:
            _B20_INFLIGHT = True
            _B20_INFLIGHT_SINCE = _b20_now_ms()
            if _B20_NATIVE and _NLIB is not None:
                try: _NLIB.cd_anr_ping()
                except Exception: pass
    except Exception as e:
        _log("Block#20: post ping err: %r" % e)

def _b20_pid_of_frame_mod(mod):
    if not mod or mod == _SELF_ID or mod == __id__:
        return None
    try:
        mobj = _sys.modules.get(mod)
        cand = getattr(mobj, "__id__", None) if mobj is not None else None
        if not (isinstance(cand, str) and cand):
            try:
                c2 = _canon_pid(mod)
                if isinstance(c2, str) and c2 and c2 != mod:
                    cand = c2
            except Exception:
                pass
        if isinstance(cand, str) and cand and cand != _SELF_ID and cand != __id__:
            return cand
    except Exception:
        pass
    return None

def _b20_capture_culprit(fr):
    deepest = None
    stack = []
    f = fr; hops = 0
    while f is not None and hops < 60:
        try:
            g = f.f_globals
            mod = g.get("__name__") or ""
            fn = g.get("__file__") or ((mod + ".py") if mod else "?")
            ln = f.f_lineno
            nm = f.f_code.co_name
        except Exception:
            mod = ""; fn = "?"; ln = -1; nm = "?"
        stack.append("%s:%s %s" % (fn, ln, nm))
        if deepest is None:
            pid = _b20_pid_of_frame_mod(mod)
            if pid:
                deepest = (pid, fn, int(ln) if ln is not None else -1)
        try: f = f.f_back
        except Exception: f = None
        hops += 1
    return deepest, stack[:25]

def _persist_anr_fail(rec):
    p = _b20_anr_path()
    if not p:
        _log("Block#20: нет пути -- пропуск"); return
    _PERSIST_IO_LOCK.acquire()
    try:
        cur = []
        if os.path.exists(p):
            try:
                with open(p, "r", encoding="utf-8") as f: cur = list(json.load(f))
            except Exception: cur = []
        cur.append(rec)
        _atomic_json_write(p, cur, 20)
        _log("Block#20: anr verdict zapisan (%d zapisej) -> %s" % (len(cur), _ANR_FILE_NAME))
    except Exception as e:
        _log("Block#20: verdict persist err: %s: %s" % (type(e).__name__, e))
    finally:
        try: _PERSIST_IO_LOCK.release()
        except Exception: pass

def _b20_owner_from_op(window_ms):
    try:
        if not (_OP_NATIVE_OK and _NLIB is not None and _CTYPES_OK and hasattr(_NLIB, "cd_op_read")):
            return None
    except Exception:
        return None
    best = None
    try:
        ob = ctypes.create_string_buffer(_OP_OWNER_MAX)
        ab = ctypes.create_string_buffer(_OP_API_MAX)
        for _dn, _di in _OP_DOMAIN_IDX.items():
            try:
                age = int(_NLIB.cd_op_read(ctypes.c_int32(_di), ob, ctypes.c_int32(_OP_OWNER_MAX), ab, ctypes.c_int32(_OP_API_MAX)))
            except Exception:
                continue
            if age < 0 or age > int(window_ms):
                continue
            own = ob.value.decode("utf-8", "replace") if ob.value else ""
            if not own:
                continue
            if own[:1] == "#" and own[1:].isdigit():
                _nm = _resolve_idx(int(own[1:]))
                if not (isinstance(_nm, str) and _nm):
                    _nm = _resolve_idx_durable(int(own[1:]))
                own = _nm if (isinstance(_nm, str) and _nm) else ""
            if not own:
                continue
            try: own = _canon_pid(own)
            except Exception: pass
            if not isinstance(own, str) or not own or own == _SELF_ID or own == __id__:
                continue
            api = ab.value.decode("utf-8", "replace") if ab.value else ""
            if api == "dispatchMessage":
                continue
            if best is None or age < best[0]:
                best = (age, _dn, own, api)
    except Exception:
        return None
    if best is None:
        return None
    return {"owner": best[2], "domain": best[1], "api": best[3], "age_ms": best[0]}

def _b20_owner_from_scope():
    try:
        if not (_ANR_NATIVE_OK and _NLIB is not None and hasattr(_NLIB, "cd_anr_owner")):
            return None
        idx = int(_NLIB.cd_anr_owner())
    except Exception:
        return None
    if idx is None or idx < 0:
        return None
    nm = _resolve_idx(idx)
    if not (isinstance(nm, str) and nm):
        nm = _resolve_idx_durable(idx)
    if not (isinstance(nm, str) and nm):
        return None
    try: nm = _canon_pid(nm)
    except Exception: pass
    if not isinstance(nm, str) or not nm or nm == _SELF_ID or nm == __id__:
        return None
    return nm

_B29_ON = True
_B29_PERIOD_S = 3.0
_B29_MIN_PCT = 1.0
_B29_TOP_N = 8
_B29_HOG_PCT = 60.0
_B29_STALE_MS = 8000
_B29_STOP = threading.Event()
_B29_THREAD = None
_B29_LOCK = threading.Lock()
_B29_LAST = None
_B29_CLK_TCK = None

def _b29_clk_tck():
    global _B29_CLK_TCK
    if _B29_CLK_TCK is None:
        try: _B29_CLK_TCK = float(os.sysconf(os.sysconf_names["SC_CLK_TCK"]))
        except Exception: _B29_CLK_TCK = 100.0
    return _B29_CLK_TCK

def _b29_read_thread(path):
    with open(path + "/stat", "r") as f:
        data = f.read()
    op = data.find("("); cp = data.rfind(")")
    rest = data[cp + 1:].split()
    ticks = int(rest[11]) + int(rest[12])
    name = data[op + 1:cp] if (op >= 0 and cp > op) else "?"
    return ticks, name

def _b29_raw_snapshot(pid):
    out = {}
    try:
        base = "/proc/%d/task" % pid
        for tid in os.listdir(base):
            try:
                t, nm = _b29_read_thread(base + "/" + tid)
                out[int(tid)] = (t, nm)
            except (FileNotFoundError, ProcessLookupError, OSError, ValueError):
                continue
    except (FileNotFoundError, ProcessLookupError, OSError):
        pass
    return out

def _b29_compute(prev, cur, elapsed_s):
    tbl = {}
    if elapsed_s <= 0: return tbl
    clk = _b29_clk_tck()
    for tid, (t2, nm) in cur.items():
        if tid not in prev:
            tbl[tid] = (0.0, nm)
            continue
        t1 = prev[tid][0]
        d = t2 - t1
        if d < 0: d = 0
        pct = (d / clk) * 100.0 / elapsed_s
        tbl[tid] = (pct, nm)
    return tbl

def _b29_loop(stop):
    pid = os.getpid()
    prev = _b29_raw_snapshot(pid); prev_t = time.monotonic()
    while not stop.is_set():
        if stop.wait(_B29_PERIOD_S): break
        try:
            cur = _b29_raw_snapshot(pid); now = time.monotonic()
            tbl = _b29_compute(prev, cur, now - prev_t)
            with _B29_LOCK:
                globals()["_B29_LAST"] = {"tbl": tbl, "ts": int(time.time() * 1000),
                                          "win_ms": int((now - prev_t) * 1000.0)}
            prev = cur; prev_t = now
        except Exception as e:
            try: _log("Block#29 loop err: %r" % e)
            except Exception: pass

_GIL_B29, _GIL_B27, _GIL_B6, _GIL_B31, _GIL_B20, _GIL_B28, _GIL_OTHER = 0, 1, 2, 3, 4, 5, 6
_GIL_SLOT_NAMES = ["b29_cpu", "b27_reaper", "b6_oom", "b31_wd", "b20_anr", "b28_corr", "other"]
_B33_GIL_PREV = None

def _gil_begin(slot):
    if _GIL_NATIVE_OK and _NLIB is not None:
        try: _NLIB.cd_gil_mark_begin(int(slot))
        except Exception: pass

def _gil_end(slot):
    if _GIL_NATIVE_OK and _NLIB is not None:
        try: _NLIB.cd_gil_mark_end(int(slot))
        except Exception: pass

def _b33_read_gil_holders(period_s):
    global _B33_GIL_PREV
    if not (_GIL_NATIVE_OK and _NLIB is not None):
        return None
    try:
        n = int(_NLIB.cd_gil_slots())
        if n <= 0: return None
        buf = (ctypes.c_int64 * (n * 3))()
        got = int(_NLIB.cd_gil_hold(buf, n * 3))
        rows = [(int(buf[i*3+0]), int(buf[i*3+1]), int(buf[i*3+2])) for i in range(max(0, got))]
        prev = _B33_GIL_PREV
        _B33_GIL_PREV = rows
        out = []
        for i, (hns, cnt, mx) in enumerate(rows):
            p = prev[i] if (prev and i < len(prev)) else (0, 0, 0)
            dh = hns - p[0]; dc = cnt - p[1]
            if dh < 0: dh = 0
            if dc < 0: dc = 0
            if dh == 0 and dc == 0: continue
            nm = _GIL_SLOT_NAMES[i] if i < len(_GIL_SLOT_NAMES) else ("slot%d" % i)
            out.append({"src": nm,
                        "held_ms_per_s": round((dh / 1e6) / max(0.001, period_s), 2),
                        "holds": int(dc),
                        "max_ms": round(mx / 1e6, 2)})
        out.sort(key=lambda r: r["held_ms_per_s"], reverse=True)
        return out or None
    except Exception:
        return None

class _CdCpuRow(ctypes.Structure):
    _fields_ = [("tid", ctypes.c_int32), ("owner_idx", ctypes.c_int32),
                ("milli_pct", ctypes.c_int32), ("_pad", ctypes.c_int32),
                ("comm", ctypes.c_char * 16)]

def _b29_owner_from_idx(idx, tid):
    if idx is None or idx < 0:
        try: idx = _reg_get(int(tid))
        except Exception: idx = None
    if idx is None or idx < 0: return None
    nm = _resolve_idx(idx)
    if not (isinstance(nm, str) and nm):
        nm = _resolve_idx_durable(idx)
    if not (isinstance(nm, str) and nm): return None
    try: nm = _canon_pid(nm)
    except Exception: pass
    if not isinstance(nm, str) or not nm or nm == _SELF_ID or nm == __id__:
        return None
    return nm

def _b29_native_read():
    if not (_CPU_NATIVE_OK and _NLIB is not None):
        return None
    try:
        addr = int(_NLIB.cd_cpu_rows_addr())
        rsz = int(_NLIB.cd_cpu_row_size())
        cap = int(_NLIB.cd_cpu_max())
        if addr == 0 or rsz != ctypes.sizeof(_CdCpuRow) or cap <= 0:
            return None
        arr_t = _CdCpuRow * cap
        for _att in range(8):
            s1 = int(_NLIB.cd_cpu_seq())
            if s1 & 1:
                time.sleep(0.0005); continue
            cnt = int(_NLIB.cd_cpu_count())
            if cnt < 0: cnt = 0
            if cnt > cap: cnt = cap
            win = int(_NLIB.cd_cpu_win_ms())
            ts = int(_NLIB.cd_cpu_ts_ms())
            arr = arr_t.from_address(addr)
            raw = [(int(arr[i].tid), int(arr[i].owner_idx), int(arr[i].milli_pct),
                    arr[i].comm.decode("utf-8", "replace")) for i in range(cnt)]
            s2 = int(_NLIB.cd_cpu_seq())
            if s1 == s2:
                age = (int(time.time() * 1000) - ts) if ts else (1 << 30)
                rows = []
                for tid, oidx, mpct, nm in raw:
                    pct = mpct / 1000.0
                    if pct < _B29_MIN_PCT: continue
                    rows.append({"tid": tid, "name": nm, "pct": round(pct, 1),
                                 "owner": _b29_owner_from_idx(oidx, tid)})
                return rows[:_B29_TOP_N], {"age_ms": age, "win_ms": win}
            time.sleep(0.0003)
        return None
    except Exception:
        return None

def _b29_owner_of_tid(tid):
    try:
        idx = _reg_get(int(tid))
    except Exception:
        idx = None
    if idx is None or idx < 0: return None
    nm = _resolve_idx(idx)
    if not (isinstance(nm, str) and nm):
        nm = _resolve_idx_durable(idx)
    if not (isinstance(nm, str) and nm): return None
    try: nm = _canon_pid(nm)
    except Exception: pass
    if not isinstance(nm, str) or not nm or nm == _SELF_ID or nm == __id__:
        return None
    return nm

def _b29_cpu_top():
    if _CPU_NATIVE_OK and _NLIB is not None:
        _nr = _b29_native_read()
        if _nr is not None: return _nr
    snap = None
    with _B29_LOCK:
        if _B29_LAST is not None:
            snap = {"tbl": dict(_B29_LAST["tbl"]), "ts": _B29_LAST["ts"], "win_ms": _B29_LAST.get("win_ms")}
    if not snap: return [], None
    age = int(time.time() * 1000) - snap["ts"]
    rows = []
    for tid, (pct, nm) in snap["tbl"].items():
        if pct < _B29_MIN_PCT: continue
        rows.append({"tid": int(tid), "name": nm, "pct": round(float(pct), 1),
                     "owner": _b29_owner_of_tid(tid)})
    rows.sort(key=lambda r: r["pct"], reverse=True)
    return rows[:_B29_TOP_N], {"age_ms": age, "win_ms": snap.get("win_ms")}

def _b29_fresh_top(window_ms=160):
    if _CPU_NATIVE_OK and _NLIB is not None:
        try: _NLIB.cd_cpu_sample_now(int(window_ms))
        except Exception: pass
        _nr = _b29_native_read()
        if _nr is not None:
            try: _nr[1]["age_ms"] = 0
            except Exception: pass
            return _nr
    pid = os.getpid()
    try:
        s1 = _b29_raw_snapshot(pid); t1 = time.monotonic()
        time.sleep(max(0.05, float(window_ms) / 1000.0))
        s2 = _b29_raw_snapshot(pid); t2 = time.monotonic()
    except Exception:
        return [], None
    tbl = _b29_compute(s1, s2, t2 - t1)
    rows = []
    for tid, (pct, nm) in tbl.items():
        if pct < _B29_MIN_PCT: continue
        rows.append({"tid": int(tid), "name": nm, "pct": round(float(pct), 1),
                     "owner": _b29_owner_of_tid(tid)})
    rows.sort(key=lambda r: r["pct"], reverse=True)
    return rows[:_B29_TOP_N], {"age_ms": 0, "win_ms": int((t2 - t1) * 1000.0)}

def _b29_hog_culprit(rows, meta):
    if not rows or meta is None: return None
    if meta.get("age_ms", 1 << 30) > _B29_STALE_MS: return None
    top = rows[0]
    if top.get("owner") and top["pct"] >= _B29_HOG_PCT:
        if len(rows) == 1 or rows[1]["pct"] < top["pct"] * 0.5 or rows[1].get("owner") == top["owner"]:
            return {"owner": top["owner"], "pct": top["pct"], "tid": top["tid"],
                    "name": top["name"], "age_ms": meta.get("age_ms")}
    return None

_B29_CORROB_PCT = 35.0

def _b29_top_owned_by(rows, owner):
    if not rows or not owner:
        return None
    best = None
    for r in (rows or []):
        try:
            if r.get("owner") == owner and float(r.get("pct") or 0.0) >= _B29_CORROB_PCT:
                if best is None or r["pct"] > best["pct"]:
                    best = r
        except Exception:
            continue
    return best


def _b29_start():
    global _B29_THREAD
    if not _B29_ON:
        _log("Block#29: disabled"); return
    if _CPU_NATIVE_OK and _NLIB is not None:
        try:
            _rc = int(_NLIB.cd_cpu_start(int(_B29_PERIOD_S * 1000), int(_B29_MIN_PCT * 1000), int(_B29_TOP_N)))
            _log("Block#29 native CPU sampler: start rc=%d period=%.1fs (off-GIL, +DR Lever 1)" % (_rc, _B29_PERIOD_S))
            return
        except Exception as _e:
            _log("Block#29 native start failed (%r) -> python fallback" % _e)
    try:
        os.listdir("/proc/%d/task" % os.getpid())
    except Exception as e:
        _log("Block#29: /proc/task unavailable (%r) -> CPU snapshot OFF" % e); return
    _B29_STOP.clear()
    _B29_THREAD = threading.Thread(target=_b29_loop, args=(_B29_STOP,), name="culprit-cpu", daemon=True)
    _B29_THREAD.start()
    _log("Block#29 per-thread CPU snapshot: start period=%.1fs min_pct=%.1f hog_pct=%.1f" % (
        _B29_PERIOD_S, _B29_MIN_PCT, _B29_HOG_PCT))

def _b29_stop():
    global _B29_THREAD
    try:
        if _CPU_NATIVE_OK and _NLIB is not None:
            try: _NLIB.cd_cpu_stop()
            except Exception: pass
        _B29_STOP.set()
        t = _B29_THREAD
        if t is not None: t.join(timeout=2.0)
        _B29_THREAD = None
    except Exception: pass

_BLOCK33_ON = False
_B33_PERIOD_S = 2.0
_B33_LAST_EMIT = 0
_B33_EMIT_MIN_MS = 60000
_B33_UI_BUDGET_MS_PER_S = 8.0
_B33_TOTAL_BUDGET_MS_PER_S = 25.0
_B33_STRIKES_TO_DEGRADE = 3
_B33_RECOVER_WINDOWS = 10
_B33_SLOT_NAMES = ("malloc_tagger", "gref", "scope", "op_stamp", "looper", "signal", "other")
_B33_SNAP_MAXLEN = 128
_B33_GIL_GAP_BUDGET_MS_PER_S = 14.0
_B33_STOP = threading.Event()
_B33_THREAD = None
_B33_PREV = None
_B33_STRIKE = 0
_B33_OK_RUN = 0
_B33_LEVEL = 0
_B33_GREF_LEVEL = 0
_B33_GREF_DIVS = (128, 512, 2048)

def _b33_read_native():
    if not (_SELF_NATIVE_OK and _NLIB is not None and hasattr(_NLIB, "cd_self_snapshot")):
        return None
    try:
        buf = (ctypes.c_int64 * _B33_SNAP_MAXLEN)()
        n = int(_NLIB.cd_self_snapshot(buf, _B33_SNAP_MAXLEN))
        if n <= 0:
            return None
        rows = []
        for i in range(n):
            b = i * 4
            if b + 3 >= _B33_SNAP_MAXLEN:
                break
            rows.append([int(buf[b]), int(buf[b + 1]), int(buf[b + 2]), int(buf[b + 3])])
        return rows
    except Exception:
        return None

def _b33_read_ui_stall():
    if not (_SELF_NATIVE_OK and _NLIB is not None and hasattr(_NLIB, "cd_self_ui_stall")):
        return None
    try:
        buf = (ctypes.c_int64 * 8)()
        n = int(_NLIB.cd_self_ui_stall(buf, 8))
        if n <= 0:
            return None
        vals = [int(buf[i]) for i in range(min(n, 8))]
        while len(vals) < 8:
            vals.append(0)
        try:
            if hasattr(_NLIB, "cd_self_ui_stall_reset"):
                _NLIB.cd_self_ui_stall_reset()
        except Exception:
            pass
        return vals
    except Exception:
        return None

def _b33_emit(slots, ui_rate, total_rate, top, action, native, gil=None):
    global _B33_LAST_EMIT
    _now_emit = int(time.time() * 1000)
    if action is None and (_now_emit - _B33_LAST_EMIT) < _B33_EMIT_MIN_MS:
        return
    _B33_LAST_EMIT = _now_emit
    try:
        payload = {
            "ts": int(time.time() * 1000),
            "native": bool(native),
            "culprit": __id__,
            "label": "self-overhead",
            "ui_self_ms_per_s": round(ui_rate, 2),
            "total_self_ms_per_s": round(total_rate, 2),
            "ui_budget_ms_per_s": _B33_UI_BUDGET_MS_PER_S,
            "total_budget_ms_per_s": _B33_TOTAL_BUDGET_MS_PER_S,
            "degrade_level": _B33_LEVEL,
            "gref_level": _B33_GREF_LEVEL,
            "top_slot": (top or {}).get("slot"),
            "slots": slots,
        }
        if gil is not None:
            payload["gil"] = gil
        try:
            _vw = _vw_stats_snapshot()
            if _vw is not None:
                payload["vw"] = _vw
        except Exception:
            pass
        if action:
            payload["action"] = action
            payload["reason"] = str(action.get("detail") or "деградация функций для спасения FPS")
        else:
            payload["reason"] = "Превышен бюджет задержек (действий не предпринято)"
        p = _oom_path(_SELF_OVERHEAD_NAME)
        if p:
            _enqueue_verdict_write(p, payload, dedup=True)
    except Exception as e:
        try: _log("Block#33 emit err: %r" % e)
        except Exception: pass

def _b33_degrade_gref(ui_rate, total_rate):
    global _B33_GREF_LEVEL
    lvl = min(len(_B33_GREF_DIVS), _B33_GREF_LEVEL + 1)
    div = _B33_GREF_DIVS[lvl - 1]
    act = "gref self-timing sample 1/%d" % div
    try:
        if globals().get("_SELF_NATIVE_OK") and _NLIB is not None and hasattr(_NLIB, "cd_gref_set_time_div"):
            _NLIB.cd_gref_set_time_div(int(div))
        else:
            act = "gref relief unavailable (old .so)"
    except Exception as e:
        act = "gref relief failed: %r" % e
    _B33_GREF_LEVEL = lvl
    try: _log("Block#33 AUTO-DEGRADE gref-L%d (ui=%.1f total=%.1f ms/s top=gref): %s" % (lvl, ui_rate, total_rate, act))
    except Exception: pass
    return {"degrade_to": "gref-L%d" % lvl, "detail": act}

def _b33_recover_gref():
    global _B33_GREF_LEVEL
    lvl = _B33_GREF_LEVEL - 1
    div = _B33_GREF_DIVS[lvl - 1] if lvl >= 1 else 32
    act = "gref self-timing sample 1/%d" % div
    try:
        if globals().get("_SELF_NATIVE_OK") and _NLIB is not None and hasattr(_NLIB, "cd_gref_set_time_div"):
            _NLIB.cd_gref_set_time_div(int(div))
    except Exception: pass
    _B33_GREF_LEVEL = max(0, lvl)
    try: _log("Block#33 recover gref-L%d: %s" % (_B33_GREF_LEVEL, act))
    except Exception: pass
    return {"recover_to": "gref-L%d" % _B33_GREF_LEVEL, "detail": act}

def _b33_degrade(top_slot, ui_rate, total_rate):
    global _B33_LEVEL, _NA_MIN_BYTES, _B29_PERIOD_S, _NA_SAMPLE_DIV
    if top_slot == "gref":
        return _b33_degrade_gref(ui_rate, total_rate)
    lvl = _B33_LEVEL + 1
    act = None
    try:
        if lvl == 1:
            try:
                _NA_MIN_BYTES = int(_NA_MIN_BYTES) * 4
                if _NA_NATIVE_OK and _NLIB is not None and hasattr(_NLIB, "cd_na_enable"):
                    _NLIB.cd_na_enable(1, int(_NA_MIN_BYTES))
                _NA_SAMPLE_DIV = 8
                if _NA_NATIVE_OK and _NLIB is not None and hasattr(_NLIB, "cd_na_set_sample_div"):
                    _NLIB.cd_na_set_sample_div(int(_NA_SAMPLE_DIV))
                act = "raise _NA_MIN_BYTES->%d + sample 1/%d (malloc-tagger coarser)" % (_NA_MIN_BYTES, _NA_SAMPLE_DIV)
            except Exception as e:
                act = "na raise failed: %r" % e
        elif lvl == 2:
            try:
                _B29_PERIOD_S = min(12.0, float(_B29_PERIOD_S) * 2.0)
                act = "Block29 CPU sampler period->%.1fs" % _B29_PERIOD_S
            except Exception as e:
                act = "b29 throttle failed: %r" % e
        else:
            lvl = 3
            try:
                if _NA_NATIVE_OK and _NLIB is not None and hasattr(_NLIB, "cd_na_enable"):
                    _NLIB.cd_na_enable(0, 0)
                act = "malloc-tagger DISABLED (cd_na_enable 0)"
            except Exception as e:
                act = "na disable failed: %r" % e
    except Exception as e:
        act = "degrade err: %r" % e
    _B33_LEVEL = min(3, lvl)
    try: _log("Block#33 AUTO-DEGRADE L%d (ui=%.1f total=%.1f ms/s top=%s): %s" % (
        _B33_LEVEL, ui_rate, total_rate, top_slot, act))
    except Exception: pass
    return {"degrade_to": _B33_LEVEL, "detail": act}

def _b33_recover():
    global _B33_LEVEL, _NA_MIN_BYTES, _B29_PERIOD_S, _NA_SAMPLE_DIV
    if _B33_GREF_LEVEL > 0:
        return _b33_recover_gref()
    lvl = _B33_LEVEL
    act = None
    try:
        if lvl == 1:
            _NA_MIN_BYTES = max(8192, int(_NA_MIN_BYTES) // 4)
            if _NA_NATIVE_OK and _NLIB is not None and hasattr(_NLIB, "cd_na_enable"):
                _NLIB.cd_na_enable(1, int(_NA_MIN_BYTES))
            _NA_SAMPLE_DIV = 1
            if _NA_NATIVE_OK and _NLIB is not None and hasattr(_NLIB, "cd_na_set_sample_div"):
                _NLIB.cd_na_set_sample_div(1)
            act = "restore _NA_MIN_BYTES->%d + sample 1/1" % _NA_MIN_BYTES
        elif lvl == 2:
            _B29_PERIOD_S = max(3.0, float(_B29_PERIOD_S) / 2.0)
            act = "Block29 CPU sampler period->%.1fs" % _B29_PERIOD_S
        else:
            return None
        _B33_LEVEL = lvl - 1
        try: _log("Block#33 recover -> L%d: %s" % (_B33_LEVEL, act))
        except Exception: pass
        return {"recover_to": _B33_LEVEL, "detail": act}
    except Exception:
        return None

def _b33_poll(period_s):
    global _B33_PREV, _B33_STRIKE, _B33_OK_RUN
    rows = _b33_read_native()
    slots = []
    ui_rate = 0.0
    total_rate = 0.0
    native = rows is not None
    if native:
        prev = _B33_PREV
        for i, r in enumerate(rows):
            p = prev[i] if (prev and i < len(prev)) else [0, 0, 0, 0]
            dc = max(0, r[0] - p[0]); dt = max(0, r[1] - p[1]); dui = max(0, r[3] - p[3])
            nm = _B33_SLOT_NAMES[i] if i < len(_B33_SLOT_NAMES) else ("slot%d" % i)
            tms = dt / 1e6; ums = dui / 1e6
            total_rate += tms; ui_rate += ums
            slots.append({"slot": nm, "count": dc, "total_ms": round(tms, 2),
                          "max_ms": round(r[2] / 1e6, 2), "ui_ms": round(ums, 2)})
        _B33_PREV = rows
        ui_rate /= max(0.001, period_s); total_rate /= max(0.001, period_s)
        over = ui_rate > _B33_UI_BUDGET_MS_PER_S or total_rate > _B33_TOTAL_BUDGET_MS_PER_S
    else:
        try:
            with _B29_LOCK:
                last = _B29_LAST
                tbl = dict(last["tbl"]) if last else {}
        except Exception:
            tbl = {}
        for tid, (pct, nm) in tbl.items():
            try: own = _b29_owner_of_tid(tid)
            except Exception: own = None
            is_self = str(nm or "").startswith("culprit-") or own == __id__ or own == _SELF_ID
            if is_self and pct and pct > 0:
                ms_s = float(pct) * 10.0
                total_rate += ms_s
                slots.append({"slot": str(nm or ("tid%d" % tid)), "count": 1,
                              "total_ms": round(ms_s, 2), "max_ms": 0.0, "ui_ms": 0.0})
        over = total_rate > _B33_TOTAL_BUDGET_MS_PER_S
    gil = None
    gil_over = False
    uirow = _b33_read_ui_stall()
    if uirow is not None:
        ticks, gap_ns, max_gap_ns, awall_ns, acpu_ns, stalls, idle_skips = uirow[:7]
        off_cpu_ms_per_s = (gap_ns / 1e6) / max(0.001, period_s)
        on_cpu_pct = (100.0 * acpu_ns / awall_ns) if awall_ns > 0 else None
        gil = {"ui_off_cpu_ms_per_s": round(off_cpu_ms_per_s, 2),
               "ui_off_cpu_budget_ms_per_s": _B33_GIL_GAP_BUDGET_MS_PER_S,
               "max_stall_ms": round(max_gap_ns / 1e6, 2),
               "stalls_over_2ms": int(stalls),
               "active_on_cpu_pct": (round(on_cpu_pct, 1) if on_cpu_pct is not None else None),
               "ui_ticks": int(ticks), "idle_skips": int(idle_skips)}
        try:
            _holders = _b33_read_gil_holders(period_s)
            if _holders: gil["holders"] = _holders
        except Exception: pass
        gil_over = off_cpu_ms_per_s > _B33_GIL_GAP_BUDGET_MS_PER_S
    if over:
        _B33_STRIKE += 1; _B33_OK_RUN = 0
    else:
        if _B33_STRIKE > 0: _B33_STRIKE -= 1
        _B33_OK_RUN += 1
    top = None
    if slots:
        try: top = sorted(slots, key=lambda s: (s.get("ui_ms") or 0, s.get("total_ms") or 0), reverse=True)[0]
        except Exception: top = slots[0]
    action = None
    if _B33_STRIKE >= _B33_STRIKES_TO_DEGRADE:
        action = _b33_degrade(top.get("slot") if top else None, ui_rate, total_rate); _B33_STRIKE = 0
    elif (_B33_LEVEL > 0 or _B33_GREF_LEVEL > 0) and _B33_OK_RUN >= _B33_RECOVER_WINDOWS:
        action = _b33_recover(); _B33_OK_RUN = 0
    if over or action or gil_over:
        _b33_emit(slots, ui_rate, total_rate, top, action, native, gil)

def _b33_loop(stop):
    while not stop.is_set():
        if stop.wait(_B33_PERIOD_S): break
        try:
            _b33_poll(_B33_PERIOD_S)
        except Exception as e:
            try: _log("Block#33 loop err: %r" % e)
            except Exception: pass

def _b33_start():
    global _B33_THREAD, _B33_PREV
    _vw_start()
    if not _BLOCK33_ON:
        _log("Block#33: disabled"); return
    _B33_PREV = _b33_read_native()
    _B33_STOP.clear()
    _B33_THREAD = threading.Thread(target=_b33_loop, args=(_B33_STOP,), name="culprit-self", daemon=True)
    _B33_THREAD.start()
    _log("Block#33 self-overhead watchdog: start period=%.1fs ui_budget=%.1fms/s total_budget=%.1fms/s native=%s" % (
        _B33_PERIOD_S, _B33_UI_BUDGET_MS_PER_S, _B33_TOTAL_BUDGET_MS_PER_S, _SELF_NATIVE_OK))

def _b33_stop():
    global _B33_THREAD
    try:
        _B33_STOP.set()
        t = _B33_THREAD
        if t is not None: t.join(timeout=2.0)
        _B33_THREAD = None
    except Exception: pass
    _vw_stop()

_DN_IDLE_CLASSES = ("android.os.MessageQueue", "android.os.Looper", "android.os.Handler", "android.app.ActivityThread", "com.android.internal.os", "java.lang.reflect.Method", "dalvik.system", "java.lang.Object", "com.chaquo", "java.chaquopy", "org.python")
_DN_PLUGIN_MARKERS = ("chaquo", "chaquopy", "org.python", "pythonplugin")
_DN_SYSCALL_NAMES = {98: "futex", 73: "ppoll", 22: "epoll_pwait", 63: "read", 64: "write", 113: "clock_nanosleep", 101: "nanosleep", 71: "sendmsg", 212: "recvmsg", 29: "ioctl", 56: "openat"}
_DN_MIDSTALL_AFTER_MS = 1200
_DN_MIDSTALL_EVERY_MS = 800
_DN_MIDSTALL_MAX = 5
_DN_MIDSTALL_SNAPSHOT = []

def _dn_capture_java_ui_stack(max_frames=48):
    try:
        from java import jclass as _jc
        Looper = _jc("android.os.Looper")
        main = Looper.getMainLooper()
        if main is None:
            return None, 0, None
        th = main.getThread()
        if th is None:
            return None, 0, None
        elems = th.getStackTrace()
    except Exception as e:
        try: _log("Block#20 +DN: java stack err: %r" % e)
        except Exception: pass
        return None, 0, None
    frames = []
    plugin_n = 0
    component = None
    try:
        n = len(elems)
    except Exception:
        n = 0
    for i in range(n):
        try:
            el = elems[i]
            cls = el.getClassName() or "?"
            mth = el.getMethodName() or "?"
            fn = el.getFileName() or ""
            ln = el.getLineNumber()
        except Exception:
            continue
        frames.append("%s.%s(%s:%s)" % (cls, mth, fn, ln))
        low = cls.lower()
        if any(m in low for m in _DN_PLUGIN_MARKERS):
            plugin_n += 1
        if component is None and not cls.startswith(_DN_IDLE_CLASSES):
            component = "%s.%s" % (cls, mth)
        if len(frames) >= max_frames:
            break
    return frames, plugin_n, component

def _dn_proc_field(path):
    try:
        with open(path, "r") as f:
            return f.read().strip()
    except Exception:
        return None

def _dn_capture_kernel_state(ui_tid_linux):
    try:
        tid = int(ui_tid_linux)
    except Exception:
        return None
    if tid <= 0:
        return None
    base = "/proc/self/task/%d" % tid
    out = {"tid": tid}
    st = _dn_proc_field(base + "/stat")
    if st:
        try:
            cp = st.rfind(")")
            out["state"] = st[cp + 2] if (cp >= 0 and len(st) > cp + 2) else None
        except Exception:
            out["state"] = None
    out["wchan"] = _dn_proc_field(base + "/wchan")
    sc = _dn_proc_field(base + "/syscall")
    if sc:
        out["syscall_raw"] = sc
        try:
            nr = int(sc.split()[0])
            out["syscall_nr"] = nr
            out["syscall"] = _DN_SYSCALL_NAMES.get(nr)
        except Exception:
            pass
    s = out.get("state")
    wc = (out.get("wchan") or "").lower()
    if s == "R":
        out["nature"] = "on-cpu (host compute / busy-loop)"
    elif s in ("S", "D"):
        if "futex" in wc or out.get("syscall") == "futex":
            out["nature"] = "blocked on lock (futex) - host lock contention"
        elif "binder" in wc or "ioctl" in wc:
            out["nature"] = "blocked in binder IPC"
        elif "poll" in wc or "epoll" in wc:
            out["nature"] = "epoll/poll wait (looper idle or polling)"
        elif "io_schedule" in wc or "wait_on_page" in wc or out.get("syscall") in ("read", "write"):
            out["nature"] = "blocked on disk I/O"
        else:
            out["nature"] = "sleeping (%s)" % (wc or "?")
    else:
        out["nature"] = "state=%s" % (s or "?")
    return out

def _persist_host_stall(rec, p):
    _PERSIST_IO_LOCK.acquire()
    try:
        cur = []
        if os.path.exists(p):
            try:
                with open(p, "r", encoding="utf-8") as f: cur = list(json.load(f))
            except Exception: cur = []
        cur.append(rec)
        _atomic_json_write(p, cur, 20)
        _log("Block#20 +DN: host-stall verdict zapisan (%d zapisej) -> %s" % (len(cur), _HOST_STALL_FILE_NAME))
    except Exception as e:
        _log("Block#20 +DN: host verdict persist err: %s: %s" % (type(e).__name__, e))
    finally:
        try: _PERSIST_IO_LOCK.release()
        except Exception: pass

def _dn_choose_host_sample(midsamples):
    best = None
    for s in midsamples or []:
        try:
            if s.get("component"):
                if best is None or (s.get("held_ms") or 0) > (best.get("held_ms") or 0):
                    best = s
        except Exception:
            continue
    return best

def _dn_classify_host(jframes, plugin_n, component, kernel, phase):
    top = (jframes[0] if jframes else "") or ""
    idle = (component is None) or top.startswith("android.os.MessageQueue.nativePollOnce")
    if idle:
        return "host/undetermined", "low", "anr/host-idle", True
    if plugin_n > 0:
        if phase == "mid-stall":
            return component, "medium", "anr/host?+plugin-frames", False
        return component, "low", "anr/host?+plugin-frames", False
    if phase == "mid-stall":
        return component, "high", "anr/host", False
    wc = ((kernel or {}).get("wchan") or "").lower()
    st = (kernel or {}).get("state")
    active = (st in ("R", "D")) or ("futex" in wc) or ("binder" in wc) or ("io_schedule" in wc)
    return component, ("medium" if active else "low"), "anr/host", False

def _b20_report_stall(waited_ms):
    global _B20_REPORTED
    try:
        frames = _sys._current_frames()
    except Exception as e:
        _log("Block#20: _current_frames err: %r" % e); return
    fr = frames.get(_B20_UI_TID) if _B20_UI_TID is not None else None
    deepest, stack = (None, [])
    if fr is not None:
        try: deepest, stack = _b20_capture_culprit(fr)
        except Exception as e: _log("Block#20: capture err: %r" % e)
    try:
        _crows, _cmeta = _b29_cpu_top()
    except Exception:
        _crows, _cmeta = [], None
    if deepest is not None:
        culprit, py_file, py_line = deepest
        src = "anr/ui-thread"; conf = "high"; py_mod = culprit
    else:
        owner = _b20_owner_from_scope()
        _opinfo = _b20_owner_from_op(int(waited_ms) + 2500)
        if owner is not None:
            culprit = owner; py_mod = owner; py_file = ""; py_line = -1
            if _opinfo is not None and _opinfo["owner"] == owner:
                src = "anr/ui-thread-scope+op:%s" % _opinfo["domain"]; conf = "medium"
                _log("Block#20: no py-frame; scope-owner %r corroborated by op-stamp (domain=%s api=%s age=%dms, UI stall %dms)" % (owner, _opinfo["domain"], _opinfo["api"], int(_opinfo["age_ms"]), int(waited_ms)))
            else:
                src = "anr/ui-thread-scope-residual"; conf = "low"
                _div = (" (op-stamp -> %r/%s instead)" % (_opinfo["owner"], _opinfo["domain"])) if _opinfo is not None else " (no corroborating op-stamp)"
                _log("Block#20: no py-frame; scope-owner -> %r uncorroborated -> scope-residual conf=low%s (UI stall %dms)" % (owner, _div, int(waited_ms)))
        elif _opinfo is not None:
            culprit = _opinfo["owner"]; py_mod = _opinfo["owner"]; py_file = ""; py_line = -1
            src = "anr/ui-thread-op:%s" % _opinfo["domain"]; conf = "low"
            _log("Block#20: no py-frame/scope; op-stamp fallback -> %r (domain=%s api=%s age=%dms, UI stall %dms)" % (_opinfo["owner"], _opinfo["domain"], _opinfo["api"], int(_opinfo["age_ms"]), int(waited_ms)))
            try:
                _crows2, _cmeta2 = _b29_fresh_top(160)
                _cw = _b29_top_owned_by(_crows2, _opinfo["owner"])
                if _cw is not None:
                    _crows = _crows2; _cmeta = _cmeta2
                    src = "anr/ui-thread-op:%s+cpu" % _opinfo["domain"]; conf = "medium"
                    _log("Block#29 +CR: op-stamp owner %r corroborated by hot bg thread (tid=%s name=%s pct=%.1f%%) -> conf=medium" % (_opinfo["owner"], _cw["tid"], _cw["name"], _cw["pct"]))
            except Exception as _ecr:
                try: _log("Block#29 +CR corroborate err: %r" % _ecr)
                except Exception: pass
        else:
            _hog = None
            try:
                _hog = _b29_hog_culprit(_crows, _cmeta)
            except Exception as _e29:
                try: _log("Block#29: hog probe err: %r" % _e29)
                except Exception: pass
            if _hog is None:
                try:
                    _frows, _fmeta = _b29_fresh_top(160)
                    _fhog = _b29_hog_culprit(_frows, _fmeta)
                    if _fhog is not None:
                        _hog = _fhog; _crows = _frows; _cmeta = _fmeta
                        _log("Block#29: rolling snapshot missed hog -> fresh on-demand sample caught %r (tid=%s pct=%.1f%%)" % (_fhog["owner"], _fhog["tid"], _fhog["pct"]))
                    else:
                        try:
                            _fdiag = "; ".join("tid=%s/%s pct=%.1f owner=%s" % (r["tid"], r["name"], r["pct"], r.get("owner")) for r in (_frows or [])[:8])
                            _log("Block#29 fresh(retry): rows=%d win=%sms | %s" % (len(_frows or []), (_fmeta or {}).get("win_ms"), _fdiag or "<none>"))
                        except Exception: pass
                except Exception as _ef29:
                    try: _log("Block#29: fresh-sample err: %r" % _ef29)
                    except Exception: pass
            if _hog is not None:
                culprit = _hog["owner"]; py_mod = _hog["owner"]; py_file = ""; py_line = -1
                src = "anr/cpu-hog"; conf = "low"
                _log("Block#20: no py-frame/scope/op; CPU-hog fallback -> %r (tid=%s name=%s pct=%.1f%% age=%sms, UI stall %dms)" % (
                    _hog["owner"], _hog["tid"], _hog["name"], _hog["pct"], _hog.get("age_ms"), int(waited_ms)))
            else:
                try:
                    _diag_rows = "; ".join("tid=%s/%s pct=%.1f owner=%s" % (r["tid"], r["name"], r["pct"], r.get("owner")) for r in (_crows or [])[:8])
                    _log("Block#29 diag(suppress): rows=%d age=%sms win=%sms | %s" % (len(_crows or []), (_cmeta or {}).get("age_ms"), (_cmeta or {}).get("win_ms"), _diag_rows or "<none>"))
                except Exception as _ed29:
                    _log("Block#29 diag err: %r" % _ed29)
                _ui_lin = globals().get("_B33_UI_TID")
                _mid = list(globals().get("_DN_MIDSTALL_SNAPSHOT") or [])
                _chosen = _dn_choose_host_sample(_mid)
                if _chosen is not None:
                    _jframes = _chosen.get("jframes"); _plugin_n = int(_chosen.get("plugin_n") or 0)
                    _component = _chosen.get("component"); _kstate = _chosen.get("kernel")
                    _phase = "mid-stall"; _sample_held_ms = _chosen.get("held_ms")
                else:
                    _jframes, _plugin_n, _component = _dn_capture_java_ui_stack()
                    _kstate = _dn_capture_kernel_state(_ui_lin)
                    _phase = "post-hoc"; _sample_held_ms = None
                if _jframes:
                    _hculprit, _hconf, _hsrc, _idle = _dn_classify_host(_jframes, _plugin_n, _component, _kstate, _phase)
                    _idle_suppress = False; _kernel_idle = False
                    try:
                        _kw = ((_kstate or {}).get("wchan") or "").lower()
                        _kst = (_kstate or {}).get("state")
                        _active = (_kst in ("R", "D")) or ("futex" in _kw) or ("binder" in _kw) or ("io_schedule" in _kw)
                        _pollwait = ("epoll" in _kw) or ("poll" in _kw)
                        _t0 = (_jframes[0] if _jframes else "") or ""
                        _idletop = _idle or _t0.startswith("android.view.DisplayEventReceiver") or _t0.startswith("android.view.Choreographer") or _t0.startswith("android.os.MessageQueue.nativePollOnce")
                        _uicpu = None
                        for _r in (_crows or []):
                            if int(_r.get("tid") or -1) == int(_ui_lin or -2): _uicpu = float(_r.get("pct") or 0.0); break
                        _cpu_low = (_uicpu is None) or (_uicpu < _B20_IDLE_CPU_MAX)
                        _host_uiloop_top = _t0.startswith("android.view.") or _t0.startswith("android.graphics.HardwareRenderer") or _t0.startswith("android.graphics.RenderNode") or _t0.startswith("android.os.Looper") or _t0.startswith("android.os.MessageQueue")
                        _idle_suppress = (int(_plugin_n or 0) <= 0) and (not _active) and _pollwait and _idletop and _cpu_low
                        _kernel_idle = (int(_plugin_n or 0) <= 0) and (not _active) and ("epoll" in _kw) and _cpu_low and _host_uiloop_top and (not _idle_suppress)
                    except Exception:
                        _idle_suppress = False; _kernel_idle = False
                    if _idle_suppress:
                        _hculprit = "host/idle"; _hconf = "none"; _hsrc = "anr/host-idle"; _idle = True
                    elif _kernel_idle:
                        _hculprit = "host/idle"; _hconf = "none"; _hsrc = "anr/host-idle?kernel"; _idle = True; _idle_suppress = True
                    _hrec = {"had_anr": (not _idle_suppress), "host_side": True, "event_type": ("host_idle" if _idle_suppress else "host_stall"), "dropbox_tag": (None if _idle_suppress else "data_app_anr"), "tombstone_norm_version": 1, "culprit": _hculprit,
                             "src": _hsrc, "confidence": _hconf,
                             "where": "ui-thread", "stalled_ms": int(waited_ms),
                             "ui_tid": _B20_UI_TID, "ui_tid_linux": _ui_lin,
                             "component": (None if _idle else _component),
                             "plugin_frames_in_ui_stack": _plugin_n,
                             "sample_phase": _phase, "sample_held_ms": _sample_held_ms,
                             "looper_idle": bool(_idle),
                             "java_stack": _jframes, "kernel": _kstate,
                             "cpu_top": _crows, "cpu_win_ms": (_cmeta or {}).get("win_ms"),
                             "reason": (("UI thread parked in kernel epoll-wait (do_epoll_wait) with framework looper top at sample -> kernel-proven idle, NOT a host freeze (+HN host_idle?kernel)") if _kernel_idle else (("UI thread unresponsive > %dms; looper idle at sample (stall ended before capture) -> host component undetermined" % _B20_TIMEOUT_MS) if _idle else ("UI thread unresponsive > %dms; no plugin signal -> host component %s (caught %s)" % (_B20_TIMEOUT_MS, _component, _phase)))),
                             "ts": int(time.time() * 1000)}
                    try:
                        _hp = _oom_path(_HOST_STALL_FILE_NAME)
                        if _hp:
                            with _B20_LOCK:
                                _persist_host_stall(_hrec, _hp)
                    except Exception as _ehp:
                        try: _log("Block#20 +DN: host verdict write err: %r" % _ehp)
                        except Exception: pass
                    _ktxt = ""
                    if _kstate:
                        _ktxt = " | kernel: state=%s wchan=%s syscall=%s -> %s" % (_kstate.get("state"), _kstate.get("wchan"), (_kstate.get("syscall") or _kstate.get("syscall_nr")), _kstate.get("nature"))
                    _top3 = " <- ".join((_jframes or [])[:3])
                    _log("Block#20 +DN/+DP%s: host-side UI stall %dms (NOT plugin; %d plugin frames; sample=%s%s) -> culprit=%r conf=%s src=%s%s | top: %s" % ((" +HN SUPPRESSED->host_idle(kernel epoll-wait)" if _kernel_idle else (" +HL SUPPRESSED->host_idle(had_anr=false)" if _idle_suppress else "")), int(waited_ms), _plugin_n, _phase, ((" held=%dms" % int(_sample_held_ms)) if _sample_held_ms else ""), _hculprit, _hconf, _hsrc, _ktxt, _top3 or "<none>"))
                else:
                    _log("Block#20: UI stall %dms but no plugin py-frame/scope/op/cpu (tid=%s) and host stack unavailable -> suppressed (no culprit)" % (int(waited_ms), _B20_UI_TID))
                _B20_REPORTED = True
                return
    rec = {"had_anr": True, "event_type": "anr", "dropbox_tag": "data_app_anr", "tombstone_norm_version": 1, "culprit": culprit, "src": src, "confidence": conf,
           "where": "ui-thread", "stalled_ms": int(waited_ms), "ui_tid": _B20_UI_TID,
           "py_module": py_mod, "py_file": py_file, "py_line": py_line,
           "stack": stack,
           "cpu_top": _crows, "cpu_win_ms": (_cmeta or {}).get("win_ms"), "cpu_age_ms": (_cmeta or {}).get("age_ms"),
           "reason": "UI thread unresponsive > %dms (ANR imminent)" % _B20_TIMEOUT_MS,
           "ts": int(time.time() * 1000)}
    try:
        with _B20_LOCK:
            _persist_anr_fail(rec)
    except Exception as e:
        _log("Block#20: verdict write err: %r" % e)
    _log("ВИНОВНИК ANR: %r conf=%s stalled=%dms where=ui-thread tid=%s" % (culprit, conf, int(waited_ms), _B20_UI_TID))
    if py_file:
        _log("  modul: %s:%s" % (py_file, py_line))
    _log("  причина: %s" % rec["reason"])
    _B20_REPORTED = True

def _b20_loop_native(stop):
    global _B20_REPORTED, _DN_MIDSTALL_SNAPSHOT
    try: last_seq = int(_NLIB.cd_anr_stall_seq())
    except Exception: last_seq = 0
    last_ping = 0.0
    poll_s = 0.25
    _infl_since = None
    _last_mid = 0.0
    _mid = []
    while not stop.is_set():
        try:
            now = time.monotonic()
            try: inflight = int(_NLIB.cd_anr_inflight())
            except Exception: inflight = 1
            if (now - last_ping) * 1000.0 >= _B20_PING_MS and not inflight:
                _b20_post_ping(); last_ping = now
            if inflight:
                if _infl_since is None: _infl_since = now
                _held = (now - _infl_since) * 1000.0
                if _held >= _DN_MIDSTALL_AFTER_MS and (now - _last_mid) * 1000.0 >= _DN_MIDSTALL_EVERY_MS:
                    try:
                        _jf, _pn, _cmp = _dn_capture_java_ui_stack()
                        if _jf:
                            _ks = _dn_capture_kernel_state(globals().get("_B33_UI_TID"))
                            _mid.append({"held_ms": _held, "jframes": _jf, "plugin_n": _pn, "component": _cmp, "kernel": _ks})
                            if len(_mid) > _DN_MIDSTALL_MAX: _mid = _mid[-_DN_MIDSTALL_MAX:]
                    except Exception: pass
                    _last_mid = now
            else:
                _infl_since = None
                if _mid: _mid = []
            try: seq = int(_NLIB.cd_anr_stall_seq())
            except Exception: seq = last_seq
            if seq != last_seq:
                last_seq = seq
                try: waited = int(_NLIB.cd_anr_stalled_ms())
                except Exception: waited = _B20_TIMEOUT_MS
                _DN_MIDSTALL_SNAPSHOT = list(_mid)
                _B20_REPORTED = False
                _b20_report_stall(waited)
        except Exception as e:
            try: _log("Block#20 native loop err: %r" % e)
            except Exception: pass
        stop.wait(poll_s)

def _b20_start():
    global _B20_THREAD, _B20_NATIVE
    if not _B20_ON:
        _log("Block#20: disabled"); return
    if not _b20_setup_handler():
        _log("Block#20: setup failed -> ANR watchdog OFF"); return
    _B20_NATIVE = bool(_ANR_NATIVE_OK and _NLIB is not None)
    if not _B20_NATIVE:
        _log("Block#20: native ANR (cd_anr_start) missing -> watchdog OFF (rebuild .so)"); return
    _B20_STOP.clear()
    try:
        rc = int(_NLIB.cd_anr_start(int(_B20_TIMEOUT_MS), int(_B20_MAX_PLAUSIBLE_MS), 250))
    except Exception as e:
        _log("Block#20: cd_anr_start err: %r -> watchdog OFF" % e); return
    if rc < 0:
        _log("Block#20: cd_anr_start rc=%d -> watchdog OFF" % rc); return
    _B20_THREAD = threading.Thread(target=_b20_loop_native, args=(_B20_STOP,), name="culprit-anr", daemon=True)
    _B20_THREAD.start()
    _log("Block#20 ANR watchdog: start ping=%dms timeout=%dms detect=C/native (Tier 2b) -> %s" % (
        _B20_PING_MS, _B20_TIMEOUT_MS, _ANR_FILE_NAME))

def _b20_stop():
    global _B20_THREAD
    try:
        _B20_STOP.set()
        t = _B20_THREAD
        if t is not None: t.join(timeout=2.0)
        if _B20_NATIVE and _NLIB is not None:
            try: _NLIB.cd_anr_stop()
            except Exception: pass
        _B20_THREAD = None
        _log("Block#20 ANR watchdog: stopped")
    except Exception:
        pass

class Plugin(BasePlugin):
    def on_plugin_load(self):
        global _CRUMB
        _init_log(); _log(f"Culprit Detector v{__version__} loading")
        try: _b28_apply_settings(self)
        except Exception as _eb28s: _log("Block#28 settings restore err: %s" % _eb28s)
        try: _cp_reclaim_basehooks()
        except Exception as _ecp: _log("cooperative-patch reclaim err: %s" % _ecp)
        _load_pidindex(); _log(f"Block#2 pid-index restored: {len(_IDX_PID)} entries")
        info = registry_info()
        _log(f"Block#2 реестр: backend={info['backend']} addr=0x{info['addr']:x} "
             f"slots={info['slots']} slot={info['slot_bytes']}B layout={info['layout']} v{info['version']}")
        _selftest_registry()
        _load_native()
        if globals().get("_ABI_FAIL", False):
            _log("Culprit Detector: ABI mismatch -- detector loaded but inert (+DT). Rebuild/embed current libculprit.so (ABI %d)." % _SO_ABI_EXPECT)
            return
        try:
