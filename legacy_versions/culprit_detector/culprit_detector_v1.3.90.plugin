            items = list(_B18_PATCHED); del _B18_PATCHED[:]
        for tup in items:
            try:
                cls, nm, orig = tup[0], tup[1], tup[2]
                our_w = tup[3] if len(tup) > 3 else None
                cur = getattr(cls, nm, None)
                if cur is not None and (cur is our_w if our_w is not None else getattr(cur, _B18_FLAG, False)):
                    setattr(cls, nm, orig)
            except Exception: pass
    except Exception: pass
    _B18_INSTALLED = False

_PYERR_FILE_NAME = "pyerr_verdict.json"
