)
_NLIB = None
_NATIVE_OK = False
_SO_NAME = "libculprit.so"
_B4C_OK = False
_SCOPE_OK = False
_LT_SLOTS = 1024
_NATIVE_CRASH_NAME = "native_crash.txt"
_NATIVE_CRASH_VERDICT_NAME = "native_crash_verdict.json"
_CRASH_VERDICT_DURABLE_NAME = "crash_verdict_persisted.json"

_SYS_PREFIXES = (
    "org.telegram.", "android.", "androidx.", "java.", "javax.",
    "sun.", "dalvik.", "libcore.", "kotlin.", "kotlinx.",
    "com.android.", "com.google.", "com.exteragram.", "com.chaquo.",
    "j$.", "jdk.", "okhttp3.", "okio.", "retrofit2.",
)
_HOOK_MARKERS = (
    "de.robv.android.xposed", "org.lsposed.", "LSPHooker_", "LSPosed",
    "io.github.libxposed", "lspatch",
)
_GENERIC = {"dex", "plugin", "plugins", "unstable", "stable", "utils", "util",
            "com", "org", "app", "messenger", "lambda", "run", "java", "main",
            "ext", "core", "helper", "helpers", "module", "impl"}

_LOG_PATH = None; _LOG_LOCK = threading.Lock()
def _init_log():
    global _LOG_PATH
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        _LOG_PATH = File(d, f"breadcrumb_{int(time.time())}.log").getAbsolutePath()
    except Exception: _LOG_PATH = None
def _log(msg):
    line = f"[{time.strftime('%H:%M:%S')}] {msg}"
    print(f"[Culprit] {line}")
    if _LOG_PATH:
        try:
            with _LOG_LOCK:
                with open(_LOG_PATH, "a", encoding="utf-8") as f: f.write(line + "\n")
        except Exception: pass

_Slot = None
_REG_BUF = None
_REG_ADDR = 0
if _CTYPES_OK:
    try:
        class _Slot(ctypes.Structure):
            _fields_ = [("tid", ctypes.c_int64),
                        ("pid_idx", ctypes.c_int32),
                        ("seq", ctypes.c_int32)]
        _REG_BUF = (_Slot * _REG_N)()
        _REG_ADDR = ctypes.addressof(_REG_BUF)
    except Exception:
        _Slot = None; _REG_BUF = None; _REG_ADDR = 0

_FALLBACK = {}; _FALLBACK_LOCK = threading.Lock()

_PID_IDX = {}; _IDX_PID = []; _INTERN_LOCK = threading.Lock()
def _pidindex_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _PIDINDEX_FILE).getAbsolutePath()
    except Exception:
        return None
def _persist_pidindex():
    p = _pidindex_path()
    if not p: return
    try:
        data = json.dumps(list(_IDX_PID), ensure_ascii=False)
        tmp = p + ".tmp"
        with open(tmp, "w", encoding="utf-8") as f:
            f.write(data); f.flush()
            try: os.fsync(f.fileno())
            except Exception: pass
        os.replace(tmp, p)
    except Exception:
        pass
_IDXNAMES_FILE = "idx_names.json"
def _idxnames_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _IDXNAMES_FILE).getAbsolutePath()
    except Exception:
        return None
def _persist_idxnames():
    p = _idxnames_path()
    if not p: return
    try:
        cur = {}
        try:
            with open(p, "r", encoding="utf-8") as f:
                old = json.load(f)
            if isinstance(old, dict):
                cur = {str(k): v for k, v in old.items() if isinstance(v, str) and v}
        except Exception:
            cur = {}
        for idx, nm in enumerate(_IDX_PID):
            if isinstance(nm, str) and nm:
                cur.setdefault(str(idx), nm)
        data = json.dumps(cur, ensure_ascii=False)
        tmp = p + ".tmp"
        with open(tmp, "w", encoding="utf-8") as f:
            f.write(data); f.flush()
            try: os.fsync(f.fileno())
            except Exception: pass
        os.replace(tmp, p)
    except Exception:
        pass
def _resolve_idx_durable(i):
    if i is None or i < 0: return None
    p = _idxnames_path()
    if not p: return None
    try:
        with open(p, "r", encoding="utf-8") as f:
            m = json.load(f)
        if isinstance(m, dict):
            v = m.get(str(i))
            return v if (isinstance(v, str) and v) else None
    except Exception:
        pass
    return None
_CANON_CACHE = {}
def _canon_pid(pid):
    if not isinstance(pid, str) or not pid:
        return pid
    cached = _CANON_CACHE.get(pid)
    if cached is not None:
        return cached
    try:
        for m in list(_sys.modules.values()):
            try:
                if getattr(m, "__name__", None) == pid:
                    cid = getattr(m, "__id__", None)
                    if isinstance(cid, str) and cid:
                        _CANON_CACHE[pid] = cid
                        return cid
            except Exception:
                pass
    except Exception:
        pass
    return pid
def _intern(pid):
    with _INTERN_LOCK:
        i = _PID_IDX.get(pid)
        if i is not None:
            return i
    try: pid = _canon_pid(pid)
    except Exception: pass
    with _INTERN_LOCK:
        i = _PID_IDX.get(pid)
        if i is None:
            i = len(_IDX_PID); _IDX_PID.append(pid); _PID_IDX[pid] = i
            _persist_pidindex()
            try: _persist_idxnames()
            except Exception: pass
        return i
def _resolve_idx(i):
    if i is None or i < 0: return None
    with _INTERN_LOCK:
        return _IDX_PID[i] if 0 <= i < len(_IDX_PID) else None
def _load_pidindex():
    saved = []
    p = _pidindex_path()
    if p:
        try:
            with open(p, "r", encoding="utf-8") as f:
                saved = list(json.load(f))
        except Exception:
            saved = []
    sidecar = {}
    sp = _idxnames_path()
    if sp:
        try:
            with open(sp, "r", encoding="utf-8") as f:
                m = json.load(f)
            if isinstance(m, dict):
                for k, v in m.items():
                    try:
                        if isinstance(v, str) and v:
                            sidecar[int(k)] = v
                    except Exception:
                        pass
        except Exception:
            sidecar = {}
    if sidecar and len(sidecar) > len([x for x in saved if isinstance(x, str) and x]):
        n = max(sidecar) + 1
        if all(j in sidecar for j in range(n)):
            saved = [sidecar[j] for j in range(n)]
    with _INTERN_LOCK:
        if _IDX_PID:
            return
        for nm in saved:
            idx = len(_IDX_PID)
            _IDX_PID.append(nm)
            if isinstance(nm, str) and nm and nm not in _PID_IDX:
                _PID_IDX[nm] = idx
        try: _persist_idxnames()
        except Exception: pass

def _cur_tid():
    if _NATIVE_OK and _NLIB is not None:
        try: return int(_NLIB.cd_gettid())
        except Exception: pass
    try:
        if _JThread is not None:
            return int(_JThread.currentThread().getId())
    except Exception: pass
    try: return int(threading.get_ident())
    except Exception: return None

def _reg_set(tid, idx):
    if tid is None: return False
    if _NATIVE_OK and _NLIB is not None and hasattr(_NLIB, "cd_reg_publish_tid"):
        try:
            if idx < 0:
                _NLIB.cd_reg_clear_tid(ctypes.c_int64(int(tid)))
            else:
                _NLIB.cd_reg_publish_tid(ctypes.c_int64(int(tid)), ctypes.c_int32(int(idx)))
            return True
        except Exception:
            pass
    if _REG_BUF is None:
        with _FALLBACK_LOCK:
            if idx < 0: _FALLBACK.pop(tid, None)
            else: _FALLBACK[tid] = idx
        return True
    i = int(tid) & (_REG_N - 1)
    for _ in range(_REG_N):
        t = _REG_BUF[i].tid
        if t == tid:
            if idx < 0:
                _REG_BUF[i].seq = _REG_BUF[i].seq + 1
                _REG_BUF[i].pid_idx = -1
                _REG_BUF[i].seq = _REG_BUF[i].seq + 1
                _REG_BUF[i].tid = -1
            else:
                _REG_BUF[i].seq = _REG_BUF[i].seq + 1
                _REG_BUF[i].pid_idx = idx
                _REG_BUF[i].seq = _REG_BUF[i].seq + 1
            return True
        if t == 0:
            break
        i = (i + 1) & (_REG_N - 1)
    if idx >= 0:
        i = int(tid) & (_REG_N - 1)
        for _ in range(_REG_N):
            t = _REG_BUF[i].tid
            if t == 0 or t == -1:
                _REG_BUF[i].seq = _REG_BUF[i].seq + 1
                _REG_BUF[i].tid = tid
                _REG_BUF[i].pid_idx = idx
                _REG_BUF[i].seq = _REG_BUF[i].seq + 1
                return True
            i = (i + 1) & (_REG_N - 1)
    return False

def _reg_get(tid):
    if tid is None: return None
    if _NATIVE_OK and _NLIB is not None and hasattr(_NLIB, "cd_reg_lookup_tid"):
        try:
            res = int(_NLIB.cd_reg_lookup_tid(ctypes.c_int64(int(tid))))
            return res if res >= 0 else None
        except Exception:
            pass
    if _REG_BUF is not None:
        i = int(tid) & (_REG_N - 1)
        for _ in range(_REG_N):
            t = _REG_BUF[i].tid
            if t == tid:
                idx = _REG_BUF[i].pid_idx
                return idx if idx >= 0 else None
            if t == 0:
                return None
            i = (i + 1) & (_REG_N - 1)
        return None
    with _FALLBACK_LOCK:
        res = _FALLBACK.get(tid)
    return res if (res is not None and res >= 0) else None

_TIDLOCAL = threading.local()
def _stack():
    s = getattr(_TIDLOCAL, "stack", None)
    if s is None: s = _TIDLOCAL.stack = []
    return s
def _scoped_set(pid):
    tid = _cur_tid()
    if tid is None: return False
    idx = _intern(pid)
    if _SCOPE_OK and _NLIB is not None:
        try: _NLIB.cd_scope_enter(int(idx))
        except Exception: pass
        return True
    prev = _reg_get(tid)
    prev = prev if (prev is not None) else -1
    _reg_set(tid, idx)
    _stack().append((tid, prev))
    if _B4C_OK and _NLIB is not None:
        try: _NLIB.cd_set_active_plugin(int(idx))
        except Exception: pass
    return True
def _scoped_clear():
    if _SCOPE_OK and _NLIB is not None:
        try: _NLIB.cd_scope_leave()
        except Exception: pass
        return
    st = _stack()
    if not st: return
    try: tid, prev = st.pop()
    except Exception: return
    _reg_set(tid, prev if prev is not None else -1)
    if _B4C_OK and _NLIB is not None:
        try: _NLIB.cd_clear_active_plugin()
        except Exception: pass
def _publish_tid(pid):
    _reg_set(_cur_tid(), _intern(pid))

_DIRECT_LOCK = threading.Lock()
_DIRECT_BYTES = {}
_DIRECT_TOTAL = 0
_DIRECT_UNTAGGED = 0
_DIRECT_LIVE = {}
_DIRECT_LIVE_TOTAL = 0
_DIRECT_LIVE_UNTAGGED = 0
_DIRECT_REGS = {}
_DIRECT_REG_LOCK = threading.Lock()
_DIRECT_RQ = None
_WeakReference = None
_SysClass = None
_DIRECT_REAPER = None
_DIRECT_REAPER_STOP = None

def _direct_snapshot():
    with _DIRECT_LOCK:
        return {
            "total": _DIRECT_TOTAL, "untagged": _DIRECT_UNTAGGED, "by_pid": dict(_DIRECT_BYTES),
            "live_total": _DIRECT_LIVE_TOTAL, "live_untagged": _DIRECT_LIVE_UNTAGGED,
            "live_by_pid": dict(_DIRECT_LIVE),
        }

def _direct_pid_now():
    try:
        idx = _reg_get(_cur_tid())
        if idx is not None and idx >= 0:
            return _resolve_idx(idx)
    except Exception:
        pass
    return None

def _direct_register(obj, nbytes):
    global _DIRECT_TOTAL, _DIRECT_UNTAGGED, _DIRECT_LIVE_TOTAL, _DIRECT_LIVE_UNTAGGED
    try:
        n = int(nbytes)
    except Exception:
        return
    if n <= 0:
        return
    pid = _direct_pid_now()
    with _DIRECT_LOCK:
        _DIRECT_TOTAL += n
        if pid is None: _DIRECT_UNTAGGED += n
        else: _DIRECT_BYTES[pid] = _DIRECT_BYTES.get(pid, 0) + n
    reg_ok = False
    if obj is not None and _DIRECT_RQ is not None and _WeakReference is not None and _SysClass is not None:
        try:
            wr = _WeakReference(obj, _DIRECT_RQ)
            ihc = int(_SysClass.identityHashCode(wr))
            with _DIRECT_REG_LOCK:
                _DIRECT_REGS.setdefault(ihc, []).append([wr, pid, n])
            reg_ok = True
        except Exception:
            reg_ok = False
    if reg_ok:
        with _DIRECT_LOCK:
            _DIRECT_LIVE_TOTAL += n
            if pid is None: _DIRECT_LIVE_UNTAGGED += n
            else: _DIRECT_LIVE[pid] = _DIRECT_LIVE.get(pid, 0) + n

def _direct_reaper(stop_evt):
    global _DIRECT_LIVE_TOTAL, _DIRECT_LIVE_UNTAGGED
    if _DIRECT_RQ is None or _SysClass is None:
        return
    while not stop_evt.is_set():
        ref = None
        try:
            ref = _DIRECT_RQ.remove(500)
        except Exception:
            ref = None
        if ref is None:
            continue
        rec = None
        try:
            ihc = int(_SysClass.identityHashCode(ref))
            with _DIRECT_REG_LOCK:
                bucket = _DIRECT_REGS.get(ihc)
                if bucket:
                    for i in range(len(bucket)):
                        try:
                            if bucket[i][0].equals(ref):
                                rec = bucket.pop(i); break
                        except Exception:
                            pass
                    if not bucket:
                        _DIRECT_REGS.pop(ihc, None)
        except Exception:
            rec = None
        if rec is not None:
            _, pid, cap = rec
            with _DIRECT_LOCK:
                _DIRECT_LIVE_TOTAL = max(0, _DIRECT_LIVE_TOTAL - cap)
                if pid is None:
                    _DIRECT_LIVE_UNTAGGED = max(0, _DIRECT_LIVE_UNTAGGED - cap)
                else:
                    v = _DIRECT_LIVE.get(pid, 0) - cap
                    if v > 0: _DIRECT_LIVE[pid] = v
                    else: _DIRECT_LIVE.pop(pid, None)

def _direct_live_start():
    global _DIRECT_RQ, _WeakReference, _SysClass, _DIRECT_REAPER, _DIRECT_REAPER_STOP
    if _DIRECT_RQ is not None:
        return True
    wref = _jc("java.lang.ref.WeakReference")
    rq   = _jc("java.lang.ref.ReferenceQueue")
    sysc = _jc("java.lang.System")
    if not (wref and rq and sysc):
        _log("Block#3D: live-tracking недоступен (нет WeakReference/ReferenceQueue/System)")
        return False
    _WeakReference = wref; _SysClass = sysc
    try:
        _DIRECT_RQ = rq()
    except Exception as e:
        _log(f"Block#3D: ReferenceQueue init err: {e}"); _DIRECT_RQ = None; return False
    _DIRECT_REAPER_STOP = threading.Event()
    _DIRECT_REAPER = threading.Thread(target=_direct_reaper, args=(_DIRECT_REAPER_STOP,), name="culprit-direct-reaper", daemon=True)
    _DIRECT_REAPER.start()
    return True

_LEAK_FILE_NAME = "leak_verdict.json"
_LEAK_FAILS_MAX = 20
_LEAK_DEDUP_MS = 60000
_LEAK_SEEN = {}; _LEAK_SEEN_LOCK = threading.Lock()
_BLOCK27_ON = True
_BLOCK27_VG_ON = False
_B27_DIAG = False
_VIEW_REGS = {}
_VIEW_REG_LOCK = threading.Lock()
_B27_REAPER = None
_B27_REAPER_STOP = None
_B27_SWEEP_MS = 3000
_B27_GRACE_MS = 1500

def _leak_verdict_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _LEAK_FILE_NAME).getAbsolutePath()
    except Exception:
        return None

def _b27_owner_now():
    try:
        pid = _pm_scan_py(_pm_python_stack(48))
        if pid and pid != _SELF_ID: return pid
    except Exception: pass
    try:
        pid = _direct_pid_now()
        if pid and pid != _SELF_ID: return pid
    except Exception: pass
    return None

def _b27_view_ihc(view):
    try:
        return int(jclass("java.lang.System").identityHashCode(view))
    except Exception:
        return None

def _b27_weakref(view):
    try:
        return jclass("java.lang.ref.WeakReference")(view)
    except Exception:
        return None

def _b27_register_add(view, desc, owner=None):
    if not _BLOCK27_ON or view is None: return
    if owner is None:
        owner = _b27_owner_now()
    if not owner or owner == _SELF_ID: return
    ihc = _b27_view_ihc(view)
    if ihc is None: return
    wref = _b27_weakref(view)
    with _VIEW_REG_LOCK:
        bucket = _VIEW_REGS.setdefault(ihc, [])
        for r in bucket:
            if r[1] == owner:
                r[3] = desc
                if len(r) > 4: r[4] = wref
                return
        bucket.append([ihc, owner, int(time.time()*1000), desc, wref])
    try: _log("Block#27: track view ihc=%d owner=%s (%s)" % (ihc, owner, desc))
    except Exception: pass

def _b27_register_remove(view):
    if view is None: return
    ihc = _b27_view_ihc(view)
    if ihc is None: return
    with _VIEW_REG_LOCK:
        if ihc in _VIEW_REGS: _VIEW_REGS.pop(ihc, None)

def _b27_live_pids():
    out = set()
    try:
        for e in _b11_plugin_entries():
            try:
                k = _safe_str(e.getKey())
                if k: out.add(k)
            except Exception: pass
    except Exception: pass
    return out

def _b27_write_leak(owner, by_desc, age_ms, count):
    p = _leak_verdict_path()
    if not p: return
    try:
        parts = sorted(by_desc.items(), key=lambda kv: -kv[1])
    except Exception:
        parts = list(by_desc.items())
    where = ", ".join("%s x%d" % (d, n) for d, n in parts) if parts else "view-leak"
    kinds = set(by_desc.keys())
    if kinds == {"WindowManager.addView"}:
        reason = "view добавлен через WindowManager.addView и не снят (removeView/removeViewImmediate) до выгрузки плагина"
    elif kinds == {"ViewGroup.addView"}:
        reason = "view добавлен в иерархию через ViewGroup.addView и не снят (removeView) до выгрузки плагина"
    else:
        reason = "views добавлены через %s и остались прикреплёнными до выгрузки плагина" % " + ".join(sorted(kinds))
    rec = {"had_leak": True, "culprit": owner, "src": "view-reaper", "confidence": "high",
           "kind": "view-leak", "where": where, "leaked_views": count, "by_desc": by_desc,
           "age_ms": age_ms, "reason": reason,
           "exc_cls": "ViewLeak", "exc_msg": where, "ts": int(time.time()*1000)}
    key = "%s" % owner; now = rec["ts"]
    with _LEAK_SEEN_LOCK:
        if now - _LEAK_SEEN.get(key, 0) < _LEAK_DEDUP_MS: return
        _LEAK_SEEN[key] = now
    try:
        cur = []
        if os.path.exists(p):
            try:
                with open(p, "r", encoding="utf-8") as f: cur = list(json.load(f))
            except Exception: cur = []
        cur.append(rec)
        _atomic_json_write(p, cur, _LEAK_FAILS_MAX)
    except Exception: pass
    try:
        _log("================ VIEW-LEAK VERDICT (Block#27) ================")
        _log("ВИНОВНИК УТЕЧКИ: %r conf=high views=%d age=%dms (%s)" % (owner, count, age_ms, where))
        _log("  причина: %s" % rec["reason"])
        _log("==============================================================")
    except Exception: pass

def _b27_is_live_leak(wref):
    if wref is None: return (False, True)
    try: vobj = wref.get()
    except Exception: return (False, True)
    if vobj is None: return (True, False)
    try:
        if vobj.getParent() is not None: return (True, True)
    except Exception: pass
    try:
        if bool(vobj.isAttachedToWindow()): return (True, True)
    except Exception: pass
    return (True, False)

def _b27_sweep(force_all=False):
    try:
        with _VIEW_REG_LOCK:
            snap = [(ihc, list(bucket)) for ihc, bucket in _VIEW_REGS.items()]
        if not snap: return
        live = _b27_live_pids()
        now = int(time.time()*1000)
        leaked = {}; drop_ihcs = []
        for ihc, bucket in snap:
            for rec in bucket:
                _ihc = rec[0]; owner = rec[1]; ts = rec[2]; desc = rec[3]
                wref = rec[4] if len(rec) > 4 else None
                if (now - ts) < _B27_GRACE_MS and not force_all: continue
                gone = (owner not in live) if live else False
                if not (gone or force_all): continue
                decided, is_leak = _b27_is_live_leak(wref)
                if decided and not is_leak:
                    drop_ihcs.append(ihc); continue
                info = leaked.setdefault(owner, {"total": 0, "by_desc": {}, "age": now - ts})
                info["total"] += 1
                info["by_desc"][desc] = info["by_desc"].get(desc, 0) + 1
                if (now - ts) > info["age"]: info["age"] = now - ts
                drop_ihcs.append(ihc)
        for owner, info in leaked.items():
            _b27_write_leak(owner, info["by_desc"], info["age"], info["total"])
        if drop_ihcs:
            with _VIEW_REG_LOCK:
                for ihc in drop_ihcs: _VIEW_REGS.pop(ihc, None)
    except Exception as e:
        try: _log("Block#27 sweep err: %s" % e)
        except Exception: pass

_BLOCK27B_SWEEP_ON = True
_B27B_SWEEP_MS = 9000
_B27B_MAX_NODES = 4000
_B27B_MAX_DEPTH = 60
_B27B_UI_TIMEOUT_S = 2.0
_B27B_RUNNABLE_CLS = None
_B27B_PENDING = []   # strong-ref na in-flight _SweepRunnable: Handler derzhit ego v ocheredi, no Python-ssylku nado uderzhat do konca run(), inache GC sobiraet proxy -> _chaquopyGetDict krash na main-threade

def _wmg_root_views_unsafe():
    out = []
    try:
        WMG = _java_lang_class("android.view.WindowManagerGlobal")
        if WMG is None: return out
        inst = WMG.getInstance()
        f = WMG.getDeclaredField("mViews"); f.setAccessible(True)
        v = f.get(inst)
        if v is None: return out
        try: arr = list(v.toArray())
        except Exception: arr = []
        for it in arr:
            if it is not None: out.append(it)
    except Exception: pass
    return out

def _b27b_walk_ui(clmap, live, results):
    try:
        cache = {}
        try: sysid = jclass("java.lang.System")
        except Exception: sysid = None
        work = [(r, 0) for r in _wmg_root_views_unsafe()]
        seen = 0
        while work and seen < _B27B_MAX_NODES:
            view, d = work.pop()
            if view is None or d > _B27B_MAX_DEPTH: continue
            seen += 1
            cn = None
            try: cn = _safe_str(view.getClass().getName())
            except Exception: cn = None
            pid = None
            if cn is not None:
                if cn in cache:
                    pid = cache[cn]
                else:
                    try:
                        clrep = _safe_str(view.getClass().getClassLoader())
                        pid = clmap.get(clrep)
                        if pid == _SELF_ID: pid = None
                    except Exception: pid = None
                    cache[cn] = pid
            if pid and (not live or pid not in live):
                attached = False
                try:
                    if view.getParent() is not None: attached = True
                except Exception: pass
                if not attached:
                    try: attached = bool(view.isAttachedToWindow())
                    except Exception: pass
                if attached:
                    ihc = 0
                    try:
                        if sysid is not None: ihc = int(sysid.identityHashCode(view))
                    except Exception: ihc = 0
                    results.append((pid, cn or "?", ihc))
            cnt = 0
            try: cnt = int(view.getChildCount())
            except Exception: cnt = 0
            for i in range(cnt):
                try:
                    ch = view.getChildAt(i)
                    if ch is not None: work.append((ch, d + 1))
                except Exception: pass
    except Exception: pass

def _b27b_runnable_cls():
    global _B27B_RUNNABLE_CLS
    if _B27B_RUNNABLE_CLS is not None: return _B27B_RUNNABLE_CLS
    try:
        from java import dynamic_proxy as _dp
    except Exception:
        return None
    iface = _RUNNABLE_IFACE if _RUNNABLE_IFACE is not None else jclass("java.lang.Runnable")
    if iface is None: return None
    class _SweepRunnable(_dp(iface)):
        def __init__(self, clmap, live, results, done):
            super().__init__()
            self._clmap = clmap; self._live = live; self._results = results; self._done = done
        def run(self):
            try: _b27b_walk_ui(self._clmap, self._live, self._results)
            finally:
                try: self._done.set()
                except Exception: pass
                try: _B27B_PENDING.remove(self)
                except Exception: pass
    _B27B_RUNNABLE_CLS = _SweepRunnable
    return _B27B_RUNNABLE_CLS

def _b27b_hierarchy_sweep():
    if not _BLOCK27B_SWEEP_ON: return
    try:
        clmap = _plugin_classloaders()
        if not clmap: return
        live = _b27_live_pids()
        RC = _b27b_runnable_cls()
        if RC is None: return
        results = []; done = threading.Event()
        posted = False
        try:
            Looper = jclass("android.os.Looper"); Handler = jclass("android.os.Handler")
            h = Handler(Looper.getMainLooper())
            _rc_inst = RC(clmap, live, results, done)
            try:
                _B27B_PENDING.append(_rc_inst)
                if len(_B27B_PENDING) > 8: del _B27B_PENDING[0]
            except Exception: pass
            posted = bool(h.post(_rc_inst))
            if not posted:
                try: _B27B_PENDING.remove(_rc_inst)
                except Exception: pass
        except Exception as e:
            _log("Block#27B sweep: post err: %s" % e); return
        if not posted: return
        if not done.wait(_B27B_UI_TIMEOUT_S):
            _log("Block#27B sweep: UI walk timeout"); return
        if not results: return
        agg = {}
        for (pid, cn, ihc) in results:
            info = agg.setdefault(pid, {"total": 0, "by_desc": {}})
            info["total"] += 1
            key = "in-hierarchy view %s (class owned by unloaded plugin)" % cn
            info["by_desc"][key] = info["by_desc"].get(key, 0) + 1
        for pid, info in agg.items():
            try: _b27_write_leak(pid, info["by_desc"], 0, info["total"])
            except Exception: pass
    except Exception as e:
        try: _log("Block#27B sweep err: %s" % e)
        except Exception: pass

def _b27_reaper(stop_evt):
    _b27b_accum = 0
    while not stop_evt.is_set():
        try: stop_evt.wait(_B27_SWEEP_MS/1000.0)
        except Exception: pass
        if stop_evt.is_set(): break
        _b27_sweep(False)
        try:
            _b27b_accum += _B27_SWEEP_MS
            if _BLOCK27B_SWEEP_ON and _b27b_accum >= _B27B_SWEEP_MS:
                _b27b_accum = 0
                _b27b_hierarchy_sweep()
        except Exception: pass

class _ViewAddHook(MethodHook):
    def after_hooked_method(self, param):
        try:
            try:
                if param.getThrowable() is not None: return
            except Exception: pass
            args = param.args
            if args is not None and len(args) >= 1 and args[0] is not None:
                pass
                _b27_register_add(args[0], "WindowManager.addView")
        except Exception: pass

class _ViewRemoveHook(MethodHook):
    def before_hooked_method(self, param):
        try:
            if not _VIEW_REGS: return
            args = param.args
            if args is not None and len(args) >= 1 and args[0] is not None:
                _b27_register_remove(args[0])
        except Exception: pass

class _ViewGroupAddHook(MethodHook):
    def after_hooked_method(self, param):
        try:
            try:
                if param.getThrowable() is not None: return
            except Exception: pass
            try: owner = _direct_pid_now()
            except Exception: owner = None
            if not owner or owner == _SELF_ID: return
            args = param.args
            if args is not None and len(args) >= 1 and args[0] is not None:
                pass
                _b27_register_add(args[0], "ViewGroup.addView", owner=owner)
        except Exception: pass

class _DirectAllocHook(MethodHook):
    def after_hooked_method(self, param):
        try:
            try:
                if param.getThrowable() is not None: return
            except Exception:
                pass
            args = param.args
            if args is not None and len(args) >= 1 and args[0] is not None:
                _direct_register(getattr(param, "thisObject", None), args[0])
        except Exception:
            pass

class _DirectAllocResultHook(MethodHook):
    def after_hooked_method(self, param):
        try:
            try:
                if param.getThrowable() is not None: return
            except Exception:
                pass
            args = param.args
            if args is not None and len(args) >= 1 and args[0] is not None:
                obj = None
                try: obj = param.getResult()
                except Exception: obj = None
                _direct_register(obj, args[0])
        except Exception:
            pass

_TSTART_TL = threading.local()
def _tstart_stack():
    s = getattr(_TSTART_TL, "s", None)
    if s is None: s = _TSTART_TL.s = []
    return s

class _ThreadStartHook(MethodHook):
    def before_hooked_method(self, param):
        seeded = False
        try:
            tid = _cur_tid()
            cur = _reg_get(tid)
            if not (cur is not None and cur >= 0):
                prov = _provenance_pid(None, 1)
                if prov is not None:
                    _scoped_set(prov); seeded = True
        except Exception:
            seeded = False
        try: _tstart_stack().append(seeded)
        except Exception: pass
    def after_hooked_method(self, param):
        try:
            st = _tstart_stack()
            if st and st.pop():
                _scoped_clear()
        except Exception: pass

def get_culprit_for_tid(tid):
    return _resolve_idx(_reg_get(tid))
def registry_info():
    return {
        "addr": _REG_ADDR,
        "slots": _REG_N,
        "slot_bytes": (ctypes.sizeof(_Slot) if (_REG_BUF is not None) else 0),
        "backend": ("native-shared" if _REG_BUF is not None else "fallback-dict"),
        "layout": "struct{int64 tid; int32 pid_idx; int32 seq;}",
        "version": _REG_LAYOUT_VER,
    }

def _selftest_registry():
    info = registry_info()
    if _REG_BUF is None:
        _log(f"Block#2 реестр: FALLBACK (ctypes={_CTYPES_OK}) — pure-dict, native-моста нет")
        return
    try:
        test_tid = 0x7FABCD01
        test_idx = _intern("__regtest__")
        _reg_set(test_tid, test_idx)
        ptr = ctypes.cast(_REG_ADDR, ctypes.POINTER(_Slot))
        i = test_tid & (_REG_N - 1); found = None
        for _ in range(_REG_N):
            if ptr[i].tid == test_tid:
                s1 = ptr[i].seq; idx = ptr[i].pid_idx; s2 = ptr[i].seq
                found = idx if (s1 == s2 and not (s1 & 1)) else None
                break
            if ptr[i].tid == 0: break
            i = (i + 1) & (_REG_N - 1)
        ok = (found == test_idx)
        _reg_set(test_tid, -1)
        _log(f"Block#2 реестр self-test: {'PASS' if ok else 'FAIL'} "
             f"(addr=0x{_REG_ADDR:x}, slots={_REG_N}, slot={info['slot_bytes']}B, raw-read={found}/{test_idx})")
    except Exception as e:
        _log(f"Block#2 реестр self-test err: {e}")

def _app_context():
    try:
        c = jclass("org.telegram.messenger.ApplicationLoader")
        ctx = getattr(c, "applicationContext", None)
        return ctx
    except Exception:
        return None

def _b3_native_dir():
    base = None
    ctx = _app_context()
    if ctx is not None:
        try: base = ctx.getCodeCacheDir().getAbsolutePath()
        except Exception:
            try: base = ctx.getFilesDir().getAbsolutePath()
            except Exception: base = None
    if not base: base = _DIR
    d = File(base, "culprit_native")
    try:
        if not d.exists(): d.mkdirs()
    except Exception: pass
    return d.getAbsolutePath()

def _b3_extract_so():
    if not _SO_ARM64:
        return None
    try:
        import base64, zlib
        raw = zlib.decompress(base64.b64decode(_SO_ARM64))
        path = File(_b3_native_dir(), _SO_NAME).getAbsolutePath()
        jf = File(path)
        try:
            if jf.exists() and int(jf.length()) == len(raw):
                return path
        except Exception:
            pass
        try:
            if jf.exists():
                jf.setWritable(True, True); jf.delete()
        except Exception:
            pass
        try:
            with open(path, "wb") as f:
                f.write(raw)
        except OSError as we:
            if jf.exists():
                _log(f"Block#3 extract: повторно использую существующий .so (запись недоступна: {we})")
                return path
            raise
        try:
            jf2 = File(path)
            jf2.setReadable(True, False); jf2.setExecutable(True, False)
        except Exception: pass
        return path
    except Exception as e:
        _log(f"Block#3 extract err: {e}")
        return None

def _b3_decl(lib):
    c = ctypes
    lib.cd_init.argtypes = [c.c_uint64, c.c_int32, c.c_int32]; lib.cd_init.restype = c.c_int
    lib.cd_gettid.restype = c.c_int
