            lib.cd_oom_start.restype = c.c_int
            lib.cd_oom_stop.restype = c.c_int
            lib.cd_oom_seq.restype = c.c_int64
            lib.cd_oom_running.restype = c.c_int
            lib.cd_oom_snap_size.restype = c.c_int32
