            pass

class _MvelOpHook(MethodHook):
    def before_hooked_method(self, param):
        try:
            ow = _mvel_owner_now(param)
            if _MVEL_FIRE_DIAG_ON: _mvel_fire_diag(param, ow)
            if ow: _mvel_mark(ow, "mvel")
        except Exception:
            pass

