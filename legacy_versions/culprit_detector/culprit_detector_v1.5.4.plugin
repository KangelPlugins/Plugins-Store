        self._install_execute(); self._install_exec_errcb(); self._install_loadplugin(); self._install_appevent(); self._install_crash_handler(); self._install_loader_hook(); self._install_b24_dexhook(); self._install_b27_view_hook(); self._install_b28c_proxy_hook(); self._install_b23_bitmap_hook(); self._install_gpu_rs_hook(); self._install_anim_op_hook(); self._install_mvel_op_hook(); self._install_binder_op_hook(); self._install_camera_op_hook(); self._install_mediacodec_op_hook(); self._install_gl_op_hook(); self._install_xphook_op_hook(); self._install_looper_barrier_hook(); self._install_suicide_hook(); self._install_direct_hook(); self._install_thread_start_hook(); self._coexist_selfcheck()
        _log(f"v{__version__} ready (tid registry + crash verdict + native malloc-tags={_NATIVE_OK})")
        try:
            _partb_install()
        except Exception as _eb:
            _log(f"PartB install err: {_eb}")
        try:
