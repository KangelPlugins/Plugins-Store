    return False
_UI_CLICK_ATTRS = ("on_click", "on_long_click", "on_select", "on_toggle", "on_change", "on_value_change")
_UI_CLICK_TL = threading.local()
_UI_CLICK_LAST = {}
_UI_CLICK_LOCK = threading.Lock()
_UI_CLICK_WINDOW_MS = 6000
def _ui_click_enter(pid):
    try:
        st = getattr(_UI_CLICK_TL, "stack", None)
        if st is None:
            st = []; _UI_CLICK_TL.stack = st
        st.append(pid)
    except Exception: pass
    try:
        if pid:
            with _UI_CLICK_LOCK: _UI_CLICK_LAST[pid] = int(time.time() * 1000)
    except Exception: pass
def _ui_click_leave():
    try:
        st = getattr(_UI_CLICK_TL, "stack", None)
        if st: st.pop()
    except Exception: pass
def _ui_click_active_owner():
    try:
        st = getattr(_UI_CLICK_TL, "stack", None)
        if st:
            return st[-1]
    except Exception: pass
    return None
def _ui_click_recent(pid, window_ms=None):
    if not pid: return None
    if window_ms is None: window_ms = _UI_CLICK_WINDOW_MS
    try:
        with _UI_CLICK_LOCK: ts = _UI_CLICK_LAST.get(pid)
        if ts is None: return None
        age = int(time.time() * 1000) - int(ts)
        return age if (0 <= age <= window_ms) else None
    except Exception:
        return None
_RELAUNCH_LAST = {}
_RELAUNCH_GLOBAL_TS = [0]
_RELAUNCH_LOCK = threading.Lock()
_RELAUNCH_WINDOW_MS = 3000
def _own_pkg():
    try:
        p = jclass("android.app.ActivityThread").currentPackageName()
        if p: return str(p)
    except Exception: pass
    try:
        return str(jclass("org.telegram.messenger.ApplicationLoader").applicationContext.getPackageName())
    except Exception: return None
def _relaunch_recent(owner=None, window_ms=None):
    if window_ms is None: window_ms = _RELAUNCH_WINDOW_MS
    try:
        with _RELAUNCH_LOCK:
            ts = None
            if owner and owner != "unknown":
                ts = _RELAUNCH_LAST.get(owner)
            if not ts:
                ts = _RELAUNCH_GLOBAL_TS[0]
        if not ts: return None
        age = int(time.time() * 1000) - int(ts)
        return age if (0 <= age <= window_ms) else None
    except Exception: return None
def _relaunch_note_intent(intent, owner=None):
    try:
        if intent is None: return
        own = _own_pkg()
        if not own: return
        tgt = None
        try:
            pkg = intent.getPackage()
            if pkg: tgt = str(pkg)
        except Exception: pass
        if tgt is None:
            try:
                comp = intent.getComponent()
                if comp is not None: tgt = str(comp.getPackageName())
            except Exception: pass
        if tgt and tgt == own:
            now = int(time.time() * 1000)
            with _RELAUNCH_LOCK:
                if owner and owner != "unknown":
                    _RELAUNCH_LAST[owner] = now
                else:
                    _RELAUNCH_GLOBAL_TS[0] = now
    except Exception: pass
class _HookRelaunchSchedule(MethodHook):
    def before_hooked_method(self, param):
        try:
            owner = None
            try: owner = _b14_caller_owner()
            except Exception: owner = None
            if owner is None:
                try: owner = _hook_scope_pid()
                except Exception: owner = None
            a = param.args
            if a is None: return
            for x in a:
                try:
                    if x is not None and "Intent" in x.getClass().getName():
                        _relaunch_note_intent(x, owner); break
                except Exception: continue
        except Exception: pass
_PM_RESTART_UI = ("View.performClick", "View$PerformClick", "OnClickListener", ".onClick(", "OnLongClickListener", ".onLongClick(", "onLongClick", "performLongClick")
_PM_RESTART_HINT = ("restartApp", ".restart(", "recreate(", "HooksInitFailed", "RestartUtil", "ProcessPhoenix", "_restart_app", "restart_app")
_PM_RESTART_EXIT_TAGS = ("System.exit", "Runtime.exit", "Runtime.halt")
_PM_RESTART_KILL_TAGS = ("Process.killProcess", "killProcess")
def _pm_is_intentional_restart(method_tag, frames, kill_arg, owner_pid=None, pyframes=None):
    try:
        _is_exit = method_tag in _PM_RESTART_EXIT_TAGS
        _is_selfkill = False
        try:
            _is_selfkill = (any(_k in str(method_tag or "") for _k in _PM_RESTART_KILL_TAGS)
                            and kill_arg is not None and int(kill_arg) == int(os.getpid()))
        except Exception:
            _is_selfkill = False
        if not _is_exit and not _is_selfkill: return False
        if _is_exit and kill_arg not in (0, None): return False
        if frames and _pm_is_teardown(frames): return False
        _allfr = list(frames or [])
        if pyframes:
            try: _allfr = _allfr + list(pyframes)
            except Exception: pass
        has_ui = False; has_hint = False
        for fr in _allfr:
            for mk in _PM_RESTART_UI:
                if mk in fr: has_ui = True; break
            for mk in _PM_RESTART_HINT:
                if mk in fr: has_hint = True; break
            if has_ui and has_hint: break
        if has_ui and has_hint:
            return True
        try:
            act = _ui_click_active_owner()
            if act is not None:
                if owner_pid in (None, "unknown", act):
                    _rl = _relaunch_recent(owner_pid if owner_pid not in (None, "unknown") else act)
                    if _rl is not None:
                        _log("PRE-MORTEM +H5.1: exit(%s) внутри UI-click scope owner=%r + запланирован само-перезапуск (%dms) -> benign restart" % (kill_arg, act, _rl))
                        return True
                    _log("PRE-MORTEM +H5.1: exit(%s) внутри UI-click scope owner=%r, НО само-перезапуск НЕ запланирован -> НЕ benign (вероятно plain-exit плагина)" % (kill_arg, act))
                else:
                    _log("PRE-MORTEM +H5.1: активный UI-click owner=%r не совпал с suicide owner=%r -> НЕ benign" % (act, owner_pid))
            if owner_pid and owner_pid != "unknown":
                age = _ui_click_recent(owner_pid)
                if age is not None:
                    _rl = _relaunch_recent(owner_pid)
                    if _rl is not None:
                        _log("PRE-MORTEM +H5.1: exit(%s) через %dms после UI-click owner=%r + запланирован само-перезапуск (%dms) -> benign restart" % (kill_arg, age, owner_pid, _rl))
                        return True
                    _log("PRE-MORTEM +H5.1: exit(%s) через %dms после UI-click owner=%r, НО само-перезапуск НЕ запланирован -> НЕ benign (вероятно plain-exit плагина)" % (kill_arg, age, owner_pid))
        except Exception: pass
        return False
    except Exception:
        return False
def _record_suicide(method_tag, param):
    if getattr(_SUICIDE_TL, "busy", False): return
    _SUICIDE_TL.busy = True
    try:
        jstack = _pm_java_stack(28)
        if _pm_is_teardown(jstack):
            _log("pre-mortem: killProcess в crash-teardown — пропуск (вердикт у _capture_crash)")
            return
        try: _direct_premortem_dump()
        except Exception: pass
        argval = None
        try:
            a = param.args
            if a is not None and len(a) >= 1 and a[0] is not None: argval = int(a[0])
        except Exception: pass
        tid = _cur_tid()
        pid = None; src = "self-kill"
        active_pid = None
        try:
            c = get_culprit_for_tid(tid)
            if c and c != "unknown": active_pid = c
        except Exception: pass
        pyframes = _pm_python_stack(48)
        pid_py = _pm_scan_py(pyframes)
        if pid_py:
            pid = pid_py; src = "self-kill/pystack"
            if active_pid and active_pid != pid_py:
                _log("PRE-MORTEM: live py-стек=%r переопределяет активного scope-owner=%r (устаревший тег)" % (pid_py, active_pid))
        elif active_pid:
            pid = active_pid; src = "self-kill/active"
        crumb_pid = None; crumb_fresh = False; crumb_age = None
        try:
            raw = _CRUMB.read_prev() if _CRUMB is not None else None
            if raw:
                parts = raw.split("\t")
                crumb_pid = parts[0] if parts else None
                if len(parts) >= 3:
                    crumb_age = int(time.time()*1000) - int(parts[2])
                    crumb_fresh = (0 <= crumb_age <= _CRUMB_FRESH_MS)
        except Exception: pass
        if pid is None and crumb_fresh and crumb_pid: pid = crumb_pid; src = "self-kill/breadcrumb"
        if pid is None:
            jpid = _pm_scan_stack(jstack)
            if jpid: pid = jpid; src = "self-kill/jstack"
        if pid is None: pid = "unknown"
        conf = "high" if src in ("self-kill/active", "self-kill/pystack") else ("medium" if pid != "unknown" else "none")
        benign_restart = _pm_is_intentional_restart(method_tag, jstack, argval, pid, pyframes=pyframes)
        if benign_restart:
            src = "self-kill/intentional-restart"; conf = "none"
            try:
                if _NLIB is not None and hasattr(_NLIB, "cd_kg_permit_restart"):
                    _NLIB.cd_kg_permit_restart()
                    _log("PRE-MORTEM: намеренный рестарт (кнопка) -> kill-guard пропускает exit, не виновник")
                else:
                    _log("PRE-MORTEM: намеренный рестарт (кнопка) -> benign (permit недоступен: старый .so)")
            except Exception as _pe:
                _log("PRE-MORTEM permit err: %s" % _pe)
        rec = {
            "had_crash": True, "crashed_plugin_id": pid, "src": src, "confidence": conf,
            "exc_cls": "ProcessTermination", "exc_msg": "%s(%s)" % (method_tag, argval),
            "thread": _pm_thread_name(), "via_hook": False, "hooked_method": method_tag,
            "self_kill": True, "benign_restart": benign_restart, "kill_method": method_tag, "kill_arg": argval,
            "pid_stack": active_pid,
            "pid_crumb": crumb_pid, "crumb_fresh": crumb_fresh, "crumb_age_ms": crumb_age,
            "py_stack": pyframes[:40], "pid_py": pid_py,
            "stack_top": jstack[:40], "ts": int(time.time()*1000),
        }
        rec = _b16_correlate(rec)
        _write_crash_verdict(rec)
        _log("PRE-MORTEM %s(%s): виновник=%r src=%s conf=%s" % (method_tag, argval, pid, src, conf))
    except Exception as _se:
        try: _log("pre-mortem record err: %s" % _se)
        except Exception: pass
    finally:
        try: _SUICIDE_TL.busy = False
        except Exception: pass
