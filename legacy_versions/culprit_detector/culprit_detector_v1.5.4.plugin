        if not d.exists(): d.mkdirs()
        return File(d, _KG_HISTORY_NAME).getAbsolutePath()
    except Exception:
        return None

def _md_hist_best(crash_ts):
    try:
        if crash_ts is None:
            return None
        ct = int(crash_ts)
        hp = _kg_history_path()
        if not (hp and os.path.exists(hp)):
            return None
        with open(hp, "r", encoding="utf-8") as f:
            hist = list(json.load(f))
    except Exception:
        return None
    best = None; best_d = None
    for it in hist:
        try:
            if not isinstance(it, dict) or it.get("event_type") != "selfkill_blocked":
                continue
            d = abs(int(it.get("ts")) - ct)
            if d <= _MD_VERDICT_FRESH_MS and (best_d is None or d < best_d):
                best = it; best_d = d
        except Exception:
            continue
    return best

