    def _t(self, s):
        return _cd_tr(s)

    def _ui_conf_label(self, c):
        try:
            c = str(c or "").lower()
        except Exception:
            c = ""
        if c.startswith("high") or c == "высокая": return self._t("🟢 высокая")
        if c.startswith("med") or c == "средняя":  return self._t("🟡 средняя")
        if c.startswith("low") or c == "низкая":   return self._t("🟠 низкая")
        return "⚪️ —"

    def _ui_when(self, ts):
        try:
            import time as _t
            if ts is None: return "—"
            if isinstance(ts, str):
                if "-" in ts and ":" in ts: return ts[5:16].replace("-", ".")
                ts = float(ts)
            ts = float(ts)
            if ts > 1e11: ts = ts / 1000.0
            return _t.strftime("%d.%m %H:%M", _t.localtime(ts))
        except Exception:
            return "—"

    def _ui_pretty_plugin(self, name):
        try:
            s = str(name or "").strip()
            if not s: return self._t("неизвестный плагин")
            if "/" in s: s = s.rsplit("/", 1)[1]
            if s.endswith(".py"): s = s[:-3]
            return self._t(s)
        except Exception:
            return self._t("неизвестный плагин")

    def _ui_extract(self, d, src):
        try:
            fname, label, emoji, what, gate = src
            if not isinstance(d, dict): return None
            if bool(d.get("benign_restart")): return None
            if gate and not any(bool(d.get(g)) for g in gate): return None
            if fname == "client_lowmem.json": return None
            if fname == "self_overhead.json":
                try:
                    _dl = d.get("degrade_level") or 0
                    _act = bool(d.get("action"))
                    _uis = float(d.get("ui_self_ms_per_s") or 0.0)
                    _tos = float(d.get("total_self_ms_per_s") or 0.0)
                    _uib = float(d.get("ui_budget_ms_per_s") or 8.0)
                    _tob = float(d.get("total_budget_ms_per_s") or 25.0)
                    _cpu_over = (_uis > _uib) or (_tos > _tob)
                    _g = d.get("gil") if isinstance(d.get("gil"), dict) else {}
                    _off = float(_g.get("ui_off_cpu_ms_per_s") or 0.0)
                    _hld = _g.get("holders") if isinstance(_g.get("holders"), list) else []
                    _hsum = 0.0
                    for _h in _hld:
                        try: _hsum += float(_h.get("held_ms_per_s") or 0.0)
                        except Exception: pass
                    _self_dominant = bool(_cpu_over or _act or (_dl and _dl > 0) or (_off > 0 and _hsum >= 0.5 * _off))
                    if not _self_dominant:
                        return None
                except Exception:
                    pass
            vd = d.get("verdict") if isinstance(d.get("verdict"), dict) else {}
            def _g(k):
                v = d.get(k)
                if v is None: v = vd.get(k)
                return v
            ck = d.get("culprit_kind")
            is_native = (fname in ("native_crash_verdict.json", "native_crash_history.json"))
            if isinstance(ck, str) and ck == "system" and not is_native:
                return None
            culprit = (d.get("culprit") or d.get("crashed_plugin_id")
                       or vd.get("culprit") or _g("top_named")
                       or d.get("pid") or d.get("plugin")
                       or d.get("py_module") or d.get("scoped_pid")
                       or d.get("owner"))
            if not culprit and isinstance(ck, str):
                if ck.startswith("plugin:"):
                    culprit = ck.split(":", 1)[1]
                elif ck == "host":
                    culprit = d.get("host_so_owner") or "host"
            if not culprit:
                top = d.get("top")
                if isinstance(top, list) and top:
                    try:
                        first = top[0]
                        culprit = first[0] if isinstance(first, (list, tuple)) else first
                    except Exception:
                        culprit = None
            if not culprit and is_native:
                culprit = _UNTAGGED_LABEL
            if not culprit: return None
            if culprit == _UNTAGGED_LABEL and vd.get("native_site_culprit") and vd.get("reason_detail") != "ambient_device_pressure":
                culprit = vd.get("native_site_culprit")
            reason = _g("reason")
            try:
                db = vd.get("display_bytes") or vd.get("culprit_bytes")
                sh = vd.get("display_share") or vd.get("share")
                if db:
                    mb = float(db) / 1048576.0
                    human = self._t("съел %.0f МБ") % mb
                    _rd = vd.get("reason_detail") or ""
                    if _rd == "async_download_pattern":
                        _unt = vd.get("untagged_bytes") or 0
                        _tnb = vd.get("culprit_bytes") or 0
                        _ar = round(float(_unt) / float(_tnb), 1) if _tnb > 0 else 0.0
                        human += " +async×%.1f" % _ar
                    elif _rd == "rate_suspect":
                        human += self._t(" (подозрев.)")
                    reason = human
            except Exception:
                pass
            if not reason:
                if d.get("cause"): reason = str(d.get("cause"))
                elif d.get("exc_cls"): reason = "%s: %s" % (d.get("exc_cls"), d.get("exc_msg"))
                elif d.get("stalled_ms"): reason = self._t("интерфейс не отвечал %s мс") % d.get("stalled_ms")
                elif vd.get("reason_detail"): reason = str(vd.get("reason_detail"))
                elif d.get("summary"): reason = str(d.get("summary"))
                else: reason = ""
            if not reason and fname in ("client_leak.json", "client_oom_killed.json"):
                reason = what
            where = ""
            if d.get("py_file"):
                pf = str(d.get("py_file")).split("/")[-1]
                where = pf + ((":" + str(d.get("py_line"))) if d.get("py_line") else "")
            elif d.get("host_so"):
                where = self._t("нативная библиотека: ") + str(d.get("host_so")).split("/")[-1]
            elif _g("where"):
                where = str(_g("where"))
            ts = d.get("ts")
            tss = 0
            try:
                if isinstance(ts, (int, float)):
                    tss = float(ts) / 1000.0 if ts > 1e11 else float(ts)
                elif isinstance(ts, str):
                    import time as _t2
                    if "-" in ts and ":" in ts:
                        tss = _t2.mktime(_t2.strptime(ts, "%Y-%m-%d %H:%M:%S"))
                    else:
                        tss = float(ts)
                        if tss > 1e11: tss = tss / 1000.0
            except Exception:
                tss = 0
            return {"label": self._t(label), "emoji": emoji, "what": self._t(what),
                    "culprit": self._ui_pretty_plugin(culprit),
                    "conf": self._ui_conf_label(_g("confidence")),
                    "reason": (self._t(reason) if reason else reason), "where": where, "ts": ts, "ts_sort": tss, "conf_raw": self._ui_conf_rank(_g("confidence")), "culprit_raw": culprit, "cat": self._ui_flt_cat_of(fname), "src": fname}
        except Exception:
            return None

    def _ui_collect_culprits(self):
        cards = []
        try:
            import os, json, glob
            for src in self._UI_VERDICT_SOURCES:
                pattern = _DIR + "/" + src[0]
                try:
                    paths = glob.glob(pattern)
                except Exception:
                    paths = []
                try:
                    mp_pat = _aw_mirror_path(src[0])
                    if mp_pat:
                        paths.extend(glob.glob(mp_pat))
                except Exception:
                    pass
                for p in paths:
                    try:
                        with open(p, "r", encoding="utf-8", errors="replace") as fh:
                            d = json.load(fh)
                    except Exception:
                        continue
                    items = d if isinstance(d, list) else [d]
                    for it in items:
                        card = self._ui_extract(it, src)
                        if card: cards.append(card)
        except Exception as e:
            _log("ui collect culprits err: %s" % e)
        try:
            seen = set(); uniq = []
            for c in cards:
                k = (c.get("label"), c.get("culprit"), c.get("ts"))
                if k in seen: continue
                seen.add(k); uniq.append(c)
            cards = uniq
        except Exception:
            pass
        try:
            cards.sort(key=lambda c: c.get("ts_sort") or 0, reverse=True)
        except Exception:
            pass
        return cards

    def _ui_clear(self, *a):
        def _do_reset():
            removed = 0
            try:
                try: self.on_plugin_unload()
                except Exception as _eu: _log("reset: unload err: %s" % _eu)
                import os
                for d in (globals().get("_DIR"), _app_priv_dir()):
                    if not d: continue
                    try:
                        for nm in os.listdir(d):
                            pth = os.path.join(d, nm)
                            try:
                                if os.path.isfile(pth) or os.path.islink(pth):
                                    os.remove(pth); removed += 1
                            except Exception: pass
                    except Exception: pass
                global _RECENT_VERDICTS, _B23_BYTES, _B23_COUNT, _B23_PEAK, _B23_OOM, _B23_RING
                global _B28_HOOK_HITS, _LEAK_SEG_RING, _DIRECT_TOTAL, _DIRECT_UNTAGGED
                try:
                    with _RECENT_VERDICTS_LOCK: _RECENT_VERDICTS.clear()
                except Exception: pass
                try:
                    with _B23_LOCK:
                        _B23_BYTES.clear(); _B23_COUNT.clear(); _B23_PEAK.clear()
                        _B23_OOM.clear(); _B23_RING.clear()
                except Exception: pass
                try:
                    with _B28_HOOK_HITS_LOCK: _B28_HOOK_HITS.clear()
                except Exception: pass
                try:
                    _LEAK_SEG_RING.clear()
                    _DIRECT_TOTAL = 0; _DIRECT_UNTAGGED = 0
                except Exception: pass
                try: self.on_plugin_load()
                except Exception as _el: _log("reset: load err: %s" % _el)
                try:
                    with _INTERN_LOCK:
                        _persist_pidindex()
                        _persist_idxnames()
                except Exception as _ep: _log("reset: idx re-persist err: %s" % _ep)
                try: _VERDICT_DEDUP.clear()
                except Exception: pass
                _log("UI: полный сброс выполнен, удалено файлов=%d" % removed)
                try:
                    from client_utils import get_last_fragment, run_on_ui_thread
                    def _close_subpage():
                        try:
                            fr = get_last_fragment()
                            if fr is not None:
                                fr.finishFragment()
                        except Exception as _ec:
                            _log("reset: close subpage err: %s" % _ec)
                    run_on_ui_thread(_close_subpage)
                except Exception as _ecl:
                    _log("reset: ui-thread close err: %s" % _ecl)
            except Exception as e:
                _log("ui reset err: %s" % e)
        try:
            threading.Thread(target=_do_reset, name="culprit-reset", daemon=True).start()
        except Exception:
            _do_reset()

    def _ui_refresh_pending(self):
        try:
            _oom_consume_native("settings", do_log=False)
        except Exception:
            pass
        try:
            _read_native_crash()
        except Exception:
            pass
        try:
            _read_globalref_overflow(logcat=False)
        except Exception:
            pass

    def _ui_copy_results(self, *a):
        """Copy all culprit verdicts to clipboard."""
        try:
            cards = self._ui_collect_culprits()
            if not cards:
                try:
                    from ui.bulletin import BulletinHelper
                    BulletinHelper.show_info(self._t("Нет результатов для копирования"))
                except Exception:
                    pass
                return
            lines = []
            lines.append("=" * 70)
            lines.append(self._t(" Culprit Detector — Результаты анализа виновников"))
            lines.append(self._t("Версия: %s") % __version__)
            lines.append(self._t("Найдено виновников: %d") % len(cards))
            lines.append("=" * 70)
            lines.append("")
            for i, c in enumerate(cards, 1):
                lines.append("[%d] %s %s" % (i, c.get("emoji", ""), c.get("label", "-")))
                lines.append(self._t("  Виноват: %s") % c.get("culprit", "?"))
                if c.get("reason"):
                    lines.append(self._t("  Что случилось: %s") % c["reason"])
                lines.append(self._t("  Когда: %s") % self._ui_when(c.get("ts", 0)))
                lines.append(self._t("  Уверенность: %s") % c.get("conf", "?"))
                if c.get("where"):
                    lines.append(self._t("  Где: %s") % c["where"])
                lines.append("")
            lines.append("=" * 70)
            text = "\n".join(lines)
            
            try:
                from java import jclass
                Context = jclass("android.content.Context")
                ClipData = jclass("android.content.ClipData")
                AppLoader = jclass("org.telegram.messenger.ApplicationLoader")
                ctx = AppLoader.applicationContext
                clipboard = ctx.getSystemService(Context.CLIPBOARD_SERVICE)
                clip = ClipData.newPlainText("Culprit Detector Results", text)
                clipboard.setPrimaryClip(clip)
                _log("UI: copied %d results to clipboard (%d chars)" % (len(cards), len(text)))
                try:
                    from ui.bulletin import BulletinHelper
                    BulletinHelper.show_success(self._t("Скопировано результатов: %d") % len(cards))
                except Exception:
                    pass
            except Exception as e:
                _log("UI copy error: %s" % e)
                try:
                    from ui.bulletin import BulletinHelper
                    BulletinHelper.show_error(self._t("Ошибка копирования: %s") % str(e)[:40])
                except Exception:
                    pass
        except Exception as e:
            _log("_ui_copy_results err: %s" % e)

    def _ui_clipboard_put(self, label, text):
        """+FI: shared clipboard helper (used by copy-all and copy-one)."""
        try:
            from java import jclass
            Context = jclass("android.content.Context")
            ClipData = jclass("android.content.ClipData")
            AppLoader = jclass("org.telegram.messenger.ApplicationLoader")
            ctx = AppLoader.applicationContext
            clipboard = ctx.getSystemService(Context.CLIPBOARD_SERVICE)
            clip = ClipData.newPlainText(label, text)
            clipboard.setPrimaryClip(clip)
            _log("UI: copied to clipboard (%d chars)" % len(text))
            return True
        except Exception as e:
            _log("UI clipboard error: %s" % e)
            try:
                from ui.bulletin import BulletinHelper
                BulletinHelper.show_error(self._t("Ошибка копирования: %s") % str(e)[:40])
            except Exception:
                pass
            return False

    def _ui_copy_one(self, c, *a):
        """+FI: copy a SINGLE culprit's data to clipboard (bound to its title row on_click)."""
        try:
            if not c:
                return
            lines = []
            lines.append("=" * 70)
            lines.append(self._t(" Culprit Detector — виновник"))
            lines.append(self._t("Версия: %s") % __version__)
            lines.append("=" * 70)
            lines.append("%s %s" % (c.get("emoji", ""), c.get("label", "-")))
            lines.append(self._t("  Виноват: %s") % c.get("culprit", "?"))
            if c.get("reason"):
                lines.append(self._t("  Что случилось: %s") % c["reason"])
            lines.append(self._t("  Когда: %s") % self._ui_when(c.get("ts", 0)))
            lines.append(self._t("  Уверенность: %s") % c.get("conf", "?"))
            if c.get("where"):
                lines.append(self._t("  Где: %s") % c["where"])
            lines.append("=" * 70)
            text = "\n".join(lines)
            if self._ui_clipboard_put("Culprit Detector — culprit", text):
                try:
                    from ui.bulletin import BulletinHelper
                    BulletinHelper.show_success(self._t("Скопирован виновник: %s") % c.get("label", "-"))
                except Exception:
                    pass
        except Exception as e:
            _log("_ui_copy_one err: %s" % e)

    _FLT_LEVELS = ("all", "high", "highmed", "low")
    _FLT_CATS = ("all", "crash", "anr", "mem", "other")

    def _ui_conf_rank(self, c):
        try:
            c = str(c or "").lower()
        except Exception:
            c = ""
        if c.startswith("high") or c == "высокая": return "high"
        if c.startswith("med") or c == "средняя":  return "med"
        if c.startswith("low") or c == "низкая":   return "low"
        return ""

    def _ui_flt_cat_of(self, fname):
        f = fname or ""
        if f.startswith("native_crash") or f.startswith("crash_verdict") or f == "cxa_verdict.json":
            return "crash"
        if f.startswith("anr_verdict") or f.startswith("host_stall"):
            return "anr"
        if (f.startswith("oom_dump") or f.startswith("b23_bitmap_oom") or f.startswith("client_oom")
                or f in ("client_lowmem.json", "client_trim_unavailable.json", "client_lowmem_unavailable.json", "client_leak.json", "globalref_verdict.json", "leak_verdict.json")):
            return "mem"
        return "other"

    def _ui_apply_filter(self, cards):
        try: lvl_i = int(self.get_setting("flt_level", 0) or 0)
        except Exception: lvl_i = 0
        try: cat_i = int(self.get_setting("flt_cat", 0) or 0)
        except Exception: cat_i = 0
        try: named_only = bool(self.get_setting("flt_named", False))
        except Exception: named_only = False
        try: rx_raw = (self.get_setting("flt_regex", "") or "").strip()
        except Exception: rx_raw = ""
        lvl = self._FLT_LEVELS[lvl_i] if 0 <= lvl_i < len(self._FLT_LEVELS) else "all"
        cat = self._FLT_CATS[cat_i] if 0 <= cat_i < len(self._FLT_CATS) else "all"
        rx = None
        if rx_raw:
            try: rx = re.compile(rx_raw, re.IGNORECASE)
            except Exception: rx = None
        out = []
        for c in cards:
            try:
                cr = c.get("conf_raw") or ""
                if lvl == "high" and cr != "high": continue
                if lvl == "highmed" and cr not in ("high", "med"): continue
                if lvl == "low" and cr != "low": continue
                if cat != "all" and (c.get("cat") or "other") != cat: continue
                if named_only:
                    craw = c.get("culprit_raw")
                    if (not craw) or (craw in (_UNTAGGED_LABEL, "unknown", "?")): continue
                if rx is not None:
                    hay = " ".join([str(c.get("label") or ""), str(c.get("culprit") or ""),
                                    str(c.get("reason") or ""), str(c.get("where") or "")])
                    if not rx.search(hay): continue
                out.append(c)
            except Exception:
                out.append(c)
        parts = []
        if lvl != "all":
            parts.append(self._t("уровень: %s") % {"high": self._t("Только высокая"), "highmed": self._t("Высокая+средняя"), "low": self._t("Только низкая")}.get(lvl, lvl))
        if cat != "all":
            parts.append(self._t("категория: %s") % {"crash": self._t("Краши"), "anr": self._t("Зависания"), "mem": self._t("Память"), "other": self._t("Прочее")}.get(cat, cat))
        if named_only: parts.append(self._t("только названные"))
        if rx_raw: parts.append(self._t("regex: %s") % rx_raw)
        return out, (", ".join(parts) if parts else None)

    def _ui_card_logs(self, c, *a):
        def _ui_post(fn):
            try:
                from client_utils import run_on_ui_thread
                run_on_ui_thread(fn); return True
            except Exception:
                pass
            try:
                import android_utils
                android_utils.run_on_ui_thread(fn, 0); return True
            except Exception:
                pass
            _log("_ui_card_logs: UI-поток недоступен -> UI-вызов пропущен (фон-safe)")
            return False
        def _note(kind, msg):
            def _show():
                try:
                    from ui.bulletin import BulletinHelper
                    getattr(BulletinHelper, kind)(msg)
                except Exception:
                    pass
            _ui_post(_show)
        def _work():
            try:
                PRE_MS = 8000; POST_MS = 8000; MAX_LINES = 800; MAX_CHARS = 60000
                center = None
                try:
                    tss = c.get("ts_sort")
                    if tss: center = int(float(tss) * 1000.0)
                except Exception:
                    center = None
                if not center:
                    try:
                        ts = c.get("ts")
                        if isinstance(ts, (int, float)):
                            center = int(ts if ts > 1e11 else ts * 1000.0)
                    except Exception:
                        center = None
                _card_base = ""
                try: _card_base = c.get("src") or ""
                except Exception: _card_base = ""
                _reuse_body = None
                if _card_base and center:
                    try:
                        _ex = _moment_find_existing_path(_card_base, center, (c.get("culprit_raw") or c.get("culprit")))
                        if _ex:
                            with open(_ex, "r", encoding="utf-8", errors="replace") as _rf:
                                _reuse_body = _rf.read()
                            _log("+HV: card-logs reuse existing snapshot -> %s" % _ex)
                    except Exception as _re:
                        _log("+HV: card-logs reuse lookup err: %s" % _re); _reuse_body = None
                if _reuse_body is not None:
                    body = _reuse_body
                    n = body.count("\n")
                else:
                    texts = []
                    try: texts = _b28_read_logcat(prefilter=False)
                    except Exception as e: _log("card_logs: logcat read err: %s" % e)
                    picked = []; total = 0; keep = False
                    for blob in texts:
                        for ln in blob.split("\n"):
                            ets = _b28_logcat_event_ts(ln)
                            if ets is not None:
                                keep = (center is not None) and (-PRE_MS <= (ets - center) <= POST_MS)
                            if keep:
                                picked.append(ln); total += len(ln) + 1
                                if len(picked) >= MAX_LINES or total >= MAX_CHARS: break
                        if len(picked) >= MAX_LINES or total >= MAX_CHARS: break
                    tail_mode = False
                    if not picked:
                        tail_mode = True
                        allln = []
                        for blob in texts: allln.extend(blob.split("\n"))
                        picked = allln[-300:]
                    head = ["Culprit Detector — %s" % self._t("логи момента"),
                            "%s %s" % (c.get("emoji", ""), c.get("label", "-")),
                            self._t("Виноват: %s") % c.get("culprit", "?"),
                            self._t("Когда: %s") % self._ui_when(c.get("ts", 0))]
                    if center: head.append("crash_ts=%d  window=-%dms/+%dms" % (center, PRE_MS, POST_MS))
                    if _card_base and center: head.append("event_id=%s  source=%s" % (_moment_event_id(_card_base, center, (c.get("culprit_raw") or c.get("culprit"))), _card_base))
                    if tail_mode: head.append(self._t("(точное время не найдено — показан хвост logcat)"))
                    head.append("=" * 60)
                    body = "\n".join(head) + "\n" + "\n".join(picked)
                    n = len(picked)
                    if _card_base and center:
                        try:
                            _fn = _moment_filename(_card_base, center, (c.get("culprit_raw") or c.get("culprit")))
                            _tp = os.path.join(_DIR, _fn)
                            if not os.path.exists(_tp) and _moment_write_text(_tp, body):
                                _moment_index_upsert(_moment_event_id(_card_base, center, (c.get("culprit_raw") or c.get("culprit"))), {"file": _fn, "source": _card_base, "culprit": c.get("culprit_raw") or c.get("culprit"), "label": c.get("label"), "center_ms": int(center), "created_ms": int(time.time() * 1000), "origin": "button"})
                        except Exception as _pe:
                            _log("+HV: card-logs persist err: %s" % _pe)
                def _put():
                    txt_path = None
                    try:
                        from java import jclass
                        from java.io import File as _File
                        AppLoader = jclass("org.telegram.messenger.ApplicationLoader")
                        ctx = AppLoader.applicationContext
                        cache = ctx.getExternalCacheDir() or ctx.getCacheDir()
                        out_dir = _File(cache, "culprit_logs")
                        try:
                            if not out_dir.exists(): out_dir.mkdirs()
                            if not (out_dir.exists() and out_dir.isDirectory()): out_dir = cache
                        except Exception:
                            out_dir = cache
                        stamp = time.strftime("%Y%m%d_%H%M%S", time.localtime())
                        txt_file = _File(out_dir, "culprit_moment_%s.txt" % stamp)
                        txt_path = str(txt_file.getAbsolutePath())
                        with open(txt_path, "w", encoding="utf-8", errors="replace") as _wf:
                            _wf.write(body)
                        _log("card_logs: wrote %d lines -> %s (%d bytes)" % (n, txt_path, txt_file.length()))
                    except Exception as _we:
                        _log("card_logs: write txt failed: %s" % _we); txt_path = None
                    if not txt_path:
                        _note("show_error", self._t("Не удалось записать файл логов")); return
                    try:
                        self._ui_share_file(txt_path, "text/plain", "Culprit Detector logs", self._t("📜 Логи момента"))
                        _note("show_success", self._t("Строк логов: %d") % n)
                    except Exception as _se:
                        _log("card_logs: share failed: %s" % _se)
                        _note("show_error", self._t("Не удалось открыть «Поделиться»: %s") % str(_se)[:40])
                _ui_post(_put)
            except Exception as e:
                _log("_ui_card_logs err: %s" % e)
                _note("show_error", self._t("Ошибка чтения логов: %s") % str(e)[:40])
        _note("show_info", self._t("Читаю logcat…"))
        try:
            threading.Thread(target=_work, name="culprit-cardlogs", daemon=True).start()
        except Exception:
            _work()

    def _ui_send_logs(self, *a):
        """Zip every file in the detector folder and open the system share sheet (pick a contact)."""
        def _note(kind, msg):
            try:
                from ui.bulletin import BulletinHelper
                getattr(BulletinHelper, kind)(msg)
            except Exception:
                pass
        try:
            from java import jclass
            from java.io import File as _File, FileInputStream, FileOutputStream
            from java.util.zip import ZipOutputStream, ZipEntry

            base = _File(_DIR)
            if (not base.exists()) or (not base.isDirectory()):
                _note("show_info", self._t("Папка логов пуста")); return
            names = base.list()
            files = []
            if names is not None:
                for nm in names:
                    try:
                        if nm == _SELF_BACKUP_NAME or nm.startswith(_SELF_BACKUP_NAME):
                            continue
                        f = _File(base, nm)
                        if f.isFile() and f.length() > 0:
                            files.append(f)
                    except Exception:
                        pass
            try:
                _have = {}
                for _i, _f in enumerate(files):
                    try: _have[_f.getName()] = _i
                    except Exception: pass
                for _mp in _aw_mirror_list():
                    try:
                        _mf = _File(_mp)
                        if _mf.isFile() and _mf.length() > 0:
                            _nm = _mf.getName()
                            if _nm not in _have:
                                files.append(_mf); _have[_nm] = len(files) - 1
                            else:
                                _oi = _have[_nm]
                                if _mf.lastModified() > files[_oi].lastModified():
                                    files[_oi] = _mf
                    except Exception: pass
            except Exception: pass
            if not files:
                _note("show_info", self._t("Папка логов пуста")); return

            _note("show_info", self._t("Готовлю архив…"))

            AppLoader = jclass("org.telegram.messenger.ApplicationLoader")
            ctx = AppLoader.applicationContext
            cache = ctx.getExternalCacheDir() or ctx.getCacheDir()
            out_dir = _File(cache, "culprit_logs")
            try:
                if not out_dir.exists():
                    out_dir.mkdirs()
                if not (out_dir.exists() and out_dir.isDirectory()):
                    out_dir = cache
            except Exception:
                out_dir = cache
            stamp = time.strftime("%Y%m%d_%H%M%S", time.localtime())
            zip_file = _File(out_dir, "culprit_logs_%s.zip" % stamp)
            try:
                _xnames = []
                _xpos = {}
                for _xi, _xf0 in enumerate(files):
                    try:
                        _xn0 = str(_xf0.getName()); _xnames.append(_xn0); _xpos[_xn0] = _xi
                    except Exception: pass
                for _ep in (_send_logs_extras(_xnames) or []):
                    try:
                        _epf = _File(_ep)
                        if _epf.isFile() and _epf.length() > 0:
                            _en = str(_epf.getName())
                            if _en in _xpos:
                                files[_xpos[_en]] = _epf
                            else:
                                _xpos[_en] = len(files); files.append(_epf)
                    except Exception: pass
            except Exception as _exe:
                _log("send_logs: extras err: %s" % _exe)

            fos = FileOutputStream(zip_file)
            zos = ZipOutputStream(fos)
            count = 0
            try:
                for f in files:
                    snap = None; src = f
                    try:
                        snap = _File(out_dir, f.getName() + ".snap")
                        _snap_path = str(snap.getAbsolutePath())
                        with open(str(f.getAbsolutePath()), "rb") as _fin, open(_snap_path, "wb") as _fout:
                            while True:
                                _chunk = _fin.read(65536)
                                if not _chunk:
                                    break
                                _fout.write(_chunk)
                        src = snap
                    except Exception as _e:
                        _log("send_logs: snapshot %s failed: %s" % (f.getName(), _e)); src = f
                        try:
                            if snap is not None and snap.exists(): snap.delete()
                        except Exception: pass
                        snap = None
                    try:
                        zos.putNextEntry(ZipEntry(f.getName()))
                        with open(str(src.getAbsolutePath()), "rb") as _zin:
                            while True:
                                _chunk = _zin.read(65536)
                                if not _chunk:
                                    break
                                zos.write(_chunk)
                        zos.closeEntry()
                        count += 1
                    except Exception as e:
                        _log("send_logs: skip %s: %s" % (f.getName(), e))
                    finally:
                        try:
                            if snap is not None and snap.exists(): snap.delete()
                        except Exception: pass
            finally:
                try: zos.close()
                except Exception: pass
                try: fos.close()
                except Exception: pass

            if count == 0:
                _note("show_error", self._t("Ошибка упаковки: %s") % "no entries"); return
            _log("send_logs: zipped %d files -> %s (%d bytes)" % (count, zip_file.getAbsolutePath(), zip_file.length()))

            Intent = jclass("android.content.Intent")
            uri = None
            authority = ctx.getPackageName() + ".provider"
            try:
                AndroidxFP = jclass("androidx.core.content.FileProvider")
                uri = AndroidxFP.getUriForFile(ctx, authority, zip_file)
            except Exception as e1:
                _log("send_logs: androidx FileProvider failed: %s" % e1)
                try:
                    FileProviderCls = jclass(ctx.getPackageName() + ".FileProvider")
                    uri = FileProviderCls.getUriForFile(ctx, authority, zip_file)
                except Exception as e2:
                    _log("send_logs: tg FileProvider failed: %s" % e2)
                    try:
                        UriCls = jclass("android.net.Uri")
                        uri = UriCls.fromFile(zip_file)
                    except Exception as e3:
                        _log("send_logs: Uri.fromFile failed: %s" % e3)
            if uri is None:
                _note("show_error", self._t("Не удалось открыть «Поделиться»: %s") % "uri=None"); return

            share = Intent(Intent.ACTION_SEND)
            share.setType("application/zip")
            share.putExtra(Intent.EXTRA_STREAM, uri)
            try: share.putExtra(Intent.EXTRA_SUBJECT, "Culprit Detector logs")
            except Exception: pass
            share.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION)

            chooser = Intent.createChooser(share, self._t(" Отправить логи"))
            chooser.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)
            chooser.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION)

            launched = False
            try:
                LaunchActivity = jclass("org.telegram.ui.LaunchActivity")
                act = getattr(LaunchActivity, "instance", None)
                if act is not None:
                    act.startActivity(chooser)
                    launched = True
            except Exception as e:
                _log("send_logs: activity start failed: %s" % e)
            if not launched:
                ctx.startActivity(chooser)

            _note("show_success", self._t("Файлов в архиве: %d") % count)
        except Exception as e:
            _log("_ui_send_logs err: %s" % e)
            _note("show_error", self._t("Не удалось открыть «Поделиться»: %s") % str(e)[:40])

    def _ui_share_file(self, path, mime, subject, chooser_title):
        from java import jclass
        from java.io import File as _File
        f = _File(path)
        AppLoader = jclass("org.telegram.messenger.ApplicationLoader")
        ctx = AppLoader.applicationContext
        Intent = jclass("android.content.Intent")
        uri = None
        authority = ctx.getPackageName() + ".provider"
        try:
            AndroidxFP = jclass("androidx.core.content.FileProvider")
            uri = AndroidxFP.getUriForFile(ctx, authority, f)
        except Exception as e1:
            _log("share_file: androidx FileProvider failed: %s" % e1)
            try:
                FileProviderCls = jclass(ctx.getPackageName() + ".FileProvider")
                uri = FileProviderCls.getUriForFile(ctx, authority, f)
            except Exception as e2:
                _log("share_file: tg FileProvider failed: %s" % e2)
                try:
                    UriCls = jclass("android.net.Uri")
                    uri = UriCls.fromFile(f)
                except Exception as e3:
                    _log("share_file: Uri.fromFile failed: %s" % e3)
        if uri is None:
            raise RuntimeError("uri=None")
        share = Intent(Intent.ACTION_SEND)
        share.setType(mime)
        share.putExtra(Intent.EXTRA_STREAM, uri)
        try: share.putExtra(Intent.EXTRA_SUBJECT, subject)
        except Exception: pass
        share.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION)
        chooser = Intent.createChooser(share, chooser_title)
        chooser.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)
        chooser.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION)
        launched = False
        try:
            LaunchActivity = jclass("org.telegram.ui.LaunchActivity")
            act = getattr(LaunchActivity, "instance", None)
            if act is not None:
                act.startActivity(chooser)
                launched = True
        except Exception as e:
            _log("share_file: activity start failed: %s" % e)
        if not launched:
            ctx.startActivity(chooser)

    def _ui_so_warning(self, rows):
        """Prepend a warning block when the native .so is missing or outdated."""
        try:
            h = _so_health()
        except Exception:
            return
        if not h or h.get("ok"):
            return
        st = h.get("state")
        if st == "not_loaded":
            title = self._t("⚠️ Нативная библиотека не загружена")
            sub = self._t("Детект ANR/OOM и точная атрибуция по PID отключены — результаты ниже могут быть неполными. Пересобери и встрой libculprit.so.")
        elif st == "abi_mismatch":
            title = self._t("⚠️ Версия нативной библиотеки не совпадает")
            sub = self._t("ABI .so=%d, нужно %d. Пересобери и встрой актуальную libculprit.so.") % (h.get("abi") if h.get("abi") is not None else -1, h.get("expect") if h.get("expect") is not None else -1)
        else:
            title = self._t("⚠️ Устаревшая нативная библиотека")
            sub = self._t("libculprit.so без версии (старый бинарь). Пересобери .so из текущих исходников и встрой заново.")
        rows.append(Text(text=title, subtext=sub, icon="msg_report", accent=True))
        try:
            feats = _so_features_str()
            if feats:
                rows.append(Text(text="", subtext=feats, icon="msg_info"))
        except Exception:
            pass
        rows.append(Divider())

    def _ui_logfilter_subpage(self):
        try: lvl_i = int(self.get_setting("b28_min_level", 0) or 0)
        except Exception: lvl_i = 0
        if not (0 <= lvl_i < len(_B28_LEVELS)): lvl_i = 0
        cur_re = None
        try: cur_re = self.get_setting("b28_keep_re", None)
        except Exception: cur_re = None
        if not isinstance(cur_re, str) or not cur_re: cur_re = _B28_KEEP_RE_ERE
        try: flt_on = bool(self.get_setting("b28_filter_on", True))
        except Exception: flt_on = True
        rows = [Header(text=self._t(" Фильтр logcat"))]
        rows.append(Switch(key="b28_filter_on", text=self._t("Пре-фильтрация в нативном слое"), default=flt_on, subtext=self._t("Отбор по уровню и regex до Python — быстрее и меньше мусора"), icon="msg_filter", on_change=self._b28_on_filter_toggle))
        rows.append(_Selector(key="b28_min_level", text=self._t("Минимальный уровень"), default=lvl_i, items=[self._t("Verbose"), self._t("Debug"), self._t("Info"), self._t("Warning"), self._t("Error")], icon="msg_list", on_change=self._b28_on_level))
        rows.append(_Input(key="b28_keep_re", text=self._t("Keep-regex (ERE)"), default=cur_re, subtext=self._t("Пусто = брать все строки нужного уровня"), icon="msg_search", on_change=self._b28_on_regex))
        rows.append(Divider(text=self._t("Применяется сразу — без перезапуска")))
        return rows

    def _b28_on_filter_toggle(self, v):
        global _B28_READ_FILTER_ON
        try:
            _B28_READ_FILTER_ON = bool(v)
            try: self.set_setting("b28_filter_on", bool(v))
            except Exception: pass
            _log("Block#28: read-filter %s (UI)" % ("ON" if v else "OFF"))
        except Exception as e:
            _log("Block#28: filter toggle err: %s" % e)

    def _b28_on_level(self, i):
        global _B28_MIN_LEVEL
        try:
            i = int(i)
            if 0 <= i < len(_B28_LEVELS):
                _B28_MIN_LEVEL = _B28_LEVELS[i]
                try: self.set_setting("b28_min_level", i)
                except Exception: pass
                _log("Block#28: min-level=%s (UI)" % _B28_MIN_LEVEL)
        except Exception as e:
            _log("Block#28: level change err: %s" % e)

    def _b28_on_regex(self, s):
        global _B28_KEEP_RE_ERE
        try:
            s = "" if s is None else str(s)
            if s.strip():
                try: re.compile(s)
                except Exception as _re: _log("Block#28: regex Python-валидация не прошла (ERE всё равно сохранён): %s" % _re)
            _B28_KEEP_RE_ERE = s
            try: self.set_setting("b28_keep_re", s)
            except Exception: pass
            _log("Block#28: keep-regex обновлён (UI, %d символов)" % len(s))
        except Exception as e:
            _log("Block#28: regex change err: %s" % e)

    def _ui_memory_stats_subpage(self):
        rows = [Header(text=self._t(" Потребление памяти прямо сейчас"))]
        try:
            self._ui_so_warning(rows)
        except Exception:
            pass
        try:
            snap = native_mem_snapshot(top=15)
        except Exception:
            snap = None
        if not snap:
            rows.append(Text(text=self._t("Данные нативного учёта недоступны"), icon="msg_info", accent=True))
            return rows
        total_mb = snap.get("total", 0) / 1048576.0
        untagged_mb = snap.get("untagged", 0) / 1048576.0
        direct_mb = snap.get("direct_live_total", 0) / 1048576.0
        direct_unt_mb = snap.get("direct_live_untagged", 0) / 1048576.0
        rows.append(Text(text=self._t("Нативная память (C/C++)"), subtext=self._t("Всего: %.2f МБ  |  Untagged: %.2f МБ") % (total_mb, untagged_mb), icon="msg_stats"))
        rows.append(Text(text=self._t("Off-heap память (NIO)"), subtext=self._t("Всего: %.2f МБ  |  Untagged: %.2f МБ") % (direct_mb, direct_unt_mb), icon="msg_stats"))
        rows.append(Divider(text=self._t("Обновляется при каждом открытии страницы")))
        rows.append(Divider())
        rows.append(Header(text=self._t("Топ потребителей")))
        tops = snap.get("top", [])
        shown = 0
        for kv in tops:
            try:
                pid = kv[0]
                if pid == "⟨untagged⟩":
                    continue
                mb = int(kv[1]) / 1048576.0
                if mb < 0.01:
                    continue
                shown += 1
                name = self._ui_pretty_plugin(pid)
                rows.append(Text(text="#%d %s" % (shown, name), subtext="%.2f MB" % mb, icon="msg_block"))
            except Exception:
                pass
        if shown == 0:
            rows.append(Text(text=self._t("✅ Пусто"), icon="msg_info"))
        return rows

    def _ui_culprits_subpage(self):
        try:
            self._ui_refresh_pending()
        except Exception:
            pass
        rows = [Header(text=self._t(" Кто виноват — результаты"))]
        rows.append(Text(text=self._t(" Отправить логи"), icon="msg_share", accent=True, on_click=self._ui_send_logs))
        rows.append(Text(text=self._t(" Скопировать результаты"), icon="msg_copy", accent=True, on_click=self._ui_copy_results))
        rows.append(Text(text=self._t(" Очистить результаты"), icon="msg_delete", accent=True, on_click=self._ui_clear))
        rows.append(Divider())
        try:
            self._ui_so_warning(rows)
        except Exception:
            pass
        if _UI_FLT_OK:
            rows.append(Header(text=self._t("🔻 Фильтр")))
            rows.append(_Selector(key="flt_level", text=self._t("Уровень уверенности"), default=0, items=[self._t("Все"), self._t("Только высокая"), self._t("Высокая+средняя"), self._t("Только низкая")], icon="msg_list"))
            rows.append(_Selector(key="flt_cat", text=self._t("Категория"), default=0, items=[self._t("Все"), self._t("Краши"), self._t("Зависания"), self._t("Память"), self._t("Прочее")], icon="msg_list"))
            rows.append(Switch(key="flt_named", text=self._t("Только названные виновники"), default=False, subtext=self._t("Скрыть неустановленных/untagged"), icon="msg_block"))
            rows.append(_Input(key="flt_regex", text=self._t("Фильтр (regex)"), default="", subtext=self._t("Совпадение: название, виновник, причина, место"), icon="msg_search"))
            rows.append(Text(text=self._t(" Применить фильтр"), icon="msg_reset", accent=True, create_sub_fragment=self._ui_culprits_subpage))
            rows.append(Divider(text=self._t("Измените фильтр и нажмите «Применить фильтр».")))
        try:
            cards = self._ui_collect_culprits()
        except Exception:
            cards = []
        try:
            cards, _flt_human = self._ui_apply_filter(cards)
        except Exception:
            _flt_human = None
        if _flt_human:
            rows.append(Divider(text=self._t("Активен фильтр: %s") % _flt_human))
        if not cards:
            rows.append(Text(text=self._t("✅ Чисто — виновники не найдены"), icon="msg_info", accent=True))
            rows.append(Divider(text="%s %s %s" % (self._t("Если приложение крашнется, зависнет"), self._t("или съест память — здесь появится"), self._t("бажный плагин с понятным описанием."))))
        else:
            shown = cards[:50]
            if len(cards) > len(shown):
                rows.append(Text(text=self._t("🔴 Найдено виновников: %d (показаны первые %d)") % (len(cards), len(shown)), icon="msg_report", accent=True))
            else:
                rows.append(Text(text=self._t("🔴 Найдено виновников: %d") % len(cards), icon="msg_report", accent=True))
            rows.append(Divider(text=self._t("Новые — сверху. Нажмите на заголовок виновника, чтобы скопировать только его данные.")))
            for i, c in enumerate(shown, 1):
                rows.append(Divider())
                rows.append(Header(text=self._t("Виновник №%d") % i))
                rows.append(Text(text="%s %s" % (c["emoji"], c["label"]), icon="msg_copy", accent=True, on_click=(lambda v=None, _c=c: self._ui_copy_one(_c))))
                rows.append(Text(text=self._t("📜 Логи момента"), icon="msg_recent", accent=True, on_click=(lambda v=None, _c=c: self._ui_card_logs(_c))))
                rows.append(Divider(text=self._t("Виноват: %s") % c["culprit"]))
                detail = c["reason"] if c["reason"] else (self._t("Плагин %s") % c["what"])
                rows.append(Text(text=self._t("Что случилось"), icon="msg_info"))
                rows.append(Divider(text=detail))
                rows.append(Text(text=self._t("Когда · уверенность"), subtext="%s   •   %s" % (self._ui_when(c["ts"]), c["conf"]), icon="msg_recent"))
                if c["where"]:
                    rows.append(Text(text=self._t("Где"), icon="msg_location"))
                    rows.append(Divider(text=c["where"]))
        return rows

    def on_settings_changed(self, key=None, value=None):
        return

    def create_settings(self):
        if not _UI_OK: return []
        try:
            self._ui_refresh_pending()
        except Exception:
            pass
        rows = [Header(text=self._t("🔎 Кто виноват в проблемах"))]
        try:
            _soh = _so_health()
        except Exception:
            _soh = {"ok": False, "state": "not_loaded"}
        if not _soh.get("ok"):
            _st = _soh.get("state")
            if _st == "abi_mismatch":
                _hdr = self._t("🔴 SO НЕСОВМЕСТИМ (ABI) 🔴")
            elif _st == "stale":
                _hdr = self._t("🔴 SO УСТАРЕЛ (НЕТ ABI) 🔴")
            else:
                _hdr = self._t("🔴 SO НЕ НАЙДЕН 🔴")
            rows.append(Header(text="🔴🔴🔴 " + _hdr + " 🔴🔴🔴"))
            rows.append(Text(text=self._t("⛔ libculprit.so ОТСУТСТВУЕТ ИЛИ НЕ НАЙДЕН"), icon="msg_block", accent=True))
            rows.append(Divider())
        rows.append(Text(text=self._t(" Покажи виновных"), icon="msg_report", accent=True, create_sub_fragment=self._ui_culprits_subpage))
        rows.append(Text(text=self._t(" Память (снимок)"), icon="msg_stats", accent=True, create_sub_fragment=self._ui_memory_stats_subpage))
        rows.append(Text(text=self._t(" Фильтр логов (logcat)"), icon="msg_info", accent=True, create_sub_fragment=self._ui_logfilter_subpage))
        rows.append(Divider())
        rows.append(Text(f"v.{__version__}", icon="msg_info"))
        rows.append(Text(f"{__author__}", icon="msg_info"))
        return rows

def create_plugin(): return Plugin()

_UI_VERDICT_SOURCES = Plugin._UI_VERDICT_SOURCES
