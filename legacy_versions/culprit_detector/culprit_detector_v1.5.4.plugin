_B10_REENTRY_LOCK = threading.Lock()
_B10_REENTRY_LAST_LOG = {}
_B10_REENTRY_STATS = {"enter": 0, "cut": 0}
_B10_UNSET = object()
_B10_OWNER_CACHE = {}
_B10_WHERE_CODE = {"before_hooked_method": 0, "after_hooked_method": 1, "replace_hooked_method": 2}
