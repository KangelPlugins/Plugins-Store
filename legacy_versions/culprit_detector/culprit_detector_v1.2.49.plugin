_B17_FUT_TAG = "_culprit_b17_wrapped"

def _b17_observe_future(fut, where):
    if not _BLOCK17_ON: return
    try:
        if getattr(fut, _B17_FUT_TAG, False): return
        if not fut.done(): return
    except Exception:
        return
    try:
        exc = fut.exception(timeout=0)
    except Exception:
        return
    if exc is None: return
    try: setattr(fut, _B17_FUT_TAG, True)
    except Exception: pass
    try: _b17_record(None, exc, None, where, True)
    except Exception: pass

def _b17_make_ascompleted_patch(orig):
    @_functools.wraps(orig)
    def _patched(fs, *args, **kwargs):
        for fut in orig(fs, *args, **kwargs):
            try: _b17_observe_future(fut, "as_completed")
            except Exception: pass
            yield fut
    try: setattr(_patched, _B17_FLAG, True)
    except Exception: pass
    return _patched

def _b17_make_wait_patch(orig):
    @_functools.wraps(orig)
    def _patched(fs, *args, **kwargs):
        res = orig(fs, *args, **kwargs)
        try:
            done = getattr(res, "done", None)
            if done:
                for fut in done:
                    try: _b17_observe_future(fut, "wait")
                    except Exception: pass
        except Exception: pass
        return res
    try: setattr(_patched, _B17_FLAG, True)
    except Exception: pass
    return _patched

def _b17_install():
