_B23_BPP = {"ALPHA_8": 1, "RGB_565": 2, "ARGB_4444": 2, "ARGB_8888": 4, "RGBA_F16": 8, "HARDWARE": 4, "RGBA_1010102": 4}

def _b23_args_ints(args):
    out = []
    for a in (args or []):
        try:
            iv = int(a)
            if iv > 0: out.append(iv)
        except Exception:
            pass
    return out

def _b23_args_est(args):
    ints = _b23_args_ints(args)
    bpp = 4
    for a in (args or []):
        try:
            nm = a.name()
            for k, v in _B23_BPP.items():
                if k in nm: bpp = v; break
        except Exception:
            pass
    ints.sort(reverse=True)
    if len(ints) >= 2:
        return ints[0] * ints[1] * bpp
    return -1

def _b23_result_bytes(param):
    try:
        r = param.getResult()
        if r is None: return -1
        try: return int(r.getAllocationByteCount())
        except Exception: pass
        try: return int(r.getByteCount())
        except Exception: pass
    except Exception: pass
    return -1

def _b23_record(pid, nbytes, kind, oom, dims):
    if pid is None: pid = _UNTAGGED_LABEL
    with _B23_LOCK:
        if nbytes and nbytes > 0:
            _B23_BYTES[pid] = _B23_BYTES.get(pid, 0) + int(nbytes)
            if int(nbytes) > _B23_PEAK.get(pid, 0): _B23_PEAK[pid] = int(nbytes)
        _B23_COUNT[pid] = _B23_COUNT.get(pid, 0) + 1
        if oom: _B23_OOM[pid] = _B23_OOM.get(pid, 0) + 1
        if oom or (nbytes and nbytes >= _B23_BIG_BYTES):
            _B23_RING.append((int(time.time() * 1000), pid, int(nbytes) if (nbytes and nbytes > 0) else -1, kind, dims))
            if len(_B23_RING) > _B23_RING_MAX:
                del _B23_RING[0:len(_B23_RING) - _B23_RING_MAX]

def b23_snapshot(top=10):
    with _B23_LOCK:
        pairs = sorted(_B23_BYTES.items(), key=lambda kv: kv[1], reverse=True)
        return {
            "by_pid": pairs[:top],
            "count": dict(_B23_COUNT),
            "peak": dict(_B23_PEAK),
            "oom": dict(_B23_OOM),
            "recent": list(_B23_RING[-top:]),
            "installed_hooks": _B23_INSTALLED,
        }

def _b23_is_oom(thr):
    try:
        if thr is None: return None
        try: nm = thr.getClass().getName()
        except Exception: nm = _safe_str(thr)
        if nm and "OutOfMemory" in nm:
            return nm
    except Exception: pass
    return None

def _b23_write_oom(pid, nbytes, kind, dims, thr_name):
    p = _b23_path()
    if not p: return
    try:
        snap = b23_snapshot(top=_OOM_TOPN)
        rec = {
            "had_bitmap_oom": True,
            "ts": int(time.time() * 1000),
            "version": __version__,
            "culprit": pid or _UNTAGGED_LABEL,
            "attempted_bytes": int(nbytes) if (nbytes and nbytes > 0) else -1,
            "kind": kind, "dims": dims, "throwable": thr_name,
            "confidence": ("high" if (pid and pid != _UNTAGGED_LABEL) else "low"),
            "reason": (("OOM при выделении %s%s%s") % (
                (kind or "bitmap"),
                (" %s" % dims) if dims else "",
                ((" (~%d МБ)" % (int(nbytes) // (1024*1024))) if (nbytes and nbytes > 0) else ""),
            )),
            "ledger": snap,
        }
        _atomic_json_write(p, rec)
        _log("================ BITMAP OOM VERDICT (Block#23) ================")
        _log("ВИНОВНИК OOM(bitmap): %r kind=%s ~%sB dims=%s thr=%s" % (
            pid or _UNTAGGED_LABEL, kind,
            (int(nbytes) if (nbytes and nbytes > 0) else "?"), dims, thr_name))
        _log("==============================================================")
    except Exception as e:
        try: _log("Block#23 write oom err: %s" % e)
        except Exception: pass

_B23_DEDUP_WINDOW_MS = 250
_B23_DEDUP_MAX = 32
_B23_TL = threading.local()

def _b23_identity(obj):
    try:
        if obj is None: return None
        return int(jclass("java.lang.System").identityHashCode(obj))
    except Exception:
        return None

def _b23_seen_recently(key):
    if key is None:
        return False
    now = int(time.time() * 1000)
    store = getattr(_B23_TL, "seen", None)
    if store is None:
        store = []; _B23_TL.seen = store
    cut = now - _B23_DEDUP_WINDOW_MS
    if store:
        store[:] = [(k, t) for (k, t) in store if t >= cut]
    for (k, t) in store:
        if k == key:
            return True
    store.append((key, now))
    if len(store) > _B23_DEDUP_MAX:
        del store[0:len(store) - _B23_DEDUP_MAX]
    return False

def _b23_after(kind, param):
    if not _B23_ON: return
    try:
        thr = None
        try: thr = param.getThrowable()
        except Exception: thr = None
        oom_name = _b23_is_oom(thr)
        try:
            _dkey = _b23_identity(thr) if oom_name is not None else _b23_identity(param.getResult())
        except Exception:
            _dkey = None
        if _b23_seen_recently(_dkey):
            return
        pid = _b23_owner_pid()
        if oom_name is not None:
            args = getattr(param, "args", None)
            nbytes = _b23_args_est(args)
            dims = None
            try:
                ints = _b23_args_ints(args)
                if len(ints) >= 2:
                    ints.sort(reverse=True); dims = "%dx%d" % (ints[0], ints[1])
            except Exception: pass
            _b23_record(pid, nbytes, kind, True, dims)
            _b23_write_oom(pid, nbytes, kind, dims, oom_name)
            return
        nbytes = _b23_result_bytes(param)
        _b23_record(pid, nbytes, kind, False, None)
    except Exception:
        pass

class _BitmapCreateHook(MethodHook):
    def after_hooked_method(self, param): _b23_after("createBitmap", param)

class _BitmapScaleHook(MethodHook):
    def after_hooked_method(self, param): _b23_after("createScaledBitmap", param)

class _BitmapCopyHook(MethodHook):
    def after_hooked_method(self, param): _b23_after("copy", param)

def _loader_culprit(frames):
    if not _B4C_OK: return None, None, {"status": "off"}
    with _REG_LOADERS_LOCK:
        loaders = list(_REG_LOADERS)
    meta = {"n": len(loaders), "status": ("no-loaders" if not loaders else "ok")}
    if not loaders: return None, None, meta
    for fr in frames:
        cn = fr.rsplit(".", 1)[0] if "." in fr else fr
        if _is_system_class(cn): continue
        for (obj, rep, pidx) in loaders:
            try:
                kls = obj.loadClass(cn)
            except Exception:
                continue
            try:
                drep = _safe_str(kls.getClassLoader())
            except Exception:
                drep = None
            if drep is not None and drep == rep:
                pid = _resolve_idx(pidx)
                if pid:
                    return pid, fr, meta
    return None, None, meta


_SIG_NAME = {4: "SIGILL", 6: "SIGABRT", 7: "SIGBUS", 8: "SIGFPE", 11: "SIGSEGV"}

def _classify_native_cause(signo, si_code=None, fault_addr=None):
    try:
        if signo is None: return "unknown"
        return _SIG_NAME.get(signo, "signo=%s" % signo)
    except Exception:
        return "unknown"

def _so_owner_from_path(path):
    soname = path.rsplit("/", 1)[-1]
    stem = soname[:-3] if soname.lower().endswith(".so") else soname
    try: known = list(_load_known() or [])
    except Exception: known = []
    comps = set(c for c in path.split("/") if c)
    for pid in known:
        if not pid: continue
        if pid in comps or stem == pid or stem == ("lib" + pid):
            return pid, "high"
    mapped = None
    try: mapped = _map_stack_to_id(soname, known) or _map_stack_to_id(path, known)
    except Exception: mapped = None
    if mapped: return mapped, "high"
    return "<so:%s>" % soname, "medium"

def _read_native_crash():
    try:
        p = _native_crash_path()
        if not p or not os.path.exists(p): return None
        with open(p, "r", encoding="utf-8", errors="replace") as f:
            raw = f.read()
        if "CULPRIT_NATIVE_CRASH" not in raw:
            try: os.remove(p)
            except Exception: pass
            return None
        _parts = raw.split("CULPRIT_NATIVE_CRASH")
        _last_full = None
        for _part in _parts[1:]:
            _block = "CULPRIT_NATIVE_CRASH" + _part
            _end = _block.find("\nEND")
            if _end != -1:
                _last_full = _block[:_end + 4] + "\n"
        if _last_full is None:
            return None
        raw = _last_full
        rec = {"raw": raw[-4000:], "signo": None, "active_pid": None, "culprit_pid": None, "pid_src": None, "pid_resolve_src": None, "pid_choice_src": None, "pid": None, "si_code": None, "fault_addr": None, "cause": None, "foreign_so": None, "foreign_app_private": None, "foreign_so_conf": None, "fso_src": None, "top_so": None, "host_so": None, "host_native": None, "culprit_kind": None, "op_stamps": {}, "frames": []}
        for line in raw.splitlines():
            line = line.strip()
            if line.startswith("signo="):
                for tok in line.split():
                    if tok.startswith("signo="):
                        try: rec["signo"] = int(tok.split("=", 1)[1])
                        except Exception: pass
                    elif tok.startswith("active_pid="):
                        try: rec["active_pid"] = int(tok.split("=", 1)[1])
                        except Exception: pass
                    elif tok.startswith("culprit_pid="):
                        try: rec["culprit_pid"] = int(tok.split("=", 1)[1])
                        except Exception: pass
                    elif tok.startswith("pid_src="):
                        rec["pid_src"] = tok.split("=", 1)[1]
                    elif tok.startswith("code="):
                        try: rec["si_code"] = int(tok.split("=", 1)[1])
                        except Exception: pass
                    elif tok.startswith("addr="):
                        _v = tok.split("=", 1)[1]
                        try: rec["fault_addr"] = int(_v, 16) if _v.lower().startswith("0x") else int(_v)
                        except Exception: pass
                    elif tok.startswith("cause="):
                        rec["cause"] = tok.split("=", 1)[1]
                    elif tok.startswith("foreign_so="):
                        rec["foreign_so"] = tok.split("=", 1)[1]
                    elif tok.startswith("foreign_app_private="):
                        _fv = tok.split("=", 1)[1]
                        rec["foreign_app_private"] = _fv not in ("0", "", "false", "False", "no")
                    elif tok.startswith("fso_src="):
                        rec["fso_src"] = tok.split("=", 1)[1]
                    elif tok.startswith("top_so="):
                        rec["top_so"] = tok.split("=", 1)[1]
                    elif tok.startswith("host_so="):
                        rec["host_so"] = tok.split("=", 1)[1]
                    elif tok.startswith("host_native="):
                        _hv = tok.split("=", 1)[1]
                        rec["host_native"] = _hv not in ("0", "", "false", "False", "no")
                    elif tok.startswith("op_") and "=" in tok:
                        try:
                            _opd, _opv = tok.split("=", 1)
                            _opd = _opd[3:]
                            _opp = _opv.split("|")
                            _opa = int(_opp[1]) if len(_opp) > 1 and _opp[1] != "" else None
                            if _opd and _opp and _opp[0] and _opa is not None:
                                _opown = _opp[0]
                                if _opown[:1] == "#" and _opown[1:].isdigit():
                                    _opnm = _resolve_idx(int(_opown[1:]))
                                    if _opnm:
                                        _opown = _opnm
                                rec["op_stamps"][_opd] = {"owner": _opown, "age_ms": _opa, "api": (_opp[2] if len(_opp) > 2 else None)}
                        except Exception: pass
            elif line.startswith("#"):
                rec["frames"].append(line)
        rec["frame_type"] = _classify_crash_frames(rec.get("frames"))
        _c_native_by = bool(rec.get("cause"))
        c_pid = rec.get("culprit_pid")
        a_pid = rec.get("active_pid")
        _ordered = []
        if a_pid is not None and a_pid >= 0:
            _ordered.append((a_pid, "scope"))
        if c_pid is not None and c_pid >= 0 and c_pid != a_pid:
            _ordered.append((c_pid, "culprit_pid"))
        for _idx_val, _choice in _ordered:
            nm = _resolve_idx(_idx_val)
            _rsrc = "memory"
            if nm is None:
                nm = _resolve_idx_durable(_idx_val)
                _rsrc = "sidecar" if nm is not None else None
            if nm is not None:
                rec["pid"] = nm; rec["pid_resolve_src"] = _rsrc; rec["pid_choice_src"] = _choice
                break
        if rec.get("pid") is None:
            try:
                top_mod = None
                by_src = "c-native"
                _fso = rec.get("foreign_so")
                _fap = rec.get("foreign_app_private")
                if _fso and _fap is not False:
                    top_mod = _fso
                if top_mod:
                    owner, conf = _so_owner_from_path(top_mod)
                    rec["pid"] = owner
                    rec["pid_choice_src"] = "so_path"
                    rec["pid_resolve_src"] = "so_app_private"
                    rec["foreign_so"] = top_mod
                    rec["foreign_so_conf"] = conf
                    _log("Block#4C +BY(native-so/%s): untagged нативный краш отнесён по ПУТИ верхнего .so -> плагин=%r (module=%s cause=%s fso_src=%s) -- ЭВРИСТИКА conf=%s"
                         % (by_src, owner, top_mod, rec.get("cause"), rec.get("fso_src"), conf))
            except Exception as _eby:
                _log("Block#4C +BY native-so err: %s" % _eby)
        if rec.get("pid") is None:
            try:
                try: crash_ts = int(os.path.getmtime(p) * 1000)
                except Exception: crash_ts = None
                if crash_ts is not None:
                    ct = rec.get("frame_type")
                    cands = []
                    _native_ops = rec.get("op_stamps") or {}
                    rec["op_stamp_src"] = "native" if _native_ops else "none"
                    _dn2ot = {"gpu": "rs", "gl": "gl", "anim": "anim", "mvel": "mvel",
                              "binder": "binder", "camera": "camera", "mediacodec": "mediacodec"}
                    for _dn, _st in _native_ops.items():
                        _ot = _dn2ot.get(_dn)
                        _age = _st.get("age_ms"); _ow = _st.get("owner")
                        if _ot and _ow and _age is not None and _age >= 0:
                            cands.append((_ot, crash_ts - int(_age), _ow))
                    if ct is not None:
                        if ct == "gpu":
                            cands = [c for c in cands if c[0] in ("rs", "gl")]
                        else:
                            cands = [c for c in cands if c[0] == ct]
                    best = None
                    for otype, op_ts, owner in cands:
                        if not owner or owner == _SELF_ID or owner == __id__: continue
                        if op_ts <= 0: continue
                        age = crash_ts - op_ts
                        if 0 <= age <= _GPU_OP_WINDOW_MS and (best is None or op_ts > best[1]):
                            best = (otype, op_ts, owner, age)
                    if best is not None:
                        otype, op_ts, owner, age = best
                        frame_match = (ct == otype) or (ct == "gpu" and otype in ("rs", "gl"))
                        if otype == "rs":
                            choice = "gpu_lib" if frame_match else "gpu_recent"; resolve = "gpu_sidecar"
                        elif otype == "gl":
                            choice = "gl_op" if frame_match else "gl_recent"; resolve = "gl_sidecar"
                        elif otype == "anim":
                            choice = "anim_op" if frame_match else "anim_recent"; resolve = "anim_sidecar"
                        elif otype == "mvel":
                            choice = "mvel_op" if frame_match else "mvel_recent"; resolve = "mvel_sidecar"
                        elif otype == "binder":
                            choice = "binder_op" if frame_match else "binder_recent"; resolve = "binder_sidecar"
                        elif otype == "camera":
                            choice = "camera_op" if frame_match else "camera_recent"; resolve = "camera_sidecar"
                        else:
                            choice = "mediacodec_op" if frame_match else "mediacodec_recent"; resolve = "mediacodec_sidecar"
                        rec["pid"] = owner
                        rec["pid_choice_src"] = choice
                        rec["pid_resolve_src"] = resolve
                        rec["gpu_lib_hint"] = (_gpu_frames_hit_rs(rec.get("frames")) if otype == "rs" else None)
                        rec["gpu_op_age_ms"] = age
                        _corr_prefix = {"rs": "+BI(rs)", "gl": "+BW(gl)", "anim": "+BL(anim)", "mvel": "+BN(mvel)", "binder": "+BT(binder)", "camera": "+BU(camera)", "mediacodec": "+BV(mediacodec)"}.get(otype, "+BL(gap9+anim)")
                        _log("Block#4C %s: untagged нативный краш скоррелирован -> плагин=%r (type=%s choice=%s frame_match=%s age=%sms) -- ЭВРИСТИКА conf=%s"
                             % (_corr_prefix, owner, otype, choice, frame_match, age, ("high" if frame_match else "medium")))
            except Exception as _eg:
                _log("Block#4C +BL correlate err: %s" % _eg)
        if rec.get("pid") is None and rec.get("host_native") and rec.get("host_so"):
            _hb = rec.get("host_so") or ""
            rec["culprit_kind"] = "host"
            rec["host_so_owner"] = _hb.rsplit("/", 1)[-1] if _hb else None
            rec["pid_choice_src"] = "host_so"
            rec["pid_resolve_src"] = "host_native"
            _log("Block#4C +CJ(host-native): краш в собственном native хоста -> host_so=%s fso_src=%s cause=%s (culprit_kind=host, не плагин)"
                 % (rec.get("host_so"), rec.get("fso_src"), rec.get("cause")))
        if rec.get("culprit_kind") is None:
            rec["culprit_kind"] = "plugin" if rec.get("pid") is not None else "system"
        if rec.get("pid") is not None and a_pid is not None and a_pid >= 0 and c_pid is not None and c_pid >= 0 and a_pid != c_pid:
            _log(f"Block#4C: scope(active_pid={a_pid}) и culprit_pid={c_pid} рас��одятся -> вы��ран источник '{rec.get('pid_choice_src')}' (плагин={rec.get('pid')!r})")
        try:
            if rec.get("ts") is None:
                try: rec["ts"] = int(os.path.getmtime(p) * 1000)
                except Exception: rec["ts"] = int(time.time() * 1000)
        except Exception: pass
        try:
            if rec.get("confidence") is None:
                _ck = rec.get("culprit_kind")
                if _ck == "plugin" and rec.get("pid") is not None:
                    rec["confidence"] = "high"
                elif _ck == "host" and rec.get("host_so"):
                    rec["confidence"] = "high"
        except Exception: pass
        try:
            _ncvp = _native_crash_verdict_path()
            if _ncvp:
                _atomic_json_write(_ncvp, rec)
                _log("Block#4C: native_crash_verdict.json записан (kind=%s plugin=%r host_so=%r signo=%s cause=%s)"
                     % (rec.get("culprit_kind"), rec.get("pid"), rec.get("host_so"), rec.get("signo"), rec.get("cause")))
        except Exception as _env:
            _log("native_crash_verdict write err: %s" % _env)

        try: os.remove(p)
        except Exception: pass
        return rec
    except Exception as e:
        _log(f"native crash read err: {e}")
        return None

def _get_declared_methods(cls, label=""):
    if cls is None: return []
    try:
        return list(cls.getDeclaredMethods())
    except Exception:
        try:
            return list(cls.getClass().getDeclaredMethods())
        except Exception as e:
            _log(f"getDeclaredMethods failed for {label}: {e}"); return []

import sys as _sys, functools as _functools, gc as _gc

_ENTRY_CBS = (
    "on_plugin_load", "on_plugin_unload", "on_settings_changed", "create_settings",
    "on_send_message_hook", "pre_request_hook", "post_request_hook",
    "on_update_hook", "on_updates_hook", "on_app_event", "on_app_update",
)
_B_TAGGED_FLAG = "__culprit_scoped__"

def _canonical_pid(obj):
    mod_name = getattr(type(obj), "__module__", None)
    mod = _sys.modules.get(mod_name) if mod_name else None
    pid = getattr(mod, "__id__", None) if mod is not None else None
    return pid or mod_name or "unknown"

def _pid_of_module(mod_name):
    if not mod_name: return None
    try:
        mod = _sys.modules.get(mod_name)
    except Exception:
        mod = None
    if mod is None: return None
    pid = getattr(mod, "__id__", None)
    if isinstance(pid, str) and pid and pid != _SELF_ID and pid != __id__:
        return pid
    return None

def _pid_of_callable(fn):
    try:
        return _pid_of_module(getattr(fn, "__module__", None))
    except Exception:
        return None

def _provenance_pid(thread_obj=None, depth=0):
    try:
        if thread_obj is not None:
            tgt = getattr(thread_obj, "_target", None)
            if tgt is not None:
                pid = _pid_of_callable(tgt)
                if pid: return pid
            pid = _pid_of_module(getattr(type(thread_obj), "__module__", None))
            if pid: return pid
    except Exception:
        pass
    try:
        f = _sys._getframe(1 + int(depth))
    except Exception:
        f = None
    seen = 0
    while f is not None and seen < 40:
        try:
            g = f.f_globals
            pid = _pid_of_module(g.get("__name__"))
            if pid is None:
                _id = g.get("__id__")
                if isinstance(_id, str) and _id and _id != _SELF_ID and _id != __id__:
                    pid = _id
            if pid:
                return pid
        except Exception:
            pass
        try: f = f.f_back
        except Exception: f = None
        seen += 1
    return None

_UI_CB_ATTRS = ("on_click", "on_change", "on_value_change", "on_toggle", "callback", "on_select", "on_long_click")
_UI_CONTAINER_ATTRS = ("elements", "children", "items", "rows", "cells", "views", "subviews", "content", "body")
_UI_FACTORY_ATTRS = ("create_sub_fragment", "create_fragment", "build_fragment", "create_page", "sub_fragment")
def _wrap_ui_callbacks(pid, items, _depth=0, _seen=None):
    if _depth > 8: return
    if _seen is None: _seen = set()
    try:
        if items is None: return
        seq = list(items) if isinstance(items, (list, tuple)) else [items]
    except Exception:
        seq = None
    if not seq: return
    for it in seq:
        if it is None: continue
        try:
            k = id(it)
            if k in _seen: continue
            _seen.add(k)
        except Exception:
            pass
        for attr in _UI_CB_ATTRS:
            try:
                cb = getattr(it, attr, None)
            except Exception:
                cb = None
            if cb is None or not callable(cb): continue
            if getattr(cb, _B_TAGGED_FLAG, False): continue
            try: setattr(it, attr, _wrap_entry(pid, cb))
            except Exception: pass
        for fattr in _UI_FACTORY_ATTRS:
            try:
                fac = getattr(it, fattr, None)
            except Exception:
                fac = None
            if fac is None or not callable(fac): continue
            if getattr(fac, _B_TAGGED_FLAG, False): continue
            try: setattr(it, fattr, _wrap_settings_factory(pid, fac))
            except Exception: pass
        for cattr in _UI_CONTAINER_ATTRS:
            try:
                child = getattr(it, cattr, None)
            except Exception:
                child = None
            if child is None or callable(child): continue
            if isinstance(child, (str, bytes)): continue
            try: _wrap_ui_callbacks(pid, child, _depth + 1, _seen)
            except Exception: pass

def _wrap_settings_factory(pid, fn):
    if getattr(fn, _B_TAGGED_FLAG, False):
        return fn
    @_functools.wraps(fn)
    def _w(*a, **kw):
        pushed = _scoped_set(pid)
        try:
            items = fn(*a, **kw)
        finally:
            if pushed: _scoped_clear()
        try: _wrap_ui_callbacks(pid, items)
        except Exception: pass
        return items
    try: setattr(_w, _B_TAGGED_FLAG, True)
    except Exception: pass
    return _w

def _wrap_entry(pid, fn):
    if getattr(fn, _B_TAGGED_FLAG, False):
        return fn
    @_functools.wraps(fn)
    def _w(*a, **kw):
        pushed = _scoped_set(pid)
        try:
            return fn(*a, **kw)
        finally:
            if pushed: _scoped_clear()
    try: setattr(_w, _B_TAGGED_FLAG, True)
    except Exception: pass
    return _w

_SETTINGS_CTOR_HOOKED = False
_SETTINGS_ITEM_CLASSNAMES = ("Text", "Switch", "Selector", "Input", "Slider", "Header", "Divider", "Category", "Card", "Custom", "Toggle", "Button")
def _seed_settings_item(it):
    try:
        pid = _provenance_pid(None, 1)
    except Exception:
        pid = None
    if not pid or pid == _SELF_ID or pid == __id__:
        return
    for attr in _UI_CB_ATTRS:
        try: cb = getattr(it, attr, None)
        except Exception: cb = None
        if cb is None or not callable(cb): continue
        if getattr(cb, _B_TAGGED_FLAG, False): continue
        try: setattr(it, attr, _wrap_entry(pid, cb))
        except Exception: pass
    for fattr in _UI_FACTORY_ATTRS:
        try: fac = getattr(it, fattr, None)
        except Exception: fac = None
        if fac is None or not callable(fac): continue
        if getattr(fac, _B_TAGGED_FLAG, False): continue
        try: setattr(it, fattr, _wrap_settings_factory(pid, fac))
        except Exception: pass
def _install_settings_ctor_scope():
    global _SETTINGS_CTOR_HOOKED
    if _SETTINGS_CTOR_HOOKED:
        return
    uis = None
    try:
        uis = _sys.modules.get("ui.settings")
        if uis is None:
            import ui.settings as uis
    except Exception as e:
        _log("Gap8 settings-ctor: ui.settings unavailable: %r" % e)
        return
    n = 0
    for nm in dir(uis):
        try: cls = getattr(uis, nm, None)
        except Exception: cls = None
        if not isinstance(cls, type):
            continue
        mod = getattr(cls, "__module__", "") or ""
        if not (mod.startswith("ui.settings") or nm in _SETTINGS_ITEM_CLASSNAMES):
            continue
        orig = cls.__dict__.get("_culprit_orig_init", None)
        if orig is None:
            orig = cls.__dict__.get("__init__", None)
            if orig is None:
                continue
            try: cls._culprit_orig_init = orig
            except Exception: pass
        def _make(orig_init):
            def _patched(self, *a, **kw):
                orig_init(self, *a, **kw)
                try: _seed_settings_item(self)
                except Exception: pass
            return _patched
        try:
            cls.__init__ = _make(orig); n += 1
        except Exception:
            pass
    _SETTINGS_CTOR_HOOKED = True
    _log("Gap8/+BH settings-ctor scope: обёрнуто классов ui.settings=%d (on_change/on_click/create_sub_fragment тегируются в источнике)" % n)

_GPU_OP_WINDOW_MS = 8000
_GPU_HOOK_INSTALLED = 0
_GPU_RS_LIB_HINTS = ("librs", "libRS", "rs_jni", "rsjni", "RSCpuRef", "RSDriver", "renderscript",
                     "libGLES", "libEGL", "libgpu", "libvulkan", "GLESv", "adreno", "mali",
                     "PowerVR", "rsdScript", "ScriptC")

_OP_DOMAIN_IDX = {"gpu": 0, "anim": 1, "mvel": 2, "binder": 3, "camera": 4, "mediacodec": 5, "gl": 6}
_OP_OWNER_MAX = 64
_OP_API_MAX = 48
_OP_NATIVE_OK = False
_MVEL_NATIVE_OK = False
_MVEL_NATIVE_ON = True
_MVEL_NATIVE_ACTIVE = False
_MVEL_ENTRY_OFFSET = 0
_MVEL_RETRY_GEN = 0
_MVEL_RETRY_MAX = 15
_MVEL_RETRY_PERIOD_S = 4.0

def _mvel_native_can_attempt():
    return bool(_MVEL_NATIVE_ON and _MVEL_NATIVE_OK and _NLIB is not None and _CTYPES_OK
                and hasattr(_NLIB, "cd_mvel_install") and hasattr(_NLIB, "cd_mvel_selftest"))

def _mvel_native_try_install(reason="boot"):
    global _MVEL_NATIVE_ACTIVE, _MVEL_HOOK_INSTALLED
    if not _mvel_native_can_attempt():
        return 0
    _moff = int(_MVEL_ENTRY_OFFSET or 0)
    try:
        _st = int(_NLIB.cd_mvel_selftest(_moff))
    except Exception as _e1:
        _log("Block#4C +CL(mvel-native): selftest threw (%s): %s" % (reason, _e1))
        return 0
    if _st <= 0:
        _log("Block#4C +CL(mvel-native): selftest=%d not ready (%s)" % (_st, reason))
        return 0
    try:
        _minst = int(_NLIB.cd_mvel_install(_moff))
    except Exception as _e2:
        _log("Block#4C +CL(mvel-native): install threw (%s): %s" % (reason, _e2))
        return 0
    if _minst > 0:
        _MVEL_NATIVE_ACTIVE = True
        _MVEL_HOOK_INSTALLED = _minst
        _log("Block#4C +CL(mvel-native): native MVEL interceptor installed (%s): selftest=%d points=%d" % (reason, _st, _minst))
    else:
        _log("Block#4C +CL(mvel-native): selftest=%d OK but cd_mvel_install=0 (%s)" % (_st, reason))
    return _minst

_MVEL_MAIN_PENDING = []
_MVEL_MAIN_RUNNABLE_CLS = None

def _mvel_main_runnable_cls():
    global _MVEL_MAIN_RUNNABLE_CLS
    if _MVEL_MAIN_RUNNABLE_CLS is not None:
        return _MVEL_MAIN_RUNNABLE_CLS
    try:
        from java import jclass as _jc, dynamic_proxy as _dp
    except Exception:
        return None
    try:
        Runnable = _jc("java.lang.Runnable")
    except Exception:
        return None
    class _MvelInstallRunnable(_dp(Runnable)):
        def __init__(self, plugin, handler, gen, attempt, maxn, delay_ms):
            super().__init__()
            self._plugin = plugin; self._handler = handler; self._gen = gen
            self._attempt = attempt; self._maxn = maxn; self._delay_ms = delay_ms
        def run(self):
            try:
                if self._gen != _MVEL_RETRY_GEN or _MVEL_NATIVE_ACTIVE:
                    return
                got = 0
                try:
                    got = _mvel_native_try_install("main#%d/%d" % (self._attempt, self._maxn))
                except Exception:
                    got = 0
                if got > 0:
                    try:
                        removed = 0
                        for u in list(getattr(self._plugin, "_mvel_unhooks", [])):
                            try: self._plugin.unhook_method(u); removed += 1
                            except Exception: pass
                        try: self._plugin._mvel_unhooks = []
                        except Exception: pass
                        _log("Block#4C +CL(mvel-native): deferred switch done (main) -- removed %d Python MVEL hooks" % removed)
                    except Exception as _eu:
                        _log("Block#4C +CL(mvel-native): main unhook err: %s" % _eu)
                    return
                if self._attempt < self._maxn and self._gen == _MVEL_RETRY_GEN and not _MVEL_NATIVE_ACTIVE:
                    nxt = _mvel_main_runnable_cls()(self._plugin, self._handler, self._gen, self._attempt + 1, self._maxn, self._delay_ms)
                    try:
                        _MVEL_MAIN_PENDING.append(nxt)
                        if len(_MVEL_MAIN_PENDING) > 4: del _MVEL_MAIN_PENDING[0]
                    except Exception: pass
                    try: self._handler.postDelayed(nxt, int(self._delay_ms))
                    except Exception: pass
                else:
                    _log("Block#4C +CL(mvel-native): main retry gave up after %d attempts -> staying on Python hook" % self._attempt)
            finally:
                try: _MVEL_MAIN_PENDING.remove(self)
                except Exception: pass
    _MVEL_MAIN_RUNNABLE_CLS = _MvelInstallRunnable
    return _MVEL_MAIN_RUNNABLE_CLS

def _mvel_schedule_native_retry(plugin):
    global _MVEL_RETRY_GEN
    try:
        _MVEL_RETRY_GEN += 1
        gen = _MVEL_RETRY_GEN
        try:
            from java import jclass as _jc
        except Exception as _ej:
            _log("Block#4C +CL(mvel-native): java bridge unavailable: %s" % _ej); return
        Looper = _jc("android.os.Looper"); Handler = _jc("android.os.Handler")
        main = Looper.getMainLooper()
        if main is None:
            _log("Block#4C +CL(mvel-native): getMainLooper() is None -> cannot schedule native install"); return
        h = Handler(main)
        RC = _mvel_main_runnable_cls()
        if RC is None:
            _log("Block#4C +CL(mvel-native): Runnable proxy unavailable -> cannot schedule native install"); return
        delay_ms = int(_MVEL_RETRY_PERIOD_S * 1000)
        inst = RC(plugin, h, gen, 1, _MVEL_RETRY_MAX, delay_ms)
        try:
            _MVEL_MAIN_PENDING.append(inst)
            if len(_MVEL_MAIN_PENDING) > 4: del _MVEL_MAIN_PENDING[0]
        except Exception: pass
        if not bool(h.postDelayed(inst, delay_ms)):
            try: _MVEL_MAIN_PENDING.remove(inst)
            except Exception: pass
            _log("Block#4C +CL(mvel-native): main post failed -> staying on Python hook"); return
        _log("Block#4C +CL(mvel-native): deferred native install scheduled on MAIN looper (every %.0fs, up to %d)" % (_MVEL_RETRY_PERIOD_S, _MVEL_RETRY_MAX))
    except Exception as _es:
        _log("Block#4C +CL(mvel-native): main schedule err: %s" % _es)

def _op_mark_native(domain, owner, api):
    if not _OP_NATIVE_OK or _NLIB is None or not _CTYPES_OK:
        return False
    try:
        d = _OP_DOMAIN_IDX.get(domain)
        if d is None:
            return False
        ob = str(owner or "").replace(" ", "_").encode("utf-8")[:_OP_OWNER_MAX - 1]
        ab = str(api or "").replace(" ", "_").encode("utf-8")[:_OP_API_MAX - 1]
        return int(_NLIB.cd_op_mark(ctypes.c_int32(d), ctypes.c_char_p(ob), ctypes.c_char_p(ab))) == 0
    except Exception:
        return False


def _gpu_mark(owner, api):
    if not owner or owner == _SELF_ID or owner == __id__:
        return
    try:
        _op_mark_native("gpu", owner, api)
    except Exception:
        pass

def _gpu_owner_now():
    try:
        cur = _reg_get(_cur_tid())
        if cur is not None and cur >= 0:
            nm = _resolve_idx(cur)
            if nm and nm != _SELF_ID and nm != __id__:
                return nm
    except Exception:
        pass
    try:
        prov = _provenance_pid(None, 2)
        if prov and prov != _SELF_ID and prov != __id__:
            return prov
    except Exception:
        pass
    return None


def _gpu_frames_hit_rs(frames):
    try:
        for fr in (frames or []):
            for h in _GPU_RS_LIB_HINTS:
                if h in fr:
                    return h
    except Exception:
        pass
    return None

