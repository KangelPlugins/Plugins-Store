def _cd_tr(s):
    try:
        if _cd_lang() == "ru":
            return s
        return _CD_EN.get(s, s)
    except Exception:
        return s

_SELF_ID = __id__
_PRIO_MAX = 10000
_D3_THREADSTART_ON = True
_DIR_CANDIDATES = [
    "/sdcard/Download/CulpritDetector",
    "/storage/emulated/0/Download/CulpritDetector",
]
def _resolve_dir(cands):
    for _c in cands:
        try:
            _d = File(_c)
            if not _d.exists():
                _d.mkdirs()
            if _d.exists() and _d.isDirectory() and _d.canWrite():
                return _c
        except Exception:
            continue
    return cands[0]
