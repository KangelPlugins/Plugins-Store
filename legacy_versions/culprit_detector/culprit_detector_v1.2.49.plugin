def _b18_is_cancel(exc):
    try:
        import asyncio as _aio
        ce = getattr(_aio, "CancelledError", None)
        if ce is not None and isinstance(exc, ce): return True
    except Exception: pass
    try:
        import concurrent.futures as _cf
        ce2 = getattr(_cf, "CancelledError", None)
        if ce2 is not None and isinstance(exc, ce2): return True
    except Exception: pass
    try:
        return isinstance(exc, (GeneratorExit, KeyboardInterrupt, SystemExit))
    except Exception:
        return False

def _b18_record(loop, context):
    if not _BLOCK18_ON: return
    exc = None
    try:
        if isinstance(context, dict): exc = context.get("exception")
    except Exception: exc = None
    if exc is None: return
    if _b18_is_cancel(exc): return
    try: exc_cls = type(exc).__name__
    except Exception: exc_cls = "?"
    try: exc_msg = str(exc)
    except Exception: exc_msg = None
    reason = ("%s: %s" % (exc_cls, exc_msg)) if exc_msg else exc_cls
    py_mod = None; py_file = None; py_line = None
    try:
        py_mod, py_file, py_line = _b10_pyframe_culprit(exc, None)
    except Exception:
        py_mod = None
    if not py_mod: return
    culprit = py_mod; src = "py-frame/asyncio"; conf = "high"
    if culprit == _SELF_ID or culprit == __id__: return
    aio_msg = None
    try:
        if isinstance(context, dict): aio_msg = context.get("message")
    except Exception: aio_msg = None
    now = int(time.time() * 1000)
    key = "%s|%s|asyncio" % (culprit, reason)
    try:
        with _ASYNC_SEEN_LOCK:
            if now - _ASYNC_SEEN.get(key, 0) < _ASYNC_DEDUP_MS: return
            _ASYNC_SEEN[key] = now
    except Exception: pass
    rec = {"had_async_fail": True, "culprit": culprit, "src": src, "confidence": conf,
           "where": "asyncio", "py_module": py_mod, "py_file": py_file, "py_line": py_line,
           "aio_message": aio_msg, "reason": reason, "exc_cls": exc_cls, "exc_msg": exc_msg, "ts": now}
    try: _b16_push_verdict("async", rec)
    except Exception: pass
    try: _async_verdict_log(rec, "live")
    except Exception: pass
    try: _persist_async_fail(rec)
    except Exception: pass

def _b18_make_ceh_patch(orig):
    @_functools.wraps(orig)
