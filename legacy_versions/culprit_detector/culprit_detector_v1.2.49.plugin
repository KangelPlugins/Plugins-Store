    "addEntitiesToText", "applyEntities", "generateLayout",
    "messageTextToString", "replaceAnimatedEmoji",
)

def _b28_reg_hot_hook(pid, method, persist=False):
    """
    Запоминает, какой плагин зарегистрировал/исполняет хук на горячем render-методе.
    Нужно для Block#28, когда Block#4A не может прочитать Xposed/LSPlant jmap
    и возвращает lsplant-no-jmap.
    """
    try:
        if not pid or not method:
            return False
        try:
            pid = _canon_pid(pid)
        except Exception:
            pass
        if not isinstance(pid, str) or not pid:
            return False
        if pid == _SELF_ID or pid == __id__:
            return False
        if method not in _B28_HOT_METHODS:
            return False
        changed = False
        with _B28_HOOK_REG_LOCK:
            arr = _B28_HOOK_REG.get(pid)
            if arr is None:
                arr = []
                _B28_HOOK_REG[pid] = arr
            if method not in arr:
                arr.append(method)
                changed = True
        if changed:
            try:
                _log("Block#28: hot-hook registered owner=%r method=%s" % (pid, method))
            except Exception:
                pass
        if persist:
            try:
                _b28_persist_hot_hook(pid, method)
            except Exception:
                pass
        return True
    except Exception:
        return False
_GLOBALREF_HOOKS_NAME = "globalref_hooks.json"

