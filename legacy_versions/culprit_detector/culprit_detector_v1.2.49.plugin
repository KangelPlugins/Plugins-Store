def _b26_decl(lib):
    global _B26_OK
    c = ctypes
    needed = ("cd_cxa_start", "cd_cxa_stop", "cd_cxa_running")
    if not all(hasattr(lib, n) for n in needed):
        _B26_OK = False
        _log("Block#26: cd_cxa_* нет в .so (старый бинарь) — C++ throw-атрибуция отключена")
        return False
    lib.cd_cxa_start.argtypes = [c.c_char_p]; lib.cd_cxa_start.restype = c.c_int
    lib.cd_cxa_stop.restype = c.c_int
    lib.cd_cxa_running.restype = c.c_int
    for opt in ("cd_cxa_seen", "cd_cxa_captured", "cd_cxa_dropped"):
        if hasattr(lib, opt): getattr(lib, opt).restype = c.c_int64
    if hasattr(lib, "cd_cxa_selftest"): lib.cd_cxa_selftest.restype = c.c_int
    _B26_OK = True
    return True

def _b26_init(lib):
    if not _BLOCK26_ON:
        _log("Block#26: otkljuchen (_BLOCK26_ON=False)"); return
    try:
        if not _b26_decl(lib): return
    except Exception as e:
        _log("Block#26 decl err: %s" % e); return
    try:
        if hasattr(lib, "cd_cxa_selftest"):
            st = int(lib.cd_cxa_selftest())
            _log("Block#26: cd_cxa_selftest=%s" % ("PASS" if st == 0 else "FAIL(%d)" % st))
    except Exception as e:
        _log("Block#26 selftest err: %s" % e)

