        ("oom_dump*.json",            "НЕХВАТКА ПАМЯТИ (OOM)", "🧠", "съел память", ("had_oom",)),
        ("b23_bitmap_oom*.json",      "OOM от картинок", "🧠", "съел память картинками", None),
        ("bg_verdict.json",           "СБОЙ в фоне", "⚠️", "упал в фоновом потоке", ("had_bg_fail",)),
        ("cb_verdict.json",           "СБОЙ в колбэке", "⚠️", "упал в колбэке", ("had_cb_fail",)),
        ("ui_verdict.json",           "СБОЙ в интерфейсе", "⚠️", "упал в обработчике UI", None),
        ("dispatch_verdict.json",     "СБОЙ диспетчера", "⚠️", "упал в диспетчере", None),
