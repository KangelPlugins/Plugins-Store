def _host_lib_dir():
    try:
        ctx = _app_context()
        if ctx is None: return None
        ai = ctx.getApplicationInfo()
        d = getattr(ai, "nativeLibraryDir", None)
        return str(d) if d else None
    except Exception:
        return None

def _scope_decl(lib):
    c = ctypes
    if not all(hasattr(lib, n) for n in ("cd_scope_enter", "cd_scope_leave", "cd_scope_current")):
        return False
    lib.cd_scope_enter.argtypes = [c.c_int32]; lib.cd_scope_enter.restype = c.c_int
    lib.cd_scope_leave.argtypes = []; lib.cd_scope_leave.restype = c.c_int
    lib.cd_scope_current.argtypes = []; lib.cd_scope_current.restype = c.c_int32
    try:
        lib.cd_scope_depth.argtypes = []; lib.cd_scope_depth.restype = c.c_int32
    except Exception: pass
    try:
        lib.cd_thread_inherited.argtypes = []; lib.cd_thread_inherited.restype = c.c_int64
    except Exception: pass
    return True

def _b4c_init(lib):
    global _B4C_OK
    try:
        _b4c_decl(lib)
    except Exception as e:
        _B4C_OK = False
        _log(f"Block#4C: символы не найдены в .so (старый бинарь?) — #4C отключён: {e}")
        return
    try:
        rc = int(lib.cd_lt_init(int(_LT_SLOTS)))
        try:
            lib.cd_lt_clear()
        except Exception as ce:
            _log(f"Block#4C: lt_clear pre-selftest warn: {ce}")
        st = int(lib.cd_uw_selftest())
        try:
            lib.cd_lt_clear()
        except Exception as ce:
            _log(f"Block#4C: lt_clear post-selftest warn: {ce}")
        ncp = _native_crash_path()
        inst = -1
        if ncp:
            inst = int(lib.cd_install_crash_handler(ncp.encode("utf-8")))
        hld = None
        if hasattr(lib, "cd_set_host_lib_dir"):
            try:
                hld = _host_lib_dir()
                lib.cd_set_host_lib_dir((hld or "").encode("utf-8"))
            except Exception as _ehl:
                _log(f"Block#4C: cd_set_host_lib_dir err: {_ehl}"); hld = None
        if rc != 0:
            _B4C_OK = False
            _log(f"Block#4C: cd_lt_init FAIL rc={rc} — #4C otключён (native-crash attribution OFF)")
            return
        if st != 0:
            _B4C_OK = False
            _log(f"Block#4C: cd_uw_selftest FAIL rc={st} — #4C otключён (native-crash attribution OFF)")
            return
        if ncp and inst != 0:
            _B4C_OK = False
            _log(f"Block#4C: cd_install_crash_handler FAIL rc={inst} — #4C otключён")
            return
        _B4C_OK = True
        _log(f"Block#4C: lt_init rc={rc} slots={_LT_SLOTS}, uw_selftest={'PASS' if st==0 else 'FAIL(%d)' % st}, crash_handler={'OK' if inst==0 else 'rc=%d' % inst} -> {ncp}")
        _log(f"Block#4C +CJ host-native: lib_dir={hld!r} -> {'ON' if hld else 'OFF (старый .so или нет контекста)'}")
        global _SCOPE_OK
        try:
            if _scope_decl(lib):
                lib.cd_scope_enter(-1); lib.cd_scope_leave()
                _SCOPE_OK = True
                _log("Block#10/C scope: cd_scope_enter/leave доступны — _scoped_set/clear через ОДИН нативный вызов")
                try:
                    if hasattr(lib, "cd_thread_inherited"):
                        _log("Block#10/C: cd_thread_inherited=%d (порождённые потоки унаследовали тег)" % int(lib.cd_thread_inherited()))
                except Exception: pass
            else:
                _SCOPE_OK = False
                _log("Block#10/C scope: cd_scope_* нет в .so (старый бинарь) — _scoped_set/clear через legacy (2 вызова)")
        except Exception as _esc:
            _SCOPE_OK = False
            _log("Block#10/C scope: декл/round-trip err: %s" % _esc)
    except Exception as e:
        _B4C_OK = False
        _log(f"Block#4C init err: {e}")

def _load_native():
    global _NLIB, _NATIVE_OK
    if not _CTYPES_OK or _REG_BUF is None:
        _log("Block#3: ctypes/shared-реестр недоступен — натив отключён (tid=Java id)")
        return
    if not _SO_ARM64:
        _log("Block#3: .so не вшит (_SO_ARM64 пуст) — запусти embed_so.py; натив отключён")
        return
    try:
        path = _b3_extract_so()
        if not path:
            return
        try:
            jclass("java.lang.System").load(path)
        except Exception as e:
            _log(f"Block#3 System.load warn: {e}")
        lib = ctypes.CDLL(path)
        _b3_decl(lib)
        info = registry_info()
        rc = int(lib.cd_init(ctypes.c_uint64(info["addr"]), int(info["slots"]), int(info["slot_bytes"])))
        if rc != 0:
            _log(f"Block#3 cd_init FAIL rc={rc} — натив отключён")
            return
        hooks = int(lib.cd_start())
        if hooks < 0:
            _log(f"Block#3 cd_start FAIL rc={hooks} — натив отключён")
            try: lib.cd_stop()
            except Exception: pass
            _NLIB = None; _NATIVE_OK = False
            return
        _NLIB = lib; _NATIVE_OK = True
        _b4c_init(lib)
        try:
            _b19_init(lib)
        except Exception as _e19:
            _log(f"Block#19 init err: {_e19}")
        try:
            _b26_init(lib)
        except Exception as _e26:
            _log(f"Block#26 init err: {_e26}")
        _log(f"Block#3 натив загружен: {path}")
        _log(f"Block#3 cd_init OK (reg=0x{info['addr']:x} slots={info['slots']} slot={info['slot_bytes']}B), хуков malloc={hooks}")
        if hooks <= 0:
            _log("Block#3 ⚠ ноль хуков — sh не перехватил libc (проверь sh)")
    except Exception as e:
        _NLIB = None; _NATIVE_OK = False
        _log(f"Block#3 load err: {e}")

def _so_features_str():
    g = globals()
    flags = [("OOM", "_OOM_NATIVE_OK"), ("ANR", "_ANR_NATIVE_OK"),
             ("GREF", "_GREF_NATIVE_OK"), ("OP", "_OP_NATIVE_OK"),
             ("SCOPE", "_SCOPE_OK")]
    try:
        return "  ".join("%s:%s" % (lbl, "on" if g.get(v) else "off") for lbl, v in flags)
    except Exception:
        return ""

def _so_health():
    """Health of native libculprit.so for the 'Show culprits' header.
    state: 'ok' | 'not_loaded' | 'stale' | 'abi_mismatch'."""
    exp = _SO_ABI_EXPECT
    if not _NATIVE_OK or _NLIB is None:
        return {"ok": False, "state": "not_loaded", "abi": None, "expect": exp}
    abi = None
    try:
        if hasattr(_NLIB, "cd_abi_version"):
            abi = int(_NLIB.cd_abi_version())
    except Exception:
        abi = None
    if abi is None:
        return {"ok": False, "state": "stale", "abi": None, "expect": exp}
    if abi != exp:
        return {"ok": False, "state": "abi_mismatch", "abi": abi, "expect": exp}
    return {"ok": True, "state": "ok", "abi": abi, "expect": exp}


def native_mem_snapshot(top=5):
    d = _direct_snapshot()
    if not _NATIVE_OK or _NLIB is None:
        if not d["live_by_pid"] and d["total"] == 0:
            return None
        _pairs_src = dict(d["live_by_pid"])
        if int(d["live_untagged"]) > 0: _pairs_src["⟨untagged⟩"] = int(d["live_untagged"])
        pairs = sorted(_pairs_src.items(), key=lambda kv: kv[1], reverse=True)
        return {
            "total": 0, "untagged": 0, "dropped": 0, "dropped_bytes": -1, "live": 0,
            "direct_total": d["total"], "direct_untagged": d["untagged"],
            "direct_live_total": d["live_total"], "direct_live_untagged": d["live_untagged"],
            "top": pairs[:top],
        }
    try:
        n = len(_IDX_PID)
        arr = (ctypes.c_int64 * max(n, 1))()
        _NLIB.cd_snapshot(arr, n)
        combined = {}
        for i in range(n):
            pid = _resolve_idx(i) or f"idx{i}"
            combined[pid] = combined.get(pid, 0) + int(arr[i])
        for pid, b in d["live_by_pid"].items():
            combined[pid] = combined.get(pid, 0) + int(b)
        _unt = int(d["live_untagged"]) + int(_NLIB.cd_untagged())
        if _unt > 0: combined["⟨untagged⟩"] = combined.get("⟨untagged⟩", 0) + _unt
        pairs = sorted(combined.items(), key=lambda kv: kv[1], reverse=True)
        return {
            "total": int(_NLIB.cd_total()), "untagged": int(_NLIB.cd_untagged()),
            "dropped": int(_NLIB.cd_dropped()), "dropped_bytes": (int(_NLIB.cd_dropped_bytes()) if hasattr(_NLIB,'cd_dropped_bytes') else -1), "live": int(_NLIB.cd_live_count()),
            "direct_total": d["total"], "direct_untagged": d["untagged"],
            "direct_live_total": d["live_total"], "direct_live_untagged": d["live_untagged"],
            "top": pairs[:top],
        }
    except Exception:
        return None

class _CrumbFile:
    NAME = "last_breadcrumb.txt"
    def __init__(self):
        self.path = None; self._lock = threading.Lock()
        try:
            d = File(_DIR)
            if not d.exists(): d.mkdirs()
            self.path = File(d, self.NAME).getAbsolutePath()
        except Exception as e:
            _log(f"crumb init err: {e}")
    def read_prev(self):
        try:
            if self.path and os.path.exists(self.path):
                with open(self.path, "r", encoding="utf-8") as f:
                    return f.read().strip()
        except Exception: pass
        return None
    def write(self, pid, where):
        if not self.path: return
        with self._lock:
            try:
                with open(self.path, "w", encoding="utf-8") as f:
                    f.write(f"{pid}\t{where}\t{int(time.time()*1000)}"); f.flush()
            except Exception: pass
_CRUMB = None

def _known_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _KNOWN_FILE).getAbsolutePath()
    except Exception:
        return None
def _load_known():
    p = _known_path()
    try:
        if p and os.path.exists(p):
            with open(p, "r", encoding="utf-8") as f:
                return list(json.load(f))
    except Exception:
        pass
    return []
def _save_known(pid):
    try:
        cur = set(_load_known())
        if pid in cur: return
        cur.add(pid)
        p = _known_path()
        if not p: return
        _atomic_json_write(p, sorted(cur))
    except Exception:
        pass

def _known_union():
    out = set()
    try:
        out.update(_load_known() or [])
    except Exception:
        pass
    try:
        out.update([n for n in _IDX_PID if isinstance(n, str) and n])
    except Exception:
        pass
    try:
        p = _idxnames_path()
        if p and os.path.exists(p):
            with open(p, "r", encoding="utf-8") as f:
                m = json.load(f)
            if isinstance(m, dict):
                out.update([v for v in m.values() if isinstance(v, str) and v])
    except Exception:
        pass
    return list(out)


def _simple(class_str):
    s = class_str.replace("class ", "").strip()
    for sep in ("$", "."):
        if sep in s: s = s.split(sep)[-1]
    return s
def _tokens(s):
    return set(t for t in re.split(r"[^a-z0-9]+", (s or "").lower()) if len(t) >= 3)
def _is_hook_frame(f):
    if not f: return False
    for m in _HOOK_MARKERS:
        if m in f: return True
    return False
def _is_system_class(cls):
    if not cls: return True
    if "culprit" in cls.lower(): return True
    for p in _SYS_PREFIXES:
        if cls.startswith(p): return True
    return False
def _is_obfuscated(frame):
    parts = (frame or "").split(".")
    if len(parts) < 2: return True
    return all(len(p) <= 2 for p in parts[:-1])
def _short_method(frame):
    parts = (frame or "").split(".")
    return ".".join(parts[-2:]) if len(parts) >= 2 else frame
def _squash(s):
    return re.sub(r"[^a-z0-9]+", "", (s or "").lower())
def _py_module_of(frame):
    if not frame or not frame.startswith(_PY_PREFIX): return None
    rest = frame[len(_PY_PREFIX):]
    if not rest: return None
    return rest.split(".", 1)[0]
def _is_py_runtime_frame(fr):
    if not fr or not fr.startswith(_PY_PREFIX): return False
    low = fr[len(_PY_PREFIX):].lower()
    return any(low == s or low.startswith(s) for s in _PY_SYS_MODS)
def _stack_culprit(frames):
    for fr in frames:
        if _is_system_class(fr): continue
        if _is_hook_frame(fr): continue
        if _is_py_runtime_frame(fr): continue
        if _is_obfuscated(fr): continue
        return fr
    return None
def _pkg_of(frame):
    parts = (frame or "").split(".")
    return ".".join(parts[:3]) if len(parts) >= 3 else frame
def _map_stack_to_id(culprit_frame, known):
    if not culprit_frame or not known: return None
    mod = _py_module_of(culprit_frame)
    sq = _squash(mod) if mod else ""
    if sq:
        for pid in known:
            if _squash(pid) == sq: return pid
        for pid in known:
            ps = _squash(pid)
            if ps and len(ps) >= 4 and (ps in sq or sq in ps): return pid
    ct = _tokens(culprit_frame) - _GENERIC
    if not ct: return None
    best = None; best_score = 0; second = 0
    for pid in known:
        pt = _tokens(pid) - _GENERIC
        score = len(ct & pt)
        if score > best_score:
            second = best_score; best_score = score; best = pid
        elif score > second:
            second = score
    if best_score >= 1 and best_score > second:
        return best
    return None

_REENTRY = threading.local()
_FIRST_LOGGED = False
def _note_first(pid, where):
    global _FIRST_LOGGED
    if _FIRST_LOGGED: return
    _FIRST_LOGGED = True
    _log(f"first breadcrumb captured: pid={pid} where={where!r}")

def _crash_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _CRASH_FILE_NAME).getAbsolutePath()
    except Exception:
        return None
def _atomic_json_write(path, data, max_len=None):
    if not path: return False
    try:
        if max_len is not None:
            try:
                if len(data) > max_len: data = data[-max_len:]
            except Exception: pass
        tmp = path + ".tmp"
        with open(tmp, "w", encoding="utf-8") as f:
            json.dump(data, f, ensure_ascii=False); f.flush()
            try: os.fsync(f.fileno())
            except Exception: pass
        try:
            os.replace(tmp, path)
        except Exception:
            with open(path, "w", encoding="utf-8") as f2:
                json.dump(data, f2, ensure_ascii=False); f2.flush()
                try: os.fsync(f2.fileno())
                except Exception: pass
            try: os.remove(tmp)
            except Exception: pass
        return True
    except Exception as e:
        try: _log("atomic write err (%s): %s: %s" % (path, type(e).__name__, e))
        except Exception: pass
        return False

def _write_crash_verdict(rec):
    p = _crash_path()
    if not p: return
    _atomic_json_write(p, rec)

_LOAD_FILE_NAME = "load_verdict.json"
_LOAD_FAILS_MAX = 20
_LOAD_DEDUP_MS = 4000
_LOAD_SEEN = {}; _LOAD_SEEN_LOCK = threading.Lock()
_PY_PREFIX = "<python>."
_PY_SYS_MODS = ("importlib", "java.chaquopy", "java.", "chaquopy_java",
                "_sdk_version", "encodings.", "<frozen", "base_plugin")

def _load_verdict_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _LOAD_FILE_NAME).getAbsolutePath()
    except Exception:
        return None

def _thr_chain(thr):
    out = []; n = 0; cur = thr
    while cur is not None and n < 12:
        n += 1
        try: cls = cur.getClass().getName()
        except Exception: cls = "?"
        try: msg = cur.getMessage()
        except Exception: msg = None
        out.append((cls, msg, cur))
        try: nxt = cur.getCause()
        except Exception: nxt = None
        if nxt is cur: break
        cur = nxt
    return out

def _py_module_from_throwable(chain):
    for (_c, _m, exc) in chain:
        try: st = exc.getStackTrace()
        except Exception: st = None
        if st is None: continue
        for el in st:
            try:
                cn = el.getClassName() or ""
                mn = el.getMethodName() or ""
                fn = el.getFileName() or ""
                ln = el.getLineNumber()
            except Exception:
                continue
            if not cn.startswith(_PY_PREFIX): continue
            if mn != "<module>": continue
            mod = cn[len(_PY_PREFIX):]
            low = mod.lower()
            if any(low == s or low.startswith(s) for s in _PY_SYS_MODS): continue
            return mod, (fn or (mod + ".py")), (int(ln) if ln is not None else -1)
    return None, None, -1

def _load_reason(chain):
    for (cls, msg, _e) in reversed(chain):
        if msg:
            scls = cls.rsplit(".", 1)[-1] if cls else "?"
            return ("%s: %s" % (scls, msg)) if (scls and scls not in (msg or "")) else msg
    for (cls, _m, _e) in reversed(chain):
        if cls and cls != "?":
            return cls.rsplit(".", 1)[-1]
    return "unknown"

def _record_load_fail(scoped_pid, thr, where):
    try: chain = _thr_chain(thr)
    except Exception: chain = []
    py_mod, py_file, py_line = _py_module_from_throwable(chain)
    reason = _load_reason(chain)
    top_cls = chain[0][0] if chain else "?"
    top_msg = chain[0][1] if chain else None
    if where == "loadPlugin" and scoped_pid:
        culprit = scoped_pid; src = "scope/loadPlugin"; conf = "high" if py_mod else "medium"
    elif py_mod:
        culprit = py_mod; src = "py-frame"; conf = "high"
    elif scoped_pid:
        culprit = scoped_pid; src = "scope/" + where; conf = "medium"
    else:
        culprit = "unknown"; src = "none"; conf = "low"
    rec = {"had_load_fail": True, "culprit": culprit, "src": src, "confidence": conf,
           "where": where, "scoped_pid": scoped_pid, "py_module": py_mod,
           "py_file": py_file, "py_line": py_line, "reason": reason,
           "exc_cls": top_cls, "exc_msg": top_msg, "ts": int(time.time() * 1000)}
    key = "%s|%s|%s" % (culprit, reason, where); now = rec["ts"]
    with _LOAD_SEEN_LOCK:
        if now - _LOAD_SEEN.get(key, 0) < _LOAD_DEDUP_MS: return
        _LOAD_SEEN[key] = now
    try: _load_verdict_log(rec, "live")
    except Exception: pass
    try: _persist_load_fail(rec)
    except Exception: pass

def _persist_load_fail(rec):
    p = _load_verdict_path()
    if not p: return
    try:
        cur = []
        if os.path.exists(p):
            try:
                with open(p, "r", encoding="utf-8") as f: cur = list(json.load(f))
            except Exception: cur = []
        cur.append(rec)
        _atomic_json_write(p, cur, _LOAD_FAILS_MAX)
    except Exception: pass

def _read_and_clear_load_fails():
