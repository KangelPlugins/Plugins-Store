    _log("  detector survived; verdict -> %s" % _KG_VERDICT_NAME)
    _log("===============================================================")
    try:
        _b16_push_verdict("self_kill_blocked", {"culprit": name, "confidence": "high", "where": vector, "ts": ts})
    except Exception:
        pass
    return verdict

