_OP_DOMAIN_IDX = {"gpu": 0, "anim": 1, "mvel": 2, "binder": 3, "camera": 4, "mediacodec": 5, "gl": 6, "looper": 7}
_OP_OWNER_MAX = 64
_OP_API_MAX = 48
