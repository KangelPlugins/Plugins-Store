    except Exception as e:
        _log("Block#31 decl err: %s" % e)

def _b31_start():
    global _B31_STARTED, _B31_WD_STOPPED
    if not _BLOCK31_ON: return
    _B31_WD_STOPPED = False
    try: _b31_native_wd_start()
    except Exception: pass
    try: _b31_backup_self()
    except Exception: pass
    try: _b31_watchdog_arm()
    except Exception: pass
    if not (_B31_OK and _NATIVE_OK and _NLIB is not None):
        _log("Block#31: натив/символы недоступны -- только бэкап"); return
    if _B31_STARTED: return
    sp = _self_plugin_path()
    if not sp:
        _log("Block#31: put detektora ne razreshen -- propusk"); return
    try:
        rc = int(_NLIB.cd_fg_protect(sp.encode("utf-8")))
        if rc < 0: _log("Block#31: cd_fg_protect vernul %d" % rc)
    except Exception as e:
        _log("Block#31 cd_fg_protect err: %s" % e); return
    p = _fg_sentinel_path()
    _pw = _aw_mirror_path(p) or p
    try:
        rc2 = int(_NLIB.cd_fg_start((_pw or "").encode("utf-8")))
    except Exception as e:
        _log("Block#31 cd_fg_start err: %s" % e); return
    if rc2 < 0:
        _log("Block#31: cd_fg_start vernul %d -- libc rename/unlink ne zacepilis" % rc2); return
    _B31_STARTED = True
    _log("Block#31: file-guard установлен (libc rename/renameat/unlink/unlinkat), хуков=%d, защищён=%s" % (rc2, sp))
    try: _b31_read_sentinel("post-start")
    except Exception: pass

def _b31_stop():
    global _B31_STARTED
    try: _b31_watchdog_stop()
    except Exception: pass
    if not _B31_STARTED: return
    try:
        if _NLIB is not None: _NLIB.cd_fg_stop()
    except Exception: pass
    _B31_STARTED = False
    _log("Block#31: snjat (cd_fg_stop)")

def _b31_parse_sentinel(text):
    rec = {}
    try:
        for line in text.splitlines():
            line = line.strip()
            if not line or line in ("CULPRIT_FILEGUARD", "END"): continue
            for tok in line.split(" "):
                if "=" in tok:
                    k, v = tok.split("=", 1)
                    rec[k] = v
    except Exception:
        pass
    return rec

def _b31_read_sentinel(tag):
    if not _BLOCK31_ON: return None
    p = _fg_sentinel_path()
    if not p: return None
    _rp = _rc_take_path(p)
    if not _rp: return None
    try:
        with open(_rp, "r", encoding="utf-8", errors="replace") as f:
            text = f.read()
    except Exception:
        return None
    finally:
        try: os.remove(_rp)
        except Exception: pass
    rec = _b31_parse_sentinel(text)
    if not rec: return None
    owner_id = rec.get("owner_id") or ""
    if owner_id in ("(?)", ""): owner_id = ""
    try: idx = int(rec.get("owner_idx", "-1"))
    except Exception: idx = -1
    name = owner_id or _resolve_idx_durable(idx) or (("idx#%d" % idx) if idx >= 0 else "unknown")
    api = rec.get("api", "?")
    path = rec.get("path", "?")
    try: ts = int(rec.get("ts", "0"))
    except Exception: ts = int(time.time() * 1000)
    low = name.lower()
    dropper = ("netprotector" in low) or ("netblocker" in low) or ("shikatu" in low)
    verdict = {"event_type": "file_delete_blocked", "dropbox_tag": "self_protection", "tombstone_norm_version": 1, "kind": "detector_erase_blocked", "culprit": name, "owner_idx": idx,
               "api": api, "path": path, "vector": "os.replace/os.remove on detector .py",
               "dropper_signature": dropper, "neutralized": True,
               "confidence": "high", "detector": "Block#31 native file-guard",
               "version": __version__, "ts": ts, "tag": tag}
    vp = _fg_verdict_path()
    if vp:
        try:
            if not _atomic_json_write(vp, verdict):
                _log("Block#31 verdict write returned False")
        except Exception as e:
            _log("Block#31 verdict write err: %s" % e)
    _log("=============== DETECTOR ERASE NEUTRALIZED (Block#31) ===============")
    _log("  culprit=%s api=%s path=%s" % (name, api, path))
    _log("  detector .py survived; verdict -> %s" % _FG_VERDICT_NAME)
    _log("====================================================================")
    try:
        _b16_push_verdict("detector_erase_blocked", {"culprit": name, "confidence": "high", "where": api, "ts": ts})
    except Exception:
        pass
    return verdict

