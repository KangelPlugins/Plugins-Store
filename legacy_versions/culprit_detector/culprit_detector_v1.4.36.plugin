def _b17_record(owner, exc, fn=None, where="future", skip_unknown=False):
    if not _BLOCK17_ON: return
    try: exc_cls = type(exc).__name__
    except Exception: exc_cls = "?"
    try: exc_msg = str(exc)
    except Exception: exc_msg = None
    reason = ("%s: %s" % (exc_cls, exc_msg)) if exc_msg else exc_cls
    py_mod = None; py_file = None; py_line = None
    try:
        py_mod, py_file, py_line = _b10_pyframe_culprit(exc, owner)
    except Exception:
        py_mod = None
    if py_mod:
        culprit = py_mod; src = "py-frame/" + where; conf = "high"
    elif owner:
        culprit = owner; src = "scope/" + where; conf = "medium"
    else:
        culprit = "unknown"; src = "none"; conf = "low"
    if skip_unknown and conf == "low":
        return
    if culprit == _SELF_ID or culprit == __id__:
        return
    rec = {"had_fut_fail": True, "event_type": "future_exception", "dropbox_tag": "data_app_crash", "tombstone_norm_version": 1, "culprit": culprit, "src": src, "confidence": conf,
           "where": where, "scoped_pid": owner, "py_module": py_mod, "py_file": py_file,
           "py_line": py_line, "reason": reason, "exc_cls": exc_cls, "exc_msg": exc_msg,
           "ts": int(time.time() * 1000)}
    key = "%s|%s|%s" % (culprit, reason, where); now = rec["ts"]
    try:
        with _FUT_SEEN_LOCK:
            if now - _FUT_SEEN.get(key, 0) < _FUT_DEDUP_MS: return
            _FUT_SEEN[key] = now
    except Exception: pass
    try: _b16_push_verdict("fut", rec)
    except Exception: pass
    try: _fut_verdict_log(rec, "live")
    except Exception: pass
    try: _persist_fut_fail(rec)
    except Exception: pass

def _b17_wrap_fn(owner, fn, where="future"):
    if fn is None or not callable(fn) or getattr(fn, _B17_FLAG, False):
        return fn
    def _w(*a, **kw):
        pushed = False
        if owner is not None:
            try: pushed = _scoped_set(owner)
            except Exception: pushed = False
        try:
            return fn(*a, **kw)
        except BaseException as e:
            try: _b17_record(owner, e, fn, where)
            except Exception: pass
            raise
        finally:
            if pushed:
                try: _scoped_clear()
                except Exception: pass
    try: _functools.update_wrapper(_w, fn)
    except Exception: pass
    try: setattr(_w, _B17_FLAG, True)
    except Exception: pass
    return _w

def _b17_make_submit_patch(orig):
    @_functools.wraps(orig)
    def _patched(self, fn, /, *args, **kwargs):
        owner = None
        try: owner = _b14_caller_owner()
        except Exception: owner = None
        wfn = fn
        if owner is not None and callable(fn) and not getattr(fn, _B17_FLAG, False):
            try: wfn = _b17_wrap_fn(owner, fn)
            except Exception: wfn = fn
        fut = orig(self, wfn, *args, **kwargs)
        try: setattr(fut, _B17_FUT_TAG, True)
        except Exception: pass
        return fut
    try: setattr(_patched, _B17_FLAG, True)
    except Exception: pass
    return _patched

_B17_DELETE = object()

def _b17_make_map_patch(orig):
    @_functools.wraps(orig)
    def _patched(self, fn, *iterables, **kwargs):
        owner = None
        try: owner = _b14_caller_owner()
        except Exception: owner = None
        wfn = fn
        if owner is not None and callable(fn) and not getattr(fn, _B17_FLAG, False):
            try: wfn = _b17_wrap_fn(owner, fn, "map")
            except Exception: wfn = fn
        return orig(self, wfn, *iterables, **kwargs)
    try: setattr(_patched, _B17_FLAG, True)
    except Exception: pass
    return _patched

def _b17_make_adc_patch(orig):
    @_functools.wraps(orig)
    def _patched(self, fn, *args, **kwargs):
        owner = None
        try: owner = _b14_caller_owner()
        except Exception: owner = None
        wfn = fn
        if owner is not None and callable(fn) and not getattr(fn, _B17_FLAG, False):
            try: wfn = _b17_wrap_fn(owner, fn, "done_callback")
            except Exception: wfn = fn
        return orig(self, wfn, *args, **kwargs)
    try: setattr(_patched, _B17_FLAG, True)
    except Exception: pass
    return _patched

_B17_FUT_TAG = "_culprit_b17_wrapped"

def _b17_observe_future(fut, where):
    if not _BLOCK17_ON: return
    try:
        if getattr(fut, _B17_FUT_TAG, False): return
        if not fut.done(): return
    except Exception:
        return
    try:
        exc = fut.exception(timeout=0)
    except Exception:
        return
    if exc is None: return
    try: setattr(fut, _B17_FUT_TAG, True)
    except Exception: pass
    try: _b17_record(None, exc, None, where, True)
    except Exception: pass

def _b17_make_ascompleted_patch(orig):
    @_functools.wraps(orig)
    def _patched(fs, *args, **kwargs):
        for fut in orig(fs, *args, **kwargs):
            try: _b17_observe_future(fut, "as_completed")
            except Exception: pass
            yield fut
    try: setattr(_patched, _B17_FLAG, True)
    except Exception: pass
    return _patched

def _b17_make_wait_patch(orig):
    @_functools.wraps(orig)
    def _patched(fs, *args, **kwargs):
        res = orig(fs, *args, **kwargs)
        try:
            done = getattr(res, "done", None)
            if done:
                for fut in done:
                    try: _b17_observe_future(fut, "wait")
                    except Exception: pass
        except Exception: pass
        return res
    try: setattr(_patched, _B17_FLAG, True)
    except Exception: pass
    return _patched

def _b17_install():
    global _B17_INSTALLED
    if not _BLOCK17_ON:
        _log("Block#17: отключён (_BLOCK17_ON=False)"); return
    try:
        import concurrent.futures as _cf
    except Exception as e:
        _log("Block#17: concurrent.futures import err: %s" % e); return
    n = 0
    try:
        TPE = getattr(_cf, "ThreadPoolExecutor", None)
        if TPE is not None:
            orig = TPE.__dict__.get("submit")
            if orig is None:
                orig = getattr(TPE, "submit", None)
            if orig is not None and not getattr(orig, _B17_FLAG, False):
                patched = _b17_make_submit_patch(orig)
                TPE.submit = patched
                with _B17_WRAP_LOCK:
                    _B17_PATCHED.append((TPE, "submit", orig))
                n += 1
    except Exception as e:
        _log("Block#17: ThreadPoolExecutor.submit patch err: %s" % e)
    try:
        TPE = getattr(_cf, "ThreadPoolExecutor", None)
        if TPE is not None:
            had_map = "map" in TPE.__dict__
            origm = getattr(TPE, "map", None)
            if origm is not None and not getattr(origm, _B17_FLAG, False):
                patchedm = _b17_make_map_patch(origm)
                TPE.map = patchedm
                with _B17_WRAP_LOCK:
                    _B17_PATCHED.append((TPE, "map", TPE.__dict__.get("map") if had_map else _B17_DELETE))
                n += 1
    except Exception as e:
        _log("Block#17: ThreadPoolExecutor.map patch err: %s" % e)
    try:
        Fut = getattr(_cf, "Future", None)
        if Fut is not None:
            origc = Fut.__dict__.get("add_done_callback")
            if origc is None:
                origc = getattr(Fut, "add_done_callback", None)
            if origc is not None and not getattr(origc, _B17_FLAG, False):
                patchedc = _b17_make_adc_patch(origc)
                Fut.add_done_callback = patchedc
                with _B17_WRAP_LOCK:
                    _B17_PATCHED.append((Fut, "add_done_callback", origc))
                n += 1
    except Exception as e:
        _log("Block#17: Future.add_done_callback patch err: %s" % e)
    try:
        ac = getattr(_cf, "as_completed", None)
        if ac is not None and not getattr(ac, _B17_FLAG, False):
            _cf.as_completed = _b17_make_ascompleted_patch(ac)
            with _B17_WRAP_LOCK:
                _B17_PATCHED.append((_cf, "as_completed", ac))
            n += 1
    except Exception as e:
        _log("Block#17: as_completed patch err: %s" % e)
    try:
        wf = getattr(_cf, "wait", None)
        if wf is not None and not getattr(wf, _B17_FLAG, False):
            _cf.wait = _b17_make_wait_patch(wf)
            with _B17_WRAP_LOCK:
                _B17_PATCHED.append((_cf, "wait", wf))
            n += 1
    except Exception as e:
        _log("Block#17: wait patch err: %s" % e)
    _B17_INSTALLED = n > 0
    _log("Block#17: установлен (futures submit+map+add_done_callback+as_completed+wait wrap): %d/5 -> %s" % (n, _FUT_FILE_NAME))

def _b17_uninstall():
    global _B17_INSTALLED
    try:
        with _B17_WRAP_LOCK:
            items = list(_B17_PATCHED); del _B17_PATCHED[:]
        for cls, nm, orig in items:
            try:
                cur = getattr(cls, nm, None)
                if cur is not None and getattr(cur, _B17_FLAG, False):
                    if orig is _B17_DELETE:
                        try: delattr(cls, nm)
                        except Exception: pass
                    else:
                        setattr(cls, nm, orig)
            except Exception: pass
    except Exception: pass
    _B17_INSTALLED = False

