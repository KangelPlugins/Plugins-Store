                        except Exception: pass
                    _ktxt = ""
                    if _kstate:
                        _ktxt = " | kernel: state=%s wchan=%s syscall=%s -> %s" % (_kstate.get("state"), _kstate.get("wchan"), (_kstate.get("syscall") or _kstate.get("syscall_nr")), _kstate.get("nature"))
                    _top3 = " <- ".join((_jframes or [])[:3])
                    _log("Block#20 +DN/+DP%s: host-side UI stall %dms (NOT plugin; %d plugin frames; sample=%s%s) -> culprit=%r conf=%s src=%s%s | top: %s" % ((" +HN SUPPRESSED->host_idle(kernel epoll-wait)" if _kernel_idle else (" +HS SUPPRESSED->host_idle(kernel epoll-wait)" if _kernel_epoll_idle else (" +HL SUPPRESSED->host_idle(had_anr=false)" if _idle_suppress else ""))), int(waited_ms), _plugin_n, _phase, ((" held=%dms" % int(_sample_held_ms)) if _sample_held_ms else ""), _hculprit, _hconf, _hsrc, _ktxt, _top3 or "<none>"))
                else:
                    _log("Block#20: UI stall %dms but no plugin py-frame/scope/op/cpu (tid=%s) and host stack unavailable -> suppressed (no culprit)" % (int(waited_ms), _B20_UI_TID))
                _B20_REPORTED = True
                return
    try:
        culprit, src, conf, _hx_extra = _hx_apply(culprit, src, conf, py_file, _crows)
