                             "looper_idle": bool(_idle),
                             "java_stack": _jframes, "kernel": _kstate,
                             "cpu_top": _crows, "cpu_win_ms": (_cmeta or {}).get("win_ms"),
                             "reason": (("UI thread parked in kernel epoll-wait (do_epoll_wait) with framework looper top at sample -> kernel-proven idle, NOT a host freeze (+HN host_idle?kernel)") if _kernel_idle else (("UI thread sleeping in kernel poll/epoll wait (state=S, wchan=%s) with low UI CPU -> kernel-proven idle, NOT a host freeze (+HS host_idle?kernel-epoll)" % (_kw or "?")) if _kernel_epoll_idle else (("UI thread unresponsive > %dms; looper idle at sample (stall ended before capture) -> host component undetermined" % _B20_TIMEOUT_MS) if _idle else ("UI thread unresponsive > %dms; no plugin signal -> host component %s (caught %s)" % (_B20_TIMEOUT_MS, _component, _phase))))),
                             "ts": int(time.time() * 1000)}
                    try:
                        _hp = _oom_path(_HOST_STALL_FILE_NAME)
                        if _hp:
