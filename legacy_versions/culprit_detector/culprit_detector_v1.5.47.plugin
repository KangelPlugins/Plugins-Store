                else:
                    rec["culprit_basis"] = ("scope-active plugin at fault in host native code (crash_so=%s); no plugin-private .so (top_so null)" % rec.get("crash_so"))
                if rec.get("confidence") is None and _ic_br is None and rec.get("pid_choice_src") == "scope":
                    rec["confidence"] = "medium"
                _log("Block#4C +IC: host-native краш отнесён плагину %r -> crash_so=%s bridge=%s call_path=%s"
                     % (rec.get("pid"), rec.get("crash_so"), _ic_br, rec.get("call_path")))
        except Exception as _eic:
