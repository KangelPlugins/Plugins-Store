                    rec["ig_correlated"] = {"from": (_ig_best.get("kind") or "pyerr") + "_verdict", "culprit": _ig_cul, "py_file": _ig_best.get("py_file"), "py_line": _ig_best.get("py_line"), "age_ms": abs(int(_ig_ts) - _ig_best_ts)}
