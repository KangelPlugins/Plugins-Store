def _iu_stack_is_bridge(jframes, component):
    
    try:
        if component and any(_s in component for _s in _IU_BRIDGE_NAMES):
            return True
        for _f in (jframes or [])[:8]:
            if any(_s in _f for _s in _IU_BRIDGE_NAMES):
                return True
    except Exception:
        pass
    return False

def _iu_bridge_owner(jframes, waited_ms):
    
    try:
        _op = _b20_owner_from_op(int(waited_ms) + 2500)
        if _op and _op.get("owner"):
            return _op.get("owner"), ("op:" + str(_op.get("domain") or "?"))
    except Exception:
        pass
    try:
        _o, _fr, _how, _meta = _hook_owner_for_frames(jframes or [])
        if _o and _o not in (_SELF_ID, __id__):
            return _o, ("hook-map:" + str(_how))
    except Exception:
        pass
    try:
        for _f in (jframes or []):
            _cls = _f.split("(", 1)[0].rsplit(".", 1)[0] if "(" in _f else _f
            _pid = _map_stack_to_id(_cls, _known_union()) if _cls else None
            if _pid and _pid not in (_SELF_ID, __id__):
                return _pid, "stack-loader"
    except Exception:
        pass
    return None, None

def _op_family_native_install(dom):
    
    _U = dom.upper()
    if not (globals().get("_%s_NATIVE_ON" % _U, True) and globals().get("_%s_NATIVE_OK" % _U, False)
            and _NLIB is not None and _CTYPES_OK):
        return (False, 0)
    off = int(globals().get("_%s_ENTRY_OFFSET" % _U, 0) or 0)
    try:
        _self = getattr(_NLIB, "cd_%s_selftest" % dom)
        _inst = getattr(_NLIB, "cd_%s_install" % dom)
    except Exception:
        return (False, 0)
    try:
        _ok = int(_self(ctypes.c_int32(off)))
    except Exception:
        _ok = 0
    if _ok <= 0:
        return (False, 0)
    try:
        _n = int(_inst(ctypes.c_int32(off)))
    except Exception:
        _n = 0
    if _n > 0:
        globals()["_%s_NATIVE_ACTIVE" % _U] = True
        return (True, _n)
    return (False, 0)

def _gpu_frames_hit_rs(frames):
    try:
        for fr in (frames or []):
            for h in _GPU_RS_LIB_HINTS:
                if h in fr:
                    return h
    except Exception:
        pass
    return None

