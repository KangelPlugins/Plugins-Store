            _exec_tl_stk().append(False); return
        _REENTRY.busy = True; pushed = False
        try:
            args = param.args
            n = len(args) if args is not None else 0
            if n == 0: return
            a0 = args[0]
            pid = str(a0) if a0 is not None else "unknown"
            if len(pid) > 80: pid = pid[:80]
            where = ""
            if n > 3:
                a3 = args[3]; a2 = args[2]
                pn = str(a3) if a3 is not None else ""
