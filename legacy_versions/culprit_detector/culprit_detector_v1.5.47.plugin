_LOG_PATH = None; _LOG_LOCK = threading.Lock()
def _init_log():
    global _LOG_PATH
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        _LOG_PATH = File(d, f"breadcrumb_{int(time.time())}.log").getAbsolutePath()
    except Exception: _LOG_PATH = None
def _log(msg):
    line = f"[{time.strftime('%H:%M:%S')}] {msg}"
    print(f"[Culprit] {line}")
    if _LOG_PATH:
        try:
            with _LOG_LOCK:
                with open(_LOG_PATH, "a", encoding="utf-8") as f: f.write(line + "\n")
        except Exception: pass

_Slot = None
_REG_BUF = None
_REG_ADDR = 0
if _CTYPES_OK:
    try:
        class _Slot(ctypes.Structure):
            _fields_ = [("tid", ctypes.c_int64),
                        ("pid_idx", ctypes.c_int32),
                        ("seq", ctypes.c_int32)]
        _REG_BUF = (_Slot * _REG_N)()
        _REG_ADDR = ctypes.addressof(_REG_BUF)
    except Exception:
        _Slot = None; _REG_BUF = None; _REG_ADDR = 0


_PID_IDX = {}; _IDX_PID = []; _INTERN_LOCK = threading.RLock()
def _pidindex_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _PIDINDEX_FILE).getAbsolutePath()
    except Exception:
        return None
def _persist_pidindex():
    p = _pidindex_path()
    if not p: return
    try:
        with _INTERN_LOCK:
            data = list(_IDX_PID)
        _atomic_json_write(p, data)
    except Exception:
        pass
_IDXNAMES_FILE = "idx_names.json"
def _idxnames_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _IDXNAMES_FILE).getAbsolutePath()
    except Exception:
        return None
_IDXNAMES_GEN = 0
def _persist_idxnames():
    p = _idxnames_path()
    if not p: return
    try:
        with _INTERN_LOCK:
            names = list(_IDX_PID)
        cur = {}
        try:
            with open(p, "r", encoding="utf-8") as f:
                old = json.load(f)
            if isinstance(old, dict):
                cur = {str(k): v for k, v in old.items() if isinstance(v, str) and v}
        except Exception:
            cur = {}
        global _IDXNAMES_GEN
        for idx, nm in enumerate(names):
            if isinstance(nm, str) and nm:
                prev = cur.get(str(idx))
                if prev is None:
                    cur[str(idx)] = nm
                elif prev != nm:
                    cur[str(idx)] = nm
                    _IDXNAMES_GEN += 1
                    try: _log("Block#2 idx-sidecar remap idx=%d %r->%r (gen=%d)" % (idx, prev, nm, _IDXNAMES_GEN))
                    except Exception: pass
        _atomic_json_write(p, cur)
    except Exception:
        pass
def _resolve_idx_durable(i):
    if i is None or i < 0: return None
    p = _idxnames_path()
    if not p: return None
    try:
        with open(p, "r", encoding="utf-8") as f:
            m = json.load(f)
        if isinstance(m, dict):
            v = m.get(str(i))
            return v if (isinstance(v, str) and v) else None
    except Exception:
        pass
    return None
_CANON_CACHE = {}
def _canon_pid(pid):
    if not isinstance(pid, str) or not pid:
        return pid
    cached = _CANON_CACHE.get(pid)
    if cached is not None:
        return cached
    try:
        for m in list(_sys.modules.values()):
            try:
                if getattr(m, "__name__", None) == pid:
                    cid = getattr(m, "__id__", None)
                    if isinstance(cid, str) and cid:
                        _CANON_CACHE[pid] = cid
                        return cid
            except Exception:
                pass
    except Exception:
        pass
    return pid
def _intern(pid):
    if not (isinstance(pid, str) and pid):
        return -1
    with _INTERN_LOCK:
        i = _PID_IDX.get(pid)
        if i is not None:
            return i
    try: pid = _canon_pid(pid)
    except Exception: pass
    if not (isinstance(pid, str) and pid):
        return -1
    _grew = None
    with _INTERN_LOCK:
        i = _PID_IDX.get(pid)
        if i is None:
            i = len(_IDX_PID); _IDX_PID.append(pid); _PID_IDX[pid] = i
            _grew = len(_IDX_PID)
    if _grew is not None:
        _PERSIST_IO_LOCK.acquire()
        try:
            try: _persist_pidindex()
            except Exception: pass
            try: _persist_idxnames()
            except Exception: pass
        finally:
            try: _PERSIST_IO_LOCK.release()
            except Exception: pass
        _publish_pid_count(_grew)
    return i
def _deidx_name(name):
    try:
        if isinstance(name, str) and len(name) > 1 and name[0] == "#" and name[1:].isdigit():
            nm = _resolve_idx_durable(int(name[1:]))
            if nm:
                return nm
    except Exception:
        pass
    return name

def _resolve_idx(i):
    if i is None or i < 0: return None
    with _INTERN_LOCK:
        return _IDX_PID[i] if 0 <= i < len(_IDX_PID) else None
def _load_pidindex():
    saved = []
    p = _pidindex_path()
    if p:
        try:
            with open(p, "r", encoding="utf-8") as f:
                saved = list(json.load(f))
        except Exception:
            saved = []
    sidecar = {}
    sp = _idxnames_path()
    if sp:
        try:
            with open(sp, "r", encoding="utf-8") as f:
                m = json.load(f)
            if isinstance(m, dict):
                for k, v in m.items():
                    try:
                        if isinstance(v, str) and v:
                            sidecar[int(k)] = v
                    except Exception:
                        pass
        except Exception:
            sidecar = {}
    if sidecar and len(sidecar) > len([x for x in saved if isinstance(x, str) and x]):
        n = max(sidecar) + 1
        if all(j in sidecar for j in range(n)):
            saved = [sidecar[j] for j in range(n)]
    with _INTERN_LOCK:
        if _IDX_PID:
            return
        for nm in saved:
            idx = len(_IDX_PID)
            _IDX_PID.append(nm)
            if isinstance(nm, str) and nm and nm not in _PID_IDX:
                _PID_IDX[nm] = idx
        try: _persist_idxnames()
        except Exception: pass

def _cur_tid():
    if _NATIVE_OK and _NLIB is not None:
        try: return int(_NLIB.cd_gettid())
        except Exception: pass
    return None

def _reg_set(tid, idx):
    if tid is None: return False
    if _NATIVE_OK and _NLIB is not None and hasattr(_NLIB, "cd_reg_publish_tid"):
        try:
            if idx < 0:
                _NLIB.cd_reg_clear_tid(ctypes.c_int64(int(tid)))
            else:
                _NLIB.cd_reg_publish_tid(ctypes.c_int64(int(tid)), ctypes.c_int32(int(idx)))
            return True
        except Exception:
            pass
    return False

def _reg_get(tid):
    if tid is None: return None
    if _NATIVE_OK and _NLIB is not None and hasattr(_NLIB, "cd_reg_lookup_tid"):
        try:
            res = int(_NLIB.cd_reg_lookup_tid(ctypes.c_int64(int(tid))))
            return res if res >= 0 else None
        except Exception:
            pass
    return None

_EXC_RATE = {}
_EXC_RATE_LOCK = threading.Lock()
_EXC_RATE_WINDOW_MS = 60000
_EXC_RATE_MAXKEEP = 240
_EXC_RATE_HOT = 30.0
def _exc_rate_record(culprit):
    if not culprit: return (0.0, 0)
    now = int(time.time() * 1000)
    try:
        with _EXC_RATE_LOCK:
            lst = _EXC_RATE.get(culprit)
            if lst is None: lst = _EXC_RATE[culprit] = []
            lst.append(now)
            cut = now - _EXC_RATE_WINDOW_MS
            drop = 0
            for _ts in lst:
                if _ts >= cut: break
                drop += 1
            if drop: del lst[:drop]
            if len(lst) > _EXC_RATE_MAXKEEP: del lst[:len(lst) - _EXC_RATE_MAXKEEP]
            n = len(lst)
            span = (lst[-1] - lst[0]) if n >= 2 else 0
            per_min = (n * 60000.0 / span) if span > 0 else float(n)
            return (round(per_min, 2), n)
    except Exception:
        return (0.0, 0)

_ARM_OK = False
_PIDCOUNT_OK = False
_SEED_OK = False
_JP_ARM_SEED = False
def _publish_pid_count(n):
    if not (_PIDCOUNT_OK and _NLIB is not None): return
    try: _NLIB.cd_reg_set_pid_count(int(n))
    except Exception: pass
def _scoped_arm(pid):
    if not (_ARM_OK and _NLIB is not None): return False
    try:
        _NLIB.cd_scope_arm(int(_intern(pid))); return True
    except Exception:
        return False
def _scoped_arm_clear():
    if not (_ARM_OK and _NLIB is not None): return
    try: _NLIB.cd_scope_arm_clear()
    except Exception: pass

def _scoped_seed_arm(pid):
    if not (_SEED_OK and _NLIB is not None): return False
    try:
        return int(_NLIB.cd_seed_arm(int(_intern(pid)))) == 0
    except Exception:
        return False

def _scoped_set(pid):
    tid = _cur_tid()
    if tid is None: return False
    idx = _intern(pid)
    if _SCOPE_OK and _NLIB is not None:
        try: _NLIB.cd_scope_enter(int(idx))
        except Exception: pass
        return True
    return False
def _scoped_clear():
    if _SCOPE_OK and _NLIB is not None:
        try: _NLIB.cd_scope_leave()
        except Exception: pass
        return
    return
def _publish_tid(pid):
    _reg_set(_cur_tid(), _intern(pid))

_DIRECT_LOCK = threading.Lock()
_DIRECT_BYTES = {}
_DIRECT_TOTAL = 0
_DIRECT_UNTAGGED = 0
_DIRECT_LIVE = {}
_DIRECT_LIVE_TOTAL = 0
_DIRECT_LIVE_UNTAGGED = 0
_DIRECT_REGS = {}
_DIRECT_REG_LOCK = threading.Lock()
_DIRECT_RQ = None
_WeakReference = None
_SysClass = None
_DIRECT_REAPER = None
_DIRECT_REAPER_STOP = None

def _direct_snapshot():
    with _DIRECT_LOCK:
        return {
            "total": _DIRECT_TOTAL, "untagged": _DIRECT_UNTAGGED, "by_pid": dict(_DIRECT_BYTES),
            "live_total": _DIRECT_LIVE_TOTAL, "live_untagged": _DIRECT_LIVE_UNTAGGED,
            "live_by_pid": dict(_DIRECT_LIVE),
        }

def _direct_pid_now():
    try:
        idx = _reg_get(_cur_tid())
        if idx is not None and idx >= 0:
            return _resolve_idx(idx)
    except Exception:
        pass
    return None

def _direct_register(obj, nbytes):
    global _DIRECT_TOTAL, _DIRECT_UNTAGGED, _DIRECT_LIVE_TOTAL, _DIRECT_LIVE_UNTAGGED
    try:
        n = int(nbytes)
    except Exception:
        return
    if n <= 0:
        return
    pid = _direct_pid_now()
    with _DIRECT_LOCK:
        _DIRECT_TOTAL += n
        if pid is None: _DIRECT_UNTAGGED += n
        else: _DIRECT_BYTES[pid] = _DIRECT_BYTES.get(pid, 0) + n
    reg_ok = False
    if obj is not None and _DIRECT_RQ is not None and _WeakReference is not None and _SysClass is not None:
        try:
            wr = _WeakReference(obj, _DIRECT_RQ)
            ihc = int(_SysClass.identityHashCode(wr))
            with _DIRECT_REG_LOCK:
                _DIRECT_REGS.setdefault(ihc, []).append([wr, pid, n])
            reg_ok = True
        except Exception:
            reg_ok = False
    if reg_ok:
        with _DIRECT_LOCK:
            _DIRECT_LIVE_TOTAL += n
            if pid is None: _DIRECT_LIVE_UNTAGGED += n
            else: _DIRECT_LIVE[pid] = _DIRECT_LIVE.get(pid, 0) + n

def _direct_reaper(stop_evt):
    global _DIRECT_LIVE_TOTAL, _DIRECT_LIVE_UNTAGGED
    if _DIRECT_RQ is None or _SysClass is None:
        return
    while not stop_evt.is_set():
        ref = None
        try:
            ref = _DIRECT_RQ.remove(500)
        except Exception:
            ref = None
        if ref is None:
            continue
        rec = None
        try:
            ihc = int(_SysClass.identityHashCode(ref))
            with _DIRECT_REG_LOCK:
                bucket = _DIRECT_REGS.get(ihc)
                if bucket:
                    for i in range(len(bucket)):
                        try:
                            if bucket[i][0].equals(ref):
                                rec = bucket.pop(i); break
                        except Exception:
                            pass
                    if not bucket:
                        _DIRECT_REGS.pop(ihc, None)
        except Exception:
            rec = None
        if rec is not None:
            _, pid, cap = rec
            with _DIRECT_LOCK:
                _DIRECT_LIVE_TOTAL = max(0, _DIRECT_LIVE_TOTAL - cap)
                if pid is None:
                    _DIRECT_LIVE_UNTAGGED = max(0, _DIRECT_LIVE_UNTAGGED - cap)
                else:
                    v = _DIRECT_LIVE.get(pid, 0) - cap
                    if v > 0: _DIRECT_LIVE[pid] = v
                    else: _DIRECT_LIVE.pop(pid, None)

def _direct_live_start():
    global _DIRECT_RQ, _WeakReference, _SysClass, _DIRECT_REAPER, _DIRECT_REAPER_STOP
    if _DIRECT_RQ is not None:
        return True
    wref = _jc("java.lang.ref.WeakReference")
    rq   = _jc("java.lang.ref.ReferenceQueue")
    sysc = _jc("java.lang.System")
    if not (wref and rq and sysc):
        _log("Block#3D: live-tracking недоступен (нет WeakReference/ReferenceQueue/System)")
        return False
    _WeakReference = wref; _SysClass = sysc
    try:
        _DIRECT_RQ = rq()
    except Exception as e:
        _log(f"Block#3D: ReferenceQueue init err: {e}"); _DIRECT_RQ = None; return False
    _DIRECT_REAPER_STOP = threading.Event()
    _DIRECT_REAPER = threading.Thread(target=_direct_reaper, args=(_DIRECT_REAPER_STOP,), name="culprit-direct-reaper", daemon=True)
    _DIRECT_REAPER.start()
    return True

_LEAK_FILE_NAME = "leak_verdict.json"
_LEAK_FAILS_MAX = 20
_LEAK_DEDUP_MS = 60000
_LEAK_SEEN = {}; _LEAK_SEEN_LOCK = threading.Lock()
_BLOCK27_ON = True
_BLOCK27_VG_ON = False
_VIEW_REGS = {}
_VIEW_REG_LOCK = threading.Lock()
_B27_REAPER = None
_B27_REAPER_STOP = None
_B27_SWEEP_MS = 3000
_B27_GRACE_MS = 1500

def _leak_verdict_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _LEAK_FILE_NAME).getAbsolutePath()
    except Exception:
        return None

_B27_LOG_WINDOW_MS = 10000
_B27_LOG_BURST = 3
_B27_LOG_STATE = {}
_B27_LOG_LOCK = threading.Lock()

def _b27_log_emit_summary(owner, suppressed, span_ms, last_ihc, last_desc):
    if suppressed <= 0: return
    try: _log("Block#27: track view owner=%s +%d more (%s, last ihc=%d) in %.1fs [throttled]" % (owner, suppressed, last_desc, last_ihc, span_ms/1000.0))
    except Exception: pass

def _b27_log_track(ihc, owner, desc):
    now = int(time.time()*1000)
    line = None; summary = None
    with _B27_LOG_LOCK:
        st = _B27_LOG_STATE.get(owner)
        if st is None or (now - st[0]) >= _B27_LOG_WINDOW_MS:
            if st is not None and st[2] > 0:
                summary = (owner, st[2], now - st[0], st[3], st[4])
            _B27_LOG_STATE[owner] = [now, 1, 0, ihc, desc]
            line = "Block#27: track view ihc=%d owner=%s (%s)" % (ihc, owner, desc)
        else:
            st[1] += 1; st[3] = ihc; st[4] = desc
            if st[1] <= _B27_LOG_BURST:
                line = "Block#27: track view ihc=%d owner=%s (%s)" % (ihc, owner, desc)
            else:
                st[2] += 1
    if line:
        try: _log(line)
        except Exception: pass
    if summary is not None:
        _b27_log_emit_summary(summary[0], summary[1], summary[2], summary[3], summary[4])

def _b27_log_flush():
    now = int(time.time()*1000)
    pending = []
    with _B27_LOG_LOCK:
        for owner in list(_B27_LOG_STATE.keys()):
            st = _B27_LOG_STATE[owner]
            if (now - st[0]) >= _B27_LOG_WINDOW_MS:
                if st[2] > 0:
                    pending.append((owner, st[2], now - st[0], st[3], st[4]))
                _B27_LOG_STATE.pop(owner, None)
    for p in pending:
        _b27_log_emit_summary(p[0], p[1], p[2], p[3], p[4])

def _b27_owner_now():
    try:
        pid = _pm_scan_py(_pm_python_stack(48))
        if pid and pid != _SELF_ID: return pid
    except Exception: pass
    try:
        pid = _direct_pid_now()
        if pid and pid != _SELF_ID: return pid
    except Exception: pass
    return None

def _b27_view_ihc(view):
    try:
        return int(jclass("java.lang.System").identityHashCode(view))
    except Exception:
        return None

def _b27_weakref(view):
    try:
        return jclass("java.lang.ref.WeakReference")(view)
    except Exception:
        return None

def _b27_register_add(view, desc, owner=None):
    if not _BLOCK27_ON or view is None: return
    if owner is None:
        owner = _b27_owner_now()
    if not owner or owner == _SELF_ID: return
    ihc = _b27_view_ihc(view)
    if ihc is None: return
    wref = _b27_weakref(view)
    if wref is None:
        return
    with _VIEW_REG_LOCK:
        bucket = _VIEW_REGS.setdefault(ihc, [])
        for r in bucket:
            if r[1] == owner:
                r[3] = desc
                if len(r) > 4 and wref is not None: r[4] = wref
                return
        bucket.append([ihc, owner, int(time.time()*1000), desc, wref])
    _b27_log_track(ihc, owner, desc)

def _b27_register_remove(view):
    if view is None: return
    ihc = _b27_view_ihc(view)
    if ihc is None: return
    with _VIEW_REG_LOCK:
        bucket = _VIEW_REGS.get(ihc)
        if not bucket:
            return
        kept = []
        for r in bucket:
            wr = r[4] if len(r) > 4 else None
            vobj = None
            if wr is not None:
                try: vobj = wr.get()
                except Exception: vobj = None
            drop = False
            if vobj is not None:
                try:
                    if vobj is view or bool(vobj.equals(view)): drop = True
                except Exception:
                    drop = False
            if not drop:
                kept.append(r)
        if kept:
            _VIEW_REGS[ihc] = kept
        else:
            _VIEW_REGS.pop(ihc, None)

def _b27_live_pids():
    out = set()
    reg = {}
    try:
        with _REG_LOCK:
            reg = dict(_REGISTRY)
    except Exception:
        reg = {}
    try:
        for e in _b11_plugin_entries():
            try:
                k = _safe_str(e.getKey())
                if not k: continue
                r = reg.get(k)
                if r is not None and not r.get("inst"):
                    continue
                out.add(k)
            except Exception: pass
    except Exception: pass
    try:
        for pid, r in reg.items():
            if r and r.get("inst"): out.add(pid)
    except Exception: pass
    return out

def _b27_write_leak(owner, by_desc, age_ms, count):
    p = _leak_verdict_path()
    if not p: return
    try:
        parts = sorted(by_desc.items(), key=lambda kv: -kv[1])
    except Exception:
        parts = list(by_desc.items())
    where = ", ".join("%s x%d" % (d, n) for d, n in parts) if parts else "view-leak"
    kinds = set(by_desc.keys())
    if kinds == {"WindowManager.addView"}:
        reason = "view добавлен через WindowManager.addView и не снят (removeView/removeViewImmediate) до выгрузки плагина"
    elif kinds == {"ViewGroup.addView"}:
        reason = "view добавлен в иерархию через ViewGroup.addView и не снят (removeView) до выгрузки плагина"
    else:
        reason = "views добавлены через %s и остались прикреплёнными до выгрузки плагина" % " + ".join(sorted(kinds))
    rec = {"had_leak": True, "culprit": owner, "src": "view-reaper", "confidence": "high",
           "kind": "view-leak", "where": where, "leaked_views": count, "by_desc": by_desc,
           "age_ms": age_ms, "reason": reason,
           "exc_cls": "ViewLeak", "exc_msg": where, "ts": int(time.time()*1000),
           "event_type": "view_leak", "dropbox_tag": "app_memory_leak", "tombstone_norm_version": 1}
    key = "%s" % owner; now = rec["ts"]
    with _LEAK_SEEN_LOCK:
        if now - _LEAK_SEEN.get(key, 0) < _LEAK_DEDUP_MS: return
        _LEAK_SEEN[key] = now
    try:
        with _HX_LEAK_LOCK: _HX_LEAK_RECENT[owner] = now
    except Exception: pass
    _PERSIST_IO_LOCK.acquire()
    try:
        cur = []
        if os.path.exists(p):
            try:
                with open(p, "r", encoding="utf-8") as f: cur = list(json.load(f))
            except Exception: cur = []
        cur.append(rec)
        _atomic_json_write(p, cur, _LEAK_FAILS_MAX)
    except Exception: pass
    finally:
        try: _PERSIST_IO_LOCK.release()
        except Exception: pass
    try:
        _log("================ VIEW-LEAK VERDICT (Block#27) ================")
        _log("ВИНОВНИК УТЕЧКИ: %r conf=high views=%d age=%dms (%s)" % (owner, count, age_ms, where))
        _log("  причина: %s" % rec["reason"])
        _log("==============================================================")
    except Exception: pass

def _b27_is_live_leak(wref):
    if wref is None: return (False, True)
    try: vobj = wref.get()
    except Exception: return (False, True)
    if vobj is None: return (True, False)
    try:
        if vobj.getParent() is not None: return (True, True)
    except Exception: pass
    try:
        if bool(vobj.isAttachedToWindow()): return (True, True)
    except Exception: pass
    return (True, False)

_B27_EMPTY_LIVE_STREAK = 0
def _b27_sweep(force_all=False):
    try:
        with _VIEW_REG_LOCK:
            snap = [(ihc, list(bucket)) for ihc, bucket in _VIEW_REGS.items()]
        if not snap: return
        live = _b27_live_pids()
        global _B27_EMPTY_LIVE_STREAK
        if not live:
            _B27_EMPTY_LIVE_STREAK += 1
            if _B27_EMPTY_LIVE_STREAK in (1, 5, 20) or (_B27_EMPTY_LIVE_STREAK % 100 == 0):
                try: _log("Block#27 WARN: live-owner set EMPTY for %d sweep(s) -- leak detection inert (host getPlugins() API change?)" % _B27_EMPTY_LIVE_STREAK)
                except Exception: pass
        elif _B27_EMPTY_LIVE_STREAK:
            try: _log("Block#27: live-owner set recovered after %d empty sweep(s)" % _B27_EMPTY_LIVE_STREAK)
            except Exception: pass
            _B27_EMPTY_LIVE_STREAK = 0
        now = int(time.time()*1000)
        leaked = {}; drop_recs = {}
        for ihc, bucket in snap:
            for rec in bucket:
                owner = rec[1]; ts = rec[2]; desc = rec[3]
                wref = rec[4] if len(rec) > 4 else None
                if (now - ts) < _B27_GRACE_MS and not force_all: continue
                decided, is_leak = _b27_is_live_leak(wref)
                if decided and not is_leak:
                    drop_recs.setdefault(ihc, set()).add(id(rec)); continue
                gone = (owner not in live) if live else False
                if force_all and not gone:
                    drop_recs.setdefault(ihc, set()).add(id(rec)); continue
                if not gone: continue
                info = leaked.setdefault(owner, {"total": 0, "by_desc": {}, "age": now - ts})
                info["total"] += 1
                info["by_desc"][desc] = info["by_desc"].get(desc, 0) + 1
                if (now - ts) > info["age"]: info["age"] = now - ts
                drop_recs.setdefault(ihc, set()).add(id(rec))
        for owner, info in leaked.items():
            _b27_write_leak(owner, info["by_desc"], info["age"], info["total"])
        if drop_recs:
            with _VIEW_REG_LOCK:
                for ihc, ids in drop_recs.items():
                    bucket = _VIEW_REGS.get(ihc)
                    if not bucket: continue
                    kept = [r for r in bucket if id(r) not in ids]
                    if kept: _VIEW_REGS[ihc] = kept
                    else: _VIEW_REGS.pop(ihc, None)
    except Exception as e:
        try: _log("Block#27 sweep err: %s" % e)
        except Exception: pass

def _b27_reaper(stop_evt):
    while not stop_evt.is_set():
        try: stop_evt.wait(_B27_SWEEP_MS/1000.0)
        except Exception: pass
        if stop_evt.is_set(): break
        _gil_begin(_GIL_B27)
        try:
            _b27_sweep(False)
            _b27_log_flush()
        finally:
            _gil_end(_GIL_B27)

class _ViewAddHook(MethodHook):
    def after_hooked_method(self, param):
        try:
            try:
                if param.getThrowable() is not None: return
            except Exception: pass
            args = param.args
            if args is not None and len(args) >= 1 and args[0] is not None:
                pass
                _b27_register_add(args[0], "WindowManager.addView")
        except Exception: pass

class _ViewRemoveHook(MethodHook):
    def before_hooked_method(self, param):
        try:
            if not _VIEW_REGS: return
            args = param.args
            if args is not None and len(args) >= 1 and args[0] is not None:
                _b27_register_remove(args[0])
        except Exception: pass

class _ViewGroupAddHook(MethodHook):
    def after_hooked_method(self, param):
        try:
            try:
                if param.getThrowable() is not None: return
            except Exception: pass
            try: owner = _direct_pid_now()
            except Exception: owner = None
            if not owner or owner == _SELF_ID: return
            args = param.args
            if args is not None and len(args) >= 1 and args[0] is not None:
                pass
                _b27_register_add(args[0], "ViewGroup.addView", owner=owner)
        except Exception: pass

class _DirectAllocHook(MethodHook):
    def after_hooked_method(self, param):
        try:
            try:
                if param.getThrowable() is not None: return
            except Exception:
                pass
            args = param.args
            if args is not None and len(args) >= 1 and args[0] is not None:
                _direct_register(getattr(param, "thisObject", None), args[0])
        except Exception:
            pass

class _DirectAllocResultHook(MethodHook):
    def after_hooked_method(self, param):
        try:
            try:
                if param.getThrowable() is not None: return
            except Exception:
                pass
            args = param.args
            if args is not None and len(args) >= 1 and args[0] is not None:
                obj = None
                try: obj = param.getResult()
                except Exception: obj = None
                _direct_register(obj, args[0])
        except Exception:
            pass

class _ThreadStartHook(MethodHook):
    def before_hooked_method(self, param):
        if not _JP_ARM_SEED:
            return
        try:
            if int(_NLIB.cd_scope_current()) < 0:
                prov = _provenance_pid(None, 1)
                if prov is not None:
                    _scoped_seed_arm(prov)
        except Exception:
            pass
    def after_hooked_method(self, param):
        return

def get_culprit_for_tid(tid):
    return _resolve_idx(_reg_get(tid))
def registry_info():
    return {
        "addr": _REG_ADDR,
        "slots": _REG_N,
        "slot_bytes": (ctypes.sizeof(_Slot) if (_REG_BUF is not None) else 0),
        "backend": ("native-shared" if _REG_BUF is not None else "none"),
        "layout": "struct{int64 tid; int32 pid_idx; int32 seq;}",
        "version": _REG_LAYOUT_VER,
    }

def _selftest_registry():
    info = registry_info()
    if _REG_BUF is None:
        _log(f"Block#2 реестр: shared-buffer N/A (ctypes={_CTYPES_OK}) — native-моста нет (+DT)")
        return
    try:
        test_tid = 0x7FABCD01
        test_idx = _intern("__regtest__")
        _i0 = test_tid & (_REG_N - 1)
        _REG_BUF[_i0].seq = _REG_BUF[_i0].seq + 1
        _REG_BUF[_i0].tid = test_tid
        _REG_BUF[_i0].pid_idx = test_idx
        _REG_BUF[_i0].seq = _REG_BUF[_i0].seq + 1
        ptr = ctypes.cast(_REG_ADDR, ctypes.POINTER(_Slot))
        i = test_tid & (_REG_N - 1); found = None
        for _ in range(_REG_N):
            if ptr[i].tid == test_tid:
                s1 = ptr[i].seq; idx = ptr[i].pid_idx; s2 = ptr[i].seq
                found = idx if (s1 == s2 and not (s1 & 1)) else None
                break
            if ptr[i].tid == 0: break
            i = (i + 1) & (_REG_N - 1)
        ok = (found == test_idx)
        _REG_BUF[_i0].seq = _REG_BUF[_i0].seq + 1
        _REG_BUF[_i0].pid_idx = -1
        _REG_BUF[_i0].seq = _REG_BUF[_i0].seq + 1
        _REG_BUF[_i0].tid = -1
        _log(f"Block#2 реестр self-test: {'PASS' if ok else 'FAIL'} "
             f"(addr=0x{_REG_ADDR:x}, slots={_REG_N}, slot={info['slot_bytes']}B, raw-read={found}/{test_idx})")
    except Exception as e:
        _log(f"Block#2 реестр self-test err: {e}")

def _app_context():
    try:
        c = jclass("org.telegram.messenger.ApplicationLoader")
        ctx = getattr(c, "applicationContext", None)
        return ctx
    except Exception:
        return None

def _b3_native_dir():
    base = None
    ctx = _app_context()
    if ctx is not None:
        try: base = ctx.getCodeCacheDir().getAbsolutePath()
        except Exception:
            try: base = ctx.getFilesDir().getAbsolutePath()
            except Exception: base = None
    if not base: base = _DIR
    d = File(base, "culprit_native")
    try:
        if not d.exists(): d.mkdirs()
    except Exception: pass
    return d.getAbsolutePath()

def _b3_extract_so():
    if not _SO_ARM64:
        return None
    try:
        import base64, zlib
        raw = zlib.decompress(base64.b64decode(_SO_ARM64))
        path = File(_b3_native_dir(), _SO_NAME).getAbsolutePath()
        jf = File(path)
        try:
            if jf.exists() and int(jf.length()) == len(raw):
                return path
        except Exception:
            pass
        try:
            if jf.exists():
                jf.setWritable(True, True); jf.delete()
        except Exception:
            pass
        try:
            with open(path, "wb") as f:
                f.write(raw)
        except OSError as we:
            if jf.exists():
                _log(f"Block#3 extract: повторно использую существующий .so (запись недоступна: {we})")
                return path
            raise
        try:
            jf2 = File(path)
            jf2.setReadable(True, False); jf2.setExecutable(True, False)
        except Exception: pass
        return path
    except Exception as e:
        _log(f"Block#3 extract err: {e}")
        return None

def _b3_decl(lib):
    c = ctypes
    lib.cd_init.argtypes = [c.c_uint64, c.c_int32, c.c_int32]; lib.cd_init.restype = c.c_int
    try:
        if hasattr(lib, "cd_abi_version"):
            lib.cd_abi_version.restype = c.c_int
        if hasattr(lib, "cd_build_rev"):
            lib.cd_build_rev.restype = c.c_int
    except Exception:
        pass
    lib.cd_gettid.restype = c.c_int
    lib.cd_start.restype = c.c_int
    lib.cd_stop.restype = c.c_int
    lib.cd_selftest.restype = c.c_int
    lib.cd_bytes_for.argtypes = [c.c_int32]; lib.cd_bytes_for.restype = c.c_int64
    lib.cd_total.restype = c.c_int64
    lib.cd_untagged.restype = c.c_int64
    lib.cd_dropped.restype = c.c_int64
    try:
        lib.cd_dropped_bytes.restype = c.c_int64
    except Exception:
        pass
    lib.cd_live_count.restype = c.c_int64
    lib.cd_snapshot.argtypes = [c.POINTER(c.c_int64), c.c_int32]; lib.cd_snapshot.restype = c.c_int
    lib.cd_top1.argtypes = [c.POINTER(c.c_int64)]; lib.cd_top1.restype = c.c_int32
    lib.cd_logcat_read_filtered.argtypes = [c.c_char_p, c.c_char_p, c.c_char_p, c.c_int32, c.c_char_p, c.c_int32]; lib.cd_logcat_read_filtered.restype = c.c_int32

    try:
        lib.cd_emit_snapshot.argtypes = [c.c_char_p, c.c_char_p, c.c_int32]; lib.cd_emit_snapshot.restype = c.c_int32
        lib.cd_emit_snapshot_fd.argtypes = [c.c_int32, c.c_int32]; lib.cd_emit_snapshot_fd.restype = c.c_int32
    except Exception:
        pass
    try:
        lib.cd_thread_inherit_ok.restype = c.c_int
    except Exception:
        pass
    try:
        lib.cd_reg_publish_tid.argtypes = [c.c_int64, c.c_int32]; lib.cd_reg_publish_tid.restype = c.c_int
        lib.cd_reg_clear_tid.argtypes = [c.c_int64]; lib.cd_reg_clear_tid.restype = c.c_int
        lib.cd_reg_lookup_tid.argtypes = [c.c_int64]; lib.cd_reg_lookup_tid.restype = c.c_int32
        lib.cd_reg_selftest.restype = c.c_int
        lib.cd_reg_live.restype = c.c_int64
    except Exception:
        pass
    global _OP_NATIVE_OK
    try:
        if hasattr(lib, "cd_op_mark"):
            lib.cd_op_mark.argtypes = [c.c_int32, c.c_char_p, c.c_char_p]; lib.cd_op_mark.restype = c.c_int
            if hasattr(lib, "cd_op_read"):
                lib.cd_op_read.argtypes = [c.c_int32, c.c_char_p, c.c_int32, c.c_char_p, c.c_int32]; lib.cd_op_read.restype = c.c_int64
            if hasattr(lib, "cd_op_mark_bitmap"):
                lib.cd_op_mark_bitmap.argtypes = [c.c_char_p, c.c_char_p]; lib.cd_op_mark_bitmap.restype = c.c_int
            _OP_NATIVE_OK = True
        else:
            _OP_NATIVE_OK = False
    except Exception:
        _OP_NATIVE_OK = False
    global _ANIM_NATIVE_OK
    try:
        lib.cd_anim_install.argtypes = [c.c_int32]; lib.cd_anim_install.restype = c.c_int
        lib.cd_anim_selftest.argtypes = [c.c_int32]; lib.cd_anim_selftest.restype = c.c_int
        lib.cd_anim_unhook.restype = c.c_int
        lib.cd_anim_running.restype = c.c_int
        lib.cd_anim_fires_total.restype = c.c_int64
        lib.cd_anim_owned_total.restype = c.c_int64
        lib.cd_anim_owner.argtypes = [c.POINTER(c.c_int64)]; lib.cd_anim_owner.restype = c.c_int32
        _ANIM_NATIVE_OK = True
    except Exception:
        _ANIM_NATIVE_OK = False
    global _MVEL_NATIVE_OK
    try:
        if hasattr(lib, "cd_mvel_install") and hasattr(lib, "cd_op_mark_idx"):
            lib.cd_op_mark_idx.argtypes = [c.c_int32, c.c_int32]; lib.cd_op_mark_idx.restype = c.c_int
            lib.cd_mvel_install.argtypes = [c.c_int32]; lib.cd_mvel_install.restype = c.c_int
            lib.cd_mvel_selftest.argtypes = [c.c_int32]; lib.cd_mvel_selftest.restype = c.c_int
            lib.cd_mvel_unhook.restype = c.c_int
            lib.cd_mvel_running.restype = c.c_int
            lib.cd_mvel_fires_total.restype = c.c_int64
            lib.cd_mvel_owned_total.restype = c.c_int64
            lib.cd_mvel_owner.argtypes = [c.POINTER(c.c_int64)]; lib.cd_mvel_owner.restype = c.c_int32
            _MVEL_NATIVE_OK = True
        else:
            _MVEL_NATIVE_OK = False
    except Exception:
        _MVEL_NATIVE_OK = False
    for _dom in ("gpu", "binder", "camera", "mediacodec", "gl"):
        _okname = "_%s_NATIVE_OK" % _dom.upper()
        try:
            _inst = getattr(lib, "cd_%s_install" % _dom, None)
            _self = getattr(lib, "cd_%s_selftest" % _dom, None)
            if _inst is not None and _self is not None:
                _inst.argtypes = [c.c_int32]; _inst.restype = c.c_int
                _self.argtypes = [c.c_int32]; _self.restype = c.c_int
                _unh = getattr(lib, "cd_%s_unhook" % _dom, None)
                if _unh is not None: _unh.restype = c.c_int
                _run = getattr(lib, "cd_%s_running" % _dom, None)
                if _run is not None: _run.restype = c.c_int
                _ft = getattr(lib, "cd_%s_fires_total" % _dom, None)
                if _ft is not None: _ft.restype = c.c_int64
                _ot = getattr(lib, "cd_%s_owned_total" % _dom, None)
                if _ot is not None: _ot.restype = c.c_int64
                _own = getattr(lib, "cd_%s_owner" % _dom, None)
                if _own is not None:
                    _own.argtypes = [c.POINTER(c.c_int64)]; _own.restype = c.c_int32
                globals()[_okname] = True
            else:
                globals()[_okname] = False
        except Exception:
            globals()[_okname] = False
    global _LOOPER_NATIVE_OK
    try:
        if hasattr(lib, "cd_looper_install") and hasattr(lib, "cd_op_mark"):
            lib.cd_looper_install.argtypes = [c.c_int32]; lib.cd_looper_install.restype = c.c_int
            lib.cd_looper_selftest.argtypes = [c.c_int32]; lib.cd_looper_selftest.restype = c.c_int
            lib.cd_looper_unhook.restype = c.c_int
            lib.cd_looper_running.restype = c.c_int
            _LOOPER_NATIVE_OK = True
        else:
            _LOOPER_NATIVE_OK = False
    except Exception:
        _LOOPER_NATIVE_OK = False
    global _HANDLER_NATIVE_OK
    try:
        if hasattr(lib, "cd_handler_install") and hasattr(lib, "cd_op_mark"):
            lib.cd_handler_install.argtypes = [c.c_int32]; lib.cd_handler_install.restype = c.c_int
            lib.cd_handler_selftest.argtypes = [c.c_int32]; lib.cd_handler_selftest.restype = c.c_int
            lib.cd_handler_unhook.restype = c.c_int
