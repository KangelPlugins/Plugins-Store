                    hooked += 1
                except Exception: pass
            _log("Block#28C: dynamic_proxy creation tracer hooks: %d (sample=1/%d)" % (hooked, _B28C_SAMPLE))
        except Exception as e:
            _log("Block#28C install err: %s" % e)

