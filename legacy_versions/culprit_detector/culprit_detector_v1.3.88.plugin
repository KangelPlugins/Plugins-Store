            lib.cd_na_enable.argtypes = [c.c_int, c.c_int64]; lib.cd_na_enable.restype = c.c_int
            lib.cd_na_dump.argtypes = [c.c_char_p]; lib.cd_na_dump.restype = c.c_int64
            for _nm in ("cd_na_unique", "cd_na_sampled_count", "cd_na_full_drops", "cd_na_min_bytes"):
                if hasattr(lib, _nm): getattr(lib, _nm).restype = c.c_int64
            if hasattr(lib, "cd_na_is_on"): lib.cd_na_is_on.restype = c.c_int
            if hasattr(lib, "cd_na_set_sample_div"):
                lib.cd_na_set_sample_div.argtypes = [c.c_int]; lib.cd_na_set_sample_div.restype = None
            if hasattr(lib, "cd_na_sample_div"): lib.cd_na_sample_div.restype = c.c_int
            _NA_NATIVE_OK = True
        else:
            _NA_NATIVE_OK = False
    except Exception:
        _NA_NATIVE_OK = False

    global _SELF_NATIVE_OK
    try:
        if hasattr(lib, "cd_self_snapshot"):
            lib.cd_self_snapshot.argtypes = [c.POINTER(c.c_int64), c.c_int32]; lib.cd_self_snapshot.restype = c.c_int32
            if hasattr(lib, "cd_self_reset"): lib.cd_self_reset.restype = None
            if hasattr(lib, "cd_self_set_ui_tid"):
                lib.cd_self_set_ui_tid.argtypes = [c.c_int64]; lib.cd_self_set_ui_tid.restype = None
            if hasattr(lib, "cd_self_ui_stall"):
                lib.cd_self_ui_stall.argtypes = [c.POINTER(c.c_int64), c.c_int32]; lib.cd_self_ui_stall.restype = c.c_int32
                if hasattr(lib, "cd_self_ui_stall_reset"): lib.cd_self_ui_stall_reset.restype = None
            _SELF_NATIVE_OK = True
        else:
            _SELF_NATIVE_OK = False
    except Exception:
        _SELF_NATIVE_OK = False

    # +DR: native CPU sampler (Lever 1) + GIL-hold attributor (additive; ABI stays 3)
    global _CPU_NATIVE_OK, _GIL_NATIVE_OK
    try:
        if hasattr(lib, "cd_cpu_start"):
            lib.cd_cpu_start.argtypes = [c.c_int32, c.c_int32, c.c_int32]; lib.cd_cpu_start.restype = c.c_int
            lib.cd_cpu_stop.restype = c.c_int
            lib.cd_cpu_running.restype = c.c_int
            lib.cd_cpu_seq.restype = c.c_int64
            lib.cd_cpu_count.restype = c.c_int32
            lib.cd_cpu_win_ms.restype = c.c_int64
            lib.cd_cpu_ts_ms.restype = c.c_int64
            lib.cd_cpu_rows_addr.restype = c.c_uint64
            lib.cd_cpu_row_size.restype = c.c_int32
            lib.cd_cpu_max.restype = c.c_int32
            lib.cd_cpu_sample_now.argtypes = [c.c_int32]; lib.cd_cpu_sample_now.restype = c.c_int32
            if hasattr(lib, "cd_cpu_set_period"):
                lib.cd_cpu_set_period.argtypes = [c.c_int32]; lib.cd_cpu_set_period.restype = None
            _CPU_NATIVE_OK = True
        else:
            _CPU_NATIVE_OK = False
    except Exception:
        _CPU_NATIVE_OK = False
    try:
        if hasattr(lib, "cd_gil_hold"):
            lib.cd_gil_mark_begin.argtypes = [c.c_int32]; lib.cd_gil_mark_begin.restype = None
            lib.cd_gil_mark_end.argtypes = [c.c_int32]; lib.cd_gil_mark_end.restype = None
            lib.cd_gil_hold.argtypes = [c.POINTER(c.c_int64), c.c_int32]; lib.cd_gil_hold.restype = c.c_int
            lib.cd_gil_slots.restype = c.c_int
            lib.cd_gil_reset.restype = None
            _GIL_NATIVE_OK = True
        else:
            _GIL_NATIVE_OK = False
    except Exception:
        _GIL_NATIVE_OK = False

    global _WD_NATIVE_OK
    try:
        if hasattr(lib, "cd_wd_read"):
            lib.cd_wd_start.argtypes = [c.c_char_p, c.c_char_p, c.c_char_p, c.c_int32]; lib.cd_wd_start.restype = c.c_int
            lib.cd_wd_stop.restype = c.c_int
            lib.cd_wd_running.restype = c.c_int
            lib.cd_wd_read.argtypes = [c.POINTER(c.c_int64), c.c_int32]; lib.cd_wd_read.restype = c.c_int
            if hasattr(lib, "cd_wd_set_period"):
                lib.cd_wd_set_period.argtypes = [c.c_int32]; lib.cd_wd_set_period.restype = None
            if hasattr(lib, "cd_wd_polls"):
                lib.cd_wd_polls.restype = c.c_int64
            _WD_NATIVE_OK = True
        else:
            _WD_NATIVE_OK = False
    except Exception:
        _WD_NATIVE_OK = False

    global _SMAPS_NATIVE_OK
    try:
        if hasattr(lib, "cd_smaps_groups"):
            lib.cd_smaps_groups.argtypes = [c.POINTER(c.c_int64), c.c_int32]; lib.cd_smaps_groups.restype = c.c_int
            lib.cd_smaps_rollup.argtypes = [c.POINTER(c.c_int64), c.c_int32]; lib.cd_smaps_rollup.restype = c.c_int
            lib.cd_smaps_selftest.restype = c.c_int
            _SMAPS_NATIVE_OK = True
            try: _log("Block#6D +DU(smaps-native): selftest groups=%d" % int(lib.cd_smaps_selftest()))
            except Exception: pass
        else:
            _SMAPS_NATIVE_OK = False
    except Exception:
        _SMAPS_NATIVE_OK = False

def _b4c_decl(lib):
    c = ctypes
    lib.cd_lt_init.argtypes = [c.c_int32]; lib.cd_lt_init.restype = c.c_int
    lib.cd_register_loader.argtypes = [c.c_int64, c.c_int32]; lib.cd_register_loader.restype = c.c_int
    lib.cd_loader_pid.argtypes = [c.c_int64]; lib.cd_loader_pid.restype = c.c_int32
    lib.cd_lt_count.restype = c.c_int32
    lib.cd_lt_clear.restype = None
    lib.cd_set_active_plugin.argtypes = [c.c_int32]; lib.cd_set_active_plugin.restype = None
    lib.cd_clear_active_plugin.restype = None
    lib.cd_active_plugin.restype = c.c_int32
    try: lib.cd_reset_active_plugin.restype = None
    except Exception: pass
    lib.cd_install_crash_handler.argtypes = [c.c_char_p]; lib.cd_install_crash_handler.restype = c.c_int
    lib.cd_uninstall_crash_handler.restype = None
    if hasattr(lib, "cd_set_host_lib_dir"):
        lib.cd_set_host_lib_dir.argtypes = [c.c_char_p]; lib.cd_set_host_lib_dir.restype = c.c_int
    if hasattr(lib, "cd_maps_refresh"):
        lib.cd_maps_refresh.restype = c.c_int
    if hasattr(lib, "cd_maps_count"):
        lib.cd_maps_count.restype = c.c_int
    if hasattr(lib, "cd_tomb_count"):
        lib.cd_tomb_count.restype = c.c_int64
    if hasattr(lib, "cd_compactions"):
        lib.cd_compactions.restype = c.c_int64
    if hasattr(lib, "cd_compact"):
        lib.cd_compact.restype = c.c_int64

