    def _install_looper_barrier_hook(self):
        global _LOOPER_HOOK_INSTALLED, _LOOPER_NATIVE_ACTIVE
        try:
            self._looper_unhooks = getattr(self, "_looper_unhooks", [])
            if (_LOOPER_NATIVE_ON and _LOOPER_NATIVE_OK and _NLIB is not None and _CTYPES_OK
                    and hasattr(_NLIB, "cd_looper_install")):
                _loff = int(_LOOPER_ENTRY_OFFSET or 0)
                _lok = 0
                try: _lok = int(_NLIB.cd_looper_selftest(_loff))
                except Exception: _lok = 0
                if _lok > 0:
                    _linst = 0
                    try: _linst = int(_NLIB.cd_looper_install(_loff))
                    except Exception: _linst = 0
                    if _linst > 0:
                        _LOOPER_NATIVE_ACTIVE = True
