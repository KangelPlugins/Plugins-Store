def _b18_is_cancel(exc):
    try:
        import asyncio as _aio
        ce = getattr(_aio, "CancelledError", None)
        if ce is not None and isinstance(exc, ce): return True
    except Exception: pass
    try:
        import concurrent.futures as _cf
        ce2 = getattr(_cf, "CancelledError", None)
        if ce2 is not None and isinstance(exc, ce2): return True
    except Exception: pass
    try:
        return isinstance(exc, (GeneratorExit, KeyboardInterrupt, SystemExit))
    except Exception:
        return False

def _b18_record(loop, context):
    if not _BLOCK18_ON: return
    exc = None
    try:
        if isinstance(context, dict): exc = context.get("exception")
    except Exception: exc = None
    if exc is None: return
    if _b18_is_cancel(exc): return
    try: exc_cls = type(exc).__name__
    except Exception: exc_cls = "?"
    try: exc_msg = str(exc)
    except Exception: exc_msg = None
    reason = ("%s: %s" % (exc_cls, exc_msg)) if exc_msg else exc_cls
    py_mod = None; py_file = None; py_line = None
    try:
        py_mod, py_file, py_line = _b10_pyframe_culprit(exc, None)
    except Exception:
        py_mod = None
    if not py_mod: return
    culprit = py_mod; src = "py-frame/asyncio"; conf = "high"
    if culprit == _SELF_ID or culprit == __id__: return
    aio_msg = None
    try:
        if isinstance(context, dict): aio_msg = context.get("message")
    except Exception: aio_msg = None
    now = int(time.time() * 1000)
    key = "%s|%s|asyncio" % (culprit, reason)
    try:
        with _ASYNC_SEEN_LOCK:
            if now - _ASYNC_SEEN.get(key, 0) < _ASYNC_DEDUP_MS: return
            _ASYNC_SEEN[key] = now
    except Exception: pass
    rec = {"had_async_fail": True, "event_type": "async_exception", "dropbox_tag": "data_app_crash", "tombstone_norm_version": 1, "culprit": culprit, "src": src, "confidence": conf,
           "where": "asyncio", "py_module": py_mod, "py_file": py_file, "py_line": py_line,
           "aio_message": aio_msg, "reason": reason, "exc_cls": exc_cls, "exc_msg": exc_msg, "ts": now}
    try: _b16_push_verdict("async", rec)
    except Exception: pass
    try: _async_verdict_log(rec, "live")
    except Exception: pass
    try: _persist_async_fail(rec)
    except Exception: pass

def _b18_make_ceh_patch(orig):
    @_functools.wraps(orig)
    def _patched(self, context):
        try: _b18_record(self, context)
        except Exception: pass
        return orig(self, context)
    try: setattr(_patched, _B18_FLAG, True)
    except Exception: pass
    return _patched

def _b18_install():
    global _B18_INSTALLED
    if not _BLOCK18_ON:
        _log("Block#18: отключён (_BLOCK18_ON=False)"); return
    n = 0
    try:
        import asyncio as _aio
        be = getattr(_aio, "base_events", None)
        BEL = getattr(be, "BaseEventLoop", None) if be is not None else None
        if BEL is not None:
            orig = BEL.__dict__.get("call_exception_handler")
            if orig is not None and not getattr(orig, _B18_FLAG, False):
                patched = _b18_make_ceh_patch(orig)
                BEL.call_exception_handler = patched
                with _B18_LOCK:
                    _B18_PATCHED.append((BEL, "call_exception_handler", orig, patched))
                n += 1
    except Exception as e:
        _log("Block#18: call_exception_handler patch err: %s" % e)
    _B18_INSTALLED = n > 0
    _log("Block#18: установлен (asyncio call_exception_handler wrap): %d/1 -> %s" % (n, _ASYNC_FILE_NAME))

def _b18_uninstall():
    global _B18_INSTALLED
    try:
        with _B18_LOCK:
            items = list(_B18_PATCHED); del _B18_PATCHED[:]
        for tup in items:
            try:
                cls, nm, orig = tup[0], tup[1], tup[2]
                our_w = tup[3] if len(tup) > 3 else None
                cur = getattr(cls, nm, None)
                if cur is not None and (cur is our_w if our_w is not None else getattr(cur, _B18_FLAG, False)):
                    setattr(cls, nm, orig)
            except Exception: pass
    except Exception: pass
    _B18_INSTALLED = False

_PYERR_FILE_NAME = "pyerr_verdict.json"
