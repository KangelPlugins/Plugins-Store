            c = get_culprit_for_tid(tid)
            if c and c != "unknown": active_pid = c
        except Exception: pass
        pyframes = _pm_python_stack(48)
        pid_py = _pm_scan_py(pyframes)
        if pid_py:
            pid = pid_py; src = "self-kill/pystack"
            if active_pid and active_pid != pid_py:
                _log("PRE-MORTEM: live py-стек=%r переопределяет активного scope-owner=%r (устаревший тег)" % (pid_py, active_pid))
        elif active_pid:
            pid = active_pid; src = "self-kill/active"
        crumb_pid = None; crumb_fresh = False; crumb_age = None
        try:
            raw = _CRUMB.read_prev() if _CRUMB is not None else None
            if raw:
                parts = raw.split("\t")
                crumb_pid = parts[0] if parts else None
                if len(parts) >= 3:
                    crumb_age = int(time.time()*1000) - int(parts[2])
                    crumb_fresh = (0 <= crumb_age <= _CRUMB_FRESH_MS)
        except Exception: pass
        if pid is None and crumb_fresh and crumb_pid: pid = crumb_pid; src = "self-kill/breadcrumb"
        if pid is None:
            jpid = _pm_scan_stack(jstack)
            if jpid: pid = jpid; src = "self-kill/jstack"
        if pid is None: pid = "unknown"
        conf = "high" if src in ("self-kill/active", "self-kill/pystack") else ("medium" if pid != "unknown" else "none")
        benign_restart = _pm_is_intentional_restart(method_tag, jstack, argval, pid)
        if benign_restart:
            src = "self-kill/intentional-restart"; conf = "none"
            try:
                if _NLIB is not None and hasattr(_NLIB, "cd_kg_permit_restart"):
                    _NLIB.cd_kg_permit_restart()
                    _log("PRE-MORTEM: намеренный рестарт (кнопка) -> kill-guard пропускает exit, не виновник")
                else:
                    _log("PRE-MORTEM: намеренный рестарт (кнопка) -> benign (permit недоступен: старый .so)")
            except Exception as _pe:
                _log("PRE-MORTEM permit err: %s" % _pe)
        rec = {
            "had_crash": True, "crashed_plugin_id": pid, "src": src, "confidence": conf,
            "exc_cls": "ProcessTermination", "exc_msg": "%s(%s)" % (method_tag, argval),
            "thread": _pm_thread_name(), "via_hook": False, "hooked_method": method_tag,
            "self_kill": True, "benign_restart": benign_restart, "kill_method": method_tag, "kill_arg": argval,
            "pid_stack": active_pid,
            "pid_crumb": crumb_pid, "crumb_fresh": crumb_fresh, "crumb_age_ms": crumb_age,
            "py_stack": pyframes[:40], "pid_py": pid_py,
            "stack_top": jstack[:40], "ts": int(time.time()*1000),
        }
        rec = _b16_correlate(rec)
        _write_crash_verdict(rec)
        _log("PRE-MORTEM %s(%s): виновник=%r src=%s conf=%s" % (method_tag, argval, pid, src, conf))
    except Exception as _se:
        try: _log("pre-mortem record err: %s" % _se)
        except Exception: pass
    finally:
        try: _SUICIDE_TL.busy = False
        except Exception: pass
