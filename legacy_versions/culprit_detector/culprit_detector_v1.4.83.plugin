def _b6_register_lowmem_native():
    try:
        if _LOWMEM_NATIVE_OK and _NLIB is not None and hasattr(_NLIB, "cd_lowmem_install"):
            m = int(_NLIB.cd_lowmem_install(0))
            if m > 0:
                _OOM_CLIENT_KILL_STATE["lowmem_native"] = True
                _log("Block#6CL: onLowMemory -> нативный off-GIL interceptor=%d (handleLowMemory, GIL-free, без Python-bounce на UI)" % m)
                return
            _lowmem_native_unavailable_marker("cd_lowmem_install=%d" % m)
            _log("Block#6CL: нативный lowmem interceptor n=%d -> onLowMemory no-op (handleLowMemory не JIT-скомпилирован; маркер в вердикт)" % m)
            return
    except Exception as _eln:
        try:
            _lowmem_native_unavailable_marker("cd_lowmem_install err: %s" % _eln)
            _log("Block#6CL native lowmem install err: %s -> onLowMemory no-op (маркер в вердикт)" % _eln)
        except Exception: pass
        return
    _lowmem_native_unavailable_marker("native lowmem unsupported (_LOWMEM_NATIVE_OK=%s)" % _LOWMEM_NATIVE_OK)
    _log("Block#6CL: нативный lowmem недоступен (_LOWMEM_NATIVE_OK=%s) -> onLowMemory no-op (маркер в вердикт)" % _LOWMEM_NATIVE_OK)

def _b6_register_trim_callbacks():
    try:
        if _TRIM_NATIVE_OK and _NLIB is not None and hasattr(_NLIB, "cd_trim_install"):
            n = int(_NLIB.cd_trim_install(0))
            if n > 0:
                _OOM_CLIENT_KILL_STATE["trim_native"] = True
                _log("Block#6C: onTrimMemory -> нативный off-GIL interceptor=%d (handleTrimMemory, GIL-free, без Python-bounce на UI)" % n)
            else:
                _trim_native_unavailable_marker("cd_trim_install=%d" % n)
                _log("Block#6C: нативный trim interceptor n=%d -> onTrimMemory no-op (Python-фолбэк удалён; маркер в вердикт)" % n)
        else:
            _trim_native_unavailable_marker("native trim unsupported (_TRIM_NATIVE_OK=%s)" % _TRIM_NATIVE_OK)
            _log("Block#6C: нативный trim недоступен (_TRIM_NATIVE_OK=%s) -> onTrimMemory no-op (Python-фолбэк удалён; маркер в вердикт)" % _TRIM_NATIVE_OK)
    except Exception as _etn:
        try:
            _trim_native_unavailable_marker("cd_trim_install err: %s" % _etn)
            _log("Block#6C native trim install err: %s -> onTrimMemory no-op (Python-фолбэк удалён; маркер в вердикт)" % _etn)
        except Exception: pass
    try:
        _b6_register_lowmem_native()
    except Exception as _elr:
        try: _log("Block#6CL lowmem register err: %s" % _elr)
        except Exception: pass
    return None

def _b6_unregister_trim_callbacks():
    try:
        if _OOM_CLIENT_KILL_STATE.get("trim_native"):
            try:
                if _NLIB is not None and hasattr(_NLIB, "cd_trim_unhook"):
                    _NLIB.cd_trim_unhook()
            except Exception: pass
            _OOM_CLIENT_KILL_STATE["trim_native"] = False
            _log("Block#6C: нативный onTrimMemory interceptor снят")
    except Exception as e:
        try: _log("Block#6C trim unregister err: %s" % e)
        except Exception: pass
    try:
        if _OOM_CLIENT_KILL_STATE.get("lowmem_native"):
            try:
                if _NLIB is not None and hasattr(_NLIB, "cd_lowmem_unhook"):
                    _NLIB.cd_lowmem_unhook()
            except Exception: pass
            _OOM_CLIENT_KILL_STATE["lowmem_native"] = False
            _log("Block#6CL: нативный onLowMemory interceptor снят")
    except Exception as e2:
        try: _log("Block#6CL lowmem unregister err: %s" % e2)
        except Exception: pass

_LEAK_NAME = "client_leak.json"
_NA_NAME = "native_alloc_sites.json"
_NA_SAMPLE_ENABLE = True
_NA_SAMPLE_DIV = 1
_NA_MIN_BYTES = 8192
_NA_NATIVE_OK = False
_LEAK_NATIVE_OK = False
_LEAK_DIM_KEYS = ("rss", "java", "native", "fd", "threads")
_LEAK_DIM_NAMES = {"rss": "RSS", "java": "Java-heap", "native": "native-heap",
                   "fd": "descriptors (fd)", "threads": "threads"}
_LEAK_BYTE_DIMS = ("rss", "java", "native")
_LEAK_SNAP_HEAD = 3
_LEAK_SNAP_PER = 7
_LEAK_STATE = {"last_seq": 0}
_LEAK_SEG_KEYS = ("summary.java-heap", "summary.native-heap", "summary.graphics",
                  "summary.stack", "summary.code", "summary.system",
                  "summary.total-pss", "summary.total-swap")
_LEAK_SEG_LABELS = {"summary.java-heap": "java-heap", "summary.native-heap": "native-heap",
                    "summary.graphics": "graphics", "summary.stack": "stack",
                    "summary.code": "code", "summary.system": "system",
                    "summary.total-pss": "total-pss", "summary.total-swap": "total-swap"}
_LEAK_SEG_TOP_SKIP = ("total-pss", "total-swap")
_LEAK_SEG_RING = []
_LEAK_SEG_MIN_GAP_MS = 25000
_LEAK_SEG_RING_MAX = 160

def _leak_seg_read(g=None, roll=None):
    try:
        if g is None:
            g = _smaps_scan_native()
        if not g:
            return None
        def _p(name):
            v = g.get(name)
            return int(v["pss"]) if v else 0
        java_heap = _p("dalvik-heap")
        native_heap = _p("native-malloc")
        graphics = _p("gfx-gpu") + _p("gfx-dmabuf")
        stack = _p("thread-stack")
        code = _p("code-so") + _p("code-dex-oat-art") + _p("code-apk")
        if roll is None:
            roll = _smaps_rollup_native()
        total_pss = int(roll["pss"]) if roll else sum(int(v["pss"]) for v in g.values())
        total_swap = int(roll["swap"]) if roll else sum(int(v["swap"]) for v in g.values())
        system = total_pss - (java_heap + native_heap + graphics + stack + code)
        if system < 0: system = 0
        return {"summary.java-heap": java_heap, "summary.native-heap": native_heap,
                "summary.graphics": graphics, "summary.stack": stack,
                "summary.code": code, "summary.system": system,
                "summary.total-pss": total_pss, "summary.total-swap": total_swap}
    except Exception:
        return None

def _leak_seg_sample():
    try:
        now = int(time.time() * 1000)
        if _LEAK_SEG_RING and (now - _LEAK_SEG_RING[-1][0]) < _LEAK_SEG_MIN_GAP_MS:
            return
        segs = _leak_seg_read()
        if not segs:
            return
        _LEAK_SEG_RING.append((now, segs))
        if len(_LEAK_SEG_RING) > _LEAK_SEG_RING_MAX:
            del _LEAK_SEG_RING[:len(_LEAK_SEG_RING) - _LEAK_SEG_RING_MAX]
    except Exception:
        pass

def _leak_seg_delta(span_s):
    try:
        if len(_LEAK_SEG_RING) < 2:
            return None
        now, cur = _LEAK_SEG_RING[-1][0], _LEAK_SEG_RING[-1][1]
        target = now - int(float(span_s or 0) * 1000)
        base_t, base = _LEAK_SEG_RING[0][0], _LEAK_SEG_RING[0][1]
        for t, segs in _LEAK_SEG_RING:
            if t <= target:
                base_t, base = t, segs
            else:
                break
        out = {"baseline_age_ms": now - base_t, "n_samples": len(_LEAK_SEG_RING),
               "span_s": (now - base_t) / 1000.0, "segments": {}}
        best_name, best_growth = None, None
        for k in _LEAK_SEG_KEYS:
            f, l = base.get(k), cur.get(k)
            if f is None or l is None:
                continue
            lbl = _LEAK_SEG_LABELS.get(k, k)
            g = l - f
            out["segments"][lbl] = {"first": f, "last": l, "growth": g}
            if lbl not in _LEAK_SEG_TOP_SKIP and (best_growth is None or g > best_growth):
                best_name, best_growth = lbl, g
        if best_name is not None:
            out["top"] = {"segment": best_name, "growth": best_growth}
        return out if out["segments"] else None
    except Exception:
        return None

def _leak_feed_java():
    try:
        if not (_LEAK_NATIVE_OK and _NLIB is not None):
            return
        ju, jm, _nh = _java_mem()
        if ju is None:
            return
        _NLIB.cd_leak_feed_java(ctypes.c_int64(int(ju)),
                                ctypes.c_int64(int(jm) if jm else -1))
    except Exception:
        pass

def _leak_read_native_snap():
    try:
        if not (_LEAK_NATIVE_OK and _NLIB is not None):
            return None
        n = int(_NLIB.cd_leak_slots())
        if n <= 0 or n > 4096:
            return None
        arr = (ctypes.c_int64 * n)()
        got = int(_NLIB.cd_leak_read(arr, ctypes.c_int32(n)))
        if got < _LEAK_SNAP_HEAD:
            return None
        vals = [int(arr[i]) for i in range(got)]
        ts_ms, flags, dimn = vals[0], vals[1], vals[2]
        dims = []
        for d in range(dimn):
            base = _LEAK_SNAP_HEAD + d * _LEAK_SNAP_PER
            if base + _LEAK_SNAP_PER > got:
                break
            key = _LEAK_DIM_KEYS[d] if d < len(_LEAK_DIM_KEYS) else ("dim%d" % d)
            dims.append({"dim": key, "leaking": bool(flags & (1 << d)),
                         "first": vals[base + 0], "last": vals[base + 1],
                         "slope_per_s": vals[base + 2] / 1000.0,
                         "r2": vals[base + 3] / 1000.0,
                         "growth": vals[base + 4], "n": vals[base + 5],
                         "span_s": vals[base + 6] / 1000.0})
        return {"ts_ms": ts_ms, "flags": flags, "dims": dims}
    except Exception as e:
        try: _log("Block#6D snap read err: %s" % e)
        except Exception: pass
        return None

def _leak_fmt_amount(dim, v):
    try:
        if dim in _LEAK_BYTE_DIMS:
            return "%.1f MB" % (float(v) / (1024.0 * 1024.0))
        return str(int(v))
    except Exception:
        return str(v)

def _leak_mem_snapshot():
    snap = {}
    try:
        g = _smaps_scan_native()
        if g:
            def _p(name):
                v = g.get(name)
                return int(v["pss"]) if v else 0
            roll = _smaps_rollup_native()
            dalvik = _p("dalvik-heap")
            native = _p("native-malloc")
            total = int(roll["pss"]) if roll else sum(int(v["pss"]) for v in g.values())
            other = total - dalvik - native
            if other < 0: other = 0
            snap["pss"] = {"dalvik": dalvik, "native": native, "other": other, "total": total}
            seg = _leak_seg_read(g, roll)
            if seg: snap["memstat"] = seg
    except Exception: pass
    try:
        kinds = {}
        base = "/proc/self/fd"
        for name in os.listdir(base):
            try: tgt = os.readlink(os.path.join(base, name))
            except Exception: tgt = ""
            if tgt.startswith("socket:"): kk = "socket"
            elif tgt.startswith("pipe:"): kk = "pipe"
            elif tgt.startswith("anon_inode:"): kk = "anon_inode"
            elif tgt.startswith("/"): kk = "file"
            else: kk = "other"
            kinds[kk] = kinds.get(kk, 0) + 1
        if kinds: snap["fd_by_kind"] = kinds
    except Exception: pass
    return snap

_LEAK_PEAK_NAME = "client_leak_peak.json"
_LEAK_PEAK_MIN_GAP_MS = 60000
_LEAK_PEAK_STATE = {"last_ms": 0}
_SMAPS_NATIVE_GROUPS = ("native-malloc", "gfx-gpu", "gfx-dmabuf", "shmem-ashmem",
                        "code-so", "code-dex-oat-art", "code-apk", "fonts",
                        "dalvik-heap", "thread-stack", "file-other", "anon-other",
                        "anon-private")
_SMAPS_NATIVE_FIELDS = 4

def _smaps_scan_native():
    try:
        if not (_SMAPS_NATIVE_OK and _NLIB is not None):
            return None
        n = len(_SMAPS_NATIVE_GROUPS) * _SMAPS_NATIVE_FIELDS
        arr = (ctypes.c_int64 * n)()
        got = int(_NLIB.cd_smaps_groups(arr, ctypes.c_int32(n)))
        if got < n:
            return None
        out = {}
        for i, name in enumerate(_SMAPS_NATIVE_GROUPS):
            b = i * _SMAPS_NATIVE_FIELDS
            out[name] = {"rss": int(arr[b + 0]), "pss": int(arr[b + 1]),
                         "swap": int(arr[b + 2]), "n": int(arr[b + 3])}
        return out
    except Exception:
        return None

def _smaps_rollup_native():
    try:
        if not (_SMAPS_NATIVE_OK and _NLIB is not None):
            return None
        arr = (ctypes.c_int64 * 3)()
        got = int(_NLIB.cd_smaps_rollup(arr, ctypes.c_int32(3)))
        if got < 3:
            return None
        return {"pss": int(arr[0]), "rss": int(arr[1]), "swap": int(arr[2])}
    except Exception:
        return None

def _smaps_top_groups(limit=14):
    g = _smaps_scan_native()
    if not g:
        return None
    items = [(k, v) for k, v in g.items() if (v["rss"] or v["pss"] or v["swap"] or v["n"])]
    if not items:
        return None
    items.sort(key=lambda kv: kv[1].get("pss", 0), reverse=True)
    return [{"group": k, "rss": v["rss"], "pss": v["pss"], "swap": v["swap"], "maps": v["n"]}
            for k, v in items[:limit]]

def _smaps_rollup_text():
    try:
        with open("/proc/self/smaps_rollup", "r") as f:
            return f.read()[:4096]
    except Exception:
        return None

def _leak_fd_detail():
    out = {"by_kind": {}, "by_target": {}}
    try:
        base = "/proc/self/fd"
        for name in os.listdir(base):
            try: tgt = os.readlink(os.path.join(base, name))
            except Exception: tgt = ""
            if tgt.startswith("socket:"): kk = "socket"
            elif tgt.startswith("pipe:"): kk = "pipe"
            elif tgt.startswith("anon_inode:"): kk = "anon_inode"
            elif tgt.startswith("/"): kk = "file"
            else: kk = "other"
            out["by_kind"][kk] = out["by_kind"].get(kk, 0) + 1
            if tgt.startswith("anon_inode:"):
                tb = "anon_inode:" + tgt[11:].strip("[]").split(":")[0][:24]
            elif tgt.startswith("/dev/"):
                tb = "/dev/" + tgt[5:].split("/")[0]
            elif tgt.startswith("/"):
                dot = tgt.rfind(".")
                tb = ("ext:" + tgt[dot:][:8]) if dot > tgt.rfind("/") else "file-other"
            elif tgt.startswith("socket:") or tgt.startswith("pipe:"):
                tb = kk
            else:
                tb = "other"
            out["by_target"][tb] = out["by_target"].get(tb, 0) + 1
    except Exception:
        pass
    try:
        tt = sorted(out["by_target"].items(), key=lambda kv: kv[1], reverse=True)[:15]
        out["by_target"] = dict(tt)
    except Exception:
        pass
    return out

def _dumpsys_meminfo_text():
    proc = None; rdr = None
    try:
        pid = os.getpid()
        Runtime = jclass("java.lang.Runtime")
        proc = Runtime.getRuntime().exec(["sh", "-c", "dumpsys meminfo %d 2>&1" % pid])
        ins = proc.getInputStream()
        rdr = jclass("java.io.BufferedReader")(jclass("java.io.InputStreamReader")(ins))
        sb = []; n = 0
        while n < 400:
            ln = rdr.readLine()
            if ln is None: break
            sb.append(str(ln)); n += 1
        txt = "\n".join(sb)
        return txt[:8192] if txt.strip() else None
    except Exception:
        return None
    finally:
        if rdr is not None:
            try: rdr.close()
            except Exception: pass
        if proc is not None:
            try: proc.getOutputStream().close()
            except Exception: pass
            try: proc.getErrorStream().close()
            except Exception: pass
            try: proc.destroy()
            except Exception: pass

def _leak_peak_capture(where, rec):
    try:
        now = int(time.time() * 1000)
        if (now - _LEAK_PEAK_STATE.get("last_ms", 0)) < _LEAK_PEAK_MIN_GAP_MS:
            return
        _LEAK_PEAK_STATE["last_ms"] = now
        cap = {"type": "client_leak_peak", "ts": now, "where": where,
               "leaking_dims": rec.get("leaking_dims"),
               "confidence": rec.get("confidence"),
               "rss_top_segment": rec.get("rss_top_segment"),
               "meminfo": _leak_mem_snapshot(),
               "smaps_rollup": _smaps_rollup_text(),
               "smaps_top_groups": _smaps_top_groups(),
               "fd_detail": _leak_fd_detail(),
               "dumpsys_meminfo": _dumpsys_meminfo_text()}
        p = _oom_path(_LEAK_PEAK_NAME)
        if p: _atomic_json_write(p, cap)
        try:
            tg = cap.get("smaps_top_groups") or []
            top = ", ".join("%s=%.1fMB" % (g["group"], g["pss"] / 1048576.0) for g in tg[:5])
            _log("Block#6D peak-capture -> %s | top smaps: %s" % (_LEAK_PEAK_NAME, top))
        except Exception:
            pass
    except Exception as e:
        try: _log("Block#6D peak-capture err: %s" % e)
        except Exception: pass

_NA_CLIENT_LIBS = ("libtmessages", "libetgadblock", "libculprit", "libvosk", "libmaps-mobile", "libimage_processing_util_jni", "liblanguage_id_l2c_jni", "libsurface_util_jni", "libjnidispatch", "libshadowhook", "libdatastore_shared_counter", "libchaquopy_java", "libpython", "libsqlite3_chaquopy", "libsqlite3_python", "libcrypto_chaquopy", "libcrypto_python", "libssl_chaquopy", "libssl_python")
_NA_GFX_LIBS = ("vulkan", "adreno", "libgsl", "libllvm-glnext", "libEGL", "libGLES", "libvulkan", "libVK", "mali", "libgpu", "powervr", "libhwui", "libskia", "libgui", "librenderengine", "libnativewindow", "libjnigraphics")

def _na_frame_cat(fr):
    try:
        m = fr.split("+", 1)[0]
    except Exception:
        return None
    for pfx in _NA_CLIENT_LIBS:
        if m.startswith(pfx):
            return "app"
    for pfx in _NA_GFX_LIBS:
        if m.startswith(pfx):
            return "gfx"
    return None

_NA_GFX_FAMILY_MIN = 3
_NA_TOPBUCKET_MIN_BYTES = 2 * 1024 * 1024

def _na_mod_label(frame):
    try:
        m = frame.split("+", 1)[0]
    except Exception:
        return None
    if not m:
        return None
    if m.endswith(".so"):
        m = m[:-3]
    _p = m.rsplit(".", 1)
    if len(_p) == 2 and _p[1].isdigit():
        m = _p[0]
    return m or None

def _na_top_bucket_summary():
    try:
        p = _oom_path(_NA_NAME)
        if not p or not os.path.exists(p):
            return None
        with open(p, "r", encoding="utf-8") as _f:
            d = json.load(_f)
    except Exception:
        return None
    sites = d.get("sites")
    if not isinstance(sites, list) or not sites:
        return None
    agg = {}
    gfx_frame = {}
    for s in sites:
        try:
            frames = s.get("frames") or []
            bucket = s.get("bucket") or "app"
            rb = int(s.get("retained_bytes") or 0)
        except Exception:
            continue
        if rb <= 0 or not frames:
            continue
        mod = None
        for fr in frames:
            c = _na_frame_cat(fr)
            if (bucket == "app" and c == "app") or (bucket == "gfx" and c == "gfx"):
                mod = _na_mod_label(fr); break
        if not mod:
            mod = _na_mod_label(frames[0]) or "?"
        label = ("%s/%s" % (bucket, mod)) if bucket == "gfx" else mod
        e = agg.get(label)
        if e is None:
            agg[label] = [rb, 1, bucket, mod]
        else:
            e[0] += rb; e[1] += 1
        if bucket == "gfx":
            tf = frames[0]
            g = gfx_frame.get(tf)
            if g is None:
                gfx_frame[tf] = [1, rb]
            else:
                g[0] += 1; g[1] += rb
    if not agg:
        return None
    order = sorted(agg.items(), key=lambda kv: kv[1][0], reverse=True)
    modules = []
    for label, (b, n, bucket, mod) in order:
        if b < _NA_TOPBUCKET_MIN_BYTES and modules:
            continue
        modules.append({"label": label, "module": mod, "bucket": bucket, "bytes": b, "sites": n})
        if len(modules) >= 3:
            break
    parts = []
    for _i, _m in enumerate(modules):
        _mb = _m["bytes"] / 1048576.0
        parts.append(("%s dominant (~%.0fMB)" if _i == 0 else "%s (~%.0fMB)") % (_m["label"], _mb))
    display = ("host_native: " + " + ".join(parts)) if parts else None
    leak_family = None; gfx_family = None
    if gfx_frame:
        _tf, (_cnt, _b) = max(gfx_frame.items(), key=lambda kv: kv[1][0])
        if _cnt >= _NA_GFX_FAMILY_MIN:
            leak_family = "hwui_gfx"
            gfx_family = {"top_frame": _tf, "sites": _cnt, "bytes": _b}
    return {"display": display, "modules": modules, "leak_family": leak_family, "gfx_family": gfx_family}

_NA_OTHER_TOPN = 40

def _na_filter_client(path):
    try:
        with open(path, "r", encoding="utf-8") as _f:
            d = json.load(_f)
        sites = d.get("sites")
        if not isinstance(sites, list):
            return None
        kept = []; other = []
        for s in sites:
            frames = s.get("frames") or []
            cat = None
            for fr in frames:
                c = _na_frame_cat(fr)
                if c == "app":
                    cat = "app"; break
                if c == "gfx" and cat is None:
                    cat = "gfx"
            if cat:
                s["bucket"] = cat
                kept.append(s)
            else:
                other.append(s)
        def _rb(x):
            try: return int(x.get("retained_bytes") or 0)
            except Exception: return 0
        try:
            kept.sort(key=_rb, reverse=True)
            for _i, _s in enumerate(kept): _s["rank"] = _i + 1
        except Exception: pass
        try:
            other.sort(key=_rb, reverse=True)
            for _i, _s in enumerate(other): _s["rank"] = _i + 1
        except Exception: pass
        kept_bytes = 0
        for _s in kept: kept_bytes += _rb(_s)
        other_bytes = 0
        for _s in other: other_bytes += _rb(_s)
        other_n = len(other)
        other_top = other[:_NA_OTHER_TOPN]
        d["sites"] = kept
        d["other_sites"] = other_top
        _app_n = 0; _gfx_n = 0
        for _s in kept:
            if _s.get("bucket") == "gfx": _gfx_n += 1
            else: _app_n += 1
        d["filtered"] = {"mode": "client_plugin_focused", "kept_sites": len(kept), "kept_app_sites": _app_n, "kept_gfx_sites": _gfx_n, "kept_retained_bytes": kept_bytes, "other_sites": other_n, "other_retained_bytes": other_bytes, "other_sites_listed": len(other_top)}
        _atomic_json_write(path, d)
        return (len(kept), kept_bytes, other_n, other_bytes)
    except Exception as e:
        try: _log("Block#3S na filter err: %s" % e)
        except Exception: pass
        return None

def _na_dump(where):
    try:
        if not (_NA_NATIVE_OK and _NLIB is not None and hasattr(_NLIB, "cd_na_dump")):
            return
        try:
            if not int(_NLIB.cd_na_is_on()):
                return
        except Exception:
            return
        p = _oom_path(_NA_NAME)
        if not p:
            return
        n = int(_NLIB.cd_na_dump(p.encode("utf-8")))
        _flt = _na_filter_client(p)
        try:
            _log("Block#3S native alloc-sites -> %s | live_sampled=%d uniq=%d sampled=%d full_drops=%d" % (
                _NA_NAME, n, int(_NLIB.cd_na_unique()), int(_NLIB.cd_na_sampled_count()), int(_NLIB.cd_na_full_drops())))
        except Exception:
            pass
        if _flt is not None:
            try:
                _log("Block#3S site split: client/plugin=%d (%.2fMB), other/system=%d (%.2fMB) [retained in other_sites]" % (
                    _flt[0], _flt[1] / 1048576.0, _flt[2], _flt[3] / 1048576.0))
            except Exception:
                pass
    except Exception as e:
        try: _log("Block#3S na dump err: %s" % e)
        except Exception: pass

def _iz_proxy_top():
    try:
        p = _b28c_proxy_path()
        if not p or not os.path.exists(p):
            return None
        with open(p, "r", encoding="utf-8") as f:
            data = json.load(f)
        if not isinstance(data, dict) or not data:
            return None
        total = 0; best = None; best_n = -1
        for pid, rec in data.items():
            if not pid or pid == _SELF_ID or pid == __id__:
                continue
            try: n = int((rec or {}).get("count") or 0)
            except Exception: n = 0
            if n <= 0:
                continue
            total += n
            if n > best_n:
                best_n = n; best = pid
        if not best or best_n <= 0 or total <= 0:
            return None
        return {"culprit": best, "count": int(best_n), "total": int(total),
                "untagged": 0, "src": "proxy"}
    except Exception:
        return None


def _leak_emit(decoded, where):
    try:
        dims = decoded.get("dims", [])
        leaking = [d for d in dims if d.get("leaking")]
        if not leaking:
            return
        try: adj, score = _proc_oom_score()
        except Exception: adj, score = None, None
        rss_r2 = max([d["r2"] for d in leaking if d["dim"] == "rss"] or [0.0])
        conf = "high" if rss_r2 >= 0.90 else "medium"
        _gref_attr = None
        try:
            _lk = [d.get("dim") for d in leaking]
            if any(x in ("native", "rss", "java") for x in _lk):
                _g = _oom_gref_top()
                if not _g:
                    _g = _iz_proxy_top()
                if _g:
                    _gc = int(_g.get("count") or 0); _gt = int(_g.get("total") or 0)
                    _gu = int(_g.get("untagged") or 0); _gnm = _gt - _gu
                    _gsh = (float(_gc) / float(_gnm)) if _gnm > 0 else ((float(_gc) / float(_gt)) if _gt > 0 else 0.0)
                    if _g.get("culprit") and _gc >= _B28C_MIN and _gsh >= _B28C_DOMINANCE:
                        _gref_attr = {"culprit": _g.get("culprit"), "count": _gc,
                                      "total": _gt, "share": round(_gsh, 4),
                                      "untagged": int(_g.get("untagged") or 0),
                                      "src": (_g.get("src") or "native")}
        except Exception:
            _gref_attr = None
        if _gref_attr:
            try: _log("Block#6D/A: client leak attributed to native global-ref CREATION/churn (not a confirmed leak; DeleteGlobalRef untracked) -> %s (%d/%d gref, %.0f%%)" % (
                _gref_attr["culprit"], _gref_attr["count"], _gref_attr["total"], _gref_attr["share"] * 100.0))
            except Exception: pass
        _ii_ambient = None
        try:
            if _gref_attr:
                _iu = int(_gref_attr.get("untagged") or 0)
                _it = int(_gref_attr.get("total") or 0)
                _ic = int(_gref_attr.get("count") or 0)
                _iu_sh = (float(_iu) / float(_it)) if _it > 0 else 0.0
                _abs_sh = (float(_ic) / float(_it)) if _it > 0 else 0.0
                _java_leak = any(d.get("dim") == "java" and d.get("leaking") for d in dims)
                _rssnat = any(d.get("dim") in ("rss", "native") and d.get("leaking") for d in dims)
                if (_iu_sh >= _B28C_UNTAG_AMBIENT) and _rssnat and (not _java_leak) and (_abs_sh < _B28C_ABS_MIN_SHARE):
                    _ii_ambient = {"gref_suspect": dict(_gref_attr), "untagged_share": round(_iu_sh, 4), "abs_share": round(_abs_sh, 4)}
                    _gref_attr = None
                    conf = "low"
                    try: _log("Block#6D/A +II: gref attribution demoted (ambient/untagged dominates: untagged=%.0f%% of total, suspect abs=%.1f%% of total, rss/native leak, java flat) -> host-unattributed low" % (_iu_sh * 100.0, _abs_sh * 100.0))
                    except Exception: pass
        except Exception:
            _ii_ambient = None
        _na_sum = None; _na_dumped = False
        if (not _gref_attr) and (not _ii_ambient):
            try: _na_dump(where); _na_dumped = True
            except Exception: pass
            try: _na_sum = _na_top_bucket_summary()
            except Exception: _na_sum = None
        _na_reason = (_na_sum.get("display") if (_na_sum and _na_sum.get("display")) else "host_unattributed")
        rec = {"type": "client_memory_leak",
               "event_type": "client_memory_leak", "dropbox_tag": "client_memory_leak", "tombstone_norm_version": 1,
               "verdict": "CLIENT MEMORY LEAK",
               "where": where,
               "ts": int(time.time() * 1000),
               "confidence": conf,
               "culprit": (_gref_attr["culprit"] if _gref_attr else "client (host process)"),
               "kind": ("plugin-globalref" if _gref_attr else "host"),
               "gref_attribution": _gref_attr,
               "gref_suspect": (_ii_ambient.get("gref_suspect") if _ii_ambient else None),
               "ambient_note": (_ii_ambient if _ii_ambient else None),
               "reason_detail": (("globalref_" + (_gref_attr.get("src") or "native")) if _gref_attr else ("globalref_ambient" if _ii_ambient else _na_reason)),
               "oom_score_adj": adj, "oom_score": score,
               "dims": dims,
               "leaking_dims": [d["dim"] for d in leaking],
               "mem_snapshot": _leak_mem_snapshot()}
        if _na_sum:
            if _na_reason != "host_unattributed":
                rec["reason_detail_base"] = "host_unattributed"
                try: _log("Block#6D +IX: host leak enriched -> %s" % _na_reason)
                except Exception: pass
            if _na_sum.get("modules"): rec["native_top_modules"] = _na_sum["modules"]
            if _na_sum.get("leak_family"):
                rec["leak_family"] = _na_sum["leak_family"]
                rec["gfx_family"] = _na_sum.get("gfx_family")
                try:
                    _gf = _na_sum.get("gfx_family") or {}
                    _log("Block#6D +IX: leak_family=hwui_gfx (gfx top-frame %s x%s, ~%.0fMB) -- рост кэша текстур/битмапов/RenderNode на стороне клиента" % (_gf.get("top_frame"), _gf.get("sites"), (_gf.get("bytes") or 0) / 1048576.0))
                except Exception: pass
        try:
            _rss_span = max([float(d.get("span_s") or 0) for d in dims] or [0.0])
            _seg = _leak_seg_delta(_rss_span)
            if _seg:
                rec["rss_segments"] = _seg
                if _seg.get("top"): rec["rss_top_segment"] = _seg["top"]
                _order = sorted(_seg.get("segments", {}).items(),
                                key=lambda kv: kv[1].get("growth", 0), reverse=True)
                _slines = ["  RSS segment deltas (window ~%.0fs):" % _seg.get("span_s", 0)]
                for _nm, _v in _order:
                    _slines.append("    %-12s %+.1f MB (%.1f -> %.1f MB)" % (
                        _nm, _v.get("growth", 0) / 1048576.0,
                        _v.get("first", 0) / 1048576.0, _v.get("last", 0) / 1048576.0))
                try: _log("\n".join(_slines))
                except Exception: pass
        except Exception: pass
        lines = ["CLIENT MEMORY LEAK (%s) conf=%s" % (where, conf)]
        for d in dims:
            mark = "LEAK" if d.get("leaking") else "  - "
            nm = _LEAK_DIM_NAMES.get(d["dim"], d["dim"])
            lines.append("  [%s] %-16s %s -> %s growth=%s slope=%.4g/s r2=%.2f n=%d span=%.0fs" % (
                mark, nm, _leak_fmt_amount(d["dim"], d["first"]),
                _leak_fmt_amount(d["dim"], d["last"]),
                _leak_fmt_amount(d["dim"], d["growth"]),
                d["slope_per_s"], d["r2"], d["n"], d["span_s"]))
        try: _log("\n".join(lines))
        except Exception: pass
        p = _oom_path(_LEAK_NAME)
        if p: _atomic_json_write(p, rec, 65536)
        try: _leak_peak_capture(where, rec)
        except Exception: pass
        if not _na_dumped:
            try: _na_dump(where)
            except Exception: pass
    except Exception as e:
        try: _log("Block#6D leak emit err: %s" % e)
        except Exception: pass

def _leak_check(where):
    try:
        if not (_LEAK_NATIVE_OK and _NLIB is not None):
            return
        _leak_feed_java()
        _leak_seg_sample()
        seq = int(_NLIB.cd_leak_seq())
        if seq == _LEAK_STATE.get("last_seq", 0):
            return
        _LEAK_STATE["last_seq"] = seq
        decoded = _leak_read_native_snap()
        if decoded and decoded.get("flags"):
            _leak_emit(decoded, where)
    except Exception as e:
        try: _log("Block#6D leak check err: %s" % e)
        except Exception: pass

def _read_and_clear_crash_verdict():
    p = _crash_path()
    if not p: return None
    rec = None
    _rp = _rc_take_path(p)
    try:
        if _rp:
            with open(_rp, "r", encoding="utf-8") as f:
                rec = json.load(f)
    except Exception:
        rec = None
    if _rp:
        try: os.remove(_rp)
        except Exception: pass
    return rec

_BLOCK4A_ON = True
_BLOCK4B_ON = True
_XPOSED_BRIDGE_CLASSES = (
    "de.robv.android.xposed.XposedBridge",
    "com.taobao.android.dexposed.DexposedBridge",
)
_HOOK_FRAMEWORK_PROBES = [
    ("de.robv.android.xposed.XposedBridge", "sHookedMethodCallbacks"),
    ("com.taobao.android.dexposed.DexposedBridge", "sHookedMethodCallbacks"),
    ("top.canyie.pine.Pine", "sHookListeners"),
    ("top.canyie.pine.PineConfig", None),
    ("me.weishu.epic.art.Epic", None),
    ("com.swift.sandhook.SandHook", None),
    ("org.lsposed.lsplant.LSPlant", None),
    ("org.lsposed.lspd.core.Main", None),
    ("io.github.libxposed.api.XposedInterface", None),
    ("lab.galaxy.yahfa.HookMain", None),
    ("com.exteragram.messenger.plugins.PythonPluginsEngine", None),
]

def _class_obj(cn):
    try:
        return jclass("java.lang.Class").forName(cn)
    except Exception:
        return None

def _probe_hook_frameworks():
    found = []
    for cn, fld in _HOOK_FRAMEWORK_PROBES:
        cls = _class_obj(cn)
        if cls is None:
            continue
        info = cn
        if fld:
            try:
                f = cls.getDeclaredField(fld); f.setAccessible(True); v = f.get(None)
                try: sz = v.size()
                except Exception:
                    try: sz = len(v)
                    except Exception: sz = "?"
                info += f" [{fld}={sz}]"
            except Exception as e:
                info += f" [{fld}:нет поля]"
        found.append(info)
    return found

def _safe_str(o):
    try: return str(o)
    except Exception:
        try: return o.toString()
        except Exception: return ""

def _plugin_classloaders():
    out = {}
    try:
        PC = jclass("com.exteragram.messenger.plugins.PluginsController")
        controller = PC.getInstance()
        plugins = controller.getPlugins() if controller is not None else None
        if plugins is None: return out
        for e in _entryset_snapshot(plugins):
            try:
                pid = _safe_str(e.getKey()); inst = e.getValue()
                cl = inst.getClass().getClassLoader() if inst is not None else None
                if cl is not None: out[_safe_str(cl)] = pid
            except Exception: pass
    except Exception: pass
    return out

def _entryset_snapshot(m):
    last = None
    for _ in range(4):
        try: return list(m.entrySet().toArray())
        except Exception as e: last = e
    try: _log("entrySet snapshot failed: %s" % last)
    except Exception: pass
    return []

def _xposed_field_value():
    for cn in _XPOSED_BRIDGE_CLASSES:
        try:
            cls = _class_obj(cn)
            if cls is None: continue
            f = cls.getDeclaredField("sHookedMethodCallbacks")
            f.setAccessible(True)
            v = f.get(None)
            if v is not None: return v, cn
        except Exception: continue
    return None, None

def _cb_array(callbacks):
    for getter in ("getSnapshot", "toArray"):
        try:
            a = getattr(callbacks, getter)()
            if a is not None: return a
        except Exception: pass
    return []

def _build_hook_owner_map():
    res = {}
    m, _ = _xposed_field_value()
    if m is None:
        st = "lsplant-no-jmap" if _class_obj("de.robv.android.xposed.XposedBridge") is not None else "no-xposed"
        return res, 0, st
    try:
        clmap = _plugin_classloaders(); known = _load_known()
        for e in _entryset_snapshot(m):
            try:
                member = e.getKey(); callbacks = e.getValue()
                dcl = member.getDeclaringClass().getName()
                try: mname = member.getName()
                except Exception: mname = "<init>"
                key = dcl + "." + mname
                owner = None
                for cb in _cb_array(callbacks):
                    try:
                        cl = cb.getClass().getClassLoader(); rep = _safe_str(cl)
                        if rep in clmap: owner = clmap[rep]; break
                        owner = _map_stack_to_id(rep, known) or _map_stack_to_id(cb.getClass().getName(), known)
                        if owner: break
                    except Exception: pass
                res[key] = owner
            except Exception: pass
    except Exception:
        return res, len(res), "err"
    return res, len(res), "ok"

def _hook_owner_for_frames(frames):
    if not _BLOCK4A_ON: return None, None, None, {"status": "off"}
    omap, n, status = _build_hook_owner_map()
    meta = {"n": n, "status": status}
    if not omap: return None, None, None, meta
    for fr in frames:
        if fr in omap and omap[fr]: return omap[fr], fr, "exact", meta
    simple = {}
    for k, v in omap.items():
        try:
            cls, mth = k.rsplit(".", 1); simple[(_simple(cls), mth)] = (v, k)
        except Exception: pass
    for fr in frames:
        try:
            cls, mth = fr.rsplit(".", 1); t = (_simple(cls), mth)
            if t in simple and simple[t][0]: return simple[t][0], simple[t][1], "simple", meta
        except Exception: pass
    by_method = {}
    for k, v in omap.items():
        if not v: continue
        try: mth = k.rsplit(".", 1)[1]
        except Exception: continue
        by_method.setdefault(mth, set()).add((v, k))
    for fr in frames:
        if not _is_hook_frame(fr): continue
        try: mth = fr.rsplit(".", 1)[1]
        except Exception: continue
        hits = by_method.get(mth)
        if hits and len(hits) == 1:
            v, k = next(iter(hits))
            return v, k, "hook-method", meta
    for fr in frames:
        if fr in omap: return None, fr, "method-only", meta
    return None, None, None, meta

def _plugin_loaders():
    out = []
    try:
        PC = jclass("com.exteragram.messenger.plugins.PluginsController")
        controller = PC.getInstance()
        plugins = controller.getPlugins() if controller is not None else None
        if plugins is None: return out
        for e in _entryset_snapshot(plugins):
            try:
                pid = _safe_str(e.getKey()); inst = e.getValue()
                cl = inst.getClass().getClassLoader() if inst is not None else None
                if cl is not None: out.append((cl, _safe_str(cl), pid))
            except Exception: pass
    except Exception: pass
    return out

def _classloader_culprit(frames):
    if not _BLOCK4B_ON: return None, None, {"status": "off"}
    loaders = _plugin_loaders()
    meta = {"n": len(loaders), "status": ("no-loaders" if not loaders else "ok")}
    if not loaders: return None, None, meta
    repr2pids = {}
    for (cl, rep, pid) in loaders:
        repr2pids.setdefault(rep, set()).add(pid)
    ambig = 0
    for fr in frames:
        cn = fr.rsplit(".", 1)[0] if "." in fr else fr
        if _is_system_class(cn): continue
        for (cl, rep, pid) in loaders:
            try:
                kls = cl.loadClass(cn)
            except Exception:
                continue
            try:
                drep = _safe_str(kls.getClassLoader())
            except Exception:
                drep = None
            if drep is None: continue
            pids = repr2pids.get(drep)
            if not pids: continue
            if len(pids) == 1:
                if ambig: meta["ambiguous"] = ambig
                return next(iter(pids)), fr, meta
            ambig += 1; break
    if ambig: meta["ambiguous"] = ambig
    return None, None, meta

def _b16_push_verdict(kind, rec):
    if not _B16_ON: return
    try:
        conf = rec.get("confidence")
        if conf not in ("high", "medium"): return
        e = {"kind": kind, "culprit": rec.get("culprit"), "confidence": conf,
             "where": rec.get("where"), "exc_cls": rec.get("exc_cls"),
             "exc_msg": rec.get("exc_msg"), "py_file": rec.get("py_file"),
             "py_line": rec.get("py_line"), "ts": rec.get("ts") or int(time.time() * 1000)}
        with _RECENT_VERDICTS_LOCK:
            _RECENT_VERDICTS.append(e)
            if len(_RECENT_VERDICTS) > _RECENT_MAX:
                del _RECENT_VERDICTS[:-_RECENT_MAX]
    except Exception:
        pass

def _b16_disk_candidates():
    out = []
    try:
        srcs = (("cb", _cb_verdict_path), ("bg", _bg_verdict_path), ("ui", _ui_verdict_path), ("fut", _fut_verdict_path), ("async", _async_verdict_path), ("pyerr", _pyerr_verdict_path))
    except Exception:
        srcs = ()
    for kind, pathfn in srcs:
        try:
            p = pathfn()
            _rp = _rc_read_path(p) if p else None
            if not _rp: continue
            with open(_rp, "r", encoding="utf-8") as f:
                arr = list(json.load(f))
            for r in arr[-12:]:
                try:
                    out.append({"kind": kind, "culprit": r.get("culprit"),
                                "confidence": r.get("confidence"), "where": r.get("where"),
                                "exc_cls": r.get("exc_cls"), "exc_msg": r.get("exc_msg"),
                                "py_file": r.get("py_file"), "py_line": r.get("py_line"),
                                "ts": r.get("ts")})
                except Exception: pass
        except Exception:
            pass
    return out

def _b16_exc_match(crash_exc_cls, crash_exc_msg, v_exc_cls, v_exc_msg):
    cm = str(crash_exc_msg or "")
    vm = str(v_exc_msg or "")
    vc = str(v_exc_cls or "")
    if vm and (vm == cm or vm in cm or cm.endswith(vm)):
        return True
    combo = ("%s: %s" % (vc, vm)) if vm else vc
    if combo and (combo == cm or combo in cm or cm.endswith(combo)):
        return True
    return False

def _b19_exc_ring_put(exc):
    try: _ec = type(exc).__name__
    except Exception: _ec = None
    try: _em = str(exc)
    except Exception: _em = None
    if not _ec: return
    try:
        with _B19_EXC_RING_LOCK:
            _B19_EXC_RING.append((int(time.time() * 1000), _ec, _em))
            if len(_B19_EXC_RING) > _B19_EXC_RING_MAX:
                del _B19_EXC_RING[0:len(_B19_EXC_RING) - _B19_EXC_RING_MAX]
    except Exception: pass

def _b19_exc_ring_lookup(crash_ts, window_ms):
    best = None; best_dt = None
    try:
        with _B19_EXC_RING_LOCK:
            _snap = list(_B19_EXC_RING)
    except Exception:
        _snap = []
    for _ts, _ec, _em in _snap:
        try: _dt = abs(int(crash_ts) - int(_ts))
        except Exception: continue
        if _dt <= window_ms and (best_dt is None or _dt < best_dt):
            best = (_ec, _em); best_dt = _dt
    return best


def _b16_correlate(rec):
    try:
        if not _B16_ON or not isinstance(rec, dict): return rec
        crash_ts = rec.get("ts") or int(time.time() * 1000)
        cx = rec.get("exc_cls"); cm = rec.get("exc_msg")
        if (not cx or str(cx).strip() in ("", "?")) and (not cm or str(cm).strip() == ""):
            _enr = _b19_exc_ring_lookup(crash_ts, _B16_CORR_WINDOW_MS)
            if _enr:
                rec["exc_cls"] = _enr[0]
                if _enr[1]: rec["exc_msg"] = _enr[1]
                rec["exc_from"] = "b19_ring+window"
                cx = rec.get("exc_cls"); cm = rec.get("exc_msg")
        cands = []
        try:
            with _RECENT_VERDICTS_LOCK:
                cands = list(_RECENT_VERDICTS)
        except Exception:
            cands = []
        try:
            cands = cands + _b16_disk_candidates()
        except Exception:
            pass
        top_pid = None
        try:
            nm = rec.get("native_mem")
            if isinstance(nm, dict): top_pid = nm.get("top_pid")
        except Exception:
            top_pid = None
        try:
            frames = rec.get("stack_top") or []
        except Exception:
            frames = []
        best = None; best_ts = -1
        best_py = None; best_py_ts = -1
        for v in cands:
            try:
                if v.get("confidence") != "high": continue
                vts = v.get("ts")
                if vts is None: continue
                if abs(int(crash_ts) - int(vts)) > _B16_CORR_WINDOW_MS: continue
                if _b16_exc_match(cx, cm, v.get("exc_cls"), v.get("exc_msg")):
                    if int(vts) > best_ts:
                        best = v; best_ts = int(vts)
                elif v.get("kind") == "pyerr":
                    if int(vts) > best_py_ts:
                        best_py = v; best_py_ts = int(vts)
            except Exception:
                pass
        if best is None and best_py is not None:
            best = best_py; best_ts = best_py_ts
        if best is None:
            try:
                cms = str(cm or "")
                if "_chaquopyGetDict" in cms or "_chaquopyGetType" in cms:
                    q1 = cms.find("'") + 1
                    q2 = cms.find("'", q1) if q1 > 0 else -1
                    cls_name = cms[q1:q2] if (q1 > 0 and q2 > q1) else None
                    if cls_name:
                        entry = _B14_IFACE_OWNER.get(cls_name)
                        if entry:
                            zowner, zts = entry
                            if abs(int(crash_ts) - int(zts)) < _B16_ZOMBIE_WINDOW_MS:
                                rec["correlated"] = {
                                    "from": "zombie_proxy",
                                    "culprit": zowner,
                                    "confidence": "medium",
                                    "where": "proxy.invoke/fromJava",
                                    "proxy_class": cls_name,
                                    "match": "iface_owner+window",
                                    "age_ms": abs(int(crash_ts) - int(zts))}
                                cur_pid = rec.get("crashed_plugin_id")
                                cur_conf = rec.get("confidence")
                                weak = (
                                    (cur_conf != "high") or (not cur_pid) or
                                    (cur_pid == "unknown") or
                                    (isinstance(cur_pid, str) and
                                     cur_pid.startswith("<python>"))
                                )
                                if weak:
                                    rec["crashed_plugin_id_native"] = cur_pid
                                    rec["crashed_plugin_id"] = zowner
                                    rec["confidence"] = "medium"
                                    rec["src"] = "zombie_proxy/" + cls_name
            except Exception: pass
            return rec
        culprit = best.get("culprit")
        if not culprit or culprit == "unknown": return rec
        sig = ["exc", "window"]
        try:
            if top_pid and top_pid == culprit: sig.append("top_pid")
        except Exception: pass
        try:
            for fr in frames:
                if isinstance(fr, str) and culprit in fr:
                    sig.append("stack"); break
        except Exception: pass
        rec["correlated"] = {
            "from": (best.get("kind") or "cb") + "_verdict", "culprit": culprit,
            "confidence": best.get("confidence"), "where": best.get("where"),
            "py_file": best.get("py_file"), "py_line": best.get("py_line"),
            "match": "+".join(sig), "age_ms": abs(int(crash_ts) - best_ts),
        }
        cur_pid = rec.get("crashed_plugin_id")
        cur_conf = rec.get("confidence")
        weak = (cur_conf != "high") or (not cur_pid) or (cur_pid == "unknown") or (isinstance(cur_pid, str) and cur_pid.startswith("<python>"))
        if weak:
            rec["crashed_plugin_id_native"] = cur_pid
            rec["crashed_plugin_id"] = culprit
            rec["confidence"] = "high"
            rec["src"] = "correlated/" + (best.get("kind") or "cb")
        return rec
    except Exception:
        return rec

def _b16_correlate_boot(rec, cands):
    try:
        if not _B16_ON or not isinstance(rec, dict) or not cands:
            return rec
        cur_pid = rec.get("crashed_plugin_id"); cur_conf = rec.get("confidence")
        weak = (cur_conf != "high") or (not cur_pid) or (cur_pid == "unknown") or (isinstance(cur_pid, str) and cur_pid.startswith("<python>"))
        if not weak:
            return rec
        crash_ts = rec.get("ts") or int(time.time() * 1000)
        cx = rec.get("exc_cls"); cm = rec.get("exc_msg")
        if (not cx or str(cx).strip() in ("", "?")) and (not cm or str(cm).strip() == ""):
            _enr = _b19_exc_ring_lookup(crash_ts, _B16_CORR_WINDOW_MS)
            if _enr:
                rec["exc_cls"] = _enr[0]
                if _enr[1]: rec["exc_msg"] = _enr[1]
                rec["exc_from"] = "b19_ring+window"
                cx = rec.get("exc_cls"); cm = rec.get("exc_msg")
        best = None; best_ts = -1; best_py = None; best_py_ts = -1
        for v in cands:
            try:
                if v.get("confidence") != "high":
                    continue
                vts = v.get("ts")
                if vts is None:
                    continue
                if abs(int(crash_ts) - int(vts)) > _B16_CORR_WINDOW_MS:
                    continue
                if _b16_exc_match(cx, cm, v.get("exc_cls"), v.get("exc_msg")):
                    if int(vts) > best_ts:
                        best = v; best_ts = int(vts)
                elif v.get("kind") == "pyerr":
                    if int(vts) > best_py_ts:
                        best_py = v; best_py_ts = int(vts)
            except Exception:
                pass
        if best is None and best_py is not None:
            best = best_py; best_ts = best_py_ts
        if best is None:
            return rec
        culprit = best.get("culprit")
        if not culprit or culprit == "unknown":
            return rec
        rec["crashed_plugin_id_native"] = cur_pid
        rec["crashed_plugin_id"] = culprit
        rec["confidence"] = "high"
        rec["src"] = "correlated-boot/" + (best.get("kind") or "py")
        rec["correlated"] = {"from": (best.get("kind") or "py") + "_verdict", "culprit": culprit,
                             "confidence": best.get("confidence"), "where": best.get("where"),
                             "py_file": best.get("py_file"), "py_line": best.get("py_line"),
                             "match": "boot+window", "age_ms": abs(int(crash_ts) - int(best_ts))}
        return rec
    except Exception:
        return rec


def _capture_crash(thread, ex):
    crash_ts = int(time.time() * 1000)
    tid = None
    if _NATIVE_OK and _NLIB is not None:
        try: tid = int(_NLIB.cd_gettid())
        except Exception: tid = None
    if tid is None:
        try: tid = int(thread.getId())
        except Exception: tid = None
    idx_tid = _reg_get(tid)
    pid_tid = _resolve_idx(idx_tid) if (idx_tid is not None and idx_tid >= 0) else None
    crumb_raw = None
    try:
        crumb_raw = _CRUMB.read_prev() if _CRUMB is not None else None
    except Exception:
        crumb_raw = None
    pid_crumb = None; crumb_fresh = False; crumb_age = None
    if crumb_raw:
        try:
            parts = crumb_raw.split("\t")
            pid_crumb = parts[0]; cts = int(parts[2]); crumb_age = crash_ts - cts
            if 0 <= crumb_age <= _CRUMB_FRESH_MS: crumb_fresh = True
        except Exception:
            pid_crumb = crumb_raw.split("\t")[0] if "\t" in crumb_raw else crumb_raw
    frames = []
    try:
        st = ex.getStackTrace()
        if st is not None:
            for el in st:
                try: frames.append(el.getClassName() + "." + el.getMethodName())
                except Exception: pass
    except Exception:
        pass
    via_hook = any(_is_hook_frame(f) for f in frames)
    hooked_method = None
    if via_hook:
        for f in frames:
            if _is_hook_frame(f) and "LSPHooker_" in f:
                try: hooked_method = f.rsplit(".", 1)[1]
                except Exception: hooked_method = _short_method(f)
                break
        if not hooked_method:
            for f in frames:
                if f.startswith("org.telegram."):
                    hooked_method = _short_method(f); break
    culprit_frame = _stack_culprit(frames)
    pid_stack = _map_stack_to_id(culprit_frame, _known_union()) if culprit_frame else None
    pid_4a = None; hook4a_method = None; hook4a_kind = None; hook4a_meta = {}
    try:
        pid_4a, hook4a_method, hook4a_kind, hook4a_meta = _hook_owner_for_frames(frames)
    except Exception as _e4a:
        hook4a_meta = {"status": "err:%s" % _e4a}
    pid_4b = None; cl4b_frame = None; cl4b_meta = {}
    try:
        pid_4b, cl4b_frame, cl4b_meta = _classloader_culprit(frames)
    except Exception as _e4b:
        cl4b_meta = {"status": "err:%s" % _e4b}
    pid_4c = None; cl4c_frame = None; cl4c_meta = {}
    try:
        pid_4c, cl4c_frame, cl4c_meta = _loader_culprit(frames)
    except Exception as _e4c:
        cl4c_meta = {"status": "err:%s" % _e4c}
    pid_stack_strong = pid_stack if (pid_stack and culprit_frame and not _is_obfuscated(culprit_frame)) else None
    if pid_tid:
        pid = pid_tid; src = "tid"; conf = "high"
    elif pid_stack_strong:
        pid = pid_stack_strong; src = "stack"; conf = "high"
    elif pid_4c:
        pid = pid_4c; src = "loader"; conf = "high"
    elif pid_4b:
        pid = pid_4b; src = "classloader"; conf = "high"
    elif pid_4a:
        pid = pid_4a; src = "hookmap"; conf = "high"
    elif pid_stack:
        pid = pid_stack; src = "stack"; conf = "medium"
    elif culprit_frame:
        pid = _pkg_of(culprit_frame); src = "stack-pkg"; conf = "low"
    elif crumb_fresh and pid_crumb:
        pid = pid_crumb; src = "breadcrumb"; conf = "low"
    else:
        pid = "unknown"; src = ("hook-obfuscated" if via_hook else "none"); conf = "none"
    exc_cls = ""; exc_msg = ""; tname = ""
    try: exc_cls = ex.getClass().getName()
    except Exception: pass
    try:
        m = ex.getMessage(); exc_msg = str(m) if m is not None else ""
    except Exception: pass
    try: tname = thread.getName()
    except Exception: pass
    is_selftest = (_SELFTEST_MARK in (exc_msg or "")) or (tname == _SELFTEST_TNAME)
    nat = None
    if _NATIVE_OK and _NLIB is not None:
        try:
            b = ctypes.c_int64(0)
            ti = int(_NLIB.cd_top1(ctypes.byref(b)))
            nat = {"top_idx": ti, "top_pid": (_resolve_idx(ti) if ti >= 0 else None),
                   "top_bytes": int(b.value), "total": int(_NLIB.cd_total())}
        except Exception:
            nat = None
    rec = {
        "had_crash": True, "crashed_plugin_id": pid, "src": src, "confidence": conf,
        "exc_cls": exc_cls, "exc_msg": exc_msg, "thread": tname,
        "via_hook": via_hook, "hooked_method": hooked_method,
        "pid_tid": pid_tid, "reg_idx": idx_tid, "reg_backend": registry_info()["backend"],
        "pid_stack": pid_stack, "culprit_frame": culprit_frame,
        "pid_4a": pid_4a, "hook4a_method": hook4a_method, "hook4a_kind": hook4a_kind, "hook4a_meta": hook4a_meta,
        "pid_4b": pid_4b, "cl4b_frame": cl4b_frame, "cl4b_meta": cl4b_meta,
        "pid_4c": pid_4c, "cl4c_frame": cl4c_frame, "cl4c_meta": cl4c_meta,
        "pid_crumb": pid_crumb, "crumb_fresh": crumb_fresh, "crumb_age_ms": crumb_age, "crumb": crumb_raw,
        "stack_top": frames[:40], "native_mem": nat, "ts": crash_ts,
    }
    if _is_py_memoryerror(exc_cls, exc_msg):
        rec["mem_pressure"] = True; rec["reason"] = _MEM_PRESSURE_REASON
    rec = _b16_correlate(rec)
    _write_crash_verdict(rec)
    return is_selftest

_UEH_IFACE = None
try:
    _UEH_IFACE = jclass("java.lang.Thread$UncaughtExceptionHandler")
except Exception:
    _UEH_IFACE = None
_HANDLER_CLASS = None
if _UEH_IFACE is not None:
    try:
        from java import dynamic_proxy
        class _CrashHandler(dynamic_proxy(_UEH_IFACE)):
            def __init__(self, prev):
                super().__init__(); self._prev = prev
            def uncaughtException(self, thread, ex):
                swallow = False
                try: swallow = _capture_crash(thread, ex)
                except Exception: swallow = False
                if not swallow:
                    try:
                        if self._prev is not None:
                            self._prev.uncaughtException(thread, ex)
                    except Exception: pass
        _HANDLER_CLASS = _CrashHandler
    except Exception:
        _HANDLER_CLASS = None

_RUNNABLE_IFACE = None
try:
    _RUNNABLE_IFACE = jclass("java.lang.Runnable")
except Exception:
    _RUNNABLE_IFACE = None
_SELFTEST_RUNNABLE_CLASS = None
if _RUNNABLE_IFACE is not None:
    try:
        from java import dynamic_proxy as _dp2
        class _SelfTestRunnable(dynamic_proxy(_RUNNABLE_IFACE)):
            def run(self):
                try:
                    _publish_tid("__selftest__")
                    if _CRUMB is not None:
                        _CRUMB.write("__selftest__", "selftest:crash")
                except Exception: pass
                raise RuntimeError(_SELFTEST_MARK + " Culprit Detector self-test (преднамеренный uncaught)")
        _SELFTEST_RUNNABLE_CLASS = _SelfTestRunnable
    except Exception:
        _SELFTEST_RUNNABLE_CLASS = None

_PREV_UEH = None
_OUR_UEH = None

_SUICIDE_TL = threading.local()
def _pm_thread_name():
    try:
        if _JThread is not None: return str(_JThread.currentThread().getName())
    except Exception: pass
    return ""
def _pm_java_stack(maxn=28):
    out = []
    try:
        if _JThread is None: return out
        st = _JThread.currentThread().getStackTrace()
        for e in list(st)[:maxn]:
            try:
                out.append("%s.%s(%s:%s)" % (e.getClassName(), e.getMethodName(), e.getFileName(), e.getLineNumber()))
            except Exception: pass
    except Exception: pass
    return out
def _pm_scan_stack(frames):
    try: known = _load_known()
    except Exception: known = []
    if not known: return None
    for fr in frames:
        low = fr.lower()
        for pid in known:
            if pid and pid.lower() in low: return pid
    for fr in frames:
        fsq = _squash(fr)
        for pid in known:
            ps = _squash(pid)
            if ps and len(ps) >= 4 and ps in fsq: return pid
    return None
def _pm_python_stack(maxn=48):
    out = []
    try:
        import traceback as _tb
        for fr in _tb.extract_stack()[-maxn:]:
            try:
                fn = getattr(fr, "filename", None); nm = getattr(fr, "name", None)
                if fn is None: fn = fr[0]; nm = fr[2]
                out.append("%s::%s" % (fn, nm))
            except Exception: pass
    except Exception: pass
    return out
def _pm_scan_py(pyframes):
    try: known = _load_known()
    except Exception: known = []
    if not known: return None
    for fr in pyframes:
        low = fr.lower()
        if "culprit" in low: continue
        for pid in known:
            if pid and pid != _SELF_ID and pid.lower() in low: return pid
    for fr in pyframes:
        if "culprit" in fr.lower(): continue
        fsq = _squash(fr)
        for pid in known:
            if pid == _SELF_ID: continue
            ps = _squash(pid)
            if ps and len(ps) >= 4 and ps in fsq: return pid
    return None
_PM_TEARDOWN = ("uncaughtException", "dispatchUncaughtException", "KillApplicationHandler")
def _pm_is_teardown(frames):
    try:
        for fr in frames:
            for mk in _PM_TEARDOWN:
                if mk in fr: return True
    except Exception: pass
    return False
_UI_CLICK_ATTRS = ("on_click", "on_long_click", "on_select", "on_toggle", "on_change", "on_value_change")
_UI_CLICK_TL = threading.local()
_UI_CLICK_LAST = {}
_UI_CLICK_LOCK = threading.Lock()
_UI_CLICK_WINDOW_MS = 6000
def _ui_click_enter(pid):
    try:
        _UI_CLICK_TL.depth = int(getattr(_UI_CLICK_TL, "depth", 0)) + 1
        _UI_CLICK_TL.owner = pid
    except Exception: pass
    try:
        if pid:
            with _UI_CLICK_LOCK: _UI_CLICK_LAST[pid] = int(time.time() * 1000)
    except Exception: pass
def _ui_click_leave():
    try:
        d = int(getattr(_UI_CLICK_TL, "depth", 0))
        if d > 0: _UI_CLICK_TL.depth = d - 1
    except Exception: pass
def _ui_click_active_owner():
    try:
        if int(getattr(_UI_CLICK_TL, "depth", 0)) > 0:
            return getattr(_UI_CLICK_TL, "owner", None)
    except Exception: pass
    return None
def _ui_click_recent(pid, window_ms=None):
    if not pid: return None
    if window_ms is None: window_ms = _UI_CLICK_WINDOW_MS
    try:
        with _UI_CLICK_LOCK: ts = _UI_CLICK_LAST.get(pid)
        if ts is None: return None
        age = int(time.time() * 1000) - int(ts)
        return age if (0 <= age <= window_ms) else None
    except Exception:
        return None
_RELAUNCH_LAST_TS = [0]
_RELAUNCH_LOCK = threading.Lock()
_RELAUNCH_WINDOW_MS = 3000
def _own_pkg():
    try:
        p = jclass("android.app.ActivityThread").currentPackageName()
        if p: return str(p)
    except Exception: pass
    try:
        return str(jclass("org.telegram.messenger.ApplicationLoader").applicationContext.getPackageName())
    except Exception: return None
def _relaunch_recent(window_ms=None):
    if window_ms is None: window_ms = _RELAUNCH_WINDOW_MS
    try:
        with _RELAUNCH_LOCK: ts = _RELAUNCH_LAST_TS[0]
        if not ts: return None
        age = int(time.time() * 1000) - int(ts)
        return age if (0 <= age <= window_ms) else None
    except Exception: return None
def _relaunch_note_intent(intent):
    try:
        if intent is None: return
        own = _own_pkg()
        if not own: return
        tgt = None
        try:
            pkg = intent.getPackage()
            if pkg: tgt = str(pkg)
        except Exception: pass
        if tgt is None:
            try:
                comp = intent.getComponent()
                if comp is not None: tgt = str(comp.getPackageName())
            except Exception: pass
        if tgt and tgt == own:
            with _RELAUNCH_LOCK: _RELAUNCH_LAST_TS[0] = int(time.time() * 1000)
    except Exception: pass
class _HookRelaunchSchedule(MethodHook):
    def before_hooked_method(self, param):
        try:
