try:
    _LocaleController = jclass("org.telegram.messenger.LocaleController")
except Exception:
    _LocaleController = None

def _cd_lang():
    try:
        if _LocaleController is not None:
            lc = _LocaleController.getInstance()
            if lc is not None and hasattr(lc, "getCurrentLocale"):
                loc = lc.getCurrentLocale()
                if loc is not None and hasattr(loc, "getLanguage"):
                    if str(loc.getLanguage()) == "ru":
                        return "ru"
    except Exception:
        pass
    return "en"

