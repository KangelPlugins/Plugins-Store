def _iu_stack_is_bridge(jframes, component):
    """+IU: is this UI-stall stack an Xposed/Chaquopy bridge dispatch (a plugin
    hook running through the shared engine frame)?"""
    try:
        if component and any(_s in component for _s in _IU_BRIDGE_NAMES):
            return True
        for _f in (jframes or [])[:8]:
            if any(_s in _f for _s in _IU_BRIDGE_NAMES):
                return True
    except Exception:
        pass
    return False

def _iu_bridge_owner(jframes, waited_ms):
    """+IU: resolve the REAL plugin owning a bridge UI-stall. Order:
    (1) native xphook op-stamp (GIL-free owner from +IT), (2) any fresh op-stamp,
    (3) hook-owner map from the stack frames (LSPHooker_.<m> -> plugin),
    (4) plugin frame in the UI stack (class -> loader -> plugin). Returns
    (owner|None, how|None)."""
    # (1)+(2) op-stamps (xphook first, then any domain) within the stall window
    try:
        _op = _b20_owner_from_op(int(waited_ms) + 2500)
        if _op and _op.get("owner"):
            return _op.get("owner"), ("op:" + str(_op.get("domain") or "?"))
    except Exception:
        pass
    # (3) hook-owner map (Block#4A) resolves a hooked frame -> plugin
    try:
        _o, _fr, _how, _meta = _hook_owner_for_frames(jframes or [])
        if _o and _o not in (_SELF_ID, __id__):
            return _o, ("hook-map:" + str(_how))
    except Exception:
        pass
    # (4) plugin frame in the UI stack -> class -> loader -> plugin id
    try:
        for _f in (jframes or []):
            _cls = _f.split("(", 1)[0].rsplit(".", 1)[0] if "(" in _f else _f
            _pid = _map_stack_to_id(_cls, _known_union()) if _cls else None
            if _pid and _pid not in (_SELF_ID, __id__):
                return _pid, "stack-loader"
    except Exception:
        pass
    return None, None

def _op_family_native_install(dom):
    """+IN: install the native op-stamp interceptor for one op family
    (gpu/mvel/binder/camera/mediacodec/gl). Mirrors the anim/looper native
    path: selftest -> install -> mark ACTIVE. NO Python fallback by design --
    if the native path is unavailable or selftest fails, the op-stamp is
    simply absent (no per-call Java->Python/GIL MethodHook on app threads).
    Returns (active: bool, nstub: int)."""
    _U = dom.upper()
    if not (globals().get("_%s_NATIVE_ON" % _U, True) and globals().get("_%s_NATIVE_OK" % _U, False)
            and _NLIB is not None and _CTYPES_OK):
        return (False, 0)
    off = int(globals().get("_%s_ENTRY_OFFSET" % _U, 0) or 0)
    try:
        _self = getattr(_NLIB, "cd_%s_selftest" % dom)
        _inst = getattr(_NLIB, "cd_%s_install" % dom)
    except Exception:
        return (False, 0)
    try:
        _ok = int(_self(ctypes.c_int32(off)))
    except Exception:
        _ok = 0
    if _ok <= 0:
        return (False, 0)
    try:
        _n = int(_inst(ctypes.c_int32(off)))
    except Exception:
        _n = 0
    if _n > 0:
        globals()["_%s_NATIVE_ACTIVE" % _U] = True
        return (True, _n)
    return (False, 0)

