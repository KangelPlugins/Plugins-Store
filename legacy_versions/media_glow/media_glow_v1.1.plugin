from typing import Any, Dict, List, Optional
import threading
import time

from base_plugin import BasePlugin, MethodHook
from hook_utils import find_class, get_private_field, set_private_field
from client_utils import run_on_queue, PLUGINS_QUEUE
from android_utils import run_on_ui_thread
from ui.settings import Header, Switch, Selector, Input

from java.lang import Boolean, Integer
from java.lang.ref import WeakReference

from android.graphics import Bitmap, Canvas, Color, Paint, Rect, RectF
from android.view import View
from org.telegram.messenger import Utilities


__id__ = "media_glow"
__name__ = "Media Glow"
__description__ = "добавляет мягкую размытую подсветку по краям полноэкранных фото и видео"
__author__ = "@itskotovski & @mishabotov"
__version__ = "1.1"
__icon__ = "sfsymbols/347"


SETTING_ENABLED = "enabled"
SETTING_STRENGTH = "strength"
SETTING_BLUR = "blur"
SETTING_TRANSITION = "transition"
SETTING_VIDEO_DELAY = "video_delay_ms"

STRENGTH_ITEMS = ["мягкая", "сбалансированная", "яркая"]
BLUR_ITEMS = ["мягкое", "широкое", "очень широкое"]
TRANSITION_ITEMS = ["быстрый", "плавный", "кинематографичный"]
DEFAULT_STRENGTH = 1
DEFAULT_BLUR = 1
DEFAULT_TRANSITION = 1
DEFAULT_VIDEO_DELAY_MS = 450
MIN_VIDEO_DELAY_MS = 16
VIDEO_CROSSFADE_MIN_MS = 120


def _as_int(value: Any, default: int = 0) -> int:
    try:
        return int(value)
    except Exception:
        return default


def _key(viewer: Any) -> int:
    try:
        return int(viewer.hashCode())
    except Exception:
        try:
            return id(viewer)
        except Exception:
            return 0


def _to_class(value: Any) -> Optional[Any]:
    if value is None:
        return None
    try:
        if hasattr(value, "getDeclaredMethod"):
            return value
    except Exception:
        pass
    try:
        return value.getClass()
    except Exception:
        return None


def _copy_bitmap(bitmap: Any, max_side: int = 420) -> Optional[Any]:
    if bitmap is None:
        return None
    try:
        width = int(bitmap.getWidth())
        height = int(bitmap.getHeight())
        if width <= 0 or height <= 0:
            return None

        scale = min(1.0, float(max_side) / float(max(width, height)))
        target_w = max(16, int(width * scale))
        target_h = max(16, int(height * scale))

        if target_w != width or target_h != height:
            result = Bitmap.createScaledBitmap(bitmap, target_w, target_h, True)
        else:
            result = bitmap.copy(Bitmap.Config.ARGB_8888, True)

        if result is not None and (result.getConfig() != Bitmap.Config.ARGB_8888 or not result.isMutable()):
            mutable = result.copy(Bitmap.Config.ARGB_8888, True)
            try:
                result.recycle()
            except Exception:
                pass
            result = mutable
        return result
    except Exception:
        return None


def _make_glow(bitmap: Any, blur_radius: int) -> Optional[Any]:
    if bitmap is None:
        return None
    try:
        width = int(bitmap.getWidth())
        height = int(bitmap.getHeight())
        if width <= 0 or height <= 0:
            return None

        canvas = Canvas(bitmap)
        paint = Paint()
        paint.setColor(Color.argb(72, 0, 0, 0))
        canvas.drawRect(0.0, 0.0, float(width), float(height), paint)

        Utilities.stackBlurBitmap(bitmap, max(1, min(blur_radius, 60)))
        return bitmap
    except Exception:
        try:
            bitmap.recycle()
        except Exception:
            pass
        return None


def _ease_in_out(value: float) -> float:
    value = max(0.0, min(1.0, value))
    return value * value * (3.0 - 2.0 * value)


def _blend_glows(previous: Any, current: Any, current_alpha: float) -> Optional[Any]:
    if previous is None or current is None:
        return None
    result = None
    try:
        width = int(current.getWidth())
        height = int(current.getHeight())
        if width <= 0 or height <= 0:
            return None

        result = Bitmap.createBitmap(width, height, Bitmap.Config.ARGB_8888)
        canvas = Canvas(result)
        paint = Paint()
        paint.setAntiAlias(True)
        paint.setFilterBitmap(True)

        previous_w = int(previous.getWidth())
        previous_h = int(previous.getHeight())
        if previous_w > 0 and previous_h > 0:
            scale = max(float(width) / float(previous_w), float(height) / float(previous_h))
            draw_w = previous_w * scale
            draw_h = previous_h * scale
            left = (width - draw_w) / 2.0
            top = (height - draw_h) / 2.0
            src = Rect(0, 0, previous_w, previous_h)
            dst = RectF(float(left), float(top), float(left + draw_w), float(top + draw_h))
            paint.setAlpha(max(0, min(255, int(255 * (1.0 - current_alpha)))))
            canvas.drawBitmap(previous, src, dst, paint)

        paint.setAlpha(max(0, min(255, int(255 * current_alpha))))
        canvas.drawBitmap(current, 0.0, 0.0, paint)
        return result
    except Exception:
        try:
            if result is not None:
                result.recycle()
        except Exception:
            pass
        return None


class _IndexHook(MethodHook):
    def __init__(self, plugin: "MediaGlowPlugin") -> None:
        self.plugin = plugin

    def before_hooked_method(self, param: Any) -> None:
        try:
            self.plugin.force_texture(param.thisObject)
        except Exception:
            pass

    def after_hooked_method(self, param: Any) -> None:
        try:
            self.plugin.schedule(param.thisObject)
        except Exception:
            pass


class _CloseHook(MethodHook):
    def __init__(self, plugin: "MediaGlowPlugin") -> None:
        self.plugin = plugin

    def before_hooked_method(self, param: Any) -> None:
        try:
            self.plugin.clear(param.thisObject)
        except Exception:
            pass


class _DrawHook(MethodHook):
    def __init__(self, plugin: "MediaGlowPlugin") -> None:
        self.plugin = plugin

    def before_hooked_method(self, param: Any) -> None:
        try:
            if param.args is None or len(param.args) < 1:
                return
            self.plugin.draw(param.thisObject, param.args[0])
        except Exception:
            pass


class _TextureHook(MethodHook):
    def __init__(self, plugin: "MediaGlowPlugin") -> None:
        self.plugin = plugin

    def before_hooked_method(self, param: Any) -> None:
        try:
            self.plugin.force_texture(param.thisObject)
        except Exception:
            pass

    def after_hooked_method(self, param: Any) -> None:
        try:
            self.plugin.poll_video(param.thisObject, self.plugin._video_delay_ms())
        except Exception:
            pass


class _PrepareHook(MethodHook):
    def __init__(self, plugin: "MediaGlowPlugin") -> None:
        self.plugin = plugin

    def before_hooked_method(self, param: Any) -> None:
        try:
            self.plugin.force_texture(param.thisObject)
        except Exception:
            pass

    def after_hooked_method(self, param: Any) -> None:
        try:
            self.plugin.schedule(param.thisObject)
            self.plugin.poll_video(param.thisObject, self.plugin._video_delay_ms())
        except Exception:
            pass


class MediaGlowPlugin(BasePlugin):
    def __init__(self) -> None:
        super().__init__()
        self._hooks: List[Any] = []
        self._jobs: Dict[int, int] = {}
        self._bitmaps: Dict[int, Any] = {}
        self._previous_bitmaps: Dict[int, Any] = {}
        self._fade_started_at: Dict[int, float] = {}
        self._last_signature: Dict[int, str] = {}
        self._next_video_refresh_at: Dict[int, float] = {}
        self._poll_pending: Dict[int, bool] = {}
        self._capture_pending: Dict[int, bool] = {}
        self._disposed = False
        self._draw_paint: Optional[Any] = None
        self._draw_src_rect: Optional[Any] = None
        self._draw_dst_rect: Optional[Any] = None
        self._lock = threading.RLock()

    def on_plugin_load(self) -> None:
        self._disposed = False
        self._install()

    def on_plugin_unload(self) -> None:
        self._disposed = True
        for ref in list(self._hooks):
            try:
                self.unhook_method(ref)
            except Exception:
                pass
        self._hooks = []
        self._jobs = {}
        self._last_signature = {}
        self._next_video_refresh_at = {}
        self._poll_pending = {}
        self._capture_pending = {}
        self._drop_bitmaps()
        self._draw_paint = None
        self._draw_src_rect = None
        self._draw_dst_rect = None
        run_on_ui_thread(self._clear_current)

    def create_settings(self) -> List[Any]:
        return [
            Switch(
                key=SETTING_ENABLED,
                text="включить подсветку",
                subtext="мягко заполняет края полноэкранных фото и видео размытым фоном",
                default=True,
                icon="msg_photo_blur",
                on_change=lambda _v: run_on_ui_thread(self._refresh),
            ),
            Selector(
                key=SETTING_STRENGTH,
                text="сила подсветки",
                default=DEFAULT_STRENGTH,
                items=STRENGTH_ITEMS,
                icon="msg_brightness_high",
                on_change=lambda _v: run_on_ui_thread(self._refresh),
            ),
            Selector(
                key=SETTING_BLUR,
                text="размытие",
                default=DEFAULT_BLUR,
                items=BLUR_ITEMS,
                icon="msg_blur_radial",
                on_change=lambda _v: run_on_ui_thread(self._refresh),
            ),
            Selector(
                key=SETTING_TRANSITION,
                text="переход между медиа",
                default=DEFAULT_TRANSITION,
                items=TRANSITION_ITEMS,
                icon="msg_photo_curve",
                on_change=lambda _v: run_on_ui_thread(self._refresh),
            ),
            Input(
                key=SETTING_VIDEO_DELAY,
                text="задержка свечения",
                default=str(DEFAULT_VIDEO_DELAY_MS),
                subtext=f"для видео: чем меньше значение, тем чаще обновляется подсветка. минимум {MIN_VIDEO_DELAY_MS}мс",
                icon="msg_recent",
                on_change=lambda _v: run_on_ui_thread(self._refresh),
            ),
        ]

    def _install(self) -> None:
        photo_viewer = _to_class(find_class("org.telegram.ui.PhotoViewer"))
        if photo_viewer is None:
            self.log("PhotoViewer class not found")
            return

        index_hook = _IndexHook(self)
        for signature in (
            (Integer.TYPE,),
            (Integer.TYPE, Boolean.TYPE, Boolean.TYPE),
            (Integer.TYPE, Boolean.TYPE, Boolean.TYPE, Boolean.TYPE),
        ):
            try:
                method = photo_viewer.getDeclaredMethod("setImageIndex", *signature)
                method.setAccessible(True)
                ref = self.hook_method(method, index_hook)
                if ref is not None:
                    self._hooks.append(ref)
            except Exception:
                pass

        try:
            close_method = photo_viewer.getDeclaredMethod("closePhoto", Boolean.TYPE, Boolean.TYPE)
            close_method.setAccessible(True)
            ref = self.hook_method(close_method, _CloseHook(self))
            if ref is not None:
                self._hooks.append(ref)
        except Exception:
            pass

        try:
            canvas_class = _to_class(find_class("android.graphics.Canvas"))
            if canvas_class is None:
                self.log("Canvas class not found")
                return
            draw_method = photo_viewer.getDeclaredMethod("onDraw", canvas_class)
            draw_method.setAccessible(True)
            ref = self.hook_method(draw_method, _DrawHook(self), priority=100)
            if ref is not None:
                self._hooks.append(ref)
        except Exception as error:
            self.log(f"onDraw hook failed: {error}")

        try:
            methods = photo_viewer.getDeclaredMethods()
            for index in range(int(len(methods))):
                method = methods[index]
                method_name = str(method.getName())
                if method_name not in ("createVideoTextureView", "preparePlayer"):
                    continue
                method.setAccessible(True)
                hook = _TextureHook(self) if method_name == "createVideoTextureView" else _PrepareHook(self)
                ref = self.hook_method(method, hook)
                if ref is not None:
                    self._hooks.append(ref)
        except Exception:
            pass

    def force_texture(self, viewer: Any) -> None:
        if viewer is None:
            return
        try:
            set_private_field(viewer, "ALLOW_USE_SURFACE", Boolean.FALSE)
        except Exception:
            pass

    def schedule(self, viewer: Any) -> None:
        if self._disposed:
            return
        if not self.get_setting(SETTING_ENABLED, True):
            self.clear(viewer)
            return
        key = _key(viewer)
        if key == 0:
            return
        with self._lock:
            generation = self._jobs.get(key, 0) + 1
            self._jobs[key] = generation

        viewer_ref = WeakReference(viewer)
        for delay in (40, 260, 850, 1500):
            run_on_ui_thread(lambda r=viewer_ref, g=generation: self._capture_ref(r, g), delay)
        run_on_ui_thread(lambda r=viewer_ref: self._poll_ref(r, self._video_delay_ms()), MIN_VIDEO_DELAY_MS)

    def _capture_ref(self, viewer_ref: Any, generation: int) -> None:
        if self._disposed:
            return
        try:
            viewer = viewer_ref.get()
        except Exception:
            viewer = None
        if viewer is not None:
            self._capture(viewer, generation)

    def _capture(self, viewer: Any, generation: int) -> None:
        if self._disposed:
            return
        key = _key(viewer)
        with self._lock:
            if self._jobs.get(key) != generation:
                return
            if self._capture_pending.get(key):
                return
            self._capture_pending[key] = True

        if not self.get_setting(SETTING_ENABLED, True):
            with self._lock:
                self._capture_pending.pop(key, None)
            self.clear(viewer)
            return

        if self._container(viewer) is None:
            with self._lock:
                self._capture_pending.pop(key, None)
            return

        source = self._grab_source(viewer)
        if source is None:
            with self._lock:
                self._capture_pending.pop(key, None)
            if self._should_poll(viewer):
                self.poll_video(viewer, self._video_delay_ms())
            return

        signature = self._signature(source)
        if self._should_poll(viewer):
            signature = f"{signature}:video:{generation}"
        with self._lock:
            if self._last_signature.get(key) == signature:
                self._capture_pending.pop(key, None)
                try:
                    source.recycle()
                except Exception:
                    pass
                return
            self._last_signature[key] = signature

        viewer_ref = WeakReference(viewer)
        radius = self._radius()
        run_on_queue(lambda: self._blur_async(viewer_ref, key, generation, source, radius), PLUGINS_QUEUE)

    def _blur_async(self, viewer_ref: Any, key: int, generation: int, bitmap: Any, blur_radius: int) -> None:
        try:
            if self._disposed:
                try:
                    bitmap.recycle()
                except Exception:
                    pass
                return
            result = _make_glow(bitmap, blur_radius)
            if result is None:
                with self._lock:
                    self._capture_pending.pop(key, None)
                return
            run_on_ui_thread(lambda r=viewer_ref, b=result: self._apply_ref(r, key, generation, b))
        except Exception:
            with self._lock:
                self._capture_pending.pop(key, None)
            pass

    def _apply_ref(self, viewer_ref: Any, key: int, generation: int, bitmap: Any) -> None:
        if self._disposed:
            with self._lock:
                self._capture_pending.pop(key, None)
            try:
                bitmap.recycle()
            except Exception:
                pass
            return
        try:
            viewer = viewer_ref.get()
        except Exception:
            viewer = None
        if viewer is None:
            with self._lock:
                self._capture_pending.pop(key, None)
            try:
                bitmap.recycle()
            except Exception:
                pass
            return
        self._apply(viewer, key, generation, bitmap)

    def _apply(self, viewer: Any, key: int, generation: int, bitmap: Any) -> None:
        if self._disposed:
            try:
                bitmap.recycle()
            except Exception:
                pass
            return
        with self._lock:
            self._capture_pending.pop(key, None)
            if self._jobs.get(key) != generation:
                try:
                    bitmap.recycle()
                except Exception:
                    pass
                return

        try:
            old = None
            recycle_after = []
            is_video = self._should_poll(viewer)
            with self._lock:
                old = self._bitmaps.get(key)
                if old is not None and is_video:
                    old_previous = self._previous_bitmaps.pop(key, None)
                    previous = old
                    if old_previous is not None:
                        if self._use_video_crossfade():
                            started_at = self._fade_started_at.get(key)
                            if started_at is not None:
                                linear = (time.monotonic() - started_at) / self._video_fade()
                                mixed = _blend_glows(old_previous, old, _ease_in_out(linear))
                                if mixed is not None:
                                    previous = mixed
                                    recycle_after.append(old)
                        recycle_after.append(old_previous)

                    target = _blend_glows(previous, bitmap, self._video_blend_alpha())
                    if target is not None:
                        self._bitmaps[key] = target
                        recycle_after.append(bitmap)
                    else:
                        self._bitmaps[key] = bitmap
                    if self._use_video_crossfade():
                        self._previous_bitmaps[key] = previous
                        self._fade_started_at[key] = time.monotonic()
                    else:
                        recycle_after.append(previous)
                        self._fade_started_at.pop(key, None)
                        previous = None
                else:
                    self._bitmaps[key] = bitmap
                if old is not None and not is_video:
                    previous = old
                    old_previous = self._previous_bitmaps.pop(key, None)
                    started_at = self._fade_started_at.get(key)
                    if old_previous is not None and started_at is not None:
                        duration = self._fade(viewer)
                        linear = (time.monotonic() - started_at) / duration
                        mixed = _blend_glows(old_previous, old, _ease_in_out(linear))
                        if mixed is not None:
                            previous = mixed
                            recycle_after.append(old)
                        recycle_after.append(old_previous)
                    elif old_previous is not None:
                        recycle_after.append(old_previous)
                    self._previous_bitmaps[key] = previous
                    self._fade_started_at[key] = time.monotonic()
                elif old is None:
                    previous = self._previous_bitmaps.pop(key, None)
                    if previous is not None:
                        self._previous_bitmaps[key] = previous
                    self._fade_started_at[key] = time.monotonic()
                active_bitmap = self._bitmaps.get(key)
            for item in recycle_after:
                try:
                    if item is not None and item is not active_bitmap and item is not previous:
                        item.recycle()
                except Exception:
                    pass
            target = self._container(viewer) or self._window(viewer)
            if target is not None:
                target.invalidate()
            if self._should_poll(viewer):
                self.poll_video(viewer, self._video_delay_ms())
        except Exception:
            pass

    def clear(self, viewer: Any) -> None:
        key = _key(viewer)
        with self._lock:
            bitmap = self._bitmaps.pop(key, None)
            previous = self._previous_bitmaps.pop(key, None)
            self._fade_started_at.pop(key, None)
            self._last_signature.pop(key, None)
            self._next_video_refresh_at.pop(key, None)
            self._poll_pending.pop(key, None)
            self._capture_pending.pop(key, None)
        for item in (bitmap, previous):
            try:
                if item is not None:
                    item.recycle()
            except Exception:
                pass

    def draw(self, viewer: Any, canvas: Any) -> None:
        if self._disposed:
            return
        if not self.get_setting(SETTING_ENABLED, True):
            return
        key = _key(viewer)
        with self._lock:
            bitmap = self._bitmaps.get(key)
            previous = self._previous_bitmaps.get(key)
            started_at = self._fade_started_at.get(key)
        if bitmap is None:
            return
        try:
            progress = 1.0
            if started_at is not None:
                duration = self._fade(viewer)
                progress = _ease_in_out((time.monotonic() - started_at) / duration)
            canvas_w = int(canvas.getWidth())
            canvas_h = int(canvas.getHeight())
            if canvas_w <= 0 or canvas_h <= 0:
                return
            base_alpha = self._alpha()
            if previous is not None and progress < 1.0:
                self._draw_cover(canvas, previous, canvas_w, canvas_h, base_alpha * (1.0 - progress))
            self._draw_cover(canvas, bitmap, canvas_w, canvas_h, base_alpha * progress)
            if started_at is not None:
                target = self._container(viewer) or self._window(viewer)
                if progress >= 1.0:
                    with self._lock:
                        if self._fade_started_at.get(key) == started_at:
                            old_previous = self._previous_bitmaps.pop(key, None)
                            self._fade_started_at.pop(key, None)
                        else:
                            old_previous = None
                    try:
                        if old_previous is not None:
                            old_previous.recycle()
                    except Exception:
                        pass
                elif target is not None:
                    target.invalidate()
            self._tick_video(viewer, key)
        except Exception:
            pass

    def _draw_cover(self, canvas: Any, bitmap: Any, canvas_w: int, canvas_h: int, alpha: float) -> None:
        bitmap_w = int(bitmap.getWidth())
        bitmap_h = int(bitmap.getHeight())
        if bitmap_w <= 0 or bitmap_h <= 0 or alpha <= 0:
            return
        scale = max(float(canvas_w) / float(bitmap_w), float(canvas_h) / float(bitmap_h))
        draw_w = bitmap_w * scale
        draw_h = bitmap_h * scale
        left = (canvas_w - draw_w) / 2.0
        top = (canvas_h - draw_h) / 2.0
        paint = self._draw_paint
        if paint is None:
            paint = Paint()
            self._draw_paint = paint
        paint.setAntiAlias(True)
        paint.setFilterBitmap(True)
        paint.setAlpha(max(0, min(255, int(255 * alpha))))
        src = self._draw_src_rect
        if src is None:
            src = Rect()
            self._draw_src_rect = src
        src.set(0, 0, bitmap_w, bitmap_h)
        dst = self._draw_dst_rect
        if dst is None:
            dst = RectF()
            self._draw_dst_rect = dst
        dst.set(float(left), float(top), float(left + draw_w), float(top + draw_h))
        canvas.drawBitmap(bitmap, src, dst, paint)

    def _tick_video(self, viewer: Any, key: int) -> None:
        if self._disposed:
            return
        if not self._should_poll(viewer):
            return
        now = time.monotonic()
        with self._lock:
            if self._poll_pending.get(key):
                return
            if self._capture_pending.get(key):
                return
            next_at = self._next_video_refresh_at.get(key, 0.0)
            if now < next_at:
                return
            self._next_video_refresh_at[key] = now + (self._video_delay_ms() / 1000.0)
            generation = self._jobs.get(key, 0) + 1
            self._jobs[key] = generation
        self._capture(viewer, generation)

    def poll_video(self, viewer: Any, delay_ms: int = 450) -> None:
        if self._disposed:
            return
        if not self.get_setting(SETTING_ENABLED, True):
            return
        if not self._should_poll(viewer):
            return
        key = _key(viewer)
        if key == 0:
            return
        with self._lock:
            if self._poll_pending.get(key):
                return
            self._poll_pending[key] = True
        viewer_ref = WeakReference(viewer)
        run_on_ui_thread(lambda r=viewer_ref, k=key: self._run_poll(r, k), max(MIN_VIDEO_DELAY_MS, int(delay_ms)))

    def _poll_ref(self, viewer_ref: Any, delay_ms: int) -> None:
        if self._disposed:
            return
        try:
            viewer = viewer_ref.get()
        except Exception:
            viewer = None
        if viewer is not None:
            self.poll_video(viewer, delay_ms)

    def _run_poll(self, viewer_ref: Any, key: int) -> None:
        with self._lock:
            self._poll_pending.pop(key, None)
        if self._disposed:
            return
        try:
            viewer = viewer_ref.get()
        except Exception:
            viewer = None
        if viewer is None:
            return
        if not self.get_setting(SETTING_ENABLED, True):
            return
        if not self._should_poll(viewer):
            return
        retry_delay = None
        with self._lock:
            if self._capture_pending.get(key):
                retry_delay = self._video_delay_ms()
            else:
                generation = self._jobs.get(key, 0) + 1
                self._jobs[key] = generation
        if retry_delay is not None:
            self.poll_video(viewer, retry_delay)
            return
        self._capture(viewer, generation)

    def _grab_source(self, viewer: Any) -> Optional[Any]:
        bitmap = self._grab_video(viewer)
        if bitmap is not None:
            return bitmap
        if self._should_poll(viewer):
            return None
        return self._grab_image(viewer)

    def _grab_video(self, viewer: Any) -> Optional[Any]:
        try:
            texture_view = self._texture_view(viewer)
            if texture_view is None or not self._view_ready(texture_view):
                return None
            width = int(texture_view.getWidth())
            height = int(texture_view.getHeight())
            scale = min(1.0, 420.0 / float(max(width, height)))
            target_w = max(16, int(width * scale))
            target_h = max(16, int(height * scale))
            frame = texture_view.getBitmap(target_w, target_h)
            result = _copy_bitmap(frame)
            try:
                if frame is not None and frame is not result:
                    frame.recycle()
            except Exception:
                pass
            return result
        except Exception:
            return None

    def _video_visible(self, viewer: Any) -> bool:
        try:
            return self._view_ready(self._texture_view(viewer))
        except Exception:
            return False

    def _should_poll(self, viewer: Any) -> bool:
        if self._video_visible(viewer):
            return True
        return self._video_active(viewer)

    def _texture_view(self, viewer: Any) -> Optional[Any]:
        for field_name in ("changedTextureView", "videoTextureView"):
            try:
                texture_view = get_private_field(viewer, field_name)
                if self._view_ready(texture_view):
                    return texture_view
            except Exception:
                pass
        try:
            texture_view = viewer.getVideoTextureView()
            if self._view_ready(texture_view):
                return texture_view
        except Exception:
            pass
        return None

    def _video_active(self, viewer: Any) -> bool:
        for field_name in ("isCurrentVideo", "videoSizeSet", "textureUploaded"):
            try:
                if not bool(get_private_field(viewer, field_name)):
                    return False
            except Exception:
                pass
        try:
            layout = get_private_field(viewer, "aspectRatioFrameLayout")
            if layout is not None and layout.getVisibility() != View.VISIBLE:
                return False
        except Exception:
            pass
        return True

    def _view_ready(self, view: Any) -> bool:
        if view is None:
            return False
        try:
            if int(view.getWidth()) <= 0 or int(view.getHeight()) <= 0:
                return False
        except Exception:
            return False
        try:
            if view.getVisibility() == View.VISIBLE:
                return True
        except Exception:
            pass
        try:
            return bool(view.isAvailable())
        except Exception:
            return False

    def _grab_image(self, viewer: Any) -> Optional[Any]:
        try:
            image = get_private_field(viewer, "centerImage")
            if image is None:
                return None
            bitmap = None
            for method_name in ("getBitmap", "getBitmapSafe"):
                try:
                    candidate = getattr(image, method_name)()
                    if candidate is not None:
                        bitmap = candidate
                        break
                except Exception:
                    continue
            return _copy_bitmap(bitmap)
        except Exception:
            return None

    def _window(self, viewer: Any) -> Optional[Any]:
        if viewer is None:
            return None
        try:
            window_view = getattr(viewer, "windowView", None)
            if window_view is not None:
                return window_view
        except Exception:
            pass
        try:
            return get_private_field(viewer, "windowView")
        except Exception:
            return None

    def _container(self, viewer: Any) -> Optional[Any]:
        if viewer is None:
            return None
        try:
            container_view = getattr(viewer, "containerView", None)
            if container_view is not None:
                return container_view
        except Exception:
            pass
        try:
            return get_private_field(viewer, "containerView")
        except Exception:
            return None

    def _refresh(self) -> None:
        if self._disposed:
            return
        viewer = self._viewer()
        if viewer is not None:
            key = _key(viewer)
            with self._lock:
                self._last_signature.pop(key, None)
                self._next_video_refresh_at.pop(key, None)
                self._poll_pending.pop(key, None)
            self.schedule(viewer)

    def _clear_current(self) -> None:
        viewer = self._viewer()
        if viewer is not None:
            self.clear(viewer)

    def _viewer(self) -> Optional[Any]:
        try:
            photo_viewer = _to_class(find_class("org.telegram.ui.PhotoViewer"))
            if photo_viewer is None:
                return None
            method = photo_viewer.getDeclaredMethod("getInstance")
            method.setAccessible(True)
            return method.invoke(None)
        except Exception:
            return None

    def _drop_bitmaps(self) -> None:
        with self._lock:
            bitmaps = list(self._bitmaps.values()) + list(self._previous_bitmaps.values())
            self._bitmaps.clear()
            self._previous_bitmaps.clear()
            self._fade_started_at.clear()
        for bitmap in bitmaps:
            try:
                if bitmap is not None:
                    bitmap.recycle()
            except Exception:
                pass

    def _signature(self, bitmap: Any) -> str:
        try:
            width = int(bitmap.getWidth())
            height = int(bitmap.getHeight())
            points = [
                (width // 2, height // 2),
                (max(0, width // 6), max(0, height // 6)),
                (max(0, width - width // 6 - 1), max(0, height // 6)),
                (max(0, width // 6), max(0, height - height // 6 - 1)),
                (max(0, width - width // 6 - 1), max(0, height - height // 6 - 1)),
            ]
            colors = []
            for x, y in points:
                try:
                    colors.append(str(bitmap.getPixel(x, y)))
                except Exception:
                    colors.append("0")
            return f"{width}x{height}:{':'.join(colors)}"
        except Exception:
            return str(id(bitmap))

    def _alpha(self) -> float:
        index = _as_int(self.get_setting(SETTING_STRENGTH, DEFAULT_STRENGTH), DEFAULT_STRENGTH)
        return [0.42, 0.62, 0.82][max(0, min(index, 2))]

    def _radius(self) -> int:
        index = _as_int(self.get_setting(SETTING_BLUR, DEFAULT_BLUR), DEFAULT_BLUR)
        return [22, 36, 52][max(0, min(index, 2))]

    def _fade(self, viewer: Any = None) -> float:
        index = _as_int(self.get_setting(SETTING_TRANSITION, DEFAULT_TRANSITION), DEFAULT_TRANSITION)
        duration = [0.18, 0.35, 0.65][max(0, min(index, 2))]
        if viewer is not None and self._should_poll(viewer):
            return self._video_fade()
        return duration

    def _video_delay_ms(self) -> int:
        value = _as_int(self.get_setting(SETTING_VIDEO_DELAY, DEFAULT_VIDEO_DELAY_MS), DEFAULT_VIDEO_DELAY_MS)
        return max(MIN_VIDEO_DELAY_MS, value)

    def _video_blend_alpha(self) -> float:
        delay = float(self._video_delay_ms())
        if self._use_video_crossfade():
            return max(0.16, min(0.34, delay / 900.0))
        return max(0.08, min(0.22, delay / 640.0))

    def _video_fade(self) -> float:
        delay = float(self._video_delay_ms()) / 1000.0
        return max(0.10, min(0.28, delay * 1.6))

    def _use_video_crossfade(self) -> bool:
        return self._video_delay_ms() >= VIDEO_CROSSFADE_MIN_MS
