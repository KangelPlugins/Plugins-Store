import base64
import zlib

from base_plugin import BasePlugin
from java import jclass
from org.telegram.messenger import ApplicationLoader

__id__ = "local_gift_hider"
__name__ = "Local Gift Hider"
__description__ = "Локально скрывает подарки из личного профиля."
__author__ = "@kvucoplugins"
__version__ = "1.1.0"
__icon__ = "Jingliunation_by_fStikBot/93"
__app_version__ = ">=12.5.1"
__sdk_version__ = ">=1.4.0"

ENTRY_CLASS = "com.extera.plugins.localgifthider.LocalGiftHiderBridge"
DEX_BEGIN = "__DEX_BEGIN__"
DEX_END = "__DEX_END__"
BuildVersion = jclass("android.os.Build$VERSION")


class Dex:
    def __init__(self, entry_class):
        self.entry_class = entry_class
        self.clazz = None
        self.loaded = False

    def load(self):
        if self.loaded:
            return
        if self.clazz is None:
            context = ApplicationLoader.applicationContext
            if context is None:
                raise RuntimeError("application context is not ready")
            if int(BuildVersion.SDK_INT) < 26:
                raise RuntimeError("embedded DEX requires Android API 26+")
            ByteBuffer = jclass("java.nio.ByteBuffer")
            InMemoryDexClassLoader = jclass("dalvik.system.InMemoryDexClassLoader")
            loader = InMemoryDexClassLoader(
                ByteBuffer.wrap(self._read_payload()),
                context.getClassLoader(),
            )
            self.clazz = loader.loadClass(self.entry_class)
        try:
            self._invoke("load")
            self.loaded = True
        except Exception as load_error:
            try:
                self._invoke("unload")
            except Exception as cleanup_error:
                self.loaded = False
                raise RuntimeError(
                    "DEX load failed and cleanup also failed: "
                    f"{load_error}; cleanup: {cleanup_error}"
                ) from cleanup_error
            self.loaded = False
            raise

    def unload(self):
        if self.clazz is None or not self.loaded:
            return
        self._invoke("unload")
        self.loaded = False

    def _invoke(self, method_name, *args):
        if self.clazz is None:
            raise RuntimeError("embedded DEX class is not loaded")
        matches = []
        for method in self.clazz.getDeclaredMethods():
            if str(method.getName()) != method_name:
                continue
            if len(method.getParameterTypes()) != len(args):
                continue
            method.setAccessible(True)
            matches.append(method)
        if len(matches) > 1:
            raise RuntimeError(f"ambiguous core method: {method_name}/{len(args)}")
        if matches:
            return matches[0].invoke(None, *args)
        raise RuntimeError(f"core method not found: {method_name}/{len(args)}")

    def _read_payload(self):
        try:
            with open(__file__, "r", encoding="utf-8") as source:
                text = source.read()
            block = text.split(f"# {DEX_BEGIN}", 1)[1].split(
                f"# {DEX_END}", 1
            )[0]
            payload = "".join(
                line.strip()[1:].strip()
                for line in block.splitlines()
                if line.strip().startswith("#")
            )
        except Exception as exc:
            raise RuntimeError(f"embedded dex read failed: {exc}")
        if not payload:
            raise RuntimeError("embedded dex payload not found")
        try:
            return zlib.decompress(base64.b64decode(payload))
        except Exception as exc:
            raise RuntimeError(f"embedded dex decode failed: {exc}")


class LocalGiftHiderPlugin(BasePlugin):
    def __init__(self):
        super().__init__()
        self.dex = Dex(ENTRY_CLASS)

    def on_plugin_load(self):
        try:
            self.dex.load()
        except Exception as exc:
            try:
                self.dex.unload()
            except Exception as cleanup_error:
                self.log(f"Ошибка очистки после сбоя загрузки DEX: {cleanup_error}")
            self.log(f"Не удалось загрузить DEX: {exc}")
            raise

    def on_plugin_unload(self):
        try:
            self.dex.unload()
        except Exception as exc:
            self.log(f"Ошибка выгрузки DEX: {exc}")


# __DEX_BEGIN__
# 
# __DEX_END__
