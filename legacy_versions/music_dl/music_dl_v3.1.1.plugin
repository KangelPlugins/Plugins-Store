# ─────────────────────────────────────────────────────────────────────────────
SC_API = "https://api-v2.soundcloud.com"
SC_HEADERS = {
    "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
    "Accept": "application/json, text/javascript, */*; q=0.01",
    "Origin": "https://soundcloud.com",
    "Referer": "https://soundcloud.com/",
}

STOP_WORDS = {
    "the", "a", "an", "and", "or", "of", "in", "on", "to", "for", "with", "feat",
    "ft", "mix", "remix", "edit", "radio", "version", "official", "audio", "lyrics",
    "music", "track", "song", "full", "hd", "video",
}

_sc_client_id = None
_search_sessions: dict = {}   # peer_id → session dict
_locks = {
    "likes": threading.Lock(),
    "update": threading.Lock(),
}


def _sc_get(url: str, *, fallback_insecure: bool = True, **kwargs):
    try:
        return requests.get(url, **kwargs)
    except SSLError:
        if not fallback_insecure:
            raise
        kwargs = dict(kwargs)
        kwargs["verify"] = False
        return requests.get(url, **kwargs)


# ─── small utils ─────────────────────────────────────────────────────────────

def _now_ts() -> int:
    return int(time.time())


def _safe_text(value: Any) -> str:
    return "" if value is None else str(value)


def _normalize(text: str) -> str:
    text = _safe_text(text).lower()
    text = re.sub(r"[\[\]()<>{}_~`*!?.,:;\"'\\/|+=\-]", " ", text)
    text = re.sub(r"\s+", " ", text).strip()
    return text


def _tokens(text: str) -> List[str]:
    out = []
    for token in _normalize(text).split():
        if token and token not in STOP_WORDS and len(token) > 1:
            out.append(token)
    return out


def _version_tuple(value: str) -> Tuple[int, ...]:
    parts = re.findall(r"\d+", value or "")
    return tuple(int(p) for p in parts[:4]) or (0,)


def _dedupe_tracks(tracks: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
    seen = set()
    out = []
    for track in tracks:
        tid = track.get("id")
        if tid in seen:
            continue
        seen.add(tid)
        out.append(track)
    return out


# ─── SoundCloud ───────────────────────────────────────────────────────────────

def get_sc_client_id():
    global _sc_client_id
    if _sc_client_id:
        return _sc_client_id
    try:
        resp = _sc_get("https://soundcloud.com", headers=SC_HEADERS, timeout=10)
        js_urls = re.findall(r'"(https://a-v2\.sndcdn\.com/assets/[^"]+\.js)"', resp.text)
        for url in reversed(js_urls):
            try:
                js = _sc_get(url, headers=SC_HEADERS, timeout=10)
                match = re.search(r'client_id\s*:\s*"([a-zA-Z0-9]{32})"', js.text)
                if not match:
                    match = re.search(r'"client_id"\s*,\s*"([a-zA-Z0-9]{32})"', js.text)
                if match:
                    _sc_client_id = match.group(1)
                    return _sc_client_id
            except Exception:
                continue
    except Exception:
        pass
    return None


def _track_blob(track: Dict[str, Any]) -> str:
    return " | ".join(
        x for x in [
            track.get("title", ""),
            track.get("artist", ""),
            track.get("genre", ""),
            track.get("year", ""),
        ] if x
    )


def _base_score(query: str, track: Dict[str, Any]) -> float:
    q = _normalize(query)
    if not q:
        return 0.0

    title = _normalize(track.get("title", ""))
    artist = _normalize(track.get("artist", ""))
    genre = _normalize(track.get("genre", ""))
    combo = " ".join(x for x in [title, artist, genre] if x)

    q_tokens = set(_tokens(query))
    c_tokens = set(_tokens(combo))
    overlap = len(q_tokens & c_tokens) / max(1, len(q_tokens))

    score = 0.0
    if q == combo:
        score += 10.0
    if q in title:
        score += 4.0
    if q in artist:
        score += 2.5
    if q in combo:
        score += 1.5
    if q_tokens:
        score += overlap * 4.0

    score += SequenceMatcher(None, q, combo).ratio() * 3.5
    score += SequenceMatcher(None, q, title).ratio() * 1.6
    score += SequenceMatcher(None, q, artist).ratio() * 1.2

    # tiny bump for visible activity
    score += min(track.get("plays", 0) or 0, 250000) / 250000.0
    score += min(track.get("likes", 0) or 0, 100000) / 50000.0

    return score


def _profile_score(track: Dict[str, Any], liked_tracks: List[Dict[str, Any]]) -> float:
    if not liked_tracks:
        return 0.0

    track_blob = _track_blob(track)
    track_tokens = set(_tokens(track_blob))
    best = 0.0

    for liked in liked_tracks:
        liked_blob = _track_blob(liked)
        liked_tokens = set(_tokens(liked_blob))
        if not liked_tokens:
            continue

        overlap = len(track_tokens & liked_tokens) / max(1, len(track_tokens | liked_tokens))
        similarity = SequenceMatcher(None, _normalize(track_blob), _normalize(liked_blob)).ratio()
        score = overlap * 6.0 + similarity * 4.0

        if liked.get("genre") and track.get("genre") and _normalize(liked["genre"]) == _normalize(track["genre"]):
            score += 1.25

        best = max(best, score)

    return best


def sc_search(query, limit=20):
    client_id = get_sc_client_id()
    if not client_id:
        return [], "❌ Не удалось получить SoundCloud client_id"

    try:
        limit = max(1, min(int(limit), 50))
        resp = _sc_get(
            f"{SC_API}/search/tracks",
            params={
                "q": query,
                "limit": limit,
                "client_id": client_id,
                "app_version": "1735820463",
            },
            headers=SC_HEADERS,
            timeout=10,
        )
        tracks = resp.json().get("collection", [])
        results = []
        for t in tracks:
            dur_ms = t.get("duration", 0)
            duration = f"{dur_ms // 60000}:{(dur_ms % 60000) // 1000:02d}" if dur_ms else ""
            if t.get("id") and t.get("streamable") and t.get("policy") != "BLOCK":
                results.append({
                    "title": t.get("title", ""),
                    "artist": t.get("user", {}).get("username", ""),
                    "duration": duration,
                    "id": t.get("id"),
                    "artwork_url": (t.get("artwork_url") or "").replace("large", "t200x200"),
                    "genre": t.get("genre", ""),
                    "year": (t.get("created_at") or "")[:4],
                    "plays": t.get("playback_count", 0),
                    "likes": t.get("likes_count", 0),
                    "_query_score": 0.0,
                })

        results = _dedupe_tracks(results)
        for t in results:
            t["_query_score"] = _base_score(query, t)

        results.sort(key=lambda x: x.get("_query_score", 0.0), reverse=True)
        return results, None
    except Exception as e:
        return [], f"❌ Ошибка поиска: {e}"


def get_stream_url(track_id):
    client_id = get_sc_client_id()
    if not client_id:
        return None, "нет client_id"
    try:
        resp = _sc_get(
            f"{SC_API}/tracks/{track_id}",
            params={"client_id": client_id},
            headers=SC_HEADERS,
            timeout=10,
        )
        transcodings = resp.json().get("media", {}).get("transcodings", [])
        mp3_url = None
        for tc in transcodings:
            fmt = tc.get("format", {})
            if fmt.get("mime_type") == "audio/mpeg" and fmt.get("protocol") == "progressive":
                mp3_url = tc.get("url")
                break
        if not mp3_url:
            for tc in transcodings:
                if "mp3" in tc.get("url", ""):
                    mp3_url = tc.get("url")
                    break
        if not mp3_url:
            return None, f"нет mp3 (форматов: {len(transcodings)})"
        final = _sc_get(
            mp3_url,
            params={"client_id": client_id},
            headers=SC_HEADERS,
            timeout=10,
        ).json().get("url")
        return (final, None) if final else (None, "нет url в ответе")
    except Exception as e:
        return None, str(e)


def download_file(url, path):
    try:
        with _sc_get(url, headers=SC_HEADERS, stream=True, timeout=120) as r:
            r.raise_for_status()
            with open(path, "wb") as f:
                for chunk in r.iter_content(chunk_size=65536):
                    if chunk:
                        f.write(chunk)
        return True
    except Exception:
        return False


def fetch_artwork(url):
    if not url:
        return None
    try:
        resp = _sc_get(url, timeout=8)
        resp.raise_for_status()
        img = Image.open(io.BytesIO(resp.content)).convert("RGB")
        buf = io.BytesIO()
        img.save(buf, format="JPEG", quality=85)
        return buf.getvalue()
    except Exception:
        return None


# ─── ID3 (pure Python) ────────────────────────────────────────────────────────

def _syncsafe(n):
    r = bytearray(4)
    for i in range(3, -1, -1):
        r[i] = n & 0x7F
        n >>= 7
    return bytes(r)


def _frame(fid, data):
    return fid.encode() + struct.pack(">I", len(data)) + b"\x00\x00" + data


def _tf(fid, text):
    return _frame(fid, b"\x03" + text.encode("utf-8"))


def _apic(jpeg):
    return _frame("APIC", b"\x03image/jpeg\x00\x03\x00" + jpeg)


def write_id3(path, title, artist, performer_tag, genre, year, artwork):
    try:
        frames = b""
        frames += _tf("TIT2", title)
        frames += _tf("TPE1", performer_tag)
        frames += _tf("TPE2", artist)
        if genre:
            frames += _tf("TCON", genre)
        if year:
            frames += _tf("TDRC", year)
        frames += _tf("TENC", "music_dl")
        if artwork:
            frames += _apic(artwork)

        header = b"ID3\x03\x00\x00" + _syncsafe(len(frames))
        with open(path, "rb") as f:
            mp3 = f.read()
        if mp3[:3] == b"ID3":
            old = ((mp3[6] & 0x7F) << 21 | (mp3[7] & 0x7F) << 14 | (mp3[8] & 0x7F) << 7 | (mp3[9] & 0x7F))
            mp3 = mp3[10 + old:]
        with open(path, "wb") as f:
            f.write(header + frames + mp3)
    except Exception:
        pass


# ─── text builders ────────────────────────────────────────────────────────────

def build_page(results, page, per_page, query, show_stats, show_genre):
    total_pages = max(1, (len(results) + per_page - 1) // per_page)
    page = max(1, min(page, total_pages))
    start = (page - 1) * per_page
    chunk = results[start: start + per_page]

    lines = [
        "🎵 Music Downloader",
        f"🔎 «{query}»  •  стр. {page}/{total_pages}",
        "",
    ]
    for i, t in enumerate(chunk, start + 1):
        dur = f" [{t['duration']}]" if t["duration"] else ""
        extra = []
        if show_stats:
            if t.get("plays"):
                extra.append(f"▶{t['plays']:,}")
            if t.get("likes"):
                extra.append(f"♥{t['likes']:,}")
        if show_genre and t.get("genre"):
            extra.append(t["genre"])
        extra_txt = f"  ({' • '.join(extra)})" if extra else ""
        lines.append(f"{i}. {t['title']} — {t['artist']}{dur}{extra_txt}")

    lines.append("")
    lines.append(f"Лайк: .like [1–{start + len(chunk)}]  |  Скачивание: dlf [номер]")
    if total_pages > 1:
        lines.append("Листать: .fc next / .fc prev")
    lines.append("Меню сообщения: лайк, избранное, рекомендации, инфо")
    return "\n".join(lines)


def _format_track_line(track: Dict[str, Any], index: Optional[int] = None) -> str:
    dur = f" [{track.get('duration')}]" if track.get("duration") else ""
    prefix = f"{index}. " if index is not None else ""
    return f"{prefix}{track.get('title', '')} — {track.get('artist', '')}{dur}"


def _extract_peer_id(context: Dict[str, Any]):
    for key in ("dialog_id", "chatId", "userId", "peer", "dialogId"):
        if context.get(key) is not None:
            return context.get(key)
    return None


def _extract_first_listed_track(text: str) -> Optional[Tuple[str, str]]:
    if not text:
        return None
    for line in text.splitlines():
        m = re.match(r"^\s*\d+\.\s*(.+?)\s+—\s+(.+?)(?:\s+\[.*?\])?(?:\s+\(.*?\))?\s*$", line)
        if m:
            return m.group(1).strip(), m.group(2).strip()
    return None


