    # ── helpers ───────────────────────────────────────────────────────────────

    def _per_page(self):
        return [3, 5, 7, 10][self.get_setting("results_per_page", 1)]

    def _limit(self):
        return [10, 20, 30, 50][self.get_setting("search_limit", 1)]

    def _wm(self):
        return self.get_setting("watermark_user", "@s1mclick")

    def _performer(self, artist):
        return f"{artist} | dled by {self._wm()}"

    def _get_favorites(self) -> List[Dict[str, Any]]:
        value = self.get_setting("liked_tracks", [])
        return value if isinstance(value, list) else []

    def _save_favorites(self, items: List[Dict[str, Any]]) -> None:
        self.set_setting("liked_tracks", items, reload_settings=False)

    def _trim_favorites(self, items: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
        try:
            cap = int(self.get_setting("favorites_cap", "200"))
        except Exception:
            cap = 200
        cap = max(10, min(cap, 1000))
        return items[:cap]

    def _track_record(self, track: Dict[str, Any], query: str = "") -> Dict[str, Any]:
        return {
            "id": track.get("id"),
            "title": track.get("title", ""),
            "artist": track.get("artist", ""),
            "duration": track.get("duration", ""),
            "genre": track.get("genre", ""),
            "year": track.get("year", ""),
            "plays": track.get("plays", 0),
            "likes": track.get("likes", 0),
            "artwork_url": track.get("artwork_url", ""),
            "query": query,
            "liked_at": _now_ts(),
            "like_count": 1,
        }

    def _upsert_favorite(self, track: Dict[str, Any], query: str = "", delta: int = 1) -> Dict[str, Any]:
        with _locks["likes"]:
            favorites = self._get_favorites()
            tid = track.get("id")
            found = False
            for item in favorites:
                if item.get("id") == tid:
                    item["like_count"] = max(1, int(item.get("like_count", 1)) + delta)
                    item["liked_at"] = _now_ts()
                    item["title"] = track.get("title", item.get("title", ""))
                    item["artist"] = track.get("artist", item.get("artist", ""))
                    item["duration"] = track.get("duration", item.get("duration", ""))
                    item["genre"] = track.get("genre", item.get("genre", ""))
                    item["year"] = track.get("year", item.get("year", ""))
                    item["plays"] = track.get("plays", item.get("plays", 0))
                    item["likes"] = track.get("likes", item.get("likes", 0))
                    item["artwork_url"] = track.get("artwork_url", item.get("artwork_url", ""))
                    if query:
                        item["query"] = query
                    found = True
                    saved = item
                    break

            if not found:
                saved = self._track_record(track, query=query)
                favorites.insert(0, saved)

            favorites.sort(key=lambda x: (int(x.get("like_count", 1)), int(x.get("liked_at", 0))), reverse=True)
            favorites = self._trim_favorites(favorites)
            self._save_favorites(favorites)
            return saved

    def _remove_favorite(self, track_id: Any) -> bool:
        with _locks["likes"]:
            favorites = self._get_favorites()
            before = len(favorites)
            favorites = [x for x in favorites if x.get("id") != track_id]
            if len(favorites) == before:
                return False
            self._save_favorites(favorites)
            return True

    def _favorites_as_text(self, favorites: List[Dict[str, Any]], title: str) -> str:
        if not favorites:
            return f"{title}\n\nПока пусто."
        lines = [title, ""]
        for i, t in enumerate(favorites[:10], 1):
            cnt = int(t.get("like_count", 1))
            dur = f" [{t.get('duration')}]" if t.get("duration") else ""
            extra = []
            if t.get("genre"):
                extra.append(t["genre"])
            if t.get("year"):
                extra.append(t["year"])
            extra_txt = f"  ({' • '.join(extra)})" if extra else ""
            lines.append(f"{i}. {t.get('title', '')} — {t.get('artist', '')}{dur}  ×{cnt}{extra_txt}")
        return "\n".join(lines)

    def _warn_update_if_needed(self, peer_id) -> None:
        if not self.get_setting("auto_update_check", True):
            return

        url = _safe_text(self.get_setting("update_feed_url", "")).strip()
        if not url:
            return

        def task():
            with _locks["update"]:
                try:
                    last_notified = _safe_text(self.get_setting("last_update_notified", ""))
                    resp = _sc_get(url, timeout=8, headers=SC_HEADERS)
                    text = resp.text.strip()
                    latest = None
                    notes = ""

                    try:
                        payload = resp.json()
                        if isinstance(payload, dict):
                            latest = _safe_text(payload.get("version") or payload.get("latest") or payload.get("tag") or "").strip()
                            notes = _safe_text(payload.get("notes") or payload.get("changelog") or "").strip()
                    except Exception:
                        pass

                    if not latest:
                        latest = text.splitlines()[0].strip()

                    if not latest:
                        return

                    if _version_tuple(latest) <= _version_tuple(__version__):
                        return

                    if last_notified == latest:
                        return

                    msg = f"⚠️ Доступно обновление: {latest} (сейчас {__version__})"
                    if notes:
                        msg += f"\n{notes[:700]}"
                    send_text(peer_id, msg)
                    self.set_setting("last_update_notified", latest, reload_settings=False)
                except Exception:
                    return

        run_on_queue(task)

    def _do_download(self, peer_id, track):
        dur = f" [{track['duration']}]" if track.get("duration") else ""
        send_text(peer_id, f"⬇️ Скачиваю: {track['title']} — {track['artist']}{dur}")

        artwork_result = [None]

        def _fetch_art():
            if self.get_setting("send_artwork", True):
                artwork_result[0] = fetch_artwork(track.get("artwork_url", ""))

        art_thread = threading.Thread(target=_fetch_art, daemon=True)
        art_thread.start()

        stream_url, err = get_stream_url(track["id"])
        if not stream_url:
            send_text(peer_id, f"❌ Не удалось получить поток: {err}")
            return

        path = "/sdcard/Download/music_dl.mp3"
        try:
            if os.path.exists(path):
                os.remove(path)
        except Exception:
            pass

        if not download_file(stream_url, path):
            send_text(peer_id, "❌ Ошибка при скачивании файла")
            return

        art_thread.join(timeout=10)

        write_id3(
            path=path,
            title=track["title"],
            artist=track["artist"],
            performer_tag=self._performer(track["artist"]),
            genre=track.get("genre", ""),
            year=track.get("year", ""),
            artwork=artwork_result[0],
        )

        if self.get_setting("auto_like_downloads", True):
            self._upsert_favorite(track, query=track.get("query", "") or "", delta=1)

        caption = f"🎧 {track['title']} — {track['artist']}{dur}"
        if self.get_setting("show_dl_stats", True):
            if track.get("plays"):
                caption += f"\n▶ {track['plays']:,} прослушиваний"
            if track.get("likes"):
                caption += f"  ♥ {track['likes']:,} лайков"
            if track.get("genre"):
                caption += f"\n🎵 {track['genre']}"
        caption += f"\n\n♥ saved locally via music_dl"
        send_audio(peer_id, path, caption=caption)

    def _recommend_tracks(self, seed_tracks: List[Dict[str, Any]], limit: int = 10) -> Tuple[List[Dict[str, Any]], Optional[str]]:
        favorites = self._get_favorites()
        if not favorites and not seed_tracks:
            return [], "Сначала добавь несколько лайков."

        # Build a compact query profile from liked tracks.
        token_counter = Counter()
        for item in favorites[:25]:
            token_counter.update(_tokens(_track_blob(item)))

        if not token_counter and seed_tracks:
            for item in seed_tracks[:5]:
                token_counter.update(_tokens(_track_blob(item)))

        profile_tokens = [t for t, _ in token_counter.most_common(5)]
        profile_query = " ".join(profile_tokens).strip()

        candidate_sources: List[Dict[str, Any]] = []
        queries = []

        if profile_query:
            queries.append(profile_query)
        for item in favorites[:3]:
            q = " ".join(x for x in [item.get("artist", ""), item.get("title", "")] if x).strip()
            if q:
                queries.append(q)

        if seed_tracks:
            for item in seed_tracks[:2]:
                q = " ".join(x for x in [item.get("artist", ""), item.get("title", "")] if x).strip()
                if q:
                    queries.append(q)

        queries = list(dict.fromkeys(queries))  # preserve order, drop dupes

        for q in queries[:4]:
            results, _err = sc_search(q, limit=max(20, limit * 3))
            candidate_sources.extend(results)

        candidate_sources = _dedupe_tracks(candidate_sources)
        liked_ids = {x.get("id") for x in favorites}
        seed_blob = " ".join(_track_blob(x) for x in seed_tracks)

        scored = []
        for track in candidate_sources:
            if track.get("id") in liked_ids:
                continue

            score = 0.0
            score += _profile_score(track, favorites)
            if seed_tracks:
                score += SequenceMatcher(None, _normalize(_track_blob(track)), _normalize(seed_blob)).ratio() * 2.0
            if profile_query:
                score += _base_score(profile_query, track) * 0.35
            if track.get("plays"):
                score += min(track["plays"], 500000) / 500000.0
            scored.append((score, track))

        scored.sort(key=lambda x: x[0], reverse=True)
        out = []
        seen = set()
        for score, track in scored:
            tid = track.get("id")
            if tid in seen:
                continue
            seen.add(tid)
            track["_rec_score"] = score
            out.append(track)
            if len(out) >= limit:
                break

        if not out:
            return [], "Не удалось собрать рекомендации."
        return out, None

    def _handle_like_track(self, peer_id, track: Dict[str, Any], query: str = "", respond: bool = True):
        liked = self._upsert_favorite(track, query=query, delta=1)
        if respond:
            msg = f"♥ В избранное: {liked.get('title', '')} — {liked.get('artist', '')}"
            send_text(peer_id, msg)

    def _handle_unlike_track(self, peer_id, track_id: Any):
        if self._remove_favorite(track_id):
            send_text(peer_id, "🗑 Удалено из избранного")
        else:
            send_text(peer_id, "❌ Трек не найден в избранном")

    def _show_info(self, peer_id):
        favorites = self._get_favorites()
        total_likes = sum(int(x.get("like_count", 1)) for x in favorites)
        text = [
            "ℹ️ Music Downloader",
            f"Версия: {__version__}",
            f"Избранное: {len(favorites)}",
            f"Суммарно лайков: {total_likes}",
            "",
            "Команды:",
            ".find <название>",
            ".like [номер]",
            ".unlike [номер]",
            ".rec",
            ".info",
            "",
            "Меню:",
            "Music Downloader, Favorites, Recommendations, Check update",
        ]
        send_text(peer_id, "\n".join(text))
        self._warn_update_if_needed(peer_id)

    def _show_favorites(self, peer_id):
        favorites = self._get_favorites()
        favorites.sort(key=lambda x: (int(x.get("like_count", 1)), int(x.get("liked_at", 0))), reverse=True)
        send_text(peer_id, self._favorites_as_text(favorites, "⭐ Избранное"))
        self._warn_update_if_needed(peer_id)

    def _show_recommendations(self, peer_id):
        favorites = self._get_favorites()
        favorites.sort(key=lambda x: (int(x.get("like_count", 1)), int(x.get("liked_at", 0))), reverse=True)
        seeds = favorites[:5]
        recs, err = self._recommend_tracks(seeds, limit=10)
        if not recs:
            send_text(peer_id, err or "Нет рекомендаций")
            return

        lines = ["✨ Рекомендации", ""]
        for i, t in enumerate(recs, 1):
            dur = f" [{t['duration']}]" if t.get("duration") else ""
            score = t.get("_rec_score", 0.0)
            extra = []
            if t.get("genre"):
                extra.append(t["genre"])
            if t.get("plays"):
                extra.append(f"▶{t['plays']:,}")
            extra_txt = f"  ({' • '.join(extra)})" if extra else ""
            lines.append(f"{i}. {t.get('title', '')} — {t.get('artist', '')}{dur}  · {score:.2f}{extra_txt}")
        send_text(peer_id, "\n".join(lines))
        self._warn_update_if_needed(peer_id)

    def _check_update_now(self, peer_id):
        url = _safe_text(self.get_setting("update_feed_url", "")).strip()
        if not url:
            send_text(peer_id, "ℹ️ Сначала укажи URL обновлений в настройках")
            return

        def task():
            try:
                resp = requests.get(url, timeout=8, headers=SC_HEADERS)
                latest = None
                notes = ""

                try:
                    payload = resp.json()
                    if isinstance(payload, dict):
                        latest = _safe_text(payload.get("version") or payload.get("latest") or payload.get("tag") or "").strip()
                        notes = _safe_text(payload.get("notes") or payload.get("changelog") or "").strip()
                except Exception:
                    pass

                if not latest:
                    latest = resp.text.strip().splitlines()[0].strip()

                if not latest:
                    send_text(peer_id, "❌ Не удалось прочитать версию из feed")
                    return

                if _version_tuple(latest) > _version_tuple(__version__):
                    msg = f"⚠️ Доступно обновление: {latest} (сейчас {__version__})"
                    if notes:
                        msg += f"\n{notes[:700]}"
                    send_text(peer_id, msg)
                    self.set_setting("last_update_notified", latest, reload_settings=False)
                else:
                    send_text(peer_id, f"✅ Обновлений нет. Текущая версия: {__version__}")
            except Exception as e:
                send_text(peer_id, f"❌ Ошибка проверки обновления: {e}")

        run_on_queue(task)

    # ── menu handlers ─────────────────────────────────────────────────────────

    def handle_music_menu(self, context: Dict[str, Any]):
        peer_id = _extract_peer_id(context)
        if peer_id is None:
            return
        text = (
            "🎵 Music Downloader\n\n"
            "Поиск:\n"
            ".find <название>\n\n"
            "Лайки:\n"
            ".like [номер]\n"
            ".unlike [номер]\n\n"
            "Ещё:\n"
            ".rec\n"
            ".info"
        )
        send_text(peer_id, text)
        self._warn_update_if_needed(peer_id)

    def handle_favorites_menu(self, context: Dict[str, Any]):
        peer_id = _extract_peer_id(context)
        if peer_id is None:
            return
        self._show_favorites(peer_id)

    def handle_recommendations_menu(self, context: Dict[str, Any]):
        peer_id = _extract_peer_id(context)
        if peer_id is None:
            return
        self._show_recommendations(peer_id)

    def handle_update_menu(self, context: Dict[str, Any]):
        peer_id = _extract_peer_id(context)
        if peer_id is None:
            return
        self._check_update_now(peer_id)

    def handle_like_message_menu(self, context: Dict[str, Any]):
        peer_id = _extract_peer_id(context)
        if peer_id is None:
            return

        session = _search_sessions.get(peer_id)
        chosen = None
        query = ""

        if session and session.get("results"):
            text = _safe_text(context.get("message").messageText if context.get("message") else "")
            parsed = _extract_first_listed_track(text)
            if parsed:
                title, artist = parsed
                candidate_query = f"{artist} {title}".strip()
                results, _err = sc_search(candidate_query, limit=10)
                if results:
                    chosen = results[0]
                    query = candidate_query
            if chosen is None:
                chosen = session["results"][0]
                query = session.get("query", "")

        else:
            message = context.get("message")
            text = _safe_text(getattr(message, "messageText", "") or getattr(message, "caption", "") or "")
            parsed = _extract_first_listed_track(text)
            if parsed:
                title, artist = parsed
                candidate_query = f"{artist} {title}".strip()
                results, _err = sc_search(candidate_query, limit=10)
                if results:
                    chosen = results[0]
                    query = candidate_query

        if not chosen:
            send_text(peer_id, "❌ Не удалось определить трек для лайка")
            return

        self._handle_like_track(peer_id, chosen, query=query, respond=True)

    # ── command-like helpers ──────────────────────────────────────────────────

    def _like_by_number(self, peer_id, arg: str):
        session = _search_sessions.get(peer_id)
        if not session:
            send_text(peer_id, "❌ Нет активного поиска. Сначала используй .find")
            return

        if not arg:
            idx = 0
        else:
            if not arg.isdigit():
                send_text(peer_id, "Использование: .like [номер]")
                return
            idx = int(arg) - 1

        results = session["results"]
        if idx < 0 or idx >= len(results):
            send_text(peer_id, f"❌ Номер вне диапазона (1–{len(results)})")
            return

        self._handle_like_track(peer_id, results[idx], query=session.get("query", ""), respond=True)

    def _unlike_by_number(self, peer_id, arg: str):
        favorites = self._get_favorites()
        favorites.sort(key=lambda x: (int(x.get("like_count", 1)), int(x.get("liked_at", 0))), reverse=True)

        if not arg:
            idx = 0
        else:
            if not arg.isdigit():
                send_text(peer_id, "Использование: .unlike [номер]")
                return
            idx = int(arg) - 1

        if idx < 0 or idx >= len(favorites):
            send_text(peer_id, f"❌ Номер вне диапазона (1–{len(favorites)})")
            return

        self._handle_unlike_track(peer_id, favorites[idx].get("id"))

    # ── hook ──────────────────────────────────────────────────────────────────

    def on_send_message_hook(self, account: int, params: Any) -> HookResult:
        if not isinstance(params.message, str):
            return HookResult()

        msg = params.message.strip()
        peer_id = params.peer

        # .find
        if msg.startswith(".find"):
            query = msg[5:].strip()
            if not query:
                params.message = "Использование: .find <название>"
                return HookResult(strategy=HookStrategy.MODIFY, params=params)

            per_page = self._per_page()
            limit = self._limit()
            show_stats = self.get_setting("show_stats", True)
            show_genre = self.get_setting("show_genre", False)

            def search_task():
                results, err = sc_search(query, limit=limit)
                if not results:
                    send_text(peer_id, err or f"❌ Ничего не найдено: {query}")
                    return
                _search_sessions[peer_id] = {
                    "query": query,
                    "results": results,
                    "page": 1,
                    "per_page": per_page,
                    "show_stats": show_stats,
                    "show_genre": show_genre,
                }
                send_text(peer_id, build_page(results, 1, per_page, query, show_stats, show_genre))
                self._warn_update_if_needed(peer_id)

            run_on_queue(search_task)
            return HookResult(strategy=HookStrategy.CANCEL)

        # .fc next / .fc prev
        if msg.startswith(".fc"):
            arg = msg[3:].strip().lower()
            session = _search_sessions.get(peer_id)

            if not session:
                params.message = "❌ Нет активного поиска. Сначала используй .find"
                return HookResult(strategy=HookStrategy.MODIFY, params=params)
            if arg not in ("next", "prev", "previous"):
                params.message = "Использование: .fc next / .fc prev"
                return HookResult(strategy=HookStrategy.MODIFY, params=params)

            results = session["results"]
            per_page = session["per_page"]
            total_pgs = max(1, (len(results) + per_page - 1) // per_page)
            new_page = session["page"] + (1 if arg == "next" else -1)

            if new_page < 1:
                params.message = "❌ Это первая страница"
                return HookResult(strategy=HookStrategy.MODIFY, params=params)
            if new_page > total_pgs:
                params.message = "❌ Больше страниц нет"
                return HookResult(strategy=HookStrategy.MODIFY, params=params)

            session["page"] = new_page
            text = build_page(
                results,
                new_page,
                per_page,
                session["query"],
                session["show_stats"],
                session["show_genre"],
            )

            def fc_task():
                send_text(peer_id, text)

            run_on_queue(fc_task)
            return HookResult(strategy=HookStrategy.CANCEL)

        # .like
        if msg.lower().startswith(".like"):
            arg = msg[5:].strip()
            def like_task():
                self._like_by_number(peer_id, arg)
            run_on_queue(like_task)
            return HookResult(strategy=HookStrategy.CANCEL)

        # .unlike
        if msg.lower().startswith(".unlike"):
            arg = msg[7:].strip()
            def unlike_task():
                self._unlike_by_number(peer_id, arg)
            run_on_queue(unlike_task)
            return HookResult(strategy=HookStrategy.CANCEL)

        # .rec
        if msg.startswith(".rec"):
            def rec_task():
                self._show_recommendations(peer_id)
            run_on_queue(rec_task)
            return HookResult(strategy=HookStrategy.CANCEL)

        # .info
        if msg.startswith(".info"):
            def info_task():
                self._show_info(peer_id)
            run_on_queue(info_task)
            return HookResult(strategy=HookStrategy.CANCEL)

        # dlf <number>
        if msg.lower().startswith("dlf"):
            arg = msg[3:].strip()
            if not arg.isdigit():
                params.message = "Использование: dlF [номер из списка]"
                return HookResult(strategy=HookStrategy.MODIFY, params=params)

            session = _search_sessions.get(peer_id)
            if not session:
                params.message = "❌ Нет активного поиска. Сначала используй .find"
                return HookResult(strategy=HookStrategy.MODIFY, params=params)

            idx = int(arg) - 1
            if idx < 0 or idx >= len(session["results"]):
                params.message = f"❌ Номер вне диапазона (1–{len(session['results'])})"
                return HookResult(strategy=HookStrategy.MODIFY, params=params)

            track = dict(session["results"][idx])
            track["query"] = session.get("query", "")

            def dlf_task():
                self._do_download(peer_id, track)

            run_on_queue(dlf_task)
            return HookResult(strategy=HookStrategy.CANCEL)

        # .download
        if msg.startswith(".download"):
            query = msg[9:].strip()
            if not query:
                params.message = "Использование: .download <название>"
                return HookResult(strategy=HookStrategy.MODIFY, params=params)

            def quick_task():
                send_text(peer_id, f"⏳ Ищу: {query}...")
                results, err = sc_search(query, limit=1)
                if not results:
                    send_text(peer_id, err or "❌ Ничего не найдено")
                    return
                track = dict(results[0])
                track["query"] = query
                self._do_download(peer_id, track)
                self._warn_update_if_needed(peer_id)

            run_on_queue(quick_task)
            return HookResult(strategy=HookStrategy.CANCEL)

        return HookResult()