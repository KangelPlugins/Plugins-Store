def _safe_int(x, default=0):
    if x is None: return default
    if isinstance(x, int): return x
    try: return int(x)
    except (ValueError, TypeError): return default

def _is_me(plugin, parentFragment, container, UserConfig):
    if not parentFragment or not UserConfig: return False
    try:
        frag_hash = parentFragment.hashCode()
        if frag_hash in plugin._is_me_cache:
            return plugin._is_me_cache[frag_hash]

        if len(plugin._is_me_cache) > 100:
            plugin._is_me_cache.clear()

        dialog_id = parentFragment.getDialogId()
        acc = -1
        if plugin.f_currentAccount:
            acc = _safe_int(plugin.f_currentAccount.get(container), -1)
        if acc < 0:
            acc = _safe_int(get_private_field(container, "currentAccount"), -1)
            
        if acc >= 0:
            me = UserConfig.getInstance(acc).getClientUserId()
        else:
            selected = _safe_int(UserConfig.selectedAccount, -1)
            me = UserConfig.getInstance(selected).getClientUserId() if selected >= 0 else -1
            
        res = (dialog_id == me)
        plugin._is_me_cache[frag_hash] = res
        return res
    except Exception: pass
    return False

def _is_search_active(plugin, action_bar):
    if not action_bar or not plugin.ActionBarMenuItemClass: return False
    try:
        for i in range(action_bar.getChildCount()):
            child = action_bar.getChildAt(i)
            if child and "Menu" in child.getClass().getSimpleName(): 
                for j in range(child.getChildCount()):
                    item = child.getChildAt(j)
                    if isinstance(item, plugin.ActionBarMenuItemClass):
                        try:
                            if hasattr(item, "isSearchFieldVisible"):
                                try: res = item.isSearchFieldVisible()
                                except TypeError: res = getattr(item, "isSearchFieldVisible")
                                if bool(res): return True
                                continue
                        except Exception: pass
                        
                        sf = get_private_field(item, "searchField")
                        if sf and sf.getVisibility() == 0:
                            return True
    except Exception: pass
    return False

class _HeaderDispatchTouchHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def before_hooked_method(self, param):
        try:
            event = param.args[0]
            if not event: return
            
            this = param.thisObject
            p = self.plugin
            avatar = p.get_cached_view(this, p.f_avatar, "avatarImageView")
            if not avatar or avatar.getVisibility() == 8: return

            x, y = event.getX(), event.getY()
            a_left, a_right = avatar.getLeft(), avatar.getRight()
            a_top, a_bottom = avatar.getTop(), avatar.getBottom()
            
            is_on_avatar = (a_left <= x <= a_right) and (a_top <= y <= a_bottom)

            if is_on_avatar:
                if event.getAction() == 1: 
                    pf = p.get_cached_view(this, p.f_parentFragment, "parentFragment")
                    if pf:
                        headerItem = get_private_field(pf, "headerItem")
                        if headerItem: headerItem.toggleSubMenu()
                param.setResult(True)
                return
            elif getattr(p, 'h_full_profile_click', True):
                cx = a_left + (a_right - a_left) * 0.5
                cy = a_top + (a_bottom - a_top) * 0.5
                event.setLocation(cx, cy)
        except Exception: pass

class _ThemeApplyHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin
    def after_hooked_method(self, param):
        self.plugin._force_recalc = True
        self.plugin._last_theme_check_time = 0.0 
        self.plugin._force_redraw()

class ChannelDynamicGiftHook(MethodHook):
    def __init__(self, plugin):
        super().__init__()
        self.plugin = plugin
        self.active_btns = {}  

    def before_hooked_method(self, param):
        if not getattr(self.plugin, 'channel_gifts_enabled', True): return
        if not param.args or len(param.args) < 2: return

        btn_id = param.args[0]
        show_btn = bool(param.args[1])
        self.active_btns[btn_id] = show_btn

        if btn_id == 1:
            is_mute = self.active_btns.get(0, False)
            is_comments = self.active_btns.get(2, False)

            if is_comments: param.args[1] = False
            elif is_mute: param.args[1] = True

class ActionBarSetBackHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def before_hooked_method(self, param):
        if not getattr(self.plugin, 'h_static_back_icon', True): return
        try:
            drawable = param.args[0]
            if drawable and "BackDrawable" in drawable.getClass().getSimpleName():
                p = self.plugin
                if not hasattr(p, 'ic_ab_back_id'):
                    R_drawable = find_class("org.telegram.messenger.R$drawable")
                    p.ic_ab_back_id = getattr(R_drawable, "ic_ab_back")
                
                context = param.thisObject.getContext()
                static_drawable = context.getResources().getDrawable(p.ic_ab_back_id).mutate()
                if static_drawable: param.args[0] = static_drawable
        except Exception: pass

class EnterViewDispatchDrawHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def before_hooked_method(self, param):
        p = self.plugin
        if not p.e_md3_enabled and not p.e_stroke_enabled and not p.p_stroke_enabled: 
            return

        try:
            this = param.thisObject
            canvas = param.args[0]
            p._check_theme_colors()
            
            this_hash = this.hashCode()
            is_bot = p._bot_chat_cache.get(this_hash)
            
            if is_bot is None:
                is_bot = False
                try:
                    acc = -1
                    if getattr(p, 'f_currentAccount', None):
                        try: acc = _safe_int(p.f_currentAccount.get(this), -1)
                        except: pass
                    if acc < 0:
                        try: acc = _safe_int(get_private_field(this, "currentAccount"), -1)
                        except: pass
                        
                    dialog_id = None
                    try: dialog_id = get_private_field(this, "dialog_id")
                    except: pass
                    
                    if acc >= 0 and dialog_id is not None:
                        did = int(dialog_id)
                        if did > 0 and getattr(p, 'MessagesController', None):
                            user = p.MessagesController.getInstance(acc).getUser(did)
                            if user and getattr(user, 'bot', False):
                                is_bot = True
                except Exception: pass
                
                if len(p._bot_chat_cache) > 50:
                    p._bot_chat_cache.clear()
                p._bot_chat_cache[this_hash] = is_bot

            if is_bot:
                if p.p_stroke_enabled and p.p_border_paint:
                    w, h = float(this.getWidth()), float(this.getHeight())
                    if w > 0 and h > 0:
                        p.p_rect.set(p.p_m_left, p.p_m_top, w - p.p_m_right, h - p.p_m_bottom)
                        canvas.drawRoundRect(p.p_rect, p.p_dp_rad, p.p_dp_rad, p.p_border_paint)
                return
            
            emoji_btn = p.get_cached_view(this, p.f_emojiBtn, "emojiButton")
            if emoji_btn:
                if abs(float(emoji_btn.getTranslationX())) > 1.0:
                    if p.p_stroke_enabled and p.p_border_paint:
                        w, h = float(this.getWidth()), float(this.getHeight())
                        if w > 0 and h > 0:
                            p.p_rect.set(p.p_m_left, p.p_m_top, w - p.p_m_right, h - p.p_m_bottom)
                            canvas.drawRoundRect(p.p_rect, p.p_dp_rad, p.p_dp_rad, p.p_border_paint)
                    return

            if p.p_stroke_enabled and p.p_border_paint:
                w, h = float(this.getWidth()), float(this.getHeight())
                if w > 0 and h > 0:
                    p.p_rect.set(p.p_m_left, p.p_m_top, w - p.p_m_right, h - p.p_m_bottom)
                    canvas.drawRoundRect(p.p_rect, p.p_dp_rad, p.p_dp_rad, p.p_border_paint)

            paint = p.enter_paint
            border_paint = p.e_border_paint
            
            if emoji_btn and emoji_btn.getVisibility() == 0 and emoji_btn.getAlpha() > 0.1:
                try:
                    if float(emoji_btn.getScaleX()) < 0.1: return
                except Exception: pass

                ew, eh = emoji_btn.getWidth(), emoji_btn.getHeight()
                if ew > 0 and eh > 0:
                    current_w, current_h = this.getWidth(), this.getHeight()
                    current_left = emoji_btn.getLeft()
                    
                    if p._emoji_last_w != current_w or p._emoji_last_h != current_h or p._emoji_last_left != current_left:
                        p._emoji_cx_offset = None
                        p._emoji_last_w, p._emoji_last_h, p._emoji_last_left = current_w, current_h, current_left
                        
                    if p._emoji_cx_offset is None:
                        cx_off, cy_off = 0.0, 0.0
                        view = emoji_btn
                        for _ in range(5):
                            if view == this or not view: break
                            cx_off += view.getLeft() + view.getTranslationX()
                            cy_off += view.getTop() + view.getTranslationY()
                            try: view = view.getParent()
                            except: break
                        p._emoji_cx_offset = cx_off
                        p._emoji_cy_offset = cy_off
                    
                    cx = (ew * 0.5) + p._emoji_cx_offset
                    cy = (eh * 0.5) + p._emoji_cy_offset
                    dp_rad = p.e_dp_rad

                    if paint and p.e_md3_enabled:
                        canvas.drawCircle(cx, cy, dp_rad, paint)
                    if border_paint and p.e_stroke_enabled:
                        canvas.drawCircle(cx, cy, dp_rad, border_paint)
        except Exception: pass

class ListViewDrawHook(MethodHook):
    def __init__(self, plugin):
        self.p = plugin

    def before_hooked_method(self, param):
        p = self.p
        if not p.l_enabled and not p.l_unpinned_enabled: return
            
        try:
            list_view = param.thisObject
            count = list_view.getChildCount()
            if count <= 0 or not p.DialogCellClass: return

            child1 = list_view.getChildAt(0)
            if not isinstance(child1, p.DialogCellClass) and (count <= 1 or not isinstance(list_view.getChildAt(1), p.DialogCellClass)):
                return 

            canvas = param.args[0]
            if not p._active_list_view or p._active_list_view() is not list_view:
                p._active_list_view = weakref.ref(list_view)

            p._check_theme_colors()
                
            paint_pinned = p.paint_pinned
            paint_unpinned = p.paint_unpinned
            l_dp_rad = p.l_dp_rad
            l_dp_mx = p.l_dp_mx
            l_dp_my = p.l_dp_my
            
            for i in range(count):
                child = list_view.getChildAt(i)
                if not child or not isinstance(child, p.DialogCellClass): continue
                
                is_pinned = child.getIsPinned()
                if is_pinned and not p.l_enabled: continue
                if not is_pinned and not p.l_unpinned_enabled: continue
                
                paint = paint_pinned if is_pinned else paint_unpinned
                if not paint: continue
                    
                left = child.getLeft() + child.getTranslationX()
                top = child.getTop() + child.getTranslationY()
                w, h = child.getWidth(), child.getHeight()
                
                canvas.save()
                canvas.translate(left, top)

                if p.l_md3 and p.list_rect:
                    p.list_rect.set(l_dp_mx, l_dp_my, w - l_dp_mx, h - l_dp_my)
                    canvas.drawRoundRect(p.list_rect, l_dp_rad, l_dp_rad, paint)
                    
                    border_paint = p.l_pinned_border_paint if is_pinned else p.l_unpinned_border_paint
                    if border_paint and ((is_pinned and p.l_stroke_enabled) or (not is_pinned and p.l_unpinned_stroke_enabled)):
                        canvas.drawRoundRect(p.list_rect, l_dp_rad, l_dp_rad, border_paint)
                else:
                    canvas.drawRect(0.0, 0.0, float(w), float(h), paint)
                    
                canvas.restore()
        except Exception: pass

class _ActionBarLayoutHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def after_hooked_method(self, param):
        try:
            this = param.thisObject
            p = self.plugin
            if p.h_md3_back:
                back_btn = p.get_cached_view(this, p.f_backBtn, "backButtonImageView")
                if back_btn:
                    p._check_theme_colors()
                    drawable = p.get_back_drawable()
                    if drawable and back_btn.getBackground() != drawable:
                        back_btn.setBackground(drawable)
                        pad_v = p.h_dp_back_v + p.dp_2
                        pad_h = p.h_dp_back_h + p.dp_2
                        back_btn.setPadding(pad_h, pad_v, pad_h, pad_v)

            if p.ActionBarMenuItemClass:
                for i in range(this.getChildCount()):
                    child = this.getChildAt(i)
                    if child and "Menu" in child.getClass().getSimpleName():
                        for j in range(child.getChildCount()):
                            item = child.getChildAt(j)
                            if isinstance(item, p.ActionBarMenuItemClass):
                                sf = get_private_field(item, "searchField")
                                if sf and sf.getVisibility() == 0:
                                    avatar_visible = any(
                                        "AvatarContainer" in cac.getClass().getSimpleName() and 
                                        p.get_cached_view(cac, p.f_avatar, "avatarImageView") and 
                                        p.get_cached_view(cac, p.f_avatar, "avatarImageView").getVisibility() == 0
                                        for k in range(this.getChildCount()) if (cac := this.getChildAt(k))
                                    )
                                    
                                    cb = get_private_field(item, "clearButton")
                                    if avatar_visible:
                                        offset = -float(p.dp_50)
                                        if cb and cb.getTranslationX() != offset: cb.setTranslationX(offset)
                                        target_pad = int(p.dp_50 + p.dp_49) 
                                        if sf.getPaddingRight() != target_pad:
                                            sf.setPadding(sf.getPaddingLeft(), sf.getPaddingTop(), target_pad, sf.getPaddingBottom())
                                    else:
                                        if cb and cb.getTranslationX() != 0.0: cb.setTranslationX(0.0)
                                        if sf and sf.getPaddingRight() > int(p.dp_60):
                                            sf.setPadding(sf.getPaddingLeft(), sf.getPaddingTop(), int(p.dp_49), sf.getPaddingBottom())
        except Exception: pass

class _ActionBarDispatchDrawHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin
    def before_hooked_method(self, param):
        if self.plugin.h_md3_back: self.plugin._check_theme_colors()

class _HeaderDispatchDrawHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def _get_text_w(self, view):
        if not view: return 0.0
        try:
            if view.getVisibility() == 8: return 0.0
            if hasattr(view, 'getTextWidth'):
                tw = float(view.getTextWidth())
                if tw > 0:
                    w = tw + view.getPaddingLeft() + view.getPaddingRight()
                    
                    dp_val = 0.0
                    try:
                        if hasattr(view, "getDrawablePadding"):
                            dp_val = float(view.getDrawablePadding())
                        else:
                            val = get_private_field(view, "drawablePadding")
                            if val is not None: dp_val = float(val)
                    except: pass
                    
                    if dp_val <= 0: dp_val = float(self.plugin.dp_4)
                    
                    for fname in ("leftDrawable", "rightDrawable", "rightDrawable2"):
                        try:
                            d = None
                            getter = "get" + fname[0].upper() + fname[1:]
                            if hasattr(view, getter): d = getattr(view, getter)()
                            if not d: d = get_private_field(view, fname)
                            if d and hasattr(d, 'getIntrinsicWidth'):
                                iw = float(d.getIntrinsicWidth())
                                if iw > 0: w += iw + dp_val
                        except: pass
                        
                    return w + float(self.plugin.dp_2)
                    
            tw = float(view.getWidth())
            if tw > 0: return tw
        except Exception: pass
        return 0.0

    def _is_search_visible(self, this):
        p = self.plugin
        try:
            this_hash = this.hashCode()

            if len(p._parent_actionbar_cache) > 50:
                p._parent_actionbar_cache.clear()

            ab = p._parent_actionbar_cache.get(this_hash)
            if ab is None:
                parent = this.getParent()
                for _ in range(5):
                    if not parent: break
                    if isinstance(parent, p.ActionBar):
                        ab = parent
                        break
                    try: parent = parent.getParent()
                    except Exception: break
                p._parent_actionbar_cache[this_hash] = ab or False
            
            if ab: return _is_search_active(p, ab)
        except Exception: pass
        return False

    def before_hooked_method(self, param):
        p = self.plugin
        if not p.h_md3_enabled and not p.h_md3_avatar: return

        try:
            this = param.thisObject
            canvas = param.args[0]
            p._check_theme_colors()
            
            paint = p.header_paint
            if not paint or not p.header_rect: return

            hide_title_bg = False
            pf = p.get_cached_view(this, p.f_parentFragment, "parentFragment")
            
            if pf:
                if p._meth_isThreadChat is False:
                    try:
                        p._meth_isThreadChat = pf.getClass().getDeclaredMethod("isThreadChat")
                        p._meth_isThreadChat.setAccessible(True)
                    except Exception:
                        p._meth_isThreadChat = None
                        
                if p._meth_isThreadChat:
                    try:
                        if p._meth_isThreadChat.invoke(pf): hide_title_bg = True
                    except Exception: pass

            if not hide_title_bg and self._is_search_visible(this):
                hide_title_bg = True

            h_dp_rad = p.h_dp_rad
            h_dp_avatar_bg = p.h_dp_avatar_bg

            if p.h_md3_avatar:
                avatar = p.get_cached_view(this, p.f_avatar, "avatarImageView")
                if avatar and avatar.getVisibility() != 8:
                    a_l, a_t, a_r, a_b = avatar.getLeft(), avatar.getTop(), avatar.getRight(), avatar.getBottom()
                    if a_r > a_l:
                        cx, cy = (a_l + a_r) * 0.5, (a_t + a_b) * 0.5
                        canvas.drawCircle(cx, cy, h_dp_avatar_bg, paint)
                        if p.h_avatar_stroke and p.h_border_paint:
                            canvas.drawCircle(cx, cy, h_dp_avatar_bg, p.h_border_paint)

            if p.h_md3_enabled and not hide_title_bg:
                title = p.get_cached_view(this, p.f_title, "titleTextView")
                if title and title.getVisibility() != 8:
                    subtitle = p.get_cached_view(this, p.f_subtitle, "subtitleTextView")
                    
                    t_left, t_right = float(title.getLeft()), float(title.getRight())
                    top, bottom = float(title.getTop()), float(title.getBottom())
                    
                    if subtitle and subtitle.getVisibility() != 8:
                        bottom = max(bottom, float(subtitle.getBottom()))
                        
                    title_w = self._get_text_w(title)
                    subtitle_w = self._get_text_w(subtitle) if (subtitle and subtitle.getVisibility() != 8) else 0.0

                    for raw_view, is_title in ((p.get_cached_view(this, p.f_titleCopy, "titleTextLargerCopyView"), True), 
                                               (p.get_cached_view(this, p.f_subtitleCopy, "subtitleTextLargerCopyView"), False)):
                        try:
                            vc = raw_view.get() if hasattr(raw_view, 'get') else raw_view
                            if vc and vc.getVisibility() != 8:
                                if is_title: title_w = max(title_w, self._get_text_w(vc))
                                else: subtitle_w = max(subtitle_w, self._get_text_w(vc))
                        except Exception: pass
                    
                    max_text_w = max(title_w, subtitle_w)
                    regionWidth = t_right - t_left
                    
                    max_text_w = min(max_text_w, regionWidth)

                    dp_16 = float(p.dp_16)
                    dp_8 = float(p.dp_8)

                    if max_text_w >= regionWidth - dp_8:
                        left = t_left - dp_16
                        right = t_right + dp_16
                    else:
                        view_cx = (t_left + t_right) / 2.0
                        left = view_cx - (max_text_w / 2.0) - dp_16
                        right = view_cx + (max_text_w / 2.0) + dp_16
                    
                    min_left = 0.0
                    max_right = float(this.getWidth())
                    
                    if p.h_md3_avatar:
                        avatar = p.get_cached_view(this, p.f_avatar, "avatarImageView")
                        if avatar and avatar.getVisibility() != 8:
                            a_l = float(avatar.getLeft())
                            a_r = float(avatar.getRight())
                            if a_l < max_right / 2: 
                                min_left = max(min_left, a_r + float(p.dp_6))
                            else: 
                                max_right = min(max_right, a_l - float(p.dp_6))
                                
                    left = max(left, min_left)
                    right = min(right, max_right)
                    
                    p.header_rect.set(left, top - float(p.dp_4), right, bottom + float(p.dp_4))
                    canvas.drawRoundRect(p.header_rect, h_dp_rad, h_dp_rad, paint)
                    
                    if p.h_text_stroke and p.h_border_paint:
                        canvas.drawRoundRect(p.header_rect, h_dp_rad, h_dp_rad, p.h_border_paint)

        except Exception: pass

    def after_hooked_method(self, param):
        p = self.plugin
        if not getattr(p, 'h_online_badge', False): return
        try:
            this = param.thisObject
            canvas = param.args[0]
            
            is_group = False
            pf = p.get_cached_view(this, p.f_parentFragment, "parentFragment")
            if pf:
                try:
                    if pf.getDialogId() < 0: is_group = True
                except Exception: pass

            if is_group and not getattr(p, 'h_online_badge_groups', False): return
            
            def check_online_text(view):
                if not view: return False
                try:
                    text = str(view.getText() or "").strip().lower()
                    if not text or any(word in text for word in ["был", "was", "seen", "недавно"]): return False
                    return any(word in text for word in ["в сети", "online", "печат", "typing", "записыв", "отправля", "играет"])
                except Exception: return False
            
            subtitle = p.get_cached_view(this, p.f_subtitle, "subtitleTextView")
            is_online = check_online_text(subtitle)
            
            if not is_online:
                try:
                    subtitle_copy_raw = p.get_cached_view(this, p.f_subtitleCopy, "subtitleTextLargerCopyView")
                    if subtitle_copy_raw:
                        sc = subtitle_copy_raw.get() if hasattr(subtitle_copy_raw, 'get') else subtitle_copy_raw
                        is_online = check_online_text(sc)
                except Exception: pass
            
            if not is_online: return
            
            avatar = p.get_cached_view(this, p.f_avatar, "avatarImageView")
            if not avatar or avatar.getVisibility() == 8: return
            
            a_l, a_t, a_r, a_b = avatar.getLeft(), avatar.getTop(), avatar.getRight(), avatar.getBottom()
            if a_r <= a_l: return
            
            cx, cy = (a_l + a_r) * 0.5, (a_t + a_b) * 0.5
            offset = ((a_r - a_l) * 0.5) * 0.75 
            badge_cx, badge_cy = cx + offset, cy + offset
            
            if p.online_stroke_paint:
                canvas.drawCircle(badge_cx, badge_cy, p.dp_7_f, p.online_stroke_paint)
            if p.online_paint:
                canvas.drawCircle(badge_cx, badge_cy, p.dp_5_f, p.online_paint)

        except Exception: pass

class _UpdateSubtitleHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def after_hooked_method(self, param):
        try:
            this = param.thisObject
            this.requestLayout()
            this.invalidate()
            
            p = self.plugin
            parentFragment = p.get_cached_view(this, p.f_parentFragment, "parentFragment")
            if not parentFragment: return

            subtitle = p.get_cached_view(this, p.f_subtitle, "subtitleTextView")
            
            currentAccount = -1
            if p.f_currentAccount:
                try: currentAccount = _safe_int(p.f_currentAccount.get(this), -1)
                except: pass
            if currentAccount < 0:
                try:
                    acc_field = this.getClass().getDeclaredField("currentAccount")
                    acc_field.setAccessible(True)
                    p.f_currentAccount = acc_field
                    currentAccount = _safe_int(acc_field.get(this), -1)
                except:
                    currentAccount = _safe_int(get_private_field(this, "currentAccount"), -1)
                
            if not subtitle or currentAccount < 0 or not getattr(p, 'MessagesController', None): return

            MessagesController = p.MessagesController
            dialog_id = parentFragment.getDialogId()
            thread_id = parentFragment.getThreadId()
            
            print_string = MessagesController.getInstance(currentAccount).getPrintingString(dialog_id, thread_id, False)
            if not print_string or len(str(print_string)) == 0: return

            type_idx = MessagesController.getInstance(currentAccount).getPrintingStringType(dialog_id, thread_id)
            if type_idx is None or type_idx < 0: return

            subtitle.setLeftDrawable(None)
            try: subtitle.replaceTextWithDrawable(None, None)
            except Exception: pass
            # ФИКС 3: Сбрасываем паддинги при обновлении
            try: subtitle.setPadding(0, 0, 0, 0)
            except Exception: pass

            subtitle.setText(f"{str(print_string).replace('.', '').strip()}...")
        except Exception: pass

class _RefreshHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin
    def after_hooked_method(self, param):
        try:
            this = param.thisObject
            this.requestLayout()
            this.invalidate()
        except Exception: pass

class _CtorHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def after_hooked_method(self, param):
        try:
            this = param.thisObject
            p = self.plugin
            if not p.Gravity: return

            title = p.get_cached_view(this, p.f_title, "titleTextView")
            subtitle = p.get_cached_view(this, p.f_subtitle, "subtitleTextView")
            
            if title:
                title.setGravity(1) 
                
                for setter in ('setLines', 'setSingleLine', 'setRightDrawableOutside', 'setScrolling', 'setScrollNonFitText'):
                    try: getattr(title, setter)(True if 'SingleLine' in setter or 'Scroll' in setter else 1 if 'Lines' in setter else False)
                    except: pass
                for setter in ('setRightDrawable', 'setLeftDrawable'):
                    try: getattr(title, setter)(None)
                    except: pass
                try: title.setCompoundDrawablesWithIntrinsicBounds(0, 0, 0, 0)
                except: pass

                if p.TextUtils:
                    try:
                        title.setEllipsize(p.TextUtils.TruncateAt.MARQUEE)
                        title.setMarqueeRepeatLimit(-1)
                        title.setSelected(True)
                        title.setHorizontallyScrolling(True)
                    except Exception: pass
            
            if subtitle:
                subtitle.setGravity(1)
                try: subtitle.setLines(1)
                except Exception: pass
                try: subtitle.setSingleLine(True)
                except Exception: pass
                # ФИКС 1: Сбрасываем паддинги при инициализации
                try: subtitle.setPadding(0, 0, 0, 0)
                except Exception: pass

        except Exception: pass

class _OnMeasureReplacement(MethodReplacement):
    def __init__(self, plugin):
        self.plugin = plugin

    def replace_hooked_method(self, param):
        p = self.plugin
        try:
            this = param.thisObject
            if not p.MeasureSpec or not p.AndroidUtilities: return None

            widthBase = p.MeasureSpec.getSize(param.args[0])
            height = p.MeasureSpec.getSize(param.args[1])

            avatar = p.get_cached_view(this, p.f_avatar, "avatarImageView")
            title = p.get_cached_view(this, p.f_title, "titleTextView")
            subtitle = p.get_cached_view(this, p.f_subtitle, "subtitleTextView")
            parentFragment = p.get_cached_view(this, p.f_parentFragment, "parentFragment")
            timeItem = p.get_cached_view(this, p.f_timeItem, "timeItem")

            dp42 = p.dp_42
            ms_exact = p.MS_EXACTLY
            ms_at_most = p.MS_AT_MOST

            if not parentFragment:
                leftPadding = _safe_int(p.get_cached_view(this, p.f_leftPadding, "leftPadding"), p.dp_8)
                width0 = widthBase + (_safe_int(title.getPaddingRight()) if title else 0)
                
                avatarRightBound = 0
                if avatar and avatar.getVisibility() != 8:
                    avatar.measure(
                        p.MeasureSpec.makeMeasureSpec(dp42, ms_exact),
                        p.MeasureSpec.makeMeasureSpec(dp42, ms_exact),
                    )
                    avatarRightBound = leftPadding + dp42 + p.dp_12

                regionWidth = max(0, widthBase - avatarRightBound - p.dp_16)

                if title:
                    title.measure(
                        p.MeasureSpec.makeMeasureSpec(regionWidth, ms_exact),
                        p.MeasureSpec.makeMeasureSpec(p.dp_32 + _safe_int(title.getPaddingRight()), ms_at_most),
                    )
                if subtitle:
                    subtitle.measure(
                        p.MeasureSpec.makeMeasureSpec(regionWidth, ms_exact),
                        p.MeasureSpec.makeMeasureSpec(p.dp_20, ms_at_most),
                    )
                if timeItem:
                    timeItem.measure(
                        p.MeasureSpec.makeMeasureSpec(p.dp_34, ms_exact),
                        p.MeasureSpec.makeMeasureSpec(p.dp_34, ms_exact),
                    )
                this.setMeasuredDimension(width0, height)
                return None

            if avatar:
                if parentFragment and _is_me(p, parentFragment, this, getattr(p, 'UserConfig', None)):
                    avatar.setVisibility(0)

                if avatar.getVisibility() != 8:
                    avatar.measure(
                        p.MeasureSpec.makeMeasureSpec(dp42, ms_exact),
                        p.MeasureSpec.makeMeasureSpec(dp42, ms_exact),
                    )

            maxHalfWidth = max(0, (widthBase * 0.5) - p.dp_90)
            regionWidth = int(maxHalfWidth * 2)

            if title:
                title.measure(
                    p.MeasureSpec.makeMeasureSpec(regionWidth, ms_exact),
                    p.MeasureSpec.makeMeasureSpec(p.dp_32 + _safe_int(title.getPaddingRight()), ms_at_most),
                )
            if subtitle:
                subtitle.measure(
                    p.MeasureSpec.makeMeasureSpec(regionWidth, ms_exact),
                    p.MeasureSpec.makeMeasureSpec(p.dp_20, ms_at_most),
                )

            this.setMeasuredDimension(widthBase, height)
            return None
        except Exception: return None

class _OnLayoutReplacement(MethodReplacement):
    def __init__(self, plugin):
        self.plugin = plugin

    def _get_text_w(self, view):
        if not view: return 0.0
        try:
            if hasattr(view, 'getTextWidth'):
                tw = float(view.getTextWidth())
                if tw > 0:
                    w = tw + view.getPaddingLeft() + view.getPaddingRight()
                    dp_val = 0.0
                    try:
                        if hasattr(view, "getDrawablePadding"):
                            dp_val = float(view.getDrawablePadding())
                        else:
                            val = get_private_field(view, "drawablePadding")
                            if val is not None: dp_val = float(val)
                    except: pass
                    
                    if dp_val <= 0: dp_val = float(self.plugin.dp_4)
                    
                    for fname in ("leftDrawable", "rightDrawable", "rightDrawable2"):
                        try:
                            d = None
                            getter = "get" + fname[0].upper() + fname[1:]
                            if hasattr(view, getter): d = getattr(view, getter)()
                            if not d: d = get_private_field(view, fname)
                            if d and hasattr(d, 'getIntrinsicWidth'):
                                iw = float(d.getIntrinsicWidth())
                                if iw > 0: w += iw + dp_val
                        except: pass
                    return w + float(self.plugin.dp_2)
            return float(view.getMeasuredWidth())
        except Exception: pass
        return 0.0

    def replace_hooked_method(self, param):
        p = self.plugin
        try:
            this = param.thisObject
            if not p.AndroidUtilities or not p.ActionBar: return None

            occupyStatusBar = p.get_cached_view(this, p.f_occupyStatusBar, "occupyStatusBar")
            occupyStatusBar = bool(occupyStatusBar) if occupyStatusBar is not None else True

            avatar = p.get_cached_view(this, p.f_avatar, "avatarImageView")
            title = p.get_cached_view(this, p.f_title, "titleTextView")
            subtitle = p.get_cached_view(this, p.f_subtitle, "subtitleTextView")
            timeItem = p.get_cached_view(this, p.f_timeItem, "timeItem")
            titleCopy = p.get_cached_view(this, p.f_titleCopy, "titleTextLargerCopyView")
            subtitleCopy = p.get_cached_view(this, p.f_subtitleCopy, "subtitleTextLargerCopyView")
            parentFragment = p.get_cached_view(this, p.f_parentFragment, "parentFragment")

            w = this.getWidth()
            actionBarHeight = p.ActionBar.getCurrentActionBarHeight()
            viewTop = int((actionBarHeight - p.dp_42) * 0.5) + (p.AndroidUtilities.statusBarHeight if occupyStatusBar else 0)
            dp42 = p.dp_42
            ms_exact = p.MS_EXACTLY
            ms_at_most = p.MS_AT_MOST

            if not parentFragment:
                leftPadding = _safe_int(p.get_cached_view(this, p.f_leftPadding, "leftPadding"), p.dp_8)
                avatarRightBound = 0

                if avatar and avatar.getVisibility() != 8:
                    avatar.layout(leftPadding, viewTop + 1, leftPadding + dp42, viewTop + 1 + dp42)
                    avatarRightBound = leftPadding + dp42 + p.dp_12

                regionLeft = min(avatarRightBound, w - p.dp_16)
                regionRight = w - p.dp_16
                
                regionLeft = max(avatarRightBound, regionLeft)
                regionRight = min(w, regionRight)
                
                regionWidth = regionRight - regionLeft

                has_visible_subtitle = subtitle and subtitle.getVisibility() != 8

                if title:
                    actual_w = self._get_text_w(title)
                    if actual_w >= regionWidth - p.dp_8:
                        title.setGravity(3) 
                    else:
                        title.setGravity(1) 
                    
                    try: title.setTranslationX(0.0)
                    except Exception: pass

                    t_top = viewTop + (p.dp_1_3 if has_visible_subtitle else p.dp_11) - title.getPaddingTop()
                    title.layout(regionLeft, t_top, regionRight, t_top + title.getTextHeight() - title.getPaddingTop() + title.getPaddingBottom())
                    try:
                        if titleCopy:
                            tc = titleCopy.get() if hasattr(titleCopy, 'get') else titleCopy
                            if tc: tc.layout(regionLeft, t_top + title.getPaddingTop(), regionLeft + tc.getMeasuredWidth(), t_top + title.getPaddingTop() + tc.getTextHeight())
                    except Exception: pass
                
                if has_visible_subtitle:
                    actual_sw = self._get_text_w(subtitle)
                    if actual_sw >= regionWidth - p.dp_8:
                        subtitle.setGravity(3) 
                    else:
                        subtitle.setGravity(1) 
                        
                    # ФИКС 2: Сбрасываем паддинги и трансляцию перед финальным лайаутом
                    try:
                        subtitle.setPadding(0, 0, 0, 0)
                        subtitle.setTranslationX(0.0)
                    except Exception: pass

                    sTop = viewTop + p.dp_24
                    subtitle.layout(regionLeft, sTop, regionRight, sTop + subtitle.getTextHeight())
                    try:
                        if subtitleCopy:
                            sc = subtitleCopy.get() if hasattr(subtitleCopy, 'get') else subtitleCopy
                            if sc: sc.layout(regionLeft, sTop, regionLeft + sc.getMeasuredWidth(), sTop + sc.getTextHeight())
                    except Exception: pass
                        
                if timeItem:
                    timeItem.layout(leftPadding + p.dp_16, viewTop + p.dp_15, leftPadding + p.dp_50, viewTop + p.dp_49)
                return None

            if timeItem:
                try:
                    timeItem.layout(0, 0, 0, 0)
                    timeItem.setVisibility(8)
                except Exception: pass

            leftInParent = param.args[1] if param.args and len(param.args) >= 5 else 0
            parentW = w
            
            try:
                pa = this.getParent()
                if pa:
                    parentW = pa.getWidth()
                    this.setClipChildren(False)
                    this.setClipToPadding(False)
                    pa.setClipChildren(False)
                    pa.setClipToPadding(False)
            except Exception: pass

            absoluteRight = parentW - leftInParent
            
            if avatar:
                if parentFragment and _is_me(p, parentFragment, this, getattr(p, 'UserConfig', None)):
                    avatar.setVisibility(0)

                if avatar.getVisibility() != 8:
                    avatarRight = absoluteRight - p.dp_6
                    avatar.layout(avatarRight - dp42, viewTop + 1, avatarRight, viewTop + 1 + dp42)

            headerCenterLocal = (parentW * 0.5) - leftInParent
            maxHalfWidth = max(0, (parentW * 0.5) - p.dp_90)
            regionLeft = int(headerCenterLocal - maxHalfWidth)
            regionRight = int(headerCenterLocal + maxHalfWidth)

            min_left = 0
            max_right = w
            
            if avatar and avatar.getVisibility() != 8:
                a_l = avatar.getLeft()
                a_r = avatar.getRight()
                if a_l < w / 2:
                    min_left = max(min_left, a_r + p.dp_6)
                else:
                    max_right = min(max_right, a_l - p.dp_6)

            if regionLeft < min_left: regionLeft = min_left
            if regionRight > max_right: regionRight = max_right
            regionWidth = regionRight - regionLeft

            has_visible_subtitle = subtitle and subtitle.getVisibility() != 8

            if title:
                if p.MeasureSpec:
                    try:
                        title.measure(
                            p.MeasureSpec.makeMeasureSpec(regionWidth, ms_exact),
                            p.MeasureSpec.makeMeasureSpec(p.dp_32 + _safe_int(title.getPaddingRight()), ms_at_most),
                        )
                    except: pass

                actual_w = self._get_text_w(title)
                if actual_w >= regionWidth - p.dp_8:
                    title.setGravity(3) 
                else:
                    title.setGravity(1) 

                try: title.setTranslationX(0.0)
                except Exception: pass

                titleTop = viewTop + (p.dp_1_3 if has_visible_subtitle else p.dp_11) - title.getPaddingTop()
                title.layout(regionLeft, titleTop, regionRight, titleTop + title.getTextHeight() - title.getPaddingTop() + title.getPaddingBottom())

                try:
                    if titleCopy:
                        tc = titleCopy.get() if hasattr(titleCopy, 'get') else titleCopy
                        if tc:
                            tc_top = viewTop + (p.dp_1_3 if has_visible_subtitle else p.dp_11)
                            tc.layout(regionLeft, tc_top, regionLeft + tc.getMeasuredWidth(), tc_top + tc.getTextHeight())
                except Exception: pass

            if subtitle:
                if p.MeasureSpec and has_visible_subtitle:
                    try:
                        subtitle.measure(
                            p.MeasureSpec.makeMeasureSpec(regionWidth, ms_exact),
                            p.MeasureSpec.makeMeasureSpec(p.dp_20, ms_at_most),
                        )
                    except: pass

                if has_visible_subtitle:
                    actual_sw = self._get_text_w(subtitle)
                    if actual_sw >= regionWidth - p.dp_8:
                        subtitle.setGravity(3) 
                    else:
                        subtitle.setGravity(1) 

                    # ФИКС 2: Сбрасываем паддинги и трансляцию перед финальным лайаутом
                    try:
                        subtitle.setPadding(0, 0, 0, 0)
                        subtitle.setTranslationX(0.0)
                    except Exception: pass

                    sTop = viewTop + p.dp_24
                    subtitle.layout(regionLeft, sTop, regionRight, sTop + subtitle.getTextHeight())
                    try:
                        if subtitleCopy:
                            sc = subtitleCopy.get() if hasattr(subtitleCopy, 'get') else subtitleCopy
                            if sc: sc.layout(regionLeft, sTop, regionLeft + sc.getMeasuredWidth(), sTop + sc.getTextHeight())
                    except Exception: pass

            try:
                if parentFragment:
                    headerItem = get_private_field(parentFragment, "headerItem")
                    if headerItem: headerItem.setAlpha(0.0)
                        
                parent_ab = this.getParent()
                if parent_ab and p.ActionBarMenuItemClass:
                    for i in range(parent_ab.getChildCount()):
                        child = parent_ab.getChildAt(i)
                        if child and "Menu" in child.getClass().getSimpleName():
                            for j in range(child.getChildCount()):
                                item = child.getChildAt(j)
                                if isinstance(item, p.ActionBarMenuItemClass):
                                    try:
                                        if item.hasSubMenu():
                                            item.setAlpha(0.0)
                                            continue
                                    except Exception: pass
            except Exception: pass
            return None
        except Exception: return None

class _ChatActivityCreateViewHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin
    def after_hooked_method(self, param):
        try:
            this = param.thisObject
            p = self.plugin
            avatarContainer = p.get_cached_view(this, p.f_avatarContainer, "avatarContainer")
            if not avatarContainer: return
            lp = avatarContainer.getLayoutParams()
            if not lp: return
            lp.rightMargin = 0
            if p.AndroidUtilities:
                lp.topMargin = p.AndroidUtilities.dp(p.h_top_margin)
            avatarContainer.setLayoutParams(lp)
        except Exception: pass

class _SearchFieldVisibilityHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def _invalidate_avatar_containers(self, action_bar):
        p = self.plugin
        if not action_bar or not p.ChatAvatarContainerClass: return
        try:
            for i in range(action_bar.getChildCount()):
                child = action_bar.getChildAt(i)
                if isinstance(child, p.ChatAvatarContainerClass):
                    child.invalidate()
        except Exception: pass

    def after_hooked_method(self, param):
        try:
            parent = param.thisObject.getParent()
            for _ in range(6):
                if not parent: break
                if isinstance(parent, self.plugin.ActionBar):
                    self._invalidate_avatar_containers(parent)
                    
                    def force_redraw_later():
                        try:
                            if parent: self._invalidate_avatar_containers(parent)
                        except Exception: pass
                    
                    run_on_ui_thread(force_redraw_later, 250)
                    
                    break
                try: parent = parent.getParent()
                except Exception: break
        except Exception: pass

