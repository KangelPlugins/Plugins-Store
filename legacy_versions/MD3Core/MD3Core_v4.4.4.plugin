            "l_unpinned_stroke_enabled": True, "l_unpinned_stroke_color": 0, "l_unpinned_stroke_opacity": 2, "l_unpinned_stroke_hex": "", "l_unpinned_stroke_width": "1",
            "l_corner_radius": "25", "l_margin_x": "8", "l_margin_y": "3",
