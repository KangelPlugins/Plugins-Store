        super().__init__()
        
        self._default_settings = {
            "use_monet": False,
            "h_md3_container": True, "h_md3_avatar": True, "h_md3_back": True, "h_online_badge": True,
            "h_online_badge_groups": False, "h_static_back_icon": True, "h_full_profile_click": True,
            "h_color_preset": 0, "h_opacity_preset": 5, "h_alpha_preset": 2, "h_custom_hex": "",
