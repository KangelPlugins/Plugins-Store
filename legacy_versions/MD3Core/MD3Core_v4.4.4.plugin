    def get_cached_view(self, obj, field, default_name):
        if not obj: return None
        obj_hash = obj.hashCode()
        cache_key = (obj_hash, default_name)
        
        if cache_key in self._view_cache:
            return self._view_cache[cache_key]
            
        if len(self._view_cache) > 200:
            self._view_cache.clear()
            
        view = None
        if field is not None:
            try: view = field.get(obj)
            except: pass
        if view is None and default_name:
            try: view = get_private_field(obj, default_name)
            except: pass
            
        self._view_cache[cache_key] = view
        return view

    def fast_get(self, field, obj, default_name=None):
        if field is not None:
            try: return field.get(obj)
            except: pass
        if default_name:
            try: return get_private_field(obj, default_name)
            except: pass
        return None

    def _get_field(self, clazz, name):
        try:
            f = clazz.getDeclaredField(name)
            f.setAccessible(True)
            return f
        except: return None

