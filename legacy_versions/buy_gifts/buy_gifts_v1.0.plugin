        except Exception:
            pass

    def _create_round_drawable(self, fill_key: str, stroke_key: str, radius_dp: int, stroke_dp: int):
        try:
            GradientDrawable = jclass("android.graphics.drawable.GradientDrawable")
            bg = GradientDrawable()
            bg.setShape(GradientDrawable.RECTANGLE)
            bg.setCornerRadius(float(self._dp(radius_dp)))

            fill_color = self._theme_color(fill_key)
            if fill_color:
                bg.setColor(int(fill_color))

            if stroke_key and int(stroke_dp) > 0:
                stroke_color = self._theme_color(stroke_key)
                if stroke_color:
                    bg.setStroke(self._dp(stroke_dp), int(stroke_color))
            return bg
        except Exception:
            return None

    def _set_view_background(self, view: Any, background: Any):
