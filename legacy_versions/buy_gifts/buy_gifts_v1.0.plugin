    def _add_field_card(self, container: Any, context: Any, label_text: str, field: Any):
        LinearLayout = jclass("android.widget.LinearLayout")
        ViewGroupLayoutParams = jclass("android.view.ViewGroup$LayoutParams")
        LayoutParams = jclass("android.widget.LinearLayout$LayoutParams")

        card = LinearLayout(context)
        card.setOrientation(LinearLayout.VERTICAL)
        card.setPadding(self._dp(12), self._dp(10), self._dp(12), self._dp(10))
        self._set_view_background(card, self._create_round_drawable("key_dialogBackgroundGray", "key_divider", 14, 1))

        card_lp = LayoutParams(ViewGroupLayoutParams.MATCH_PARENT, ViewGroupLayoutParams.WRAP_CONTENT)
        card_lp.setMargins(0, self._dp(8), 0, 0)
        container.addView(card, card_lp)

        label = self._build_field_label(context, label_text)
        card.addView(label, LayoutParams(ViewGroupLayoutParams.MATCH_PARENT, ViewGroupLayoutParams.WRAP_CONTENT))

        field_lp = LayoutParams(ViewGroupLayoutParams.MATCH_PARENT, ViewGroupLayoutParams.WRAP_CONTENT)
        field_lp.setMargins(0, self._dp(3), 0, 0)
        card.addView(field, field_lp)
        return card

    def _add_message_emoji_action(self, card: Any, context: Any, message_input: Any):
        if card is None or message_input is None:
            return

        try:
            TextView = jclass("android.widget.TextView")
            TypedValue = jclass("android.util.TypedValue")
            ViewGroupLayoutParams = jclass("android.view.ViewGroup$LayoutParams")
            LayoutParams = jclass("android.widget.LinearLayout$LayoutParams")
            Gravity = jclass("android.view.Gravity")
        except Exception:
