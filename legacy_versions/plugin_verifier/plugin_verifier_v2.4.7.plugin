        except Exception as e: log(f"Render Error: {e}")

def parse_metadata_robust(code: str) -> Dict[str, str]:
    meta = {"id": "Unknown", "name": "Unknown", "version": "1.0.0", "author": "Unknown"}
    try:
        for node in ast.walk(ast.parse(code)):
            if isinstance(node, ast.Assign):
                for target in node.targets:
                    if isinstance(target, ast.Name) and target.id in ["__id__", "__name__", "__version__", "__author__"]:
                        try: meta[target.id.strip("_")] = str(ast.literal_eval(node.value))
                        except: pass
    except: pass
    if meta.get("id") == "Unknown":
        for key in ["id", "name", "version", "author"]:
            match = re.search(rf"__{key}__\s*=\s*['\"]([^'\"]+)['\"]", code)
            if match: meta[key] = match.group(1)
    return meta

def extract_advanced_tokens(code_str: str) -> set:
    tokens = set()
    try:
        tree = ast.parse(code_str)
        for node in ast.walk(tree):
            if isinstance(node, ast.FunctionDef) and node.name not in BOILERPLATE_BLACKLIST: tokens.add(f"func:{node.name}")
            elif isinstance(node, ast.ClassDef) and node.name not in BOILERPLATE_BLACKLIST: tokens.add(f"class:{node.name}")
            elif isinstance(node, (ast.Import, ast.ImportFrom)):
                if isinstance(node, ast.Import):
                    for alias in node.names:
                        if alias.name not in BOILERPLATE_BLACKLIST: tokens.add(f"import:{alias.name}")
                elif node.module and node.module not in BOILERPLATE_BLACKLIST: tokens.add(f"import:{node.module}")
            elif isinstance(node, ast.Call):
                if isinstance(node.func, ast.Name) and node.func.id in ('find_class', 'jclass', 'forName'):
                    if node.args and isinstance(node.args[0], ast.Constant) and isinstance(node.args[0].value, str):
                        tokens.add(f"tg_api:{node.args[0].value}")
    except: pass
    return tokens

def compute_code_minhash(tokens: set, num_hashes: int = 16) -> List[int]:
    if not tokens: return [0] * num_hashes
    sig = []
    for i in range(num_hashes):
        min_val = float('inf')
        for token in tokens:
            h_input = f"{i}:{token}".encode('utf-8')
            h_val = int(hashlib.md5(h_input).hexdigest()[:15], 16)
            if h_val < min_val: min_val = h_val
        sig.append(min_val)
    return sig

def get_similarity(sig1: List[int], sig2: List[int]) -> float:
    matches = sum(1 for x, y in zip(sig1, sig2) if x == y)
    return matches / len(sig1)

def analyze_heuristics(code: str) -> List[str]:
    warnings = []
    try: tree = ast.parse(code)
    except: return ["Критическая обфускация"]
    dangerous_imports = {'socket', 'subprocess', 'ctypes', 'smtplib', 'importlib', 'urllib'}
    dangerous_calls = {'eval', 'exec', 'compile', '__import__'}
    for node in ast.walk(tree):
        if isinstance(node, (ast.Import, ast.ImportFrom)):
            names = [node.module] if isinstance(node, ast.ImportFrom) and node.module else []
            names.extend(alias.name for alias in node.names)
            for name in names:
                if name.split('.')[0] in dangerous_imports: warnings.append(f"Импорт {name.split('.')[0]}")
        elif isinstance(node, ast.Call) and isinstance(node.func, ast.Name) and node.func.id in dangerous_calls:
            warnings.append(f"Запуск {node.func.id}()")
        elif isinstance(node, ast.Constant) and isinstance(node.value, str):
            val = node.value.lower()
            if "session" in val: warnings.append("Поиск сессий (.session)")
            if "/data/data/" in val or "shared_prefs" in val: warnings.append("Доступ к директориям Android")
            if len(node.value) > 200 and re.match(r'^[a-zA-Z0-9+/=]+$', node.value.strip()): warnings.append("Строка Base64")
    if re.search(r'(eval|exec)\s*\(', code) and not any("вызов" in w.lower() for w in warnings): warnings.append("Вызов exec/eval")
    if re.search(r'\.session', code) and not any("сесси" in w.lower() for w in warnings): warnings.append("Путь к .session")
    return list(set(warnings))

def get_field_deep(target: Any, name: str) -> Any:
    cl = target.getClass() if target else None
    while cl:
        try:
            field = cl.getDeclaredField(name)
            field.setAccessible(True)
            return field.get(target)
        except: cl = cl.getSuperclass()
    return None

def find_view_pair(root: Any, cls: Any) -> Tuple[Any, Any]:
    if not root or not cls: return None, None
    if isinstance(root, cls): return root, root.getParent()
    if hasattr(root, "getChildCount") and hasattr(root, "getChildAt"):
        for i in range(root.getChildCount()):
            found, parent = find_view_pair(root.getChildAt(i), cls)
            if found: return found, parent
    return None, None

def query_db_native(url_str: str) -> Optional[list]:
    try:
        URL = jclass("java.net.URL")
        HttpsURLConnection = jclass("javax.net.ssl.HttpsURLConnection")
        BufferedReader = jclass("java.io.BufferedReader")
        InputStreamReader = jclass("java.io.InputStreamReader")
        StringBuilder = jclass("java.lang.StringBuilder")

        if not url_str.startswith("https://"): url_str = url_str.replace("http://", "https://")
        url = URL(url_str)
        conn = url.openConnection()
        conn.setRequestMethod("GET")
        conn.setRequestProperty("apikey", SUPABASE_ANON_KEY)
        conn.setRequestProperty("Authorization", f"Bearer {SUPABASE_ANON_KEY}")
        conn.setConnectTimeout(6000)
        conn.setReadTimeout(6000)

        if conn.getResponseCode() == 200:
            reader = BufferedReader(InputStreamReader(conn.getInputStream(), "UTF-8"))
            sb = StringBuilder()
            line = reader.readLine()
            while line is not None:
                sb.append(line)
                line = reader.readLine()
            reader.close()
            res_text = sb.toString()
            if res_text: return json.loads(res_text)
    except Exception as e: log(f"[Verifier] Native query error: {e}")
    return None

def verify_plugin_logic(p_inst, path: str) -> Tuple[str, Optional[Dict[str, Any]], List[str], float]:
    h = get_sha256(path)
    if not h: return "ERROR_READ", None, [], 0.0
    try:
        with open(path, "r", encoding="utf-8", errors="ignore") as f: code = f.read()
    except: return "ERROR_READ", None, [], 0.0
    
    meta = parse_metadata_robust(code)
    p_id = meta.get("id", "Unknown")

    if p_inst._global_whitelist_loaded:
        if h in p_inst._global_whitelist:
            orig_info = p_inst._global_whitelist_signatures.get(h, {})
            return "APPROVED", {"plugin_id": p_id, "original_link": orig_info.get("link", "")}, [], 1.0
    else:
        res = query_db_native(f"{SUPABASE_URL}/rest/v1/verified_plugins?sha256_hash=eq.%5Cx{h}")
        if res: return "APPROVED", res[0], [], 1.0

    if p_inst._global_whitelist_loaded and p_inst._global_whitelist_signatures:
        tokens = extract_advanced_tokens(code)
        current_sig = compute_code_minhash(tokens)
        highest_sim = 0.0; matched_info = None
        for v_hash, info in p_inst._global_whitelist_signatures.items():
            sig = info.get("signature")
            if sig:
                sim = get_similarity(current_sig, sig)
                if sim > highest_sim: highest_sim = sim; matched_info = info
        if highest_sim >= 0.55:
            return "MODIFIED", {"plugin_id": matched_info["id"], "original_link": matched_info["link"], "similarity": highest_sim}, [], highest_sim

    if p_id and p_id != "Unknown":
        if p_inst._global_whitelist_loaded:
            if p_id in p_inst._global_whitelist_ids:
                orig_link = p_inst._global_whitelist_links_by_id.get(p_id, "")
                return "MODIFIED", {"plugin_id": p_id, "original_link": orig_link, "similarity": 0.68}, [], 0.68
        else:
            res_id = query_db_native(f"{SUPABASE_URL}/rest/v1/verified_plugins?plugin_id=eq.{p_id}&order=created_at.desc&limit=1")
            if res_id: return "MODIFIED", res_id[0], [], 0.68

    heuristics = analyze_heuristics(code)
    return ("SUSPICIOUS", None, heuristics, 0.0) if heuristics else ("UNKNOWN", None, [], 0.0)

def async_verify(p_inst, path: str, sheet: Any, p_id: str):
    status, orig, heur, similarity = verify_plugin_logic(p_inst, path)
    def update():
        try:
            ctx = sheet.getContext()
            U = find_class("org.telegram.messenger.AndroidUtilities")
            LH = find_class("org.telegram.ui.Components.LayoutHelper")
            custom_view = get_field_deep(sheet, "customView") or get_field_deep(sheet, "containerView")
            Btn = find_class("org.telegram.ui.Stories.recorder.ButtonWithCounterView")
            TV = jclass("android.widget.TextView")
            LL = jclass("android.widget.LinearLayout")
            IV = jclass("android.widget.ImageView")
            GD = jclass("android.graphics.drawable.GradientDrawable")
            btn, parent = find_view_pair(custom_view, Btn)
            if not btn or not parent: return

            def find_badge(view):
                if not view: return None, None
                if isinstance(view, LL) and view.getOrientation() == 0:
                    for idx in range(view.getChildCount()):
                        child = view.getChildAt(idx)
                        if isinstance(child, TV):
                            text = str(child.getText() or "").lower()
                            if "источник" in text or "source" in text:
                                return view, view.getParent()
                if hasattr(view, "getChildCount"):
                    for idx in range(view.getChildCount()):
                        found, p = find_badge(view.getChildAt(idx))
                        if found: return found, p
                return None, None

            badge, b_parent = find_badge(custom_view)
            
            target_idx = 1
            if badge and b_parent:
                target_idx = b_parent.indexOfChild(badge)
                b_parent.removeView(badge)
            else:
                for i in range(parent.getChildCount()):
                    child = parent.getChildAt(i)
                    if isinstance(child, TV):
                        text = str(child.getText() or "").lower()
                        if "источник" in text or "source" in text or "надёжный" in text or "неизвестный" in text:
                            target_idx = i
                            badge = child
                            parent.removeView(child)
                            break

            row = LL(ctx)
            row.setOrientation(0)
            row.setGravity(17)

            if badge:
                row.addView(badge)
                spacer = View(ctx)
                row.addView(spacer, LH.createLinear(8, 0))

            def make_chip(txt, status_type):
                b = create_modern_chip(ctx, txt, status_type)
                orig_link = orig.get("original_link") if orig else ""
                
                class OpenAnalyzerClick(dynamic_proxy(View.OnClickListener)):
                    def __init__(self, c, p, pid, o_link, sim, st, p_inst): super().__init__(); self.c=c; self.p=p; self.pid=pid; self.o_link=o_link; self.sim=sim; self.st=st; self.p_inst=p_inst
                    def onClick(self, v): AnalyzerBottomSheet(self.c, self.p, self.pid, self.o_link, self.sim, self.st, self.p_inst).show()
                b.setOnClickListener(OpenAnalyzerClick(ctx, path, p_id, orig_link, similarity, status, p_inst))
                return b

            if status == "APPROVED": 
                row.addView(make_chip("Проверен", "approved"), LH.createLinear(-2, -2))
            elif status == "MODIFIED": 
                row.addView(make_chip("Подмена", "modified"), LH.createLinear(-2, -2))
            elif status == "SUSPICIOUS": 
                row.addView(make_chip("Опасно", "modified"), LH.createLinear(-2, -2))
            else: 
                row.addView(make_chip("Неизвестно", "ordinary"), LH.createLinear(-2, -2))
            
            parent.addView(row, target_idx, LH.createLinear(-1, -2, 0, 12, 0, 12))

            if status != "APPROVED":
                warning_card = LL(ctx)
                warning_card.setOrientation(1)
                warning_card.setPadding(U.dp(16), U.dp(14), U.dp(16), U.dp(14))
                is_dark = Theme.isCurrentThemeDark()
                g = GD()
                g.setCornerRadius(float(U.dp(12)))
                warning_card.setBackground(g)
                title_row = LL(ctx)
                title_row.setOrientation(0)
                title_row.setGravity(16)
                warn_icon = IV(ctx)
                R_drawable = jclass("org.telegram.messenger.R").drawable
                warn_icon.setImageResource(getattr(R_drawable, "msg_info", 0))
                warn_title = TV(ctx)
                warn_title.setTextSize(1, 14.5)
                warn_title.setTypeface(AndroidUtilities.bold())
                warn_desc = TV(ctx)
                warn_desc.setTextSize(1, 13.0)
                warn_desc.setPadding(0, U.dp(6), 0, 0)
                warn_desc.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
                
                if status == "MODIFIED" and orig:
                    g.setColor(to_s32(0x16EF5350 if is_dark else 0x12D32F2F))
                    warn_title.setText("Внимание: обнаружена подмена")
                    warn_title.setTextColor(to_s32(0xFFEF5350 if is_dark else 0xFFC62828))
                    warn_icon.setColorFilter(jclass("android.graphics.PorterDuffColorFilter")(to_s32(0xFFEF5350 if is_dark else 0xFFC62828), jclass("android.graphics.PorterDuff$Mode").SRC_IN))
                    sim_val = orig.get("similarity", similarity)
                    warn_desc.setText(f"Сходство: {sim_val * 100:.1f}%\nФайл изменён или заражён.\nЭто не оригинальный плагин.")
                    btn.setText("Установить изменённую версию", True)
                    try: btn.setBackground(Theme.createSimpleSelectorRoundRectDrawable(U.dp(8), to_s32(0xFFC62828), to_s32(0xFFB71C1C)))
                    except: pass
                elif status == "UNKNOWN":
                    g.setColor(to_s32(0x169E9E9E if is_dark else 0x12757575))
                    warn_title.setText("Внимание: неизвестный источник")
                    warn_title.setTextColor(to_s32(0xFF9E9E9E if is_dark else 0xFF424242))
                    warn_icon.setColorFilter(jclass("android.graphics.PorterDuffColorFilter")(to_s32(0xFF9E9E9E if is_dark else 0xFF424242), jclass("android.graphics.PorterDuff$Mode").SRC_IN))
                    warn_desc.setText("Файл отсутствует в реестре проверенных плагинов Exteragram.\nУстанавливайте только если доверяете автору.")
                    btn.setText("Установить неизвестный плагин", True)
                elif status == "SUSPICIOUS":
                    g.setColor(to_s32(0x16EF5350 if is_dark else 0x12D32F2F))
                    warn_title.setText("Внимание: подозрительный код")
                    warn_title.setTextColor(to_s32(0xFFEF5350 if is_dark else 0xFFC62828))
                    warn_icon.setColorFilter(jclass("android.graphics.PorterDuffColorFilter")(to_s32(0xFFEF5350 if is_dark else 0xFFC62828), jclass("android.graphics.PorterDuff$Mode").SRC_IN))
                    warn_desc.setText(f"Обнаружен подозрительный код в неизвестном файле!\nНайденные угрозы: {', '.join(heur)}. Рекомендуется отменить установку.")
                    btn.setText("Установить подозрительный код", True)
                    try: btn.setBackground(Theme.createSimpleSelectorRoundRectDrawable(U.dp(8), to_s32(0xFFD84315), to_s32(0xFFBF360C)))
                    except: pass
                
                title_row.addView(warn_icon, LH.createLinear(20, 20, 0, 0, 8, 0))
                title_row.addView(warn_title, LH.createLinear(-1, -2))
                warning_card.addView(title_row, LH.createLinear(-1, -2))
                warning_card.addView(warn_desc, LH.createLinear(-1, -2))
                
                b_idx = parent.indexOfChild(btn)
                if b_idx != -1: parent.addView(warning_card, b_idx, LH.createLinear(-1, -2, 0, 14, 0, 14, 12))
            parent.requestLayout()
        except Exception as e: log(f"[Verifier] UI update err: {e}")
    run_on_ui_thread(update)

class _OpenForViewHook(MethodHook):
    def __init__(self, p):
        self.p = p

    def before_hooked_method(self, param):
        try:
            if not param.args:
                return

            file_path = None
            filename = None
            activity = None
            doc = None
            message_obj = None
            arg_types = [str(type(a)) + (" (None)" if a is None else "") for a in param.args]
            log(f"[Verifier] openForView called with args: {arg_types}")

            for arg in param.args:
                if arg is None:
                    continue
                
                if isinstance(arg, str):
                    if os.path.exists(arg):
                        file_path = arg
                        filename = os.path.basename(file_path).lower()
                    elif "." in arg:
                        filename = arg.lower()
                    continue

                if not hasattr(arg, "getClass"):
                    continue

                cl_name = str(arg.getClass().getName())

                if "Activity" in cl_name and "$" not in cl_name and "Delegate" not in cl_name:
                    activity = arg
                elif "MessageObject" in cl_name:
                    message_obj = arg
                    doc = message_obj.getDocument()
                elif hasattr(arg, "getDocument"):
                    doc = arg.getDocument()
                elif "java.io.File" in cl_name:
                    file_path = str(arg.getAbsolutePath())
                    filename = os.path.basename(file_path).lower()

            if doc and not filename:
                try:
                    FileLoader_class = find_class("org.telegram.messenger.FileLoader")
                    filename = str(FileLoader_class.getAttachFileName(doc) or "").lower()
                except:
                    filename = str(getattr(doc, "file_name_fixed", "")).lower()

            log(f"[Verifier] Extracted filename: {filename}")

            if doc and (not file_path or not os.path.exists(file_path)):
                try:
                    uc_cls = find_class("org.telegram.messenger.UserConfig")
                    account = int(get_private_field(uc_cls, "selectedAccount") or 0)
                    fl = find_class("org.telegram.messenger.FileLoader").getInstance(account)
                    
                    if message_obj and hasattr(message_obj, "messageOwner"):
                        path_obj = fl.getPathToMessage(message_obj.messageOwner)
                        if path_obj and path_obj.exists():
                            file_path = str(path_obj.getAbsolutePath())
                            log(f"[Verifier] Found path via getPathToMessage: {file_path}")
                    
                    if not file_path or not os.path.exists(file_path):
                        path_obj = fl.getPathToAttach(doc, False)
                        if path_obj and path_obj.exists():
                            file_path = str(path_obj.getAbsolutePath())
                            log(f"[Verifier] Found path via getPathToAttach(False): {file_path}")

                    if not file_path or not os.path.exists(file_path):
                        path_obj = fl.getPathToAttach(doc, True)
                        if path_obj and path_obj.exists():
                            file_path = str(path_obj.getAbsolutePath())
                            log(f"[Verifier] Found path via getPathToAttach(True): {file_path}")

                except Exception as e:
                    log(f"[Verifier] FileLoader path extraction error: {e}")

            if not file_path or not os.path.exists(file_path):
                try:
                    if message_obj and hasattr(message_obj, "messageOwner") and message_obj.messageOwner.attachPath:
                        temp_path = str(message_obj.messageOwner.attachPath)
                        if os.path.exists(temp_path):
                            file_path = temp_path
                            log(f"[Verifier] Found path via attachPath: {file_path}")
                except:
                    pass

            log(f"[Verifier] Final file_path: {file_path}, exists: {os.path.exists(file_path) if file_path else False}")

            if filename and any(filename.endswith(ext) for ext in [".dex", ".so", ".db", ".sqlite", ".rs", ".cpp", ".h", ".c", ".py", ".plugin", ".txt", ".json", ".conf"]):
                if not activity:
                    from client_utils import get_last_fragment
                    frag = get_last_fragment()
                    if frag:
                        activity = frag.getParentActivity()
                
                if activity and file_path and os.path.exists(file_path):
                    from java import jboolean
                    param.setResult(jboolean(True)) 
                    
                    from android_utils import run_on_ui_thread
                    run_on_ui_thread(lambda: self.p.open_direct_file(activity, file_path, filename))
                    
                elif activity:
                    from java import jboolean
                    param.setResult(jboolean(True))
                    
                    def show_safe_toast():
                        try:
                            from ui.bulletin import BulletinHelper
                            BulletinHelper.show_error("Скачайте файл перед открытием!")
                        except:
                            from android.widget import Toast
                            Toast.makeText(activity, "Скачайте файл перед открытием!", 0).show()
                    
                    from android_utils import run_on_ui_thread
                    run_on_ui_thread(show_safe_toast)

        except Exception as e:
            log(f"[Verifier] openForView exception: {e}")

class PluginVerifierPlugin(BasePlugin):
    def __init__(self):
        super().__init__()
        self._hooks = []
        self._stored_activity = None
        self._global_whitelist = {}
        self._global_whitelist_ids = set()
        self._global_whitelist_links_by_id = {}
        self._global_whitelist_signatures = {}
        self._global_whitelist_loaded = False
        self._local_scan_cache = {}

    def on_plugin_load(self):
        self._hook_install_ui()
        self._hook_plugin_cell()
        self._hook_open_for_view()
        self._async_load_global_whitelist()

    def on_plugin_unload(self):
        for h in self._hooks:
            try: self.unhook_method(h)
            except: pass
        self._hooks.clear()
        self._stored_activity = None
        self._global_whitelist.clear()
        self._global_whitelist_ids.clear()
        self._global_whitelist_links_by_id.clear()
        self._global_whitelist_signatures.clear()
        self._global_whitelist_loaded = False
        self._local_scan_cache.clear()

    def create_settings(self):
        from ui.settings import Header, Selector
        return [
            Header(text="Просмотр баз данных (SQLite)"),
            Selector(
                key="db_pagination_mode",
                text="Режим пагинации",
                default=0,
                items=["Подгружать ниже (Append)", "Заменять список (Replace)"],
                icon="msg_menu"
            )
        ]

    def open_direct_file(self, activity, file_path: str, filename: str):
        try:
            fn_lower = filename.lower()
            if fn_lower.endswith((".db", ".sqlite")):
                DbViewerBottomSheet(activity, file_path, self).show()
            elif fn_lower.endswith((".rs", ".cpp", ".h", ".c", ".py", ".plugin", ".txt", ".json", ".conf")):
                with open(file_path, "r", encoding="utf-8", errors="ignore") as f:
                    code_content = f.read()
                CodeViewerBottomSheet(activity, filename, code_content, file_path).show()
            elif fn_lower.endswith((".dex", ".so")):
                AnalyzerBottomSheet(activity, file_path, filename, status="UNKNOWN", similarity=0.0, plugin_instance=self).show()
        except Exception as e:
            log(f"[Verifier] open_direct_file error: {e}")
            BulletinHelper.show_error("Ошибка открытия файла")

    def _get_plugin_path(self, p_id: str) -> str:
        try:
            pc = find_class("com.exteragram.messenger.plugins.PluginsController").getInstance()
            path = pc.getPluginPath(p_id)
            if path: return str(path)
        except: pass
        try:
            p_dir = os.path.join(ApplicationLoader.applicationContext.getFilesDir().getAbsolutePath(), "plugins")
            return os.path.join(p_dir, f"{p_id}.plugin")
        except: return ""

    def _hook_install_ui(self):
        try:
            jc = find_class("java.lang.Class")
            sheet_cl = jc.forName("com.exteragram.messenger.plugins.ui.components.InstallPluginBottomSheet") if jc else None
            if sheet_cl:
                for ctor in sheet_cl.getDeclaredConstructors():
                    params = ctor.getParameterTypes()
                    if len(params) == 3 and "BaseFragment" in params[0].getName() and "PluginInstallParams" in params[2].getName():
                        ctor.setAccessible(True)
                        self._hooks.append(self.hook_method(ctor, self._InstallSheetHook(self)))
                        break
        except: pass

    def _hook_plugin_cell(self):
        try:
            cell_cl = find_class("com.exteragram.messenger.plugins.ui.components.PluginCell")
            if cell_cl:
                for meth in cell_cl.getClass().getDeclaredMethods():
                    if meth.getName() == "set" and len(meth.getParameterTypes()) == 2:
                        meth.setAccessible(True)
                        self._hooks.append(self.hook_method(meth, self._PluginCellHook(self)))
                        break
        except: pass

    def _hook_open_for_view(self):
        try:
            jc = find_class("java.lang.Class")
            au_cls = jc.forName("org.telegram.messenger.AndroidUtilities")
            hooked_count = 0
            for m in au_cls.getDeclaredMethods():
                if m.getName() == "openForView" and len(m.getParameterTypes()) >= 2:
                    m.setAccessible(True)
                    self._hooks.append(self.hook_method(m, _OpenForViewHook(self)))
                    hooked_count += 1
            log(f"[Verifier] Successfully hooked {hooked_count} overloads of openForView")
        except Exception as e:
            log(f"[Verifier] Failed to hook openForView: {e}")

    def _async_load_global_whitelist(self):
        if self._global_whitelist_loaded: return
        def task():
            url = f"{SUPABASE_URL}/rest/v1/verified_plugins?select=sha256_hash,plugin_id,original_link,code_signature"
            res = query_db_native(url)
            if res:
                wl, wl_ids, wl_links, wl_sigs = {}, set(), {}, {}
                for item in res:
                    h = item.get("sha256_hash")
                    p_id = item.get("plugin_id")
                    orig_l = item.get("original_link")
                    sig = item.get("code_signature")
                    if h and h.startswith("\\x"):
                        clean_h = h[2:].lower()
                        wl[clean_h] = p_id
                        if p_id:
                            wl_ids.add(p_id)
                            if orig_l: wl_links[p_id] = orig_l
                            if sig: wl_sigs[clean_h] = {"id": p_id, "link": orig_l, "signature": sig}
                self._global_whitelist = wl
                self._global_whitelist_ids = wl_ids
                self._global_whitelist_links_by_id = wl_links
                self._global_whitelist_signatures = wl_sigs
                self._global_whitelist_loaded = True
                self._refresh_plugins_list()
        threading.Thread(target=task, daemon=True).start()

    def _open_url(self, context, url: str):
        if not url or not isinstance(url, str) or url.strip() == "": return
        try:
            from android.content import Intent
            from android.net import Uri
            context.startActivity(Intent(Intent.ACTION_VIEW, Uri.parse(url)))
        except: pass

    def _refresh_plugins_list(self):
        activity = self._stored_activity
        if not activity: return
        def run():
            try:
                list_view = get_private_field(activity, "listView")
                if list_view and list_view.adapter: list_view.adapter.update(True)
            except: pass
        run_on_ui_thread(run)

    class _InstallSheetHook(MethodHook):
        def __init__(self, p): self.p = p
        @catch
        def after_hooked_method(self, param):
            sheet = param.thisObject
            params = param.args[2] if len(param.args) > 2 else None
            if sheet and params:
                path = get_field_deep(params, "filePath")
                p_id = get_field_deep(params, "plugin")
                p_id_str = str(p_id.getId()) if p_id else "Unknown"
                if path: threading.Thread(target=async_verify, args=(self.p, str(path), sheet, p_id_str), daemon=True).start()

    class _PluginCellHook(MethodHook):
        def __init__(self, p): self.p = p
        @catch
        def after_hooked_method(self, param):
            obj = param.args[0]
            p_id = str(obj.getId()) if obj else ""
            if not p_id: return
            sub = get_private_field(param.thisObject, "subtitleView")
            if sub is None: return
            
            sub_text = str(sub.getText() or "")
            clean = sub_text
            for pfx in ["✅ Проверен", "🔴 Осторожно!", "🔴 Осторожно! (Нажмите для перехода к оригиналу)"]:
                if clean.startswith(pfx): clean = clean.replace(pfx, "").strip(" · ")

            if p_id in self.p._local_scan_cache:
                status, matched_id, similarity = self.p._local_scan_cache[p_id]
            else:
                path = self.p._get_plugin_path(p_id)
                h = get_sha256(path)
                if not h: return
                status = "UNKNOWN"
                matched_id = None
                similarity = 0.0
                
                if self.p._global_whitelist_loaded:
                    if h in self.p._global_whitelist: status = "APPROVED"; similarity = 1.0
                    else:
                        try:
                            with open(path, "r", encoding="utf-8", errors="ignore") as f: code = f.read()
                            tokens = extract_advanced_tokens(code)
                            current_sig = compute_code_minhash(tokens)
                            highest_sim = 0.0; matched_info = None
                            for v_hash, info in self.p._global_whitelist_signatures.items():
                                sig = info.get("signature")
                                if sig:
                                    sim = get_similarity(current_sig, sig)
                                    if sim > highest_sim: highest_sim = sim; matched_info = info
                            if highest_sim >= 0.55:
                                status = "MODIFIED"
                                matched_id = matched_info["id"]
                                similarity = highest_sim
                        except: pass
                        if status == "UNKNOWN" and p_id in self.p._global_whitelist_ids:
                            status = "MODIFIED"
                            matched_id = p_id
                            similarity = 0.68
                self.p._local_scan_cache[p_id] = (status, matched_id, similarity)

            SSB = jclass("android.text.SpannableStringBuilder")
            FCS = jclass("android.text.style.ForegroundColorSpan")
            Spanned = jclass("android.text.Spanned")
            sb = SSB()
            
            if status == "APPROVED":
                sb.append("✅ Проверен")
                sb.setSpan(FCS(to_s32(0xFF2E7D32)), 0, len("✅ Проверен"), Spanned.SPAN_EXCLUSIVE_EXCLUSIVE)
                sub.setOnClickListener(None)
                sub.setClickable(False)
            elif status == "MODIFIED":
                lookup_id = matched_id or p_id
                link = self.p._global_whitelist_links_by_id.get(lookup_id, "https://t.me/exteraSettings")
                label = "🔴 Осторожно! (Нажмите для перехода к оригиналу)"
                sb.append(label)
                sb.setSpan(FCS(to_s32(0xFFC62828)), 0, len(label), Spanned.SPAN_EXCLUSIVE_EXCLUSIVE)
                class LinkClick(dynamic_proxy(View.OnClickListener)):
                    def __init__(self, p_self, url, ctx): super().__init__(); self.p=p_self; self.url=url; self.ctx=ctx
                    def onClick(self, v): self.p._open_url(self.ctx, self.url)
                sub.setOnClickListener(LinkClick(self.p, link, param.thisObject.getContext()))
                sub.setClickable(True)
            
            if sb.length() > 0:
                if clean.strip():
                    sb.append(" · ")
                    sb.append(clean)
                sub.setText(sb)
            else: sub.setText(clean)