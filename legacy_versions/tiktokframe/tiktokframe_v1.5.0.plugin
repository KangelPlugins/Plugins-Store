FRAME_URL = "https://www.clipartmax.com/png/full/283-2835256_golden-frame-png-image-background-frame-gold-png-transparent.png"
FRAME_CACHE_NAME = "frame_gold_cut.png"

FONT_BOLD_URL = "https://github.com/source-foundry/Hack/raw/refs/heads/master/build/ttf/Hack-Bold.ttf"
FONT_REGULAR_URL = "https://github.com/source-foundry/Hack/raw/refs/heads/master/build/ttf/Hack-Regular.ttf"

TWEMOJI_BASE = "https://cdn.jsdelivr.net/gh/twitter/twemoji@14.0.2/assets/72x72/"

