_class_cache = {}

DEFAULT_SETTINGS = {
    "enabled": True,
    "apply_action_bar": True,
    "apply_top_panels": True,
    "apply_pinned": True,
    "apply_search_bar": True,
    "apply_story_bar": True,
    "apply_compose_bar": True,
    "apply_dialogs_list": False,
    "apply_settings_header": False,
    "apply_topics_header": False,
    "action_bar_alpha": "0.82",
    "panel_alpha": "0.80",
    "action_bar_thickness": "14",
    "panel_thickness": "12",
    "action_bar_intensity": "0.42",
    "panel_intensity": "0.38",
    "panel_radius": "12",
    "glass_offset_x_dp": "0",
    "glass_offset_y_dp": "0",
    "strong_glass": False,
    "debug_logs": False,
    "performance_mode": False,
}

class _ColorProviderProxy(dynamic_proxy(BlurredBackgroundColorProvider)):
    def __init__(self, base, disable_top_stroke=False, disable_shadow=False, disable_bottom_stroke=False):
        super().__init__()
        self._base = base
        self._disable_top_stroke = disable_top_stroke
        self._disable_shadow = disable_shadow
        self._disable_bottom_stroke = disable_bottom_stroke

    def getShadowColor(self):
        if self._disable_shadow:
            return 0
        try:
            return self._base.getShadowColor()
        except Exception:
            return 0

    def getBackgroundColor(self):
        try:
            return self._base.getBackgroundColor()
        except Exception:
            return 0

    def getStrokeColorTop(self):
        if self._disable_top_stroke:
            return 0
        try:
            return self._base.getStrokeColorTop()
        except Exception:
            return 0

    def getStrokeColorBottom(self):
        if self._disable_bottom_stroke:
            return 0
        try:
            return self._base.getStrokeColorBottom()
        except Exception:
            return 0


def safe_find_class(class_name):
    if class_name in _class_cache:
        return _class_cache[class_name]
    try:
        cls = find_class(class_name)
        _class_cache[class_name] = cls
        return cls
    except Exception:
        _class_cache[class_name] = None
        return None


def _get_first_available_field(obj, *names):
    if not obj or not names:
        return None
    for name in names:
        try:
            v = getattr(obj, name, None)
        except Exception:
            v = None
        if v is not None:
            return v
        try:
            v = get_private_field(obj, name)
        except Exception:
            v = None
        if v is not None:
            return v
    return None


def _truthy_fragment_flag(raw):
    if raw is None:
        return False
    try:
        if callable(raw):
            raw = raw()
    except Exception:
        return False
    try:
        return bool(raw)
    except Exception:
        return False


class LiquidGlassPlugin(BasePlugin):
    _CONTEXT_STYLE_AUDIO_PLAYER = 0
    _CONTEXT_STYLE_INACTIVE_GROUP_CALL = 4
    _CONTEXT_STYLE_STORY = 5
    _APPLY_DEBOUNCE_MS = 100
    _PERFORMANCE_DEBOUNCE_MS = 200
    _DRAWABLE_CACHE_MAX = 256
    _MIN_TOP_PANEL_DP = 8
    _MIN_PINNED_ROW_DP = 18
    _MIN_PINNED_LATCH_DP = 26
    _MAX_STORY_TOPICS_STRIP_HEIGHT_DP = 200
    _DIALOGS_EXTRA_FROM_CELL_MS = 520

    def __init__(self):
        super().__init__()
        self._hooks = []
        self._applied = {}
        self._warned = False
        self._apply_pending = set()
        self._apply_requested = set()
        self._drawable_cache = OrderedDict()
        self._last_apply_time = {}
        self._active_chats = WeakSet()
        self._extras_applied = {}
        self._active_extras = WeakSet()
        self._stats = {"apply_count": 0, "cache_hits": 0, "cache_misses": 0, "cache_evictions": 0}
        self._last_dialogs_extra_from_cell = {}

    def on_plugin_load(self):
        self._warned = False
        self._hook_chat_activity()
        self._hook_chat_activity_enter_view()
        self._hook_dialog_cell_extras()
        self._hook_fragment_context_view()
        self._hook_chat_search_tabs()
        self._hook_extra_fragments()
        log(f"[LG] Liquid Glass v{__version__} loaded")

    def on_plugin_unload(self):
        try:
            self._last_dialogs_extra_from_cell.clear()
        except Exception:
            self._last_dialogs_extra_from_cell = {}
        for ref in self._hooks:
            try:
                self.unhook_method(ref)
            except Exception:
                pass
        self._hooks.clear()
        self._drawable_cache.clear()
        _class_cache.clear()
        run_on_ui_thread(lambda: self._restore_all(reapply_after=False))
        run_on_ui_thread(lambda: self._restore_all_extras(reapply_after=False))
        log("[LG] Plugin unloaded")

    def _register_hook(self, ref):
        if ref and ref not in self._hooks:
            self._hooks.append(ref)

    def _open_tg(self, username):
        u = str(username or "").strip().lstrip("@")
        if not u:
            return
        try:
            AppLoader = safe_find_class("org.telegram.messenger.ApplicationLoader")
            if AppLoader is None:
                AppLoader = safe_find_class("com.exteragram.messenger.ApplicationLoader")
            Intent_cls = safe_find_class("android.content.Intent")
            Uri_cls = safe_find_class("android.net.Uri")
            if AppLoader is None or Intent_cls is None or Uri_cls is None:
                return
            ctx = AppLoader.applicationContext
            if ctx is None:
                return
            it = Intent_cls(Intent_cls.ACTION_VIEW, Uri_cls.parse("tg://resolve?domain=%s" % u))
            it.addFlags(Intent_cls.FLAG_ACTIVITY_NEW_TASK)
            ctx.startActivity(it)
        except Exception as e:
            if self.get_setting("debug_logs", False):
                log("[LG] open_tg: %s" % e)

    def _requirements_hint_widgets(self):
        rows = []
        if Build.VERSION.SDK_INT < 33:
            rows.append(
                Text(
                    text="Нужен Android 13+",
                    subtext="Жидкое стекло работает с API 33.",
                    icon="msg_warning",
                )
            )
        try:
            blur_on = SharedConfig.chatBlurEnabled()
        except Exception:
            blur_on = True
        if not blur_on:
            rows.append(
                Text(
                    text="Включите размытие чата",
                    subtext="Telegram / AyuGram: Настройки → Настройки чата → Размытие (вкл). Без этого эффект не включится.",
                    icon="msg_warning",
                )
            )
        return rows

    def _get_application_context(self):
        for pkg in (
            "org.telegram.messenger.ApplicationLoader",
            "com.exteragram.messenger.ApplicationLoader",
        ):
            AL = safe_find_class(pkg)
            if not AL:
                continue
            try:
                ctx = AL.applicationContext
                if ctx is not None:
                    return ctx
            except Exception:
                pass
        return None

    def _clipboard_copy_text(self, text):
        ctx = self._get_application_context()
        if not ctx or not text:
            return False
        try:
            Context = safe_find_class("android.content.Context")
            ClipData = safe_find_class("android.content.ClipData")
            if not Context or not ClipData:
                return False
            cm = ctx.getSystemService(Context.CLIPBOARD_SERVICE)
            if not cm:
                return False
            clip = ClipData.newPlainText("Liquid Glass", text)
            cm.setPrimaryClip(clip)
            return True
        except Exception as e:
            if self.get_setting("debug_logs", False):
                log("[LG] clipboard copy: %s" % e)
            return False

    def _clipboard_get_text(self):
        ctx = self._get_application_context()
        if not ctx:
            return None
        try:
            Context = safe_find_class("android.content.Context")
            if not Context:
                return None
            cm = ctx.getSystemService(Context.CLIPBOARD_SERVICE)
            if not cm:
                return None
            clip = cm.getPrimaryClip()
            if not clip or clip.getItemCount() < 1:
                return None
            t = clip.getItemAt(0).getText()
            if t is None:
                return None
            return str(t)
        except Exception as e:
            if self.get_setting("debug_logs", False):
                log("[LG] clipboard read: %s" % e)
            return None

    def _coerce_import_value(self, key, raw):
        if key not in DEFAULT_SETTINGS:
            return None
        default = DEFAULT_SETTINGS[key]
        if isinstance(default, bool):
            if isinstance(raw, bool):
                return raw
            if isinstance(raw, (int, float)):
                return raw != 0
            s = str(raw).strip().lower()
            return s in ("1", "true", "yes", "on", "да")
        return str(raw)

    def _export_profile_json(self):
        payload = {
            "format": "liquid_glass",
            "version": __version__,
            "settings": {k: self.get_setting(k, DEFAULT_SETTINGS[k]) for k in DEFAULT_SETTINGS},
        }
        try:
            text = json.dumps(payload, ensure_ascii=False, indent=2)
        except Exception as e:
            try:
                BulletinHelper.show_info("Ошибка экспорта")
            except Exception:
                pass
            if self.get_setting("debug_logs", False):
                log("[LG] export json: %s" % e)
            return
        if self._clipboard_copy_text(text):
            try:
                BulletinHelper.show_info("Профиль скопирован в буфер")
            except Exception:
                pass
        else:
            try:
                BulletinHelper.show_info("Не удалось записать буфер обмена")
            except Exception:
                pass

    def _import_profile_from_clipboard(self):
        raw = self._clipboard_get_text()
        if not raw or not str(raw).strip():
            try:
                BulletinHelper.show_info("Буфер пуст")
            except Exception:
                pass
            return
        try:
            obj = json.loads(str(raw).strip())
        except Exception:
            try:
                BulletinHelper.show_info("Неверный JSON в буфере")
            except Exception:
                pass
            return
        if not isinstance(obj, dict):
            try:
                BulletinHelper.show_info("Ожидался объект JSON")
            except Exception:
                pass
            return
        fmt = obj.get("format")
        if fmt is not None and fmt != "liquid_glass":
            try:
                BulletinHelper.show_info("Это не профиль Liquid Glass")
            except Exception:
                pass
            return
        inner = obj.get("settings", obj)
        if not isinstance(inner, dict):
            try:
                BulletinHelper.show_info("Нет блока settings")
            except Exception:
                pass
            return
        if "apply_profile_header" in inner and "apply_settings_header" not in inner:
            inner = dict(inner)
            inner["apply_settings_header"] = inner.get("apply_profile_header")
        merged = {k: self.get_setting(k, DEFAULT_SETTINGS[k]) for k in DEFAULT_SETTINGS}
        n = 0
        for k, v in inner.items():
            if k not in DEFAULT_SETTINGS:
                continue
            c = self._coerce_import_value(k, v)
            if c is None:
                continue
            merged[k] = c
            n += 1
        if n == 0:
            try:
                BulletinHelper.show_info("Нет распознанных полей")
            except Exception:
                pass
            return
        self._persist_settings_bulk(merged)
        self._drawable_cache.clear()
        self._last_apply_time.clear()
        run_on_ui_thread(self._restore_all)
        try:
            BulletinHelper.show_info("Импорт: %d полей" % n)
        except Exception:
            pass

