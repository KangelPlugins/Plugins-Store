            Switch(key="apply_top_panels", text="Верхние панели", subtext="Плашки над сообщениями", default=True, on_change=on_change),
            Divider(),
            Switch(key="apply_search_bar", text="Поиск", subtext="Панель поиска внутри чата", default=True, on_change=on_change),
