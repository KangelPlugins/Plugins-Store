        if hints:
            head.append(Divider())
        head.extend(
            [
            Switch(
                key="enabled",
                text="Включить эффект",
                subtext="Главный переключатель плагина",
                default=True,
                on_change=on_change,
            ),
            Divider(),
            Header(text="Настройка"),
            Text(
                text="Области применения",
                subtext="Где отображать стеклянный эффект",
                icon="msg_folders",
                create_sub_fragment=self._create_areas_settings,
            ),
            Text(
                text="Внешний вид",
                subtext="Прозрачность и профиль эффекта",
                icon="msg_theme",
                create_sub_fragment=self._create_appearance_settings,
            ),
            Text(
                text="Тонкая настройка",
                subtext="Толщина и интенсивность",
                icon="msg_photo_settings",
                create_sub_fragment=self._create_position_settings,
            ),
            Divider(),
            Header(text="Сервис"),
            Text(
                text="Инструменты",
                subtext="Импорт, экспорт и обслуживание",
                icon="msg_settings",
                create_sub_fragment=self._create_tools_settings,
            ),
            Text(
                text="Справка",
                subtext="Кратко о работе и настройке",
                icon="msg_info",
                create_sub_fragment=self._create_help_settings,
            ),
            Divider(),
            Header(text="О плагине"),
            Text(
                text="@PluginProject",
                subtext="Канал",
                icon="msg_channel",
                accent=True,
                on_click=lambda v: self._open_tg("PluginProject"),
            ),
            Text(
                text="@w3b_0s1nt",
                subtext="Автор",
                icon="msg_contact",
                accent=True,
                on_click=lambda v: self._open_tg("w3b_0s1nt"),
            ),
            Divider(text="%s · v%s" % (__name__, __version__)),
            ]
        )
        return head

