def expand_surrogates(text):
    return re.compile(r"[\U00010000-\U0010FFFF]").sub(
        lambda match: "".join(chr(i) for i in unpack("<HH", match.group().encode("utf-16le"))),
        text,
    )


def collapse_surrogates(text):
    return text.encode("utf-16", "surrogatepass").decode("utf-16")


def is_russian():
    try:
        return Locale.getDefault().getLanguage() == "ru"
    except Exception:
        return True


def localize(ru_text, en_text):
    return ru_text if is_russian() else en_text


def debug_log(message):
    if DEBUG:
        log(f"[{__id__}] {message}")


def code_span(value):
    return str(value or "").replace("`", "'")


def text_setting(text, subtext="", **kwargs):
    label = str(text or "")
    detail = str(subtext or "").strip()
    if detail:
        try:
            return Text(text=label, subtext=detail, **kwargs)
        except TypeError:
            label = f"{label}: {detail}"
    return Text(text=label, **kwargs)


def with_premium_emoji(text):
    parts = re.split(r"(`[^`]*`)", str(text or ""))
    for index, part in enumerate(parts):
        if index % 2 == 1:
            continue
        for regular_emoji, premium_emoji in PREMIUM_EMOJI.items():
            part = part.replace(regular_emoji, premium_emoji)
        parts[index] = part
    return "".join(parts)


def format_date(timestamp):
    if not timestamp:
        return localize("Неизвестно", "Unknown")
    dt = datetime.fromtimestamp(int(timestamp))
    if is_russian():
        return f"{dt.day} {MONTHS_RU[dt.month]} {dt.year}"
    return f"{MONTHS_EN[dt.month]} {dt.day}, {dt.year}"


def format_age(value):
    try:
        month, year = map(int, str(value or "").split("."))
    except Exception:
        return localize("Неизвестно", "Unknown")

    now = datetime.now()
    years = now.year - year
    months = now.month - month
    if months < 0:
        years -= 1
        months += 12

    if is_russian():
        if years <= 0 and months <= 0:
            return "меньше месяца"
        parts = []
        if years > 0:
            if years % 10 == 1 and years % 100 != 11:
                parts.append(f"{years} год")
            elif 2 <= years % 10 <= 4 and not 12 <= years % 100 <= 14:
                parts.append(f"{years} года")
            else:
                parts.append(f"{years} лет")
        if months > 0:
            if months % 10 == 1 and months % 100 != 11:
                parts.append(f"{months} месяц")
            elif 2 <= months % 10 <= 4 and not 12 <= months % 100 <= 14:
                parts.append(f"{months} месяца")
            else:
                parts.append(f"{months} месяцев")
        return " и ".join(parts)

    if years <= 0 and months <= 0:
        return "less than a month"
    parts = []
    if years > 0:
        parts.append(f"{years} year" + ("s" if years != 1 else ""))
    if months > 0:
        parts.append(f"{months} month" + ("s" if months != 1 else ""))
    return " and ".join(parts)


def format_size(size):
    try:
        size = int(size)
    except Exception:
        return "0 B"
    if size < 1024:
        return f"{size} B"
    if size < 1024 * 1024:
        return f"{size / 1024:.1f} KB"
    return f"{size / (1024 * 1024):.2f} MB"


def format_seconds(seconds):
    seconds = max(0, int(seconds or 0))
    days, seconds = divmod(seconds, 86400)
    hours, seconds = divmod(seconds, 3600)
    minutes, _ = divmod(seconds, 60)
    if is_russian():
        if days:
            return f"{days} д. {hours} ч."
        if hours:
            return f"{hours} ч. {minutes} мин."
        return f"{minutes} мин."
    if days:
        return f"{days}d {hours}h"
    if hours:
        return f"{hours}h {minutes}m"
    return f"{minutes}m"


def describe_cache_ttl(ttl):
    ttl = max(0, int(ttl or 0))
    if ttl <= 0:
        return localize("Кеш выключен", "Cache disabled")

    presets = {
        3600: localize("1 час", "1 hour"),
        21600: localize("6 часов", "6 hours"),
        43200: localize("12 часов", "12 hours"),
        86400: localize("24 часа", "24 hours"),
        172800: localize("2 дня", "2 days"),
        604800: localize("7 дней", "7 days"),
    }
    if ttl in presets:
        return presets[ttl]
    return format_seconds(ttl)


def get_user(user_id):
    try:
        return get_messages_controller().getUser(int(user_id))
    except Exception:
        return None


def get_user_full(user_id):
    try:
        return get_messages_controller().getUserFull(int(user_id))
    except Exception:
        return None


def get_public_username(user):
    if user is None:
        return ""
    try:
        return str(UserObject.getPublicUsername(user) or "").strip()
    except Exception:
        return str(getattr(user, "username", "") or "").strip()


def get_account_name(user_id):
    user = get_user(user_id)
    if user is None:
        return localize("Неизвестно", "Unknown")

    first_name = str(getattr(user, "first_name", "") or "").strip()
    last_name = str(getattr(user, "last_name", "") or "").strip()
    full_name = " ".join(part for part in (first_name, last_name) if part).strip()
    if full_name and full_name != "DELETED":
        return full_name

    username = get_public_username(user)
    return f"@{username}" if username else localize("Неизвестно", "Unknown")


def get_all_usernames(user_id):
    user = get_user(user_id)
    if user is None:
        return []

    result = []
    usernames = getattr(user, "usernames", None)
    try:
        if usernames and usernames.size() > 0:
            for index in range(usernames.size()):
                item = usernames.get(index)
                username = str(getattr(item, "username", "") or "").strip()
                if username:
                    result.append(
                        {
                            "username": username,
                            "active": bool(getattr(item, "active", True)),
                            "editable": bool(getattr(item, "editable", True)),
                        }
                    )
    except Exception as error:
        debug_log(f"Failed to read usernames list: {error}")

    if not result:
        username = get_public_username(user)
        if username:
            result.append({"username": username, "active": True, "editable": True})
    return result


def join_usernames(user_id):
    usernames = get_all_usernames(user_id)
    active = [f"@{item['username']}" for item in usernames if item.get("active", True)]
    if active:
        return ", ".join(active)
    return ", ".join(f"@{item['username']}" for item in usernames)


def get_nft_usernames(user_id):
    return [
        item["username"]
        for item in get_all_usernames(user_id)
        if item.get("active", True) and not item.get("editable", True)
    ]


def get_phone(user_id):
    user = get_user(user_id)
    phone = str(getattr(user, "phone", "") or "").strip() if user is not None else ""
    if phone and not phone.startswith("+"):
        phone = "+" + phone
    return phone


def get_birthday(user_id):
    birthday = getattr(get_user_full(user_id), "birthday", None)
    if birthday is None:
        return ""

    day = int(getattr(birthday, "day", 0) or 0)
    month = int(getattr(birthday, "month", 0) or 0)
    if not (1 <= day <= 31 and 1 <= month <= 12):
        return ""

    month_name = MONTHS_RU[month] if is_russian() else MONTHS_EN[month]
    year = int(getattr(birthday, "year", 0) or 0)
    flags = int(getattr(birthday, "flags", 0) or 0)
    if year > 0 and flags & 1:
        return f"{day} {month_name} {year}"
    return f"{day} {month_name}"


def guess_dc(user_id):
    try:
        user_id = int(user_id)
    except Exception:
        return 0
    if user_id < 10000000:
        return 2
    if user_id < 100000000:
        return 1
    if user_id < 500000000:
        return 2
    if user_id < 1000000000:
        return 4
    return 5


def get_dc_id(user_id):
    user = get_user(user_id)
    if user is not None:
        photo = getattr(user, "photo", None)
        dc_id = int(getattr(photo, "dc_id", 0) or 0) if photo is not None else 0
        if dc_id > 0:
            return dc_id

    user_full = get_user_full(user_id)
    for field_name in ("profile_photo", "personal_photo", "fallback_photo"):
        photo = getattr(user_full, field_name, None) if user_full is not None else None
        dc_id = int(getattr(photo, "dc_id", 0) or 0) if photo is not None else 0
        if dc_id > 0:
            return dc_id

    return guess_dc(user_id)


def get_region(dc_id):
    return DC_REGIONS.get(int(dc_id or 0), localize("Неизвестно", "Unknown"))


def is_self_user(user_id):
    try:
        return int(user_id) == int(get_user_config().getClientUserId())
    except Exception:
        return False


class CacheStore:
    def __init__(self):
        cache_dir = os.path.join(os.path.dirname(os.path.realpath(__file__)), "cache")
        os.makedirs(cache_dir, exist_ok=True)
        self.path = os.path.join(cache_dir, f"{__id__}_cache.json")
        self._lock = threading.RLock()
        self.data = self._load()

    def _load(self):
        try:
            with open(self.path, "r", encoding="utf-8") as handle:
                payload = json.load(handle)
            if not isinstance(payload, dict):
                return {}
            return {str(key): value for key, value in payload.items() if isinstance(value, dict)}
        except Exception:
            return {}

    def _save_locked(self):
        temp_path = self.path + ".tmp"
        payload = copy.deepcopy(self.data)
        try:
            with open(temp_path, "w", encoding="utf-8") as handle:
                json.dump(payload, handle, ensure_ascii=False, indent=2)
            os.replace(temp_path, self.path)
        finally:
            if os.path.exists(temp_path):
                try:
                    os.remove(temp_path)
                except Exception:
                    pass

    def _delete_keys_locked(self, keys):
        removed = 0
        for key in keys:
            if key in self.data:
                self.data.pop(key, None)
                removed += 1
        if removed:
            self._save_locked()
        return removed

    def get(self, user_id, method, ttl):
        if ttl <= 0:
            return None
        cache_key = f"{user_id}:{method}"
        with self._lock:
            entry = self.data.get(cache_key)
            if not isinstance(entry, dict):
                return None

            timestamp = int(entry.get("timestamp", 0) or 0)
            if time.time() - timestamp >= ttl:
                self._delete_keys_locked([cache_key])
                return None
            return copy.deepcopy(entry.get("data"))

    def set(self, user_id, method, value, meta=None):
        cache_key = f"{user_id}:{method}"
        with self._lock:
            self.data[cache_key] = {
                "timestamp": int(time.time()),
                "data": copy.deepcopy(value),
                "meta": copy.deepcopy(meta or {}),
            }
            self._save_locked()

    def delete_user(self, user_id):
        user_id = str(user_id)
        with self._lock:
            keys = [key for key in self.data if key.startswith(f"{user_id}:")]
            return self._delete_keys_locked(keys)

    def delete_entry(self, user_id, method):
        with self._lock:
            return self._delete_keys_locked([f"{user_id}:{method}"])

    def prune(self, ttl):
        with self._lock:
            if ttl <= 0:
                removed = len(self.data)
                self.data = {}
                self._save_locked()
                return removed

            now = time.time()
            keys = [
                key
                for key, entry in self.data.items()
                if now - int(entry.get("timestamp", 0) or 0) >= ttl
            ]
            return self._delete_keys_locked(keys)

    def clear(self):
        with self._lock:
            self.data = {}
            self._save_locked()

    def entries(self, ttl):
        with self._lock:
            snapshot = copy.deepcopy(self.data)

        now = time.time()
        result = []
        for key, entry in snapshot.items():
            try:
                user_id, method = key.split(":", 1)
            except ValueError:
                continue

            timestamp = int(entry.get("timestamp", 0) or 0)
            remaining = max(0, int(ttl - (now - timestamp))) if ttl > 0 else 0
            result.append(
                {
                    "user_id": user_id,
                    "method": method,
                    "timestamp": timestamp,
                    "remaining": remaining,
                    "expired": ttl <= 0 or remaining <= 0,
                    "data": entry.get("data") or {},
                    "meta": entry.get("meta") or {},
                }
            )
        result.sort(key=lambda item: item["timestamp"], reverse=True)
        return result

    def stats(self, ttl):
        entries = self.entries(ttl)
        return {
            "total": len(entries),
            "unique_users": len({item["user_id"] for item in entries}),
            "expired": sum(1 for item in entries if item["expired"]),
            "active": sum(1 for item in entries if not item["expired"]),
            "fast": sum(1 for item in entries if str(item.get("method", "")).lower() == "fast"),
            "smart": sum(1 for item in entries if str(item.get("method", "")).lower() == "smart"),
            "inline": sum(1 for item in entries if str(item.get("method", "")).lower() == "inline"),
            "size": format_size(os.path.getsize(self.path) if os.path.exists(self.path) else 0),
        }


class DateRegApi:
    def __init__(self, token, base_url=""):
        self.token = str(token or "").strip()
        self.base_url = str(base_url or API_URL).strip().rstrip("/")
        self.session = requests.Session()
        self.session.headers.update({"User-Agent": f"ExteraGram/{__id__}/{__version__}"})

    def _request(self, path, **params):
        try:
            response = self.session.get(
                f"{self.base_url}{path}",
                params={"token": self.token, **params},
                timeout=20,
            )
        except requests.RequestException as error:
            return {"ok": False, "error": str(error), "data": None}

        try:
            payload = response.json()
        except Exception:
            payload = {}

        if response.status_code != 200:
            message = payload.get("detail") or payload.get("error") or response.text or f"HTTP {response.status_code}"
            if response.status_code == 401:
                message = localize("Неверный API-ключ.", "Invalid API key.")
            elif response.status_code == 402:
                message = localize("Недостаточно баланса.", "Insufficient balance.")
            elif response.status_code == 404:
                message = localize("Пользователь не найден.", "User not found.")
            return {"ok": False, "error": message, "data": payload}

        return {"ok": True, "error": "", "data": payload}

    def resolve_username(self, username):
        username = str(username or "").strip().lstrip("@")
        if not username:
            return {"ok": False, "error": localize("Юзернейм пуст.", "Username is empty."), "data": None}
        result = self._request("/users/resolveUsername", username=username)
        if result["ok"] and result["data"].get("id"):
            return result
        error = result["error"] or localize("Не удалось разрешить юзернейм.", "Failed to resolve username.")
        return {"ok": False, "error": error, "data": result["data"]}

    def get_info(self, user_id, method):
        path = "/users/getCreationDateSmart" if method == "smart" else "/users/getCreationDateFast"
        result = self._request(path, user_id=str(user_id))
        if result["ok"] and result["data"].get("creation_date"):
            return result
        error = result["error"] or result["data"].get("error") or localize(
            "Дата регистрации не найдена.",
            "Creation date was not found.",
        )
        return {"ok": False, "error": error, "data": result["data"]}


@dataclass
class RichEntity:
    kind: str
    offset: int
    length: int
    url: str = ""
    document_id: int = 0

    def to_tlrpc_object(self):
        if self.kind == "bold":
            entity = TLRPC.TL_messageEntityBold()
        elif self.kind == "italic":
            entity = TLRPC.TL_messageEntityItalic()
        elif self.kind == "code":
            entity = TLRPC.TL_messageEntityCode()
        elif self.kind == "link":
            entity = TLRPC.TL_messageEntityTextUrl()
            entity.url = self.url
        elif self.kind == "emoji":
            entity = TLRPC.TL_messageEntityCustomEmoji()
            entity.document_id = int(self.document_id)
        else:
            return None
        entity.offset = self.offset
        entity.length = self.length
        return entity


class RichTextParser(HTMLParser):
    def __init__(self):
        super().__init__()
        self.text = ""
        self.entities = []
        self.open_tags = {}

    def handle_starttag(self, tag, attrs):
        attrs = dict(attrs)
        kind = None
        extra = {}

        if tag in ("b", "strong"):
            kind = "bold"
        elif tag in ("i", "em"):
            kind = "italic"
        elif tag == "code":
            kind = "code"
        elif tag == "a":
            kind = "link"
            extra["url"] = attrs.get("href", "")
        elif tag == "emoji":
            emoji_id = attrs.get("id", attrs.get("document_id", "0"))
            if not str(emoji_id).isdigit():
                return
            kind = "emoji"
            extra["document_id"] = int(emoji_id)
        else:
            return

        self.open_tags.setdefault(tag, []).append(
            RichEntity(kind=kind, offset=len(self.text), length=0, **extra)
        )

    def handle_data(self, data):
        data = html.unescape(data)
        for entities in self.open_tags.values():
            for entity in entities:
                entity.length += len(data)
        self.text += data

    def handle_endtag(self, tag):
        try:
            entity = self.open_tags[tag].pop()
        except (KeyError, IndexError):
            return
        self.entities.append(entity)
        if not self.open_tags[tag]:
            self.open_tags.pop(tag, None)


def parse_rich_text(text):
    parser = RichTextParser()
    parser.feed(expand_surrogates(str(text or "")))
    parser.close()
    entities = [entity for entity in parser.entities if entity.length > 0]
    tl_entities = []
    for entity in sorted(entities, key=lambda item: item.offset):
        tl_entity = entity.to_tlrpc_object()
        if tl_entity is not None:
            tl_entities.append(tl_entity)
    return collapse_surrogates(parser.text), tl_entities


class AccountAgePlugin(BasePlugin):
    def __init__(self):
        super().__init__()
        self.api = None
        self.cache = CacheStore()
        self.is_processing = False
        self.loading_dialog = None
        self.drawer_settings_item = None
        self.chat_settings_item = None
        self.profile_menu_item = None
        self.inline_bot_user_id = 0

    def on_plugin_load(self):
        self.add_on_send_message_hook()
        self.load_config()
        self.cache.prune(self._cache_ttl())
        if self.get_setting("show_settings_buttons", True):
            self._add_settings_buttons()
        self._add_profile_button()
        debug_log("Plugin loaded")

    def on_plugin_unload(self):
        for item in (self.drawer_settings_item, self.chat_settings_item, self.profile_menu_item):
            if item:
                try:
                    self.remove_menu_item(item)
                except Exception as error:
                    debug_log(f"Failed to remove menu item: {error}")
        self.drawer_settings_item = None
        self.chat_settings_item = None
        self.profile_menu_item = None
        self._dismiss_loading()
        debug_log("Plugin unloaded")

    def load_config(self, _=None):
        global DEBUG
        DEBUG = bool(self.get_setting("debug_mode", False))
        token = str(self.get_setting("api_key", "") or "").strip()
        base_url = str(self.get_setting("custom_api_url", "") or "").strip()
        self.api = DateRegApi(token, base_url) if token else None

    def create_settings(self):
        return [
            Header(text=localize("Разделы", "Sections")),
            text_setting(
                text=localize("Режим поиска", "Lookup mode"),
                subtext=self._settings_mode_summary(),
                icon="msg_calendar_solar",
                accent=True,
                create_sub_fragment=self._create_lookup_settings,
            ),
            text_setting(
                text="API",
                subtext=self._settings_api_summary(),
                icon="msg_pin_code",
                accent=True,
                create_sub_fragment=self._create_api_settings,
            ),
            text_setting(
                text=localize("Кеш", "Cache"),
                subtext=self._settings_cache_summary(),
                icon="files_storage",
                accent=True,
                create_sub_fragment=self._create_cache_settings,
            ),
            text_setting(
                text=localize("Интерфейс", "Interface"),
                subtext=self._settings_interface_summary(),
                icon="msg_settings",
                accent=True,
                create_sub_fragment=self._create_interface_settings,
            ),
            Text(
                text=localize("Справка по командам", "Command help"),
                icon="msg_info",
                on_click=lambda _: self._show_faq_sheet(),
            ),
        ]

    def _settings_mode_summary(self):
        if self.get_setting("free_mode", True):
            return localize("Локальные данные и inline", "Local data and inline")
        if self.api is None:
            return localize("Нужен API-ключ", "API key required")
        return localize("API fast/smart", "API fast/smart")

    def _settings_api_summary(self):
        endpoint = str(self.get_setting("custom_api_url", "") or "").strip() or API_URL
        endpoint = re.sub(r"^https?://", "", endpoint).rstrip("/")
        status = localize("ключ задан", "key set") if self.api is not None else localize("ключ не задан", "key missing")
        return f"{status} · {endpoint}"

    def _settings_cache_summary(self):
        ttl = self._cache_ttl()
        stats = self.cache.stats(ttl)
        return localize(
            f"{describe_cache_ttl(ttl)} · {stats['unique_users']} польз. · {stats['total']} записей",
            f"{describe_cache_ttl(ttl)} · {stats['unique_users']} users · {stats['total']} entries",
        )

    def _cache_contents_summary(self, stats):
        return localize(
            f"{stats['unique_users']} пользователей · {stats['total']} записей · {stats['size']}",
            f"{stats['unique_users']} users · {stats['total']} entries · {stats['size']}",
        )

    def _cache_users_settings_summary(self, stats):
        if stats["unique_users"] <= 0:
            return localize("Кеш пуст", "Cache is empty")
        if stats["expired"] > 0:
            return localize(
                f"{stats['unique_users']} пользователей · {stats['expired']} просроченных записей",
                f"{stats['unique_users']} users · {stats['expired']} expired entries",
            )
        return localize(
            f"{stats['unique_users']} пользователей в кеше",
            f"{stats['unique_users']} users cached",
        )

    def _cache_prune_summary(self, stats):
        if stats["expired"] <= 0:
            return localize("Сейчас удалять нечего", "Nothing to remove right now")
        return localize(
            f"{stats['expired']} просроченных записей",
            f"{stats['expired']} expired entries",
        )

    def _cache_clear_summary(self, stats):
        if stats["total"] <= 0:
            return localize("Кеш уже пуст", "Cache is already empty")
        return localize(
            f"{stats['total']} записей · {stats['size']}",
            f"{stats['total']} entries · {stats['size']}",
        )

    def _cache_ttl_selector_items(self):
        return [describe_cache_ttl(value) for value in CACHE_PRESETS] + [localize("Свой интервал", "Custom")]

    def _cache_ttl_selector_index(self, ttl=None):
        ttl_value = self._cache_ttl() if ttl is None else max(0, int(ttl or 0))
        try:
            return CACHE_PRESETS.index(ttl_value)
        except ValueError:
            return len(CACHE_PRESETS)

    def _on_cache_ttl_preset_change(self, index):
        try:
            index = int(index)
        except Exception:
            return

        if 0 <= index < len(CACHE_PRESETS):
            ttl = CACHE_PRESETS[index]
            self.set_setting("cache_duration", str(ttl))
            BulletinHelper.show_success(
                localize(
                    f"Время хранения: {describe_cache_ttl(ttl)}.",
                    f"Cache lifetime: {describe_cache_ttl(ttl)}.",
                )
            )
            return

        BulletinHelper.show_info(
            localize(
                "Ниже можно задать свой интервал в секундах.",
                "Set a custom interval in seconds below.",
            )
        )

    def _on_cache_duration_change(self, value):
        try:
            ttl = max(0, int(str(value).strip()))
        except Exception:
            return
        self.set_setting("cache_ttl_preset", self._cache_ttl_selector_index(ttl))

    def _settings_interface_summary(self):
        menu = localize("кнопки в меню", "menu buttons") if self.get_setting("show_settings_buttons", True) else localize(
            "кнопки скрыты",
            "buttons hidden",
        )
        logs = localize("логи вкл.", "logs on") if self.get_setting("debug_mode", False) else localize(
            "логи выкл.",
            "logs off",
        )
        return f"{menu} · {logs}"

    def _create_lookup_settings(self):
