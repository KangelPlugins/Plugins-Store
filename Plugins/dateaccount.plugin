        ]

    def _show_faq_sheet(self):
        def show():
            fragment = get_last_fragment()
            activity = fragment.getParentActivity() if fragment is not None else None
            if activity is None:
                return

            try:
                from android.content.res import ColorStateList
                from android.graphics import Color
                from android.graphics.drawable import GradientDrawable, RippleDrawable
                from android.util import TypedValue
                from android.view import Gravity, View
                from android.widget import FrameLayout, ImageView, LinearLayout, ScrollView, TextView
                from android_utils import OnClickListener
                from org.telegram.messenger import AndroidUtilities, R
                from org.telegram.ui.ActionBar import BottomSheet, Theme
                from org.telegram.ui.Components import LayoutHelper

                sheet = BottomSheet(activity, False)

                root = LinearLayout(activity)
                root.setOrientation(LinearLayout.VERTICAL)
                root.setPadding(
                    AndroidUtilities.dp(20),
                    AndroidUtilities.dp(18),
                    AndroidUtilities.dp(20),
                    AndroidUtilities.dp(16),
                )
                try:
                    root.setBackgroundColor(Theme.getColor(Theme.key_dialogBackground))
                except Exception:
                    pass

                accent_color = Theme.getColor(Theme.key_featuredStickers_addButton)
                accent_text_color = Theme.getColor(Theme.key_windowBackgroundWhiteBlueText)
                primary_text_color = Theme.getColor(Theme.key_dialogTextBlack)
                secondary_text_color = Theme.getColor(Theme.key_dialogTextGray2)
                card_color = Theme.getColor(Theme.key_windowBackgroundGray)
                divider_color = Theme.getColor(Theme.key_listSelector)

                icon_bg = GradientDrawable()
                icon_bg.setShape(GradientDrawable.OVAL)
                icon_bg.setColor(accent_color & 0x15FFFFFF | 0x10000000)

                icon_view = ImageView(activity)
                icon_view.setImageResource(R.drawable.msg_info)
                icon_view.setColorFilter(accent_color)
                icon_view.setBackground(icon_bg)
                icon_padding = AndroidUtilities.dp(18)
                icon_view.setPadding(icon_padding, icon_padding, icon_padding, icon_padding)
                root.addView(icon_view, LayoutHelper.createLinear(72, 72, Gravity.CENTER_HORIZONTAL, 0, 0, 0, 14))

                title_view = TextView(activity)
                title_view.setText(localize("Как пользоваться", "How to use"))
                title_view.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 22)
                title_view.setTypeface(AndroidUtilities.bold())
                title_view.setTextColor(primary_text_color)
                title_view.setGravity(Gravity.CENTER)
                root.addView(title_view, LayoutHelper.createLinear(-1, -2, Gravity.CENTER_HORIZONTAL, 0, 0, 0, 6))

                subtitle_view = TextView(activity)
                subtitle_view.setText(
                    localize(
                        "Коротко про команды, режимы и кеш.",
                        "Quick guide to commands, modes and cache.",
                    )
                )
                subtitle_view.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
                subtitle_view.setTextColor(secondary_text_color)
                subtitle_view.setGravity(Gravity.CENTER)
                root.addView(subtitle_view, LayoutHelper.createLinear(-1, -2, Gravity.CENTER_HORIZONTAL, 0, 0, 0, 14))

                chips_row = LinearLayout(activity)
                chips_row.setOrientation(LinearLayout.HORIZONTAL)
                chips_row.setGravity(Gravity.CENTER)

                def add_chip(text, right_margin=0):
                    chip = FrameLayout(activity)
                    chip_bg = GradientDrawable()
                    chip_bg.setCornerRadius(AndroidUtilities.dp(14))
                    chip_bg.setColor(accent_color & 0x12FFFFFF | 0x09000000)
                    chip.setBackground(chip_bg)

                    chip_text = TextView(activity)
                    chip_text.setText(text)
                    chip_text.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
                    chip_text.setTypeface(AndroidUtilities.bold())
                    chip_text.setTextColor(accent_text_color)
                    chip_text.setPadding(
                        AndroidUtilities.dp(12),
                        AndroidUtilities.dp(6),
                        AndroidUtilities.dp(12),
                        AndroidUtilities.dp(6),
                    )
                    chip.addView(chip_text)
                    chips_row.addView(chip, LayoutHelper.createLinear(-2, -2, Gravity.CENTER_VERTICAL, 0, 0, right_margin, 0))

                add_chip(".age", 8)
                add_chip("smart", 8)
                add_chip(".cache")
                root.addView(chips_row, LayoutHelper.createLinear(-1, -2, Gravity.CENTER_HORIZONTAL, 0, 0, 0, 16))

                body_scroll = ScrollView(activity)
                body_scroll.setVerticalScrollBarEnabled(False)
                body_scroll.setPadding(
                    AndroidUtilities.dp(4),
                    0,
                    AndroidUtilities.dp(4),
                    0,
                )

                body = LinearLayout(activity)
                body.setOrientation(LinearLayout.VERTICAL)

                for section_title, items in self._faq_sections():
                    card = FrameLayout(activity)
                    card_bg = GradientDrawable()
                    card_bg.setCornerRadius(AndroidUtilities.dp(18))
                    card_bg.setColor(card_color)
                    card_bg.setStroke(AndroidUtilities.dp(1), divider_color)
                    card.setBackground(card_bg)

                    card_content = LinearLayout(activity)
                    card_content.setOrientation(LinearLayout.VERTICAL)
                    card_content.setPadding(
                        AndroidUtilities.dp(16),
                        AndroidUtilities.dp(14),
                        AndroidUtilities.dp(16),
                        AndroidUtilities.dp(14),
                    )

                    section_view = TextView(activity)
                    section_view.setText(section_title)
                    section_view.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
                    section_view.setTypeface(AndroidUtilities.bold())
                    section_view.setTextColor(primary_text_color)
                    card_content.addView(section_view, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 0, 10))

                    for index, (label, description) in enumerate(items):
                        row = LinearLayout(activity)
                        row.setOrientation(LinearLayout.VERTICAL)

                        label_view = TextView(activity)
                        label_view.setText(label)
                        label_view.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
                        label_view.setTypeface(AndroidUtilities.bold())
                        label_view.setTextColor(accent_text_color)
                        row.addView(label_view, LayoutHelper.createLinear(-1, -2))

                        description_view = TextView(activity)
                        description_view.setText(description)
                        description_view.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
                        description_view.setTextColor(secondary_text_color)
                        try:
                            description_view.setLineSpacing(AndroidUtilities.dp(2), 1.1)
                        except Exception:
                            pass
                        row.addView(description_view, LayoutHelper.createLinear(-1, -2, 0, 0, 2, 0, 0))

                        bottom_margin = 10 if index < len(items) - 1 else 0
                        card_content.addView(row, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 0, bottom_margin))

                    card.addView(card_content)
                    body.addView(card, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 0, 12))

                body_scroll.addView(body)
                root.addView(body_scroll, LayoutHelper.createLinear(-1, 0, 1.0))

                divider = View(activity)
                divider.setBackgroundColor(divider_color)
                root.addView(divider, LayoutHelper.createLinear(-1, 1, 0, 0, 16, 0, 12))

                close_button = FrameLayout(activity)
                close_bg = GradientDrawable()
                close_bg.setCornerRadius(AndroidUtilities.dp(12))
                close_bg.setColor(accent_text_color)
                try:
                    close_button.setBackground(
                        RippleDrawable(ColorStateList.valueOf(Color.parseColor("#30FFFFFF")), close_bg, None)
                    )
                except Exception:
                    close_button.setBackground(close_bg)
                close_button.setPadding(0, AndroidUtilities.dp(14), 0, AndroidUtilities.dp(14))
                close_button.setClickable(True)
                close_button.setFocusable(True)

                close_text = TextView(activity)
                close_text.setText(localize("Понятно", "Got it"))
                close_text.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
                close_text.setTypeface(AndroidUtilities.bold())
                close_text.setTextColor(Color.WHITE)
                close_text.setGravity(Gravity.CENTER)
                close_button.addView(close_text, LayoutHelper.createFrame(-1, -2, Gravity.CENTER))
                close_button.setOnClickListener(OnClickListener(lambda *_: sheet.dismiss()))

                root.addView(close_button, LayoutHelper.createLinear(-1, -2))
                sheet.setCustomView(root)
                sheet.show()
            except Exception as error:
                debug_log(f"Failed to show FAQ sheet: {error}")
                self._show_alert(localize("Справка", "FAQ"), self._faq_text())

        run_on_ui_thread(show)

    def _show_loading(self):
        fragment = get_last_fragment()
        if fragment is None or self.loading_dialog is not None:
            return

        def show():
            activity = fragment.getParentActivity()
            self.loading_dialog = AlertDialog(activity, 3)
            self.loading_dialog.setCanCancel(False)
            self.loading_dialog.show()
            self.loading_dialog.setTitle(localize("Загрузка", "Loading"))

        run_on_ui_thread(show)

    def _dismiss_loading(self):
        def dismiss():
            if self.loading_dialog is None:
                return
            try:
                self.loading_dialog.dismiss()
            except Exception as error:
                debug_log(f"Failed to dismiss loading dialog: {error}")
            finally:
                self.loading_dialog = None

        run_on_ui_thread(dismiss)

    def _reply_markdown(self, params, text):
        try:
            parsed = parse_markdown(text)
            entities = [entity.to_tlrpc_object() for entity in parsed.entities]
            if self.get_setting("use_collapsible_quote", False):
                quote = TLRPC.TL_messageEntityBlockquote()
                quote.offset = 0
                quote.length = len(parsed.text.encode("utf-16-le")) // 2
                quote.collapsed = True
                entities.insert(0, quote)

            payload = {
                "peer": params.peer,
                "message": parsed.text,
                "entities": entities or None,
                "searchLinks": False,
            }
        except Exception as error:
            debug_log(f"Markdown parse failed: {error}")
            plain_text = str(text or "").replace("*", "").replace("`", "").replace("_", "")
            payload = {"peer": params.peer, "message": plain_text, "searchLinks": False}
            if self.get_setting("use_collapsible_quote", False):
                quote = TLRPC.TL_messageEntityBlockquote()
                quote.offset = 0
                quote.length = len(plain_text.encode("utf-16-le")) // 2
                quote.collapsed = True
                payload["entities"] = [quote]

        reply_to_msg = getattr(params, "replyToMsg", None)
        reply_to_top = getattr(params, "replyToTopMsg", None)
        if reply_to_msg is not None:
            payload["replyToMsg"] = reply_to_msg
        if reply_to_top is not None:
            payload["replyToTopMsg"] = reply_to_top

        try:
            send_message(payload)
        except Exception as error:
            debug_log(f"Failed to send message: {error}")

    def _reply_rich_text(self, params, text):
        try:
            message, entities = parse_rich_text(text)
            if self.get_setting("use_collapsible_quote", False):
                quote = TLRPC.TL_messageEntityBlockquote()
                quote.offset = 0
                quote.length = len(message.encode("utf-16-le")) // 2
                quote.collapsed = True
                entities.insert(0, quote)

            payload = {
                "peer": params.peer,
                "message": message,
                "entities": entities or None,
                "searchLinks": False,
            }
        except Exception as error:
            debug_log(f"Rich text parse failed: {error}")
            plain_text = re.sub(r"<[^>]+>", "", str(text or ""))
            payload = {"peer": params.peer, "message": html.unescape(plain_text), "searchLinks": False}

        reply_to_msg = getattr(params, "replyToMsg", None)
        reply_to_top = getattr(params, "replyToTopMsg", None)
        if reply_to_msg is not None:
            payload["replyToMsg"] = reply_to_msg
        if reply_to_top is not None:
            payload["replyToTopMsg"] = reply_to_top

        try:
            send_message(payload)
        except Exception as error:
            debug_log(f"Failed to send rich text message: {error}")

    def _usage_text(self):
        return (
            "⚠️ *"
            + localize("Использование", "Usage")
            + ":*\n"
            + ".age [username/ID]\n"
            + ".age smart [username/ID]\n"
            + localize(
                "Можно отвечать на сообщение командой .age.",
                "You can also reply to a message with .age.",
            )
        )

    def _faq_text(self):
        lines = [
            localize(
                ".age ищет дату регистрации аккаунта Telegram.",
                ".age looks up the Telegram account creation date.",
            )
        ]
        for section_title, items in self._faq_sections():
            lines.append("")
            lines.append(f"{section_title}:")
            for label, description in items:
                lines.append(f"• {label} - {description}")
        return "\n".join(lines)

    def _api_error_text(self, message):
        return f"⚠️ *{localize('Ошибка API', 'API error')}:*\n\n{code_span(message)}"

    def _error_text(self, message):
        return f"⚠️ *{localize('Ошибка', 'Error')}:*\n\n{code_span(message)}"

    def _free_lookup_error(self, target, direct_error=""):
        if direct_error:
            return self._error_text(direct_error)
        safe_target = str(target or "").replace("`", "").strip()
        return (
            "⚠️ "
            + localize(
                f"Не удалось получить данные по {code_span(safe_target)}. Попробуйте точный ID, ответ на сообщение или API-режим.",
                f"Failed to get data for {code_span(safe_target)}. Try an exact ID, a reply, or API mode.",
            )
        )

    def _accuracy_emoji(self, percent):
        try:
            percent = int(percent)
        except Exception:
            return "❓"
        if percent >= 87:
            return "🟢"
        if percent >= 70:
            return "🟡"
        if percent >= 50:
            return "🟠"
        return "🔴"

    def _accuracy_text(self, text, percent=0):
        text = str(text or "").strip()
        if text:
            return self._sanitize_accuracy_text(text)
        percent = int(percent or 0)
        if percent >= 87:
            return localize("Очень высокая", "Very high")
        if percent >= 70:
            return localize("Высокая", "High")
        if percent >= 50:
            return localize("Средняя", "Medium")
        return localize("Низкая", "Low")

    def _sanitize_accuracy_text(self, text):
        value = str(text or "")
        value = re.sub(r"\(\s*\d{1,3}\s*%\s*\)", "", value)
        value = re.sub(r"\(\s*$", "", value)
        value = re.sub(r"\s+", " ", value).strip(" -:|()[]{}.,")
        return value

    def _emoji(self, symbol):
        if self.get_setting("use_premium_emoji", False) and symbol in PREMIUM_EMOJI:
            return f"<emoji id={PREMIUM_EMOJI[symbol].split('(')[-1].rstrip(')')}>{html.escape(symbol)}</emoji>"
        return symbol

    def _escape_rich(self, value):
        return html.escape(str(value or ""))

    def _rich_bold(self, value):
        return f"<b>{self._escape_rich(value)}</b>"

    def _rich_italic(self, value):
        return f"<i>{self._escape_rich(value)}</i>"

    def _rich_code(self, value):
        return f"<code>{self._escape_rich(value)}</code>"

    def _rich_link(self, label, url):
        return f'<a href="{self._escape_rich(url)}">{self._escape_rich(label)}</a>'

    def _as_list(self, value):
        if value is None:
            return []
        try:
            return [value.get(index) for index in range(value.size())]
        except Exception:
            pass
        try:
            return list(value)
        except Exception:
            return []

    def _request_error(self, error, fallback):
        try:
            text = str(error.text or "")
        except Exception:
            text = ""
        if not text:
            text = str(error or "")
        return text.strip() or fallback

    def _send_sync(self, request, timeout_seconds=None):
        timeout = float(timeout_seconds or INLINE_TIMEOUT)
        event = threading.Event()
        holder = {"response": None, "error": None}

        def callback(response, error):
            holder["response"] = response
            holder["error"] = error
            event.set()

        try:
            send_request(request, RequestCallback(callback))
        except Exception as error:
            return {"success": False, "response": None, "error": str(error)}

        if not event.wait(timeout):
            return {
                "success": False,
                "response": None,
                "error": localize("Таймаут запроса.", "Request timeout."),
            }

        if holder["error"] is not None:
            return {
                "success": False,
                "response": holder["response"],
                "error": self._request_error(holder["error"], localize("Запрос не удался.", "Request failed.")),
            }
        return {"success": True, "response": holder["response"], "error": ""}

    def _cache_entities(self, response):
        controller = get_messages_controller()
        if controller is None or response is None:
            return
        users = getattr(response, "users", None)
        chats = getattr(response, "chats", None)
        try:
            if users is not None and hasattr(controller, "putUsers"):
                controller.putUsers(users, False)
        except Exception as error:
            debug_log(f"putUsers failed: {error}")
        try:
            if chats is not None and hasattr(controller, "putChats"):
                controller.putChats(chats, False)
        except Exception as error:
            debug_log(f"putChats failed: {error}")

    def _clean_username(self, value):
        value = str(value or "").strip().lstrip("@")
        if not value:
            return ""
        result = []
        for char in value:
            if char.isalnum() or char == "_":
                result.append(char)
            else:
                break
        username = "".join(result)
        if len(username) < 3 or not any(char.isalpha() for char in username):
            return ""
        if username.lower() in {"joinchat", "addlist", "addstickers", "share", "iv", "s", "c"}:
            return ""
        return username

    def _username_from_url(self, value):
        text = str(value or "").strip()
        if not text:
            return ""
        if text.startswith("@"):
            return self._clean_username(text[1:])
        if " " not in text and "/" not in text and ":" not in text and "@" not in text:
            username = self._clean_username(text)
            if username:
                return username

        match = re.search(
            r"(?:https?://)?(?:t\.me|telegram\.me|telegram\.dog)/(?:(?:s|c)/)?([A-Za-z0-9_]{3,})",
            text,
            flags=re.IGNORECASE,
        )
        return self._clean_username(match.group(1)) if match else ""

    def _username_from_text(self, value):
        username = self._username_from_url(value)
        if username:
            return username
        match = re.search(r"@([A-Za-z0-9_]{3,})", str(value or ""))
        return self._clean_username(match.group(1)) if match else ""

    def _inline_username(self, username, resolved_target=None):
        value = self._clean_username(username)
        if value and value.lower() != INLINE_BOT.lower():
            return value

        fallback = ""
        if isinstance(resolved_target, dict):
            fallback = self._clean_username(resolved_target.get("username"))
        if fallback and fallback.lower() != INLINE_BOT.lower():
            return fallback
        return ""

    def _entity_text(self, message, entity):
        try:
            offset = int(getattr(entity, "offset", 0) or 0)
            length = int(getattr(entity, "length", 0) or 0)
        except Exception:
            return ""
        if offset < 0 or length <= 0:
            return ""
        text = str(message or "")
        return text[offset : offset + length]

    def _username_from_entities(self, message, entities):
        for entity in self._as_list(entities):
            class_name = ""
            try:
                class_name = str(entity.getClass().getName() or "")
            except Exception:
                pass

            part = self._entity_text(message, entity)
            if class_name.endswith("TL_messageEntityTextUrl"):
                return self._username_from_url(getattr(entity, "url", "")) or self._username_from_text(part)
            if class_name.endswith("TL_messageEntityUrl"):
                username = self._username_from_url(part)
                if username:
                    return username
            if class_name.endswith("TL_messageEntityMention"):
                username = self._username_from_text(part)
                if username:
                    return username
        return ""

    def _labeled_value(self, text, labels):
        for raw_line in str(text or "").splitlines():
            line = raw_line.strip()
            if not line:
                continue
            line = re.sub(r"^[^\wА-Яа-яA-Za-z0-9@]+", "", line)
            lower = line.lower()
            for label in labels:
                if not lower.startswith(label):
                    continue
                parts = re.split(r"\s*[:\-]\s*", line, maxsplit=1)
                value = parts[1].strip() if len(parts) == 2 else line[len(label) :].strip(" :\t")
                value = value.strip("`*_[]() ")
                if value:
                    return value
        return ""

    def _date_value(self, value):
        text = str(value or "").strip()
        if not text:
            return ""

        full_date_match = re.search(r"\b(0?[1-9]|[12]\d|3[01])\.(0?[1-9]|1[0-2])\.(20\d{2})\b", text)
        if full_date_match:
            return f"{int(full_date_match.group(2)):02d}.{full_date_match.group(3)}"

        short_date_match = re.search(r"(?<!\d\.)(0?[1-9]|1[0-2])\.(20\d{2})\b", text)
        if short_date_match:
            return f"{int(short_date_match.group(1)):02d}.{short_date_match.group(2)}"

        month_match = re.search(r"([A-Za-zА-Яа-яЁё]+)\s+(20\d{2})", text, flags=re.IGNORECASE)
        if not month_match:
            return ""

        month = MONTHS_BY_NAME.get(month_match.group(1).lower())
        if not month:
            return ""
        return f"{month:02d}.{month_match.group(2)}"

    def _creation_date(self, text):
        text = str(text or "")
        labeled_value = self._labeled_value(
            text,
            ("регистрация", "дата регистрации", "registration", "creation date", "date created"),
        )
        creation_date = self._date_value(labeled_value)
        if creation_date:
            return creation_date

        for raw_line in text.splitlines():
            line = raw_line.strip()
            if not line:
                continue
            normalized = re.sub(r"^[^\wА-Яа-яA-Za-z0-9@]+", "", line).lower()
            if normalized.startswith(("появление", "appearance")):
                continue
            creation_date = self._date_value(line)
            if creation_date:
                return creation_date
        return ""

    def _accuracy_percent(self, text):
        match = re.search(r"(\d{1,3})\s*%", str(text or ""))
        if not match:
            return 0
        return max(0, min(100, int(match.group(1))))

    def _reply_accuracy(self, text, percent=0):
        value = self._labeled_value(text, ("точность", "accuracy"))
        value = re.sub(r"\b\d{1,3}\s*%", "", value) if value else ""
        value = self._sanitize_accuracy_text(value) if value else ""
        if value:
            return value

        source = str(text or "").lower()
        if "very high" in source or "очень высок" in source:
            return localize("Очень высокая", "Very high")
        if "high" in source or "высок" in source:
            return localize("Высокая", "High")
        if "medium" in source or "средн" in source:
            return localize("Средняя", "Medium")
        if "low" in source or "низк" in source:
            return localize("Низкая", "Low")
        return self._accuracy_text("", percent)

    def _reply_account(self, text, title="", username=""):
        value = self._labeled_value(text, ("имя аккаунта", "account name", "name"))
        if value:
            return value
        cleaned_title = str(title or "").strip().strip("`*_[]() ")
        if cleaned_title and cleaned_title.lower() not in {str(username or "").lower(), f"@{str(username or '').lower()}"}:
            return cleaned_title
        return ""

    def _target_from_response(self, response):
        if response is None:
            return {"user_id": "", "username": "", "error": ""}

        self._cache_entities(response)
        users = self._as_list(getattr(response, "users", None))
        chats = self._as_list(getattr(response, "chats", None))
        peer = getattr(response, "peer", None)

        user_id = int(getattr(peer, "user_id", 0) or 0) if peer is not None else 0
        if user_id > 0:
            username = ""
            for user in users:
                if int(getattr(user, "id", 0) or 0) == user_id:
                    username = str(getattr(user, "username", "") or "").strip()
                    break
            return {"user_id": str(user_id), "username": username, "error": ""}

        if chats or int(getattr(peer, "channel_id", 0) or 0) or int(getattr(peer, "chat_id", 0) or 0):
            return {
                "user_id": "",
                "username": "",
                "error": localize(
                    "Команда работает только с аккаунтами пользователей.",
                    "This command only works with user accounts.",
                ),
            }
        return {"user_id": "", "username": "", "error": ""}

    def _resolve_username(self, username):
        username = self._clean_username(username)
        if not username:
            return {"user_id": "", "username": "", "error": ""}

        request = TLRPC.TL_contacts_resolveUsername()
        request.flags = 0
        request.username = username
        result = self._send_sync(request)
        if not result["success"]:
            return {"user_id": "", "username": username, "error": result["error"]}

        resolved = self._target_from_response(result["response"])
        if not resolved.get("username"):
            resolved["username"] = username
        return resolved

    def _free_target(self, target):
        target = str(target or "").strip()
        if not target:
            return {"user_id": "", "username": "", "error": ""}
        if target.isdigit():
            return {"user_id": target, "username": "", "error": ""}

        username = self._username_from_text(target) or self._clean_username(target)
        if not username:
            return {"user_id": "", "username": "", "error": ""}

        controller = get_messages_controller()
        if controller is not None and hasattr(controller, "getUserOrChat"):
            for lookup in (username, "@" + username):
                try:
                    item = controller.getUserOrChat(lookup)
                except Exception:
                    item = None
                if item is not None and hasattr(item, "id") and not hasattr(item, "title"):
                    return {"user_id": str(int(getattr(item, "id", 0) or 0)), "username": username, "error": ""}

        return self._resolve_username(username)

    def _cached_inline_bot(self):
        controller = get_messages_controller()
        if controller is None:
            return None

        user_id = int(self.inline_bot_user_id or 0)
        if user_id > 0 and hasattr(controller, "getUser"):
            try:
                user = controller.getUser(user_id)
                if user is not None:
                    return user
            except Exception:
                pass

        if hasattr(controller, "getUserOrChat"):
            for lookup in (INLINE_BOT, "@" + INLINE_BOT):
                try:
                    item = controller.getUserOrChat(lookup)
                except Exception:
                    item = None
                if item is not None and hasattr(item, "bot"):
                    self.inline_bot_user_id = int(getattr(item, "id", 0) or 0)
                    return item
        return None

    def _inline_bot(self):
        cached = self._cached_inline_bot()
        if cached is not None:
            return cached

        request = TLRPC.TL_contacts_resolveUsername()
        request.flags = 0
        request.username = INLINE_BOT
        result = self._send_sync(request)
        if not result["success"]:
            return None

        self._cache_entities(result["response"])
        users = self._as_list(getattr(result["response"], "users", None))
        if not users:
            return None
        self.inline_bot_user_id = int(getattr(users[0], "id", 0) or 0)
        return users[0]

    def _inline_results(self, query):
        bot_user = self._inline_bot()
        controller = get_messages_controller()
        if bot_user is None or controller is None or not hasattr(controller, "getInputUser"):
            return None

        try:
            input_user = controller.getInputUser(bot_user)
        except Exception:
            input_user = None
        if input_user is None:
            return None

        request = TLRPC.TL_messages_getInlineBotResults()
        request.bot = input_user
        request.query = str(query or "")
        request.offset = ""
        request.peer = TLRPC.TL_inputPeerEmpty()
        result = self._send_sync(request)
        if not result["success"]:
            return None
        self._cache_entities(result["response"])
        return result["response"]

    def _inline_queries(self, initial_target, resolved_target):
        queries = []
        seen = set()

        def add(value):
            item = str(value or "").strip()
            if not item:
                return
            if not item.isdigit():
                item = self._username_from_text(item) or self._clean_username(item)
            if not item:
                return
            key = item.lower()
            if key in seen:
                return
            seen.add(key)
            queries.append(item)

        add(resolved_target.get("user_id"))
        add(resolved_target.get("username"))
        add(initial_target)
        return queries

    def _inline_result(self, result, query, resolved_target):
        title = str(getattr(result, "title", "") or "").strip()
        description = str(getattr(result, "description", "") or "").strip()
        url = str(getattr(result, "url", "") or "").strip()
        send_message_obj = getattr(result, "send_message", None)
        message = str(getattr(send_message_obj, "message", "") or "").strip() if send_message_obj is not None else ""
        entities = getattr(send_message_obj, "entities", None) if send_message_obj is not None else None

        combined = "\n".join(part for part in (title, description, message, url) if part)
        creation_date = self._creation_date(combined)
        if not creation_date:
            return {}

        username = self._inline_username(
            self._username_from_url(url)
            or self._username_from_entities(message, entities)
            or self._username_from_text(message)
            or self._username_from_text(description)
            or self._username_from_text(title)
            or str(resolved_target.get("username", "") or "").strip(),
            resolved_target,
        )
        user_id = str(resolved_target.get("user_id", "") or "").strip()
        labeled_id = self._labeled_value(combined, ("id", "user id"))
        if labeled_id.isdigit():
            user_id = labeled_id
        if not user_id and str(query or "").isdigit():
            user_id = str(query).strip()

        accuracy_percent = self._accuracy_percent(combined) or 80
        accuracy_text = self._reply_accuracy(combined, accuracy_percent)
        account_name = self._reply_account(combined, title=title, username=username)

        score = 100
        target_id = str(resolved_target.get("user_id", "") or "").strip()
        target_username = str(resolved_target.get("username", "") or "").strip().lower()
        query_text = str(query or "").strip().lower()
        combined_lower = combined.lower()

        if target_id and user_id == target_id:
            score += 180
        elif target_id and target_id in combined_lower:
            score += 90
        if target_username and username.lower() == target_username:
            score += 140
        elif query_text and query_text in combined_lower:
            score += 40

        return {
            "user_id": user_id,
            "username": username,
            "creation_date": creation_date,
            "accuracy_percent": accuracy_percent,
            "accuracy_text": accuracy_text,
            "account_name": account_name,
            "_score": score,
        }

    def _lookup_inline(self, initial_target, resolved_target):
        best = {}
        for query in self._inline_queries(initial_target, resolved_target):
            response = self._inline_results(query)
            if response is None:
                continue
            for result in self._as_list(getattr(response, "results", None)):
                parsed = self._inline_result(result, query, resolved_target)
                if parsed and int(parsed.get("_score", 0)) > int(best.get("_score", 0)):
                    best = parsed
        best.pop("_score", None)
        return best