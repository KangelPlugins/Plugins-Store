    def _create_interface_settings(self):
        return [
            Header(text=localize("Интерфейс", "Interface")),
            Switch(
                key="show_settings_buttons",
                text=localize("Кнопка настроек в меню", "Settings button in menu"),
                subtext=localize(
                    "Добавляет быстрый переход к настройкам плагина в drawer и меню чата.",
                    "Adds a quick link to plugin settings in the drawer and chat menu.",
                ),
                default=True,
                on_change=self._toggle_settings_buttons,
                icon="filled_add_sticker",
            ),
            Switch(
                key="debug_mode",
                text=localize("Подробные логи", "Verbose logs"),
                subtext=localize(
                    "Пишет внутренние сообщения в лог exteraGram.",
                    "Writes internal messages to the exteraGram log.",
                ),
                default=False,
                on_change=self.load_config,
                icon="msg_log",
            ),
        ]

    def on_send_message_hook(self, account, params):
        message = getattr(params, "message", None)
        if not isinstance(message, str):
            return HookResult()

        text = message.strip()
        if not text:
            return HookResult()

        if text.startswith(".cache "):
            self._handle_cache_command(text)
            return HookResult(strategy=HookStrategy.CANCEL)

        if not text.startswith(".age"):
            return HookResult()

        if self.is_processing:
            BulletinHelper.show_info(localize("Запрос уже выполняется.", "A request is already running."))
            return HookResult(strategy=HookStrategy.CANCEL)

        try:
            method, target = self._parse_command(text, params)
            if method == "faq":
                self._show_faq_sheet()
                return HookResult(strategy=HookStrategy.CANCEL)

            if not target:
                self._reply_markdown(params, self._usage_text())
                return HookResult(strategy=HookStrategy.CANCEL)

            if not self.get_setting("free_mode", True):
                if self.api is None:
                    self._reply_markdown(params, self._api_error_text(localize("Укажите API-ключ в настройках.", "Set the API key in settings.")))
                    return HookResult(strategy=HookStrategy.CANCEL)
                self.is_processing = True
                self._show_loading()
                run_on_queue(lambda: self._process_api_request(params, target, method))
            else:
                self.is_processing = True
                self._show_loading()
                run_on_queue(lambda: self._process_free_request(params, target))
        except Exception as error:
            self.is_processing = False
            self._dismiss_loading()
            debug_log(f"Hook error: {traceback.format_exc()}")
            self._reply_markdown(params, self._error_text(str(error)))

        return HookResult(strategy=HookStrategy.CANCEL)

    def _handle_cache_command(self, text):
        target = text.split(" ", 1)[1].strip()
        if not target:
            BulletinHelper.show_error(localize("Использование: .cache <user_id>", "Usage: .cache <user_id>"))
            return
        removed = self.cache.delete_user(target)
        if removed:
            BulletinHelper.show_success(
                localize(f"Удалено записей: {removed}.", f"Removed entries: {removed}.")
            )
        else:
            BulletinHelper.show_info(localize("Записей для этого ID не найдено.", "No entries were found for this ID."))

    def _parse_command(self, text, params):
        parts = text.split(" ", 2)
        if len(parts) > 1 and parts[1].strip().lower() == "faq":
            return "faq", ""

        use_smart = len(parts) > 1 and parts[1].strip().lower() == "smart"
        if use_smart:
            target = parts[2].strip() if len(parts) > 2 else ""
        else:
            target = parts[1].strip() if len(parts) > 1 else ""
        if not target:
            target = self._reply_user_id(params)
        return ("smart" if use_smart else "fast"), str(target or "").strip()

    def _reply_user_id(self, params):
        reply_to = getattr(params, "replyToMsg", None)
        owner = getattr(reply_to, "messageOwner", None) if reply_to is not None else None
        from_id = getattr(owner, "from_id", None) if owner is not None else None
        user_id = int(getattr(from_id, "user_id", 0) or 0) if from_id is not None else 0
        return str(user_id) if user_id > 0 else ""

    def _process_free_request(self, params, target):
        try:
            resolved = self._free_target(target)
            user_id = str(resolved.get("user_id", "") or "")
            cached = self.cache.get(user_id, INLINE_METHOD, self._cache_ttl()) if user_id else None
            cached_inline = isinstance(cached, dict) and bool(str(cached.get("creation_date", "") or "").strip())
            inline_data = dict(cached) if cached_inline else self._lookup_inline(target, resolved)

            if inline_data.get("user_id") and not user_id:
                user_id = str(inline_data["user_id"])
            if user_id and not inline_data.get("user_id"):
                inline_data["user_id"] = user_id
            if resolved.get("username") and not inline_data.get("username"):
                inline_data["username"] = resolved["username"]
            if not cached_inline and user_id and inline_data.get("creation_date"):
                self.cache.set(
                    user_id,
                    INLINE_METHOD,
                    inline_data,
                    meta=self._cache_meta(
                        user_id,
                        inline_data,
                        fallback_username=resolved.get("username", ""),
                    ),
                )

            if inline_data.get("creation_date"):
                message = self._build_report(
                    user_id=inline_data.get("user_id") or user_id,
                    data=inline_data,
                    method="Inline",
                    free_badge=True,
                    cached=cached_inline,
                )
            elif user_id:
                message = self._build_report(user_id=user_id, data={}, method="", free_badge=True)
            else:
                message = self._free_lookup_error(target, resolved.get("error", ""))

            if user_id:
                message += self._build_nft_report_section(user_id)

            run_on_ui_thread(lambda: self._reply_rich_text(params, message))
        except Exception as error:
            debug_log(f"Free mode error: {traceback.format_exc()}")
            run_on_ui_thread(lambda: self._reply_markdown(params, self._error_text(str(error))))
        finally:
            self.is_processing = False
            self._dismiss_loading()

    def _process_api_request(self, params, target, method):
        try:
            resolved = self._resolve_api_target(target)
            if not resolved["ok"]:
                run_on_ui_thread(
                    lambda: self._reply_markdown(params, self._api_error_text(resolved["error"]))
                )
                return

            user_id = resolved["user_id"]
            cached = self.cache.get(user_id, method, self._cache_ttl())
            if cached is not None:
                message = self._build_report(user_id=user_id, data=cached, method=method, cached=True)
            else:
                result = self.api.get_info(user_id, method)
                if not result["ok"]:
                    run_on_ui_thread(
                        lambda: self._reply_markdown(params, self._api_error_text(result["error"]))
                    )
                    return
                self.cache.set(user_id, method, result["data"], meta=self._cache_meta(user_id, result["data"]))
                message = self._build_report(user_id=user_id, data=result["data"], method=method)

            message += self._build_nft_report_section(user_id)
            run_on_ui_thread(lambda: self._reply_rich_text(params, message))
        except Exception as error:
            debug_log(f"API mode error: {traceback.format_exc()}")
            run_on_ui_thread(lambda: self._reply_markdown(params, self._error_text(str(error))))
        finally:
            self.is_processing = False
            self._dismiss_loading()

    def _resolve_api_target(self, target):
        target = str(target or "").strip()
        if target.isdigit():
            return {"ok": True, "user_id": target, "error": ""}

        username = self._username_from_text(target) or self._clean_username(target)
        if not username:
            return {"ok": False, "user_id": "", "error": localize("Некорректный ID или юзернейм.", "Invalid ID or username.")}

        result = self.api.resolve_username(username)
        if not result["ok"]:
            return {"ok": False, "user_id": "", "error": result["error"]}
        return {"ok": True, "user_id": str(result["data"]["id"]), "error": ""}

    def _collect_context(self, user_id, fallback_name="", fallback_username=""):
        labels = {
            "unknown": localize("Неизвестно", "Unknown"),
            "username_missing": localize("отсутствует", "not available"),
        }

        name = labels["unknown"]
        usernames = ""
        dc_id = 0
        region = labels["unknown"]
        birthday = ""
        phone = ""

        if user_id:
            name = get_account_name(user_id)
            usernames = join_usernames(user_id)
            dc_id = get_dc_id(user_id)
            region = get_region(dc_id) if dc_id > 0 else labels["unknown"]
            birthday = get_birthday(user_id)
            if not is_self_user(user_id):
                phone = get_phone(user_id)

        if not name or name in ("Unknown", "Неизвестно"):
            name = str(fallback_name or labels["unknown"]).strip() or labels["unknown"]

        if not usernames:
            usernames = str(fallback_username or "").strip()

        return {
            "name": name,
            "user_id": str(user_id or labels["unknown"]),
            "username": usernames,
            "birthday": birthday,
            "phone": phone,
            "dc": str(dc_id) if dc_id > 0 else labels["unknown"],
            "region": region,
            "nft": get_nft_usernames(user_id) if user_id else [],
        }

    def _build_report(self, user_id, data, method="", free_badge=False, cached=False):
        context = self._collect_context(
            user_id,
            fallback_name=str(data.get("account_name", "") or ""),
            fallback_username=str(data.get("username", "") or ""),
        )

        lines = [f"{self._emoji('📊')} {self._rich_bold(localize('Информация об аккаунте', 'Account information'))}"]
        if free_badge:
            lines[0] += f" ({self._emoji('🆓')})"
        if cached:
            lines.append(self._rich_italic(localize("Из кэша", "From cache")))
        lines.extend(
            [
                "",
                f"{self._emoji('👤')} {self._rich_bold(localize('Имя', 'Name') + ':')} {self._rich_code(context['name'])}",
                f"{self._emoji('🆔')} {self._rich_bold('ID:')} {self._rich_code(context['user_id'])}",
                f"{self._emoji('🖥')} {self._rich_bold('DC:')} {self._rich_code(context['dc'])}",
                f"{self._emoji('🌍')} {self._rich_bold(localize('Регион', 'Region') + ':')} {self._rich_code(context['region'])}",
            ]
        )

        if context["username"]:
            lines.append(
                f"{self._emoji('🔗')} {self._rich_bold(localize('Юзернейм', 'Username') + ':')} {self._rich_code(context['username'])}"
            )
        else:
            lines.append(
                f"{self._emoji('🔗')} {self._rich_bold(localize('Юзернейм', 'Username') + ':')} {self._escape_rich(localize('отсутствует', 'not available'))}"
            )

        if context["phone"]:
            lines.append(
                f"{self._emoji('📱')} {self._rich_bold(localize('Телефон', 'Phone') + ':')} {self._rich_code(context['phone'])}"
            )
        if context["birthday"]:
            lines.append(
                f"{self._emoji('🎂')} {self._rich_bold(localize('День рождения', 'Birthday') + ':')} {self._rich_code(context['birthday'])}"
            )

        creation_date = str(data.get("creation_date", "") or "").strip()
        if creation_date:
            accuracy_percent = int(data.get("accuracy_percent", 0) or 0)
            accuracy_text = self._sanitize_accuracy_text(str(data.get("accuracy_text", "") or "").strip())
            if not accuracy_text:
                accuracy_text = self._accuracy_text("", accuracy_percent)

            lines.append(
                f"{self._emoji('📅')} {self._rich_bold(localize('Дата создания', 'Creation date') + ':')} {self._rich_code(creation_date)}"
            )
            lines.append(
                f"{self._emoji('⏳')} {self._rich_bold(localize('Возраст аккаунта', 'Account age') + ':')} {self._rich_code(format_age(creation_date))}"
            )
            lines.append(
                f"{self._emoji('🎯')} {self._rich_bold(localize('Точность', 'Accuracy') + ':')} {self._emoji(self._accuracy_emoji(accuracy_percent))} {self._escape_rich(accuracy_text)}"
            )
            if method:
                lines.append(
                    f"{self._emoji('⚙️')} {self._rich_bold(localize('Метод', 'Method') + ':')} {self._rich_code(method.capitalize())}"
                )

        return "\n".join(lines)

    def _build_profile_text(self, user_id, api_data=None, api_error=""):
        context = self._collect_context(
            user_id,
            fallback_name=str((api_data or {}).get("account_name", "") or ""),
            fallback_username=str((api_data or {}).get("username", "") or ""),
        )
        lines = [
            f"{localize('Имя', 'Name')}: {context['name']}",
            f"ID: {context['user_id']}",
            f"{localize('Юзернейм', 'Username')}: {context['username'] or localize('отсутствует', 'not available')}",
        ]
        if context["phone"]:
            lines.append(f"{localize('Телефон', 'Phone')}: {context['phone']}")
        if context["birthday"]:
            lines.append(f"{localize('День рождения', 'Birthday')}: {context['birthday']}")

        creation_date = str((api_data or {}).get("creation_date", "") or "").strip()
        if creation_date:
            accuracy_percent = int((api_data or {}).get("accuracy_percent", 0) or 0)
            accuracy_text = self._sanitize_accuracy_text(str((api_data or {}).get("accuracy_text", "") or "").strip())
            if not accuracy_text:
                accuracy_text = self._accuracy_text("", accuracy_percent)
            lines.append(f"{localize('Дата создания', 'Creation date')}: {creation_date}")
            lines.append(f"{localize('Возраст аккаунта', 'Account age')}: {format_age(creation_date)}")
            lines.append(f"{localize('Точность', 'Accuracy')}: {self._accuracy_emoji(accuracy_percent)} {accuracy_text}")

        lines.append(f"DC: {context['dc']}")
        lines.append(f"{localize('Регион', 'Region')}: {context['region']}")

        if context["nft"] and self.get_setting("show_nft_usernames", True):
            lines.append("")
            lines.append(localize("NFT-юзернеймы:", "NFT usernames:"))
            lines.extend(f"• @{username}" for username in context["nft"])

        if api_error:
            lines.append("")
            lines.append(f"{localize('Ошибка API', 'API error')}: {api_error}")

        return "\n".join(lines)

    def _build_nft_report_section(self, user_id):
        if not self.get_setting("show_nft_usernames", True):
            return ""

        lines = []
        for username in get_nft_usernames(user_id):
            info = self._collectible_info(username)
            if info is None:
                lines.append(f"• {self._rich_code('@' + username)}")
                continue

            pieces = [f"• {self._rich_code('@' + username)}", self._escape_rich(format_date(info.get('purchase_date')))]
            price = self._format_collectible_price(info)
            crypto_price = self._format_collectible_price(info, crypto=True)
            if price:
                pieces.append(self._escape_rich(price))
            if crypto_price:
                pieces.append(self._escape_rich(crypto_price))
            line = " — ".join(part for part in pieces if part)

            url = str(info.get("url", "") or "").strip()
            if url:
                line += " " + self._rich_link("Fragment", url)
            lines.append(line)

        if not lines:
            return ""
        return "\n\n" + self._emoji("💎") + " " + self._rich_bold(localize("NFT-юзернеймы", "NFT usernames")) + "\n" + "\n".join(lines)

    def _format_collectible_price(self, info, crypto=False):
        if crypto:
            amount = int(info.get("crypto_amount", 0) or 0)
            currency = str(info.get("crypto_currency", "") or "").strip()
            return f"{amount / 1000000000:.4f} {currency}" if amount and currency else ""
        amount = int(info.get("amount", 0) or 0)
        currency = str(info.get("currency", "") or "").strip()
        return f"{amount / 100:.2f} {currency}" if amount and currency else ""

    def _collectible_info(self, username):
        request = TL_fragment.TL_getCollectibleInfo()
        collectible = TL_fragment.TL_inputCollectibleUsername()
        collectible.username = username
        request.collectible = collectible
        result = self._send_sync(request, timeout_seconds=10)
        response = result["response"]
        if not result["success"] or response is None:
            return None
        return {
            "purchase_date": int(getattr(response, "purchase_date", 0) or 0),
            "currency": str(getattr(response, "currency", "") or ""),
            "amount": int(getattr(response, "amount", 0) or 0),
            "crypto_currency": str(getattr(response, "crypto_currency", "") or ""),
            "crypto_amount": int(getattr(response, "crypto_amount", 0) or 0),
            "url": str(getattr(response, "url", "") or ""),
        }

    def _add_profile_button(self):
        try:
            self.profile_menu_item = self.add_menu_item(
                MenuItemData(
                    menu_type=MenuItemType.PROFILE_ACTION_MENU,
                    item_id="account_info_button",
                    text=localize("Информация об аккаунте", "Account info"),
                    icon="msg_info",
                    on_click=self._handle_profile_click,
                    condition="user != null",
                )
            )
        except Exception as error:
            debug_log(f"Failed to add profile menu item: {error}")

    def _handle_profile_click(self, context):
        user = context.get("user") if context else None
        user_id = str(getattr(user, "id", 0) or 0)
        if not user_id or user_id == "0":
            BulletinHelper.show_error(localize("Пользователь не найден.", "User not found."))
            return

        if self.get_setting("free_mode", True) or self.api is None:
            self._show_alert(
                localize("Информация об аккаунте", "Account information"),
                self._build_profile_text(user_id),
            )
            return

        self._show_loading()
        run_on_queue(lambda: self._process_profile_request(user_id))

    def _process_profile_request(self, user_id):
        title = localize("Информация об аккаунте", "Account information")
        try:
            cached = self.cache.get(user_id, "fast", self._cache_ttl())
            if cached is not None:
                title += localize(" (из кэша)", " (cached)")
                text = self._build_profile_text(user_id, cached)
            else:
                result = self.api.get_info(user_id, "fast")
                if result["ok"]:
                    self.cache.set(user_id, "fast", result["data"], meta=self._cache_meta(user_id, result["data"]))
                    text = self._build_profile_text(user_id, result["data"])
                else:
                    text = self._build_profile_text(user_id, None, result["error"])
            run_on_ui_thread(lambda: self._show_alert(title, text))
        except Exception as error:
            debug_log(f"Profile request error: {traceback.format_exc()}")
            run_on_ui_thread(lambda: self._show_alert(localize("Ошибка", "Error"), str(error)))
        finally:
            self._dismiss_loading()

    def _cache_ttl(self):
        try:
            return max(0, int(str(self.get_setting("cache_duration", CACHE_TTL)).strip()))
        except Exception:
            return CACHE_TTL

    def _prune_cache(self):
        removed = self.cache.prune(self._cache_ttl())
        BulletinHelper.show_success(
            localize(f"Удалено {removed} просроченных записей.", f"Removed {removed} expired entries.")
        )

    def _clear_cache(self):
        self.cache.clear()
        BulletinHelper.show_success(localize("Кеш очищен.", "Cache cleared."))

    def _normalize_username_text(self, value):
        text = str(value or "").strip()
        if not text:
            return ""
        if "," in text:
            parts = []
            for part in text.split(","):
                username = str(part or "").strip().lstrip("@")
                if username:
                    parts.append("@" + username)
            return ", ".join(parts)
        if text.startswith("@"):
            return text
        return "@" + text.lstrip("@")

    def _cache_meta(self, user_id, data=None, fallback_username=""):
        payload = data if isinstance(data, dict) else {}
        unknown = localize("Неизвестно", "Unknown")

        display_name = get_account_name(user_id) if user_id else ""
        if not display_name or display_name == unknown:
            display_name = str(payload.get("account_name", "") or "").strip() or unknown

        usernames = join_usernames(user_id) if user_id else ""
        if not usernames:
            usernames = self._normalize_username_text(payload.get("username") or fallback_username)

        return {"display_name": display_name, "username_text": usernames}

    def _cache_method_label(self, method):
        method = str(method or "").lower()
        labels = {
            "inline": localize("Inline", "Inline"),
            "fast": localize("Fast API", "Fast API"),
            "smart": localize("Smart API", "Smart API"),
        }
        return labels.get(method, str(method or "").strip() or localize("Неизвестно", "Unknown"))

    def _cache_sources_label(self, count):
        count = max(0, int(count or 0))
        if is_russian():
            if count % 10 == 1 and count % 100 != 11:
                word = "источник"
            elif 2 <= count % 10 <= 4 and not 12 <= count % 100 <= 14:
                word = "источника"
            else:
                word = "источников"
            return f"{count} {word}"
        return f"{count} source" + ("s" if count != 1 else "")

    def _cache_entry_line(self, entry):
        creation_date = str((entry.get("data") or {}).get("creation_date", "") or "—")
        remaining = localize("просрочено", "expired") if entry["expired"] else format_seconds(entry["remaining"])
        return f"• {self._cache_method_label(entry['method'])} · {creation_date} · {remaining}"

    def _cache_user_groups(self):
        groups = {}
        for entry in self.cache.entries(self._cache_ttl()):
            user_id = str(entry.get("user_id", "") or "").strip()
            if not user_id:
                continue

            group = groups.setdefault(
                user_id,
                {
                    "user_id": user_id,
                    "entries": [],
                    "methods": [],
                    "timestamp": 0,
                    "remaining": 0,
                    "expired": True,
                    "creation_date": "",
                    "display_name": "",
                    "username_text": "",
                },
            )
            group["entries"].append(entry)
            group["remaining"] = max(group["remaining"], int(entry.get("remaining", 0) or 0))
            group["expired"] = group["expired"] and bool(entry.get("expired", False))
            if int(entry.get("timestamp", 0) or 0) >= group["timestamp"]:
                group["timestamp"] = int(entry.get("timestamp", 0) or 0)
                group["creation_date"] = str((entry.get("data") or {}).get("creation_date", "") or "")

            method_label = self._cache_method_label(entry.get("method"))
            if method_label not in group["methods"]:
                group["methods"].append(method_label)

        result = []
        unknown = localize("Неизвестно", "Unknown")
        for user_id, group in groups.items():
            sample = group["entries"][0] if group["entries"] else {}
            data = sample.get("data") or {}
            meta = sample.get("meta") or {}

            display_name = get_account_name(user_id)
            if not display_name or display_name == unknown:
                display_name = str(meta.get("display_name", "") or data.get("account_name", "")).strip() or unknown

            usernames = join_usernames(user_id)
            if not usernames:
                usernames = self._normalize_username_text(meta.get("username_text") or data.get("username"))

            group["display_name"] = display_name
            group["username_text"] = usernames
            result.append(group)

        result.sort(key=lambda item: item["timestamp"], reverse=True)
        return result

    def _cache_user_row_subtext(self, group):
        identity = group["username_text"] or f"ID {group['user_id']}"
        methods = self._cache_sources_label(len(group["entries"]))
        ttl_text = localize("просрочено", "expired") if group["expired"] else format_seconds(group["remaining"])
        return f"{identity} · {methods} · {ttl_text}"

    def _show_cache_stats_dialog(self):
        ttl = self._cache_ttl()
        stats = self.cache.stats(ttl)
        message = "\n".join(
            [
                f"{localize('Хранение', 'Lifetime')}: {describe_cache_ttl(ttl)}",
                f"{localize('Пользователи', 'Users')}: {stats['unique_users']}",
                localize(
                    f"Записи: {stats['total']} ({stats['active']} активных, {stats['expired']} просроченных)",
                    f"Entries: {stats['total']} ({stats['active']} active, {stats['expired']} expired)",
                ),
                f"Fast API: {stats['fast']} · Smart API: {stats['smart']} · Inline: {stats['inline']}",
                f"{localize('Размер', 'Size')}: {stats['size']}",
            ]
        )
        self._show_alert(localize("Статистика кеша", "Cache stats"), message)

    def _show_cache_users_dialog(self):
        users = self._cache_user_groups()
        if not users:
            self._show_alert(localize("Кеш", "Cache"), localize("Кеш пуст.", "Cache is empty."))
            return

        fragment = get_last_fragment()
        context = fragment.getParentActivity() if fragment is not None else None
        if context is None:
            BulletinHelper.show_error(localize("Не удалось открыть список пользователей.", "Failed to open user list."))
            return

        items = [f"{group['display_name']}\n{self._cache_user_row_subtext(group)}" for group in users]
        builder = AlertDialogBuilder(context, AlertDialogBuilder.ALERT_TYPE_MESSAGE)
        builder.set_title(
            localize(
                f"Пользователи в кеше ({len(users)})",
                f"Cached users ({len(users)})",
            )
        )

        def on_select(dialog, which):
            dialog.dismiss()
            if 0 <= which < len(users):
                self._show_cache_user_actions(users[which])

        builder.set_items(items, on_select)
        builder.set_negative_button(localize("Закрыть", "Close"), lambda d, _w: d.dismiss())
        run_on_ui_thread(builder.show)

    def _show_cache_user_actions(self, group):
        fragment = get_last_fragment()
        context = fragment.getParentActivity() if fragment is not None else None
        if context is None:
            BulletinHelper.show_error(localize("Не удалось открыть карточку пользователя.", "Failed to open user card."))
            return

        status_text = (
            localize("все записи просрочены", "all entries are expired")
            if group["expired"]
            else localize(
                f"осталось {format_seconds(group['remaining'])}",
                f"{format_seconds(group['remaining'])} remaining",
            )
        )
        lines = [f"ID: {group['user_id']}"]
        if group["username_text"]:
            lines.append(f"{localize('Юзернейм', 'Username')}: {group['username_text']}")
        if group["creation_date"]:
            lines.append(f"{localize('Дата регистрации', 'Creation date')}: {group['creation_date']}")
        lines.append(f"{localize('Источники', 'Sources')}: {', '.join(group['methods'])}")
        lines.append(f"{localize('Состояние', 'Status')}: {status_text}")
        lines.append("")
        lines.append(localize("По источникам:", "By source:"))

        for entry in group["entries"]:
            lines.append(self._cache_entry_line(entry))

        actions = [localize("Очистить всё для пользователя", "Clear all for user")]
        action_entries = []
        if len(group["entries"]) > 1:
            for entry in group["entries"]:
                actions.append(
                    localize(
                        f"Удалить только {self._cache_method_label(entry['method'])}",
                        f"Remove only {self._cache_method_label(entry['method'])}",
                    )
                )
                action_entries.append(entry)

        builder = AlertDialogBuilder(context, AlertDialogBuilder.ALERT_TYPE_MESSAGE)
        builder.set_title(group["display_name"])
        builder.set_message("\n".join(lines))

        def on_select(dialog, which):
            dialog.dismiss()
            if which == 0:
                self._confirm_delete_user_cache(group["user_id"], group["display_name"])
                return
            entry_index = which - 1
            if 0 <= entry_index < len(action_entries):
                entry = action_entries[entry_index]
                self._confirm_delete_cache_entry(group["user_id"], entry["method"], group["display_name"])

        builder.set_items(actions, on_select)
        builder.set_negative_button(localize("Закрыть", "Close"), lambda d, _w: d.dismiss())
        run_on_ui_thread(builder.show)

    def _show_confirm_dialog(self, title, message, on_confirm, confirm_text, red=False):
        fragment = get_last_fragment()
        context = fragment.getParentActivity() if fragment is not None else None
        if context is None:
            BulletinHelper.show_error(localize("Не удалось открыть подтверждение.", "Failed to open confirmation."))
            return

        builder = AlertDialogBuilder(context, AlertDialogBuilder.ALERT_TYPE_MESSAGE)
        builder.set_title(title)
        builder.set_message(message)
        builder.set_positive_button(confirm_text, lambda d, _w: (d.dismiss(), on_confirm()))
        builder.set_negative_button(localize("Отмена", "Cancel"), lambda d, _w: d.dismiss())
        if red:
            builder.make_button_red(AlertDialogBuilder.BUTTON_POSITIVE)
        run_on_ui_thread(builder.show)

    def _confirm_prune_cache(self):
        stats = self.cache.stats(self._cache_ttl())
        if stats["expired"] <= 0:
            BulletinHelper.show_info(localize("Просроченных записей нет.", "There are no expired entries."))
            return

        self._show_confirm_dialog(
            localize("Удалить просроченное?", "Prune expired entries?"),
            localize(
                f"Будут удалены {stats['expired']} просроченных записей.",
                f"{stats['expired']} expired entries will be removed.",
            ),
            self._prune_cache,
            localize("Удалить", "Remove"),
            red=True,
        )

    def _confirm_clear_cache(self):
        stats = self.cache.stats(self._cache_ttl())
        if stats["total"] <= 0:
            BulletinHelper.show_info(localize("Кеш уже пуст.", "Cache is already empty."))
            return

        self._show_confirm_dialog(
            localize("Очистить весь кеш?", "Clear all cache?"),
            localize(
                f"Будут удалены {stats['total']} записей для {stats['unique_users']} пользователей.",
                f"{stats['total']} entries for {stats['unique_users']} users will be removed.",
            ),
            self._clear_cache,
            localize("Очистить", "Clear"),
            red=True,
        )

    def _confirm_delete_user_cache(self, user_id, display_name=""):
        title = display_name or localize("Пользователь", "User")
        self._show_confirm_dialog(
            localize("Удалить пользователя из кеша?", "Remove user from cache?"),
            localize(
                f"Все записи для {title} будут удалены.",
                f"All cache entries for {title} will be removed.",
            ),
            lambda: self._delete_cached_user(user_id),
            localize("Удалить", "Remove"),
            red=True,
        )

    def _confirm_delete_cache_entry(self, user_id, method, display_name=""):
        method_label = self._cache_method_label(method)
        title = display_name or localize("Пользователь", "User")
        self._show_confirm_dialog(
            localize("Удалить запись кеша?", "Remove cache entry?"),
            localize(
                f"Будет удалён только источник {method_label} для {title}.",
                f"Only the {method_label} source will be removed for {title}.",
            ),
            lambda: self._delete_cached_entry(user_id, method),
            localize("Удалить", "Remove"),
            red=True,
        )

    def _delete_cached_user(self, user_id):
        removed = self.cache.delete_user(user_id)
        if removed:
            BulletinHelper.show_success(
                localize(f"Удалено {removed} записей.", f"Removed {removed} entries.")
            )
        else:
            BulletinHelper.show_info(localize("Записи уже удалены.", "Entries are already removed."))

    def _delete_cached_entry(self, user_id, method):
        removed = self.cache.delete_entry(user_id, method)
        if removed:
            BulletinHelper.show_success(
                localize(
                    f"Удалён источник {self._cache_method_label(method)}.",
                    f"Removed {self._cache_method_label(method)} source.",
                )
            )
        else:
            BulletinHelper.show_info(localize("Запись уже удалена.", "Entry is already removed."))

    def _add_settings_buttons(self):
        try:
            if self.drawer_settings_item is None:
                self.drawer_settings_item = self.add_menu_item(
                    MenuItemData(
                        menu_type=MenuItemType.DRAWER_MENU,
                        text=localize("AAC", "AAC"),
                        icon="filled_sharing_off2_24",
                        priority=5,
                        on_click=lambda _: run_on_ui_thread(self._open_plugin_settings),
                    )
                )
            if self.chat_settings_item is None:
                self.chat_settings_item = self.add_menu_item(
                    MenuItemData(
                        menu_type=MenuItemType.CHAT_ACTION_MENU,
                        text=localize("AAC", "AAC"),
                        icon="filled_sharing_off2_24",
                        priority=5,
                        on_click=lambda _: run_on_ui_thread(self._open_plugin_settings),
                    )
                )
        except Exception as error:
            debug_log(f"Failed to add settings buttons: {error}")

    def _toggle_settings_buttons(self, enabled):
        def toggle():
            if enabled:
                self._add_settings_buttons()
                return
            for attr in ("drawer_settings_item", "chat_settings_item"):
                item = getattr(self, attr)
                if item:
                    try:
                        self.remove_menu_item(item)
                    except Exception as error:
                        debug_log(f"Failed to remove {attr}: {error}")
                setattr(self, attr, None)

        run_on_ui_thread(toggle)

    def _open_plugin_settings(self):
        try:
            fragment = get_last_fragment()
            java_plugin = PluginsController.getInstance().plugins.get(self.id)
            if fragment is not None and java_plugin is not None:
                fragment.presentFragment(PluginSettingsActivity(java_plugin))
        except Exception as error:
            debug_log(f"Failed to open settings: {error}")

    def _show_alert(self, title, message):
        fragment = get_last_fragment()
        if fragment is None:
            return
        builder = AlertDialogBuilder(fragment.getParentActivity())
        builder.set_title(title)
        builder.set_message(message)
        builder.set_positive_button(localize("Закрыть", "Close"), None)
        run_on_ui_thread(builder.show)

