_PAYLOAD_SHA256 = "0ffac035c1a12abbd43f260390d11350427de40cd1056cf18a63ec9397c3f491"


def _log(msg):
    try:
        from android_utils import log as android_log
        android_log(f"[eblannft-single] {msg}")
    except Exception:
        pass


def _client_storage_name():
    try:
        from org.telegram.messenger import ApplicationLoader
        ctx = ApplicationLoader.applicationContext
        pkg = str(ctx.getPackageName() or "").lower() if ctx is not None else ""
        if "extera" in pkg:
            return "exteraGram"
        if "ayu" in pkg:
            return "AyuGram"
    except Exception:
        pass
    return _RUNTIME_DIR_NAME


def _candidate_roots():
    roots, seen = [], set()
    def push(path):
        if not path:
            return
        try:
            path = os.path.abspath(str(path))
        except Exception:
            return
        if path and path not in seen:
            seen.add(path)
            roots.append(path)
    try:
        from org.telegram.messenger import ApplicationLoader
        ctx = ApplicationLoader.applicationContext
        if ctx is not None:
            try:
                ext = ctx.getExternalFilesDir(None)
                if ext is not None:
                    push(os.path.join(str(ext.getAbsolutePath()), _RUNTIME_DIR_NAME))
            except Exception:
                pass
            try:
                files_dir = ctx.getFilesDir()
                if files_dir is not None:
                    push(os.path.join(str(files_dir.getAbsolutePath()), _RUNTIME_DIR_NAME))
            except Exception:
                pass
    except Exception:
        pass
    try:
        from java import jclass
        Environment = jclass("android.os.Environment")
        downloads = Environment.getExternalStoragePublicDirectory(Environment.DIRECTORY_DOWNLOADS)
        if downloads is not None:
            push(os.path.join(str(downloads.getAbsolutePath()), _client_storage_name(), _RUNTIME_DIR_NAME))
            push(os.path.join(str(downloads.getAbsolutePath()), _RUNTIME_DIR_NAME))
    except Exception:
        pass
    try:
        push(os.path.dirname(os.path.abspath(__file__)))
    except Exception:
        pass
    return roots


def _is_writable(root):
    try:
        os.makedirs(os.path.join(root, _RUNTIME_PACKAGE_NAME), exist_ok=True)
        probe = os.path.join(root, _RUNTIME_PACKAGE_NAME, ".write_probe.tmp")
        with open(probe, "wb") as fh:
            fh.write(b"x")
        os.remove(probe)
        return True
    except Exception:
        return False


def _runtime_hash_path(root):
    return os.path.join(root, _RUNTIME_PACKAGE_NAME, ".single_payload_sha256")


def _runtime_current(root):
    try:
        with open(_runtime_hash_path(root), "r", encoding="utf-8") as fh:
            return fh.read().strip() == _PAYLOAD_SHA256
    except Exception:
        return False


def _extract_runtime(root):
    raw = base64.b64decode(_PAYLOAD_B64)
    if hashlib.sha256(raw).hexdigest() != _PAYLOAD_SHA256:
        raise RuntimeError("embedded runtime payload hash mismatch")
    os.makedirs(root, exist_ok=True)
    with zipfile.ZipFile(io.BytesIO(raw), "r") as zf:
        for info in zf.infolist():
            name = str(info.filename or "").replace("\\", "/")
            if not name.startswith(_RUNTIME_PACKAGE_NAME + "/") or name.endswith("/"):
                continue
            dest = os.path.abspath(os.path.join(root, name.replace("/", os.sep)))
            base = os.path.abspath(root)
            if not (dest == base or dest.startswith(base + os.sep)):
                continue
            os.makedirs(os.path.dirname(dest), exist_ok=True)
            tmp = dest + ".tmp"
            with zf.open(info, "r") as src, open(tmp, "wb") as out:
                out.write(src.read())
            os.replace(tmp, dest)
    with open(_runtime_hash_path(root), "w", encoding="utf-8") as fh:
        fh.write(_PAYLOAD_SHA256)


def _bootstrap_runtime():
    first_writable = None
    for root in _candidate_roots():
        if first_writable is None and _is_writable(root):
            first_writable = root
        if _is_writable(root):
            if not _runtime_current(root):
                _extract_runtime(root)
                return root, "extracted"
            return root, "reused"
    if not first_writable:
        raise RuntimeError("No writable directory for eblanNFT runtime")
    _extract_runtime(first_writable)
    return first_writable, "extracted"


def _evict_runtime_modules():
    for name in (
        f"{_RUNTIME_PACKAGE_ALIAS}.plugin",
        f"{_RUNTIME_PACKAGE_ALIAS}.updater",
        f"{_RUNTIME_PACKAGE_ALIAS}.sync_client",
        f"{_RUNTIME_PACKAGE_ALIAS}.legacy_gifts",
        _RUNTIME_PACKAGE_ALIAS,
        _RUNTIME_PACKAGE_NAME,
    ):
        try:
            sys.modules.pop(name, None)
        except Exception:
            pass


def _import_runtime(root):
    pkg_dir = os.path.join(root, _RUNTIME_PACKAGE_NAME)
    init_py = os.path.join(pkg_dir, "__init__.py")
    plugin_py = os.path.join(pkg_dir, "plugin.py")
    pkg_spec = importlib.util.spec_from_file_location(
        _RUNTIME_PACKAGE_ALIAS,
        init_py,
        submodule_search_locations=[pkg_dir],
    )
    if pkg_spec is None or pkg_spec.loader is None:
        raise ImportError(f"cannot load runtime package from {pkg_dir}")
    pkg_mod = importlib.util.module_from_spec(pkg_spec)
    sys.modules[_RUNTIME_PACKAGE_ALIAS] = pkg_mod
    pkg_spec.loader.exec_module(pkg_mod)

    mod_name = f"{_RUNTIME_PACKAGE_ALIAS}.plugin"
    plugin_spec = importlib.util.spec_from_file_location(mod_name, plugin_py)
    if plugin_spec is None or plugin_spec.loader is None:
        raise ImportError(f"cannot load runtime plugin from {plugin_py}")
    plugin_mod = importlib.util.module_from_spec(plugin_spec)
    sys.modules[mod_name] = plugin_mod
    plugin_spec.loader.exec_module(plugin_mod)

    for attr in _IMPL_ATTR_CANDIDATES:
        impl = getattr(plugin_mod, attr, None)
        if isinstance(impl, type) and issubclass(impl, BasePlugin):
            return impl
    raise ImportError("runtime plugin class not found")


def _load_impl():
    root, mode = _bootstrap_runtime()
    _log(f"runtime {mode}: {root}")
    _evict_runtime_modules()
    impl = _import_runtime(root)
    try:
        impl._EBLANNFT_RUNTIME_ROOT = root
        impl._EBLANNFT_BOOTSTRAP_PATH = os.path.abspath(__file__)
        impl._EBLANNFT_SINGLE_FILE_BUILD = True
        impl._EBLANNFT_UPDATE_CHANNEL = "eblannftlogs"
    except Exception:
        pass
    return impl


_LOAD_ERROR = None
try:
    EblanNftPlugin = _load_impl()
except Exception as exc:
    _LOAD_ERROR = exc
    _log(f"fatal loader error: {exc}")

    class EblanNftPlugin(BasePlugin):
        def on_plugin_load(self):
            _log(f"runtime unavailable on load: {_LOAD_ERROR}")

        def create_settings(self):
            try:
                from ui.settings import Header, Text, Divider
                return [
                    Header(text="eblanNFT"),
                    Text(
                        text="Runtime не загрузился",
                        subtext=str(_LOAD_ERROR or "unknown error")[:180],
                        icon="msg_error",
                    ),
                    Text(
                        text="Переустановить плагин",
                        subtext="Удалите и установите свежий eblannft.plugin",
                        icon="msg_retry",
                    ),
                    Divider(),
                    Text(
                        text="Версия bootstrap",
                        subtext=str(__version__),
                        icon="msg_info",
                    ),
                ]
            except Exception:
                return []


NftClonerPlugin = EblanNftPlugin
