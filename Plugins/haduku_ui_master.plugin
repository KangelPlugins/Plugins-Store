    # ── 15. Сброс настроек ────────────────────────────────────────────────────

    def _reset_all_settings(self, view):
        from client_utils import get_last_fragment
        from ui.alert import AlertDialogBuilder

        fragment = get_last_fragment()
        if not fragment:
            return
        activity = fragment.getParentActivity()
        if not activity:
            return

        def do_reset(bld, which):
            self.import_settings({}, reload_settings=True)
            BulletinHelper.show_info("Все настройки haduku UI Master сброшены.")
            bld.dismiss()

        bld = AlertDialogBuilder(activity)
        bld.set_title("Сбросить настройки?")
        bld.set_message(
            "Все параметры haduku UI Master вернутся к значениям по умолчанию. "
            "Это действие нельзя отменить."
        )
        bld.set_positive_button("Сбросить", do_reset)
        bld.make_button_red(AlertDialogBuilder.BUTTON_POSITIVE)
        bld.set_negative_button("Отмена", lambda b, w: b.dismiss())
        bld.show()

    # ══════════════════════════════════════════════════════════════════════════
    #  ГЛАВНЫЙ ЭКРАН НАСТРОЕК
    # ══════════════════════════════════════════════════════════════════════════

    def create_settings(self) -> List[Any]:
        return [
            # ── заголовок ─────────────────────────────────────────────────────
            Header(text="haduku UI Master"),

            # ── быстрый переключатель ─────────────────────────────────────────
            Switch(
                key="plugin_master_enabled",
                text="Плагин включён",
                default=True,
                subtext="Глобальный переключатель всех модификаций UI.",
                icon="msg_settings",
                on_change=lambda v: BulletinHelper.show_info(
                    "haduku UI Master " + ("включён ✓" if v else "выключен")
                ),
                link_alias="master_toggle",
            ),

            Divider(),
            Header(text="Разделы"),

            # ── пузыри ────────────────────────────────────────────────────────
            Text(
                text="💬  Пузыри сообщений",
                icon="msg_edit",
                create_sub_fragment=self._sub_bubbles,
                link_alias="section_bubbles",
            ),

            # ── список диалогов ───────────────────────────────────────────────
            Text(
                text="📋  Список диалогов",
                icon="msg_list",
                create_sub_fragment=self._sub_dialogs,
                link_alias="section_dialogs",
            ),

            # ── шапка / actionbar ─────────────────────────────────────────────
            Text(
                text="🔧  ActionBar и шапка",
                icon="msg_settings",
                create_sub_fragment=self._sub_actionbar,
                link_alias="section_actionbar",
            ),

            # ── нижняя навигация ──────────────────────────────────────────────
            Text(
                text="🧭  Нижняя навигация",
                icon="msg_menu",
                create_sub_fragment=self._sub_navbar,
                link_alias="section_navbar",
            ),

            # ── аватарки ──────────────────────────────────────────────────────
            Text(
                text="👤  Аватарки",
                icon="msg_contacts",
