class BubbleRadiusHook(MethodHook):
    """Перехватывает метод отрисовки пузыря и подменяет радиус скругления."""

    def __init__(self, plugin: "UIMasterPlugin"):
        self.plugin = plugin

    def before_hooked_method(self, param):
        try:
            if not self.plugin.get_setting("bubbles_custom_radius", False):
                return
            radius = self.plugin.get_setting("bubble_corner_radius", 16)
            # args[0] — обычно объект RectF или float radius
            if param.args and len(param.args) > 0:
                param.args[0] = Float(float(radius))
        except Exception as e:
            self.plugin.log(f"[BubbleRadiusHook] {e}")


class BubbleShadowHook(MethodHook):
    """Включает или отключает тень под пузырём сообщения."""

    def __init__(self, plugin: "UIMasterPlugin"):
        self.plugin = plugin

    def before_hooked_method(self, param):
        try:
            if not self.plugin.get_setting("bubbles_disable_shadow", False):
                return
            param.setResult(None)
        except Exception as e:
            self.plugin.log(f"[BubbleShadowHook] {e}")


class AnimationSpeedHook(MethodHook):
    """Масштабирует длительность всех системных анимаций."""

    def __init__(self, plugin: "UIMasterPlugin"):
        self.plugin = plugin

    def after_hooked_method(self, param):
        try:
            multiplier = self.plugin.get_setting("animation_speed_multiplier", 10)
            # 10 → 1.0x, 5 → 0.5x, 20 → 2.0x
            factor = multiplier / 10.0
            result = param.getResult()
            if result is not None:
                try:
                    param.setResult(Float(float(result) * factor))
                except Exception:
                    pass
        except Exception as e:
            self.plugin.log(f"[AnimationSpeedHook] {e}")


class NavBarHeightHook(MethodHook):
    """Меняет высоту нижней навигации."""

    def __init__(self, plugin: "UIMasterPlugin"):
        self.plugin = plugin

    def after_hooked_method(self, param):
        try:
            if not self.plugin.get_setting("navbar_custom_height", False):
                return
            height_dp = self.plugin.get_setting("navbar_height_dp", 52)
            param.setResult(Integer(int(height_dp * 3)))  # dp → px ~3x
        except Exception as e:
            self.plugin.log(f"[NavBarHeightHook] {e}")


