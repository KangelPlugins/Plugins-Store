class ScrollSpeedHook(MethodHook):
    """Изменяет скорость прокрутки списка сообщений."""

    def __init__(self, plugin: "UIMasterPlugin"):
        self.plugin = plugin

    def after_hooked_method(self, param):
        try:
            if not self.plugin.get_setting("scroll_custom_speed", False):
                return
            speed = self.plugin.get_setting("scroll_speed_factor", 10) / 10.0
            result = param.getResult()
            if result is not None:
                try:
                    param.setResult(Float(float(result) * speed))
                except Exception:
                    pass
        except Exception as e:
            self.plugin.log(f"[ScrollSpeedHook] {e}")


class RoundAvatarHook(MethodReplacement):
    """Переключает форму аватара: круг / квадрат со скруглением."""

    def __init__(self, plugin: "UIMasterPlugin"):
        self.plugin = plugin

    def replace_hooked_method(self, param):
        style = self.plugin.get_setting("avatar_shape_style", 0)
        # 0 = circle (default), 1 = squircle, 2 = square
        try:
            if style == 0:
                # вызвать оригинальную реализацию невозможно в MethodReplacement,
                # поэтому просто возвращаем значение "round" = true
                return Boolean(True)
            else:
                return Boolean(False)
        except Exception as e:
            self.plugin.log(f"[RoundAvatarHook] {e}")
            return Boolean(True)


# ══════════════════════════════════════════════════════════════════════════════
#  MAIN PLUGIN CLASS
# ══════════════════════════════════════════════════════════════════════════════

class UIMasterPlugin(BasePlugin):

    # ── жизненный цикл ────────────────────────────────────────────────────────

    def on_plugin_load(self):
        self.log("haduku UI Master загружен ✓")
        self._register_hooks()

    def on_plugin_unload(self):
        self.log("haduku UI Master выгружен")

    # ── регистрация хуков ─────────────────────────────────────────────────────

    def _register_hooks(self):
        """Пробуем найти и зацепить все нужные методы. Любой сбой не роняет плагин."""
        self._hook_bubble_radius()
        self._hook_bubble_shadow()
        self._hook_animation_speed()
        self._hook_navbar_height()
        self._hook_actionbar_height()
        self._hook_avatar_size()
        self._hook_avatar_shape()
        self._hook_emoji_size()
        self._hook_sticker_size()
        self._hook_typing_indicator()
        self._hook_online_status()
        self._hook_reaction_size()
        self._hook_forward_header()
        self._hook_message_timestamp()
        self._hook_verified_badge()
        self._hook_premium_badge()
        self._hook_scroll_speed()

    def _safe_hook(self, label: str, class_name: str, method_name: str, handler,
                   *param_types):
        try:
            clazz = find_class(class_name)
            if not clazz:
                self.log(f"[hook] класс не найден: {class_name}")
                return
            if param_types:
                method = clazz.getClass().getDeclaredMethod(method_name, *param_types)
            else:
                method = clazz.getClass().getDeclaredMethod(method_name)
            method.setAccessible(True)
            self.hook_method(method, handler)
            self.log(f"[hook] ✓ {label}")
        except Exception as e:
            self.log(f"[hook] ✗ {label}: {e}")

    def _hook_bubble_radius(self):
        self._safe_hook(
            "BubbleRadius",
            "org.telegram.ui.Cells.ChatMessageCell",
            "getBubbleTopRadius",
            BubbleRadiusHook(self),
        )

    def _hook_bubble_shadow(self):
        self._safe_hook(
            "BubbleShadow",
            "org.telegram.ui.Cells.ChatMessageCell",
            "drawBubbleShadow",
            BubbleShadowHook(self),
        )

    def _hook_animation_speed(self):
        from java.lang import Long
        self._safe_hook(
            "AnimationDuration",
            "org.telegram.messenger.AndroidUtilities",
            "getAnimDuration",
            AnimationSpeedHook(self),
        )

    def _hook_navbar_height(self):
        self._safe_hook(
            "NavBarHeight",
            "org.telegram.ui.ActionBar.BottomNavigationPanel",
            "getHeight",
            NavBarHeightHook(self),
        )

    def _hook_actionbar_height(self):
        self._safe_hook(
            "ActionBarHeight",
            "org.telegram.ui.ActionBar.ActionBar",
            "getCurrentActionBarHeight",
            ActionBarHeightHook(self),
        )

    def _hook_avatar_size(self):
        self._safe_hook(
            "AvatarSize",
            "org.telegram.ui.Cells.DialogCell",
            "getAvatarSize",
            AvatarSizeHook(self),
        )

    def _hook_avatar_shape(self):
        self._safe_hook(
            "AvatarShape",
            "org.telegram.ui.Components.AvatarDrawable",
            "isRound",
            RoundAvatarHook(self),
        )

    def _hook_emoji_size(self):
        self._safe_hook(
            "EmojiSize",
            "org.telegram.messenger.Emoji",
            "getEmojiDrawable",
            EmojiSizeHook(self),
        )

    def _hook_sticker_size(self):
        self._safe_hook(
            "StickerSize",
            "org.telegram.ui.Cells.ChatMessageCell",
            "getStickerSize",
            StickerSizeHook(self),
        )

    def _hook_typing_indicator(self):
        self._safe_hook(
            "TypingIndicator",
            "org.telegram.ui.ActionBar.ChatActivityEnterView",
            "setTypingIndicatorVisible",
            TypingIndicatorHook(self),
        )

    def _hook_online_status(self):
        self._safe_hook(
            "OnlineStatus",
            "org.telegram.ui.Cells.ChatActionCell",
            "drawOnlineStatus",
            OnlineStatusHook(self),
        )

    def _hook_reaction_size(self):
        self._safe_hook(
            "ReactionSize",
            "org.telegram.ui.Components.ReactionsContainerLayout",
            "getReactionSize",
            ReactionBubbleSizeHook(self),
        )

    def _hook_forward_header(self):
        self._safe_hook(
            "ForwardHeader",
            "org.telegram.ui.Cells.ChatMessageCell",
            "drawForwardedNameLayout",
            ForwardHeaderHook(self),
        )

    def _hook_message_timestamp(self):
        self._safe_hook(
            "MessageTimestamp",
            "org.telegram.ui.Cells.ChatMessageCell",
            "drawTime",
            MessageTimestampHook(self),
        )

    def _hook_verified_badge(self):
        self._safe_hook(
            "VerifiedBadge",
            "org.telegram.messenger.MessagesController",
            "isVerified",
            VerifiedBadgeHook(self),
        )

    def _hook_premium_badge(self):
        self._safe_hook(
            "PremiumBadge",
            "org.telegram.messenger.MessagesController",
            "isPremiumUser",
            PremiumBadgeHook(self),
        )

    def _hook_scroll_speed(self):
        self._safe_hook(
            "ScrollSpeed",
            "org.telegram.ui.ChatActivity",
            "getScrollFriction",
            ScrollSpeedHook(self),
        )

    # ── вспомогательные ────────────────────────────────────────────────────────

    def _reload_and_notify(self, message: str = "Настройки сохранены"):
        BulletinHelper.show_success(message)

