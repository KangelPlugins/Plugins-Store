__id__ = "material_containers"
__name__ = "Material Containers"
__description__ = """Делает все секции в стиле Material 3.
Styles all sections in the Material 3 style."""
__author__ = "@RnPlugins"
__version__ = "1.0.0"
__icon__ = "RnDev/14"
__app_version__ = ">=12.5.1"
__sdk_version__ = ">=1.4.3.3"

import base64
from base_plugin import BasePlugin
from java.nio import ByteBuffer
from dalvik.system import InMemoryDexClassLoader
from org.telegram.messenger import ApplicationLoader, LocaleController
from ui.settings import Switch, Selector

DEX_B64 = """"""

def get_localized_strings():
    lang = LocaleController.getInstance().getCurrentLocale().getLanguage()
    strings = {
        "ru": {
            "m3_sections_style": "Material Секции",
            "m3_sections_spacing": "Отступы",
            "spacing_normal": "Обычный",
            "spacing_big": "Большой",
            "spacing_huge": "Огромный",
        },
        "en": {
            "m3_sections_style": "Material Sections",
            "m3_sections_spacing": "Spacing",
            "spacing_normal": "Normal",
            "spacing_big": "Big",
            "spacing_huge": "Huge",
        }
    }
    return strings.get(lang, strings["en"])

class MaterialContainersPlugin(BasePlugin):
    def on_plugin_load(self):
        try:
            self.log("Loading Java MaterialContainers module...")
            dex_bytes = base64.b64decode(DEX_B64)
            buffer = ByteBuffer.wrap(dex_bytes)
            parent_cl = ApplicationLoader.applicationContext.getClassLoader()
            self.dex_loader = InMemoryDexClassLoader(buffer, parent_cl)
            self.dex_class = self.dex_loader.loadClass("dev.rooni.materialcontainers.MaterialContainers")
            
            self.dex_class.getMethod("syncSettings").invoke(None)
            
            start_method = self.dex_class.getMethod("start")
            start_method.invoke(None)
            self.log("Java MaterialContainers module loaded and started successfully.")
        except Exception as e:
            self.log(f"Failed to load Java MaterialContainers module: {e}")

    def on_plugin_unload(self):
        try:
            self.log("Unloading Java MaterialContainers module...")
            if hasattr(self, "dex_class") and self.dex_class is not None:
                stop_method = self.dex_class.getMethod("stop")
                stop_method.invoke(None)
                self.log("Java MaterialContainers module stopped successfully.")
            self.dex_class = None
            self.dex_loader = None
        except Exception as e:
            self.log(f"Failed to unload Java MaterialContainers module: {e}")

    def on_setting_changed(self, key, value):
        if key == "m3_sections_style":
            val = value.lower() == "true" if isinstance(value, str) else bool(value)
        elif key == "m3_sections_spacing":
            try:
                val = int(value)
            except Exception:
                val = 0
        else:
            val = value
            
        self.set_setting(key, val)
        if hasattr(self, "dex_class") and self.dex_class is not None:
            try:
                self.dex_class.getMethod("syncSettings").invoke(None)
            except Exception as e:
                self.log(f"Failed to sync settings on change: {e}")

    def create_settings(self):
        s = get_localized_strings()
        
        m3_style_raw = self.get_setting("m3_sections_style", True)
        if isinstance(m3_style_raw, str):
            m3_style = m3_style_raw.lower() == "true"
        else:
            m3_style = bool(m3_style_raw)

        spacing_raw = self.get_setting("m3_sections_spacing", 0)
        try:
            spacing = int(spacing_raw)
        except Exception:
            spacing = 0

        return [
            Switch(
                "m3_sections_style",
                s["m3_sections_style"],
                m3_style,
                icon="menu_photo",
                on_change=lambda v: self.on_setting_changed("m3_sections_style", v)
            ),
            Selector(
                "m3_sections_spacing",
                s["m3_sections_spacing"],
                spacing,
                [s["spacing_normal"], s["spacing_big"], s["spacing_huge"]],
                icon="menu_photo",
                on_change=lambda v: self.on_setting_changed("m3_sections_spacing", v)
            )
        ]
