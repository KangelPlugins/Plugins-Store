            from android.view import View, Gravity
            from android.widget import LinearLayout, TextView, NumberPicker
            from android.util import TypedValue

            fragment = get_last_fragment()
            if not fragment:
                self._sticker_picker_showing = False
                return
            act = fragment.getParentActivity()
            if not act:
                self._sticker_picker_showing = False
                return

            import datetime as dt
            now = dt.datetime.now()
            plugin = self

            builder = BottomSheet.Builder(act)
            builder.setApplyTopPadding(False)
            builder.setApplyBottomPadding(False)

            root = LinearLayout(act)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(8),
                            AndroidUtilities.dp(16), AndroidUtilities.dp(24))

            # Получаем info о текущем стикере для кнопки добавления пака
            sticker_set_id = getattr(plugin, "_pending_sticker_set_id", None)
            sticker_set_name = getattr(plugin, "_pending_sticker_set_name", None)

            title = TextView(act)
            title.setText("🕐 Когда удалить стикер?")
            title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 18)
            title.setTypeface(AndroidUtilities.bold())
            title.setGravity(Gravity.CENTER)
            title.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
            title.setPadding(0, AndroidUtilities.dp(12), 0, AndroidUtilities.dp(8))
            root.addView(title, LayoutHelper.createLinear(-1, -2))

            # Кнопка добавления пака в список отслеживаемых
            pack_key = sticker_set_name or sticker_set_id
            if pack_key:
                existing = plugin._get_sticker_sets()
                already = any(
                    str(k).strip().lower() == str(pack_key).strip().lower()
                    for k in existing.keys()
                )
                if not already:
                    add_pack_btn = TextView(act)
                    add_pack_btn.setText(f"📦 Добавить пак в список")
                    add_pack_btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
                    add_pack_btn.setGravity(Gravity.CENTER)
                    add_pack_btn.setTextColor(Theme.getColor(Theme.key_featuredStickers_buttonText))
                    add_pack_btn.setPadding(0, AndroidUtilities.dp(8), 0, AndroidUtilities.dp(8))
                    try:
                        add_pack_btn.setBackground(Theme.createSimpleSelectorRoundRectDrawable(
                            AndroidUtilities.dp(6),
                            Theme.getColor(Theme.key_featuredStickers_addButton),
                            Theme.getColor(Theme.key_featuredStickers_addButtonPressed)
                        ))
                    except Exception:
                        add_pack_btn.setBackgroundColor(Theme.getColor(Theme.key_featuredStickers_addButton))
                    add_pack_btn.setClickable(True)

                    def on_add_pack(v):
                        cs = plugin._get_sticker_sets()
                        cs[pack_key] = pack_key
                        plugin._save_sticker_sets(cs)
                        add_pack_btn.setText(f"✅ Пак добавлен")
                        add_pack_btn.setClickable(False)
                        BulletinHelper.show_info(f"✅ Пак {pack_key} добавлен")

                    add_pack_btn.setOnClickListener(OnClickListener(on_add_pack))
                    root.addView(add_pack_btn, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 8))

            pickers_row = LinearLayout(act)
            pickers_row.setOrientation(LinearLayout.HORIZONTAL)
            pickers_row.setGravity(Gravity.CENTER)

            day_picker = NumberPicker(act)
            day_picker.setMinValue(0)
            day_picker.setMaxValue(30)
            day_labels = []
            for i in range(31):
                d = now + dt.timedelta(days=i)
                day_labels.append("Сегодня" if i == 0 else ("Завтра" if i == 1 else d.strftime("%d %b")))
            day_picker.setDisplayedValues(day_labels)
            day_picker.setValue(0)
            try: day_picker.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
            except Exception: pass

            hour_picker = NumberPicker(act)
            hour_picker.setMinValue(0); hour_picker.setMaxValue(23); hour_picker.setValue(now.hour)
            try: hour_picker.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
            except Exception: pass

            minute_picker = NumberPicker(act)
            minute_picker.setMinValue(0); minute_picker.setMaxValue(59); minute_picker.setValue(now.minute)
            try: minute_picker.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
            except Exception: pass

            second_picker = NumberPicker(act)
            second_picker.setMinValue(0); second_picker.setMaxValue(59); second_picker.setValue(0)
            try: second_picker.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
            except Exception: pass

            def labeled(picker, lbl):
                col = LinearLayout(act)
                col.setOrientation(LinearLayout.VERTICAL)
                col.setGravity(Gravity.CENTER)
                tv = TextView(act)
                tv.setText(lbl)
                tv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 11)
                tv.setGravity(Gravity.CENTER)
                tv.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText2))
                col.addView(tv, LayoutHelper.createLinear(-2, -2))
                col.addView(picker, LayoutHelper.createLinear(-2, -2))
                return col

            pickers_row.addView(labeled(day_picker, "День"), LayoutHelper.createLinear(-2, -2, 1.0))
            pickers_row.addView(labeled(hour_picker, "Час"),  LayoutHelper.createLinear(-2, -2, 1.0))
            pickers_row.addView(labeled(minute_picker, "Мин"), LayoutHelper.createLinear(-2, -2, 1.0))
            pickers_row.addView(labeled(second_picker, "Сек"), LayoutHelper.createLinear(-2, -2, 1.0))
            root.addView(pickers_row, LayoutHelper.createLinear(-1, -2))

            div = View(act)
            div.setBackgroundColor(Theme.getColor(Theme.key_divider))
            root.addView(div, LayoutHelper.createLinear(-1, 1, 0, 16, 0, 8))

            sheet_ref = [None]

            def send_sticker_with_delete(delete_at):
                if sheet_ref[0]:
                    sheet_ref[0].dismiss()
                plugin._schedule(msg_id, dialog_id, delete_at)

            # Кнопка с дефолтным временем
            default_sec = int(plugin.get_setting("default_delete_sec", "300"))
            default_label = plugin._sec_to_label(default_sec)

            default_btn = TextView(act)
            default_btn.setText(f"⚡ Через {default_label}")
            default_btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
            default_btn.setGravity(Gravity.CENTER)
            default_btn.setTextColor(Theme.getColor(Theme.key_featuredStickers_buttonText))
            default_btn.setPadding(0, AndroidUtilities.dp(14), 0, AndroidUtilities.dp(14))
            try:
                default_btn.setBackground(Theme.createSimpleSelectorRoundRectDrawable(
                    AndroidUtilities.dp(8),
                    Theme.getColor(Theme.key_featuredStickers_addButton),
                    Theme.getColor(Theme.key_featuredStickers_addButtonPressed)
                ))
            except Exception:
                default_btn.setBackgroundColor(Theme.getColor(Theme.key_featuredStickers_addButton))
            default_btn.setClickable(True)
            default_btn.setOnClickListener(OnClickListener(
                lambda v: send_sticker_with_delete(int(time.time()) + default_sec)
            ))
            root.addView(default_btn, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 4))

            # Кнопка Готово (кастомное время)
            ok_btn = TextView(act)
            ok_btn.setText("Выбрать время")
            ok_btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
            ok_btn.setGravity(Gravity.CENTER)
            ok_btn.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
            ok_btn.setPadding(0, AndroidUtilities.dp(12), 0, AndroidUtilities.dp(12))
            ok_btn.setBackground(Theme.createSimpleSelectorRoundRectDrawable(
                AndroidUtilities.dp(8),
                Theme.getColor(Theme.key_dialogBackground),
                Theme.getColor(Theme.key_dialogBackgroundGray)
            ))
            ok_btn.setClickable(True)

            def on_ok(v):
                try:
                    target = now.replace(
                        hour=hour_picker.getValue(),
                        minute=minute_picker.getValue(),
                        second=second_picker.getValue(),
                        microsecond=0
                    ) + dt.timedelta(days=day_picker.getValue())
                    delete_at = int(target.timestamp())
                    if delete_at <= int(time.time()):
                        BulletinHelper.show_error("Выбранное время уже прошло!")
                        return
                    send_sticker_with_delete(delete_at)
                except Exception as e:
                    plugin.log(f"[AutoDelete] sticker ok: {e}")

            ok_btn.setOnClickListener(OnClickListener(on_ok))
            root.addView(ok_btn, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 4))

            cancel_btn = TextView(act)
            cancel_btn.setText("Отмена (отправить без удаления)")
            cancel_btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
            cancel_btn.setGravity(Gravity.CENTER)
            try:
                cancel_btn.setTextColor(Theme.getColor(Theme.key_text_RedRegular))
            except Exception:
                cancel_btn.setTextColor(Theme.getColor(Theme.key_dialogTextRed))
            cancel_btn.setPadding(0, AndroidUtilities.dp(12), 0, AndroidUtilities.dp(12))
            cancel_btn.setBackground(Theme.createSimpleSelectorRoundRectDrawable(
                AndroidUtilities.dp(8),
                Theme.getColor(Theme.key_dialogBackground),
                Theme.getColor(Theme.key_dialogBackgroundGray)
            ))
            cancel_btn.setClickable(True)

            def on_cancel(v):
                if sheet_ref[0]:
                    sheet_ref[0].dismiss()

            cancel_btn.setOnClickListener(OnClickListener(on_cancel))
            root.addView(cancel_btn, LayoutHelper.createLinear(-1, -2))

            builder.setCustomView(root)
            sheet = builder.create()
            sheet_ref[0] = sheet
            sheet.show()

        except Exception as e:
            self.log(f"[AutoDelete] _show_sticker_delete_picker: {e}")
            self._sticker_picker_showing = False

    def _sec_to_label(self, sec: int) -> str:
        if sec < 60:
            return f"{sec} сек"
        if sec < 3600:
            m = sec // 60
            return f"{m} мин"
        if sec < 86400:
            h = sec // 3600
            m = (sec % 3600) // 60
            return f"{h} ч {m} мин" if m else f"{h} ч"
        return f"{sec // 86400} дн"

    def _show_preset_picker(self, setting_key: str, title: str):
        """Пикер для настройки пресета быстрого удаления."""
        try:
            from org.telegram.messenger import AndroidUtilities
            from org.telegram.ui.ActionBar import BottomSheet, Theme
            from org.telegram.ui.Components import LayoutHelper
            from android.view import View, Gravity
            from android.widget import LinearLayout, TextView, NumberPicker
            from android.util import TypedValue
            from ui.bulletin import BulletinHelper

            fragment = get_last_fragment()
            if not fragment:
                return
            act = fragment.getParentActivity()
            if not act:
                return

            options = [
                (0,      "Отключён"),
                (30,     "30 сек"),
                (60,     "1 мин"),
                (120,    "2 мин"),
                (300,    "5 мин"),
                (600,    "10 мин"),
                (900,    "15 мин"),
                (1800,   "30 мин"),
                (3600,   "1 час"),
                (7200,   "2 часа"),
                (10800,  "3 часа"),
                (21600,  "6 часов"),
                (43200,  "12 часов"),
                (86400,  "1 день"),
                (172800, "2 дня"),
                (604800, "1 неделя"),
            ]
            labels  = [o[1] for o in options]
            seconds = [o[0] for o in options]

            current = int(self.get_setting(setting_key, "0"))
            try:
                cur_idx = seconds.index(current)
            except ValueError:
                cur_idx = 0

            builder = BottomSheet.Builder(act)
            builder.setApplyTopPadding(False)
            builder.setApplyBottomPadding(False)

            root = LinearLayout(act)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(8),
                            AndroidUtilities.dp(16), AndroidUtilities.dp(24))

            tv_title = TextView(act)
            tv_title.setText(f"⚡ {title}")
            tv_title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 18)
            tv_title.setTypeface(AndroidUtilities.bold())
            tv_title.setGravity(Gravity.CENTER)
            tv_title.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
            tv_title.setPadding(0, AndroidUtilities.dp(12), 0, AndroidUtilities.dp(16))
            root.addView(tv_title, LayoutHelper.createLinear(-1, -2))

            picker = NumberPicker(act)
            picker.setMinValue(0)
            picker.setMaxValue(len(labels) - 1)
            picker.setDisplayedValues(labels)
            picker.setValue(cur_idx)
            try:
                picker.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
            except Exception:
                pass
            root.addView(picker, LayoutHelper.createLinear(-2, -2, Gravity.CENTER_HORIZONTAL))

            div = View(act)
            div.setBackgroundColor(Theme.getColor(Theme.key_divider))
            root.addView(div, LayoutHelper.createLinear(-1, 1, 0, 16, 0, 8))

            sheet_ref = [None]
            plugin = self

            ok_btn = TextView(act)
            ok_btn.setText("Сохранить")
            ok_btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
            ok_btn.setTypeface(AndroidUtilities.bold())
            ok_btn.setGravity(Gravity.CENTER)
            ok_btn.setTextColor(Theme.getColor(Theme.key_featuredStickers_buttonText))
            ok_btn.setPadding(0, AndroidUtilities.dp(14), 0, AndroidUtilities.dp(14))
            try:
                ok_btn.setBackground(Theme.createSimpleSelectorRoundRectDrawable(
                    AndroidUtilities.dp(8),
                    Theme.getColor(Theme.key_featuredStickers_addButton),
                    Theme.getColor(Theme.key_featuredStickers_addButtonPressed)
                ))
            except Exception:
                ok_btn.setBackgroundColor(Theme.getColor(Theme.key_featuredStickers_addButton))
            ok_btn.setClickable(True)

            def on_save(v):
                idx = picker.getValue()
                secs = seconds[idx]
                plugin.set_setting(setting_key, str(secs), reload_settings=False)
                if sheet_ref[0]:
                    sheet_ref[0].dismiss()
                label = labels[idx]
                BulletinHelper.show_info(f"✅ {title}: {label}")

            ok_btn.setOnClickListener(OnClickListener(on_save))
            root.addView(ok_btn, LayoutHelper.createLinear(-1, -2))

            builder.setCustomView(root)
            sheet = builder.create()
            sheet_ref[0] = sheet
            sheet.show()

        except Exception as e:
            self.log(f"[AutoDelete] _show_preset_picker: {e}")

    def _show_default_time_picker(self):
        """Пикер для выбора дефолтного времени удаления стикеров."""
        try:
            from org.telegram.messenger import AndroidUtilities
            from org.telegram.ui.ActionBar import BottomSheet, Theme
            from org.telegram.ui.Components import LayoutHelper
            from android.view import View, Gravity
            from android.widget import LinearLayout, TextView, NumberPicker
            from android.util import TypedValue

            fragment = get_last_fragment()
            if not fragment:
                return
            act = fragment.getParentActivity()
            if not act:
                return

            options = [
                (10, "10 сек"), (30, "30 сек"), (60, "1 мин"), (120, "2 мин"),
                (300, "5 мин"), (600, "10 мин"), (900, "15 мин"), (1800, "30 мин"),
                (3600, "1 ч"), (7200, "2 ч"), (21600, "6 ч"), (86400, "24 ч"),
            ]
            labels  = [o[1] for o in options]
            seconds = [o[0] for o in options]
            current = int(self.get_setting("default_delete_sec", "300"))
            try:
                idx = seconds.index(current)
            except ValueError:
                idx = 4

            builder = BottomSheet.Builder(act)
            builder.setApplyTopPadding(False)
            builder.setApplyBottomPadding(False)

            root = LinearLayout(act)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(8),
                            AndroidUtilities.dp(16), AndroidUtilities.dp(24))

            title = TextView(act)
            title.setText("⚡ Время удаления по умолчанию")
            title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 17)
            title.setTypeface(AndroidUtilities.bold())
            title.setGravity(Gravity.CENTER)
            title.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
            title.setPadding(0, AndroidUtilities.dp(12), 0, AndroidUtilities.dp(16))
            root.addView(title, LayoutHelper.createLinear(-1, -2))

            picker = NumberPicker(act)
            picker.setMinValue(0)
            picker.setMaxValue(len(labels) - 1)
            picker.setDisplayedValues(labels)
            picker.setValue(idx)
            picker.setWrapSelectorWheel(False)
            try:
                picker.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
            except Exception:
                pass
            root.addView(picker, LayoutHelper.createLinear(-1, -2, Gravity.CENTER, 32, 0, 32, 0))

            div = View(act)
            div.setBackgroundColor(Theme.getColor(Theme.key_divider))
            root.addView(div, LayoutHelper.createLinear(-1, 1, 0, 16, 0, 8))

            sheet_ref = [None]
            plugin = self

            ok_btn = TextView(act)
            ok_btn.setText("Готово")
            ok_btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
            ok_btn.setTypeface(AndroidUtilities.bold())
            ok_btn.setGravity(Gravity.CENTER)
            ok_btn.setTextColor(Theme.getColor(Theme.key_featuredStickers_buttonText))
            ok_btn.setPadding(0, AndroidUtilities.dp(14), 0, AndroidUtilities.dp(14))
            try:
                ok_btn.setBackground(Theme.createSimpleSelectorRoundRectDrawable(
                    AndroidUtilities.dp(8),
                    Theme.getColor(Theme.key_featuredStickers_addButton),
                    Theme.getColor(Theme.key_featuredStickers_addButtonPressed)
                ))
            except Exception:
                ok_btn.setBackgroundColor(Theme.getColor(Theme.key_featuredStickers_addButton))
            ok_btn.setClickable(True)

            def on_ok(v):
                sec = seconds[picker.getValue()]
                plugin.set_setting("default_delete_sec", str(sec), reload_settings=False)
                BulletinHelper.show_info(f"✅ По умолчанию: {labels[picker.getValue()]}")
                if sheet_ref[0]:
                    sheet_ref[0].dismiss()

            ok_btn.setOnClickListener(OnClickListener(on_ok))
            root.addView(ok_btn, LayoutHelper.createLinear(-1, -2))

            builder.setCustomView(root)
            sheet = builder.create()
            sheet_ref[0] = sheet
            sheet.show()

        except Exception as e:
            self.log(f"[AutoDelete] _show_default_time_picker: {e}")

    def _show_sticker_sets_manager(self):
        """Управление паками стикеров."""
        try:
            from org.telegram.messenger import AndroidUtilities
            from org.telegram.ui.ActionBar import BottomSheet, Theme
            from org.telegram.ui.Components import LayoutHelper
            from android.view import View, Gravity
            from android.widget import LinearLayout, TextView, EditText, ScrollView
            from android.util import TypedValue
            from android.text import InputType

            fragment = get_last_fragment()
            if not fragment:
                return
            act = fragment.getParentActivity()
            if not act:
                return

            sets = self._get_sticker_sets()
            plugin = self

            builder = BottomSheet.Builder(act)
            builder.setApplyTopPadding(False)
            builder.setApplyBottomPadding(False)

            root = LinearLayout(act)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(8),
                            AndroidUtilities.dp(16), AndroidUtilities.dp(24))

            title = TextView(act)
            title.setText("📦 Паки стикеров")
            title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 18)
            title.setTypeface(AndroidUtilities.bold())
            title.setGravity(Gravity.CENTER)
            title.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
            title.setPadding(0, AndroidUtilities.dp(12), 0, AndroidUtilities.dp(8))
            root.addView(title, LayoutHelper.createLinear(-1, -2))

            hint = TextView(act)
            hint.setText("Введи ID пака (число из ссылки t.me/addstickers/...)")
            hint.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
            hint.setGravity(Gravity.CENTER)
            hint.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText2))
            hint.setPadding(0, 0, 0, AndroidUtilities.dp(8))
            root.addView(hint, LayoutHelper.createLinear(-1, -2))

            input_row = LinearLayout(act)
            input_row.setOrientation(LinearLayout.HORIZONTAL)
            input_row.setGravity(Gravity.CENTER_VERTICAL)

            et = EditText(act)
            et.setHint("ID или ссылка пака")
            et.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
            et.setInputType(InputType.TYPE_CLASS_TEXT)
            et.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
            et.setHintTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText2))
            input_row.addView(et, LayoutHelper.createLinear(0, -2, 1.0))

            add_btn = TextView(act)
            add_btn.setText("Добавить")
            add_btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
            add_btn.setTextColor(Theme.getColor(Theme.key_featuredStickers_buttonText))
            add_btn.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(8),
                               AndroidUtilities.dp(12), AndroidUtilities.dp(8))
            try:
                add_btn.setBackground(Theme.createSimpleSelectorRoundRectDrawable(
                    AndroidUtilities.dp(6),
                    Theme.getColor(Theme.key_featuredStickers_addButton),
                    Theme.getColor(Theme.key_featuredStickers_addButtonPressed)
                ))
            except Exception:
                add_btn.setBackgroundColor(Theme.getColor(Theme.key_featuredStickers_addButton))
            add_btn.setClickable(True)

            list_container = [root]  # для обновления списка

            def refresh_list(container):
                # Удаляем старые элементы после кнопки добавления (index > 4)
                while container.getChildCount() > 4:
                    container.removeViewAt(4)
                current_sets = plugin._get_sticker_sets()
                if not current_sets:
                    empty = TextView(act)
                    empty.setText("Нет добавленных паков")
                    empty.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
                    empty.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText2))
                    empty.setGravity(Gravity.CENTER)
                    empty.setPadding(0, AndroidUtilities.dp(8), 0, 0)
                    container.addView(empty, LayoutHelper.createLinear(-1, -2))
                else:
                    for sid, stitle in list(current_sets.items()):
                        row = LinearLayout(act)
                        row.setOrientation(LinearLayout.HORIZONTAL)
                        row.setGravity(Gravity.CENTER_VERTICAL)
                        row.setPadding(0, AndroidUtilities.dp(6), 0, AndroidUtilities.dp(6))

                        tv = TextView(act)
                        tv.setText(f"ID: {sid}")
                        tv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
                        tv.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
                        row.addView(tv, LayoutHelper.createLinear(0, -2, 1.0))

                        del_btn = TextView(act)
                        del_btn.setText("Удалить")
                        del_btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
                        try:
                            del_btn.setTextColor(Theme.getColor(Theme.key_text_RedRegular))
                        except Exception:
                            del_btn.setTextColor(Theme.getColor(Theme.key_dialogTextRed))
                        del_btn.setPadding(AndroidUtilities.dp(8), AndroidUtilities.dp(4),
                                           AndroidUtilities.dp(8), AndroidUtilities.dp(4))
                        del_btn.setClickable(True)

                        def make_delete(s):
                            def on_del(v):
                                cs = plugin._get_sticker_sets()
                                cs.pop(s, None)
                                plugin._save_sticker_sets(cs)
                                refresh_list(container)
                            return on_del

                        del_btn.setOnClickListener(OnClickListener(make_delete(sid)))
                        row.addView(del_btn, LayoutHelper.createLinear(-2, -2))
                        container.addView(row, LayoutHelper.createLinear(-1, -2))

            def on_add(v):
                raw = et.getText().toString().strip()
                if not raw:
                    return
                # Извлекаем short_name из ссылки (t.me/addstickers/PackName)
                # или числовой ID — берём как есть
                if "/" in raw:
                    set_key = raw.split("/")[-1]
                else:
                    set_key = raw
                cs = plugin._get_sticker_sets()
                cs[set_key] = set_key
                plugin._save_sticker_sets(cs)
                et.setText("")
                refresh_list(root)
                BulletinHelper.show_info(f"✅ Пак добавлен: {set_key}")

            add_btn.setOnClickListener(OnClickListener(on_add))
            input_row.addView(add_btn, LayoutHelper.createLinear(-2, -2, 0, 0, 0, 0, 8))
            root.addView(input_row, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 8))

            div = View(act)
            div.setBackgroundColor(Theme.getColor(Theme.key_divider))
            root.addView(div, LayoutHelper.createLinear(-1, 1, 0, 0, 0, 8))

            refresh_list(root)

            builder.setCustomView(root)
            builder.create().show()

        except Exception as e:
            self.log(f"[AutoDelete] _show_sticker_sets_manager: {e}")

    def _show_sticker_ids_manager(self):
        """Управление отдельными стикерами по ID."""
        try:
            from org.telegram.messenger import AndroidUtilities
            from org.telegram.ui.ActionBar import BottomSheet, Theme
            from org.telegram.ui.Components import LayoutHelper
            from android.view import View, Gravity
            from android.widget import LinearLayout, TextView, EditText
            from android.util import TypedValue
            from android.text import InputType

            fragment = get_last_fragment()
            if not fragment:
                return
            act = fragment.getParentActivity()
            if not act:
                return

            plugin = self

            builder = BottomSheet.Builder(act)
            builder.setApplyTopPadding(False)
            builder.setApplyBottomPadding(False)

            root = LinearLayout(act)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(8),
                            AndroidUtilities.dp(16), AndroidUtilities.dp(24))

            title = TextView(act)
            title.setText("🎯 Отдельные стикеры")
            title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 18)
            title.setTypeface(AndroidUtilities.bold())
            title.setGravity(Gravity.CENTER)
            title.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
            title.setPadding(0, AndroidUtilities.dp(12), 0, AndroidUtilities.dp(8))
            root.addView(title, LayoutHelper.createLinear(-1, -2))

            hint = TextView(act)
            hint.setText("Отправь стикер чтобы узнать его ID, или введи вручную")
            hint.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
            hint.setGravity(Gravity.CENTER)
            hint.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText2))
            hint.setPadding(0, 0, 0, AndroidUtilities.dp(8))
            root.addView(hint, LayoutHelper.createLinear(-1, -2))

            input_row = LinearLayout(act)
            input_row.setOrientation(LinearLayout.HORIZONTAL)
            input_row.setGravity(Gravity.CENTER_VERTICAL)

            et = EditText(act)
            et.setHint("document_id стикера")
            et.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
            et.setInputType(InputType.TYPE_CLASS_NUMBER)
            et.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
            et.setHintTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText2))
            input_row.addView(et, LayoutHelper.createLinear(0, -2, 1.0))

            add_btn = TextView(act)
            add_btn.setText("Добавить")
            add_btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
            add_btn.setTextColor(Theme.getColor(Theme.key_featuredStickers_buttonText))
            add_btn.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(8),
                               AndroidUtilities.dp(12), AndroidUtilities.dp(8))
            try:
                add_btn.setBackground(Theme.createSimpleSelectorRoundRectDrawable(
                    AndroidUtilities.dp(6),
                    Theme.getColor(Theme.key_featuredStickers_addButton),
                    Theme.getColor(Theme.key_featuredStickers_addButtonPressed)
                ))
            except Exception:
                add_btn.setBackgroundColor(Theme.getColor(Theme.key_featuredStickers_addButton))
            add_btn.setClickable(True)

            def refresh_ids(container):
                while container.getChildCount() > 4:
                    container.removeViewAt(4)
                ids = plugin._get_sticker_ids()
                if not ids:
                    empty = TextView(act)
                    empty.setText("Нет добавленных стикеров")
                    empty.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
                    empty.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText2))
                    empty.setGravity(Gravity.CENTER)
                    empty.setPadding(0, AndroidUtilities.dp(8), 0, 0)
                    container.addView(empty, LayoutHelper.createLinear(-1, -2))
                else:
                    for sid in ids:
                        row = LinearLayout(act)
                        row.setOrientation(LinearLayout.HORIZONTAL)
                        row.setGravity(Gravity.CENTER_VERTICAL)
                        row.setPadding(0, AndroidUtilities.dp(6), 0, AndroidUtilities.dp(6))

                        tv = TextView(act)
                        tv.setText(f"ID: {sid}")
                        tv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
                        tv.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
                        row.addView(tv, LayoutHelper.createLinear(0, -2, 1.0))

                        del_btn = TextView(act)
                        del_btn.setText("Удалить")
                        del_btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
                        try:
                            del_btn.setTextColor(Theme.getColor(Theme.key_text_RedRegular))
                        except Exception:
                            del_btn.setTextColor(Theme.getColor(Theme.key_dialogTextRed))
                        del_btn.setPadding(AndroidUtilities.dp(8), AndroidUtilities.dp(4),
                                           AndroidUtilities.dp(8), AndroidUtilities.dp(4))
                        del_btn.setClickable(True)

                        def make_del(s):
                            def on_del(v):
                                ci = plugin._get_sticker_ids()
                                if s in ci:
                                    ci.remove(s)
                                plugin._save_sticker_ids(ci)
                                refresh_ids(container)
                            return on_del

                        del_btn.setOnClickListener(OnClickListener(make_del(sid)))
                        row.addView(del_btn, LayoutHelper.createLinear(-2, -2))
                        container.addView(row, LayoutHelper.createLinear(-1, -2))

            def on_add(v):
                raw = et.getText().toString().strip()
                if not raw:
                    return
                ci = plugin._get_sticker_ids()
                if raw not in ci:
                    ci.append(raw)
                    plugin._save_sticker_ids(ci)
                et.setText("")
                refresh_ids(root)
                BulletinHelper.show_info(f"✅ Стикер добавлен: {raw}")

            add_btn.setOnClickListener(OnClickListener(on_add))
            input_row.addView(add_btn, LayoutHelper.createLinear(-2, -2, 0, 0, 0, 0, 8))
            root.addView(input_row, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 8))

            div = View(act)
            div.setBackgroundColor(Theme.getColor(Theme.key_divider))
            root.addView(div, LayoutHelper.createLinear(-1, 1, 0, 0, 0, 8))

            refresh_ids(root)

            builder.setCustomView(root)
            builder.create().show()

        except Exception as e:
            self.log(f"[AutoDelete] _show_sticker_ids_manager: {e}")

    def create_settings(self):
        return [
            Header(text="Переменная {time}"),
            Text(
                text="Частота обновления",
                subtext="Нажми чтобы выбрать кулдаун",
                on_click=lambda v: self._show_cooldown_picker(),
            ),
            Text(
                text="Округление времени",
                subtext="Нажми чтобы выбрать",
                on_click=lambda v: self._show_rounding_picker(),
            ),
            Input(
                key="time_format",
                text="Шаблон формата",
                subtext="Используй: hh-часы, mm-минуты, ss-секунды \nПусто = авто. \nПримеры: \nhh:mm:ss, h ч mm мин, mm мин ss сек",
                default="",
            ),
            Divider(),
            Header(text="Переменная {date}"),
            Input(
                key="date_format",
                text="Шаблон {date}",
                subtext="DD=день MM=мес MMM=мес кратко MMMM=мес полно YY/YYYY=год HH=час mm=мин ss=сек. Пример: DD.MM.YYYY в HH:mm или D MMMM в HH:mm",
                default="",
            ),
            Divider(),
            Header(text="Быстрое удаление"),
            Text(
                text="Пресет 1",
                subtext=f"⚡ {self._sec_to_label(int(self.get_setting('quick_preset_1', '300')))} — нажми чтобы изменить",
                on_click=lambda v: run_on_ui_thread(lambda: self._show_preset_picker("quick_preset_1", "Пресет 1")),
            ),
            Text(
                text="Пресет 2",
                subtext=(f"⚡ {self._sec_to_label(int(self.get_setting('quick_preset_2', '0')))}" if int(self.get_setting('quick_preset_2', '0')) > 0 else "Отключён") + " — нажми чтобы изменить",
                on_click=lambda v: run_on_ui_thread(lambda: self._show_preset_picker("quick_preset_2", "Пресет 2")),
            ),
            Text(
                text="Пресет 3",
                subtext=(f"⚡ {self._sec_to_label(int(self.get_setting('quick_preset_3', '0')))}" if int(self.get_setting('quick_preset_3', '0')) > 0 else "Отключён") + " — нажми чтобы изменить",
                on_click=lambda v: run_on_ui_thread(lambda: self._show_preset_picker("quick_preset_3", "Пресет 3")),
            ),
            Divider(),
            Header(text="Авто-удаление стикеров"),
            Text(
                text="Время по умолчанию",
                subtext="Нажми чтобы выбрать дефолтное время удаления",
                on_click=lambda v: run_on_ui_thread(self._show_default_time_picker),
            ),
            Text(
                text="Управление паками",
                subtext="Нажми чтобы добавить/удалить паки стикеров",
                on_click=lambda v: run_on_ui_thread(self._show_sticker_sets_manager),
            ),
            Text(
                text="Управление стикерами",
                subtext="Нажми чтобы добавить отдельные стикеры по ID",
                on_click=lambda v: run_on_ui_thread(self._show_sticker_ids_manager),
            ),
        ]

    def _show_cooldown_picker(self):
        try:
            from org.telegram.messenger import AndroidUtilities
            from org.telegram.ui.ActionBar import BottomSheet, Theme
            from org.telegram.ui.Components import LayoutHelper
            from android.view import Gravity
            from android.widget import LinearLayout, TextView, NumberPicker
            from android.util import TypedValue

            fragment = get_last_fragment()
            if not fragment:
                return
            act = fragment.getParentActivity()
            if not act:
                return

            # Все варианты кулдауна
            options = [
                (5,      "5 сек"),
                (10,     "10 сек"),
                (15,     "15 сек"),
                (30,     "30 сек"),
                (60,     "1 мин"),
                (120,    "2 мин"),
                (300,    "5 мин"),
                (600,    "10 мин"),
                (900,    "15 мин"),
                (1800,   "30 мин"),
                (3600,   "1 час"),
                (7200,   "2 часа"),
                (10800,  "3 часа"),
                (21600,  "6 часов"),
                (43200,  "12 часов"),
                (86400,  "24 часа"),
            ]
            labels   = [o[1] for o in options]
            seconds  = [o[0] for o in options]

            current  = int(self.get_setting("edit_cooldown_secs", 60))
            try:
                cur_idx = seconds.index(current)
            except ValueError:
                cur_idx = 4  # 1 мин по умолчанию

            builder = BottomSheet.Builder(act)
            builder.setApplyTopPadding(False)
            builder.setApplyBottomPadding(False)

            root = LinearLayout(act)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(8),
                            AndroidUtilities.dp(16), AndroidUtilities.dp(24))

            title = TextView(act)
            title.setText("⏱ Частота обновления {time}")
            title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 18)
            title.setTypeface(AndroidUtilities.bold())
            title.setGravity(Gravity.CENTER)
            title.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
            title.setPadding(0, AndroidUtilities.dp(12), 0, AndroidUtilities.dp(16))
            root.addView(title, LayoutHelper.createLinear(-1, -2))

            picker = NumberPicker(act)
            picker.setMinValue(0)
            picker.setMaxValue(len(labels) - 1)
            picker.setDisplayedValues(labels)
            picker.setValue(cur_idx)
            picker.setWrapSelectorWheel(False)
            try:
                picker.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
            except Exception:
                pass
            root.addView(picker, LayoutHelper.createLinear(-2, -2, Gravity.CENTER))

            from android.view import View
            div = View(act)
            div.setBackgroundColor(Theme.getColor(Theme.key_divider))
            root.addView(div, LayoutHelper.createLinear(-1, 1, 0, 16, 0, 8))

            sheet_ref = [None]

            ok_btn = TextView(act)
            ok_btn.setText("Сохранить")
            ok_btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
            ok_btn.setTypeface(AndroidUtilities.bold())
            ok_btn.setGravity(Gravity.CENTER)
            ok_btn.setTextColor(Theme.getColor(Theme.key_featuredStickers_buttonText))
            ok_btn.setPadding(0, AndroidUtilities.dp(14), 0, AndroidUtilities.dp(14))
            try:
                ok_btn.setBackground(Theme.createSimpleSelectorRoundRectDrawable(
                    AndroidUtilities.dp(8),
                    Theme.getColor(Theme.key_featuredStickers_addButton),
                    Theme.getColor(Theme.key_featuredStickers_addButtonPressed)
                ))
            except Exception:
                ok_btn.setBackgroundColor(Theme.getColor(Theme.key_featuredStickers_addButton))
            ok_btn.setClickable(True)

            from android_utils import OnClickListener
            def on_save(v):
                idx = picker.getValue()
                secs = seconds[idx]
                self.set_setting("edit_cooldown_secs", secs, reload_settings=False)
                if sheet_ref[0]:
                    sheet_ref[0].dismiss()
                BulletinHelper.show_info(f"✅ Кулдаун: {labels[idx]}")

            ok_btn.setOnClickListener(OnClickListener(on_save))
            root.addView(ok_btn, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 4))

            builder.setCustomView(root)
            sheet = builder.create()
            sheet_ref[0] = sheet
            sheet.show()

        except Exception as e:
            self.log(f"[AutoDelete] _show_cooldown_picker: {e}")
