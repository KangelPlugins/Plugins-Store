__id__ = "meow_reply"
__name__ = "Meow Reply"
__version__ = "1.6.0 Premium Fix"
__author__ = "@oodze & @dauntupoy"
__min_version__ = "11.12.0"
__description__ = """🌟 MeowReply — Продвинутый автоответчик с системой пресетов. Есть антиспам защита 

🌍 ОБЩИЙ РЕЖИМ (по умолчанию):
• .auto on/off — Включить/выключить автоответчик в чате.
• .auto add [фраза] - [ответ] — Добавить триггер.
• .auto del [фраза] — Удалить триггер.
• .auto list — Список всех триггеров.

👤 ЛИЧНЫЕ ПРЕСЕТЫ:
• .auto onpm [имя] — Включить личный пресет.
• .auto offpm — Выключить личный режим.
• .auto offpm del — Удалить пресет.
• .auto onpmclone [стар] [нов] — Создать копию.

📦 ПЕРЕНОС ТРИГГЕРОВ:
• .auto ptog / ptog! — Личный -> Общий.
• .auto gtop / gtop! — Общий -> Личный.

⚙️ ДОПОЛНИТЕЛЬНО:
• ✨ Идеальная поддержка настоящих и фейковых Premium-эмодзи!
• Режимы ответа: Обычный, Reply, Цитата.
• .auto clear — Полная очистка.
• Поддержка | для нескольких триггеров.
"""

import json
import re
import threading
import time
from base_plugin import BasePlugin, HookResult, HookStrategy
from hook_utils import find_class
from android_utils import run_on_ui_thread, log
from ui.settings import Header, Divider, Switch, Input
from java import jclass, jlong, cast
from java.util import ArrayList

try:
    TLRPC = find_class("org.telegram.tgnet.TLRPC")
    TL_messageEntityCustomEmoji = find_class("org.telegram.tgnet.TLRPC$TL_messageEntityCustomEmoji")
    MessagesController = find_class("org.telegram.messenger.MessagesController")
    ConnectionsManager = find_class("org.telegram.tgnet.ConnectionsManager")
    UserConfig = find_class("org.telegram.messenger.UserConfig")
    NotificationCenter = find_class("org.telegram.messenger.NotificationCenter")
    Utilities = find_class("org.telegram.messenger.Utilities")
except:
    pass

def get_utf16_len(s):
    return len(s.encode('utf-16-le')) // 2

def get_utf16_offset(full_text, sub_text):
    idx = full_text.rfind(sub_text)
    if idx == -1: return -1
    return len(full_text[:idx].encode('utf-16-le')) // 2

class TelegramNotificationObserver:
    def __init__(self, plugin_instance):
        self.plugin = plugin_instance

    def before_hooked_method(self, parameter):
        try:
            notification_id = int(str(parameter.args[0]))
            if notification_id == self.plugin.id_new_msg:
                arguments = parameter.args[1]
                if arguments and len(arguments) >= 2:
                    raw_messages = arguments[1]
                    if raw_messages:
                        messages_list = cast(ArrayList, raw_messages)
                        size = messages_list.size()
                        for index in range(size):
                            message_item = messages_list.get(index)
                            self.plugin.analyze_message(message_item)
        except: pass

class MeowReply(BasePlugin):
    strings = {
        "enabled": "✅ MeowReply включен (Общий режим)",
        "disabled": "🚫 MeowReply выключен",
        "pm_enabled": "👤 Включен ЛИЧНЫЙ режим \"{}\" для этого чата.",
        "pm_disabled": "🌍 Личный режим выключен. Пресет \"{}\" закреплен за чатом.",
        "pm_busy": "⚠️ Название \"{}\" уже занято другим чатом!",
        "pm_locked": "⚠️ За чатом уже закреплен пресет \"{}\". Удалите его: .auto offpm del",
        "pm_none": "⚠️ Укажите название пресета.",
        "pm_deleted": "🗑 Пресет \"{}\" удален.",
        "pm_cloned": "🧬 Триггеры скопированы из \"{}\" в \"{}\"!",
        "pm_clone_err": "⚠️ Пресет \"{}\" не найден.",
        "pm_only_cmd": "⚠️ Команда только для Личного режима!",
        "moved_to_global": "📤 Слияние: Личный пресет \"{}\" -> ОБЩИЙ список.",
        "moved_to_personal": "📥 Слияние: ОБЩИЙ список -> Личный пресет \"{}\".",
        "replaced_to_global": "📤 ЗАМЕНА: Личный пресет \"{}\" стал ОБЩИМ.",
        "replaced_to_personal": "📥 ЗАМЕНА: ОБЩИЙ список стал пресетом \"{}\".",
        "removed": "🗑 Триггер \"{}\" удален ({})",
        "cleared": "🗑 Все триггеры очищены ({})",
        "not_found": "⚠️ Триггер не найден в {} списке",
        "no_args": "⚠️ Ошибка синтаксиса.\n.auto add фраза - ответ",
        "empty_list": "⚠️ Список пуст ({})",
        "stats": "⚙️ MeowReply v{}\n\n📊 Активных чатов: {}\n🌍 Общих триггеров: {}\n👤 Личных пресетов: {}"
    }

    def __init__(self):
        super().__init__()
        self.triggers = {} 
        self.active_chats = [] 
        self.personal_triggers = {} 
        self.chat_to_preset = {}
        self.preset_owners = {}
        self.active_pm_sessions = []
        self.config_prefix = ".auto"
        self.id_new_msg = 1 
        self.ignore_prefixes = [".auto", "✅", "🚫", "⚠️", "📋", "🗑", "⚙️", "👤", "🌍", "🧬"]
        self.flood_control = {}

    def create_settings(self):
        return [
            Header("Логика"),
            Switch("whole_words", "Только целые слова", True),
            Switch("react_own", "Отвечать на свои сообщения", False),
            Divider(),
            Header("Отправка"),
            Input("reply_mode", "Режим ответа (0-2)", "1", "0 = Обычный, 1 = Reply (Ответ), 2 = Цитата"),
            Divider("v" + __version__)
        ]

    def on_plugin_load(self):
        self.load_settings()
        self.add_on_send_message_hook(priority=60)

        try:
            if hasattr(NotificationCenter, "didReceiveNewMessages"):
                self.id_new_msg = getattr(NotificationCenter, "didReceiveNewMessages")
            
            target_method = None
            for method in NotificationCenter.getClass().getDeclaredMethods():
                if method.getName() == "postNotificationName" and len(method.getParameterTypes()) == 2:
                    target_method = method
                    break
            
            if target_method:
                target_method.setAccessible(True)
                self.hook_method(target_method, TelegramNotificationObserver(self))
        except: pass

    def load_settings(self):
        try:
            self.triggers = json.loads(self.get_setting("triggers", "{}"))
            self.active_chats = json.loads(self.get_setting("active_chats", "[]"))
            self.personal_triggers = json.loads(self.get_setting("personal_triggers", "{}"))
            self.chat_to_preset = json.loads(self.get_setting("chat_to_preset", "{}"))
            self.preset_owners = json.loads(self.get_setting("preset_owners", "{}"))
            self.active_pm_sessions = json.loads(self.get_setting("active_pm_sessions", "[]"))
        except:
            self.triggers = {}; self.active_chats = []; self.personal_triggers = {}
            self.chat_to_preset = {}; self.preset_owners = {}; self.active_pm_sessions = []

    def save_settings(self):
        self.set_setting("triggers", json.dumps(self.triggers))
        self.set_setting("active_chats", json.dumps(self.active_chats))
        self.set_setting("personal_triggers", json.dumps(self.personal_triggers))
        self.set_setting("chat_to_preset", json.dumps(self.chat_to_preset))
        self.set_setting("preset_owners", json.dumps(self.preset_owners))
        self.set_setting("active_pm_sessions", json.dumps(self.active_pm_sessions))

    def on_send_message_hook(self, account_id, params):
        try:
            input_text = getattr(params, "message", "")
            if not isinstance(input_text, str) or not input_text.startswith(self.config_prefix):
                return HookResult()

            parts = input_text.split()
            chat_id = params.peer if hasattr(params, "peer") else 0
            chat_key = str(chat_id)
            
            reply_to_id = 0
            if hasattr(params, "reply_to_msg_id"): reply_to_id = int(params.reply_to_msg_id)
            elif hasattr(params, "replyToMsgId"): reply_to_id = int(params.replyToMsgId)
            
            if len(parts) < 2:
                self.send_msg(chat_id, self.strings["stats"].format(__version__, len(self.active_chats), len(self.triggers), len(self.personal_triggers)), reply_to_id=reply_to_id)
                return HookResult(strategy=HookStrategy.CANCEL)

            action = parts[1].lower()

            if action == "on":
                if chat_id not in self.active_chats:
                    self.active_chats.append(chat_id)
                    self.save_settings()
                self.send_msg(chat_id, self.strings["enabled"], reply_to_id=reply_to_id)

            elif action == "off":
                if chat_id in self.active_chats:
                    self.active_chats.remove(chat_id)
                    self.save_settings()
                self.send_msg(chat_id, self.strings["disabled"], reply_to_id=reply_to_id)

            elif action == "onpm":
                existing_p = self.chat_to_preset.get(chat_key)
                if len(parts) < 3:
                    if not existing_p:
                        self.send_msg(chat_id, self.strings["pm_none"], reply_to_id=reply_to_id)
                        return HookResult(strategy=HookStrategy.CANCEL)
                    preset_name = existing_p
                else:
                    preset_name = parts[2]
                    if existing_p and existing_p != preset_name:
                        self.send_msg(chat_id, self.strings["pm_locked"].format(existing_p), reply_to_id=reply_to_id)
                        return HookResult(strategy=HookStrategy.CANCEL)
                
                owner = self.preset_owners.get(preset_name)
                if owner and owner != chat_key:
                    self.send_msg(chat_id, self.strings["pm_busy"].format(preset_name), reply_to_id=reply_to_id)
                    return HookResult(strategy=HookStrategy.CANCEL)

                if chat_id not in self.active_chats: self.active_chats.append(chat_id)
                if chat_key not in self.active_pm_sessions: self.active_pm_sessions.append(chat_key)
                
                self.chat_to_preset[chat_key] = preset_name
                self.preset_owners[preset_name] = chat_key
                if preset_name not in self.personal_triggers: self.personal_triggers[preset_name] = {}
                self.save_settings()
                self.send_msg(chat_id, self.strings["pm_enabled"].format(preset_name), reply_to_id=reply_to_id)

            elif action == "offpm":
                target_p = self.chat_to_preset.get(chat_key)
                if chat_key in self.active_pm_sessions: self.active_pm_sessions.remove(chat_key)
                if len(parts) >= 3 and parts[2].lower() == "del" and target_p:
                    self.personal_triggers.pop(target_p, None)
                    self.preset_owners.pop(target_p, None)
                    self.chat_to_preset.pop(chat_key, None)
                    self.save_settings()
                    self.send_msg(chat_id, self.strings["pm_deleted"].format(target_p), reply_to_id=reply_to_id)
                else:
                    self.save_settings()
                    self.send_msg(chat_id, self.strings["pm_disabled"].format(target_p if target_p else "?"), reply_to_id=reply_to_id)

            elif action in ["ptog", "ptog!", "gtop", "gtop!"]:
                preset_name = self.chat_to_preset.get(chat_key)
                if chat_key not in self.active_pm_sessions:
                    self.send_msg(chat_id, self.strings["pm_only_cmd"], reply_to_id=reply_to_id)
                else:
                    if action == "ptog":
                        self.triggers.update(self.personal_triggers.get(preset_name, {}))
                        self.send_msg(chat_id, self.strings["moved_to_global"].format(preset_name), reply_to_id=reply_to_id)
                    elif action == "ptog!":
                        self.triggers = json.loads(json.dumps(self.personal_triggers.get(preset_name, {})))
                        self.send_msg(chat_id, self.strings["replaced_to_global"].format(preset_name), reply_to_id=reply_to_id)
                    elif action == "gtop":
                        self.personal_triggers[preset_name].update(self.triggers)
                        self.send_msg(chat_id, self.strings["moved_to_personal"].format(preset_name), reply_to_id=reply_to_id)
                    elif action == "gtop!":
                        self.personal_triggers[preset_name] = json.loads(json.dumps(self.triggers))
                        self.send_msg(chat_id, self.strings["replaced_to_personal"].format(preset_name), reply_to_id=reply_to_id)
                    self.save_settings()

            elif action == "onpmclone":
                if len(parts) < 4:
                    self.send_msg(chat_id, self.strings["no_args"], reply_to_id=reply_to_id)
                    return HookResult(strategy=HookStrategy.CANCEL)
                old_n, new_n = parts[2], parts[3]
                if old_n in self.personal_triggers:
                    owner = self.preset_owners.get(new_n)
                    if owner and owner != chat_key:
                        self.send_msg(chat_id, self.strings["pm_busy"].format(new_n), reply_to_id=reply_to_id)
                        return HookResult(strategy=HookStrategy.CANCEL)
                    self.personal_triggers[new_n] = json.loads(json.dumps(self.personal_triggers[old_n]))
                    self.chat_to_preset[chat_key] = new_n
                    self.preset_owners[new_n] = chat_key
                    if chat_id not in self.active_chats: self.active_chats.append(chat_id)
                    if chat_key not in self.active_pm_sessions: self.active_pm_sessions.append(chat_key)
                    self.save_settings()
                    self.send_msg(chat_id, self.strings["pm_cloned"].format(old_n, new_n), reply_to_id=reply_to_id)
                else:
                    self.send_msg(chat_id, self.strings["pm_clone_err"].format(old_n), reply_to_id=reply_to_id)

            else:
                is_pm = chat_key in self.active_pm_sessions
                p_name = self.chat_to_preset.get(chat_key)
                target_dict = self.personal_triggers[p_name] if is_pm else self.triggers
                mode_name = f"Личный ({p_name})" if is_pm else "Общий"

                if action == "add":
                    full_parts = input_text.split(None, 2)
                    if len(full_parts) < 3:
                        self.send_msg(chat_id, self.strings["no_args"], reply_to_id=reply_to_id)
                        return HookResult(strategy=HookStrategy.CANCEL)
                    content = full_parts[2]
                    
                    if " - " in content:
                        sep_idx = content.find(" - ")
                        trigger = content[:sep_idx].strip().lower()
                        response = content[sep_idx + 3:].strip()
                    else:
                        split_p = content.find(" ")
                        if split_p != -1:
                            trigger = content[:split_p].strip().lower()
                            response = content[split_p+1:].strip()
                        else:
                            self.send_msg(chat_id, self.strings["no_args"], reply_to_id=reply_to_id)
                            return HookResult(strategy=HookStrategy.CANCEL)
                            
                    if trigger and response:
                        response_utf16_offset = get_utf16_offset(input_text, response)
                        saved_entities = []
                        entities = getattr(params, "entities", None)
                        
                        if response_utf16_offset != -1 and entities:
                            for i in range(entities.size()):
                                ent = entities.get(i)
                                try:
                                    doc_id = getattr(ent, "document_id", 0)
                                    if doc_id != 0:
                                        if int(ent.offset) >= response_utf16_offset:
                                            saved_entities.append({
                                                "o": int(ent.offset) - response_utf16_offset,
                                                "l": int(ent.length),
                                                "d": int(doc_id)
                                            })
                                except Exception: pass

                        if saved_entities:
                            target_dict[trigger] = {"text": response, "entities": saved_entities}
                        else:
                            target_dict[trigger] = response
                            
                        self.save_settings()

                        added_msg_text = f"✅ Добавлено ({mode_name}):\n🔸 {trigger} ➔ "
                        added_entities = ArrayList()
                        
                        if saved_entities and TL_messageEntityCustomEmoji:
                            base_offset = get_utf16_len(added_msg_text)
                            for e in saved_entities:
                                try:
                                    visual_ent = TL_messageEntityCustomEmoji()
                                    visual_ent.offset = base_offset + int(e["o"])
                                    visual_ent.length = int(e["l"])
                                    visual_ent.document_id = jlong(int(e["d"]))
                                    added_entities.add(visual_ent)
                                except: pass

                        added_msg_text += response
                        self.send_msg(chat_id, added_msg_text, added_entities if saved_entities else None, reply_to_id=reply_to_id)

                elif action == "del":
                    full_parts = input_text.split(None, 2)
                    if len(full_parts) < 3: return HookResult(strategy=HookStrategy.CANCEL)
                    trigger = full_parts[2].strip().lower()
                    if trigger in target_dict:
                        del target_dict[trigger]
                        self.save_settings()
                        self.send_msg(chat_id, self.strings["removed"].format(trigger, mode_name), reply_to_id=reply_to_id)
                    else:
                        self.send_msg(chat_id, self.strings["not_found"].format(mode_name), reply_to_id=reply_to_id)

                elif action == "clear":
                    target_dict.clear()
                    self.save_settings()
                    self.send_msg(chat_id, self.strings["cleared"].format(mode_name), reply_to_id=reply_to_id)

                elif action == "list":
                    if not target_dict:
                        self.send_msg(chat_id, self.strings["empty_list"].format(mode_name), reply_to_id=reply_to_id)
                    else:
                        out_text = f"📋 Активные автоответы ({mode_name}):\n\n"
                        out_entities = ArrayList()
                        
                        for k, v in target_dict.items():
                            prefix = f"🔸 {k} ➔ "
                            if isinstance(v, dict) and "entities" in v:
                                base_offset = get_utf16_len(out_text) + get_utf16_len(prefix)
                                
                                if TL_messageEntityCustomEmoji:
                                    for e in v["entities"]:
                                        try:
                                            ent = TL_messageEntityCustomEmoji()
                                            ent.offset = base_offset + int(e["o"])
                                            ent.length = int(e["l"])
                                            ent.document_id = jlong(int(e["d"]))
                                            out_entities.add(ent)
                                        except: pass
                                        
                                out_text += prefix + v["text"] + "\n"
                            else:
                                out_text += prefix + str(v) + "\n"
                                
                        self.send_msg(chat_id, out_text, out_entities if not out_entities.isEmpty() else None, reply_to_id=reply_to_id)

            return HookResult(strategy=HookStrategy.CANCEL)
        except:
            return HookResult()

    def analyze_message(self, msg_obj):
        try:
            chat_id = msg_obj.getDialogId()
            if not hasattr(msg_obj, "messageOwner"): return
            owner = msg_obj.messageOwner
            text = str(getattr(owner, "message", ""))
            if not text: return
            is_out = getattr(owner, "out", False)
            if is_out and not self.get_setting("react_own", False): return
            if is_out and any(text.startswith(p) for p in self.ignore_prefixes): return

            chat_key = str(chat_id)
            active_list = [str(chat) for chat in self.active_chats]
            if chat_key not in active_list and not (chat_key.startswith("-") and chat_key[1:] in active_list):
                return
            
            is_pm = chat_key in self.active_pm_sessions
            p_name = self.chat_to_preset.get(chat_key)
            current_triggers = self.personal_triggers.get(p_name, self.triggers) if is_pm else self.triggers

            text_lower = text.lower()
            whole = self.get_setting("whole_words", True)
            current_time = time.time()
            
            for trig, resp in current_triggers.items():
                found = False
                pattern_parts = [re.escape(p.strip()) for p in trig.split('|')]
                pattern = f"({'|'.join(pattern_parts)})"
                if whole:
                    if re.search(r'\b' + pattern + r'\b', text_lower): found = True
                else:
                    if re.search(pattern, text_lower): found = True
                
                if found:
                    chat_floods = self.flood_control.get(chat_id, {})
                    if current_time - chat_floods.get(trig, 0) < 3.0: continue 
                    chat_floods[trig] = current_time
                    self.flood_control[chat_id] = chat_floods
                    delay = 300 if is_out else 0
                    threading.Thread(target=lambda: (time.sleep(delay/1000.0) if delay else None, self.dispatch_response(chat_id, msg_obj, text, resp))).start()
                    break
        except: pass

    def dispatch_response(self, chat_id, message_object, original_text, response_data):
        def task():
            try:
                selected_acc = UserConfig.selectedAccount
                controller = MessagesController.getInstance(selected_acc)
                
                target_peer = controller.getInputPeer(jlong(int(chat_id)))
                if not target_peer: return

                req = TLRPC.TL_messages_sendMessage()
                req.peer = target_peer
                req.random_id = jlong(int(Utilities.random.nextLong()))
                
                if isinstance(response_data, dict):
                    req.message = response_data.get("text", "")
                    ents = response_data.get("entities", [])
                    if ents and TL_messageEntityCustomEmoji:
                        tl_ents = ArrayList()
                        for e in ents:
                            try:
                                ent = TL_messageEntityCustomEmoji()
                                ent.offset = int(e["o"])
                                ent.length = int(e["l"])
                                ent.document_id = jlong(int(e["d"]))
                                tl_ents.add(ent)
                            except: pass
                        req.entities = tl_ents
                        req.flags |= 8
                else:
                    req.message = str(response_data)

                mode = str(self.get_setting("reply_mode", "1"))
                
                topic_thread_id = 0
                if message_object:
                    if hasattr(message_object, "getThreadId"):
                        topic_thread_id = message_object.getThreadId()
                    
                    owner = message_object.messageOwner
                    if topic_thread_id == 0 and owner and hasattr(owner, "reply_to") and getattr(owner, "reply_to"):
                        topic_thread_id = getattr(owner.reply_to, "reply_to_msg_id", 0)

                if message_object and mode in ["1", "2"]:
                    header = TLRPC.TL_inputReplyToMessage()
                    header.reply_to_msg_id = int(str(message_object.getId()))
                    
                    if topic_thread_id != 0:
                        header.top_msg_id = int(str(topic_thread_id))
                    
                    if mode == "2":
                        header.quote = True
                        header.flags |= 2  
                    
                    req.reply_to = header
                    req.flags |= 1
                
                elif topic_thread_id != 0:
                    header = TLRPC.TL_inputReplyToForumTopic()
                    header.top_msg_id = int(str(topic_thread_id))
                    req.reply_to = header
                    req.flags |= 1

                ConnectionsManager.getInstance(selected_acc).sendRequest(req, None)
            except: pass
        run_on_ui_thread(task)

    def send_msg(self, chat_id, text, entities=None, reply_to_id=0):
        def task():
            try:
                selected_acc = UserConfig.selectedAccount
                controller = MessagesController.getInstance(selected_acc)
                
                target_peer = controller.getInputPeer(jlong(int(chat_id)))
                if not target_peer: return

                req = TLRPC.TL_messages_sendMessage()
                req.peer = target_peer
                req.message = text
                req.random_id = jlong(int(Utilities.random.nextLong()))
                
                if entities:
                    req.entities = entities
                    req.flags |= 8

                if reply_to_id != 0:
                    header = TLRPC.TL_inputReplyToMessage()
                    header.reply_to_msg_id = int(reply_to_id)
                    req.reply_to = header
                    req.flags |= 1

                ConnectionsManager.getInstance(selected_acc).sendRequest(req, None)
            except: pass
        run_on_ui_thread(task)
