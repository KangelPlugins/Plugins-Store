    def _show_theme_menu(self, view=None):
        def _do():
            try:
                f=get_last_fragment(); act=f.getParentActivity() if f else None
                if not act: return
                names=list(THEMES.keys())
                bld=AlertDialogBuilder(act)
                bld.set_title("🎨 Тема оформления")
