    def _show_health(self, view=None):
        def _do():
            try:
                f=get_last_fragment(); act=f.getParentActivity() if f else None
                if not act: return
                # Собрать инфо вручную
                lines=[]
                vurl=self.gs('vrm_url') or ''
                if vurl.startswith('file://') and os.path.exists(vurl[7:]):
                    try: lines.append("✅ VRM: "+str(os.path.getsize(vurl[7:])//1024)+"KB")
                    except: lines.append("✅ VRM: OK")
                else: lines.append("✅ VRM: URL")
                loaded=sum(1 for f in MOTION_FILES if os.path.exists(os.path.join(MOTIONS_DIR,f)))
                lines.append("✅ Анимаций: "+str(loaded)+"/"+str(len(MOTION_FILES)))
                try: lines.append("Аксессуаров: "+str(len([x for x in os.listdir(ACCESSORIES_DIR) if x.endswith('.glb')])))
                except: pass
                bld=AlertDialogBuilder(act)
                bld.set_title("🩺 Диагностика")
                bld.set_message(chr(10).join(lines))
                bld.set_positive_button("OK",lambda b,w: b.dismiss())
                bld.show()
            except Exception as e: self._log("health: "+str(e))
        run_on_ui_thread(_do)
    def _show_stats(self, view=None):
        def _do():
            try:
                f=get_last_fragment(); act=f.getParentActivity() if f else None
                if not act: return
                bld=AlertDialogBuilder(act)
                bld.set_title("📊 Статистика Стеллы")
                bld.set_message(self._stats.summary() if self._stats else "—")
                bld.set_positive_button("OK",lambda b,w: b.dismiss())
                bld.show()
            except Exception as e: self._log("stats: "+str(e))
        run_on_ui_thread(_do)

    def _toggle_debug(self, view=None):
        if not self._dbg and self._comp:
            self._dbg = StellaDebugger(self, self._comp)
        if self._dbg:
            self._dbg.toggle()
            state = "ON 🟢" if self._dbg._on else "OFF ⚫"
            try: BulletinHelper.show_info("Debug режим: " + state)
            except Exception: pass
        else:
            try: BulletinHelper.show_info("Запусти Стеллу сначала")
            except Exception: pass

    def _show_vrm_meta(self, view=None):
        def _do():
            try:
                path=str(self.gs('vrm_url') or '').replace('file://','')
                if not os.path.exists(path):
                    BulletinHelper.show_info("VRM не найден локально"); return
                meta=read_vrm_meta(path)
                f=get_last_fragment(); act=f.getParentActivity() if f else None
                if not act: return
                msg=(f"📛 {meta.get('name','?')}\n✍️ {meta.get('author','?')}\n📄 {meta.get('license','?')}"
                     if meta else "Метаданные не найдены")
                bld=AlertDialogBuilder(act)
                bld.set_title("📋 Инфо о модели")
                bld.set_message(msg)
                bld.set_positive_button("OK",lambda b,w: b.dismiss())
                bld.show()
            except Exception as e: self._log("vrm_meta: "+str(e))
        run_on_ui_thread(_do)

    def _show_mood(self, view=None):
        if not self._mood: return
        try: BulletinHelper.show_info("Стелла: " + self._mood.describe())
        except Exception: pass

    def _do_quick_menu(self, view=None):
        if not self._comp or not self._comp._alive:
            try: BulletinHelper.show_info("Стелла не запущена")
            except Exception: pass
            return
        if not self._quick:
            from client_utils import run_on_queue
            self._quick = StellaQuickMenu(self, self._comp)
        self._quick.show()

    def _open_tg(self,u):
        def _do():
            try:
                from org.telegram.ui import LaunchActivity
                from android.content import Intent
                from android.net import Uri
                ctx=find_class("org.telegram.messenger.ApplicationLoader").applicationContext
                intent=Intent(Intent.ACTION_VIEW, Uri.parse("https://t.me/"+u))
                intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)
                ctx.startActivity(intent)
            except Exception as e:
                self._log("tg open: "+str(e))
                try:
                    f=get_last_fragment()
                    if f: AndroidUtilities.openUrl(f.getParentActivity(),"https://t.me/"+u,True)
                except Exception: pass
        run_on_ui_thread(_do)

    def _show_guide(self,view=None):
        def _do():
            try:
                f=get_last_fragment(); act=f.getParentActivity() if f else None
                if not act: return
                bld=AlertDialogBuilder(act)
                bld.set_title(self.t("guide_title"))
                bld.set_message(self.t("guide_text"))
                bld.set_positive_button("OK",lambda b,w: b.dismiss())
                bld.show()
            except Exception as e: self._log("guide: "+str(e))
        run_on_ui_thread(_do)

    def _show_logs(self,view=None):
        def _do():
            try:
                f=get_last_fragment(); act=f.getParentActivity() if f else None
                if not act: return
                lt="\n".join(self._logs[-200:]) if self._logs else self.t("log_e")
                bld=AlertDialogBuilder(act); bld.set_title(self.t("log_t"))
                bld.set_message(lt); bld.set_message_text_view_clickable(True)
                bld.set_positive_button(self.t("log_copy"),lambda b,w: self._copy_t(lt))
                bld.set_neutral_button(self.t("log_clear"),
                    lambda b,w: (self._logs.clear(),self._log("cleared"),b.dismiss()))
                bld.set_negative_button(self.t("log_close"),lambda b,w: b.dismiss())
                bld.show()
            except Exception as e: self._log("logs: "+str(e))
        run_on_ui_thread(_do)

    def _reset(self,view=None):
        for k,v in DEFAULTS.items(): self.ss(k,v)
        self.ss("enable",True,r=True); self._log("reset")
        try: BulletinHelper.show_success(self.t("reset_ok"))
        except Exception: pass

    def _ci(self,key):
        def cb(v):
            try:
                val=int(float(str(v).strip())); self.ss(key,val)
                if self._comp and self._comp._alive:
                    if key in ("width_dp","height_dp"):
                        self._comp.resize(int(self.gs("width_dp")),int(self.gs("height_dp")))
                    elif key=="idle_speed":
                        run_on_ui_thread(lambda: self._comp._js(
                            "if(window.setSpd)setSpd("+str(val/50.0)+");"))
                    elif key=="cam_z":
                        run_on_ui_thread(lambda: self._comp._js(
                            "if(window.setCamZ)setCamZ("+str(val/10.0)+");"))
                    elif key=="alpha":
                        run_on_ui_thread(lambda: self._comp._root and
                            self._comp._root.setAlpha(val/100.0))
            except Exception as e: self._log("ci("+key+"): "+str(e))
        return cb

    def _cb(self,k): return lambda v: self.ss(k,bool(v))
    def _cl(self,i): self.ss("language",i,r=True)

    # ── settings UI с ВКЛАДКАМИ ──
    def create_settings(self) -> List[Any]:
        t=self.t
        tab=int(self.gs("settings_tab") or 0)
        top=[
            Selector(key="settings_tab",text="📂 Вкладка",default=0,
                     items=["🎀 Модель","📐 Окно","⚙️ Поведение","🔧 Прочее"],
                     icon="msg_settings",
                     on_change=lambda i: self.ss("settings_tab",i,r=True)),
        ]
        bot=[
            Divider(text=t("footer")),
            Text(text=t("reset"),icon="msg_settings",red=True,on_click=self._reset),
        ]
        if tab==0:
            mid=[
                Header(text="🎀 Модель"),
                Switch(key="enable",text=t("enable"),subtext=t("enable_s"),
                       default=True,icon="msg_settings",on_change=self._on_enable_change),
                Input(key="vrm_url",text=t("vrm_url"),default=DEFAULT_VRM,
                      icon="msg_settings",on_change=lambda v: self.ss("vrm_url",str(v).strip())),
                Text(text=t("reload"),icon="msg_settings",accent=True,on_click=self._do_reload),
                Text(text=t("pick"),  icon="msg_settings",accent=True,on_click=self._pick_file),
                Text(text="📋 Инфо о модели",icon="msg_settings",accent=True,on_click=self._show_vrm_meta),
                Divider(),
                Header(text="📷 Камера"),
                Input(key="cam_z",text=t("cam_z"),default=str(DEFAULTS["cam_z"]),
                      icon="msg_settings",on_change=self._ci("cam_z")),
                Divider(),
                Header(text="🎵 Звуки"),
                Switch(key="stella_enable",text=t("s_enable"),subtext=t("s_enable_s"),
                       default=True,icon="msg_settings",on_change=self._on_stella_enable),
                Divider(),
                Header(text="ℹ️ О плагине"),
                Text(text="@lyzos",icon="msg_settings",accent=True,
                     on_click=lambda v: self._open_tg("lyzos")),
                Text(text="@rei_plugins",icon="msg_settings",accent=True,
                     on_click=lambda v: self._open_tg("rei_plugins")),
                Selector(key="language",text=t("lang"),default=0,
                         items=["RU","EN"],icon="msg_settings",on_change=self._cl),
                Text(text=t("guide_btn"),icon="msg_settings",on_click=self._show_guide),
                Text(text=t("logs"),    icon="msg_settings",on_click=self._show_logs),
            ]
        elif tab==1:
            mid=[
                Header(text="📐 Размер окна"),
                Text(text="📐 Пресет размера",icon="msg_settings",on_click=self._show_size_menu),
                Input(key="width_dp", text="Ширина (dp)",default="128",
                      icon="msg_settings",on_change=lambda v: self._on_win_size(v,None)),
                Input(key="height_dp",text="Высота (dp)",default="310",
                      icon="msg_settings",on_change=lambda v: self._on_win_size(None,v)),
                Divider(),
                Header(text="🎨 Внешний вид"),
                Input(key="alpha",text=t("alpha"),default=str(DEFAULTS["alpha"]),
                      icon="msg_settings",on_change=self._ci("alpha")),
                Switch(key="show_borders",text=t("show_borders"),subtext=t("show_borders_s"),
                       default=False,icon="msg_settings",on_change=self._on_borders),
                Divider(),
                Header(text="📍 Позиция"),
                Switch(key="snap",  text=t("snap"),  subtext=t("snap_s"),
                       default=True, icon="msg_settings",on_change=self._cb("snap")),
                Switch(key="locked",text=t("locked"),subtext=t("locked_s"),
                       default=False,icon="msg_settings",on_change=self._cb("locked")),
            ]
        elif tab==2:
            mid=[
                Header(text="⚙️ Поведение"),
                Switch(key="auto_react",   text=t("react"),subtext=t("react_s"),
                       default=True,icon="msg_settings",on_change=self._cb("auto_react")),
                Switch(key="idle_quotes",  text="💬 Фразы Стеллы",
                       subtext="Показывать фразы каждые 5 мин",
                       default=True,icon="msg_settings",on_change=self._on_idle_quotes),
                Switch(key="battery_react",text="🔋 Реакция на батарею",
                       subtext="Реагировать на уровень заряда",
                       default=True,icon="msg_settings",on_change=self._cb("battery_react")),
                Switch(key="sched_react",  text="🕐 Реакция на время",
                       subtext="Приветствия утром и вечером",
                       default=True,icon="msg_settings",on_change=self._cb("sched_react")),
                Input(key="idle_speed",text=t("idle"),default=str(DEFAULTS["idle_speed"]),
                      icon="msg_settings",on_change=self._ci("idle_speed")),
            ]
        else:
            mid=[
                Header(text="🔧 Прочее"),
                Text(text="✨ Аксессуары",     icon="msg_settings",accent=True,
                     on_click=self._show_accessories_menu),
                Text(text="📊 Статистика",     icon="msg_settings",
                     on_click=self._show_stats),
                Text(text="🩺 Диагностика",    icon="msg_settings",
                     on_click=self._show_health),
                Text(text="🔧 Debug",          icon="msg_settings",
                     on_click=self._toggle_debug),
            ]
        return top+mid+bot
