class StellaMood:
    """Система настроения."""
    def __init__(self):
        self._score = 0   # -100..100
        self._mood = 'neutral'
        self._last_interact = time.time()

    @property
    def current(self): return self._mood

    def on_tap(self):
        self._score = min(100, self._score + 8)
        self._last_interact = time.time()
        self._recalc()

    def on_dance(self):
        self._score = min(100, self._score + 20)
        self._last_interact = time.time()
        self._recalc()

    def on_idle_long(self):
        self._score = max(-50, self._score - 4)
        self._recalc()

    def tick(self):
        now = time.time()
        if now - self._last_interact > 600:
            self._score = max(-30, self._score - 2)
        elif self._score > 0:
            self._score = max(0, self._score - 1)
        elif self._score < 0:
            self._score = min(0, self._score + 1)
        self._recalc()

    def _recalc(self):
        h = datetime.datetime.now().hour
        if h >= 23 or h < 5:
            self._mood = 'sleepy'
        elif self._score >= 70:
            self._mood = 'excited'
        elif self._score >= 30:
            self._mood = 'happy'
        elif self._score >= 5:
            self._mood = 'neutral'
        elif self._score <= -30:
            self._mood = 'bored'
        else:
            self._mood = 'neutral'

    def get_anim_pool(self):
        return MOODS.get(self._mood, MOODS['neutral'])['anim']

    def describe(self):
        icons = {'happy':'😊','neutral':'😐','sleepy':'😴',
                 'energetic':'⚡','bored':'😑','excited':'🤩'}
        return icons.get(self._mood, '🎀') + ' ' + self._mood.capitalize()


class StellaStats:
    """Статистика и достижения."""
    def __init__(self, plugin):
        self._p = plugin
        self._start = time.time()
        if not self._p.gs(STAT_FIRST):
            self._p.ss(STAT_FIRST, datetime.datetime.now().strftime('%d.%m.%Y'))
        self._p.ss(STAT_SESS, int(self._p.gs(STAT_SESS) or 0) + 1)

    def tap(self):
        v = int(self._p.gs(STAT_TAPS) or 0) + 1
        self._p.ss(STAT_TAPS, v)
        self._check()

    def dance(self):
        v = int(self._p.gs(STAT_DANCES) or 0) + 1
        self._p.ss(STAT_DANCES, v)
        self._check()

    def save_uptime(self):
        elapsed = int(time.time() - self._start)
        total = int(self._p.gs(STAT_UPTIME) or 0) + elapsed
        self._p.ss(STAT_UPTIME, total)

    def summary(self):
        taps  = int(self._p.gs(STAT_TAPS) or 0)
        dance = int(self._p.gs(STAT_DANCES) or 0)
        sess  = int(self._p.gs(STAT_SESS) or 0)
        up    = int(self._p.gs(STAT_UPTIME) or 0)
        first = self._p.gs(STAT_FIRST) or '?'
        h, m  = up // 3600, (up % 3600) // 60
        unlocked = json.loads(self._p.gs('achievements') or '[]')
        achs = '\n'.join(
            f"  {a['icon']} {a['name']}"
            for a in ACHIEVEMENTS if a['id'] in unlocked
        ) or '  нет пока'
        return (
            f"👆 Касаний: {taps}\n"
            f"💃 Танцев: {dance}\n"
            f"🔌 Сессий: {sess}\n"
            f"⏱ Онлайн: {h}ч {m}м\n"
            f"📅 С нами с: {first}\n\n"
            f"🏆 Достижения:\n{achs}"
        )

    def _check(self):
        s = {STAT_TAPS: int(self._p.gs(STAT_TAPS) or 0),
             STAT_DANCES: int(self._p.gs(STAT_DANCES) or 0),
             STAT_SESS: int(self._p.gs(STAT_SESS) or 0),
             STAT_UPTIME: int(self._p.gs(STAT_UPTIME) or 0)}
        unlocked = json.loads(self._p.gs('achievements') or '[]')
        for a in ACHIEVEMENTS:
            if a['id'] not in unlocked:
                try:
                    if a['req'](s):
                        unlocked.append(a['id'])
                        self._p.ss('achievements', json.dumps(unlocked))
                        try: BulletinHelper.show_success(f"🏆 {a['icon']} {a['name']}")
                        except Exception: pass
                except Exception: pass


class StellaScheduler:
    """Планировщик событий по времени суток."""
    def __init__(self, plugin, companion_ref):
        self._p = plugin
        self._cref = companion_ref
        self._last_h = -1
        self._running = False

    def start(self):
        if self._running: return
        self._running = True
        def _loop():
            while self._running:
                try:
                    h = datetime.datetime.now().hour
                    if h != self._last_h:
                        self._last_h = h
                        self._on_hour(h)
                except Exception: pass
                time.sleep(60)
        threading.Thread(target=_loop, daemon=True, name='sched').start()

    def stop(self): self._running = False

    def _on_hour(self, h):
        comp = self._cref()
        if not comp or not comp._alive: return
        if h == 7:
            run_on_queue(lambda: comp._play_random_anim(TIME_GREET['morning'][2], False))
            if self._p._sounds: self._p._sounds.play('greet')
        elif h == 19:
            run_on_queue(lambda: comp._play_random_anim(TIME_GREET['evening'][2], False))
        elif h == 23:
            if self._p._sounds: self._p._sounds.play('sleep')
        elif 10 <= h <= 20 and random.random() < 0.25:
            run_on_queue(lambda: comp._play_random_anim(ANIM_RANDOM, False))


class StellaCamera:
    """Управление камерой — пресеты и кино-режим."""
    def __init__(self, companion):
        self._c = companion
        self._preset = 'portrait'
        self._cin = False

    def apply(self, name):
        p = CAMERA_PRESETS.get(name)
        if not p or not self._c or not self._c._alive: return
        self._preset = name
        self._c._js(
            f"if(cam){{"
            f"cam.fov={p['fov']};cam.updateProjectionMatrix();"
            f"cam.position.set(0,{p['y']},{p['z']});"
            f"cam.lookAt(0,{p['y']},0);}}"
        )

    def start_cinematic(self):
        if self._cin: return
        self._cin = True
        presets = list(CAMERA_PRESETS.keys())
        idx = [0]
        def _loop():
            while self._cin and self._c and self._c._alive:
                time.sleep(9)
                if not self._cin: break
                idx[0] = (idx[0] + 1) % len(presets)
                run_on_ui_thread(lambda: self.apply(presets[idx[0]]))
        threading.Thread(target=_loop, daemon=True, name='cinematic').start()

    def stop_cinematic(self): self._cin = False


class StellaIdleQuotes:
    """Периодически показывает фразы от Стеллы."""
    def __init__(self, plugin):
        self._p = plugin
        self._running = False
        self._interval = 300  # 5 мин

    def start(self):
        if self._running: return
        self._running = True
        def _loop():
            time.sleep(120)  # первый раз через 2 мин
            while self._running:
                try:
                    if self._p.gs('idle_quotes'):
                        lang = 'en' if int(self._p.gs('language') or 0) == 1 else 'ru'
                        pool = IDLE_QUOTES_EN if lang == 'en' else IDLE_QUOTES_RU
                        try: BulletinHelper.show_info(random.choice(pool))
                        except Exception: pass
                except Exception: pass
                time.sleep(self._interval + random.randint(-60, 60))
        threading.Thread(target=_loop, daemon=True, name='quotes').start()

    def stop(self): self._running = False


class StellaBatteryMonitor:
    """Реакция на уровень батареи."""
    def __init__(self, plugin, companion_ref):
        self._p = plugin
        self._cref = companion_ref
        self._last = -1
        self._running = False

    def start(self):
        if self._running: return
        self._running = True
        def _loop():
            while self._running:
                try:
                    lv = self._level()
                    if 0 <= lv != self._last:
                        self._react(lv)
                        self._last = lv
                except Exception: pass
                time.sleep(120)
        threading.Thread(target=_loop, daemon=True, name='battery').start()

    def stop(self): self._running = False

    def _level(self):
        try:
            ctx = find_class('org.telegram.messenger.ApplicationLoader').applicationContext
            IM  = find_class('android.content.Intent')
            IF  = find_class('android.content.IntentFilter')
            b   = ctx.registerReceiver(None, IF(IM.ACTION_BATTERY_CHANGED))
            return b.getIntExtra('level', -1)
        except Exception: return -1

    def _react(self, lv):
        comp = self._cref()
        if not comp or not comp._alive: return
        if lv <= 15 and self._last > 15:
            try: BulletinHelper.show_info(f"🔋 {lv}% — Стелла устаёт...")
            except Exception: pass
            run_on_queue(lambda: comp._play_random_anim(
                ['Loop/SadIdleMain.vrma'], True))
        elif lv >= 95 and (self._last < 90 or self._last < 0):
            try: BulletinHelper.show_success(f"⚡ {lv}% — Стелла заряжена!")
            except Exception: pass
            run_on_queue(lambda: comp._play_random_anim(
                ['Loop/Offensive Idle.vrma'], True))


def read_vrm_meta(path):
    """Читает метаданные VRM файла (имя, автор, лицензия)."""
    import struct
    try:
        with open(path, 'rb') as f:
            if f.read(4) != b'glTF': return {}
            f.read(8)  # version + length
            clen = struct.unpack('<I', f.read(4))[0]
            if f.read(4) != b'JSON': return {}
            gltf = json.loads(f.read(clen).decode('utf-8', errors='ignore'))
        ext  = gltf.get('extensions', {})
        meta = (ext.get('VRM',{}).get('meta',{}) or
                ext.get('VRMC_vrm',{}).get('meta',{}))
        return {
            'name':    meta.get('title','') or meta.get('name','') or os.path.basename(path),
            'author':  meta.get('author',''),
            'version': meta.get('version',''),
            'license': meta.get('licenseName','') or meta.get('license',''),
        }
    except Exception: return {}


def haptic(strength='light'):
    """Тактильная вибрация."""
    try:
        ctx = find_class('org.telegram.messenger.ApplicationLoader').applicationContext
        vib = ctx.getSystemService('vibrator')
        ms  = {'light':15,'medium':30,'heavy':60}.get(strength,15)
        vib.vibrate(ms)
    except Exception: pass


def get_screen_dp():
    """Размер экрана в dp."""
    try:
        ctx = find_class('org.telegram.messenger.ApplicationLoader').applicationContext
        dm  = ctx.getResources().getDisplayMetrics()
        d   = dm.density or 1
        return int(dm.widthPixels / d), int(dm.heightPixels / d)
    except Exception: return 392, 850


class StellaScreensaver:
    """Хранитель экрана — автоматическая смена анимаций."""
    def __init__(self, companion):
        self._c = companion
        self._active = False

    def start(self):
        if self._active: return
        self._active = True
        pools = [ANIM_IDLE, ANIM_RANDOM, ANIM_GREET, ANIM_DANCE]
        idx = [0]
        def _loop():
            while self._active and self._c and self._c._alive:
                pool = pools[idx[0] % len(pools)]; idx[0] += 1
                self._c._play_random_anim(pool, False)
                time.sleep(30 + random.random() * 20)
        threading.Thread(target=_loop, daemon=True, name='screensaver').start()

    def stop(self): self._active = False


class StellaVRMPicker:
    """Помощник выбора VRM файлов с предпросмотром метаданных."""
    def __init__(self, plugin): self._p = plugin

    def pick_and_load(self):
        self._p._pick_file()

    def show_meta(self, path):
        meta = read_vrm_meta(path)
        if not meta: return
        def _do():
            try:
                f = get_last_fragment()
                act = f.getParentActivity() if f else None
                if not act: return
                msg = (
                    f"📛 {meta.get('name','?')}\n"
                    f"✍️  {meta.get('author','?')}\n"
                    f"📄 {meta.get('license','?')}"
                )
                bld = AlertDialogBuilder(act)
                bld.set_title("VRM Info")
                bld.set_message(msg)
                bld.set_positive_button("OK", lambda b,w: b.dismiss())
                bld.show()
            except Exception as e: self._p._log("vrm meta: "+str(e))
        run_on_ui_thread(_do)


class StellaQuickMenu:
    """Меню быстрых действий."""
    def __init__(self, plugin, companion):
        self._p = plugin
        self._c = companion

    def show(self):
        def _do():
            try:
                f = get_last_fragment()
                act = f.getParentActivity() if f else None
                if not act: return
                lang = 'en' if int(self._p.gs('language') or 0) == 1 else 'ru'
                actions = QUICK_ACTIONS_EN if lang == 'en' else QUICK_ACTIONS_RU
                labels = [a[0] for a in actions]
                bld = AlertDialogBuilder(act)
                bld.set_title("⚡ " + ("Quick Actions" if lang == 'en' else "Быстрые действия"))
                def oc(b, i):
                    b.dismiss()
                    self._exec(actions[i][1])
                bld.set_items(labels, oc)
                bld.set_negative_button("✖", lambda b,w: b.dismiss())
                bld.show()
            except Exception as e: self._p._log("quick: "+str(e))
        run_on_ui_thread(_do)

    def _exec(self, cmd):
        c = self._c; p = self._p
        if not c or not c._alive: return
        if cmd == 'wave':
            c._js('(function(){var t=0,dur=2.5;function w(){t+=0.016;var v=Math.sin(t*7)*0.5*(1-t/dur);if(vrm){var b=vrm.humanoid.getNormalizedBoneNode("rightUpperArm");if(b)b.rotation.z=-1.15+v;}if(t<dur)requestAnimationFrame(w);}w();})();')
        elif cmd == 'dance':
            run_on_queue(lambda: c._play_random_anim(ANIM_DANCE, False))
            if p._stats: p._stats.dance()
        elif cmd == 'sleep':
            run_on_ui_thread(c._go_sleep)
        elif cmd == 'greet':
            run_on_queue(lambda: c._play_random_anim(ANIM_GREET, False))
        elif cmd == 'cinematic':
            if hasattr(p, '_cam'):
                if p._cam._cin: p._cam.stop_cinematic()
                else: p._cam.start_cinematic()
        elif cmd == 'close_up':
            if hasattr(p, '_cam'): p._cam.apply('close_up')
        elif cmd == 'standard':
            if hasattr(p, '_cam'): p._cam.apply('portrait')
        elif cmd == 'reset':
            c._js("if(window.resetPan)resetPan();")
            if hasattr(p, '_cam'): p._cam.apply('portrait')


class StellaThemeManager:
    """Управление темами оформления."""
    def __init__(self, companion): self._c = companion

    def apply(self, theme_name):
        t = THEMES.get(theme_name, THEMES['dark'])
        if not self._c or not self._c._alive: return
        self._c._js("document.body.style.background='"+t['body']+"';")

    @staticmethod
    def names(): return list(THEMES.keys())


class StellaDebugger:
    """Отладчик — показывает состояние VRM и анимаций."""
    def __init__(self, plugin, companion):
        self._p = plugin
        self._c = companion
        self._on = False

    def toggle(self):
        self._on = not self._on
        if self._c and self._c._alive:
            disp = "block" if self._on else "none"
            self._c._js(f"document.getElementById('s').style.display='{disp}';")

    def dump(self):
        if not self._c or not self._c._alive: return "no model"
        self._c._js(
            "st('EXPR:'+_expressions.length+'|BONES:'+Object.keys(_bones).length+"
            "'|VRMA:'+(_vrmaPlaying?'PLAY':'idle')+'|BASE:'+(_baseAction?'OK':'NO')"
            "+'|CACHE:'+Object.keys(_clipCache).length);"
        )

    def info(self):
        p = self._p
        taps   = int(p.gs(STAT_TAPS)   or 0)
        dances = int(p.gs(STAT_DANCES) or 0)
        sess   = int(p.gs(STAT_SESS)   or 0)
        mood   = p._mood.describe() if hasattr(p, '_mood') else '?'
        w, h   = get_screen_dp()
        return (
            f"🔧 Debug Info\n"
            f"Screen: {w}×{h}dp\n"
            f"Mood: {mood}\n"
            f"Taps: {taps} | Dances: {dances}\n"
            f"Sessions: {sess}\n"
            f"VRM: {p.gs('vrm_url') or 'default'}\n"
            f"Motions: {MOTIONS_DIR}\n"
            f"Sounds: {SOUNDS_BASE}"
        )


class StellaAutoDownloader:
    """Автоматическая загрузка ресурсов."""
    def __init__(self, plugin): self._p = plugin

    def check_and_download(self):
        """Скачать все недостающие анимации и звуки в фоне."""
        import urllib.request as _ur, urllib.parse as _up
        missing = [f for f in MOTION_FILES
                   if not os.path.exists(os.path.join(MOTIONS_DIR, f))]
        if not missing: return
        self._p._log(f"auto-dl: {len(missing)} анимаций...")
        try: BulletinHelper.show_info(f"⬇️ Загружаю {len(missing)} анимаций...")
        except Exception: pass
        ok = 0
        for fn in missing:
            dst = os.path.join(MOTIONS_DIR, fn)
            url = MOTIONS_REPO + "/" + _up.quote(fn)
            try:
                os.makedirs(os.path.dirname(dst), exist_ok=True)
                _ur.urlretrieve(url, dst)
                ok += 1
            except Exception as e:
                self._p._log(f"dl fail: {fn}: {e}")
        if ok:
            try: BulletinHelper.show_success(f"✅ Загружено {ok} анимаций")
            except Exception: pass
        self._p._log(f"auto-dl done: {ok}/{len(missing)}")

    def check_vrm(self):
        if not os.path.exists(STELLA_VRM):
            import urllib.request as _ur
            try:
                os.makedirs(os.path.dirname(STELLA_VRM), exist_ok=True)
                _ur.urlretrieve(DEFAULT_VRM, STELLA_VRM)
                self._p.ss('vrm_url', 'file://' + STELLA_VRM)
                try: BulletinHelper.show_success("✅ Stella.vrm загружен!")
                except Exception: pass
            except Exception as e:
                self._p._log("vrm dl fail: " + str(e))


class StellaAccessoryManager:
    """Менеджер аксессуаров .glb."""
    def __init__(self, plugin, companion):
        self._p = plugin
        self._c = companion
        self._active = {}   # id → filename

    def list_files(self):
        try:
            return sorted([f for f in os.listdir(ACCESSORIES_DIR)
                          if f.lower().endswith('.glb')])
        except Exception: return []

    def load(self, filename, bone='head', ox=0, oy=0.12, oz=0):
        import json as _j
        path = os.path.join(ACCESSORIES_DIR, filename)
        if not os.path.exists(path): return False
        aid  = os.path.splitext(filename)[0]
        url  = 'file://' + path
        if self._c and self._c._alive:
            self._c._js(
                "if(window.loadAccessory)loadAccessory("
                + _j.dumps(aid) + ","
                + _j.dumps(url) + ","
                + _j.dumps(bone) + ","
                + str(ox) + "," + str(oy) + "," + str(oz) + ");"
            )
            self._active[aid] = filename
        return True

    def remove(self, filename):
        import json as _j
        aid = os.path.splitext(filename)[0]
        if self._c and self._c._alive:
            self._c._js("if(window.removeAccessory)removeAccessory(" + _j.dumps(aid) + ");")
        self._active.pop(aid, None)

    def remove_all(self):
        for fn in list(self._active.values()):
            self.remove(fn)

    def show_menu(self):
        files = self.list_files()
        def _do():
            try:
                f = get_last_fragment()
                act = f.getParentActivity() if f else None
                if not act: return
                bld = AlertDialogBuilder(act)
                bld.set_title("✨ Аксессуары")
                if not files:
                    bld.set_message("📂 Положи .glb файлы в:\n" + ACCESSORIES_DIR)
                    bld.set_positive_button("OK", lambda b,w: b.dismiss())
                    bld.show(); return
                active_ids = set(self._active.keys())
                items = []
                for fn in files:
                    aid = os.path.splitext(fn)[0]
                    pfx = "✅ " if aid in active_ids else "   "
                    items.append(pfx + os.path.splitext(fn)[0])
                items.append("❌ Снять все")
                def oc(b, i):
                    b.dismiss()
                    if i >= len(files):
                        self.remove_all(); return
                    fn = files[i]
                    aid = os.path.splitext(fn)[0]
                    if aid in active_ids: self.remove(fn)
                    else: self.load(fn)
                bld.set_items(items, oc)
                bld.set_negative_button("Закрыть", lambda b,w: b.dismiss())
                bld.show()
            except Exception as e: self._p._log("acc menu: " + str(e))
        run_on_ui_thread(_do)

# ═══════════════════════════════════════════
#  PLUGIN
# ═══════════════════════════════════════════

class WaifuPlugin(BasePlugin):
    def __init__(self):
        super().__init__()
        self._logs=[]; self._comp=None; self._hooks=[]
        self._sounds=None; self._sherpa=None
        self._mood    = StellaMood()
        self._stats   = StellaStats(self)
        self._dl      = StellaAutoDownloader(self)
        self._quotes  = StellaIdleQuotes(self)
        self._battery = None
        self._sched   = None
        self._cam     = None
        self._acc     = None
        self._quick   = None
        self._dbg     = None
        self._vrm_picker = None

    def gs(self,k):           return self.get_setting(k,DEFAULTS.get(k))
    def ss(self,k,v,r=False): self.set_setting(k,v,reload_settings=r)
    def is_on(self):          return bool(self.gs("enable"))
    def stella_on(self):      return bool(self.gs("stella_enable"))

    def _auto_setup(self):
        """Автоматическая загрузка VRM и звуков при первом запуске."""
        import urllib.request as _ur
        def _dl(url,path):
            try:
                os.makedirs(os.path.dirname(path),exist_ok=True)
                _ur.urlretrieve(url,path)
                return True
            except Exception as e: self._log("dl err "+os.path.basename(path)+": "+str(e)); return False
        # VRM
        if not os.path.exists(STELLA_VRM):
            self._log("auto: downloading Stella.vrm...")
            try: BulletinHelper.show_info("⬇️ Скачиваю Stella.vrm...")
            except Exception: pass
            if _dl(DEFAULT_VRM, STELLA_VRM):
                self._log("auto: VRM OK")
                self.ss("vrm_url","file://"+STELLA_VRM)
                try: BulletinHelper.show_success("✅ Stella.vrm загружен!")
                except Exception: pass
            else:
                try: BulletinHelper.show_error("❌ Ошибка загрузки VRM")
                except Exception: pass
        # Создать папки для звуков (файлы юзер кладёт сам)
        for cat in SOUND_CATS:
            try: os.makedirs(os.path.join(SOUNDS_BASE,cat),exist_ok=True)
            except Exception: pass
        # Скачать анимации если нет
        missing_m=[f for f in MOTION_FILES
                   if not os.path.exists(os.path.join(MOTIONS_DIR,f))]
        if missing_m:
            self._log("auto: downloading "+str(len(missing_m))+" motions...")
            import urllib.parse as _up2
            for fn in missing_m:
                dst=os.path.join(MOTIONS_DIR,fn)
                url=MOTIONS_REPO+"/"+_up2.quote(fn)
                _dl(url,dst)
        try: os.makedirs(ACCESSORIES_DIR,exist_ok=True)
        except Exception: pass
        if self._sounds: self._sounds.invalidate()
        self._log("auto: setup done")
    def _lang(self):
        try: return "en" if int(self.gs("language") or 0)==1 else "ru"
        except: return "ru"
    def t(self,k): return S.get(self._lang(),S["ru"]).get(k,k)

    def _log(self,msg):
        ts=datetime.datetime.now().strftime("%H:%M:%S")
        self._logs.append("["+ts+"] "+str(msg))
        if len(self._logs)>800: self._logs=self._logs[-800:]
        alog("[Stella] "+str(msg))

    # ── lifecycle ──
    def on_plugin_load(self):
        self._log("=== Stella v1.0.0 Beta ===")
        self._comp   = _Companion(self)
        self._sounds = _SoundPlayer(self)
        self._sherpa = _SherpaEngine(self)
        try:
            cls=find_class("org.telegram.ui.LaunchActivity")
            if cls:
                r=self.hook_all_methods(cls,"onActivityResult",_ResultHook(self))
                if r: self._hooks.extend(r); self._log("hook ok: "+str(len(r)))
        except Exception as e: self._log("hook: "+str(e))
        run_on_queue(self._auto_setup)
        if self.is_on():     self._comp.show()
        if self.stella_on(): run_on_queue(self._stella_start)

    def on_plugin_unload(self):
        self._log("=== unloading ===")
        if self._comp:   self._comp.hide()
        if self._sherpa: self._sherpa.stop()
        if self._sounds: self._sounds.stop()
        for h in self._hooks:
            try: self.unhook_method(h)
            except Exception: pass
        self._hooks.clear()

    def on_app_event(self,event_type:AppEvent):
        try:
            if event_type==AppEvent.RESUME:
                comp=self._comp
                if comp and not comp._alive and not comp._hidden and self.is_on():
                    comp._showing=False
                    # Если VRM уже был загружен — просто восстановить окно
                    # _open сам вызовет load_vrm если _wv уже есть
                    run_on_ui_thread(comp._open)
        except Exception: pass

    # ── stella ──
    def _stella_start(self):
        self._log('Stella OK')
        try: BulletinHelper.show_success(self.t('s_ready'))
        except Exception: pass

    def _on_stella_exit(self):
        if self._comp and self._comp._alive:
            self._comp._hidden=True; self._comp.hide()

    # ── custom commands ──
    # ── waifu callbacks ──
    def _on_enable_change(self,v):
        enabled=bool(v); self.ss("enable",enabled)
        if not self._comp: return
        if enabled:
            if not self._comp._alive:
                self._comp._showing=False; self._comp._hidden=False; self._comp.show()
        else:
            if self._comp._alive: self._comp._hidden=True; self._comp.hide()

    def _on_borders(self,v):
        self.ss("show_borders",bool(v))
        if self._comp and self._comp._alive:
            val="true" if bool(v) else "false"
            run_on_ui_thread(lambda: self._comp._js("if(window.showBorder)showBorder("+val+");"))

    def _on_pan(self,v):
        self.ss("pan_mode",bool(v))
        if self._comp and self._comp._alive:
            val="true" if bool(v) else "false"
            run_on_ui_thread(lambda: self._comp._js("if(window.showPanIndicator)showPanIndicator("+val+");"))

    def _on_stella_enable(self,v):
        enabled=bool(v); self.ss('stella_enable',enabled)
        if enabled and self._sounds: self._sounds.play('greet')

    def _on_borders(self,v):
        self.ss("show_borders",bool(v))
        if self._comp and self._comp._alive:
            val="true" if bool(v) else "false"
            run_on_ui_thread(lambda: self._comp._js("if(window.showBorder)showBorder("+val+");"))

    def _on_pan(self,v):
        self.ss("pan_mode",bool(v))
        if self._comp and self._comp._alive:
            val="true" if bool(v) else "false"
            run_on_ui_thread(lambda: self._comp._js("if(window.showPanIndicator)showPanIndicator("+val+");"))

    def _on_win_size(self,w,h):
        try:
            if w is not None: self.ss("width_dp", max(64,min(600,int(float(str(w))))))
            if h is not None: self.ss("height_dp",max(100,min(900,int(float(str(h))))))
            if self._comp and self._comp._alive:
                wd=int(self.gs("width_dp") or 128)
                hd=int(self.gs("height_dp") or 310)
                self._comp.resize(wd,hd)
        except Exception as e: self._log("win_size: "+str(e))

    def _on_win_shape(self,i):
        self.ss("win_shape",int(i))
        if self._comp and self._comp._alive: run_on_ui_thread(self._comp._apply_win_shape)

    # ── stella callbacks ──
    def _on_stella_enable(self,v):
        enabled=bool(v); self.ss("stella_enable",enabled)
        if enabled: run_on_queue(self._stella_start)
        else:        self._stella_stop()

    # ── file picker ──
    def _pick_file(self,view=None):
        def _do():
            try:
                f=get_last_fragment(); act=f.getParentActivity() if f else None
                if not act: return
                I=find_class("android.content.Intent")
                i=I(I.ACTION_OPEN_DOCUMENT)
                i.addCategory(I.CATEGORY_OPENABLE); i.setType("*/*")
                act.startActivityForResult(i,PICK_REQUEST)
            except Exception as e: self._log("pick: "+str(e))
        run_on_ui_thread(_do)

    def _copy_vrm(self,uri):
        try:
            f=get_last_fragment(); act=f.getParentActivity() if f else None
            if not act: return
            from java import jarray, jbyte
            cr=act.getContentResolver(); inp=cr.openInputStream(uri)
            if not inp: return
            buf=jarray(jbyte)(65536); chunks=[]
            while True:
                n=inp.read(buf,0,65536)
                if n==-1: break
                chunks.append(bytes(b if b>=0 else b+256 for b in buf[:n]))
            inp.close(); data=b"".join(chunks); self._log("VRM: "+str(len(data))+"b")
            cache=act.getCacheDir().getAbsolutePath()
            dst=os.path.join(cache,"waifu_model.vrm")
            with open(dst,"wb") as out: out.write(data)
            self.ss("vrm_url","file://"+dst)
            def _after():
                try: BulletinHelper.show_success(self.t("copy_ok"))
                except Exception: pass
                if self._comp:
                    if self._comp._alive: self._comp.load_vrm()
                    else: self._comp._showing=False; self._comp._hidden=False; self._comp.show()
            run_on_ui_thread(_after)
        except Exception as e:
            self._log("copy_vrm: "+str(e))
            try: BulletinHelper.show_error(self.t("copy_err"))
            except Exception: pass

    def _show_accessories_menu(self, v=None):
        """Показать список .glb аксессуаров."""
        p=self; base=ACCESSORIES_DIR
        try:
            files=[(os.path.splitext(fn)[0],os.path.join(base,fn))
                   for fn in sorted(os.listdir(base)) if fn.lower().endswith(".glb")]
        except Exception: files=[]
        if not files:
            try: BulletinHelper.show_info("📂 "+base+" — нет .glb файлов")
            except Exception: pass
            return
        def _do():
            try:
                f=get_last_fragment(); act=f.getParentActivity() if f else None
                if not act: return
                bld=AlertDialogBuilder(act)
                bld.set_title("✨ Аксессуары")
                import json as _j
                items=["✨ "+nm for nm,_ in files]+["❌ Снять всё"]
                def oc(b,i):
                    b.dismiss()
                    if i>=len(files):
                        for nm,_ in files:
                            if p._comp and p._comp._alive:
                                p._comp._js("if(window.removeAccessory)removeAccessory("+_j.dumps(nm)+");")
                        return
                    nm,path=files[i]
                    if p._comp and p._comp._alive:
                        p._comp._js("if(window.loadAccessory)loadAccessory("+
                            _j.dumps(nm)+","+_j.dumps("file://"+path)+",\"head\",0,0.12,0);")
                bld.set_items(items,oc)
                bld.set_negative_button("Закрыть",lambda b,w: b.dismiss())
                bld.show()
            except Exception as e: p._log("acc menu: "+str(e))
        run_on_ui_thread(_do)

    def _show_motions_menu(self, v=None, category=None):
        """Показать список .vrma анимаций из /sdcard/Stella/Motions/"""
        p=self
        try:
            files=[]; base=MOTIONS_DIR
            pool=None
            if category=="dance": pool=[os.path.join(base,n) for n in ANIM_DANCE]
            if pool:
                files=[(os.path.splitext(os.path.basename(p))[0],p) for p in pool if os.path.exists(p)]
            else:
                for root,dirs,fns in os.walk(base):
                    for fn in sorted(fns):
                        if fn.lower().endswith(".vrma"):
                            files.append((os.path.splitext(fn)[0], os.path.join(root,fn)))
                    dirs.sort()
            if not files:
                try: BulletinHelper.show_info("📂 "+MOTIONS_DIR+" — нет .vrma файлов")
                except Exception: pass
                return
        except Exception as e:
            p._log("motions scan: "+str(e)); return

        def _do():
            try:
                f=get_last_fragment(); act=f.getParentActivity() if f else None
                if not act: return
                items=["▶ "+nm for nm,_ in files]+["⏹ Стоп"]
                bld=AlertDialogBuilder(act)
                bld.set_title("🎬 Анимации")
                def oc(b,i):
                    b.dismiss()
                    if i>=len(files):
                        if p._comp and p._comp._alive:
                            p._comp._js("if(window.stopVrma)stopVrma();")
                        return
                    nm,path=files[i]
                    if p._comp and p._comp._alive:
                        loop=str(1 if "loop" in path.lower() else 0)
                        url="file://"+path
                        def _do_play(u=url,l=loop,n=nm):
                            # Убедиться что vrma либа загружена
                            import json as _j
                            p._comp._inject_vrma_lib()
                            p._comp._js("if(window.playVrma)playVrma("+_j.dumps(u)+","+l+");")
                            p._log("vrma: "+n)
                            try: BulletinHelper.show_info("▶ "+n)
                            except Exception: pass
                        run_on_queue(_do_play)
                        try: BulletinHelper.show_info("▶ "+nm)
                        except Exception: pass
                bld.set_items(items,oc)
                bld.set_negative_button("Закрыть",lambda b,w: b.dismiss())
                bld.show()
            except Exception as e: p._log("motions menu: "+str(e))
        run_on_ui_thread(_do)

    def _do_reload(self,view=None):
        if self._comp:
            if self._comp._alive: self._comp.load_vrm()
            else: self._comp._showing=False; self._comp._hidden=False; self._comp.show()

    def _copy_t(self,text):
        def _do():
            try: AndroidUtilities.addToClipboard(text)
            except Exception: pass
            try: BulletinHelper.show_success(self.t("copied"))
            except Exception: pass
        run_on_ui_thread(_do)

    def _on_cam_preset(self, i):
        try:
            name=list(CAMERA_PRESETS.keys())[int(i)]
            if self._cam: self._cam.apply(name)
        except Exception as e: self._log("cam_preset: "+str(e))

    def _on_size_preset(self, i):
        try:
            name=list(SIZE_PRESETS.keys())[int(i)]
            p=SIZE_PRESETS[name]
            self.ss('width_dp', p['width_dp']); self.ss('height_dp', p['height_dp'])
            if self._comp and self._comp._alive:
                self._comp.resize(p['width_dp'], p['height_dp'])
        except Exception as e: self._log("size_preset: "+str(e))

    def _on_theme(self, i):
        try:
            name=list(THEMES.keys())[int(i)]; self.ss('theme',name)
            t=THEMES.get(name,THEMES['dark'])
            if self._comp and self._comp._alive:
                self._comp._js("document.body.style.background='"+t['body']+"';")
        except Exception as e: self._log("theme: "+str(e))

    def _on_idle_quotes(self, v):
        self.ss('idle_quotes', bool(v))
        if bool(v) and self._quotes: self._quotes.start()

    def _show_cam_menu(self, view=None):
        def _do():
            try:
                f=get_last_fragment(); act=f.getParentActivity() if f else None
                if not act: return
                names=list(CAMERA_PRESETS.keys())
                bld=AlertDialogBuilder(act)
                bld.set_title("📷 Пресет камеры")
                def oc(b,i): b.dismiss(); self._on_cam_preset(i)
                bld.set_items(names,oc)
                bld.set_negative_button("Отмена",lambda b,w: b.dismiss())
                bld.show()
            except Exception as e: self._log("cam_menu: "+str(e))
        run_on_ui_thread(_do)

    def _show_size_menu(self, view=None):
