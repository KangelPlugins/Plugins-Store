ойства: занято %s из %s', 'fmt_fd': 'FD: %d (%s)', 'fmt_fd_total': 'FD: %d', 'fmt_groups_header': 'Топ smaps-групп по PSS:', 'fmt_group_row': '  %s — %s (rss %s, maps %d)', 'fmt_source': 'Источник: %s', 'fmt_no_data': 'нет данных', 'src_ok': 'натив libmemmon.so (ABI %s, rev %s)', 'src_layout_drift': 'натив загружен, smaps-слой отключён (layout drift) — пересобери .so', 'src_smaps_selftest_failed': 'натив загружен, smaps-группы отключены (selftest fail)', 'src_abi_mismatch': 'ABI mismatch (.so=%s, нужно %s) — пересобери и вшей .so', 'src_no_so': '.so не вшит — вшей через embed_so_mmp.py; данных PSS/RSS/RAM/FD нет', 'src_no_ctypes': 'ctypes недоступен — ядро не загружено', 'src_error': 'ошибка загрузки .so'}}

def _get_lang():
    try:
        LocaleController = find_class('org.telegram.messenger.LocaleController')
        if LocaleController is not None:
            lc = LocaleController.getInstance()
            if lc is not None and hasattr(lc, 'getCurrentLocale'):
                locale = lc.getCurrentLocale()
                if locale is not None and hasattr(locale, 'getLanguage'):
                    if locale.getLanguage() == 'ru':
                        return 'ru'
    except Exception:
        pass
    return 'en'

def _tr(key):
    return STRINGS.get(_get_lang(), STRINGS['en']).get(key, key)

def _mode_names():
    return [_tr('mode_all'), _tr('mode_pss'), _tr('mode_rss'), _tr('mode_java'), _tr('mode_native'), _tr('mode_graphics'), _tr('mode_code'), _tr('mode_stack'), _tr('mode_ram'), _tr('mode_pss_java')]

def _fmt_bytes(n):
    try:
        n = float(n)
    except Exception:
        return '?'
    if n >= 1024 * _MB:
        return '%.2f GB' % (n / (1024 * _MB))
    if n >= 100 * _MB:
        return '%d MB' % int(n / _MB)
    return '%.1f MB' % (n / _MB)

def _runnable(fn, log=None):
    Runnable = find_class('java.lang.Runnable')

    class _R(dynamic_proxy(Runnable)):

        def __init__(self):
            super().__init__()

        def run(self):
            try:
                fn()
            except Exception as e:
                if log:
                    log('runnable err: %s' % e)
    return _R()

class MemoryMonitorEngine:

    def __init__(self, log):
        self._log = log
        self.lib = None
        self.native_ok = False
        self.smaps_ok = False
        self.state = 'no_so'
        self.abi_seen = None
        self.build_rev = None

    def _native_dir(self):
        try:
            ApplicationLoader = find_class('org.telegram.messenger.ApplicationLoader')
            ctx = ApplicationLoader.applicationContext
            d = File(ctx.getFilesDir(), 'memory_monitor_pro')
            if not d.exists():
                d.mkdirs()
            return d.getAbsolutePath()
        except Exception:
            return None

    def _extract_so(self):
        if not _SO_ARM64:
            return None
        try:
            import base64, zlib
            raw = zlib.decompress(base64.b64decode(_SO_ARM64))
            base = self._native_dir()
            if not base:
                return None
            path = os.path.join(base, _SO_NAME)
            jf = File(path)
            try:
                if jf.exists() and int(jf.length()) == len(raw):
                    return path
            except Exception:
                pass
            try:
                if jf.exists():
                    jf.setWritable(True, True)
                    jf.delete()
            except Exception:
                pass
            try:
                with open(path, 'wb') as f:
                    f.write(raw)
            except OSError as we:
                if jf.exists():
                    self._log('extract: использую существующий .so (запись недоступна: %s)' % we)
                    return path
                raise
            try:
                jf2 = File(path)
                jf2.setReadable(True, False)
                jf2.setExecutable(True, False)
            except Exception:
                pass
            return path
        except Exception as e:
            self._log('extract err: %s' % e)
            return None

    def _declare(self, lib):
        c = ctypes
        lib.mm_abi_version.restype = c.c_int32
        lib.mm_build_rev.restype = c.c_int32
        lib.mm_smaps_group_count.restype = c.c_int32
        lib.mm_smaps_field_count.restype = c.c_int32
        lib.mm_smaps_layout_version.restype = c.c_int32
        lib.mm_smaps_groups.argtypes = [c.POINTER(c.c_int64), c.c_int32]
        lib.mm_smaps_groups.restype = c.c_int32
        lib.mm_smaps_rollup.argtypes = [c.POINTER(c.c_int64), c.c_int32]
        lib.mm_smaps_rollup.restype = c.c_int32
        lib.mm_smaps_selftest.restype = c.c_int32
        lib.mm_meminfo.argtypes = [c.POINTER(c.c_int64), c.c_int32]
        lib.mm_meminfo.restype = c.c_int32
        lib.mm_statm_rss.restype = c.c_int64
        lib.mm_fd_count.restype = c.c_int32
        lib.mm_tick.argtypes = [c.POINTER(c.c_int64), c.c_int32]
        lib.mm_tick.restype = c.c_int32
        lib.mm_fd_kinds.argtypes = [c.POINTER(c.c_int64), c.c_int32]
        lib.mm_fd_kinds.restype = c.c_int32

    def load_native(self):
        if not _CTYPES_OK:
            self.state = 'no_ctypes'
            self._log('ctypes недоступен — ядро не загрузить, данных PSS/RSS/RAM/FD не будет')
            return
        if not _SO_ARM64:
            self.state = 'no_so'
            self._log('.so не вшит (_SO_ARM64 пуст) — запусти embed_so_mmp.py; без ядра данных PSS/RSS/RAM/FD нет')
            return
        try:
            path = self._extract_so()
            if not path:
                self.state = 'error'
                return
            lib = ctypes.CDLL(path)
            self._declare(lib)
            abi = int(lib.mm_abi_version())
            self.abi_seen = abi
            if abi != MM_ABI_EXPECT:
                self.state = 'abi_mismatch'
                self._log('ABI MISMATCH .so=%d, нужно %d — натив отключён, пересобери libmemmon.so' % (abi, MM_ABI_EXPECT))
                return
            try:
                self.build_rev = int(lib.mm_build_rev())
            except Exception:
                self.build_rev = None
            layout_ok = True
            try:
                if int(lib.mm_smaps_group_count()) != len(_SMAPS_GROUPS):
                    layout_ok = False
                if int(lib.mm_smaps_field_count()) != _SMAPS_FIELDS:
                    layout_ok = False
                if int(lib.mm_smaps_layout_version()) != _SMAPS_LAYOUT_VERSION:
                    layout_ok = False
            except Exception:
                layout_ok = False
            self.lib = lib
            self.native_ok = True
            self.smaps_ok = bool(layout_ok)
            if layout_ok:
                try:
                    selftest = int(lib.mm_smaps_selftest())
                except Exception:
                    selftest = -1
                if selftest <= 0:
                    self.smaps_ok = False
                    self.state = 'smaps_selftest_failed'
                    self._log('smaps selftest FAIL (%d) — группы отключены; rollup/meminfo/tick активны' % selftest)
                else:
                    self.state = 'ok'
                    self._log('натив OK: ABI=%d rev=%s selftest groups=%d' % (abi, self.build_rev, selftest))
            else:
                self.state = 'layout_drift'
                self._log('layout drift .so vs плагин — smaps-группы отключены (защита от неверной атрибуции)')
        except Exception as e:
            self.state = 'error'
            self.lib = None
            self.native_ok = False
            self._log('load_native err: %s' % e)

    def smaps_rollup(self):
        if self.native_ok and self.lib is not None:
            try:
                arr = (ctypes.c_int64 * 3)()
                if int(self.lib.mm_smaps_rollup(arr, ctypes.c_int32(3))) >= 3:
                    return {'pss': int(arr[0]), 'rss': int(arr[1]), 'swap': int(arr[2]), 'src': 'native'}
            except Exception:
                pass
        return None

    def statm_rss(self):
        if self.native_ok and self.lib is not None:
            try:
                v = int(self.lib.mm_statm_rss())
                if v > 0:
                    return v
            except Exception:
                pass
        return 0

    def meminfo(self):
        if self.native_ok and self.lib is not None:
            try:
                arr = (ctypes.c_int64 * 4)()
                if int(self.lib.mm_meminfo(arr, ctypes.c_int32(4))) >= 2:
                    return {'total': int(arr[0]), 'avail': int(arr[1]), 'swap_total': int(arr[2]), 'swap_free': int(arr[3]), 'src': 'native'}
            except Exception:
                pass
        return None

    def java_heap(self):
        try:
            rt = find_class('java.lang.Runtime').getRuntime()
            mx = int(rt.maxMemory())
            tot = int(rt.totalMemory())
            fr = int(rt.freeMemory())
            return {'used': tot - fr, 'total': tot, 'max': mx}
        except Exception:
            return None

    def native_heap(self):
        try:
            Debug = find_class('android.os.Debug')
            return {'alloc': int(Debug.getNativeHeapAllocatedSize()), 'total': int(Debug.getNativeHeapSize()), 'free': int(Debug.getNativeHeapFreeSize())}
        except Exception:
            return None

    def debug_summary(self):
        try:
            Debug = find_class('android.os.Debug')
            MemoryInfo = find_class('android.os.Debug$MemoryInfo')
            mi = MemoryInfo()
            Debug.getMemoryInfo(mi)
            out = {}
            for key in ('java-heap', 'native-heap', 'code', 'stack', 'graphics', 'private-other', 'system', 'total-pss', 'total-swap'):
                try:
                    v = mi.getMemoryStat('summary.' + key)
                    if v is not None:
                        out[key] = int(str(v)) * 1024
                except Exception:
                    pass
            return out or None
        except Exception:
            return None

    def native_tick(self):
        if not (self.native_ok and self.lib is not None):
            return None
        try:
            arr = (ctypes.c_int64 * 9)()
            if int(self.lib.mm_tick(arr, ctypes.c_int32(9))) >= 9:
                nt = {}
                if int(arr[0]) > 0 or int(arr[1]) > 0:
                    nt['pss'] = int(arr[0])
                    nt['rss'] = int(arr[1])
                    nt['swap'] = int(arr[2])
                elif int(arr[3]) > 0:
                    nt['rss'] = int(arr[3])
                if int(arr[4]) > 0:
                    nt['dev'] = {'total': int(arr[4]), 'avail': int(arr[5]), 'swap_total': int(arr[6]), 'swap_free': int(arr[7]), 'src': 'native'}
                if int(arr[8]) > 0:
                    nt['fd_total'] = int(arr[8])
                return nt or None
        except Exception:
            pass
        return None

    def smaps_groups(self):
        if self.native_ok and self.smaps_ok and (self.lib is not None):
            try:
                n = len(_SMAPS_GROUPS) * _SMAPS_FIELDS
                arr = (ctypes.c_int64 * n)()
                if int(self.lib.mm_smaps_groups(arr, ctypes.c_int32(n))) >= n:
                    out = {}
                    for i, name in enumerate(_SMAPS_GROUPS):
                        b = i * _SMAPS_FIELDS
                        out[name] = {'rss': int(arr[b]), 'pss': int(arr[b + 1]), 'swap': int(arr[b + 2]), 'n': int(arr[b + 3])}
                    return out
            except Exception:
                pass
        return None

    def fd_kinds(self):
        if not (self.native_ok and self.lib is not None):
            return None
        try:
            arr = (ctypes.c_int64 * 5)()
            if int(self.lib.mm_fd_kinds(arr, ctypes.c_int32(5))) >= 5:
                kinds = {}
                for i, name in enumerate(('file', 'socket', 'pipe', 'anon_inode', 'other')):
                    if int(arr[i]):
                        kinds[name] = int(arr[i])
                return kinds or None
        except Exception:
            pass
        return None

    def tick_snapshot(self):
        snap = {'ts': int(time.time() * 1000)}
        nt = self.native_tick()
        if nt:
            snap.update(nt)
            if 'pss' in nt:
                snap['src'] = 'native'
            elif 'rss' in nt:
                snap['src'] = 'statm'
        else:
            roll = self.smaps_rollup()
            if roll:
                snap.update({'pss': roll['pss'], 'rss': roll['rss'], 'swap': roll['swap'], 'src': roll['src']})
            else:
                v = self.statm_rss()
                if v > 0:
                    snap['rss'] = v
                    snap['src'] = 'statm'
            mi = self.meminfo()
            if mi:
                snap['dev'] = mi
            try:
                if self.native_ok and self.lib is not None:
                    fd = int(self.lib.mm_fd_count())
                    if fd > 0:
                        snap['fd_total'] = fd
            except Exception:
                pass
        jh = self.java_heap()
        if jh:
            snap['java'] = jh
        nh = self.native_heap()
        if nh:
            snap['native'] = nh
        ad = self.debug_summary()
        if ad:
            snap['andro'] = ad
        return snap

    def full_snapshot(self):
        snap = self.tick_snapshot()
        g = self.smaps_groups()
        if g:
            snap['groups'] = g
        fd = self.fd_kinds()
        if fd:
            snap['fd'] = fd
        return snap

    def source_label(self):
        return {'ok': _tr('src_ok') % (self.abi_seen, self.build_rev), 'layout_drift': _tr('src_layout_drift'), 'smaps_selftest_failed': _tr('src_smaps_selftest_failed'), 'abi_mismatch': _tr('src_abi_mismatch') % (self.abi_seen, MM_ABI_EXPECT), 'no_so': _tr('src_no_so'), 'no_ctypes': _tr('src_no_ctypes'), 'error': _tr('src_error')}.get(self.state, self.state)

    def format_details(self, snap):
        L = []
        if 'pss' in snap:
            L.append(_tr('fmt_proc_full') % (_fmt_bytes(snap['pss']), _fmt_bytes(snap.get('rss', 0)), _fmt_bytes(snap.get('swap', 0))))
        elif 'rss' in snap:
            L.append(_tr('fmt_proc_rss') % _fmt_bytes(snap['rss']))
        jh = snap.get('java')
        if jh:
            L.append(_tr('fmt_java') % (_fmt_bytes(jh['used']), _fmt_bytes(jh['total']), _fmt_bytes(jh['max'])))
        nh = snap.get('native')
        if nh:
            L.append(_tr('fmt_native') % (_fmt_bytes(nh['alloc']), _fmt_bytes(nh['total'])))
        ad = snap.get('andro')
        if ad:
            L.append('')
            L.append(_tr('fmt_andro_header'))
            names = (('java-heap', 'Java Heap'), ('native-heap', 'Native Heap'), ('code', 'Code'), ('stack', 'Stack'), ('graphics', 'Graphics'), ('private-other', 'Private Other'), ('system', 'System'), ('total-pss', 'TOTAL PSS'), ('total-swap', 'TOTAL Swap'))
            for key, label in names:
                if key in ad:
                    L.append('  %-13s %s' % (label, _fmt_bytes(ad[key])))
        dev = snap.get('dev')
        if dev and dev.get('total'):
            L.append(_tr('fmt_ram') % (_fmt_bytes(dev['total'] - dev['avail']), _fmt_bytes(dev['total']), _fmt_bytes(dev['avail'])))
            if dev.get('swap_total'):
                L.append(_tr('fmt_swap') % (_fmt_bytes(dev['swap_total'] - dev['swap_free']), _fmt_bytes(dev['swap_total'])))
        fd = snap.get('fd')
        if fd:
            total_fd = sum(fd.values())
            det = ', '.join(('%s %d' % (k, v) for k, v in sorted(fd.items(), key=lambda kv: kv[1], reverse=True)))
            L.append(_tr('fmt_fd') % (total_fd, det))
        elif snap.get('fd_total'):
            L.append(_tr('fmt_fd_total') % snap['fd_total'])
        g = snap.get('groups')
        if g:
            items = [(k, v) for k, v in g.items() if v['pss'] or v['rss']]
            items.sort(key=lambda kv: kv[1]['pss'], reverse=True)
            L.append('')
            L.append(_tr('fmt_groups_header'))
            for name, v in items[:8]:
                L.append(_tr('fmt_group_row') % (name, _fmt_bytes(v['pss']), _fmt_bytes(v['rss']), v['n']))
        L.append('')
        L.append(_tr('fmt_source') % self.source_label())
        return '\n'.join(L) if L else _tr('fmt_no_data')

class MemoryPill:

    def __init__(self, plugin, engine):
        self.plugin = plugin
        self.engine = engine
        self.views = weakref.WeakSet()
        self._lock = threading.Lock()
        self._stopped = False
        self._last_snap = None
        self._rot = 0
        self._pss_history = []
        self._update_event = threading.Event()
        self._worker = None
        self._live_gen = 0

    def attach(self, view):
        self.views.add(view)
        self.refresh_async()
        self.ensure_loop()

    def set_pill_enabled(self, enabled):
        self.plugin.set_setting('enable_pill', bool(enabled))

        def update_visibility():
            for view in list(self.views):
                try:
                    view.setVisibility(0 if enabled else 8)
                except Exception:
                    pass
        try:
            run_on_ui_thread(update_visibility)
        except Exception:
            pass
        if enabled:
            self.refresh_async()
            self.ensure_loop()

    def stop(self):
        self._stopped = True
        self._update_event.set()

    def _interval(self):
        try:
            v = int(str(self.plugin.get_setting('update_interval', '1')).strip())
        except Exception:
            v = 1
        return max(1, min(3600, v))

    def ensure_loop(self):
        with self._lock:
            if self._stopped or (self._worker is not None and self._worker.is_alive()):
                return
            self._worker = threading.Thread(target=self._worker_loop, daemon=True)
            self._worker.start()

    def _worker_loop(self):
        while not self._stopped:
            self._update_event.wait(self._interval())
            self._update_event.clear()
            if self._stopped:
                return
            try:
                if len(self.views) and self.plugin.get_setting('enable_pill', True):
                    self._do_tick()
            except Exception as e:
                self.plugin.log('refresh err: %s' % e)

    def refresh_async(self):
        self._update_event.set()
        self.ensure_loop()

    def _do_tick(self):
        if self._stopped:
            return
        snap = self.engine.tick_snapshot()
        try:
            raw = snap.get('pss')
            if raw is None:
                raw = snap.get('rss')
            if raw is not None and float(raw) > 0:
                cur = float(raw)
                now = time.monotonic()
                self._pss_history.append((now, cur))
                self._pss_history = [x for x in self._pss_history if now - x[0] <= 10.0]
                old_pss = self._pss_history[0][1]
                if cur - old_pss > 2 * _MB:
                    snap['trend'] = '▲'
                elif old_pss - cur > 2 * _MB:
                    snap['trend'] = '▼'
        except Exception:
            pass
        self._rot += 1
        self._last_snap = snap
        if self._stopped:
            return
        run_on_ui_thread(lambda: self._render_all(snap))

    def _render_all(self, snap):
        if self._stopped:
            return
        for view in list(self.views):
            try:
                self._render(view, snap)
            except Exception as e:
                self.plugin.log('render err: %s' % e)

    def _mode(self):
        try:
            return int(self.plugin.get_setting('display_mode', 0)) % len(MM_MODES)
        except Exception:
            return 0

    def _rotation_items(self, snap):
        items = []
        if 'pss' in snap:
            items.append('PSS %s' % _fmt_bytes(snap['pss']))
        if 'rss' in snap:
            items.append('RSS %s' % _fmt_bytes(snap['rss']))
        jh = snap.get('java')
        if jh:
            items.append('Java %s' % _fmt_bytes(jh['used']))
        nh = snap.get('native')
        if nh:
            items.append('NH %s' % _fmt_bytes(nh['alloc']))
        ad = snap.get('andro') or {}
        if 'graphics' in ad:
            items.append('Gfx %s' % _fmt_bytes(ad['graphics']))
        if 'code' in ad:
            items.append('Code %s' % _fmt_bytes(ad['code']))
        if 'stack' in ad:
            items.append('Stack %s' % _fmt_bytes(ad['stack']))
        dev = snap.get('dev')
        if dev and dev.get('total'):
            items.append('RAM %s/%s' % (_fmt_bytes(dev['total'] - dev['avail']), _fmt_bytes(dev['total'])))
        return items or [_tr('fmt_no_data')]

    def _text_for(self, snap):
        mode = self._mode()
        jh = snap.get('java')
        ad = snap.get('andro') or {}
        arrow = ' ' + snap['trend'] if snap.get('trend') else ''
        if mode == 0:
            items = self._rotation_items(snap)
            return items[self._rot % len(items)] + arrow
        if mode == 1:
            if 'pss' not in snap and 'rss' not in snap:
                return 'PSS ?'
            return 'PSS %s%s' % (_fmt_bytes(snap.get('pss', snap.get('rss', 0))), arrow)
        if mode == 2:
            if 'rss' not in snap:
                return 'RSS ?'
            return 'RSS %s' % _fmt_bytes(snap['rss'])
        if mode == 3:
            if not jh:
                return 'Java ?'
            return 'Java %s/%s' % (_fmt_bytes(jh['used']), _fmt_bytes(jh['max']))
        if mode == 4:
            nh = snap.get('native')
            if not nh:
                return 'NH ?'
            return 'NH %s' % _fmt_bytes(nh['alloc'])
        if mode == 5:
            return 'Gfx %s' % _fmt_bytes(ad['graphics']) if 'graphics' in ad else 'Gfx ?'
        if mode == 6:
            return 'Code %s' % _fmt_bytes(ad['code']) if 'code' in ad else 'Code ?'
        if mode == 7:
            return 'Stack %s' % _fmt_bytes(ad['stack']) if 'stack' in ad else 'Stack ?'
        if mode == 8:
            dev = snap.get('dev')
            if not dev or not dev.get('total'):
                return 'RAM ?'
            return 'RAM %s/%s' % (_fmt_bytes(dev['total'] - dev['avail']), _fmt_bytes(dev['total']))
        p = _fmt_bytes(snap['pss']) if 'pss' in snap else '?'
        j = _fmt_bytes(jh['used']) if jh else '?'
        return 'P %s · J %s%s' % (p, j, arrow)

    def _color_hex(self, snap):
        try:
            cm = int(self.plugin.get_setting('color_mode', 0))
        except Exception:
            cm = 0
        if cm == 1:
            return None
        if cm >= 2:
            return '#FFFFFF'
        try:
            warn = float(str(self.plugin.get_setting('warn_mb', '700')))
        except Exception:
            warn = 700.0
        try:
            crit = float(str(self.plugin.get_setting('crit_mb', '1200')))
        except Exception:
            crit = 1200.0
        pss_mb = float(snap.get('pss', snap.get('rss', 0))) / _MB
        if pss_mb >= crit:
            return '#F44336'
        if pss_mb >= warn:
            return '#FF9800'
        return '#4CAF50'

    def _render(self, view, snap):
        if not self.plugin.get_setting('enable_pill', True):
            try:
                view.setVisibility(8)
            except Exception:
                pass
            return
        try:
            if int(view.getVisibility()) != 0:
                view.setVisibility(0)
        except Exception:
            pass
        tv = get_private_field(view, 'textView')
        if tv is not None:
            tv.setText(self._text_for(snap))
        iv = get_private_field(view, 'iconView')
        if iv is not None:
            try:
                ctx = view.getContext()
                res = ctx.getResources()
                icon_res = res.getIdentifier('msg_filled_datausage', 'drawable', ctx.getPackageName())
                if icon_res:
                    iv.setImageResource(icon_res)
            except Exception:
                pass
        hex_color = self._color_hex(snap)
        if hex_color:
            try:
                Color = find_class('android.graphics.Color')
                parsed = Color.parseColor(hex_color)
                if tv is not None:
                    tv.setTextColor(jint(parsed))
                if iv is not None:
                    iv.setColorFilter(jint(parsed))
            except Exception:
                pass
        else:
            try:
                if iv is not None:
                    iv.clearColorFilter()
                if tv is not None:
                    Theme = find_class('org.telegram.ui.ActionBar.Theme')
                    color = Theme.getColor(Theme.key_windowBackgroundWhiteBlackText)
                    tv.setTextColor(jint(int(color)))
            except Exception:
                pass

    def on_click(self, view):
        try:
            action = int(self.plugin.get_setting('click_action', 0))
        except Exception:
            action = 0
        if action == 1:
            self.cycle_mode()
        elif action == 2:
            self.show_details()
        else:
            self.refresh_async()

    def cycle_mode(self):
        mode = (self._mode() + 1) % len(MM_MODES)
        self.plugin.set_setting('display_mode', mode)
        self.refresh_async()

    def show_details(self):

        def work():
            try:
                snap = self.engine.full_snapshot()
                text = self.engine.format_details(snap)
            except Exception as e:
                text = '%s: %s' % (_tr('err_prefix'), e)

            def ui():
                try:
                    LaunchActivity = find_class('org.telegram.ui.LaunchActivity')
                    fragment = LaunchActivity.getSafeLastFragment()
                    if not fragment:
                        return
                    act = fragment.getParentActivity()
                    Builder = find_class('org.telegram.ui.ActionBar.AlertDialog$Builder')
                    b = Builder(act)
                    b.setTitle(_tr('live_title'))
                    tv = None
                    try:
                        TextView = find_class('android.widget.TextView')
                        ScrollView = find_class('android.widget.ScrollView')
                        AndroidUtilities = find_class('org.telegram.messenger.AndroidUtilities')
                        tv = TextView(act)
                        tv.setText(text)
                        tv.setTextSize(13.0)
                        try:
                            Theme = find_class('org.telegram.ui.ActionBar.Theme')
                            tv.setTextColor(jint(Theme.getColor(Theme.key_dialogTextBlack)))
                        except Exception:
                            pass
                        try:
                            Typeface = find_class('android.graphics.Typeface')
                            tv.setTypeface(Typeface.MONOSPACE)
                        except Exception:
                            pass
                        pad = int(AndroidUtilities.dp(16.0))
                        tv.setPadding(pad, pad, pad, pad)
                        sv = ScrollView(act)
                        sv.addView(tv)
                        b.setView(sv)
                    except Exception:
                        tv = None
                        b.setMessage(text)
                    try:
                        b.setPositiveButton(_tr('live_close'), None)
                    except Exception:
                        pass
                    dlg = b.create()
                    fragment.showDialog(dlg)
                    if tv is not None:
                        self._start_live_updates(dlg, tv)
                except Exception as e:
                    self.plugin.log('dialog err: %s' % e)
            run_on_ui_thread(ui)
        threading.Thread(target=work, daemon=True).start()

    def _start_live_updates(self, dlg, tv):
        with self._lock:
            self._live_gen += 1
            gen = self._live_gen

        def loop():
            i = 0
            while i < 36000:
                time.sleep(1.0)
                if gen != self._live_gen:
                    return
                try:
                    if self._stopped or not dlg.isShowing():
                        return
                except Exception:
                    return
                try:
                    snap = self.engine.full_snapshot()
                    text = self.engine.format_details(snap)

                    def update_ui(t=text):
                        tv.setText(t)
                        try:
                            Theme = find_class('org.telegram.ui.ActionBar.Theme')
                            tv.setTextColor(jint(Theme.getColor(Theme.key_dialogTextBlack)))
                        except Exception:
                            pass
                    run_on_ui_thread(update_ui)
                except Exception:
                    pass
                i += 1
        threading.Thread(target=loop, daemon=True).start()

    def show_menu(self, view):
        try:
            LaunchActivity = find_class('org.telegram.ui.LaunchActivity')
            fragment = LaunchActivity.getSafeLastFragment()
            if not fragment:
                return
            ItemOptions = find_class('org.telegram.ui.Components.ItemOptions')
            if not ItemOptions:
                return
            ApplicationLoader = find_class('org.telegram.messenger.ApplicationLoader')
            ctx = ApplicationLoader.applicationContext
            res = ctx.getResources()
            pkg = ctx.getPackageName()

            def icon(name):
                try:
                    return res.getIdentifier(name, 'drawable', pkg)
                except Exception:
                    return 0
            log = self.plugin.log
            plugin = self.plugin

            def open_plugin_settings():
                try:
                    from client_utils import get_last_fragment
                    from com.exteragram.messenger.plugins import PluginsController
                    PluginSettingsActivity = find_class('com.exteragram.messenger.plugins.ui.PluginSettingsActivity')
                    controller = PluginsController.getInstance()
                    plugins_map = getattr(controller, 'plugins', None)
                    java_plugin = plugins_map.get(plugin.id) if plugins_map else None
                    if java_plugin:
                        frag = get_last_fragment()
                        if frag:
                            frag.presentFragment(PluginSettingsActivity(java_plugin))
                except Exception as e:
                    log('settings err: %s' % e)

            def open_pillstack_settings():
                PillStackPreferencesActivity = find_class('com.exteragram.messenger.pillstack.ui.PillStackPreferencesActivity')
                frag = LaunchActivity.getSafeLastFragment()
                if frag and PillStackPreferencesActivity:
                    frag.presentFragment(PillStackPreferencesActivity())
            options = ItemOptions.makeOptions(fragment, view)
            options.add(jint(icon('msg_retry')), _tr('menu_refresh'), _runnable(self.refresh_async, log))
            options.add(jint(icon('msg_info')), _tr('menu_live'), _runnable(self.show_details, log))
            options.add(jint(icon('msg_stats')), _tr('menu_cycle') % _mode_names()[self._mode()], _runnable(self.cycle_mode, log))
            options.addGap()
            options.add(jint(icon('msg_settings')), _tr('menu_plugin_settings'), _runnable(open_plugin_settings, log))
            options.add(jint(icon('msg_settings')), _tr('menu_pillstack_settings'), _runnable(open_pillstack_settings, log))
            options.add(jint(icon('msg_clearcache')), _tr('menu_restart'), _runnable(self._restart_app, log))
            options.setDrawScrim(False).setDimAlpha(jint(0)).show()
        except Exception as e:
            self.plugin.log('menu err: %s' % e)

    def _restart_app(self):
        try:
            ApplicationLoader = find_class('org.telegram.messenger.ApplicationLoader')
            ctx = ApplicationLoader.applicationContext
            intent = ctx.getPackageManager().getLaunchIntentForPackage(ctx.getPackageName())
            from android.content import Intent
            intent.addFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_NEW_TASK | Intent.FLAG_ACTIVITY_CLEAR_TASK)
            ctx.startActivity(intent)
            try:
                find_class('java.lang.System').exit(jint(0))
            except Exception:
                pass
            os._exit(0)
        except Exception as e:
            self.plugin.log('restart err: %s' % e)

class MemoryMonitorProPlugin(BasePlugin):

    def __init__(self):
        super().__init__()
        self.engine = None
        self.pill = None

    def on_plugin_load(self):
        self.engine = MemoryMonitorEngine(self.log)
        self.engine.load_native()
        self.pill = MemoryPill(self, self.engine)
        self._register_pill()

    def on_plugin_unload(self):
        try:
            if self.pill:
                self.pill.stop()
        except Exception:
            pass
        super().on_plugin_unload()

    def _register_pill(self):
        PillRegistry = find_class('com.exteragram.messenger.pillstack.core.PillRegistry')
        PillInfo = find_class('com.exteragram.messenger.pillstack.core.PillRegistry$PillInfo')
        PillCreator = find_class('com.exteragram.messenger.pillstack.core.PillRegistry$PillCreator')
        PillStackConfig = find_class('com.exteragram.messenger.pillstack.core.PillStackConfig')
        WeatherPill = find_class('com.exteragram.messenger.pillstack.ui.pills.weather.WeatherPill')
        ApplicationLoader = find_class('org.telegram.messenger.ApplicationLoader')
        if not (PillRegistry and PillInfo and PillCreator and WeatherPill):
            self.log('Pill Stack API не найден — виджет не зарегистрирован')
            return
        TAG_KEY = jint(MM_TAG_VALUE)
        plugin = self
        pill = self.pill

        class MemoryPillCreator(dynamic_proxy(PillCreator)):

            def __init__(self):
                super().__init__()

            def create(self, context, resourcesProvider):
                try:
                    host = WeatherPill(context, resourcesProvider)
                    host.setTag(TAG_KEY, jint(MM_PILL_ID))
                    pill.attach(host)
                    return host
                except Exception as e:
                    plugin.log('create err: %s' % e)
                    return None

        class GetIdHook(MethodHook):

            def before_hooked_method(self, param):
                try:
                    tag = param.thisObject.getTag(TAG_KEY)
                    if tag and int(tag) == MM_PILL_ID:
                        pill.views.add(param.thisObject)
                        param.setResult(jint(MM_PILL_ID))
                except Exception:
                    pass

        class InteractionHook(MethodHook):

            def before_hooked_method(self, param):
                try:
                    tag = param.thisObject.getTag(TAG_KEY)
                    if not (tag and int(tag) == MM_PILL_ID):
                        return
                    name = param.method.getName()
                    if name == 'onPillClicked':
                        pill.on_click(param.thisObject)
                        param.setResult(None)
                    elif name == 'onPillLongClicked':
                        pill.show_menu(param.thisObject)
                        param.setResult(True)
                    elif name in ('onUpdateData', 'setData'):
                        param.setResult(None)
                except Exception:
                    pass
        try:
            ctx = ApplicationLoader.applicationContext
            res = ctx.getResources()
            icon_res = res.getIdentifier('msg_filled_datausage', 'drawable', ctx.getPackageName())
            info = PillInfo(jint(MM_PILL_ID), 'Memory Monitor Pro', jint(icon_res), jint(-11565578), jint(-13276952), MemoryPillCreator())
            PillRegistry.register(info)
            self.hook_all_methods(WeatherPill, 'getPillId', GetIdHook())
            self.hook_all_methods(WeatherPill, 'onPillClicked', InteractionHook())
            self.hook_all_methods(WeatherPill, 'onPillLongClicked', InteractionHook())
            self.hook_all_methods(WeatherPill, 'onUpdateData', InteractionHook())
            self.hook_all_methods(WeatherPill, 'setData', InteractionHook())
            if PillStackConfig:
                active = PillStackConfig.activePills
                is_active = False
                for i in range(active.size()):
                    if int(active.get(i)) == MM_PILL_ID:
                        is_active = True
                        break
                if not is_active:
                    active.add(jint(MM_PILL_ID))
                    PillStackConfig.savePillsLayout()
                    run_on_ui_thread(PillStackConfig.notifySettingsChanged)
            self.log('Memory Monitor Pro v%s зарегистрирован (id=%d); %s' % (__version__, MM_PILL_ID, self.engine.source_label()))
        except Exception as e:
            self.log('ошибка регистрации виджета: %s' % e)

    def _set_num_setting(self, key, value, default, lo, hi):
        raw = str(value or '').replace(',', '.').split('.')[0]
        digits = ''.join((ch for ch in raw if ch.isdigit()))
        try:
            n = int(digits) if digits else int(default)
        except Exception:
            n = int(default)
        n = max(int(lo), min(int(hi), n))
        self.set_setting(key, str(n), reload_settings=True)

    def _show_num_dialog(self, key, title, default, lo, hi, on_saved=None):
        try:
            from client_utils import get_last_fragment
            from ui.alert import AlertDialogBuilder
            from android.widget import EditText, LinearLayout
            from android.text import InputType, InputFilter
            from android.text.method import DigitsKeyListener
            from android.view import ViewGroup
            f = get_last_fragment()
            if not f:
                return
            ctx = f.getParentActivity()
            cur = str(self.get_setting(key, str(default)))
            layout = LinearLayout(ctx)
            layout.setOrientation(LinearLayout.VERTICAL)
            layout.setPadding(48, 24, 48, 24)
            edit = EditText(ctx)
            edit.setHint(_tr('dlg_range_hint') % (int(lo), int(hi)))
            edit.setInputType(InputType.TYPE_CLASS_NUMBER)
            try:
                _Theme = find_class('org.telegram.ui.ActionBar.Theme')
                edit.setTextColor(jint(_Theme.getColor(_Theme.key_dialogTextBlack)))
                edit.setHintTextColor(jint(_Theme.getColor(_Theme.key_dialogTextHint)))
            except Exception:
                pass
            try:
                edit.setKeyListener(DigitsKeyListener.getInstance('0123456789'))
            except Exception:
                pass
            try:
                edit.setFilters([InputFilter.LengthFilter(len(str(int(hi))))])
            except Exception:
                pass
            try:
                edit.setText(cur)
                edit.setSelection(len(cur))
            except Exception:
                pass
            layout.addView(edit, LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.WRAP_CONTENT))
            builder = AlertDialogBuilder(ctx)
            builder.set_title(title)
            builder.set_view(layout)

            def on_ok(dialog, which):
                self._set_num_setting(key, str(edit.getText()), default, lo, hi)
                if on_saved:
                    try:
                        on_saved()
                    except Exception:
                        pass
                try:
                    self.notify_settings_changed()
                except Exception:
                    pass
            builder.set_positive_button(_tr('btn_save'), on_ok)
            builder.set_negative_button(_tr('btn_cancel'), None)
            builder.show()
        except Exception as e:
            self.log('num dialog err: %s' % e)

    def _edit_interval(self, view=None):

        def after():
            if self.pill:
                self.pill.refresh_async()
        self._show_num_dialog('update_interval', _tr('dlg_interval_title'), 1, 1, 3600, on_saved=after)

    def _edit_warn(self, view=None):
        self._show_num_dialog('warn_mb', _tr('dlg_warn_title'), 700, 50, 1000000)

    def _edit_crit(self, view=None):
        self._show_num_dialog('crit_mb', _tr('dlg_crit_title'), 1200, 50, 1000000)

    def create_settings(self) -> List[Any]:
        from ui.settings import Header, Switch, Selector, Divider, Text
        interval = str(self.get_setting('update_interval', '1'))
        warn = str(self.get_setting('warn_mb', '700'))
        crit = str(self.get_setting('crit_mb', '1200'))
        rows = [Header(_tr('set_header') % __version__), Switch('enable_pill', _tr('set_enable_pill'), True, on_change=lambda v: self.pill.set_pill_enabled(v) if self.pill else self.set_setting('enable_pill', v)), Text(text=_tr('set_interval_row') % interval, icon='msg_settings', on_click=self._edit_interval), Selector('display_mode', _tr('set_display_mode'), 0, _mode_names(), on_change=lambda v: self.set_setting('display_mode', v)), Selector('click_action', _tr('set_click_action'), 0, [_tr('click_refresh'), _tr('click_cycle'), _tr('click_live')], on_change=lambda v: self.set_setting('click_action', v)), Divider(), Header(_tr('set_color_header')), Selector('color_mode', _tr('set_color_mode'), 0, [_tr('color_auto'), _tr('color_system'), _tr('color_white')], on_change=lambda v: self.set_setting('color_mode', v)), Text(text=_tr('set_warn_row') % warn, icon='msg_settings', on_click=self._edit_warn), Text(text=_tr('set_crit_row') % crit, icon='msg_settings', on_click=self._edit_crit), Divider(), Text(text='@chestertech / @useful_plugins', icon='msg_info')]
        return rows