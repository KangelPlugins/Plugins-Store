from com.exteragram.messenger.utils import AppUtils # type: ignore


__id__ = 'in_app_notifications'
__name__ = 'In-App Notifications'
__icon__ = 'remusic/6'
__description__ = 'Плагин с гибкими настройками отображающий уведомления Telegram локально внутри приложения.'
__author__ = '@meeowPlugins'
__version__ = '1.0.0'


def logcat(text: Any) -> None:
    log(f'[{__id__}] {text}')


def get_list(java_values):
    java_list = ArrayList(Arrays.asList(java_values))
    py_list = list(java_list.toArray())
    if py_list:
        return py_list
    else:
        return []


def to_json(obj: Any): return AppUtils.getGson().toJson(obj)


def show_bulletin(title: str, subtitle: str, top: bool):
    last_fragment = get_last_fragment()
    if last_fragment is None:
        return

    factory = BulletinFactory.of(last_fragment)
    bulletin = factory.createSimpleBulletin(title, subtitle)
    run_on_ui_thread(lambda: bulletin.show(top))


class Runnable1(dynamic_proxy(Runnable)):
    def __init__(self, fn: Callable[[Any], None]):
        super().__init__()
        self._fn = fn

    def run(self):
        try:
            self._fn(None)
        except:
            from traceback import format_exc
            logcat(f"Error in Runnable: {format_exc()}.")


def show_bulletin_with_photo(tl_object, title: str, subtitle: str, top: bool, maxLines: int, duration: int, button_text: str, button_action: Runnable1):
    try:
        if tl_object is None:
            return

        if not isinstance(tl_object, TLRPC.User) and not isinstance(tl_object, TLRPC.Chat):
            return

        fragment = get_last_fragment()
        context = fragment.getContext()
        resource_provider = fragment.getResourceProvider()
        layout = Bulletin.TwoLineLayout(context, resource_provider)
        location = ImageLocation.getForUserOrChat(tl_object, ImageLocation.TYPE_SMALL)

        layout.imageView.setImage(
            location,
            "64_64",
            BitmapDrawable(),
            None
        )

        layout.imageView.getImageReceiver().setRoundRadius(AndroidUtilities.dp(5))

        layout.titleTextView.setText(title)
        layout.titleTextView.setSingleLine(True)
        layout.titleTextView.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
        layout.titleTextView.setMaxLines(1)
        layout.titleTextView.setEllipsize(TextUtils.TruncateAt.END)
        layout.titleTextView.setTypeface(AndroidUtilities.bold())

        layout.subtitleTextView.setText(subtitle)
        layout.subtitleTextView.setSingleLine(False)
        layout.subtitleTextView.setMaxLines(maxLines)
        layout.subtitleTextView.setEllipsize(TextUtils.TruncateAt.END)
        layout.subtitleTextView.setTextColor(Theme.getColor(Theme.key_chats_message))

        if not button_text == "" and button_action is not None:
            layout.setButton(
                Bulletin.UndoButton(context, True, resource_provider)
                .setText(button_text)
                .setUndoAction(button_action)
            )

        length = 1500 if duration == 1 else 2750
        factory = BulletinFactory.of(fragment)
        bulletin = factory.create(layout, length)
        run_on_ui_thread(lambda: bulletin.show(top))
    except:
        import traceback
        logcat(traceback.format_exc())


def get_id_from_peer(peer) -> int:
    peer_id = 0
    if peer.chat_id is not None and peer.chat_id != 0:
        peer_id = -peer.chat_id
    elif peer.user_id is not None and peer.user_id != 0:
        peer_id = peer.user_id
    elif peer.channel_id is not None and peer.channel_id != 0:
        peer_id = peer.channel_id
    return peer_id


def open_chat(tl_id: int):
    bundle = Bundle()
    bundle.putLong("chat_id", -tl_id)
    get_last_fragment().presentFragment(ChatActivity(bundle))


def open_private_messages(tl_id: int):
    bundle = Bundle()
    bundle.putLong("user_id", tl_id)
    get_last_fragment().presentFragment(ChatActivity(bundle))


def is_channel(chat) -> bool:
    return isinstance(chat, TLRPC.TL_channel) and not chat.megagroup


def is_group(chat) -> bool:
    return isinstance(chat, TLRPC.TL_chat)


