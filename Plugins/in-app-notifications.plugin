from java import jclass, dynamic_proxy #type: ignore
from java.lang.reflect import Array #type: ignore
from java.util import ArrayList, Arrays, Locale #type: ignore
from java.lang import Class, Integer, Object, Boolean, Runnable #type: ignore

from android.util import TypedValue #type: ignore
from android.os import Bundle #type: ignore
from android.graphics.drawable import BitmapDrawable #type: ignore
from android.text import TextUtils #type: ignore

from org.telegram.messenger import NotificationCenter, R, ChatObject, AndroidUtilities, ImageLocation #type: ignore
from org.telegram.ui.Components import BulletinFactory, Bulletin #type: ignore
from org.telegram.ui import ChatActivity #type: ignore
