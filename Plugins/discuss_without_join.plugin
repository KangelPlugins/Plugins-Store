from base_plugin import BasePlugin, MethodHook
from hook_utils import find_class

__id__ = "discuss_without_join"
__name__ = "DWJ"
__description__ = "Позволяет отправлять сообщения в группах, при этом не находясь в них."
__author__ = "@akresik / Claude"
__version__ = "1.0.0"
__icon__ = "TgAndroidIcons/97"

class _IsNotInChatHook(MethodHook):
 def before_hooked_method(self, param):
  if param.args and param.args[0] is not None:
   param.setResult(False)
class DiscussWithoutJoinPlugin(BasePlugin):
 def on_plugin_load(self):
  ChatObjectClass = find_class("org.telegram.messenger.ChatObject")
  if ChatObjectClass:
   self.hook_all_methods(ChatObjectClass, "isNotInChat", _IsNotInChatHook())