import base64
from base_plugin import BasePlugin
from java import jclass
from java.nio import ByteBuffer
from dalvik.system import InMemoryDexClassLoader
from org.telegram.messenger import ApplicationLoader

__id__ = "fuck_now_playing"
__name__ = "Fuck Now Playing"
__description__ = "Скрывает карточку с треком из профилей"
__author__ = "@dekma0091"
__version__ = "1.0"
__icon__ = "pixelcamera/9"
__min_version__ = "12.5.1"

ENTRY_CLASS = "dev.extera.nowplaying.NoNowPlayingBridge"


class NativeBridge:
    def __init__(self, entry_class_name):
        self.entry_class_name = entry_class_name
        self.target_class = None
        self.is_active = False

    def start(self):
        if self.is_active:
            return
        if self.target_class is None:
            ctx = ApplicationLoader.applicationContext
            if ctx is None:
                raise RuntimeError("Application context is unavailable")
            if not _DEX_BASE64:
                raise RuntimeError("Payload data is missing")
            dex_data = base64.b64decode(_DEX_BASE64)
            dex_buffer = ByteBuffer.wrap(dex_data)
            class_loader = InMemoryDexClassLoader(
                dex_buffer,
                ctx.getClassLoader(),
            )
            self.target_class = class_loader.loadClass(self.entry_class_name)
        try:
            self._invoke_static("attach")
            self.is_active = True
        except Exception as load_err:
            try:
                self._invoke_static("detach")
            except Exception as reset_err:
                self.is_active = False
                raise RuntimeError(
                    f"Bridge initialization failed: {load_err} (Reset error: {reset_err})"
                ) from reset_err
            self.is_active = False
            raise

    def stop(self):
        if self.target_class is None or not self.is_active:
            return
        self._invoke_static("detach")
        self.is_active = False

    def _invoke_static(self, method_name, *args):
        if self.target_class is None:
            raise RuntimeError("Target class reference is null")
        methods = []
        for method in self.target_class.getDeclaredMethods():
            if str(method.getName()) == method_name and len(method.getParameterTypes()) == len(args):
                method.setAccessible(True)
                methods.append(method)
        if not methods:
            raise RuntimeError(f"Static method not found: {method_name}")
        if len(methods) > 1:
            raise RuntimeError(f"Multiple method signature matches: {method_name}")
        return methods[0].invoke(None, *args)


class NoNowPlayingPlugin(BasePlugin):
    def __init__(self):
        super().__init__()
        self.bridge = NativeBridge(ENTRY_CLASS)

    def on_plugin_load(self):
        try:
            self.bridge.start()
        except Exception as err:
            try:
                self.bridge.stop()
            except Exception as stop_err:
                self.log(f"Stop error: {stop_err}")
            self.log(f"Start error: {err}")

    def on_plugin_unload(self):
        try:
            self.bridge.stop()
        except Exception as err:
            self.log(f"Unload error: {err}")


_DEX_BASE64 = ""
