__id__ = "neural_typing"
__name__ = "Neural Typing"
__description__ = "Входящие сообщения появляются на экране постепенно, словно их в реальном времени генерирует нейросеть (эффект стриминга ответа ИИ). Чистая косметика на вашей стороне - собеседник ничего не видит."
__version__ = "1.3"
__author__ = "@van1lLove (идея: @calm_rio)"
__min_version__ = "11.12.0"

import threading
import time
import random
import traceback

from base_plugin import BasePlugin
from android_utils import run_on_ui_thread
from ui.settings import Header, Switch, Divider, Input
from java import jclass
from java.util import ArrayList

DEFAULT_TICK_MS = 22
DEFAULT_CHARS_PER_TICK = 1
DEFAULT_MAX_LEN = 4096
DEFAULT_START_PAUSE_MS = 600
STEPS_TARGET = 60  # длинные сообщения печатаем пачками, чтобы эффект уложился
                   # примерно в это число шагов, а не тянулся минутами
CURSOR = "▍"
FRESH_WINDOW_SEC = 15  # анимируем только что пришедшие, не историю при скролле


class CellBindHook:
    def __init__(self, plugin):
        self.plugin = plugin

    def after_hooked_method(self, param):
        try:
            self.plugin.on_cell_bound(param)
        except Exception as e:
            self.plugin.log(f"[NeuralTyping] bind hook: {e}")


class NeuralTypingPlugin(BasePlugin):

    def on_plugin_load(self):
        self._hooks = []
        self._timers = {}       # msg_id -> threading.Timer
        self._done = {}         # msg_id -> True (уже анимировали)
        self._suppress = False  # гвард от рекурсии: наш rebind дёргает тот же хук
        try:
            cell_cls = jclass("org.telegram.ui.Cells.ChatMessageCell")
            self._hooks = self.hook_all_methods(
                cell_cls.getClass(), "setMessageObject", CellBindHook(self))
        except Exception as e:
            self.log(f"[NeuralTyping] hook: {e}\n{traceback.format_exc()}")

    def on_plugin_unload(self):
        for t in list(self._timers.values()):
            try:
                t.cancel()
            except Exception:
                pass
        self._timers.clear()
        hooks = self._hooks or []
        for h in (hooks if isinstance(hooks, (list, tuple)) else [hooks]):
            try:
                self.unhook_method(h)
            except Exception:
                pass
        self._hooks = []

    def _int_setting(self, key, default, lo, hi):
        try:
            return max(lo, min(hi, int(self.get_setting(key, str(default)))))
        except Exception:
            return default

    def _snapshot_entities(self, mo):
        # запоминаем entities (жирный, цитата, код, ссылки, кастом-эмодзи) с их
        # исходными offset/length — при печати будем обрезать их под длину текста
        out = []
        try:
            ents = mo.messageOwner.entities
            if ents is not None:
                for i in range(ents.size()):
                    e = ents.get(i)
                    out.append((e, int(e.offset), int(e.length)))
        except Exception:
            pass
        return out

    def _set_entities(self, mo, anim, n):
        # оставляем только entities, попадающие в первые n символов, и обрезаем
        # их длину — иначе applyNewText наложит форматирование мимо текста
        ents = anim.get("entities")
        if not ents:
            return
        try:
            lst = ArrayList()
            for e, off, ln in ents:
                if n is None:                 # None → полный оригинал
                    e.length = ln
                    lst.add(e)
                elif off < n:
                    e.length = min(ln, n - off)
                    lst.add(e)
            mo.messageOwner.entities = lst
        except Exception:
            pass

    # ---- запуск анимации при появлении сообщения --------------------------

    def on_cell_bound(self, param):
        if self._suppress or not self.get_setting("enabled", True):
            return
        args = list(param.args or [])
        mo = args[0] if args else None
        if mo is None:
            return
        try:
            msg_id = int(mo.getId())
            if msg_id <= 0 or msg_id in self._done or mo.isOutOwner():
                return
            if self.get_setting("only_private", False) and int(mo.getDialogId()) < 0:
                return
            date = int(getattr(mo.messageOwner, "date", 0) or 0)
            if time.time() - date > FRESH_WINDOW_SEC:
                return
            full_cs = mo.messageText
            full = str(full_cs or "")
            if len(full) < 2 or len(full) > self._int_setting("max_len", DEFAULT_MAX_LEN, 10, 4096):
                return
            entities = self._snapshot_entities(mo)
        except Exception:
            return

        self._done[msg_id] = True
        if len(self._done) > 500:
            for k in list(self._done)[:250]:
                self._done.pop(k, None)

        # для длинных сообщений увеличиваем шаг, но не быстрее заданного
        base = self._int_setting("chars_per_tick", DEFAULT_CHARS_PER_TICK, 1, 50)
        step_chars = max(base, -(-len(full) // STEPS_TARGET))
        anim = {
            "mo": mo,
            "cell": param.thisObject,
            "args": args,
            "full": full,
            "pos": step_chars,
            "msg_id": msg_id,
            "step_chars": step_chars,
            "entities": entities,
        }
        # сразу усекаем текст прямо в момент привязки — иначе на кадр мелькнёт
        # полное сообщение до первого тика таймера
        try:
            self._apply_text(mo, anim, step_chars)
            self._redraw(anim["cell"], anim)
        except Exception:
            pass
        self._schedule(anim)

    def _schedule(self, anim):
        # стиль DeepSeek: первые символы появились — пауза, потом ровная печать
        if (anim["pos"] > 0 and not anim.get("start_pause_done")
                and self.get_setting("start_pause", False)):
            anim["start_pause_done"] = True
            tick = self._int_setting("start_pause_ms", DEFAULT_START_PAUSE_MS, 100, 3000) / 1000.0
        else:
            tick = self._int_setting("tick_ms", DEFAULT_TICK_MS, 10, 500) / 1000.0
            # живая скорость: неравномерный интервал, как у настоящего стриминга
            if self.get_setting("jitter", True):
                tick *= random.uniform(0.55, 1.6)
        t = threading.Timer(tick, lambda: run_on_ui_thread(lambda: self._step(anim)))
        t.daemon = True
        self._timers[anim["msg_id"]] = t
        t.start()

    # ---- подмена текста ---------------------------------------------------
    # applyNewText + resetLayout — способ (как у переводчиков) заменить текст в
    # существующем сообщении и заставить ячейку перерисоваться; просто присвоить
    # messageText недостаточно, ячейка держит закешированную раскладку.

    def _apply_text(self, mo, anim, n):
        # entities (форматирование) обрезаем под n символов, потом ставим текст
        self._set_entities(mo, anim, n)
        prefix = anim["full"][:n]
        payload = prefix + CURSOR if self.get_setting("cursor", True) else prefix
        mo.applyNewText(payload)
        try:
            mo.resetLayout()
        except Exception:
            pass

    def _restore_text(self, mo, anim):
        self._set_entities(mo, anim, None)  # вернуть полные entities
        try:
            mo.applyNewText()  # без аргумента — оригинал с entities и эмодзи
        except Exception:
            try:
                mo.applyNewText(anim["full"])
            except Exception:
                pass
        try:
            mo.resetLayout()
        except Exception:
            pass

    def _redraw(self, cell, anim):
        self._suppress = True
        try:
            cell.setMessageObject(*anim["args"])
        except Exception:
            pass
        finally:
            self._suppress = False
        try:
            cell.requestLayout()
            cell.invalidate()
        except Exception:
            pass

    def _step(self, anim):
        self._timers.pop(anim["msg_id"], None)
        mo = anim["mo"]
        cell = anim["cell"]
        try:
            # при скролле ячейку могли перепривязать к другому сообщению
            cur = cell.getMessageObject()
            alive = cur is not None and int(cur.getId()) == anim["msg_id"]

            anim["pos"] += anim["step_chars"]
            if not alive or anim["pos"] >= len(anim["full"]):
                self._restore_text(mo, anim)
                if alive:
                    self._redraw(cell, anim)
                return

            self._apply_text(mo, anim, anim["pos"])
            self._redraw(cell, anim)
            self._schedule(anim)
        except Exception as e:
            self._restore_text(mo, anim)
            self.log(f"[NeuralTyping] step: {e}")

    # ---- настройки --------------------------------------------------------

    def create_settings(self):
        return [
            Header(text="Neural Typing"),
            Switch(key="enabled", text="Включено", default=True),
            Switch(key="cursor", text="Курсор при печати",
                   subtext=f"Показывать «{CURSOR}» в конце появляющегося текста", default=True),
            Switch(key="jitter", text="Живая скорость",
                   subtext="Неравномерный интервал печати — выглядит как настоящий стриминг ИИ, "
                           "а не механически ровно", default=True),
            Switch(key="only_private", text="Только личные чаты",
                   subtext="Не анимировать сообщения в группах и каналах", default=False),
            Switch(key="start_pause", text="Пауза после первых символов",
                   subtext="Первые символы появляются, короткая пауза — и дальше ровная печать (как у DeepSeek)",
                   default=False),
            Input(key="start_pause_ms", text="Длительность паузы (мс)",
                  default=str(DEFAULT_START_PAUSE_MS),
                  subtext="Пауза после первых символов, 100–3000 мс"),
            Divider(),
            Input(key="chars_per_tick", text="Символов за шаг",
                  default=str(DEFAULT_CHARS_PER_TICK),
                  subtext="Сколько символов появляется за один шаг (1–50)"),
            Input(key="tick_ms", text="Интервал шага (мс)",
                  default=str(DEFAULT_TICK_MS),
                  subtext="Пауза между шагами, 10–500 мс — меньше значит плавнее"),
            Input(key="max_len", text="Максимальная длина",
                  default=str(DEFAULT_MAX_LEN),
                  subtext="Сообщения длиннее не анимируются (по умолчанию 4096 — максимум Telegram)"),
        ]
