_TGWS_CFPROXY_S = "".join(chr(c) for c in (46, 99, 111, 46, 117, 107))
def _tgws_dd(s):
    try:
        ss = str(s or "")
    except Exception:
        return s
    if not ss.endswith(".com"):
        return ss
    p = ss[:-4]
    try:
        n = sum(1 for c in p if ("a" <= c <= "z") or ("A" <= c <= "Z"))
    except Exception:
        n = 0
    out = []
    for c in p:
        o = ord(c)
        if 97 <= o <= 122:
            out.append(chr((o - 97 - n) % 26 + 97))
        elif 65 <= o <= 90:
            out.append(chr((o - 65 - n) % 26 + 65))
        else:
            out.append(c)
    return "".join(out) + _TGWS_CFPROXY_S
def _tgws_fetch_cfproxy_domains():
    try:
        url = str(CFPROXY_DOMAINS_URL) + "?" + "".join(random.choices("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ", k=7))
        r = requests.get(url, timeout=10, headers={"User-Agent": "tg-ws-proxy"})
        if getattr(r, "status_code", 0) != 200:
            return []
        text = str(getattr(r, "text", "") or "")
        raw = []
        for line in text.splitlines():
            s = str(line or "").strip()
            if not s:
                continue
            if s.startswith("#"):
                continue
            raw.append(s)
        out = []
        seen = set()
        for d in raw:
            dd = _tgws_dd(d)
            if dd and dd not in seen:
                seen.add(dd)
                out.append(dd)
        return out
    except Exception:
        return []
_tgws_cf_refresh_stop = threading.Event()
def _tgws_start_cfproxy_domain_refresh(on_update):
    global _tgws_cf_refresh_stop
    try:
        _tgws_cf_refresh_stop.set()
    except Exception:
        pass
    _tgws_cf_refresh_stop = threading.Event()
    stop = _tgws_cf_refresh_stop
    try:
        defaults = [_tgws_dd(d) for d in list(_TGWS_CFPROXY_ENC)]
    except Exception:
        defaults = []
    try:
        if callable(on_update):
            on_update(defaults)
    except Exception:
        pass
    def _loop():
        try:
            first_delay = max(0.0, float(TGWS_CF_REFRESH_DELAY_SEC))
        except Exception:
            first_delay = 25.0
        if stop.wait(timeout=first_delay):
            return
        try:
            pool = _tgws_fetch_cfproxy_domains()
            if pool and callable(on_update):
                on_update(pool)
        except Exception:
            pass
        while not stop.wait(timeout=3600):
            try:
                pool = _tgws_fetch_cfproxy_domains()
                if pool and callable(on_update):
                    on_update(pool)
            except Exception:
                continue
    threading.Thread(target=_loop, daemon=True, name="tgws-cfproxy-refresh").start()
