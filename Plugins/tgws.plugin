def _tgws_embedded_dex_dir():
    try:
        if jclass is not None:
            ctx = jclass("org.telegram.messenger.ApplicationLoader").applicationContext
            if ctx is not None:
                root = str(ctx.getFilesDir().getAbsolutePath())
                path = os.path.join(root, "tgws")
                os.makedirs(path, exist_ok=True)
                return path
    except Exception:
        pass
    path = os.path.join(os.path.expanduser("~"), ".tgws")
    try:
        os.makedirs(path, exist_ok=True)
    except Exception:
        pass
    return path
def _tgws_extract_embedded_dex():
    try:
        raw = base64.b64decode(TGWS_EMBEDDED_DEX_B64)
        path = os.path.join(_tgws_embedded_dex_dir(), TGWS_EMBEDDED_DEX_NAME)
        try:
            if os.path.exists(path) and os.path.getsize(path) == len(raw):
                return path
        except Exception:
            pass
        with open(path, "wb") as f:
            f.write(raw)
        return path
    except Exception:
        return ""
