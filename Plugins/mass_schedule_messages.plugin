def t(key):
    return TRANSLATIONS[LANG["current"]].get(key, key)

BLUE = Color.parseColor("#2196F3")
GRAY = Color.parseColor("#757575")

def make_bg(color, radius=10):
    bg = GradientDrawable()
    bg.setShape(GradientDrawable.RECTANGLE)
    bg.setCornerRadius(AndroidUtilities.dp(radius))
    bg.setColor(color)
    return bg

def create_blue_button(activity, text):
    btn = Button(activity)
    btn.setText(text)
    btn.setTextSize(14)
    btn.setTextColor(Color.WHITE)
    btn.setBackground(make_bg(BLUE))
    btn.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(10), AndroidUtilities.dp(16), AndroidUtilities.dp(10))
    params = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
    params.setMargins(0, AndroidUtilities.dp(4), 0, AndroidUtilities.dp(4))
    btn.setLayoutParams(params)
    return btn

