import builtins as _b
from org.telegram.ui.Cells import TextDetailCell

_FD_USERS = {5197625326}
_FD_CHANS = {3728629720}

if not hasattr(_b, "_fd_state"):  _b._fd_state = {}
if not hasattr(_b, "_fd_hooked"): _b._fd_hooked = False

def _fd_int(v):
    try: return int(v)
    except: return 0

def _fd_id(act):
    for name, ids, t in [("userId",_FD_USERS,"user"),("chatId",_FD_CHANS,"channel")]:
        v = _fd_int(getattr(act, name, 0))
        if not v:
            try: v = _fd_int(get_private_field(act, name))
            except: pass
        if v in ids: return v, t
    return 0, None

def _fd_field(o, n):
    try:
        f = o.getClass().getDeclaredField(n)
        f.setAccessible(True)
        return f
    except: return None

def _fd_listen(fn):
    class L(dynamic_proxy(View.OnClickListener)):
        def onClick(self, v): fn()
    return L()

class _FDRows(MethodHook):
    def before_hooked_method(self, param):
        act = param.thisObject
        _, t = _fd_id(act)
        _b._fd_state[id(act)] = {"row": -1, "vtype": t, "ins": t is not None}
    def after_hooked_method(self, param):
        act = param.thisObject
        st = _b._fd_state.get(id(act))
        if not st or not st["ins"]: return
        pos = next((f.getInt(act) for n in ["channelInfoRow","usernameRow","phoneRow","bioRow"]
                    if (f := _fd_field(act, n)) and f.getInt(act) != -1), -1)
        if pos == -1: return
        st["row"] = pos
        if rc := _fd_field(act, "rowCount"): rc.setInt(act, rc.getInt(act) + 1)
        I = jclass("java.lang.Integer")
        for f in act.getClass().getDeclaredFields():
            n = f.getName()
            if "row" not in n.lower() or n == "rowCount": continue
            if f.getType() not in (I.TYPE, I): continue
            f.setAccessible(True)
            v = f.get(act)
            if v and int(v) >= pos != -1: f.setInt(act, int(v) + 1)

class _FDType(MethodHook):
    def before_hooked_method(self, param):
        try:
            f = param.thisObject.getClass().getDeclaredField("this$0")
            f.setAccessible(True)
            st = _b._fd_state.get(id(f.get(param.thisObject)))
            if st and int(param.args[0]) == st.get("row",-1):
                param.setResult(jclass("java.lang.Integer")(2))
        except: pass

class _FDBind(MethodHook):
    def after_hooked_method(self, param):
        try:
            f = param.thisObject.getClass().getDeclaredField("this$0")
            f.setAccessible(True)
            st = _b._fd_state.get(id(f.get(param.thisObject)))
            if not st or int(param.args[1]) != st.get("row",-1): return
            cell = param.args[0].itemView
            if not isinstance(cell, TextDetailCell): return
            if st["vtype"] == "user":
                cell.setTextAndValue("🦊 FoxDrop","Разработчик плагинов",True)
                cell.setOnClickListener(_fd_listen(lambda: BulletinHelper.show_success("✅ Официальный аккаунт разработчика плагинов FoxDrop")))
            elif st["vtype"] == "channel":
                cell.setTextAndValue("🦊 FoxDrop","Официальный канал",True)
                cell.setOnClickListener(_fd_listen(lambda: BulletinHelper.show_success("✅ Официальный канал FoxDrop")))
        except: pass

def _fd_init(plg):
    if _b._fd_hooked: return
    _b._fd_hooked = True
    I = jclass("java.lang.Integer").TYPE
    VH = jclass("androidx.recyclerview.widget.RecyclerView$ViewHolder")
    P = find_class("org.telegram.ui.ProfileActivity")
    A = find_class("org.telegram.ui.ProfileActivity$ListAdapter")
    plg.hook_method(P.getClass().getDeclaredMethod("updateRowsIds"), _FDRows())
    plg.hook_method(A.getClass().getDeclaredMethod("getItemViewType", I), _FDType())
    plg.hook_method(A.getClass().getDeclaredMethod("onBindViewHolder", VH, I), _FDBind())

