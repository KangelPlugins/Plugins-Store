    btn.setTextColor(Color.WHITE)
    btn.setBackground(make_bg(color, 8))
    btn.setPadding(AndroidUtilities.dp(10), AndroidUtilities.dp(6), AndroidUtilities.dp(10), AndroidUtilities.dp(6))
    return btn

