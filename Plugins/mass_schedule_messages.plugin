            media_btn.setOnClickListener(MediaBtnClick())

            text_inputs.append(text_edit)
            media_inputs.append(media_edit)
            msgs_container.addView(row_wrap)

            idx = len(text_inputs) - 1

            class RemoveClick(dynamic_proxy(OnClickListener)):
                def onClick(self, v):
                    if len(text_inputs) <= 1:
                        return
                    msgs_container.removeView(row_wrap)
                    text_inputs.pop(idx)
                    media_inputs.pop(idx)

            remove_btn.setOnClickListener(RemoveClick())

        for entry in msg_entries:
            add_message_row(entry.get("text",""), entry.get("media",""))

        add_btn = create_blue_button(activity, t("add_msg_btn"))

        class AddMsgClick(dynamic_proxy(OnClickListener)):
            def onClick(self, v):
                add_message_row()

        add_btn.setOnClickListener(AddMsgClick())
        container.addView(add_btn)
        container.addView(create_divider(activity))

        container.addView(create_section_header(activity, t("settings_section"), "⚙️"))
        container.addView(create_spacer(activity, 6))

        container.addView(create_label(activity, t("count_label")))
        count_input = create_input_field(activity, t("count_hint"), InputType.TYPE_CLASS_NUMBER)
        if prefill:
            count_input.setText(prefill.get("count", ""))
        container.addView(count_input)
        container.addView(create_spacer(activity, 8))

        container.addView(create_label(activity, t("interval_label")))
        container.addView(create_label(activity, t("interval_fmt")))
        interval_input = create_input_field(activity, t("interval_hint"))
        if prefill:
            interval_input.setText(prefill.get("interval", ""))
        container.addView(interval_input)
        container.addView(create_spacer(activity, 8))

        container.addView(create_label(activity, t("offset_label")))
        container.addView(create_label(activity, t("offset_fmt")))
        offset_input = create_input_field(activity, t("offset_hint"))
        if prefill:
            offset_input.setText(prefill.get("offset", ""))
        container.addView(offset_input)
        container.addView(create_divider(activity))

        container.addView(create_section_header(activity, t("start_section"), "📅"))
        container.addView(create_label(activity, t("start_note")))
        container.addView(create_spacer(activity, 6))

        def make_date_label(txt, width_dp):
            lv = TextView(activity)
            lv.setText(txt)
            lv.setTextSize(11)
            lv.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
            lv.setLayoutParams(LinearLayout.LayoutParams(AndroidUtilities.dp(width_dp), LinearLayout.LayoutParams.WRAP_CONTENT))
            return lv

        date_label_row1 = LinearLayout(activity)
        date_label_row1.setOrientation(LinearLayout.HORIZONTAL)
        date_label_row1.addView(make_date_label(t("start_hint_d"), 58))
        date_label_row1.addView(make_date_label("", 12))
        date_label_row1.addView(make_date_label(t("start_hint_m"), 58))
        date_label_row1.addView(make_date_label("", 12))
        date_label_row1.addView(make_date_label(t("start_hint_y"), 78))
        container.addView(date_label_row1)

        date_row1 = LinearLayout(activity)
        date_row1.setOrientation(LinearLayout.HORIZONTAL)

        in_day   = create_small_input(activity, t("start_hint_d"),   55)
        in_month = create_small_input(activity, t("start_hint_m"),   55)
        in_year  = create_small_input(activity, t("start_hint_y"),   75)

        def make_sep(txt):
            sep = TextView(activity)
            sep.setText(txt)
            sep.setTextSize(16)
            sep.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
            sep.setPadding(0, AndroidUtilities.dp(10), AndroidUtilities.dp(4), 0)
            return sep

        date_row1.addView(in_day)
        date_row1.addView(make_sep("."))
        date_row1.addView(in_month)
        date_row1.addView(make_sep("."))
        date_row1.addView(in_year)
        container.addView(date_row1)
        container.addView(create_spacer(activity, 8))

        date_label_row2 = LinearLayout(activity)
        date_label_row2.setOrientation(LinearLayout.HORIZONTAL)
        date_label_row2.addView(make_date_label(t("start_hint_h"), 58))
        date_label_row2.addView(make_date_label("", 12))
        date_label_row2.addView(make_date_label(t("start_hint_min"), 58))
        date_label_row2.addView(make_date_label("", 12))
        date_label_row2.addView(make_date_label(t("start_hint_s"), 58))
        container.addView(date_label_row2)

        date_row2 = LinearLayout(activity)
        date_row2.setOrientation(LinearLayout.HORIZONTAL)

        in_hour  = create_small_input(activity, t("start_hint_h"),   55)
        in_min   = create_small_input(activity, t("start_hint_min"), 55)
        in_sec   = create_small_input(activity, t("start_hint_s"),   55)

        date_row2.addView(in_hour)
        date_row2.addView(make_sep(":"))
        date_row2.addView(in_min)
        date_row2.addView(make_sep(":"))
        date_row2.addView(in_sec)
        container.addView(date_row2)
        if prefill and prefill.get("start_d"): in_day.setText(prefill["start_d"])
        if prefill and prefill.get("start_m"): in_month.setText(prefill["start_m"])
        if prefill and prefill.get("start_y"): in_year.setText(prefill["start_y"])
        if prefill and prefill.get("start_h"): in_hour.setText(prefill["start_h"])
        if prefill and prefill.get("start_min"): in_min.setText(prefill["start_min"])
        if prefill and prefill.get("start_s"): in_sec.setText(prefill["start_s"])

        container.addView(create_divider(activity))

        random_cb = CheckBox(activity)
        random_cb.setText(t("random_hint"))
        random_cb.setTextSize(13)
        random_cb.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
        if prefill:
            random_cb.setChecked(prefill.get("random", False))
        container.addView(random_cb)
        container.addView(create_spacer(activity, 8))

        auto_cb = CheckBox(activity)
        auto_cb.setText(t("auto_refill_hint"))
        auto_cb.setTextSize(13)
        auto_cb.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
        if prefill:
            auto_cb.setChecked(prefill.get("auto_refill", False))
        container.addView(auto_cb)
        container.addView(make_warn_view(activity, t("auto_refill_warn")))
        container.addView(create_divider(activity))

        container.addView(create_section_header(activity, t("preview_section"), "📊"))
        container.addView(create_spacer(activity, 6))
        preview_tv = TextView(activity)
        preview_tv.setText(t("preview_default"))
        preview_tv.setTextSize(13)
        preview_tv.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
        container.addView(preview_tv)
        container.addView(create_spacer(activity, 12))

        def update_preview():
            try:
                c  = str(count_input.getText().toString()).strip()
                iv = str(interval_input.getText().toString()).strip()
                of = str(offset_input.getText().toString()).strip()
                count    = int(c) if c else 0
                interval = parse_interval(iv)
                if count <= 0 or not interval:
                    preview_tv.setText(t("preview_default"))
                    return
                offset = 0 if of == "-" else (parse_interval(of) or 0)
                lines = []
                for i in range(min(3, count)):
                    ts = interval * (i + 1) + offset * i
                    lines.append(f"  {i+1}. → {t('in')} {format_seconds(ts)}")
                if count > 3:
                    lines.append("  ...")
                    i = count - 1
                    ts = interval * (i + 1) + offset * i
                    lines.append(f"  {count}. → {t('in')} {format_seconds(ts)}")
                preview_tv.setText("\n".join(lines))
            except:
                preview_tv.setText(t("preview_default"))

        count_input.addTextChangedListener(SimpleTextWatcher(update_preview))
        interval_input.addTextChangedListener(SimpleTextWatcher(update_preview))
        offset_input.addTextChangedListener(SimpleTextWatcher(update_preview))
        if prefill:
            update_preview()

        def snap():
            msgs = []
            for i in range(len(text_inputs)):
                try:
                    msgs.append({
                        "text":  str(text_inputs[i].getText().toString()),
                        "media": str(media_inputs[i].getText().toString()),
                    })
                except:
                    pass
            return {
                "msgs":        msgs,
                "count":       str(count_input.getText().toString()),
                "interval":    str(interval_input.getText().toString()),
                "offset":      str(offset_input.getText().toString()),
                "random":      random_cb.isChecked(),
                "auto_refill": auto_cb.isChecked(),
                "start_d":     str(in_day.getText().toString()),
                "start_m":     str(in_month.getText().toString()),
                "start_y":     str(in_year.getText().toString()),
                "start_h":     str(in_hour.getText().toString()),
                "start_min":   str(in_min.getText().toString()),
                "start_s":     str(in_sec.getText().toString()),
            }

        lang_btn.setOnClickListener(LangClick(self, dialog_id, activity, snap))

        scroll = ScrollView(activity)
        scroll.addView(container)
        builder.set_view(scroll)

        def on_schedule(dialog, which):
            try:
                msgs = []
                for i in range(len(text_inputs)):
                    txt   = str(text_inputs[i].getText().toString()).strip()
                    media = str(media_inputs[i].getText().toString()).strip()
                    if txt or media:
                        msgs.append({"text": txt, "media": media if media else None})

                if not msgs:
                    return

                c  = str(count_input.getText().toString()).strip()
                iv = str(interval_input.getText().toString()).strip()
                of = str(offset_input.getText().toString()).strip()
                if not c or not iv:
                    return
                count    = int(c)
                interval = parse_interval(iv)
                offset   = 0 if of == "-" else (parse_interval(of) or 0)
                if count <= 0 or not interval:
                    return
                is_random   = random_cb.isChecked()
                auto_refill = auto_cb.isChecked()

                d   = str(in_day.getText().toString()).strip()
                m   = str(in_month.getText().toString()).strip()
                y   = str(in_year.getText().toString()).strip()
                h   = str(in_hour.getText().toString()).strip()
                mi  = str(in_min.getText().toString()).strip()
                s   = str(in_sec.getText().toString()).strip()
                start_ts, start_label = parse_start_date(d, m, y, h, mi, s)

                if start_ts == -1:
                    BulletinHelper.show_error(t("invalid_date"))
                    return

                dialog.dismiss()
                self.show_confirmation(activity, dialog_id, msgs, count, interval, offset, is_random, auto_refill, start_ts, start_label)
            except Exception as e:
                log(f"on_schedule error: {e}")

        builder.set_positive_button(t("btn_schedule"), on_schedule)
        builder.set_negative_button(t("btn_cancel"), lambda d, w: d.dismiss())
        builder.show()

    def show_confirmation(self, activity, dialog_id, msgs, count, interval, offset, is_random, auto_refill, start_ts, start_label):
        builder = AlertDialogBuilder(activity)
        builder.set_title(t("confirm_title"))

        lines = []
        lines.append(t("confirm_msgs").format(count=len(msgs)))
        lines.append(t("confirm_sends").format(sends=count))
        lines.append(t("confirm_interval").format(interval=format_seconds(interval)))
        if offset:
            lines.append(f"Offset: +{format_seconds(offset)}/msg")
        if start_label:
            lines.append(t("confirm_start").format(dt=start_label))
        else:
            lines.append(t("confirm_start_now"))
        lines.append(t("confirm_random") if is_random else t("confirm_seq"))
        lines.append("")
        for i, m in enumerate(msgs[:3]):
            preview = m["text"][:40] + "..." if len(m["text"]) > 40 else m["text"]
            media_str = " + 📎" if m.get("media") else ""
            lines.append(f"  {i+1}. {preview or '📎'}{media_str}")
        if len(msgs) > 3:
            lines.append(f"  ... +{len(msgs)-3} more")

        builder.set_message("\n".join(lines))

        def on_publish(dialog, which):
            dialog.dismiss()
            BulletinHelper.show_info(t("bulletin_start").format(count=count))
            run_on_queue(lambda: self._do_schedule(dialog_id, msgs, count, interval, offset, is_random, auto_refill, start_ts), PLUGINS_QUEUE)

        def on_edit(dialog, which):
            dialog.dismiss()
            self.show_schedule_dialog(
                {"dialog_id": dialog_id},
                prefill={
                    "msgs": msgs, "count": str(count),
                    "interval": format_seconds(interval),
                    "offset": "-" if offset == 0 else format_seconds(offset),
                    "random": is_random, "auto_refill": auto_refill,
                }
            )

        builder.set_positive_button(t("btn_publish"), on_publish)
        builder.set_negative_button(t("btn_edit"), on_edit)
        builder.show()

    def _do_schedule(self, dialog_id, msgs, count, interval, offset, is_random, auto_refill, start_ts):
        try:
            base = start_ts if start_ts else int(time.time())
            ok, fail = 0, 0

            for i in range(count):
                try:
                    ts = base + interval * (i + 1) + offset * i

                    if is_random:
                        msg = random.choice(msgs)
                    else:
                        msg = msgs[i % len(msgs)]

                    text  = msg.get("text", "")
                    media = msg.get("media")

                    self._send_one(dialog_id, text, media, ts)
                    ok += 1

                    if auto_refill:
                        ei  = count + i
                        ets = base + interval * (ei + 1) + offset * ei
                        refill_msg = random.choice(msgs) if is_random else msgs[ei % len(msgs)]
                        self._send_one(dialog_id, refill_msg.get("text",""), refill_msg.get("media"), ets)

                    if (i + 1) % 10 == 0:
                        log(f"✅ {i+1}/{count}")
                    time.sleep(0.5)
                except Exception as e:
                    fail += 1
                    log(f"❌ msg {i+1}: {e}")

            log(f"✅ Done! {ok} ok, {fail} failed")
            if fail:
                BulletinHelper.show_error(t("bulletin_fail").format(ok=ok, fail=fail))
            else:
                BulletinHelper.show_success(t("bulletin_done").format(ok=ok))
        except Exception as e:
            log(f"❌ Error: {e}")
            BulletinHelper.show_error(t("bulletin_error").format(e=e))

    def _send_one(self, dialog_id, text, media, ts):
        if media and os.path.exists(media):
            mtype = get_media_type(media)
            if mtype == "photo":
                send_photo(dialog_id, media, caption=text, scheduleDate=ts)
            elif mtype == "video":
                send_video(dialog_id, media, caption=text, scheduleDate=ts)
            else:
                send_document(dialog_id, media, caption=text, scheduleDate=ts)
        elif text:
            send_text(dialog_id, text, scheduleDate=ts)


def create_plugin():
    return MassSchedulePlugin()
