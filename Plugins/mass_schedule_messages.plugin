def parse_interval(s):
    if not s:
        return None
    s = s.strip()
    if s == "-":
        return 0
    import re
    pattern = re.compile(r'(\d+)\s*([hHчЧmMмМsScCсС])')
    matches = pattern.findall(s)
    if not matches:
        return None
    total = 0
    for val, unit in matches:
        val = int(val)
        unit = unit.lower()
        if unit in ('h', 'ч'):
            total += val * 3600
        elif unit in ('m', 'м'):
            total += val * 60
        elif unit in ('s', 'с', 'c'):
            total += val
    return total if total > 0 else None

def format_seconds(secs):
    if not secs or secs <= 0:
        return "0s"
    h = secs // 3600
    m = (secs % 3600) // 60
    s = secs % 60
    parts = []
    if h: parts.append(f"{h}h")
    if m: parts.append(f"{m}m")
    if s: parts.append(f"{s}s")
    return " ".join(parts)

def get_media_type(path):
    ext = path.lower().rsplit(".", 1)[-1] if "." in path else ""
    if ext in ("jpg", "jpeg", "png", "webp", "heic", "gif"):
        return "photo"
    if ext in ("mp4", "mov", "avi", "mkv", "webm"):
        return "video"
    return "document"

def parse_start_date(d, m, y, h, mi, s=0):
    try:
        d = int(d) if d else None
        m = int(m) if m else None
        y = int(y) if y else None
        h = int(h) if h else 0
        mi = int(mi) if mi else 0
        s = int(s) if s else 0
        if d is None and m is None and y is None:
            return None, None
        now = datetime.datetime.now()
        y = y if y else now.year
        m = m if m else now.month
        d = d if d else now.day
        dt = datetime.datetime(y, m, d, h, mi, s)
        ts = int(dt.timestamp())
        label = dt.strftime("%d.%m.%Y %H:%M:%S")
        return ts, label
    except:
        return -1, None

class SimpleTextWatcher(dynamic_proxy(TextWatcher)):
    def __init__(self, callback):
        super().__init__()
        self.callback = callback
    def beforeTextChanged(self, s, start, count, after): pass
    def onTextChanged(self, s, start, before, count):    pass
    def afterTextChanged(self, s):
        try:
            self.callback()
        except:
            pass

class MassSchedulePlugin(BasePlugin):

    def __init__(self):
        super().__init__()

    def on_plugin_load(self):
        _fd_init(self)
        log("Mass Schedule v1.1.0 loaded!")
        self.add_menu_item(MenuItemData(
            menu_type=MenuItemType.CHAT_ACTION_MENU,
            text="Mass Schedule",
            icon="filled_add_album",
            on_click=self.show_schedule_dialog
        ))

    def on_plugin_unload(self):
        _b._fd_hooked = False
        _b._fd_state.clear()
        log("Mass Schedule unloaded!")

    def show_schedule_dialog(self, context, prefill=None):
        dialog_id = context.get("dialog_id")
        if not dialog_id:
            return

        fragment = get_last_fragment()
        activity = fragment and fragment.getParentActivity()
        if not activity:
            return

        msg_entries = []
        if prefill and prefill.get("msgs"):
            for m in prefill["msgs"]:
                msg_entries.append({"text": m.get("text",""), "media": m.get("media","")})
        else:
            msg_entries.append({"text": "", "media": ""})

        builder = AlertDialogBuilder(activity)
        builder.set_title(t("title"))

        container = LinearLayout(activity)
        container.setOrientation(LinearLayout.VERTICAL)
        container.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(12), AndroidUtilities.dp(16), AndroidUtilities.dp(12))
        container.setBackgroundColor(Theme.getColor(Theme.key_dialogBackground))

        lang_btn = create_blue_button(activity, t("lang_btn"))

        class LangClick(dynamic_proxy(OnClickListener)):
            def __init__(self, plugin, did, act, snap_fn):
                super().__init__()
                self.plugin = plugin
                self.did = did
                self.act = act
                self.snap_fn = snap_fn
            def onClick(self, v):
                snap = self.snap_fn()
                LANG["current"] = "ru" if LANG["current"] == "en" else "en"
                builder.dismiss()
                self.plugin.show_schedule_dialog({"dialog_id": self.did}, prefill=snap)

        container.addView(lang_btn)
        container.addView(create_spacer(activity, 8))
        container.addView(create_divider(activity))

        container.addView(create_section_header(activity, t("msgs_section"), "💬"))
        container.addView(create_spacer(activity, 6))

        msgs_container = LinearLayout(activity)
        msgs_container.setOrientation(LinearLayout.VERTICAL)
        container.addView(msgs_container)

        text_inputs = []
        media_inputs = []

        def add_message_row(text_val="", media_val=""):
            row_wrap = LinearLayout(activity)
            row_wrap.setOrientation(LinearLayout.VERTICAL)
            row_bg = GradientDrawable()
            row_bg.setShape(GradientDrawable.RECTANGLE)
            row_bg.setCornerRadius(AndroidUtilities.dp(10))
            row_bg.setColor(Theme.getColor(Theme.key_dialogInputField))
            row_bg.setStroke(AndroidUtilities.dp(1), Theme.getColor(Theme.key_divider))
            row_wrap.setBackground(row_bg)
            row_wrap.setPadding(AndroidUtilities.dp(10), AndroidUtilities.dp(8), AndroidUtilities.dp(10), AndroidUtilities.dp(8))
            lp = LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT)
            lp.setMargins(0, 0, 0, AndroidUtilities.dp(8))
            row_wrap.setLayoutParams(lp)

            header_row = LinearLayout(activity)
            header_row.setOrientation(LinearLayout.HORIZONTAL)
            idx_tv = TextView(activity)
            idx_tv.setText(f"#{len(text_inputs) + 1}")
            idx_tv.setTextSize(13)
            idx_tv.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
            idx_lp = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
            idx_tv.setLayoutParams(idx_lp)
            header_row.addView(idx_tv)
            remove_btn = create_small_button(activity, t("remove_btn"), GRAY)
            remove_btn.setLayoutParams(LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, LinearLayout.LayoutParams.WRAP_CONTENT))
            header_row.addView(remove_btn)
            row_wrap.addView(header_row)

            fmt_row = LinearLayout(activity)
            fmt_row.setOrientation(LinearLayout.HORIZONTAL)
            fmt_row.setPadding(0, AndroidUtilities.dp(2), 0, AndroidUtilities.dp(4))

            media_btn = Button(activity)
            media_btn.setText("🖼 Фото/Видео")
            media_btn.setTextSize(12)
            media_btn.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
            media_btn.setBackground(make_bg(Theme.getColor(Theme.key_dialogBackground), 6))
            media_btn.setLayoutParams(LinearLayout.LayoutParams(LinearLayout.LayoutParams.WRAP_CONTENT, AndroidUtilities.dp(32)))
            media_btn.setPadding(AndroidUtilities.dp(8), 0, AndroidUtilities.dp(8), 0)
            fmt_row.addView(media_btn)
            row_wrap.addView(fmt_row)

            text_edit = EditText(activity)
            text_edit.setHint(t("msg_hint"))
            text_edit.setMinLines(1)
            text_edit.setTextSize(15)
            text_edit.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
            text_edit.setHintTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteHintText))
            text_edit.setBackgroundColor(Color.TRANSPARENT)
            text_edit.setPadding(0, AndroidUtilities.dp(4), 0, AndroidUtilities.dp(4))
            if text_val:
                text_edit.setText(text_val)
            row_wrap.addView(text_edit)

            media_container = LinearLayout(activity)
            media_container.setOrientation(LinearLayout.VERTICAL)
            media_container.setVisibility(8 if not media_val else 0)

            media_label = TextView(activity)
            media_label.setText("📎 " + t("media_path_hint"))
            media_label.setTextSize(12)
            media_label.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
            media_label.setPadding(0, AndroidUtilities.dp(4), 0, AndroidUtilities.dp(2))
            media_container.addView(media_label)

            media_edit = EditText(activity)
            media_edit.setHint("/storage/emulated/0/photo.jpg")
            media_edit.setTextSize(13)
            media_edit.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
            media_edit.setHintTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteHintText))
