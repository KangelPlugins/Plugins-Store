import base64
from base_plugin import BasePlugin
from hook_utils import find_class
from java.nio import ByteBuffer
from dalvik.system import InMemoryDexClassLoader
from android_utils import run_on_ui_thread
from java.util import Locale
from client_utils import get_last_fragment
from ui.alert import AlertDialogBuilder

__id__ = "sync_powersaver"
__name__ = "Powersaver Sync"
__description__ = "Synchronizes Telegram's power saving mode with system ones"
__icon__ = "nonPlugins/1"
__author__ = "@nonPlugins"
__version__ = "1.0"
__min_version__ = "12.1.1"

STRINGS = {
    "en": {
        "plugin_obsolete": "The functionality of this plugin is already implemented in this app version.\n\nPressing \"OK\" will redirect you to the power saving settings.",
        "btn_close": "Close",
        "btn_ok": "OK"
    },
    "ru": {
        "plugin_obsolete": "Функционал этого плагина уже реализован в этой версии приложения.\n\nПри нажатии кнопки \"OK\", вас перенаправит в настройки энергосбережения.",
        "btn_close": "Закрыть",
        "btn_ok": "ОК"
    }
}


def _s(key):
    try:
        lang = Locale.getDefault().getLanguage()
        return STRINGS.get(lang, STRINGS["en"]).get(key, key)
    except Exception:
        return STRINGS["en"].get(key, key)


def get_client_version_tuple():
    try:
        BuildVars = find_class("org.telegram.messenger.BuildVars")
        if BuildVars and BuildVars.BUILD_VERSION_STRING:
            return tuple(map(int, str(BuildVars.BUILD_VERSION_STRING).split(".")))
    except Exception:
        pass
    return (0, 0, 0)



# Скомпилированный DEX, содержащий non.feature.powersaver.PowerSaveReceiver
DEX_B64 = ""

class SystemPowersaverPlugin(BasePlugin):
    def __init__(self):
        super().__init__()
        self.receiver_class = None

    def on_plugin_load(self):
        if get_client_version_tuple() >= (12, 6, 0):
            msg = _s("plugin_obsolete")
            self.log(f"[SystemPowersaver] {msg}")
            
            def _do_alert():
                try:
                    fragment = get_last_fragment()
                    host = fragment.getParentActivity() if fragment else None
                    if host is None:
                        return
                    
                    def _ok_clicked(bld, which):
                        try:
                            bld.dismiss()
                        except Exception:
                            pass
                        try:
                            LiteModeSettingsActivity = find_class("org.telegram.ui.LiteModeSettingsActivity")
                            if LiteModeSettingsActivity:
                                fragment.presentFragment(LiteModeSettingsActivity())
                        except Exception as ex:
                            self.log(f"[SystemPowersaver] Failed to open Power Saving settings: {ex}")

                    dlg = AlertDialogBuilder(host)
                    dlg.set_title("Warning" if Locale.getDefault().getLanguage() == "en" else "Предупреждение")
                    dlg.set_message(msg)
                    dlg.set_positive_button(_s("btn_ok"), _ok_clicked)
                    dlg.set_negative_button(_s("btn_close"), lambda bld, which: bld.dismiss())
                    dlg.show()
                except Exception as e:
                    self.log(f"[SystemPowersaver] Alert error: {e}")
            run_on_ui_thread(_do_alert)
            
            try:
                from com.exteragram.messenger.plugins import PluginsController
                PluginsController.getInstance().deletePlugin(__id__, None)
            except Exception as e:
                self.log(f"[SystemPowersaver] Error deleting plugin: {e}")
            return

        try:
            # Получаем контекст Android
            ApplicationLoader = find_class("org.telegram.messenger.ApplicationLoader")
            if not ApplicationLoader:
                self.log("[SystemPowersaver] ApplicationLoader class not found!")
                return
            context = ApplicationLoader.applicationContext
            if not context:
                self.log("[SystemPowersaver] Application Context is null!")
                return

            # Декодируем байты DEX
            dex_bytes = base64.b64decode(DEX_B64)

            # Проверка целостности DEX-кода (SHA-256)
            import hashlib
            EXPECTED_HASH = "9bf1c4ec57e7620490f6e5f7f5f41818275968e44485d2da1cf9d17c520dc619"
            computed_hash = hashlib.sha256(dex_bytes).hexdigest()
            if computed_hash != EXPECTED_HASH:
                self.log(f"[SystemPowersaver] Integrity check failed! Expected: {EXPECTED_HASH}, Got: {computed_hash}")
                return

            # Загружаем DEX прямо в память (без записи на диск) с помощью InMemoryDexClassLoader
            # Это полностью исключает W^X проблемы безопасности Android 14+ и ускоряет работу
            dex_buffer = ByteBuffer.wrap(dex_bytes)
            parent_cl = context.getClassLoader()
            class_loader = InMemoryDexClassLoader(dex_buffer, parent_cl)
            
            receiver_class = class_loader.loadClass("non.feature.powersaver.PowerSaveReceiver")
            if not receiver_class:
                self.log("[SystemPowersaver] Loaded receiver class is null!")
                return

            # Регистрируем приёмник через вызов статического метода Java
            # Это исключает возврат инстанса PowerSaveReceiver в Python, обходя ошибку прокси Chaquopy
            register_method = receiver_class.getMethod("register", find_class("android.content.Context"))
            register_method.invoke(None, context)
            self.receiver_class = receiver_class
            
            self.log("[SystemPowersaver] Native Java System Power Saver loaded.")
        except Exception as e:
            self.log(f"[SystemPowersaver] Error on load: {e}")

    def on_plugin_unload(self):
        try:
            if hasattr(self, "receiver_class") and self.receiver_class:
                ApplicationLoader = find_class("org.telegram.messenger.ApplicationLoader")
                context = ApplicationLoader.applicationContext
                if context:
                    unregister_method = self.receiver_class.getMethod("unregister", find_class("android.content.Context"))
                    unregister_method.invoke(None, context)
                    self.log("[SystemPowersaver] BroadcastReceiver unregistered successfully.")
        except Exception as e:
            self.log(f"[SystemPowersaver] Error on unload: {e}")

