    def _hk_nfl(self):
        self.nfl_sel = NFLSelectorHook(self)
        try:
            sel_m = _fm(CA_CLS, "addToSelectedMessages", 3)
            clr_m = _fm(CA_CLS, "hideActionMode", 0)
            mul_m = _fm(CA_CLS, "startMultiselect", 1)
            if sel_m:
                u = self.hook_method(sel_m, self.nfl_sel)
                if u:
                    self._unhooks.append(u)
            if clr_m:
                u = self.hook_method(clr_m, NFLClearHook(self.nfl_sel))
                if u:
                    self._unhooks.append(u)
            if mul_m:
                u = self.hook_method(mul_m, NFLMultiHook(self))
                if u:
                    self._unhooks.append(u)
            mc = get_messages_controller()
            if mc:
                for m in mc.getClass().getDeclaredMethods():
                    if str(m.getName()) == "deleteMessages" and len(m.getParameterTypes()) >= 7:
                        m.setAccessible(True)
                        u = self.hook_method(m, NFLDeleteHook())
                        if u:
                            self._unhooks.append(u)
                        break
        except Exception as e:
            log(f"[MAX] NFL: {e}")

    def _hook_ad(self):
        plugin = self
        class PromoNoOpHook(MethodHook):
            def before_hooked_method(self, param):
                try:
                    param.setResult(None)
                except Exception:
                    return
                try:
                    controller = param.thisObject
                    plugin._run_on_stage_queue(
                        lambda: plugin._cleanup_messages_controller(controller)
                    )
                except Exception:
                    pass
        class RetF(MethodHook):
            def before_hooked_method(self, param):
                param.setResult(Boolean(False))
        class VideoAdsLoadHook(MethodHook):
            def before_hooked_method(self, param):
                video_ads = param.thisObject
                try:
                    _set_field_value(video_ads, "loading", False)
                    _set_field_value(video_ads, "loaded", True)
                    ads = _get_field_value(video_ads, "ads")
                    if ads is not None:
                        try:
                            ads.clear()
                        except Exception:
                            pass
                except Exception:
                    pass
                try:
                    param.setResult(None)
                except Exception:
                    pass
        class VideoNoOp(MethodHook):
            def before_hooked_method(self, param):
                param.setResult(None)
        mc = get_messages_controller()
        if mc:
            c = mc.getClass()
            for n, pc, h in [("checkPromoInfo", 1, PromoNoOpHook()), ("checkPromoInfoInternal", 1, PromoNoOpHook()), ("isPromoDialog", 2, RetF())]:
                m = _fm(c, n, pc)
                if m:
                    u = self.hook_method(m, h)
                    if u:
                        self._unhooks.append(u)
        video_noop = VideoNoOp()
        for vmethod, vpc, vhook in [("load", 0, VideoAdsLoadHook()), ("schedule", 0, video_noop), ("show", 0, video_noop), ("isPopupShown", 0, RetF())]:
            try:
                va_cls = jclass("org.telegram.messenger.video.VideoAds").getClass()
                m = _fm(va_cls, vmethod, vpc)
                if m:
                    u = self.hook_method(m, vhook)
                    if u:
                        self._unhooks.append(u)
            except Exception:
                pass
        self._cleanup_all_accounts_soon()

    def _run_on_stage_queue(self, fn):
        try:
            Utilities.stageQueue.postRunnable(lambda: fn())
        except Exception:
            try:
                fn()
            except Exception:
                pass

    def _cleanup_all_accounts_soon(self):
        for delay in (0, 500, 2000):
            try:
                run_on_ui_thread(
                    lambda: self._run_on_stage_queue(self._cleanup_all_accounts),
                    delay,
                )
            except Exception:
                pass

    def _cleanup_all_accounts(self):
        try:
            max_accounts = int(UserConfig.MAX_ACCOUNT_COUNT)
        except Exception:
            max_accounts = 4
        for account in range(max_accounts):
            try:
                controller = MessagesController.getInstance(account)
                if controller is not None:
                    self._cleanup_messages_controller(controller)
            except Exception:
                continue

    def _cleanup_messages_controller(self, controller):
        if controller is None:
            return
        should_remove_dialog = False
        try:
            promo_dialog = _get_field_value(controller, "promoDialog")
            promo_dialog_id = _int(_get_field_value(controller, "promoDialogId", 0), 0)
            should_remove_dialog = promo_dialog is not None or bool(promo_dialog_id)
        except Exception:
            pass
        try:
            request_id = _int(_get_field_value(controller, "checkingPromoInfoRequestId", 0), 0)
            if request_id:
                try:
                    controller.getConnectionsManager().cancelRequest(request_id, True)
                except Exception:
                    pass
            _set_field_value(controller, "checkingPromoInfoRequestId", 0)
        except Exception:
            pass
        try:
            current_time = int(controller.getConnectionsManager().getCurrentTime())
            next_check_time = current_time + ONE_YEAR_SECONDS
            _set_field_value(controller, "checkingPromoInfo", False)
            _set_field_value(controller, "nextPromoInfoCheckTime", next_check_time)
            _set_field_value(controller, "promoDialogId", 0)
            _set_field_value(controller, "promoDialogType", 0)
            _set_field_value(controller, "proxyDialogAddress", None)
            self._clear_promo_preferences(controller, next_check_time)
        except Exception:
            pass
        if should_remove_dialog:
            try:
                run_on_ui_thread(lambda: self._cleanup_promo_dialog_on_ui(controller))
            except Exception:
                pass

    def _cleanup_promo_dialog_on_ui(self, controller):
        if controller is None:
            return
        try:
            _invoke_no_arg(controller, "removePromoDialog")
        except Exception:
            pass
        try:
            _set_field_value(controller, "promoDialog", None)
            _set_field_value(controller, "promoDialogId", 0)
            _set_field_value(controller, "promoDialogType", 0)
            _set_field_value(controller, "checkingPromoInfo", False)
            _set_field_value(controller, "checkingPromoInfoRequestId", 0)
            _set_field_value(controller, "proxyDialogAddress", None)
        except Exception:
            pass

    def _clear_promo_preferences(self, controller, next_check_time):
        seen = set()
        try:
            self._clear_promo_preferences_in(controller.getMainSettings(), next_check_time, seen)
        except Exception:
            pass
        try:
            self._clear_promo_preferences_in(
                MessagesController.getGlobalMainSettings(),
                next_check_time,
                seen,
            )
        except Exception:
            pass

    def _clear_promo_preferences_in(self, preferences, next_check_time, seen):
        if preferences is None:
            return
        try:
            key = f"{preferences.getClass().getName()}:{preferences.hashCode()}"
        except Exception:
            key = str(id(preferences))
        if key in seen:
            return
        seen.add(key)
        editor = preferences.edit()
        editor.putLong("proxy_dialog", 0)
        editor.putInt("promo_dialog_type", 0)
        editor.putInt("nextPromoInfoCheckTime", int(next_check_time))
        editor.remove("proxyDialogAddress")
        try:
            editor.commit()
        except Exception:
            editor.apply()

    def on_send_message_hook(self, account, params):
        try:
            if self._is_ghost() and self.get_setting("read_on_action", True) and self.get_setting("ghost_no_read", True):
                try:
                    did = 0
                    if hasattr(params, "peer") and params.peer:
                        did = int(params.peer)
                    if not did:
                        f = get_last_fragment()
                        if f and str(f.getClass().getSimpleName()) == "ChatActivity":
                            did = int(get_private_field(f, "dialog_id") or 0)
                    if did:
                        self._send_read_for_dialog(did)
                except Exception:
                    pass
        except Exception:
            pass
        return HookResult(strategy=HookStrategy.MODIFY, params=params)

    def on_update_hook(self, update_name, account, update):
        if update_name in PRESENCE_UPD and (self._gs("presence_track", False) or self._presence_tracked):
            try:
                self._presence_on_update(update_name, account, update)
            except Exception:
                pass
        if self._gs("save_edits", True) or self._gs("save_attachments", False):
            if update_name in ("TL_updateNewMessage", "TL_updateNewChannelMessage"):
                try:
                    msg = update.message
                    if not msg.out:
                        did = _peer_did(msg)
                        mid = int(msg.id)
                        if did and mid and self.vault:
                            if self._gs("save_edits", True):
                                self.vault.save_message_version(did, mid, msg, is_original=True)
                            if self._gs("save_attachments", False):
                                _ensure_attach_saved(msg, did, mid, _get_media_hash(msg), force_download=False)
                except Exception:
                    pass
            elif update_name in ("TL_updateEditMessage", "TL_updateEditChannelMessage"):
                try:
                    msg = update.message
                    if msg.out:
                        return HookResult()
                    did, mid = _peer_did(msg), int(msg.id)
                    if did and mid and self.vault:
                        save_att = self._gs("save_attachments", False)
                        if not self.vault.has_revisions(did, mid):
                            mo = _get_message_from_chat(did, mid)
                            if mo and mo.messageOwner:
                                old_msg = mo.messageOwner
                                if self._gs("save_edits", True):
                                    self.vault.save_message_version(did, mid, old_msg, is_original=True)
                                if save_att:
                                    _ensure_attach_saved(old_msg, did, mid, _get_media_hash(old_msg), force_download=False)
                        if self._gs("save_edits", True):
                            self.vault.save_message_version(did, mid, msg, is_original=False)
                        if save_att:
                            _ensure_attach_saved(msg, did, mid, _get_media_hash(msg), force_download=False)
                except Exception:
                    pass
        if update_name == "TL_updateDeleteMessages" and self._gs("save_deleted", True):
            try:
                mids = [int(x) for x in _jlist(update.messages)]
                if mids:
                    skip_own = self._gs("track_own_deletions", False)
                    other = [m for m in mids if not skip_own or not self._is_my_deletion(m)]
                    if other:
                        did = self._resolve_did(other, account)
                        if did and self.vault:
                            self.vault.mark_removed(did, other)
            except Exception:
                pass
        if update_name == "TL_updateDeleteChannelMessages" and self._gs("save_deleted", True):
            try:
                did = -int(update.channel_id)
                mids = [int(x) for x in _jlist(update.messages)]
                if mids:
                    skip_own = self._gs("track_own_deletions", False)
                    other = [m for m in mids if not skip_own or not self._is_my_deletion(m)]
                    if other and self.vault:
                        self.vault.mark_removed(did, other)
            except Exception:
                pass
        return HookResult()

    def pre_request_hook(self, request_name, account, request):
        if request_name in DELETE_REQS and self._vault_purging_mids:
            try:
                msgs = _jlist(getattr(request, "messages", None))
                if msgs:
                    filtered = [m for m in msgs if int(m) not in self._vault_purging_mids]
                    if not filtered:
                        return HookResult(strategy=HookStrategy.CANCEL)
                    if len(filtered) < len(msgs):
                        fl = ArrayList()
                        for m in filtered:
                            fl.add(m)
                        request.messages = fl
                        return HookResult(strategy=HookStrategy.MODIFY, request=request)
            except Exception:
                pass
        if request_name == "getStarGifts" and self._gs("hidden_gifts", False):
            try:
                if _int(getattr(request, "hash", 0)) != 0:
                    request.hash = 0
                    return HookResult(strategy=HookStrategy.MODIFY, request=request)
            except Exception:
                pass
        if request_name in READ_REQS and self._pass_read:
            self._pass_read = False
            return HookResult()
        if request_name in BLOCKED_AD_REQS and self._gs("hide_ads", True):
            return HookResult(strategy=HookStrategy.CANCEL)
        if self._is_ghost():
            if request_name == "TL_messages_sendReaction" and self._gs("read_on_action", True) and self._gs("ghost_no_read", True):
                try:
                    peer = getattr(request, "peer", None)
                    did = 0
                    if peer:
                        if hasattr(peer, "user_id") and peer.user_id:
                            did = _int(peer.user_id)
                        elif hasattr(peer, "chat_id") and peer.chat_id:
                            did = -_int(peer.chat_id)
                        elif hasattr(peer, "channel_id") and peer.channel_id:
                            did = -_int(peer.channel_id)
                    mid = _int(getattr(request, "msg_id", 0))
                    if did:
                        self._send_read_for_dialog(did, mid)
                except Exception:
                    pass
            if request_name in READ_REQS and self._gs("ghost_no_read", True):
                if self._is_whitelisted_peer(request):
                    return HookResult()
                try:
                    did = 0
                    if hasattr(request, "peer"):
                        peer = request.peer
                        if hasattr(peer, "user_id") and peer.user_id:
                            did = _int(peer.user_id)
                        elif hasattr(peer, "chat_id") and peer.chat_id:
                            did = -_int(peer.chat_id)
                        elif hasattr(peer, "channel_id") and peer.channel_id:
                            did = -_int(peer.channel_id)
                    if did:
                        self._mark_local_read(did, 0)
                except Exception:
                    pass
                return HookResult(strategy=HookStrategy.CANCEL)
            if request_name in TYPING_REQS and self._gs("ghost_no_typing", True):
                return HookResult(strategy=HookStrategy.CANCEL)
            if request_name in STORIES_REQS and self._gs("ghost_no_read_stories", True):
                return HookResult(strategy=HookStrategy.CANCEL)
            if request_name in ("updateStatus", "TL_account_updateStatus") and self._gs("ghost_no_online", True):
                request.offline = True
                return HookResult(strategy=HookStrategy.MODIFY, request=request)
        silent = _int(self._gs("silent_send", 0), 0)
        if request_name in SEND_REQS and (silent == 1 or (silent == 2 and self._is_ghost())):
            try:
                request.silent = True
            except Exception:
                pass
            try:
                request.noforwards = getattr(request, "noforwards", False)
            except Exception:
                pass
            return HookResult(strategy=HookStrategy.MODIFY, request=request)
        return HookResult()

    def post_request_hook(self, request_name, account, response, error):
        if request_name in ONLINE_REQS and self._is_ghost() and self.get_setting("ghost_immediate_offline", True):
            run_on_queue(lambda: self.sendOffline(), "externalNetworkQueue", 1000)
        if request_name == "getStarGifts" and self.get_setting("hidden_gifts", False) and not error and response:
            patched = self._patch_star_gifts(response)
            if patched:
                return HookResult(strategy=HookStrategy.MODIFY, response=patched)
        if request_name == "TL_messages_getStickerSet" and self.get_setting("hidden_gifts", False) and not error and response:
            try:
                self._refresh_gift_list()
                self._ingest_sticker_set(response)
            except Exception:
                pass

    def _on_ghost_change(self, v):
        self.set_setting("ghost_mode", v)
        self._sc.clear()
        if v:
            self.sendOffline()

    def _on_view_deleted_click(self, ctx):
        try:
            did = 0
            if isinstance(ctx, dict):
                did = _int(ctx.get("dialog_id", 0))
            if not did:
                frag = get_last_fragment()
                if frag and isinstance(frag, ChatActivity):
                    f = _ff(CA_CLS, "dialog_id")
                    if f:
                        did = int(f.get(frag))
            if did:
                self._show_deleted_list(did)
            else:
                BulletinHelper.show_info(L.g("no_deleted"))
        except Exception as e:
            log(f"[MAX] viewDel: {e}")

    def _navigate_to_message(self, did, mid):
        did = int(did)
        mid = int(mid)
        plugin = self
        def _do():
            try:
                frag = get_last_fragment()
                if not frag:
                    return
                frag_did = 0
                if isinstance(frag, ChatActivity):
                    f = _ff(CA_CLS, "dialog_id")
                    if f:
                        frag_did = int(f.get(frag))
                if frag_did == did:
                    try:
                        frag.scrollToMessageId(mid, 0, True, 0, True, 0)
                    except Exception:
                        pass
                    return
                try:
                    acc = int(UserConfig.selectedAccount)
                    args = jclass("android.os.Bundle")()
                    if did > 0:
                        args.putLong("user_id", jlong(did))
                    elif did < 0:
                        chat_id = -did
                        try:
                            mc = MessagesController.getInstance(acc)
                            chat = mc.getChat(Long(chat_id))
                            if chat and ChatObject.isChannel(chat):
                                args.putLong("chat_id", jlong(chat_id))
                            else:
                                args.putLong("chat_id", jlong(chat_id))
                        except Exception:
                            args.putLong("chat_id", jlong(chat_id))
                    args.putInt("message_id", jint(mid))
                    ca = ChatActivity(args)
                    frag.presentFragment(ca)
                except Exception as e:
                    log(f"[MAX] navigate: {e}")
            except Exception:
                pass
        run_on_ui_thread(_do)

    def _scroll_to_message(self, did, mid):
        self._navigate_to_message(did, mid)

    def _try_save_media(self, mo):
        try:
            frag = get_last_fragment()
            ctx = frag.getParentActivity() if frag else None
            if not ctx:
                return
            msg = mo.messageOwner if mo else None
            if msg and _save_media_to_downloads(msg, ctx):
                BulletinHelper.show_info(L.g("saved_to"))
            else:
                BulletinHelper.show_info(L.g("no_text"))
        except Exception:
            pass

    def _show_deleted_list(self, did):
        if not self.vault:
            return
        mids = self.vault.get_removed_mids(did)
        if not mids:
            BulletinHelper.show_info(L.g("no_deleted"))
            return
        plugin = self
        def _ui():
            frag = get_last_fragment()
            if not frag or not frag.getParentActivity():
                return
            act = frag.getParentActivity()
            messages = []
            try:
                if isinstance(frag, ChatActivity):
                    msgs_field = _ff(CA_CLS, "messages")
                    if msgs_field:
                        chat_msgs = msgs_field.get(frag)
                        if chat_msgs:
                            for i in range(chat_msgs.size()):
                                mo = chat_msgs.get(i)
                                if mo and int(mo.getId()) in mids:
                                    messages.append(mo)
            except Exception:
                pass
            if not messages:
                BulletinHelper.show_info(L.g("no_deleted"))
                return
            messages.sort(key=lambda m: -int(m.getId()))
            items = []
            for mo in messages:
                try:
                    msg = mo.messageOwner
                    text = str(msg.message or "") if msg else ""
                    media_desc = _describe_media(msg) if msg else ""
                    preview = text[:60] if text else media_desc
                    if not preview:
                        preview = f"[id: {mo.getId()}]"
                    if media_desc and text:
                        preview = f"{media_desc} {preview}"
                    ts = ""
                    try:
                        k = (int(did), int(mo.getId()))
                        del_ts = plugin.vault._removed_ts.get(k, 0)
                        if del_ts:
                            ts = _format_date(del_ts)
                        elif msg and msg.date:
                            ts = _format_date(int(msg.date))
                    except Exception:
                        pass
                    label = f"{ts}  {preview}" if ts else preview
                    items.append(label)
                except Exception:
                    items.append(f"[id: {mo.getId()}]")
            def on_pick(dlg, which):
                dlg.dismiss()
                mo = messages[which]
                msg = mo.messageOwner
                text = str(msg.message or "") if msg else ""
                media_desc = _describe_media(msg) if msg else ""
                ts = ""
                try:
                    if msg and msg.date:
                        ts = _format_date(int(msg.date))
                except Exception:
                    pass
                title = f"#{mo.getId()}"
                if ts:
                    title += f" ({ts})"
                body = text if text else media_desc if media_desc else L.g("no_text")
                if media_desc and text:
                    body = f"{media_desc}\n\n{text}"
                has_media = bool(msg and getattr(msg, "media", None))
                vault_path = _get_vault_attach(did, int(mo.getId()))
                src_file = _get_file_from_msg(msg) if msg else None
                can_open = bool(vault_path) or bool(src_file and src_file.exists())
                def _detail():
                    f2 = get_last_fragment()
                    if not f2 or not f2.getParentActivity():
                        return
                    d = AlertDialogBuilder(f2.getParentActivity())
                    d.set_title(title)
                    d.set_message(body)
                    btn_items = []
                    if can_open:
                        btn_items.append(L.g("view"))
                    if has_media:
                        btn_items.append(L.g("download_file"))
                    btn_items.append(L.g("back"))
                    def on_action(dd, w):
                        dd.dismiss()
                        idx = 0
                        if can_open and w == idx:
                            fp = vault_path or (str(src_file.getAbsolutePath()) if src_file else None)
                            if fp:
                                _open_file(fp)
                            return
                        if can_open:
                            idx += 1
                        if has_media and w == idx:
                            plugin._try_save_media(mo)
                            return
                        run_on_ui_thread(_ui)
                    d.set_items(btn_items, on_action)
                    d.set_negative_button(L.g("close"), lambda dd, w: dd.dismiss())
                    d.show()
                run_on_ui_thread(_detail)
            dlg = AlertDialogBuilder(act)
            dlg.set_title(f"{L.g('deleted_list')} ({len(messages)})")
            dlg.set_items(items, on_pick)
            dlg.set_negative_button(L.g("close"), lambda d, w: d.dismiss())
            dlg.show()
        run_on_ui_thread(_ui)

    def _download_revision_media(self, dmsg):
        try:
            if not dmsg:
                BulletinHelper.show_info(L.g("error"))
                return
            did = _peer_did(dmsg)
            mid = int(getattr(dmsg, "id", 0))
            mh = _get_media_hash(dmsg)
            p = _ensure_attach_saved(dmsg, did, mid, mh, force_download=True)
            if p:
                BulletinHelper.show_info(L.g("saved_to"))
            else:
                _save_media_to_downloads(dmsg, ApplicationLoader.applicationContext)
                BulletinHelper.show_info(L.g("saved_to"))
        except Exception:
            BulletinHelper.show_info(L.g("error"))

    def _show_revisions(self, did, mid):
        if not self.vault:
            return
        revs = self.vault.get_revisions(did, mid)
        if not revs:
            BulletinHelper.show_info(L.g("no_revisions"))
            return
        plugin = self
        def _ui():
            frag = get_last_fragment()
            if not frag or not frag.getParentActivity():
                return
            act = frag.getParentActivity()
            total = len(revs)
            items = []
            for i, rev in enumerate(revs):
                ts = _format_date(rev["timestamp"]) if rev.get("timestamp") else ""
                text_preview = (rev.get("text") or "")[:40]
                has_media = bool(rev.get("media_hash"))
                if not text_preview and has_media:
                    text_preview = L.g("media_changed")
                elif not text_preview:
                    text_preview = L.g("no_text")
                elif has_media:
                    text_preview = f"[+] {text_preview}"
                if i == 0:
                    label = L.g("original")
                    if ts:
                        label += f" ({ts})"
                else:
                    label = ts or L.g("version")
                label += f": {text_preview}"
                items.append(label)
            def on_pick(dlg, which):
                dlg.dismiss()
                rev = revs[which]
                full_text = rev.get("text") or ""
                ts = _format_date(rev["timestamp"]) if rev.get("timestamp") else ""
                label = L.g("original") if which == 0 else (ts or L.g("version"))
                if ts and which == 0:
                    label += f" ({ts})"
                has_data = bool(rev.get("data"))
                has_media_hash = bool(rev.get("media_hash"))
                vault_path = _get_vault_attach_by_hash(did, mid, rev.get("media_hash")) if has_media_hash else None
                body = full_text if full_text else L.g("no_text")
                if has_media_hash:
                    mh = rev["media_hash"]
                    body = f"{mh}\n\n{body}" if full_text else mh
                def _detail():
                    f2 = get_last_fragment()
                    if not f2 or not f2.getParentActivity():
                        return
                    d = AlertDialogBuilder(f2.getParentActivity())
                    d.set_title(label)
                    d.set_message(body)
                    btn_items = []
                    if vault_path:
                        btn_items.append(L.g("view"))
                    if has_data and has_media_hash:
                        btn_items.append(L.g("download_file"))
                    btn_items.append(L.g("back"))
                    def on_action(dd, w):
                        dd.dismiss()
                        idx = 0
                        if vault_path and w == idx:
                            _open_file(vault_path)
                            return
                        if vault_path:
                            idx += 1
                        if has_data and has_media_hash and w == idx:
                            def _do_download():
                                try:
                                    dmsg = _decode_msg(rev["data"])
                                    plugin._download_revision_media(dmsg)
                                except Exception:
                                    run_on_ui_thread(lambda: BulletinHelper.show_info(L.g("error")))
                            threading.Thread(target=_do_download, daemon=True).start()
                            return
                        run_on_ui_thread(_ui)
                    d.set_items(btn_items, on_action)
                    d.set_negative_button(L.g("close"), lambda dd, w: dd.dismiss())
                    d.show()
                run_on_ui_thread(_detail)
            dlg = AlertDialogBuilder(act)
            dlg.set_title(f"{L.g('revisions')} ({total})")
            dlg.set_items(items, on_pick)
            dlg.set_negative_button(L.g("close"), lambda d, w: d.dismiss())
            dlg.show()
        run_on_ui_thread(_ui)

    def _export_settings(self, _v=None):
        plugin = self
        def _bg():
            try:
                sdk_settings = {}
                try:
                    sdk_settings = plugin.export_settings()
                    if not isinstance(sdk_settings, dict):
                        sdk_settings = {}
                except Exception:
                    pass
                data = {"_version": __version__, "_ts": int(_time.time()), "_sdk": sdk_settings}
                prefs = plugin._prefs()
                try:
                    raw = prefs.getString("filters_list", "[]")
                    data["_filters"] = json.loads(str(raw))
                except Exception:
                    pass
                try:
                    raw = prefs.getString("read_whitelist", "[]")
                    data["_read_whitelist"] = json.loads(str(raw))
                except Exception:
                    pass
                try:
                    raw = prefs.getString(PRESENCE_KEY, "{}")
                    pd = json.loads(str(raw))
                    if pd.get("tracked"):
                        data["_presence_tracked"] = pd["tracked"]
                except Exception:
                    pass
                try:
                    lang = prefs.getString(L._prefs_key, "ru")
                    data["_lang"] = str(lang)
                except Exception:
                    pass
                payload = json.dumps(data, ensure_ascii=False, indent=2)
                dir_path = os.path.join(
                    str(ApplicationLoader.applicationContext.getCacheDir().getAbsolutePath()),
                    "mre_backup"
                )
                ensure_dir_exists(dir_path)
                fpath = os.path.join(dir_path, "max_reextera.mre_backup")
                write_file(fpath, payload)
                my_id = int(UserConfig.getInstance(int(UserConfig.selectedAccount)).getClientUserId())
                send_document(my_id, fpath)
                run_on_ui_thread(lambda: BulletinHelper.show_info(L.g("export_done")))
            except Exception as e:
                log(f"[MAX] export: {e}")
                run_on_ui_thread(lambda: BulletinHelper.show_info(L.g("export_error")))
        threading.Thread(target=_bg, daemon=True).start()

    def _do_import(self, data):
        plugin = self
        def _bg():
            try:
                sdk_settings = data.get("_sdk")
                if isinstance(sdk_settings, dict) and sdk_settings:
                    try:
                        plugin.import_settings(sdk_settings, reload_settings=False)
                    except Exception:
                        pass
                prefs = plugin._prefs()
                editor = prefs.edit()
                if "_filters" in data:
                    try:
                        editor.putString("filters_list", json.dumps(data["_filters"]))
                        plugin._filters = data["_filters"]
                    except Exception:
                        pass
                if "_read_whitelist" in data:
                    try:
                        wl = data["_read_whitelist"]
                        editor.putString("read_whitelist", json.dumps(wl))
                        plugin._read_whitelist = set(wl)
                    except Exception:
                        pass
                if "_presence_tracked" in data:
                    try:
                        tracked = data["_presence_tracked"]
                        pd_raw = prefs.getString(PRESENCE_KEY, "{}")
                        pd = json.loads(str(pd_raw))
                        pd["tracked"] = tracked
                        editor.putString(PRESENCE_KEY, json.dumps(pd))
                        plugin._presence_tracked = set(tracked)
                    except Exception:
                        pass
                if "_lang" in data:
                    try:
                        editor.putString(L._prefs_key, str(data["_lang"]))
                        L._lang_cache = [None, 0]
                    except Exception:
                        pass
                editor.apply()
                plugin._sc.clear()
                plugin._load_filters()
                run_on_ui_thread(lambda: BulletinHelper.show_info(L.g("import_done")))
            except Exception as e:
                log(f"[MAX] import: {e}")
                run_on_ui_thread(lambda: BulletinHelper.show_info(L.g("import_error")))
        threading.Thread(target=_bg, daemon=True).start()

    def _load_filters(self):
        try:
            self._filters = json.loads(str(self._prefs().getString("filters_list", "[]")))
        except Exception:
            self._filters = []
        self._cpat = []
        for f in self._filters:
            if f.get("enabled", True) and f.get("expression", ""):
                try:
                    flags = re.IGNORECASE if f.get("ignore_case", True) else 0
                    self._cpat.append((re.compile(f["expression"], flags), f.get("inverted", False)))
                except Exception:
                    pass

    def _save_filters(self):
        self._prefs().edit().putString("filters_list", json.dumps(self._filters)).apply()
        self._load_filters()

    def _should_filter(self, text):
        if not text or not self._cpat:
            return False
        if not self.get_setting("filters_enabled", True):
            return False
        ts = str(text)
        for pat, inv in self._cpat:
            try:
                found = pat.search(ts) is not None
                if (inv and not found) or (not inv and found):
                    return True
            except Exception:
                pass
        return False

    def _compare_versions(self, v1, v2):
        try:
            def parse(v):
                return [int(x) for x in str(v).strip().split(".")]
            p1, p2 = parse(v1), parse(v2)
            while len(p1) < len(p2):
                p1.append(0)
            while len(p2) < len(p1):
                p2.append(0)
            for a, b in zip(p1, p2):
                if a < b:
                    return -1
                if a > b:
                    return 1
            return 0
        except Exception:
            return 0

    def _fetch_json_url(self, url):
        try:
            import requests
            return requests.get(url, timeout=7).json()
        except Exception:
            pass
        try:
            from java.net import URL as JURL
            from java.io import BufferedReader, InputStreamReader
            conn = JURL(url).openConnection()
            conn.setConnectTimeout(7000)
            conn.setReadTimeout(7000)
            conn.setRequestProperty("User-Agent", "MAX-reextera")
            reader = BufferedReader(InputStreamReader(conn.getInputStream(), "UTF-8"))
            sb = []
            line = reader.readLine()
            while line is not None:
                sb.append(str(line))
                line = reader.readLine()
            reader.close()
            conn.disconnect()
            return json.loads("\n".join(sb))
        except Exception:
            pass
        return None

    def _check_for_updates(self):
        if not self.get_setting("check_updates_on_start", True):
            return
        plugin = self
        def _bg():
            try:
                _time.sleep(3.0)
                resp = plugin._fetch_json_url(UPDATE_JSON_URL)
                if not isinstance(resp, dict):
                    return
                if resp.get("id") != __id__:
                    return
                remote_ver = str(resp.get("versionName", ""))
                if not remote_ver:
                    return
                if plugin._compare_versions(__version__, remote_ver) >= 0:
                    return
                changelog = str(resp.get("changelog", ""))
                download_url = str(resp.get("downloadUrl", ""))
                author_url = str(resp.get("author", ""))
                _time.sleep(2.0)
                run_on_ui_thread(lambda: plugin._show_update_dialog(remote_ver, changelog, download_url, author_url))
            except Exception:
                pass
        threading.Thread(target=_bg, daemon=True).start()

    def _show_update_dialog(self, version, changelog, download_url, author_url):
        try:
            frag = get_last_fragment()
            if not frag or not frag.getParentActivity():
                return
            plugin = self
            ctx = frag.getParentActivity()
            msg = changelog if changelog else ""
            d = AlertDialogBuilder(ctx)
            d.set_title(f"{L.g('update_available')} MAX re:extera: v{version}")
            d.set_message(msg)
            if download_url and author_url:
                d.set_negative_button(L.g("download_verified"), lambda dd, w: (dd.dismiss(), plugin._open_tg_link(download_url)))
                d.set_neutral_button(L.g("view_author_channel"), lambda dd, w: (dd.dismiss(), plugin._open_author_with_warning(author_url)))
                d.set_positive_button(L.g("remind_later"), lambda dd, w: dd.dismiss())
            elif download_url:
                d.set_negative_button(L.g("download_verified"), lambda dd, w: (dd.dismiss(), plugin._open_tg_link(download_url)))
                d.set_positive_button(L.g("remind_later"), lambda dd, w: dd.dismiss())
            elif author_url:
                d.set_negative_button(L.g("view_author_channel"), lambda dd, w: (dd.dismiss(), plugin._open_author_with_warning(author_url)))
                d.set_positive_button(L.g("remind_later"), lambda dd, w: dd.dismiss())
            else:
                d.set_positive_button(L.g("remind_later"), lambda dd, w: dd.dismiss())
            dlg_obj = d.show()
            try:
                dlg_obj.setCancelable(False)
                dlg_obj.setCanceledOnTouchOutside(False)
            except Exception:
                pass
        except Exception as e:
            log(f"[MAX] updateDlg: {e}")

    def _open_tg_link(self, url):
        try:
            from android.content import Intent
            from android.net import Uri
            ctx = ApplicationLoader.applicationContext
            intent = Intent(Intent.ACTION_VIEW, Uri.parse(url))
            intent.setPackage(ctx.getPackageName())
            intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)
            ctx.startActivity(intent)
        except Exception:
            pass

    def _open_author_with_warning(self, url):
        plugin = self
        if not self.get_setting("author_channel_warning", True):
            self._open_tg_link(url)
            return
        def _ui():
            try:
                frag = get_last_fragment()
                if not frag or not frag.getParentActivity():
                    plugin._open_tg_link(url)
                    return
                ctx = frag.getParentActivity()
                d = AlertDialogBuilder(ctx)
                d.set_title(L.g("view_author_channel"))
                d.set_message(L.g("author_warning"))
                d.set_positive_button("OK", lambda dlg, w: (dlg.dismiss(), plugin._open_tg_link(url)))
                d.set_negative_button(L.g("dont_show_again"), lambda dlg, w: (dlg.dismiss(), plugin._disable_author_warning(), plugin._open_tg_link(url)))
                d.show()
            except Exception:
                plugin._open_tg_link(url)
        run_on_ui_thread(_ui)

    def _disable_author_warning(self):
        self.set_setting("author_channel_warning", False)
        self._sc.clear()

    def _load_read_whitelist(self):
        try:
            raw = self._prefs().getString("read_whitelist", "[]")
            self._read_whitelist = set(json.loads(str(raw)))
        except Exception:
            self._read_whitelist = set()

    def _save_read_whitelist(self):
        try:
            self._prefs().edit().putString("read_whitelist", json.dumps(list(self._read_whitelist))).apply()
        except Exception:
            pass

    def _is_whitelisted_peer(self, request):
        if not self._read_whitelist:
            return False
        try:
            peer = getattr(request, "peer", None)
            if not peer:
                return False
            uid = 0
            if hasattr(peer, "user_id") and peer.user_id:
                uid = _int(peer.user_id)
            if uid and uid in self._read_whitelist:
                return True
        except Exception:
            pass
        return False

    def _show_read_whitelist(self, _v=None):
        plugin = self
        def _ui():
            try:
                frag = get_last_fragment()
                if not frag or not frag.getParentActivity():
                    return
                ctx = frag.getParentActivity()
                uids = sorted(plugin._read_whitelist)
                items = [f"{plugin._presence_user_name(u)} (id{u})" for u in uids]
                def on_pick(dlg, which):
                    dlg.dismiss()
                    uid = uids[which]
                    def confirm():
                        f2 = get_last_fragment()
                        if not f2 or not f2.getParentActivity():
                            return
                        d = AlertDialogBuilder(f2.getParentActivity())
                        d.set_title(L.g("remove"))
                        d.set_message(plugin._presence_user_name(uid))
                        d.set_positive_button(L.g("yes"), lambda dd, w: (dd.dismiss(), do_rm(uid)))
                        d.set_negative_button(L.g("no"), lambda dd, w: (dd.dismiss(), run_on_ui_thread(_ui)))
                        d.show()
                    def do_rm(u):
                        plugin._read_whitelist.discard(int(u))
                        plugin._save_read_whitelist()
                        BulletinHelper.show_info(L.g("removed"))
                        run_on_ui_thread(_ui)
                    run_on_ui_thread(confirm)
                def on_add(dlg, w):
                    dlg.dismiss()
                    plugin._show_read_wl_add()
                d = AlertDialogBuilder(ctx)
                if items:
                    d.set_title(f"{L.g('read_wl_users')} ({len(items)})")
                    d.set_items(items, on_pick)
                else:
                    d.set_title(L.g("read_wl_users"))
                    d.set_message(L.g("read_wl_empty"))
                d.set_positive_button(L.g("add"), on_add)
                d.set_negative_button(L.g("close"), lambda dd, w: dd.dismiss())
                d.show()
            except Exception:
                pass
        run_on_ui_thread(_ui)

    def _show_read_wl_add(self):
        plugin = self
        def _ui():
            try:
                frag = get_last_fragment()
                if not frag or not frag.getParentActivity():
                    return
                ctx = frag.getParentActivity()
                d = AlertDialogBuilder(ctx)
                d.set_title(L.g("add"))
                inp = EditText(ctx)
                inp.setHint("@username / id")
                inp.setInputType(InputType.TYPE_CLASS_TEXT)
                inp.setSingleLine(True)
                d.set_view(inp)
                def on_add(dlg, w):
                    raw = str(inp.getText()).strip()
                    dlg.dismiss()
                    if raw:
                        plugin._resolve_and_add_wl(raw)
                d.set_positive_button(L.g("add"), on_add)
                d.set_negative_button(L.g("cancel"), lambda dd, w: dd.dismiss())
                d.show()
            except Exception:
                pass
        run_on_ui_thread(_ui)

    def _resolve_and_add_wl(self, raw):
        plugin = self
        try:
            v = raw.lstrip("@").strip()
            if v.lstrip("-").isdigit():
                uid = int(v)
                if uid <= 0:
                    BulletinHelper.show_error(L.g("invalid_id"))
                    return
                plugin._read_whitelist.add(uid)
                plugin._save_read_whitelist()
                BulletinHelper.show_info(L.g("added"))
                return
            req = TLRPC.TL_contacts_resolveUsername()
            req.username = v
            def done(resp, err):
                try:
                    if err or not resp:
                        run_on_ui_thread(lambda: BulletinHelper.show_error(L.g("not_found")))
                        return
                    users = _jlist(getattr(resp, "users", None))
                    if users:
                        uid = int(str(users[0].id))
                        plugin._read_whitelist.add(uid)
                        plugin._save_read_whitelist()
                        run_on_ui_thread(lambda: BulletinHelper.show_info(L.g("added")))
                    else:
                        run_on_ui_thread(lambda: BulletinHelper.show_error(L.g("not_found")))
                except Exception:
                    run_on_ui_thread(lambda: BulletinHelper.show_error(L.g("error")))
            send_request(req, RequestCallback(done))
        except Exception:
            pass

    def _load_presence(self):
        try:
            data = json.loads(str(self._prefs().getString(PRESENCE_KEY, "{}")))
            self._presence_tracked = set(data.get("tracked", []))
            self._presence_records = data.get("records", {})
            self._presence_last_seen = {str(k): _int(v) for k, v in data.get("last_seen", {}).items() if _int(v) > 0}
        except Exception:
            self._presence_tracked = set()
            self._presence_records = {}
            self._presence_last_seen = {}

    def _save_presence(self):
        if not self._presence_dirty:
            return
        with self._presence_lock:
            try:
                for k, rows in list(self._presence_records.items()):
                    if len(rows) > 2000:
                        self._presence_records[k] = rows[-2000:]
                data = {"tracked": list(self._presence_tracked), "records": self._presence_records, "last_seen": self._presence_last_seen}
                self._prefs().edit().putString(PRESENCE_KEY, json.dumps(data)).apply()
                self._presence_dirty = False
            except Exception:
                pass

    def _presence_now(self):
        try:
            return int(ConnectionsManager.getInstance(int(UserConfig.selectedAccount)).getCurrentTime())
        except Exception:
            return int(_time.time())

    def _presence_decay(self):
        i = _int(self.get_setting("presence_decay", 1), 1)
        return [30, 45, 60, 120][i] if 0 <= i < 4 else 45

    def _presence_is_hidden(self, uid, account=None):
        try:
            acc = int(UserConfig.selectedAccount if account is None else account)
            u = MessagesController.getInstance(acc).getUser(Long(int(uid)))
            if not u:
                return False
            st = getattr(u, "status", None)
            if not st:
                return True
            name = str(st.getClass().getSimpleName())
            return name in ("TL_userStatusEmpty", "TL_userStatusRecently", "TL_userStatusLastWeek", "TL_userStatusLastMonth") or _int(getattr(st, "expires", 0)) <= 0
        except Exception:
            return False

    def _presence_apply_last_seen(self, uid, ts, account=None):
        try:
            acc = int(UserConfig.selectedAccount if account is None else account)
            user = MessagesController.getInstance(acc).getUser(Long(int(uid)))
            if not user or not self._presence_is_hidden(uid, acc):
                return
            current = _int(getattr(getattr(user, "status", None), "was_online", 0))
            if current >= int(ts):
                return
            status = TLRPC.TL_userStatusOffline()
            status.was_online = int(ts)
            user.status = status
            NotificationCenter.getInstance(acc).postNotificationName(NotificationCenter.updateInterfaces, Integer(4))
        except Exception:
            pass

    def _restore_presence_statuses(self):
        if not self.get_setting("presence_track", False):
            return
        for uid, ts in list(self._presence_last_seen.items()):
            self._presence_apply_last_seen(_int(uid), _int(ts))

    def _presence_remember(self, uid, ts, via, account):
        uid = int(uid)
        ts = int(ts)
        if uid <= 0 or ts <= 0:
            return
        key = str(uid)
        if ts > _int(self._presence_last_seen.get(key, 0)):
            self._presence_last_seen[key] = ts
            self._presence_dirty = True
        hidden = self._presence_is_hidden(uid, account)
        if hidden:
            run_on_ui_thread(lambda: self._presence_apply_last_seen(uid, ts, account), 100)
        if uid in self._presence_tracked and (not self.get_setting("presence_only_hidden", True) or hidden):
            self._presence_lamp[uid] = {"last_active": ts, "via": str(via)}

    def _presence_lamp_on(self, uid):
        e = self._presence_lamp.get(int(uid))
        if not e:
            return False
        return (self._presence_now() - int(e["last_active"])) < self._presence_decay()

    def _presence_tick(self):
        try:
            decay = self._presence_decay()
            now = self._presence_now()
            for uid, e in list(self._presence_lamp.items()):
                la = int(e["last_active"])
                via = e.get("via", "?")
                on = (now - la) < decay
                cur = self._presence_open.get(uid)
                if on:
                    if cur is None:
                        self._presence_open[uid] = {"start": la, "end": la, "via": via}
                    else:
                        cur["end"] = la
                        cur["via"] = via
                else:
                    if cur is not None:
                        k = str(int(uid))
                        rows = self._presence_records.get(k)
                        if rows is None:
                            rows = []
                            self._presence_records[k] = rows
                        row = [int(cur["start"]), int(cur["end"]), str(cur.get("via", "?"))]
                        if not rows or rows[-1] != row:
                            rows.append(row)
                            self._presence_dirty = True
                        self._presence_open.pop(uid, None)
        except Exception:
            pass

    def _presence_on_update(self, update_name, account, update):
        try:
            uid = 0
            via = "?"
            ev_date = 0
            if update_name == "TL_updateUserStatus":
                uid = _int(getattr(update, "user_id", 0))
                status = getattr(update, "status", None)
                expires = _int(getattr(status, "expires", 0))
                was_online = _int(getattr(status, "was_online", 0))
                now = self._presence_now()
                if expires > now:
                    ev_date = now
                    via = "online"
                elif was_online > 0:
                    ev_date = was_online
                    via = "offline"
                else:
                    cached = _int(self._presence_last_seen.get(str(uid), 0))
                    if cached > 0 and status is not None:
                        exact = TLRPC.TL_userStatusOffline()
                        exact.was_online = cached
                        update.status = exact
                    return
            elif update_name == "TL_updateUserTyping":
                uid = _int(getattr(update, "user_id", 0))
                via = "typing"
            elif update_name in ("TL_updateChatUserTyping", "TL_updateChannelUserTyping"):
                fid = getattr(update, "from_id", None)
                if fid and hasattr(fid, "user_id"):
                    uid = _int(fid.user_id)
                via = "typing"
            elif update_name == "TL_updateReadHistoryOutbox":
                peer = getattr(update, "peer", None)
                if peer and hasattr(peer, "user_id"):
                    uid = _int(peer.user_id)
                via = "read"
            elif update_name in ("TL_updateNewMessage", "TL_updateNewChannelMessage"):
                msg = getattr(update, "message", None)
                if msg and not bool(getattr(msg, "out", False)):
                    ev_date = _int(getattr(msg, "date", 0))
                    peer = getattr(msg, "peer_id", None)
                    if peer and hasattr(peer, "user_id"):
                        uid = _int(peer.user_id)
                    if not uid:
                        fid = getattr(msg, "from_id", None)
                        if fid and hasattr(fid, "user_id"):
                            uid = _int(fid.user_id)
                    via = "message"
            if uid <= 0:
                return
            try:
                my = int(UserConfig.getInstance(account).getClientUserId())
                if uid == my:
                    return
            except Exception:
                pass
            now = self._presence_now()
            if ev_date > 0 and via not in ("offline", "online") and abs(now - ev_date) > 30:
                return
            ts = ev_date if ev_date > 0 else now
            self._presence_remember(uid, ts, via, account)
        except Exception:
            pass

    def _presence_user_name(self, uid):
        try:
            u = MessagesController.getInstance(int(UserConfig.selectedAccount)).getUser(Long(int(uid)))
            if u:
                nm = (str(getattr(u, "first_name", "") or "") + " " + str(getattr(u, "last_name", "") or "")).strip()
                if nm:
                    return nm
                un = str(getattr(u, "username", "") or "")
                if un:
                    return "@" + un
        except Exception:
            pass
        return f"id{uid}"

    def _presence_fmt_dur(self, sec):
        sec = int(sec)
        if sec < 60:
            return f"{sec}s"
        if sec < 3600:
            return f"{sec // 60}m"
        return f"{sec // 3600}h{(sec % 3600) // 60}m"

    def _load_fp(self):
        try:
            self._fp_cache = json.loads(str(self._prefs().getString(PREMIUM_CACHE_KEY, "{}")))
        except Exception:
            self._fp_cache = {}

    def _save_fp(self):
        if not self._fp_dirty:
            return
        try:
            self._prefs().edit().putString(PREMIUM_CACHE_KEY, json.dumps(self._fp_cache)).apply()
            self._fp_dirty = False
        except Exception:
            pass

    def _show_presence_tracked(self):
        plugin = self
        def _ui():
            try:
                frag = get_last_fragment()
                if not frag or not frag.getParentActivity():
                    return
                ctx = frag.getParentActivity()
                uids = sorted(plugin._presence_tracked)
                items = [f"{plugin._presence_user_name(u)} (id{u})" for u in uids]
                def on_pick(dlg, which):
                    dlg.dismiss()
                    uid = uids[which]
                    def confirm():
                        f2 = get_last_fragment()
                        if not f2 or not f2.getParentActivity():
                            return
                        d = AlertDialogBuilder(f2.getParentActivity())
                        d.set_title("Удалить?")
                        d.set_message(plugin._presence_user_name(uid))
                        d.set_positive_button("Да", lambda dd, w: (dd.dismiss(), do_rm(uid)))
                        d.set_negative_button("Нет", lambda dd, w: (dd.dismiss(), run_on_ui_thread(_ui)))
                        d.show()
                    def do_rm(u):
                        plugin._presence_tracked.discard(int(u))
                        plugin._presence_lamp.pop(int(u), None)
                        plugin._presence_open.pop(int(u), None)
                        plugin._presence_dirty = True
                        BulletinHelper.show_info("Удалён")
                        run_on_ui_thread(_ui)
                    run_on_ui_thread(confirm)
                def on_add(dlg, w):
                    dlg.dismiss()
                    plugin._show_presence_add()
                d = AlertDialogBuilder(ctx)
                if items:
                    d.set_title(f"Отслеживаемые ({len(items)})")
                    d.set_items(items, on_pick)
                else:
                    d.set_title("Отслеживаемые")
                    d.set_message("Список пуст")
                d.set_positive_button("Добавить", on_add)
                d.set_negative_button("Закрыть", lambda dd, w: dd.dismiss())
                d.show()
            except Exception as e:
                log(f"[MAX] presTracked: {e}")
        run_on_ui_thread(_ui)

    def _show_presence_add(self):
        plugin = self
        def _ui():
            try:
                frag = get_last_fragment()
                if not frag or not frag.getParentActivity():
                    return
                ctx = frag.getParentActivity()
                d = AlertDialogBuilder(ctx)
                d.set_title("Добавить")
                inp = EditText(ctx)
                inp.setHint("@username или id")
                inp.setInputType(InputType.TYPE_CLASS_TEXT)
                inp.setSingleLine(True)
                d.set_view(inp)
                def on_add(dlg, w):
                    raw = str(inp.getText()).strip()
                    dlg.dismiss()
                    if raw:
                        plugin._resolve_and_add(raw)
                d.set_positive_button("Добавить", on_add)
                d.set_negative_button("Отмена", lambda dd, w: dd.dismiss())
                d.show()
            except Exception as e:
                log(f"[MAX] presAdd: {e}")
        run_on_ui_thread(_ui)

    def _resolve_and_add(self, raw):
        plugin = self
        try:
            v = raw.lstrip("@").strip()
            if v.lstrip("-").isdigit():
                uid = int(v)
                if uid <= 0:
                    BulletinHelper.show_error("Неверный ID")
                    return
                plugin._presence_tracked.add(uid)
                plugin._presence_dirty = True
                BulletinHelper.show_info("Добавлен")
                return
            req = TLRPC.TL_contacts_resolveUsername()
            req.username = v
            def done(resp, err):
                try:
                    if err or not resp:
                        run_on_ui_thread(lambda: BulletinHelper.show_error("Не найден"))
                        return
                    users = _jlist(getattr(resp, "users", None))
                    if users:
                        uid = int(str(users[0].id))
                        plugin._presence_tracked.add(uid)
                        plugin._presence_dirty = True
                        run_on_ui_thread(lambda: BulletinHelper.show_info("Добавлен"))
                    else:
                        run_on_ui_thread(lambda: BulletinHelper.show_error("Не найден"))
                except Exception:
                    run_on_ui_thread(lambda: BulletinHelper.show_error("Ошибка"))
            send_request(req, RequestCallback(done))
        except Exception as e:
            log(f"[MAX] resolve: {e}")

    def _show_presence_log(self):
        plugin = self
        def _ui():
            try:
                frag = get_last_fragment()
                if not frag or not frag.getParentActivity():
                    return
                uids = sorted(plugin._presence_tracked)
                if not uids:
                    BulletinHelper.show_info("Список пуст")
                    return
                items = []
                for uid in uids:
                    cnt = len(plugin._presence_records.get(str(uid), []))
                    lamp = "[ON] " if plugin._presence_lamp_on(uid) else ""
                    items.append(f"{lamp}{plugin._presence_user_name(uid)} — {cnt}")
                def on_pick(dlg, which):
                    dlg.dismiss()
                    uid = uids[which]
                    def _detail():
                        f2 = get_last_fragment()
                        if not f2 or not f2.getParentActivity():
                            return
                        rows = list(plugin._presence_records.get(str(int(uid)), []))
                        lines = []
                        for r in reversed(rows[-200:]):
                            try:
                                start, end, via = int(r[0]), int(r[1]), str(r[2])
                                a = _format_date(start)
                                dur = max(0, end - start)
                                lines.append(f"- {a} ({plugin._presence_fmt_dur(dur)}, {via})")
                            except Exception:
                                pass
                        body = "\n".join(lines) if lines else "Нет записей"
                        d = AlertDialogBuilder(f2.getParentActivity())
                        d.set_title(f"{plugin._presence_user_name(uid)} ({len(rows)})")
                        d.set_message(body)
                        d.set_negative_button("Закрыть", lambda dd, w: dd.dismiss())
                        d.show()
                    run_on_ui_thread(_detail)
                d = AlertDialogBuilder(frag.getParentActivity())
                d.set_title("Журнал онлайна")
                d.set_items(items, on_pick)
                d.set_negative_button("Закрыть", lambda dd, w: dd.dismiss())
                d.show()
            except Exception as e:
                log(f"[MAX] presLog: {e}")
        run_on_ui_thread(_ui)

    def _wipe_vault(self, _v=None):
        plugin = self
        def _ui():
            frag = get_last_fragment()
            if not frag or not frag.getParentActivity():
                return
            d = AlertDialogBuilder(frag.getParentActivity())
            d.set_title(L.g("wipe_storage"))
            d.set_message(L.g("wipe_confirm"))
            def do_wipe(dlg, w):
                dlg.dismiss()
                if plugin.vault:
                    plugin.vault.wipe()
                plugin._invalidate_removed_cache()
                try:
                    attach_dir = _get_attach_dir()
                    if attach_dir and os.path.isdir(attach_dir):
                        import shutil
                        shutil.rmtree(attach_dir, ignore_errors=True)
                        os.makedirs(attach_dir, exist_ok=True)
                except Exception:
                    pass
                BulletinHelper.show_info(L.g("cleared"))
            d.set_positive_button(L.g("delete"), do_wipe)
            d.set_negative_button(L.g("cancel"), lambda dd, w: dd.dismiss())
            d.show()
        run_on_ui_thread(_ui)

    def _show_rx_manager(self, _v=None):
        plugin = self
        def _ui():
            try:
                frag = get_last_fragment()
                if not frag or not frag.getParentActivity():
                    return
                act = frag.getParentActivity()
                patterns = plugin.vault.get_rx() if plugin.vault else []
                if not patterns:
                    d = AlertDialogBuilder(act)
                    d.set_title("Шаблоны")
                    d.set_message("Список пуст")
                    d.set_positive_button("Добавить", lambda dlg, w: (dlg.dismiss(), run_on_ui_thread(lambda: plugin._show_rx_add())))
                    d.set_negative_button("Закрыть", lambda dlg, w: dlg.dismiss())
                    d.show()
                    return
                items = [f"#{i+1}: {p}" for i, p in enumerate(patterns)]
                def on_pick(dlg, which):
                    dlg.dismiss()
                    plugin.vault.remove_rx(which)
                    BulletinHelper.show_info("Удалён")
                    run_on_ui_thread(_ui)
                dlg = AlertDialogBuilder(act)
                dlg.set_title(f"Шаблоны ({len(patterns)})")
                dlg.set_items(items, on_pick)
                dlg.set_positive_button("Добавить", lambda d, w: (d.dismiss(), run_on_ui_thread(lambda: plugin._show_rx_add())))
                dlg.set_negative_button("Закрыть", lambda d, w: d.dismiss())
                dlg.show()
            except Exception as e:
                log(f"[MAX] rxMgr: {e}")
        run_on_ui_thread(_ui)

    def _show_rx_add(self):
        plugin = self
        def _ui():
            try:
                frag = get_last_fragment()
                if not frag or not frag.getParentActivity():
                    return
                act = frag.getParentActivity()
                d = AlertDialogBuilder(act)
                d.set_title("Добавить шаблон")
                inp = EditText(act)
                inp.setHint("regex")
                inp.setInputType(InputType.TYPE_CLASS_TEXT)
                inp.setSingleLine(True)
                d.set_view(inp)
                def _on_add(dlg, w):
                    p = str(inp.getText()).strip()
                    dlg.dismiss()
                    if not p:
                        return
                    try:
                        re.compile(p)
                    except Exception:
                        BulletinHelper.show_error("Невалидный regex")
                        return
                    plugin.vault.add_rx(p)
                    BulletinHelper.show_info("Добавлен")
                d.set_positive_button("Добавить", _on_add)
                d.set_negative_button("Закрыть", lambda dlg, w: dlg.dismiss())
                d.show()
            except Exception as e:
                log(f"[MAX] rxAdd: {e}")
        run_on_ui_thread(_ui)

