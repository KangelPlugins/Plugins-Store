    def _wipe_presence(self):
        self._presence_records = {}
        self._presence_lamp = {}
        self._presence_open = {}
        self._presence_dirty = True
        self._save_presence()
        BulletinHelper.show_info(L.g("cleared"))

    def _pf(self):
        self._load_filters()
        items = [
            Header(text=L.g("filters")),
            Switch(key="filters_enabled", text=L.g("enable_filters"), default=True, subtext=L.g("enable_filters_sub")),
            Text(text=L.g("regex_patterns"), icon="msg_search", on_click=self._show_rx_manager),
            Divider(),
            Text(text=L.g("add_filter"), icon="msg_add", create_sub_fragment=lambda: self._fe(-1)),
        ]
        for i, f in enumerate(self._filters):
            idx = i
            items.append(Text(text=f"{'[+]' if f.get('enabled',True) else '[-]'} {f.get('expression','')}", subtext=L.g("inverted") if f.get("inverted") else None, create_sub_fragment=lambda idx=idx: self._fe(idx)))
        return items

    def _fe(self, index=-1):
        is_new = index == -1
        f = {"expression": "", "enabled": True, "ignore_case": True, "inverted": False}
        if not is_new and 0 <= index < len(self._filters):
            f = self._filters[index]
        pl = self
        def save(v):
            try:
                e = pl.get_setting("fe_expr", "")
                if e:
                    entry = {"expression": e, "enabled": pl.get_setting("fe_on", True), "ignore_case": pl.get_setting("fe_ic", True), "inverted": pl.get_setting("fe_inv", False)}
                    if is_new:
                        pl._filters.append(entry)
                    else:
                        pl._filters[index] = entry
                    pl._save_filters()
                    BulletinHelper.show_info(L.g("saved"))
                else:
                    BulletinHelper.show_info(L.g("enter_expr"))
            except Exception as ex:
                log(f"[MAX] fSave: {ex}")
        def delete(v):
            try:
                if not is_new and 0 <= index < len(pl._filters):
                    del pl._filters[index]
                    pl._save_filters()
                    BulletinHelper.show_info(L.g("removed"))
            except Exception:
                pass
        items = [
            Header(text=L.g("new_filter") if is_new else L.g("editor")),
            Input(key="fe_expr", text=L.g("regex_expr"), default=f["expression"]),
            Switch(key="fe_on", text=L.g("enabled"), default=f["enabled"]),
            Switch(key="fe_ic", text=L.g("case_insensitive"), default=f["ignore_case"]),
            Switch(key="fe_inv", text=L.g("inverted"), default=f["inverted"], subtext=L.g("inverted_sub")),
            Divider(),
            Text(text=L.g("save"), icon="msg_check", on_click=save),
        ]
        if not is_new:
            items.append(Text(text=L.g("delete"), icon="msg_delete", on_click=delete))
        return items

    def _ph(self):
        return [
            Header(text=L.g("hacker")),
            Switch(key="hide_ads", text=L.g("hide_ads"), default=True),
            Switch(key="no_forward_limit", text=L.g("no_fwd_limit"), default=False, subtext=L.g("no_fwd_limit_sub")),
            Switch(key="fake_premium", text=L.g("local_premium"), default=False, subtext=L.g("local_premium_sub")),
            Switch(key="keep_once", text=L.g("once_media"), default=False, subtext=L.g("once_media_sub")),
            Switch(key="hidden_gifts", text=L.g("hidden_gifts"), default=False, subtext=L.g("hidden_gifts_sub")),
            Divider(),
            Header(text=L.g("bypass")),
            Switch(key="allow_screenshots", text=L.g("screenshots"), default=False, subtext=L.g("screenshots_sub")),
            Switch(key="bypass_noforward", text=L.g("noforwards"), default=False, subtext=L.g("noforwards_sub")),
            Selector(key="fwd_mode", text=L.g("fwd_mode"), default=0, items=[L.g("fwd_copy"), L.g("fwd_try")]),
            Switch(key="bypass_story_save", text=L.g("stories_bypass"), default=False, subtext=L.g("stories_bypass_sub")),
        ]

    def _pmisc(self):
        plugin = self
        def _open_channel(v):
            try:
                from android.content import Intent
                from android.net import Uri
                ctx = ApplicationLoader.applicationContext
                intent = Intent(Intent.ACTION_VIEW, Uri.parse("https://t.me/MaxExteraPlugins"))
                intent.setPackage(ctx.getPackageName())
                intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)
                ctx.startActivity(intent)
            except Exception:
                pass
        def _on_lang_change(new_index):
            try:
                new_lang = "ru" if new_index == 0 else "en"
                ApplicationLoader.applicationContext.getSharedPreferences(PREFS_NAME, 0).edit().putString(L._prefs_key, new_lang).apply()
                plugin.set_setting("plugin_lang", int(new_index), reload_settings=True)
            except Exception:
                pass
        cur_lang = L._lang()
        cur_idx = 0 if cur_lang == "ru" else 1
        return [
            Header(text=L.g("info")),
            Text(text=L.g("author_channel"), icon="msg_channel", on_click=_open_channel),
            Text(text=L.g("credits"), icon="msg_fave", create_sub_fragment=lambda: [
                Header(text=L.g("credits")),
                Text(text="@exteraOwner", subtext="Без экстеры ничего бы не было"),
                Text(text="@bleizix", subtext="Фундамент re:extera"),
                Text(text="@shiawasez", subtext="Обновление re:extera (v2)"),
                Text(text="@ThisisGame_tig", subtext="Мотивация и поддержка"),
                Text(text="@summering", subtext="Тестирование и развитие"),
                Text(text="@homewatcha", subtext="Тестирование и развитие"),
                Text(text="@Jebebr", subtext="Тестирование и развитие"),
                Text(text="@AdzusaNakano", subtext="Тестирование и развитие"),
                Text(text="@Farewalls", subtext="Тестирование и развитие"),
                Text(text="@dyr0v_ukraine", subtext="Тестирование и развитие"),
                Text(text="@ablipo", subtext="Тестирование и развитие"),
                Text(text="@kvuco", subtext="AdBlock, Mirror"),
                Text(text="@binbash_ch", subtext="Deleted Gift Sender"),
                Text(text="ИИ", subtext="Реализация :)))"),
            ]),
            Divider(),
            Header(text=L.g("params")),
            Selector(key="plugin_lang", text=L.g("language"), default=cur_idx, items=["Русский", "English"], icon="msg_language", on_change=_on_lang_change),
            Divider(),
            Header(text=L.g("updates")),
            Switch(key="check_updates_on_start", text=L.g("check_updates"), default=True, subtext=L.g("check_updates_sub")),
            Switch(key="author_channel_warning", text=L.g("author_warn_toggle"), default=True, subtext=L.g("author_warn_toggle_sub")),
            Divider(),
            Header(text=L.g("backup")),
            Text(text=L.g("export_to_saved"), icon="msg_saved", subtext=L.g("export_to_saved_sub"), on_click=plugin._export_settings),
        ]


__plugin__ = MaxReExteraPlugin


