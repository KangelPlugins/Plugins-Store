    'secret_thanks': Achievement('secret_thanks', 'ach_thanks', 'ach_thanks_desc', AchievementCategory.SECRET, '🙏', Rarity.SECRET, is_secret=True),
    'secret_sorry': Achievement('secret_sorry', 'ach_sorry', 'ach_sorry_desc', AchievementCategory.SECRET, '😔', Rarity.SECRET, is_secret=True),
    'secret_welcome': Achievement('secret_welcome', 'ach_welcome', 'ach_welcome_desc', AchievementCategory.SECRET, '👋', Rarity.SECRET, is_secret=True),
    'secret_congrats': Achievement('secret_congrats', 'ach_congrats', 'ach_congrats_desc', AchievementCategory.SECRET, '🎉', Rarity.SECRET, is_secret=True),
    'secret_bye': Achievement('secret_bye', 'ach_bye', 'ach_bye_desc', AchievementCategory.SECRET, '👋', Rarity.SECRET, is_secret=True),
}

class GlobalBadgeCache:
    CACHE_FILE = "badges_global_cache.json"
    LOCK_FILE = "badges_cache.lock"

    def __init__(self, cache_dir: str):
        self.cache_dir = cache_dir
        self.cache_path = os.path.join(cache_dir, self.CACHE_FILE)
        self.lock_path = os.path.join(cache_dir, self.LOCK_FILE)
        self._memory_cache: Dict[int, dict] = {}
        self._etag: str = ""
        self._timestamp: float = 0
        self._lock = threading.Lock()

    def _acquire_file_lock(self, timeout: float = 5.0) -> bool:
        start = time.time()
        while time.time() - start < timeout:
            try:
                if os.path.exists(self.lock_path):
                    lock_age = time.time() - os.path.getmtime(self.lock_path)
                    if lock_age > 30:
                        os.remove(self.lock_path)
                    else:
                        time.sleep(0.1)
                        continue
                with open(self.lock_path, 'w') as f:
                    f.write(str(os.getpid()))
                return True
            except:
                time.sleep(0.1)
        return False

    def _release_file_lock(self):
        try:
            if os.path.exists(self.lock_path):
                os.remove(self.lock_path)
        except:
            pass

    def load_from_file(self) -> bool:
        try:
            if not os.path.exists(self.cache_path):
                return False
            with open(self.cache_path, 'r', encoding='utf-8') as f:
                data = json.load(f)
            with self._lock:
                self._memory_cache = {int(k): v for k, v in data.get('badges', {}).items()}
                self._etag = data.get('etag', '')
                self._timestamp = data.get('timestamp', 0)
            return True
        except:
            return False

    def save_to_file(self):
        try:
            if not self._acquire_file_lock():
                return
            try:
                with self._lock:
                    data = {
                        'badges': {str(k): v for k, v in self._memory_cache.items()},
                        'etag': self._etag,
                        'timestamp': self._timestamp,
                        'saved_at': time.time()
                    }
                temp_path = self.cache_path + '.tmp'
                with open(temp_path, 'w', encoding='utf-8') as f:
                    json.dump(data, f, ensure_ascii=False)
                os.replace(temp_path, self.cache_path)
            finally:
                self._release_file_lock()
        except:
            pass

    def needs_refresh(self) -> bool:
        return time.time() - self._timestamp > 60

    def update(self, badges: Dict[int, dict], etag: str):
        with self._lock:
            self._memory_cache = badges
            self._etag = etag
            self._timestamp = time.time()
        self.save_to_file()

    def get_badges(self) -> Dict[int, dict]:
        with self._lock:
            return self._memory_cache.copy()

    def get_etag(self) -> str:
        return self._etag

    def get_timestamp(self) -> float:
        return self._timestamp


def safe_int(v, default=0):
    try:
        s = str(v).strip()
        if not s:
            return default
        return int(s)
    except:
        return default
class BulletinFactoryHook(MethodHook):
    def __init__(self, plugin):
        self.p = plugin
    
    def before_hooked_method(self, param):
        try:
            if len(param.args) >= 4 and param.args[3] is not None:
                badges = self.p._global_badge_cache.get_badges() if self.p._global_badge_cache else {}
                if not badges:
                    return
                
                doc = param.args[0]
                if doc is None:
                    return
                
                doc_id = 0
                try:
                    if hasattr(doc, 'id'):
                        doc_id = int(doc.id)
                except:
                    pass
                
                if doc_id <= 0:
                    return
                
                is_our_badge = False
                for user_id, badge_data in badges.items():
                    emoji_doc_id = safe_int(badge_data.get("emoji_doc_id", 0), 0)
                    if emoji_doc_id == doc_id:
                        is_our_badge = True
                        break
                
                if is_our_badge:
                    param.args[3] = None
        except:
            pass

class AchievementsPlugin(BasePlugin):
    def __init__(self):
        super().__init__()
        self._cache_dir: Optional[str] = None
        self._user_id: Optional[int] = None
        self._auth_token: Optional[str] = None
        self._stats: UserStats = UserStats()
        self._unlocked: Set[str] = set()
        self._fire_streaks: Dict[int, FireStreak] = {}
        self._last_sync: float = 0
        
        self._pending_notifications: List[Dict] = []
        self._sounds_cache: Dict[str, str] = {}
        self._media_player = None
        self._notification_lock = threading.Lock()
        self._is_processing_notifications = False
        self._sound_playing = False
        
        self._streak_check_timer = None
        self._sync_timer = None
        
        self._badge_hook = None
        self._BadgeDTO = None
        
        self._global_badge_cache: Optional[GlobalBadgeCache] = None
        self._badges_stop_event = threading.Event()
        self._badges_initialized = False

    def get_badges(self) -> Dict[int, dict]:
        if self._global_badge_cache:
            return self._global_badge_cache.get_badges()
        return {}

    def _fetch_badges_sync(self, force: bool = False):
        try:
            if not self._global_badge_cache:
                return
            
            if not force:
                self._global_badge_cache.load_from_file()
                if not self._global_badge_cache.needs_refresh():
                    return
            
            headers = {}
            current_etag = self._global_badge_cache.get_etag()
            if current_etag:
                headers['If-None-Match'] = current_etag
            
            response = requests.get(
                "https://badges.ettacent.dev/api/v1/badges",
                headers=headers,
                timeout=10
            )
            
            if response.status_code == 304:
                self._global_badge_cache.update(
                    self._global_badge_cache.get_badges(),
                    current_etag
                )
                return
            
            if response.status_code == 200:
                data = response.json()
                new_etag = response.headers.get('ETag', '')
                
                badges_raw = data.get("badges", {})
                if isinstance(badges_raw, dict):
                    new_badges = {}
                    for k, v in badges_raw.items():
                        entity_id = safe_int(k, 0)
                        if entity_id != 0 and isinstance(v, dict):
                            new_badges[entity_id] = v
                    
                    self._global_badge_cache.update(new_badges, new_etag)
        except:
            pass

    def on_plugin_load(self):
        self._cache_dir = os.path.join(get_cache_dir(), "achievements")
        ensure_dir_exists(self._cache_dir)
        
        self._user_id = self._get_current_user_id()
        
        self._migrate_old_cache()
        
        self._load_local_cache()
        self._load_streaks_cache()
        self._load_auth_token()
        
        self._init_badges_system()
        
        self.add_on_send_message_hook(priority=50)
        self.add_hook("TL_messages_editMessage")
        self.add_hook("TL_messages_sendReaction")
        self.add_hook("TL_messages_forwardMessages")
        self.add_hook("TL_updateNewMessage")
        self.add_hook("TL_updateNewChannelMessage")
        
        self.add_menu_item(
            MenuItemData(
                menu_type=MenuItemType.DRAWER_MENU,
                text="🏆 " + Strings.get('plugin_name'),
                on_click=self._on_drawer_menu_click,
                icon="msg_settings_old"
            )
        )
        
        run_on_queue(self._preload_sounds)
        
        if self._user_id:
            run_on_queue(self._ensure_auth_and_sync)
        
        self._start_streak_check_timer()
        self._start_sync_timer()
        
        run_on_ui_thread(lambda: self._check_pending_streak_notifications(), 2000)
        run_on_queue(self.check_for_update)
    def on_plugin_unload(self):
        self._save_local_cache()
        self._save_streaks_cache()
        
        if self._user_id and self._auth_token:
            self._sync_to_server()
            self._sync_streaks_to_server()
        
        self._cleanup_media_player()
        
        if self._streak_check_timer:
            self._streak_check_timer.cancel()
        if self._sync_timer:
            self._sync_timer.cancel()
        
        self._badges_stop_event.set()
        
        if self._badge_hook:
            try:
                self.unhook_method(self._badge_hook)
            except:
                pass
        
        self._badges_initialized = False
    def _setup_badge_hook(self):
        if self._badge_hook:
            return
        
        try:
            from hook_utils import find_class
            from base_plugin import MethodHook
            
            BadgeDTO = find_class("com.exteragram.messenger.api.dto.BadgeDTO")
            BadgesController = find_class("com.exteragram.messenger.badges.BadgesController")
            TLObject = find_class("org.telegram.tgnet.TLObject")
            
            if not BadgeDTO or not BadgesController or not TLObject:
                return
            
            self._BadgeDTO = BadgeDTO
            
            method = BadgesController.getClass().getDeclaredMethod("getBadge", TLObject)
            method.setAccessible(True)
            
            plugin = self
            
            class CombinedBadgeHook(MethodHook):
                def after_hooked_method(self, param):
                    try:
                        tl_object = param.args[0]
                        if tl_object is None:
                            return
                        
                        obj_id = safe_int(getattr(tl_object, "id", 0), 0)
                        if obj_id <= 0:
                            return
                        
                        if obj_id != plugin._user_id:
                            streak_badge = plugin._get_streak_badge_info(obj_id)
                            if streak_badge:
                                emoji_doc_id, badge_text = streak_badge
                                if emoji_doc_id > 0 and badge_text:
                                    badge = plugin._BadgeDTO(int(emoji_doc_id), str(badge_text))
                                    param.setResult(badge)
                                    return
                        
                        server_badge = plugin._get_server_badge_info(obj_id)
                        if server_badge:
                            emoji_doc_id, badge_text = server_badge
                            if emoji_doc_id > 0:
                                badge = plugin._BadgeDTO(int(emoji_doc_id), str(badge_text))
                                param.setResult(badge)
                    except:
                        pass
            
            self._badge_hook = self.hook_method(method, CombinedBadgeHook())
            
            BulletinFactory = find_class("org.telegram.ui.Components.BulletinFactory")
            if BulletinFactory:
                self.hook_all_methods(BulletinFactory, "createEmojiBulletin", BulletinFactoryHook(self))
            
        except:
            pass

    def _get_streak_badge_info(self, user_id: int) -> Optional[tuple]:
        if not user_id or user_id <= 0:
            return None
        
        if user_id not in self._fire_streaks:
            return None
        
        streak = self._fire_streaks[user_id]
        
        if streak.is_active:
            days = streak.streak_days
            today = datetime.now().strftime("%Y-%m-%d")
            
            my_wrote_today = today in streak.my_message_dates
            partner_wrote_today = today in streak.partner_message_dates
            waiting = not my_wrote_today or not partner_wrote_today
            
            if streak.warned or waiting:
                emoji_doc_id = 5386745190914482793
                badge_text = f"{days}"
            elif days >= 365:
                emoji_doc_id = 5237694986631270872
                badge_text = f"{days}"
            elif days >= 200:
                emoji_doc_id = 5386399931378440814
                badge_text = f"{days}"
            elif days >= 100:
                emoji_doc_id = 5397890811436213746
                badge_text = f"{days}"
            elif days >= 60:
                emoji_doc_id = 5427193698259572595
                badge_text = f"{days}"
            elif days >= 30:
                emoji_doc_id = 5427168083074628963
                badge_text = f"{days}"
            elif days >= 14:
                emoji_doc_id = 5325547803936572038
                badge_text = f"{days}"
            elif days >= 7:
                emoji_doc_id = 5463154755054349837
                badge_text = f"{days}"
            else:
                emoji_doc_id = 5463154755054349837
                badge_text = f"{days}"
            
            return (emoji_doc_id, badge_text)
        
        elif streak.can_restore:
            emoji_doc_id = 5386745190914482793
            badge_text = "💔"
            return (emoji_doc_id, badge_text)
        
        return None

    def _parse_version(self, v: str) -> tuple:
        try:
            return tuple(map(int, v.replace('-', '.').split('.')[:3]))
        except:
            return (0, 0, 0)
    
    def check_for_update(self):
        try:
            r = requests.get(Config.UPDATE_CHECK_URL, timeout=10)
            if r.status_code != 200:
                return
            
            latest = r.json().get("version", "")
            if not latest:
                return
            
            current_ver = self._parse_version(__version__)
            latest_ver = self._parse_version(latest)
            
            if latest_ver <= current_ver:
                return
            
            code = requests.get(Config.UPDATE_DOWNLOAD_URL, timeout=30).text
            if not code or len(code) < 1000:
                return
            
            plugin_path = __file__
            backup_path = plugin_path + ".backup"
            
            if os.path.exists(backup_path):
                os.remove(backup_path)
            
            os.rename(plugin_path, backup_path)
            
            with open(plugin_path, "w", encoding="utf-8") as f:
                f.write(code)
            
            run_on_ui_thread(lambda: BulletinHelper.show_success(Strings.get('update_available')))
            
        except:
            pass
    def _init_badges_system(self):
        if self._badges_initialized:
            return
        
        global_cache_dir = os.path.join(get_cache_dir(), "ettacent_shared")
        ensure_dir_exists(global_cache_dir)
        self._global_badge_cache = GlobalBadgeCache(global_cache_dir)
        
        self._global_badge_cache.load_from_file()
        
        self._setup_badge_hook()
        
        self._badges_stop_event.clear()
        threading.Thread(target=self._badges_loop, daemon=True).start()
        run_on_queue(self._fetch_badges_sync)
        
        self._badges_initialized = True

    def _fetch_badges_sync(self, force: bool = False):
        try:
            if not self._global_badge_cache:
                return
            
            if not force:
                self._global_badge_cache.load_from_file()
                if not self._global_badge_cache.needs_refresh():
                    return
            
            headers = {}
            current_etag = self._global_badge_cache.get_etag()
            if current_etag:
                headers['If-None-Match'] = current_etag
            
            response = requests.get(
                "https://badges.ettacent.dev/api/v1/badges",
                headers=headers,
                timeout=10
            )
            
            if response.status_code == 304:
                self._global_badge_cache.update(
                    self._global_badge_cache.get_badges(),
                    current_etag
                )
                return
            
            if response.status_code == 200:
                data = response.json()
                new_etag = response.headers.get('ETag', '')
                
                badges_raw = data.get("badges", {})
                if isinstance(badges_raw, dict):
                    new_badges = {}
                    for k, v in badges_raw.items():
                        entity_id = safe_int(k, 0)
                        if entity_id != 0 and isinstance(v, dict):
                            new_badges[entity_id] = v
                    
                    self._global_badge_cache.update(new_badges, new_etag)
        except:
            pass

    def _badges_loop(self):
        while not self._badges_stop_event.is_set():
            try:
                if self._global_badge_cache:
                    self._global_badge_cache.load_from_file()
                
                if self._global_badge_cache and self._global_badge_cache.needs_refresh():
                    if self._quick_check_badge_updates():
                        self._fetch_badges_sync(force=True)
                    else:
                        self._global_badge_cache.update(
                            self._global_badge_cache.get_badges(),
                            self._global_badge_cache.get_etag()
                        )
            except:
                pass
            
            self._badges_stop_event.wait(15)

    def _quick_check_badge_updates(self) -> bool:
        try:
            if not self._global_badge_cache:
                return False
            timestamp = int(self._global_badge_cache.get_timestamp())
            response = requests.get(
                f"https://badges.ettacent.dev/api/v1/badges/check?since={timestamp}",
                timeout=5
            )
            if response.status_code == 200:
                data = response.json()
                return data.get('has_updates', False)
            return False
        except:
            return False

    def _get_server_badge_info(self, user_id: int) -> Optional[tuple]:
        if not self._global_badge_cache:
            return None
        
        badges = self._global_badge_cache.get_badges()
        if not badges:
            return None
        
        badge_data = badges.get(user_id)
        
        if badge_data is None and user_id > 0:
            badge_data = badges.get(-user_id)
        
        if badge_data is None and user_id > 0:
            channel_id = -1000000000000 - user_id
            badge_data = badges.get(channel_id)
        
        if not isinstance(badge_data, dict):
            return None
        
        emoji_doc_id = safe_int(badge_data.get("emoji_doc_id", 0), 0)
        if emoji_doc_id <= 0:
            return None
        
        text = str(badge_data.get("text", "") or "")
        return (emoji_doc_id, text)


    def _start_streak_check_timer(self):
        def check_loop():
            try:
                self._check_streaks_expiry()
            except:
                pass
            
            self._streak_check_timer = threading.Timer(Config.STREAK_CHECK_INTERVAL, check_loop)
            self._streak_check_timer.daemon = True
            self._streak_check_timer.start()
        
        self._streak_check_timer = threading.Timer(60, check_loop)
        self._streak_check_timer.daemon = True
        self._streak_check_timer.start()
    
    def _start_sync_timer(self):
        def sync_loop():
            try:
                if self._user_id and self._auth_token:
                    self._sync_streaks_to_server()
                    time.sleep(0.2)
                    self._sync_streaks_from_server()
                    self._save_streaks_cache()
                    
                    if self.get_setting("auto_sync", True):
                        self._sync_to_server()
                        time.sleep(0.2)
                        self._sync_from_server()
                        self._last_sync = time.time()
                        self._save_local_cache()
            except:
                pass
            
            self._sync_timer = threading.Timer(Config.SYNC_INTERVAL, sync_loop)
            self._sync_timer.daemon = True
            self._sync_timer.start()
        
        self._sync_timer = threading.Timer(Config.SYNC_INTERVAL, sync_loop)
        self._sync_timer.daemon = True
        self._sync_timer.start()

    def _preload_sounds(self):
        sounds = ["default.ogg", "rare.ogg"]
        for sound in sounds:
            self._download_sound(sound)
    
    def _download_sound(self, filename: str) -> Optional[str]:
        if filename in self._sounds_cache:
            return self._sounds_cache[filename]
        
        local_path = os.path.join(self._cache_dir, filename)
        
        if os.path.exists(local_path):
            self._sounds_cache[filename] = local_path
            return local_path
        
        try:
            url = f"{Config.SOUNDS_URL}/{filename}"
            response = requests.get(url, timeout=10)
            if response.status_code == 200:
                with open(local_path, 'wb') as f:
                    f.write(response.content)
                self._sounds_cache[filename] = local_path
                return local_path
        except:
            pass
        
        return None
    
    def _play_sound_sync(self, rarity: Rarity, force: bool = False):
        if not force and not self.get_setting("sound_enabled", True):
            return
        
        if self._sound_playing:
            return
        
        try:
            from android.media import MediaPlayer
            
            sound_file = RARITY_INFO[rarity]['sound']
            sound_path = self._sounds_cache.get(sound_file)
            
            if not sound_path or not os.path.exists(sound_path):
                sound_path = self._download_sound(sound_file)
            
            if not sound_path or not os.path.exists(sound_path):
                return
            
            self._sound_playing = True
            self._cleanup_media_player()
            
            self._media_player = MediaPlayer()
            self._media_player.setDataSource(sound_path)
            self._media_player.prepare()
            self._media_player.start()
            
            def reset_flag():
                time.sleep(1.5)
                self._sound_playing = False
            threading.Thread(target=reset_flag, daemon=True).start()
            
        except:
            self._sound_playing = False
    
    def _cleanup_media_player(self):
        try:
            if self._media_player:
                self._media_player.release()
                self._media_player = None
        except:
            pass

    def _queue_notification(self, notif_type: str, data: Any):
        with self._notification_lock:
            self._pending_notifications.append({
                "type": notif_type,
                "data": data
            })
        
        self._process_notification_queue()
    
    def _process_notification_queue(self):
        with self._notification_lock:
            has_streak_notifications = any(
                n["type"] in ("streak_started", "streak_warning", "streak_expired", "streak_restored")
                for n in self._pending_notifications
            )
        
        if not self.get_setting("notifications", True):
            with self._notification_lock:
                self._pending_notifications = [
                    n for n in self._pending_notifications
                    if n["type"] in ("streak_started", "streak_warning", "streak_expired", "streak_restored")
                ]
                if not self._pending_notifications:
                    return
        
        with self._notification_lock:
            if not self._pending_notifications or self._is_processing_notifications:
                return
            self._is_processing_notifications = True
        
        run_on_ui_thread(self._show_next_notification_ui)

    
    def _show_next_notification_ui(self):
        notification = None
        
        with self._notification_lock:
            if self._pending_notifications:
                notification = self._pending_notifications.pop(0)
            else:
                self._is_processing_notifications = False
                return
        
        if notification:
            notif_type = notification["type"]
            data = notification["data"]
            
            if notif_type == "achievement":
                achievement = ACHIEVEMENTS.get(data)
                if achievement:
                    self._play_sound_sync(achievement.rarity, force=False)
                    
                    rarity_info = RARITY_INFO[achievement.rarity]
                    message = f"{achievement.icon} {achievement.get_name()} {rarity_info['emoji']}"
                    BulletinHelper.show_success(message)
            
            elif notif_type == "streak_started":
                partner_name = data
                self._play_sound_sync(Rarity.RARE, force=True)
                BulletinHelper.show_success(Strings.get('streak_started', name=partner_name))
            
            elif notif_type == "streak_warning":
                partner_name = data
                self._play_sound_sync(Rarity.UNCOMMON, force=True)
                BulletinHelper.show_info(Strings.get('streak_warning', name=partner_name))
            
            elif notif_type == "streak_expired":
                partner_name = data
                self._play_sound_sync(Rarity.COMMON, force=True)
                BulletinHelper.show_error(Strings.get('streak_expired', name=partner_name))
            
            elif notif_type == "streak_restored":
                partner_name = data
                self._play_sound_sync(Rarity.RARE, force=True)
                BulletinHelper.show_success(Strings.get('streak_restored', name=partner_name))
        
        with self._notification_lock:
            has_more = len(self._pending_notifications) > 0
        
        if has_more:
            def show_next():
                time.sleep(Config.NOTIFICATION_DELAY_MS / 1000.0)
                run_on_ui_thread(self._show_next_notification_ui)
            threading.Thread(target=show_next, daemon=True).start()
        else:
            with self._notification_lock:
                self._is_processing_notifications = False
    
    def _check_pending_streak_notifications(self):
        for streak in self._fire_streaks.values():
            if streak.pending_notification and streak.is_active:
                streak.pending_notification = False
                self._queue_notification("streak_started", streak.partner_name)
        
        self._save_streaks_cache()

    def _try_unlock(self, achievement_id: str):
        if achievement_id in self._unlocked:
            return
        
        if achievement_id not in ACHIEVEMENTS:
            return
        
        achievement = ACHIEVEMENTS[achievement_id]
        
        if achievement.requires_threshold > 0:
            if self._stats.messages_sent < achievement.requires_threshold:
                return
        
        self._unlocked.add(achievement_id)
        
        self._queue_notification("achievement", achievement_id)
        
        self._save_local_cache()
        run_on_queue(self._sync_to_server)

    def _on_drawer_menu_click(self, context: Dict[str, Any]):
        run_on_ui_thread(self._show_main_menu)

    def create_settings(self) -> List:
        unlocked_count = len(self._unlocked)
        total_count = len(ACHIEVEMENTS)
        progress_percent = int((unlocked_count / total_count) * 100) if total_count > 0 else 0
        progress_bar = self._create_progress_bar(progress_percent)
        active_streaks = sum(1 for s in self._fire_streaks.values() if s.is_active)
        pending_streaks = sum(1 for s in self._fire_streaks.values() if s.is_pending and not s.is_active)
        
        return [
            Header(text=Strings.get('header_settings')),
            Switch(key="notifications", text=Strings.get('show_notifications'), subtext=Strings.get('show_notifications_sub'), default=True, icon="msg_notifications"),
            Switch(key="sound_enabled", text=Strings.get('sound_enabled'), subtext=Strings.get('sound_enabled_sub'), default=True, icon="msg_tone_on"),
            Switch(key="auto_sync", text=Strings.get('auto_sync'), subtext=Strings.get('auto_sync_sub'), default=True, icon="msg_retry"),
            Switch(key="streak_notifications", text=Strings.get('streak_notifications'), subtext=Strings.get('streak_notifications_sub'), default=True, icon="msg_fireworks"),
            Divider(),
            Header(text=Strings.get('header_stats')),
            Text(text=f"🏆 {progress_bar} {unlocked_count}/{total_count} ({progress_percent}%)"),
            Text(text=f"{Strings.get('messages_sent')}: {self._stats.messages_sent:,}"),
            Text(text=f"{Strings.get('photos_sent')}: {self._stats.photos_sent:,} | {Strings.get('videos_sent')}: {self._stats.videos_sent:,}"),
            Text(text=f"{Strings.get('gifs_sent')}: {self._stats.gifs_sent:,} | {Strings.get('stickers_sent')}: {self._stats.stickers_sent:,}"),
            Text(text=f"{Strings.get('chats_used')}: {self._stats.unique_chats:,} | {Strings.get('days_active')}: {len(self._stats.days_active):,}"),
            Divider(),
            Header(text=Strings.get('header_streaks')),
            Text(text=f"🔥 {active_streaks} активных | ⏳ {pending_streaks} ожидающих" if active_streaks or pending_streaks else Strings.get('streak_no_active')),
            Divider(),
            Header(text=Strings.get('header_quick_actions')),
            Text(text=Strings.get('view_achievements'), on_click=lambda v: self._show_main_menu()),
            Text(text=Strings.get('view_streaks'), on_click=lambda v: self._show_streaks_menu()),
            Text(text=Strings.get('refresh_stats'), on_click=lambda v: self._refresh_settings()),
            Text(text=Strings.get('sync_now'), on_click=lambda v: self._manual_sync()),
            Divider(),
            Text(text=Strings.get('reset_progress'), red=True, on_click=lambda v: self._confirm_reset()),
        ]

    def _create_progress_bar(self, percent: int, width: int = 10) -> str:
        filled = int(width * percent / 100)
        empty = width - filled
        return "█" * filled + "░" * empty

    def _refresh_settings(self):
        self._load_local_cache()
        self._load_streaks_cache()
        self.set_setting("_refresh_trigger", time.time(), reload_settings=True)
        BulletinHelper.show_success("🔄 " + Strings.get('refresh_stats'))

    def on_send_message_hook(self, account: int, params: Any) -> HookResult:
        try:
            self._check_account_switch()
            self._process_message(params)
        except:
            pass
        return HookResult()

    def pre_request_hook(self, request_name: str, account: int, request: Any) -> HookResult:
        try:
            self._check_account_switch()
            if request_name == "TL_messages_editMessage":
                self._on_message_edited()
            elif request_name == "TL_messages_sendReaction":
                self._on_reaction_sent()
            elif request_name == "TL_messages_forwardMessages":
                self._on_message_forwarded(request)
        except:
            pass
        return HookResult()

    def on_update_hook(self, update_name: str, account: int, update: Any) -> HookResult:
        try:
            self._check_account_switch()
            if update_name in ("TL_updateNewMessage", "TL_updateNewChannelMessage"):
                self._process_incoming_message(update)
        except:
            pass
        return HookResult()

    def _process_message(self, params: Any):
        if getattr(self, '_is_sending_debug', False):
            return
        
        message_text = getattr(params, 'message', None)
        if message_text and isinstance(message_text, str) and "ACH DEBUG" in message_text:
            return
        
        now = datetime.now()
        today = now.strftime("%Y-%m-%d")
        self._stats.days_active.add(today)
        
        document = getattr(params, 'document', None)
        photo = getattr(params, 'photo', None)
        peer = getattr(params, 'peer', None)
        reply_to = getattr(params, 'replyToMsg', None)
        
        self._stats.messages_sent += 1
        self._stats.messages_timestamps.append(time.time())
        cutoff = time.time() - 60
        self._stats.messages_timestamps = [t for t in self._stats.messages_timestamps if t > cutoff]
        
        media_type = None
        
        if peer:
            self._process_peer(peer, today)
        
        if reply_to:
            self._stats.replies_made += 1
            self._check_reply_achievements()
        
        if photo:
            self._stats.photos_sent += 1
            media_type = 'photo'
        
        if document:
            media_type = self._check_document_type(document)
        
        if message_text and isinstance(message_text, str):
            self._analyze_message_text(message_text, now)
        
        self._check_time_achievements(now)
        self._check_message_count_achievements()
        self._check_speed_achievements()
        self._check_media_achievements(media_type)
        self._check_days_active_achievements()
        self._check_collector_achievements()
        
        self._save_local_cache()

    def _process_incoming_message(self, update: Any):
        try:
            message = getattr(update, 'message', None)
            if not message:
                return
            
            from_id = None
            if hasattr(message, 'from_id'):
                from_id_obj = message.from_id
                if hasattr(from_id_obj, 'user_id'):
                    from_id = from_id_obj.user_id
            
            if not from_id:
                from_id = getattr(message, 'peer_id', None)
                if from_id and hasattr(from_id, 'user_id'):
                    from_id = from_id.user_id
                else:
                    return
            
            if from_id == self._user_id:
                return
            
            peer_id = getattr(message, 'peer_id', None)
            if not peer_id:
                return
            
            peer_class = ""
            try:
                peer_class = peer_id.getClass().getSimpleName() if hasattr(peer_id, 'getClass') else str(type(peer_id))
            except:
                peer_class = str(type(peer_id))
            
            if 'PeerUser' not in peer_class:
                return
            
            today = datetime.now().strftime("%Y-%m-%d")
            self._add_partner_message_local(from_id, today)
            
        except:
            pass

    def _process_peer(self, peer: Any, today: str):
        try:
            peer_id = None
            
            if isinstance(peer, int):
                peer_id = peer
            else:
                peer_class = ""
                try:
                    if hasattr(peer, 'getClass'):
                        peer_class = peer.getClass().getSimpleName()
                    else:
                        peer_class = type(peer).__name__
                except:
                    peer_class = str(type(peer))
                
                if 'Channel' in peer_class:
                    channel_id = getattr(peer, 'channel_id', 0)
                    if channel_id:
                        peer_id = -1000000000000 - channel_id
                elif 'Chat' in peer_class:
                    chat_id = getattr(peer, 'chat_id', 0)
                    if chat_id:
                        peer_id = -chat_id
                elif 'User' in peer_class:
                    user_id = getattr(peer, 'user_id', 0)
                    if user_id:
                        peer_id = user_id
                else:
                    if hasattr(peer, 'channel_id') and peer.channel_id:
                        peer_id = -1000000000000 - peer.channel_id
                    elif hasattr(peer, 'chat_id') and peer.chat_id:
                        peer_id = -peer.chat_id
                    elif hasattr(peer, 'user_id') and peer.user_id:
                        peer_id = peer.user_id
            
            if peer_id is None or peer_id == 0:
                return
            
            if peer_id == self._user_id:
                return
            
            is_new_chat = peer_id not in self._stats.known_chat_ids
            
            if is_new_chat:
                self._stats.known_chat_ids.add(peer_id)
                self._stats.unique_chats += 1
                self._check_social_achievements()
            
            if peer_id > 0:
                if is_new_chat:
                    self._stats.private_chats_count += 1
                    self._try_unlock('private_talk')
                
                try:
                    mc = get_messages_controller()
                    if mc:
                        user = mc.getUser(peer_id)
                        if user:
                            is_bot = getattr(user, 'bot', False)
                            if is_bot:
                                if is_new_chat:
                                    self._stats.bot_chats_count += 1
                                    self._try_unlock('bot_friend')
                            else:
                                self._add_my_message_to_streak(peer_id, user, today)
                except:
                    pass
            
            elif peer_id < 0:
                if peer_id < -1000000000000:
                    chat_id_to_check = -(peer_id + 1000000000000)
                else:
                    chat_id_to_check = abs(peer_id)
                
                try:
                    mc = get_messages_controller()
                    if mc:
                        chat = mc.getChat(chat_id_to_check)
                        
                        if chat:
                            is_megagroup = getattr(chat, 'megagroup', False)
                            is_broadcast = getattr(chat, 'broadcast', False)
                            is_gigagroup = getattr(chat, 'gigagroup', False)
                            
                            if is_megagroup or is_gigagroup:
                                if is_new_chat:
                                    self._stats.group_chats_count += 1
                                    self._try_unlock('group_member')
                            elif is_broadcast:
                                if is_new_chat:
                                    self._stats.channel_chats_count += 1
                                self._try_unlock('channel_writer')
                            else:
                                if is_new_chat:
                                    self._stats.group_chats_count += 1
                                    self._try_unlock('group_member')
                        else:
                            if is_new_chat:
                                self._stats.channel_chats_count += 1
                            self._try_unlock('channel_writer')
                except:
                    if is_new_chat:
                        self._stats.group_chats_count += 1
                    self._try_unlock('group_member')
            
        except:
            pass

    def _get_user_name(self, user_id: int) -> str:
        try:
            mc = get_messages_controller()
            if mc:
                user = mc.getUser(int(user_id))
                if user:
                    first = getattr(user, 'first_name', '') or ''
                    last = getattr(user, 'last_name', '') or ''
                    name = f"{first} {last}".strip()
                    if name:
                        return name
        except:
            pass
        return f"User {user_id}"

    def _add_my_message_to_streak(self, partner_id: int, user: Any, today: str):
        if not partner_id or partner_id == self._user_id:
            return
        
        partner_name = ""
        try:
            if user:
                first_name = getattr(user, 'first_name', '') or ''
                last_name = getattr(user, 'last_name', '') or ''
                partner_name = f"{first_name} {last_name}".strip()
                if not partner_name:
                    partner_name = getattr(user, 'username', '') or f"User {partner_id}"
        except:
            partner_name = f"User {partner_id}"
        
        if partner_id not in self._fire_streaks:
            self._fire_streaks[partner_id] = FireStreak(
                partner_id=partner_id,
                partner_name=partner_name,
            )
        
        streak = self._fire_streaks[partner_id]
        streak.partner_name = partner_name
        streak.last_interaction = datetime.now().isoformat()
        
        if today not in streak.my_message_dates:
            streak.my_message_dates.append(today)
            streak.my_message_dates = streak.my_message_dates[-30:]
            streak.last_my_date = today
            run_on_queue(self._sync_streaks_to_server)
        
        if streak.can_restore and not streak.is_active:
            if streak.check_restore_limit():
                streak.use_restore()
                streak.is_active = True
                streak.is_pending = False
                streak.can_restore = False
                streak.expired_at = ""
                streak.warned = False
                self._stats.streak_restored_count += 1
                self._try_unlock('streak_saved')
                self._queue_notification("streak_restored", partner_name)
        
        was_active = streak.is_active
        self._check_streak_activation(streak)
        
        if streak.is_active and not was_active:
            self._queue_notification("streak_started", streak.partner_name)
        
        self._save_streaks_cache()

    def _add_partner_message_local(self, partner_id: int, today: str):
        if not partner_id or partner_id == self._user_id:
            return
        
        partner_name = self._get_user_name(partner_id)
        
        if partner_id not in self._fire_streaks:
            self._fire_streaks[partner_id] = FireStreak(
                partner_id=partner_id,
                partner_name=partner_name,
            )
        
        streak = self._fire_streaks[partner_id]
        streak.partner_name = partner_name
        streak.last_interaction = datetime.now().isoformat()
        
        if today not in streak.partner_message_dates:
            streak.partner_message_dates.append(today)
            streak.partner_message_dates = streak.partner_message_dates[-30:]
            streak.last_partner_date = today
            run_on_queue(self._sync_streaks_to_server)
        
        was_active = streak.is_active
        self._check_streak_activation(streak)
        
        if streak.is_active and not was_active:
            self._queue_notification("streak_started", streak.partner_name)
        
        self._save_streaks_cache()

    def _check_streak_activation(self, streak: FireStreak):
        consecutive = streak.get_consecutive_days()
        
        if consecutive >= Config.STREAK_START_DAYS:
            if not streak.is_active:
                streak.is_active = True
                streak.is_pending = False
                streak.started_at = datetime.now().strftime("%Y-%m-%d")
                streak.streak_days = consecutive
                streak.warned = False
                
                self._try_unlock('fire_streak')
            else:
                streak.streak_days = consecutive
                streak.warned = False
            
            self._check_fire_streak_achievements()
        else:
            streak.is_pending = True
            streak.streak_days = consecutive

    def _check_streaks_expiry(self):
        now = datetime.now()
        today = now.strftime("%Y-%m-%d")
        yesterday = (now - timedelta(days=1)).strftime("%Y-%m-%d")
        
        for partner_id, streak in list(self._fire_streaks.items()):
            if not streak.is_active:
                if streak.can_restore:
                    try:
                        expired = datetime.strptime(streak.expired_at, "%Y-%m-%d")
                        if (now - expired).days > 7:
                            streak.can_restore = False
                    except:
                        pass
                continue
            
            my_dates = set(streak.my_message_dates)
            partner_dates = set(streak.partner_message_dates)
            
            my_today = today in my_dates or yesterday in my_dates
            partner_today = today in partner_dates or yesterday in partner_dates
            
            if not my_today or not partner_today:
                streak.is_active = False
                streak.expired_at = today
                streak.can_restore = streak.streak_days >= 7 and streak.check_restore_limit()
                
                self._queue_notification("streak_expired", streak.partner_name)
                continue
            
            hours_until_midnight = 24 - now.hour
            if hours_until_midnight <= Config.STREAK_WARNING_HOURS and not streak.warned:
                if today not in my_dates or today not in partner_dates:
                    streak.warned = True
                    self._queue_notification("streak_warning", streak.partner_name)
        
        self._save_streaks_cache()

    def _check_fire_streak_achievements(self):
        max_streak_days = 0
        active_count = 0
        
        for streak in self._fire_streaks.values():
            if streak.is_active:
                active_count += 1
                max_streak_days = max(max_streak_days, streak.streak_days)
        
        streak_thresholds = [
            (7, 'fire_streak_7'),
            (14, 'fire_streak_14'),
            (30, 'fire_streak_30'),
            (60, 'fire_streak_60'),
            (100, 'fire_streak_100'),
            (200, 'fire_streak_200'),
            (365, 'fire_streak_365'),
        ]
        
        for threshold, ach_id in streak_thresholds:
            if max_streak_days >= threshold:
                self._try_unlock(ach_id)
        
        if active_count >= 3:
            self._try_unlock('multi_streaks_3')
        if active_count >= 5:
            self._try_unlock('multi_streaks_5')
        if active_count >= 10:
            self._try_unlock('multi_streaks_10')

    def _on_message_edited(self):
        self._stats.edits_made += 1
        edits = self._stats.edits_made
        if edits == 1:
            self._try_unlock('editor')
        elif edits == 25:
            self._try_unlock('perfectionist')
        elif edits == 100:
            self._try_unlock('never_satisfied')
        elif edits == 500:
            self._try_unlock('obsessive_editor')
        self._save_local_cache()

    def _on_reaction_sent(self):
        self._stats.reactions_made += 1
        reactions = self._stats.reactions_made
        if reactions == 1:
            self._try_unlock('first_reaction')
        elif reactions == 25:
            self._try_unlock('reactor')
        elif reactions == 100:
            self._try_unlock('reaction_fan')
        elif reactions == 500:
            self._try_unlock('reaction_lover')
        elif reactions == 2000:
            self._try_unlock('reaction_master')
        self._save_local_cache()

    def _on_message_forwarded(self, request: Any):
        try:
            count = 1
            if hasattr(request, 'id'):
                if hasattr(request.id, 'size'):
                    count = request.id.size()
                elif isinstance(request.id, list):
                    count = len(request.id)
            self._stats.forwards_made += count
        except:
            self._stats.forwards_made += 1
        
        self._check_forward_achievements()
        self._save_local_cache()

    def _check_forward_achievements(self):
        forwards = self._stats.forwards_made
        if forwards >= 1:
            self._try_unlock('forwarder')
        if forwards >= 25:
            self._try_unlock('news_spreader')
        if forwards >= 100:
            self._try_unlock('viral_agent')
        if forwards >= 500:
            self._try_unlock('information_broker')

    def _check_reply_achievements(self):
        replies = self._stats.replies_made
        if replies == 1:
            self._try_unlock('replier')
        elif replies == 50:
            self._try_unlock('conversationalist')
        elif replies == 200:
            self._try_unlock('discussion_lover')
        elif replies == 1000:
            self._try_unlock('debate_master')

    def _check_message_count_achievements(self):
        msgs = self._stats.messages_sent
        thresholds = [
            (1, 'first_message'),
            (10, 'getting_started'),
            (50, 'warming_up'),
            (100, 'talkative'),
            (500, 'chatterbox'),
            (1000, 'messenger'),
            (2500, 'communicator'),
            (5000, 'orator'),
            (10000, 'word_master'),
            (25000, 'legend'),
            (50000, 'immortal'),
            (100000, 'god_of_words'),
        ]
        for threshold, ach_id in thresholds:
            if msgs >= threshold:
                self._try_unlock(ach_id)

    def _check_speed_achievements(self):
        timestamps = self._stats.messages_timestamps
        now = time.time()
        
        msgs_30s = sum(1 for t in timestamps if now - t <= 30)
        msgs_60s = len(timestamps)
        
        if msgs_30s >= 5:
            self._try_unlock('speed_demon')
        if msgs_60s >= 10:
            self._try_unlock('spam_master')
        if msgs_60s >= 20:
            self._try_unlock('keyboard_warrior')
        if msgs_60s >= 30:
            self._try_unlock('typing_god')

    def _check_social_achievements(self):
        chats = self._stats.unique_chats
        thresholds = [
            (1, 'first_chat'),
            (5, 'social_starter'),
            (10, 'social_10'),
            (25, 'social_25'),
            (50, 'social_50'),
            (100, 'social_100'),
            (250, 'social_250'),
            (500, 'social_500'),
        ]
        for threshold, ach_id in thresholds:
            if chats >= threshold:
                self._try_unlock(ach_id)

    def _check_days_active_achievements(self):
        days = len(self._stats.days_active)
        thresholds = [
            (1, 'day_1'),
            (7, 'week_1'),
            (30, 'month_1'),
            (90, 'quarter'),
            (180, 'half_year'),
            (365, 'year_1'),
        ]
        for threshold, ach_id in thresholds:
            if days >= threshold:
                self._try_unlock(ach_id)

    def _check_collector_achievements(self):
        stats = self._stats
        has_photo = stats.photos_sent > 0
        has_video = stats.videos_sent > 0
        has_voice = stats.voice_sent > 0
        has_sticker = stats.stickers_sent > 0
        has_gif = stats.gifs_sent > 0
        has_file = stats.files_sent > 0
        has_audio = stats.audios_sent > 0
        has_video_note = stats.video_notes_sent > 0
        
        if has_photo and has_video and has_voice and has_sticker:
            self._try_unlock('media_variety')
        
        if has_photo and has_video and has_voice and has_sticker and has_gif and has_file and has_audio and has_video_note:
            self._try_unlock('complete_set')
        
        has_private = stats.private_chats_count > 0
        has_group = stats.group_chats_count > 0
        has_channel = stats.channel_chats_count > 0
        has_bot = stats.bot_chats_count > 0
        
        if has_private and has_group and has_channel:
            self._try_unlock('chat_explorer')
        
        if has_private and has_group and has_channel and has_bot:
            self._try_unlock('full_explorer')

    def _check_media_achievements(self, media_type: Optional[str]):
        if not media_type:
            return
        
        media_thresholds = {
            'photo': [
                (1, 'first_photo'), (25, 'amateur_photographer'), (100, 'photographer'),
                (500, 'pro_photographer'), (1000, 'paparazzi'), (5000, 'photo_legend'),
            ],
            'video': [
                (1, 'first_video'), (10, 'video_amateur'), (50, 'videographer'),
                (200, 'director'), (1000, 'hollywood'),
            ],
            'voice': [
                (1, 'first_voice'), (25, 'voice_user'), (100, 'podcaster'),
                (500, 'radio_host'), (2000, 'voice_legend'),
            ],
            'sticker': [
                (1, 'first_sticker'), (50, 'sticker_fan'), (250, 'sticker_lover'),
                (1000, 'sticker_addict'), (5000, 'sticker_maniac'), (15000, 'sticker_god'),
            ],
            'gif': [
                (1, 'first_gif'), (25, 'gif_user'), (100, 'animator'),
                (500, 'gif_master'), (2000, 'gif_lord'),
            ],
            'file': [
                (1, 'first_file'), (25, 'file_sharer'), (100, 'archivist'),
                (500, 'data_hoarder'), (2000, 'cloud_storage'),
            ],
            'audio': [
                (1, 'first_audio'), (25, 'music_lover'), (100, 'dj'), (500, 'music_producer'),
            ],
            'video_note': [
                (1, 'first_video_note'), (25, 'circle_fan'), (100, 'circle_master'), (500, 'circle_legend'),
            ],
        }
        
        count_map = {
            'photo': self._stats.photos_sent,
            'video': self._stats.videos_sent,
            'voice': self._stats.voice_sent,
            'sticker': self._stats.stickers_sent,
            'gif': self._stats.gifs_sent,
            'file': self._stats.files_sent,
            'audio': self._stats.audios_sent,
            'video_note': self._stats.video_notes_sent,
        }
        
        if media_type in media_thresholds:
            count = count_map.get(media_type, 0)
            for threshold, ach_id in media_thresholds[media_type]:
                if count >= threshold:
                    self._try_unlock(ach_id)

    def _check_time_achievements(self, now: datetime):
        hour = now.hour
        minute = now.minute
        weekday = now.weekday()
        month = now.month
        day = now.day
        
        if 2 <= hour < 5:
            self._try_unlock('night_owl')
        elif 5 <= hour < 6:
            self._try_unlock('early_bird')
        elif 6 <= hour < 7:
            self._try_unlock('morning_person')
        elif 12 <= hour < 13:
            self._try_unlock('lunch_break')
        elif 20 <= hour < 22:
            self._try_unlock('evening_chatter')
        
        if weekday == 0:
            self._try_unlock('monday_blues')
        elif weekday == 4:
            self._try_unlock('friday_vibes')
        elif weekday >= 5:
            self._try_unlock('weekend_warrior')
        
        holidays = {
            (1, 1): 'new_year', (2, 14): 'valentine', (2, 23): 'defender',
            (3, 8): 'womens_day', (4, 1): 'april_fools', (5, 1): 'may_day',
            (5, 9): 'victory_day', (8, 14): 'telegram_birthday',
            (10, 31): 'halloween', (12, 25): 'christmas',
        }
        if (month, day) in holidays:
            self._try_unlock(holidays[(month, day)])
        
        if hour == 0 and minute == 0:
            self._try_unlock('midnight')
        elif hour == 12 and minute == 0:
            self._try_unlock('high_noon')
        elif hour == 11 and minute == 11:
            self._try_unlock('lucky_time')
        elif hour == 22 and minute == 22:
            self._try_unlock('double_luck')
        elif hour == minute and hour <= 23:
            self._try_unlock('triple_digits')

    def _check_document_type(self, document: Any) -> Optional[str]:
        if not document:
            return None
        
        try:
            mime_type = getattr(document, 'mime_type', '') or ''
            
            attributes = getattr(document, 'attributes', None)
            if not attributes:
                self._stats.files_sent += 1
                return 'file'
            
            attr_list = []
            try:
                if hasattr(attributes, 'size') and hasattr(attributes, 'get'):
                    for i in range(attributes.size()):
                        attr_list.append(attributes.get(i))
                elif hasattr(attributes, '__iter__'):
                    attr_list = list(attributes)
                else:
                    attr_list = [attributes]
            except:
                attr_list = []
            
            has_animated = False
            has_video = False
            has_audio = False
            has_sticker = False
            has_voice = False
            has_video_note = False
            
            for attr in attr_list:
                attr_class = ""
                try:
                    if hasattr(attr, 'getClass'):
                        attr_class = attr.getClass().getSimpleName()
                    else:
                        attr_class = type(attr).__name__
                except:
                    attr_class = str(type(attr))
                
                if 'Animated' in attr_class:
                    has_animated = True
                
                if 'Sticker' in attr_class:
                    has_sticker = True
                
                if 'Video' in attr_class:
                    has_video = True
                    if hasattr(attr, 'round_message') and attr.round_message:
                        has_video_note = True
                
                if 'Audio' in attr_class:
                    has_audio = True
                    if hasattr(attr, 'voice') and attr.voice:
                        has_voice = True
            
            if has_animated:
                self._stats.gifs_sent += 1
                return 'gif'
            
            if has_sticker:
                self._stats.stickers_sent += 1
                return 'sticker'
            
            if has_voice:
                self._stats.voice_sent += 1
                return 'voice'
            
            if has_video_note:
                self._stats.video_notes_sent += 1
                return 'video_note'
            
            if has_video:
                self._stats.videos_sent += 1
                return 'video'
            
            if has_audio:
                self._stats.audios_sent += 1
                return 'audio'
            
            if 'gif' in mime_type.lower():
                self._stats.gifs_sent += 1
                return 'gif'
            
            if mime_type.startswith('video/'):
                self._stats.videos_sent += 1
                return 'video'
            
            if mime_type.startswith('audio/'):
                self._stats.audios_sent += 1
                return 'audio'
            
            if mime_type.startswith('image/'):
                self._stats.photos_sent += 1
                return 'photo'
            
            self._stats.files_sent += 1
            return 'file'
            
        except:
            self._stats.files_sent += 1
            return 'file'
    def _analyze_message_text(self, text: str, now: datetime):
        text_stripped = text.strip()
        
        if len(text_stripped) == 1 and self._stats.messages_sent >= Config.MINIMALIST_THRESHOLD:
            self._try_unlock('minimalist')
        
        length_achievements = [
            (3000, 'tolstoy'), (1500, 'epic_writer'), (700, 'novelist'), (300, 'writer'),
        ]
        for threshold, ach_id in length_achievements:
            if len(text_stripped) >= threshold:
                self._try_unlock(ach_id)
        
        self._check_text_pattern_achievements(text_stripped, now)

    def _check_text_pattern_achievements(self, text: str, now: datetime):
        text_lower = text.lower()
        
        emoji_count = self._count_emojis(text)
        if emoji_count >= 20 and self._is_emoji_only(text):
            self._try_unlock('emoji_master')
        if emoji_count >= 5 and self._is_emoji_only(text):
            self._try_unlock('emoji_only')
        
        letters_only = re.sub(r'[^a-zA-Zа-яА-ЯёЁ]', '', text)
        if letters_only.isupper() and len(letters_only) >= 10:
            self._try_unlock('caps_lock')
        
        if text.isdigit() and len(text) >= 5:
            self._try_unlock('numbers_only')
        
        if re.search(r'https?://\S+', text):
            self._try_unlock('link_sharer')
        
        hashtags = re.findall(r'#\w+', text)
        if len(hashtags) >= 3:
            self._try_unlock('multi_hashtag')
        if len(hashtags) >= 1:
            self._try_unlock('hashtag')
        
        mentions = re.findall(r'@\w+', text)
        if len(mentions) >= 5:
            self._try_unlock('multi_mention')
        if len(mentions) >= 1:
            self._try_unlock('mention')
        
        if '??' in text:
            self._try_unlock('double_question')
        if '?' in text:
            self._try_unlock('question')
        
        if '!!!' in text:
            self._try_unlock('exclamation')
        
        script_count = self._count_scripts(text)
        if script_count >= 3:
            self._try_unlock('trilingual')
        if script_count >= 2:
            self._try_unlock('multilingual')
        
        words = re.findall(r'[a-zA-Zа-яА-ЯёЁ]+', text)
        for word in words:
            if len(word) > 25:
                self._try_unlock('mega_word')
            if len(word) > 15:
                self._try_unlock('long_word')
        
        if re.search(r'(.)\1{14,}', text):
            self._try_unlock('mega_repeater')
        if re.search(r'(.)\1{4,}', text):
            self._try_unlock('repeater')
        
        vowels_ru = set('аеёиоуыэюя')
        vowels_en = set('aeiou')
        vowels = vowels_ru | vowels_en
        for word in words:
            word_lower = word.lower()
            if len(word_lower) >= 4:
                word_letters = set(word_lower)
                if not (word_letters & vowels):
                    self._try_unlock('no_vowels')
                if vowels_ru <= word_letters or vowels_en <= word_letters:
                    self._try_unlock('all_vowels')
        
        self._check_secret_text_achievements(text_lower, now)

    def _check_secret_text_achievements(self, text_lower: str, now: datetime):
        secret_patterns = [
            (r'\b42\b', 'secret_42'),
            (r'hello[,]?\s*world', 'secret_hello_world'),
            (r'lorem ipsum', 'secret_lorem'),
            (r'never gonna give you up|rickroll', 'secret_rickroll'),
            (r'↑↑↓↓←→←→ba|uuddlrlrba', 'secret_konami'),
            (r'\b1337\b|l33t|h4x0r', 'secret_1337'),
            (r'3[.,]14159', 'secret_pi'),
            (r'red pill|blue pill|красная таблетка|синяя таблетка', 'secret_matrix'),
            (r'\bgg\b|\bгг\b', 'secret_gg'),
            (r'\blol\b|\bлол\b', 'secret_lol'),
            (r'\bbruh\b|\bбрух?\b', 'secret_bruh'),
            (r'\bsus\b|\bсас\b', 'secret_sus'),
            (r'ok boomer|окей бумер', 'secret_ok_boomer'),
            (r'\b69\b|\bnice\b', 'secret_nice'),
            (r'uwu|owo', 'secret_uwu'),
            (r'\bxd\b', 'secret_xd'),
            (r'^f$|press f|^ф$', 'secret_f_respect'),
        ]
        
        for pattern, ach_id in secret_patterns:
            if re.search(pattern, text_lower):
                self._try_unlock(ach_id)
        
        if '🤦' in text_lower:
            self._try_unlock('secret_facepalm')
        if '🤔' in text_lower:
            self._try_unlock('secret_thinking')
        if '🔥' in text_lower:
            self._try_unlock('secret_fire_emoji')
        if '❤️' in text_lower or '❤' in text_lower or '♥️' in text_lower or '♥' in text_lower:
            self._try_unlock('secret_heart')
        
        hour = now.hour
        if 0 <= hour < 5:
            if any(p in text_lower for p in ['спокойной ночи', 'good night', 'goodnight', 'споки']):
                self._try_unlock('secret_goodnight')
        
        if 5 <= hour < 8:
            if any(p in text_lower for p in ['доброе утро', 'good morning', 'доброго утра']):
                self._try_unlock('secret_goodmorning')
        
        phrase_achievements = [
            (['с днём рождения', 'happy birthday', 'с др'], 'secret_birthday'),
            (['спасибо', 'thank you', 'thanks', 'благодарю'], 'secret_thanks'),
            (['извини', 'sorry', 'прости', 'простите'], 'secret_sorry'),
            (['добро пожаловать', 'welcome'], 'secret_welcome'),
            (['поздравляю', 'congratulations', 'congrats'], 'secret_congrats'),
            (['пока', 'goodbye', 'bye', 'до свидания'], 'secret_bye'),
        ]
        
        for phrases, ach_id in phrase_achievements:
            if any(p in text_lower for p in phrases):
                self._try_unlock(ach_id)
        
        clean_text = re.sub(r'[^a-zA-Zа-яА-ЯёЁ]', '', text_lower)
        if len(clean_text) >= 5 and clean_text == clean_text[::-1]:
            self._try_unlock('secret_palindrome')
    def _count_emojis(self, text: str) -> int:
        clean_text = text.replace('\ufe0f', '').replace('\ufe0e', '')
        emoji_pattern = re.compile(
            "[\U0001F600-\U0001F64F\U0001F300-\U0001F5FF\U0001F680-\U0001F6FF"
            "\U0001F1E0-\U0001F1FF\U00002702-\U000027B0\U000024C2-\U0001F251"
            "\U0001F900-\U0001F9FF\U0001FA00-\U0001FA6F\U0001FA70-\U0001FAFF"
            "\U00002600-\U000026FF\U00002700-\U000027BF]", flags=re.UNICODE
        )
        return len(emoji_pattern.findall(clean_text))

    def _is_emoji_only(self, text: str) -> bool:
        clean_text = text.replace('\ufe0f', '').replace('\ufe0e', '')
        emoji_pattern = re.compile(
            "[\U0001F600-\U0001F64F\U0001F300-\U0001F5FF\U0001F680-\U0001F6FF"
            "\U0001F1E0-\U0001F1FF\U00002702-\U000027B0\U000024C2-\U0001F251"
            "\U0001F900-\U0001F9FF\U0001FA00-\U0001FA6F\U0001FA70-\U0001FAFF"
            "\U00002600-\U000026FF\U00002700-\U000027BF]+", flags=re.UNICODE
        )
        cleaned = emoji_pattern.sub('', clean_text)
        return len(cleaned.strip()) == 0 and len(text) > 0

    def _count_scripts(self, text: str) -> int:
        count = 0
        if re.search(r'[a-zA-Z]', text):
            count += 1
        if re.search(r'[а-яА-ЯёЁ]', text):
            count += 1
        if re.search(r'[\u4e00-\u9fff\u3040-\u309f\u30a0-\u30ff]', text):
            count += 1
        if re.search(r'[\u0600-\u06FF]', text):
            count += 1
        if re.search(r'[\u0590-\u05FF]', text):
            count += 1
        if re.search(r'[\uAC00-\uD7AF]', text):
            count += 1
        return count

    def _get_cache_path(self) -> str:
        if self._user_id:
            return os.path.join(self._cache_dir, f"achievements_cache_{self._user_id}.json")
        return os.path.join(self._cache_dir, Config.LOCAL_CACHE_FILE)

    def _get_streaks_cache_path(self) -> str:
        if self._user_id:
            return os.path.join(self._cache_dir, f"streaks_v4_{self._user_id}.json")
        return os.path.join(self._cache_dir, Config.STREAKS_CACHE_FILE)

    def _get_token_cache_path(self) -> str:
        if self._user_id:
            return os.path.join(self._cache_dir, f"auth_token_{self._user_id}.json")
        return os.path.join(self._cache_dir, "auth_token.json")

    def _migrate_old_cache(self):
        if not self._user_id:
            return
        
        old_files = [
            (Config.LOCAL_CACHE_FILE, f"achievements_cache_{self._user_id}.json"),
            (Config.STREAKS_CACHE_FILE, f"streaks_v4_{self._user_id}.json"),
            ("auth_token.json", f"auth_token_{self._user_id}.json"),
        ]
        
        for old_name, new_name in old_files:
            old_path = os.path.join(self._cache_dir, old_name)
            new_path = os.path.join(self._cache_dir, new_name)
            
            if os.path.exists(new_path):
                continue
            
            if os.path.exists(old_path):
                try:
                    content = read_file(old_path)
                    if content:
                        write_file(new_path, content)
                except:
                    pass

    def _load_local_cache(self):
        try:
            content = read_file(self._get_cache_path())
            if content:
                data = json.loads(content)
                self._stats = UserStats.from_dict(data.get('stats', {}))
                self._unlocked = set(data.get('unlocked', []))
                self._last_sync = data.get('last_sync', 0)
        except:
            pass

    def _get_current_user_id(self) -> Optional[int]:
        try:
            user_config = get_user_config()
            if user_config and user_config.getCurrentUser():
                return user_config.getCurrentUser().id
        except:
            pass
        return None

    def _check_account_switch(self):
        current_user_id = self._get_current_user_id()
        
        if current_user_id is None or current_user_id == self._user_id:
            return
        
        if self._user_id:
            self._save_local_cache()
            self._save_streaks_cache()
        
        self._user_id = current_user_id
        self._stats = UserStats()
        self._unlocked = set()
        self._fire_streaks = {}
        self._auth_token = None
        self._last_sync = 0
        
        self._load_local_cache()
        self._load_streaks_cache()
        self._load_auth_token()


    def _save_local_cache(self):
        try:
            data = {
                'stats': self._stats.to_dict(),
                'unlocked': list(self._unlocked),
                'last_sync': self._last_sync,
                'user_id': self._user_id
            }
            write_file(self._get_cache_path(), json.dumps(data, ensure_ascii=False))
        except:
            pass

    def _load_streaks_cache(self):
        try:
            content = read_file(self._get_streaks_cache_path())
            if content:
                data = json.loads(content)
                self._fire_streaks = {}
                for pid_str, sdata in data.get('streaks', {}).items():
                    self._fire_streaks[int(pid_str)] = FireStreak.from_dict(sdata)
        except:
            pass

    def _save_streaks_cache(self):
        try:
            data = {
                'user_id': self._user_id,
                'streaks': {str(pid): s.to_dict() for pid, s in self._fire_streaks.items()},
            }
            write_file(self._get_streaks_cache_path(), json.dumps(data, ensure_ascii=False))
            
            self._save_active_streaks_shared()
        except:
            pass

    def _save_active_streaks_shared(self):
        try:
            shared_dir = os.path.join(get_cache_dir(), "ettacent_shared")
            ensure_dir_exists(shared_dir)
            shared_path = os.path.join(shared_dir, "active_streaks.json")
            
            active = {}
            for pid, streak in self._fire_streaks.items():
                if streak.is_active or streak.can_restore:
                    active[str(pid)] = {
                        'is_active': streak.is_active,
                        'can_restore': streak.can_restore,
                        'streak_days': streak.streak_days
                    }
            
            data = {
                'user_id': self._user_id,
                'active_streaks': active,
                'updated_at': time.time()
            }
            
            temp_path = shared_path + '.tmp'
            with open(temp_path, 'w', encoding='utf-8') as f:
                json.dump(data, f, ensure_ascii=False)
            os.replace(temp_path, shared_path)
        except:
            pass

    def _load_auth_token(self):
        try:
            content = read_file(self._get_token_cache_path())
            if content:
                data = json.loads(content)
                if data.get('user_id') == self._user_id:
                    self._auth_token = data.get('token')
        except:
            pass

    def _save_auth_token(self):
        try:
            data = {
                'user_id': self._user_id,
                'token': self._auth_token
            }
            write_file(self._get_token_cache_path(), json.dumps(data))
        except:
            pass

    def _register_and_get_token(self) -> bool:
        if not self._user_id:
            return False
        
        try:
            response = requests.post(
                f"{Config.API_URL}/auth/register",
                params={"user_id": self._user_id},
                timeout=Config.REQUEST_TIMEOUT
            )
            
            if response.status_code == 200:
                data = response.json()
                self._auth_token = data.get('token')
                if self._auth_token:
                    self._save_auth_token()
                    return True
        except:
            pass
        
        return False

    def _ensure_auth_and_sync(self):
        if not self._auth_token:
            if not self._register_and_get_token():
                return
        
        try:
            self._sync_streaks_to_server()
            time.sleep(0.2)
            self._sync_streaks_from_server()
            self._save_streaks_cache()
        except:
            pass
        
        if self.get_setting("auto_sync", True):
            try:
                self._sync_to_server()
                time.sleep(0.2)
                self._sync_from_server()
                self._last_sync = time.time()
                self._save_local_cache()
            except:
                pass

    def _get_auth_headers(self) -> dict:
        return {"X-Auth-Token": self._auth_token or ""}

    def _get_timestamp(self) -> int:
        return int(time.time())

    def _full_sync(self):
        if not self._auth_token:
            if not self._register_and_get_token():
                return
        
        try:
            self._sync_to_server()
            time.sleep(0.2)
            self._sync_from_server()
            self._last_sync = time.time()
            self._save_local_cache()
            
            time.sleep(0.2)
            self._sync_streaks_to_server()
            time.sleep(0.2)
            self._sync_streaks_from_server()
            self._save_streaks_cache()
        except:
            pass

    def _sync_from_server(self):
        if not self._user_id or not self._auth_token:
            return
        try:
            response = requests.get(
                f"{Config.API_URL}/user/{self._user_id}",
                headers=self._get_auth_headers(),
                timeout=Config.REQUEST_TIMEOUT
            )
            
            if response.status_code == 401:
                if self._register_and_get_token():
                    response = requests.get(
                        f"{Config.API_URL}/user/{self._user_id}",
                        headers=self._get_auth_headers(),
                        timeout=Config.REQUEST_TIMEOUT
                    )
                else:
                    return
            
            if response.status_code == 200:
                data = response.json()
                if data.get('success'):
                    server_stats = data.get('stats', {})
                    server_unlocked = set(data.get('unlocked', []))
                    if server_stats:
                        self._merge_stats(server_stats)
                    self._unlocked = self._unlocked.union(server_unlocked)
                    self._save_local_cache()
        except:
            pass

    def _sync_to_server(self):
        if not self._user_id or not self._auth_token:
            return
        try:
            payload = {
                'user_id': self._user_id,
                'stats': self._stats.to_dict(),
                'unlocked': list(self._unlocked),
                'timestamp': self._get_timestamp()
            }
            response = requests.post(
                f"{Config.API_URL}/sync",
                json=payload,
                headers=self._get_auth_headers(),
                timeout=Config.REQUEST_TIMEOUT
            )
            
            if response.status_code == 401:
                if self._register_and_get_token():
                    payload['timestamp'] = self._get_timestamp()
                    requests.post(
                        f"{Config.API_URL}/sync",
                        json=payload,
                        headers=self._get_auth_headers(),
                        timeout=Config.REQUEST_TIMEOUT
                    )
        except:
            pass

    def _sync_streaks_to_server(self):
        if not self._user_id or not self._auth_token:
            return
        try:
            streaks_data = {}
            for pid, streak in self._fire_streaks.items():
                streaks_data[str(pid)] = {
                    'partner_id': streak.partner_id,
                    'partner_name': streak.partner_name,
                    'is_active': streak.is_active,
                    'is_pending': streak.is_pending,
                    'streak_days': streak.streak_days,
                    'started_at': streak.started_at,
                    'last_interaction': streak.last_interaction,
                    'my_messages': streak.my_message_dates[-30:],
                    'my_message_dates': streak.my_message_dates[-30:],
                    'partner_message_dates': streak.partner_message_dates[-30:],
                    'last_my_date': streak.last_my_date,
                    'last_partner_date': streak.last_partner_date,
                    'warned': streak.warned,
                    'can_restore': streak.can_restore,
                    'expired_at': streak.expired_at,
                    'restore_count': streak.restore_count,
                    'last_restore_month': streak.last_restore_month,
                }
            
            payload = {
                'user_id': self._user_id,
                'streaks': streaks_data,
                'timestamp': self._get_timestamp()
            }
            
            response = requests.post(
                f"{Config.API_URL}/streaks/sync",
                json=payload,
                headers=self._get_auth_headers(),
                timeout=Config.REQUEST_TIMEOUT
            )
            
            if response.status_code == 401:
                if self._register_and_get_token():
                    payload['timestamp'] = self._get_timestamp()
                    requests.post(
                        f"{Config.API_URL}/streaks/sync",
                        json=payload,
                        headers=self._get_auth_headers(),
                        timeout=Config.REQUEST_TIMEOUT
                    )
        except:
            pass

    def _sync_streaks_from_server(self):
        if not self._user_id or not self._auth_token:
            return
        try:
            response = requests.get(
                f"{Config.API_URL}/streaks/{self._user_id}",
                headers=self._get_auth_headers(),
                timeout=Config.REQUEST_TIMEOUT
            )
            
            if response.status_code == 401:
                if self._register_and_get_token():
                    response = requests.get(
                        f"{Config.API_URL}/streaks/{self._user_id}",
                        headers=self._get_auth_headers(),
                        timeout=Config.REQUEST_TIMEOUT
                    )
                else:
                    return
            
            if response.status_code == 200:
                data = response.json()
                if data.get('success'):
                    user_streaks = data.get('user_streaks', {})
                    if user_streaks and not self._fire_streaks:
                        for partner_id_str, streak_data in user_streaks.items():
                            partner_id = int(partner_id_str)
                            self._fire_streaks[partner_id] = FireStreak(
                                partner_id=streak_data.get('partner_id', partner_id),
                                partner_name=streak_data.get('partner_name', self._get_user_name(partner_id)),
                                is_active=streak_data.get('is_active', False),
                                is_pending=streak_data.get('is_pending', False),
                                streak_days=streak_data.get('streak_days', 0),
                                started_at=streak_data.get('started_at', ''),
                                last_interaction=streak_data.get('last_interaction', ''),
                                my_message_dates=streak_data.get('my_message_dates', []),
                                partner_message_dates=streak_data.get('partner_message_dates', []),
                                last_my_date=streak_data.get('last_my_date', ''),
                                last_partner_date=streak_data.get('last_partner_date', ''),
                                warned=streak_data.get('warned', False),
                                can_restore=streak_data.get('can_restore', False),
                                expired_at=streak_data.get('expired_at', ''),
                                restore_count=streak_data.get('restore_count', 0),
                                last_restore_month=streak_data.get('last_restore_month', ''),
                            )
                    
                    partner_messages = data.get('partner_messages', {})
                    for partner_id_str, messages in partner_messages.items():
                        partner_id = int(partner_id_str)
                        
                        if partner_id not in self._fire_streaks:
                            self._fire_streaks[partner_id] = FireStreak(
                                partner_id=partner_id,
                                partner_name=self._get_user_name(partner_id),
                            )
                        
                        streak = self._fire_streaks[partner_id]
                        was_active = streak.is_active
                        old_dates = set(streak.partner_message_dates)
                        
                        for msg_date in messages:
                            if msg_date not in streak.partner_message_dates:
                                streak.partner_message_dates.append(msg_date)
                        
                        streak.partner_message_dates = sorted(set(streak.partner_message_dates))[-30:]
                        
                        new_dates = set(streak.partner_message_dates)
                        if new_dates != old_dates:
                            streak.last_interaction = datetime.now().isoformat()
                            if streak.partner_message_dates:
                                streak.last_partner_date = streak.partner_message_dates[-1]
                            
                            self._check_streak_activation(streak)
                            
                            if streak.is_active and not was_active:
                                self._queue_notification("streak_started", streak.partner_name)
                    
                    self._save_streaks_cache()
        except:
            pass

    def _merge_stats(self, server_stats: dict):
        fields = [
            'messages_sent', 'photos_sent', 'videos_sent', 'voice_sent',
            'stickers_sent', 'gifs_sent', 'files_sent', 'audios_sent',
            'video_notes_sent', 'edits_made', 'replies_made', 'forwards_made',
            'reactions_made', 'unique_chats', 'private_chats_count',
            'group_chats_count', 'channel_chats_count',
            'bot_chats_count', 'streak_restored_count',
        ]
        for field in fields:
            current = getattr(self._stats, field, 0)
            server = server_stats.get(field, 0)
            setattr(self._stats, field, max(current, server))
        
        self._stats.days_active.update(server_stats.get('days_active', []))
        self._stats.known_chat_ids.update(set(server_stats.get('known_chat_ids', [])))

    def _manual_sync(self):
        def sync():
            self._full_sync()
            run_on_ui_thread(lambda: BulletinHelper.show_success(Strings.get('synced')))
            run_on_ui_thread(lambda: self.set_setting("_r", time.time(), reload_settings=True))
        
        run_on_queue(sync)
        BulletinHelper.show_info(Strings.get('syncing'))

    def _show_main_menu(self):
        fragment = get_last_fragment()
        if not fragment or not fragment.getParentActivity():
            return
        
        activity = fragment.getParentActivity()
        unlocked_count = len(self._unlocked)
        total_count = len(ACHIEVEMENTS)
        progress_percent = int((unlocked_count / total_count) * 100) if total_count > 0 else 0
        
        categories = [
            ('messages', Strings.get('cat_messages')),
            ('media', Strings.get('cat_media')),
            ('social', Strings.get('cat_social')),
            ('time', Strings.get('cat_time')),
            ('streaks', Strings.get('cat_streaks')),
            ('special', Strings.get('cat_special')),
            ('reactions', Strings.get('cat_reactions')),
            ('explorer', Strings.get('cat_explorer')),
            ('collector', Strings.get('cat_collector')),
            ('veteran', Strings.get('cat_veteran')),
            ('secret', Strings.get('cat_secret')),
        ]
        
        items = []
        for cat_key, cat_name in categories:
            cat_achievements = [a for a in ACHIEVEMENTS.values() if a.category.value == cat_key]
            cat_unlocked = sum(1 for a in cat_achievements if a.id in self._unlocked)
            cat_total = len(cat_achievements)
            items.append(f"{cat_name} ({cat_unlocked}/{cat_total})")
        
        def on_select(dialog, which):
            dialog.dismiss()
            cat_key = categories[which][0]
            run_on_ui_thread(lambda: self._show_category_achievements(cat_key))
        
        builder = AlertDialogBuilder(activity)
        builder.set_title(f"🏆 {unlocked_count}/{total_count} ({progress_percent}%)")
        builder.set_items(items, on_select)
        builder.set_negative_button(Strings.get('close'), lambda d, w: d.dismiss())
        builder.show()

    def _show_category_achievements(self, cat_key: str):
        fragment = get_last_fragment()
        if not fragment or not fragment.getParentActivity():
            return
        
        activity = fragment.getParentActivity()
        cat_achievements = [(aid, a) for aid, a in ACHIEVEMENTS.items() if a.category.value == cat_key]
        
        items = []
        achievement_ids = []
        
        for ach_id, ach in cat_achievements:
            is_unlocked = ach_id in self._unlocked
            rarity_emoji = ach.get_rarity_emoji()
            
            if ach.is_secret and not is_unlocked:
                items.append(f"❓ {Strings.get('secret')} {rarity_emoji}")
            else:
                status = "✅" if is_unlocked else "🔒"
                items.append(f"{status} {ach.icon} {ach.get_name()} {rarity_emoji}")
            achievement_ids.append(ach_id)
        
        def on_select(dialog, which):
            dialog.dismiss()
            ach_id = achievement_ids[which]
            run_on_ui_thread(lambda: self._show_achievement_details(ach_id))
        
        cat_names = {
            'messages': Strings.get('cat_messages'), 'media': Strings.get('cat_media'),
            'social': Strings.get('cat_social'), 'time': Strings.get('cat_time'),
            'streaks': Strings.get('cat_streaks'), 'special': Strings.get('cat_special'),
            'secret': Strings.get('cat_secret'), 'reactions': Strings.get('cat_reactions'),
            'explorer': Strings.get('cat_explorer'), 'collector': Strings.get('cat_collector'),
            'veteran': Strings.get('cat_veteran'),
        }
        
        builder = AlertDialogBuilder(activity)
        builder.set_title(cat_names.get(cat_key, cat_key))
        builder.set_items(items, on_select)
        builder.set_negative_button(Strings.get('back'), lambda d, w: (d.dismiss(), run_on_ui_thread(self._show_main_menu)))
        builder.show()

    def _show_achievement_details(self, ach_id: str):
        fragment = get_last_fragment()
        if not fragment or not fragment.getParentActivity():
            return
        
        activity = fragment.getParentActivity()
        ach = ACHIEVEMENTS.get(ach_id)
        if not ach:
            return
        
        is_unlocked = ach_id in self._unlocked
        
        if ach.is_secret and not is_unlocked:
            title = f"❓ {Strings.get('secret')}"
            message = f"🔮 {Strings.get('secret_desc')}\n\n{Strings.get('rarity')}: {RARITY_INFO[Rarity.SECRET]['emoji']} {ach.get_rarity_name()}\n{Strings.get('status')}: {Strings.get('status_locked')}"
        else:
            rarity_info = RARITY_INFO[ach.rarity]
            status = Strings.get('status_unlocked') if is_unlocked else Strings.get('status_locked')
            title = f"{ach.icon} {ach.get_name()}"
            message = f"{Strings.get('how_to_get')}:\n{ach.get_description()}\n\n{Strings.get('rarity')}: {rarity_info['emoji']} {ach.get_rarity_name()}\n{Strings.get('status')}: {status}"
            
            if ach.target > 1:
                current = self._get_progress_for_achievement(ach_id)
                progress_percent = int(min(current / ach.target * 100, 100))
                progress_bar = self._create_progress_bar(progress_percent, 15)
                message += f"\n\n{Strings.get('progress')}: {progress_bar}\n{current:,} / {ach.target:,}"
        
        builder = AlertDialogBuilder(activity)
        builder.set_title(title)
        builder.set_message(message)
        builder.set_negative_button(Strings.get('back'), lambda d, w: (d.dismiss(), run_on_ui_thread(lambda: self._show_category_achievements(ach.category.value))))
        builder.show()

    def _show_streaks_menu(self):
        fragment = get_last_fragment()
        if not fragment or not fragment.getParentActivity():
            return
        
        activity = fragment.getParentActivity()
        
        active_streaks = [(pid, s) for pid, s in self._fire_streaks.items() if s.is_active]
        restorable_streaks = [(pid, s) for pid, s in self._fire_streaks.items() 
                              if not s.is_active and s.can_restore and s.streak_days > 0]
        expired_streaks = [(pid, s) for pid, s in self._fire_streaks.items() 
                           if not s.is_active and not s.can_restore and s.streak_days > 0 and s.expired_at]
        
        total_active = len(active_streaks)
        total_restorable = len(restorable_streaks)
        total_expired = len(expired_streaks)
        
        if total_active == 0 and total_restorable == 0 and total_expired == 0:
            builder = AlertDialogBuilder(activity)
            builder.set_title("🔥 " + Strings.get('header_streaks'))
            builder.set_message(f"{Strings.get('streak_no_active')}\n\n{Strings.get('streak_info')}")
            builder.set_negative_button(Strings.get('close'), lambda d, w: d.dismiss())
            builder.show()
            return
        
        max_streak = max((s.streak_days for _, s in active_streaks), default=0)
        
        categories = []
        if total_active > 0:
            categories.append(('active', f"🔥 Активные ({total_active})", active_streaks))
        if total_restorable > 0:
            categories.append(('restorable', f"💔 Можно восстановить ({total_restorable})", restorable_streaks))
        if total_expired > 0:
            categories.append(('expired', f"⚰️ История ({total_expired})", expired_streaks))
        
        items = [cat[1] for cat in categories]
        
        def on_select(dialog, which):
            dialog.dismiss()
            cat_key, cat_name, streaks_list = categories[which]
            run_on_ui_thread(lambda: self._show_streaks_category(cat_key, cat_name, streaks_list))
        
        title = f"🔥 {total_active} активных"
        if max_streak > 0:
            title += f" | Рекорд: {max_streak} дн."
        
        builder = AlertDialogBuilder(activity)
        builder.set_title(title)
        builder.set_items(items, on_select)
        builder.set_negative_button(Strings.get('close'), lambda d, w: d.dismiss())
        builder.show()

    def _show_streaks_category(self, cat_key: str, cat_name: str, streaks_list: list):
        fragment = get_last_fragment()
        if not fragment or not fragment.getParentActivity():
            return
        
        activity = fragment.getParentActivity()
        
        items = []
        streak_ids = []
        
        if cat_key == 'active':
            sorted_streaks = sorted(streaks_list, key=lambda x: x[1].streak_days, reverse=True)
            for pid, streak in sorted_streaks:
                emoji = self._get_streak_emoji(streak.streak_days)
                warning = " ⚠️" if streak.warned else ""
                days_text = f"{streak.streak_days} дн."
                items.append(f"{emoji} {streak.partner_name} — {days_text}{warning}")
                streak_ids.append(pid)
        
        elif cat_key == 'restorable':
            sorted_streaks = sorted(streaks_list, key=lambda x: x[1].streak_days, reverse=True)
            
            for pid, streak in sorted_streaks:
                days_text = f"было {streak.streak_days} дн."
                expired_date = streak.expired_at if streak.expired_at else "?"
                items.append(f"💔 {streak.partner_name} — {days_text} (истёк {expired_date})")
                streak_ids.append(pid)
            
            if sorted_streaks:
                first_streak = sorted_streaks[0][1]
                restores_left = Config.STREAK_MAX_RESTORES_PER_MONTH - first_streak.restores_used_this_month
                items.append(f"ℹ️ Осталось восстановлений: {restores_left}/{Config.STREAK_MAX_RESTORES_PER_MONTH}")
        
        elif cat_key == 'expired':
            sorted_streaks = sorted(streaks_list, key=lambda x: x[1].expired_at or "", reverse=True)
            for pid, streak in sorted_streaks:
                days_text = f"было {streak.streak_days} дн."
                expired_date = streak.expired_at if streak.expired_at else "?"
                items.append(f"⚰️ {streak.partner_name} — {days_text} (истёк {expired_date})")
                streak_ids.append(pid)
        
        def on_select(dialog, which):
            if cat_key == 'restorable' and which == len(streak_ids):
                return
            dialog.dismiss()
            if which < len(streak_ids):
                pid = streak_ids[which]
                run_on_ui_thread(lambda: self._show_streak_details(pid))
        
        builder = AlertDialogBuilder(activity)
        builder.set_title(cat_name)
        builder.set_items(items, on_select)
        builder.set_negative_button(Strings.get('back'), lambda d, w: (d.dismiss(), run_on_ui_thread(self._show_streaks_menu)))
        builder.show()

    def _get_streak_emoji(self, days: int) -> str:
        if days >= 365:
            return "🌟"
        elif days >= 200:
            return "☀️"
        elif days >= 100:
            return "❤️‍🔥"
        elif days >= 60:
            return "💥"
        elif days >= 30:
            return "💎"
        elif days >= 14:
            return "⭐"
        elif days >= 7:
            return "🔥"
        else:
            return "🔥"

    def _show_streak_details(self, partner_id: int):
        fragment = get_last_fragment()
        if not fragment or not fragment.getParentActivity():
            return
        
        activity = fragment.getParentActivity()
        streak = self._fire_streaks.get(partner_id)
        if not streak:
            return
        
        if streak.is_active:
            emoji = self._get_streak_emoji(streak.streak_days)
            title = f"{emoji} {streak.partner_name}"
            
            status_text = "✅ Активен"
            if streak.warned:
                status_text = "⚠️ Напишите сегодня!"
            
            today = datetime.now().strftime("%Y-%m-%d")
            my_today = "✅" if today in streak.my_message_dates else "❌"
            partner_today = "✅" if today in streak.partner_message_dates else "❌"
            
            message = (
                f"📅 Дней подряд: {streak.streak_days}\n"
                f"📊 Статус: {status_text}\n"
                f"🗓️ Начало: {streak.started_at}\n\n"
                f"📨 Сегодня:\n"
                f"  • Вы написали: {my_today}\n"
                f"  • Партнёр написал: {partner_today}\n\n"
                f"📈 Всего дней:\n"
                f"  • Ваших: {len(streak.my_message_dates)}\n"
                f"  • Партнёра: {len(streak.partner_message_dates)}"
            )
            
            builder = AlertDialogBuilder(activity)
            builder.set_title(title)
            builder.set_message(message)
            builder.set_negative_button(Strings.get('back'), lambda d, w: (d.dismiss(), run_on_ui_thread(self._show_streaks_menu)))
            builder.show()
        
        elif streak.can_restore:
            title = f"💔 {streak.partner_name}"
            restores_left = Config.STREAK_MAX_RESTORES_PER_MONTH - streak.restores_used_this_month
            
            message = (
                f"📅 Было дней: {streak.streak_days}\n"
                f"🗓️ Истёк: {streak.expired_at}\n\n"
                f"🔄 Восстановлений осталось: {restores_left}/{Config.STREAK_MAX_RESTORES_PER_MONTH}\n\n"
                f"❓ Восстановить огонёк?\n"
                f"После восстановления нужно написать друг другу в течение 24 часов."
            )
            
            def on_restore(d, w):
                d.dismiss()
                if streak.use_restore():
                    streak.is_active = True
                    streak.is_pending = False
                    streak.can_restore = False
                    streak.expired_at = ""
                    streak.warned = False
                    self._stats.streak_restored_count += 1
                    self._try_unlock('streak_saved')
                    self._save_streaks_cache()
                    self._queue_notification("streak_restored", streak.partner_name)
                    run_on_ui_thread(self._show_streaks_menu)
                else:
                    BulletinHelper.show_error("❌ Лимит восстановлений исчерпан")
            
            builder = AlertDialogBuilder(activity)
            builder.set_title(title)
            builder.set_message(message)
            builder.set_positive_button("🔥 Восстановить", on_restore)
            builder.set_negative_button(Strings.get('back'), lambda d, w: (d.dismiss(), run_on_ui_thread(self._show_streaks_menu)))
            builder.show()
        
        else:
            title = f"⚰️ {streak.partner_name}"
            
            message = (
                f"📅 Было дней: {streak.streak_days}\n"
                f"🗓️ Истёк: {streak.expired_at}\n\n"
                f"❌ Восстановление недоступно\n\n"
                f"💡 Огонёк можно восстановить только в течение 7 дней после истечения "
                f"и если он был минимум 7 дней."
            )
            
            def on_delete(d, w):
                d.dismiss()
                if partner_id in self._fire_streaks:
                    del self._fire_streaks[partner_id]
                    self._save_streaks_cache()
                    BulletinHelper.show_success("🗑️ Удалено из истории")
                    run_on_ui_thread(self._show_streaks_menu)
            
            builder = AlertDialogBuilder(activity)
            builder.set_title(title)
            builder.set_message(message)
            builder.set_positive_button("🗑️ Удалить", on_delete)
            builder.set_negative_button(Strings.get('back'), lambda d, w: (d.dismiss(), run_on_ui_thread(self._show_streaks_menu)))
            builder.show()

    def _get_progress_for_achievement(self, ach_id: str) -> int:
        stats = self._stats
        max_fire_streak = max((s.streak_days for s in self._fire_streaks.values() if s.is_active), default=0)
        active_streaks_count = sum(1 for s in self._fire_streaks.values() if s.is_active)
        
        progress_map = {
            'getting_started': stats.messages_sent, 'warming_up': stats.messages_sent,
            'talkative': stats.messages_sent, 'chatterbox': stats.messages_sent,
            'messenger': stats.messages_sent, 'communicator': stats.messages_sent,
            'orator': stats.messages_sent, 'word_master': stats.messages_sent,
            'legend': stats.messages_sent, 'immortal': stats.messages_sent,
            'god_of_words': stats.messages_sent,
            'perfectionist': stats.edits_made, 'never_satisfied': stats.edits_made,
            'obsessive_editor': stats.edits_made,
            'conversationalist': stats.replies_made, 'discussion_lover': stats.replies_made,
            'debate_master': stats.replies_made,
            'news_spreader': stats.forwards_made, 'viral_agent': stats.forwards_made,
            'information_broker': stats.forwards_made,
            'amateur_photographer': stats.photos_sent, 'photographer': stats.photos_sent,
            'pro_photographer': stats.photos_sent, 'paparazzi': stats.photos_sent,
            'photo_legend': stats.photos_sent,
            'video_amateur': stats.videos_sent, 'videographer': stats.videos_sent,
            'director': stats.videos_sent, 'hollywood': stats.videos_sent,
            'voice_user': stats.voice_sent, 'podcaster': stats.voice_sent,
            'radio_host': stats.voice_sent, 'voice_legend': stats.voice_sent,
            'sticker_fan': stats.stickers_sent, 'sticker_lover': stats.stickers_sent,
            'sticker_addict': stats.stickers_sent, 'sticker_maniac': stats.stickers_sent,
            'sticker_god': stats.stickers_sent,
            'gif_user': stats.gifs_sent, 'animator': stats.gifs_sent,
            'gif_master': stats.gifs_sent, 'gif_lord': stats.gifs_sent,
            'file_sharer': stats.files_sent, 'archivist': stats.files_sent,
            'data_hoarder': stats.files_sent, 'cloud_storage': stats.files_sent,
            'music_lover': stats.audios_sent, 'dj': stats.audios_sent,
            'music_producer': stats.audios_sent,
            'circle_fan': stats.video_notes_sent, 'circle_master': stats.video_notes_sent,
            'circle_legend': stats.video_notes_sent,
            'social_starter': stats.unique_chats, 'social_10': stats.unique_chats,
            'social_25': stats.unique_chats, 'social_50': stats.unique_chats,
            'social_100': stats.unique_chats, 'social_250': stats.unique_chats,
            'social_500': stats.unique_chats,
            'reactor': stats.reactions_made, 'reaction_fan': stats.reactions_made,
            'reaction_lover': stats.reactions_made, 'reaction_master': stats.reactions_made,
            'day_1': len(stats.days_active), 'week_1': len(stats.days_active),
            'month_1': len(stats.days_active), 'quarter': len(stats.days_active),
            'half_year': len(stats.days_active), 'year_1': len(stats.days_active),
            'fire_streak_7': max_fire_streak, 'fire_streak_14': max_fire_streak,
            'fire_streak_30': max_fire_streak, 'fire_streak_60': max_fire_streak,
            'fire_streak_100': max_fire_streak, 'fire_streak_200': max_fire_streak,
            'fire_streak_365': max_fire_streak,
            'multi_streaks_3': active_streaks_count, 'multi_streaks_5': active_streaks_count,
            'multi_streaks_10': active_streaks_count,
        }
        return progress_map.get(ach_id, 0)

    def _confirm_reset(self):
        fragment = get_last_fragment()
        if not fragment or not fragment.getParentActivity():
            return
        
        activity = fragment.getParentActivity()
        
        def on_confirm(dialog, which):
            dialog.dismiss()
            self._reset_progress()
        
        builder = AlertDialogBuilder(activity)
        builder.set_title("⚠️ " + Strings.get('reset_progress'))
        builder.set_message(Strings.get('reset_confirm'))
        builder.set_positive_button(Strings.get('yes'), on_confirm)
        builder.set_negative_button(Strings.get('no'), lambda d, w: d.dismiss())
        builder.make_button_red(AlertDialogBuilder.BUTTON_POSITIVE)
        builder.show()

    def _reset_progress(self):
        self._stats = UserStats()
        self._unlocked = set()
        
        with self._notification_lock:
            self._pending_notifications = []
            self._is_processing_notifications = False
        
        self._save_local_cache()
        
        if self._user_id and self._auth_token:
            run_on_queue(self._delete_server_data)
        
        self.set_setting("_refresh_trigger", time.time(), reload_settings=True)
        BulletinHelper.show_success(Strings.get('reset_done'))

    def _delete_server_data(self):
        if not self._user_id or not self._auth_token:
            return
        try:
            requests.delete(
                f"{Config.API_URL}/user/{self._user_id}",
                headers=self._get_auth_headers(),
                timeout=Config.REQUEST_TIMEOUT
            )
        except:
            pass


__plugin__ = AchievementsPlugin