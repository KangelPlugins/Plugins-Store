try:
    MAIN_TABS_LAYOUT_CLS = Class.forName("org.telegram.ui.MainTabsLayout")
    MAIN_TABS_ACTIVITY_CLS = Class.forName("org.telegram.ui.MainTabsActivity")
    DIALOGS_ACTIVITY_CLS = Class.forName("org.telegram.ui.DialogsActivity")
    LAUNCH_ACTIVITY_CLS = Class.forName("org.telegram.ui.LaunchActivity")
    LOGIN_ACTIVITY_CLS = Class.forName("org.telegram.ui.LoginActivity")
    FILTER_TABS_VIEW_CLS = Class.forName("org.telegram.ui.Components.FilterTabsView")
    CONTEXT_CLS = Class.forName("android.content.Context")
    VIEW_CLS = Class.forName("android.view.View")
    VIEWGROUP_CLS = Class.forName("android.view.ViewGroup")
    ACTION_BAR_CLS = Class.forName("org.telegram.ui.ActionBar.ActionBar")
    ITEM_OPTIONS_CLS = Class.forName("org.telegram.ui.Components.ItemOptions")
    PLUGINS_CONTROLLER_CLS = Class.forName("com.exteragram.messenger.plugins.PluginsController")
    PLUGINS_ACTIVITY_CLS = Class.forName("com.exteragram.messenger.plugins.ui.PluginsActivity")
    
    try:
        DRAWER_LAYOUT_CONTAINER_CLS = Class.forName("org.telegram.ui.ActionBar.DrawerLayoutContainer")
    except:
        DRAWER_LAYOUT_CONTAINER_CLS = None

except Exception as e:
    log(f"Class Error: {e}")


