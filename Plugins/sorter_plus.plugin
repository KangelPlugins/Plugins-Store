class PluginsFoldersPlus(BasePlugin):
    def __init__(self):
        super().__init__()
        self._hooks = []
        self._folders = []
        self._selected_folder_id = "all"
        self._sort_mode = "default"
        self._stored_context = None
        self._stored_activity = None
        self._pills_container = None
        self._pills_layout = None
        self._pills_scroll = None
        self._sort_plate = None
        self._pill_meta = []
        self._folder_counter = 0
        self._self_avatar_bitmap = None
        self._pending_self_install_until = 0.0
        self._modern_spacing_fix_target = None

    def _dbg(self, text):
        return

    def on_plugin_load(self):
        self._load_state()
        self._install_hooks()

    def on_plugin_unload(self):
        for hook in list(self._hooks):
            try:
                self.unhook_method(hook)
            except Exception:
                pass
        self._hooks = []
        self._pills_container = None
        self._pills_layout = None
        self._pills_scroll = None
        self._sort_plate = None
        self._pill_meta = []
        self._self_avatar_bitmap = None
        self._pending_self_install_until = 0.0
        self._modern_spacing_fix_target = None

    def _reset_all(self):
        self._folders = []
        self._selected_folder_id = "all"
        self._sort_mode = "default"
        self._save_state()
        self._rebuild_pills()
        self._refresh_plugins_list()
        run_on_ui_thread(lambda: BulletinHelper.show_success("Сброшено"))

    def _install_hooks(self):
        try:
            PluginsActivity = find_class("com.exteragram.messenger.plugins.ui.PluginsActivity")
            if not PluginsActivity:
                self._dbg("PluginsActivity not found")
                return

            ContextClass = find_class("android.content.Context")
            ArrayListClass = find_class("java.util.ArrayList")
            UniversalAdapterClass = find_class("org.telegram.ui.Components.UniversalAdapter")
            if not (ContextClass and ArrayListClass and UniversalAdapterClass):
                self._dbg("Failed to resolve hook parameter classes")
                return

            create_view = PluginsActivity.getClass().getDeclaredMethod("createView", ContextClass)
            create_view.setAccessible(True)
            fill_items = PluginsActivity.getClass().getDeclaredMethod(
                "fillItems", ArrayListClass, UniversalAdapterClass
            )
            fill_items.setAccessible(True)

            self._hooks.append(self.hook_method(create_view, self._CreateViewHook(self)))
            self._hooks.append(self.hook_method(fill_items, self._FillItemsHook(self)))
            self._install_plugin_cell_hook()
            self._dbg("Hooks installed")
        except Exception as e:
            self._dbg(f"Hook install error: {e}")

    def _install_plugin_cell_hook(self):
        try:
            PluginCell = find_class("com.exteragram.messenger.plugins.ui.components.PluginCell")
            if not PluginCell:
                self._dbg("PluginCell class not found")
                return
            target = None
            methods = PluginCell.getClass().getDeclaredMethods()
            for method in methods:
                if method.getName() != "set":
                    continue
                params = method.getParameterTypes()
                if len(params) == 2:
                    target = method
                    break
            if not target:
                self._dbg("PluginCell.set method not found")
                return
            target.setAccessible(True)
            self._hooks.append(self.hook_method(target, self._PluginCellHook(self)))
        except Exception as e:
            self._dbg(f"PluginCell hook error: {e}")

    def _install_extra_plugin_view_hooks(self):
        for class_name in EXTRA_PLUGIN_VIEW_CLASSES:
            try:
                cls = find_class(class_name)
                if not cls:
                    continue
                hooked = 0
                for method in cls.getClass().getDeclaredMethods():
                    method_name = str(method.getName() or "")
                    if method_name not in ("set", "bind", "setData", "update"):
                        continue
                    params = method.getParameterTypes()
                    if not params:
                        continue
                    has_plugin_arg = False
                    for param_type in params:
                        try:
                            if "com.exteragram.messenger.plugins.Plugin" in str(param_type.getName() or ""):
                                has_plugin_arg = True
                                break
                        except Exception:
                            pass
                    if not has_plugin_arg:
                        continue
                    method.setAccessible(True)
                    self._hooks.append(self.hook_method(method, self._GenericPluginViewHook(self)))
                    hooked += 1
                if hooked:
                    self._dbg(f"{class_name}: hooked {hooked} methods")
            except Exception as e:
                self._dbg(f"extra hook error {class_name}: {e}")

    def _install_install_surface_hooks(self):
        for class_name in INSTALL_SURFACE_CLASSES:
            try:
                cls = jclass(class_name)
            except Exception:
                cls = None
            if cls is None:
                continue

            try:
                hooked = 0
                constructors = cls.getDeclaredConstructors()
                for ctor in constructors:
                    params = ctor.getParameterTypes()
                    if len(params) < 2:
                        continue
                    has_install_params = False
                    for p in params:
                        try:
                            if "PluginInstallParams" in str(p.getName() or ""):
                                has_install_params = True
                                break
                        except Exception:
                            pass
                    if not has_install_params:
                        continue
                    ctor.setAccessible(True)
                    self._hooks.append(self.hook_method(ctor, self._InstallSurfaceHook(self)))
                    hooked += 1
                if hooked:
                    self._dbg(f"{class_name}: hooked {hooked} constructors")
            except Exception as e:
                self._dbg(f"install surface hook error {class_name}: {e}")

    def _install_install_context_hooks(self):
        try:
            AndroidUtils = find_class("org.telegram.messenger.AndroidUtilities")
            if AndroidUtils:
                JavaFile = find_class("java.io.File")
                methods = AndroidUtils.getClass().getDeclaredMethods()
                for method in methods:
                    if method.getName() != "openForView":
                        continue
                    params = method.getParameterTypes()
                    if not params:
                        continue
                    try:
                        if JavaFile is not None and str(params[0].getName() or "") != str(JavaFile.getName() or ""):
                            continue
                    except Exception:
                        pass
                    method.setAccessible(True)
                    self._hooks.append(self.hook_method(method, self._OpenForViewHook(self)))
        except Exception as e:
            self._dbg(f"openForView hook error: {e}")

        try:
            Engine = find_class("com.exteragram.messenger.plugins.PythonPluginsEngine")
            if Engine:
                methods = Engine.getClass().getDeclaredMethods()
                for method in methods:
                    method_name = str(method.getName() or "")
                    if method_name not in ("validatePluginFromFile", "loadPluginFromFile"):
                        continue
                    params = method.getParameterTypes()
                    if not params:
                        continue
                    first_param_name = ""
                    try:
                        first_param_name = str(params[0].getName() or "")
                    except Exception:
                        first_param_name = ""
                    if first_param_name != "java.lang.String":
                        continue
                    method.setAccessible(True)
                    self._hooks.append(self.hook_method(method, self._EnginePathHook(self)))
        except Exception as e:
            self._dbg(f"engine path hook error: {e}")

    def _install_success_bulletin_hook(self):
        try:
            Sheet = None
            try:
                Sheet = jclass("com.exteragram.messenger.plugins.ui.components.InstallPluginBottomSheet")
            except Exception:
                Sheet = None
            if not Sheet:
                return
            hooked = 0
            for method in Sheet.getClass().getDeclaredMethods():
                if method.getName() != "showSuccessBulletin":
                    continue
                params = method.getParameterTypes()
                if len(params) != 3:
                    continue
                try:
                    p0 = str(params[0].getName() or "")
                    p1 = str(params[1].getName() or "")
                    p2 = str(params[2].getName() or "")
                except Exception:
                    continue
                if "org.telegram.ui.ActionBar.BaseFragment" not in p0:
                    continue
                if "com.exteragram.messenger.plugins.Plugin" not in p1:
                    continue
                if p2 != "boolean":
                    continue
                method.setAccessible(True)
                self._hooks.append(self.hook_method(method, self._InstallSuccessBulletinHook(self)))
                hooked += 1
            if hooked:
                self._dbg(f"Install success bulletin hook: {hooked}")
        except Exception as e:
            self._dbg(f"success bulletin hook error: {e}")

    class _CreateViewHook(MethodHook):
        def __init__(self, plugin):
            self.plugin = plugin

        def after_hooked_method(self, param):
            try:
                self.plugin._stored_activity = param.thisObject
                self.plugin._stored_context = param.args[0]
                self.plugin._ensure_pills_container()
                self.plugin._rebuild_pills()
                self.plugin._refresh_plugins_list()
            except Exception as e:
                self.plugin._dbg(f"createView hook error: {e}")

    class _FillItemsHook(MethodHook):
        def __init__(self, plugin):
            self.plugin = plugin

        def after_hooked_method(self, param):
            try:
                items = param.args[0]
                self.plugin._process_fill_items(items)
            except Exception as e:
                self.plugin._dbg(f"fillItems hook error: {e}")

    class _PluginCellHook(MethodHook):
        def __init__(self, plugin):
            self.plugin = plugin

        def after_hooked_method(self, param):
            try:
                try:
                    plugin_obj = param.args[0]
                except Exception:
                    plugin_obj = None
                plugin_id = self.plugin._plugin_id(plugin_obj)
                if not plugin_id:
                    return
                mtime = self.plugin._plugin_mtime(plugin_id)
                if not mtime:
                    return
                stamp = time.strftime("%d.%m.%Y %H:%M", time.localtime(int(mtime) / 1000.0))
                subtitle = get_private_field(param.thisObject, "subtitleView")
                if subtitle is None:
                    return
                subtitle_text = ""
                try:
                    subtitle_text = str(subtitle.getText() or "")
                except Exception:
                    subtitle_text = ""
                clean_subtitle = re.sub(
                    r"\s*•\s*обновл[её]н\s+\d{2}\.\d{2}\.\d{4}\s+\d{2}:\d{2}\s*$",
                    "",
                    subtitle_text or "",
                    flags=re.IGNORECASE,
                ).strip()
                subtitle.setText(clean_subtitle)

                desc_view = get_private_field(param.thisObject, "descriptionView")
                if desc_view is None:
                    return
                desc_text = ""
                try:
                    desc_text = str(desc_view.getText() or "")
                except Exception:
                    desc_text = ""
                clean_desc = re.sub(
                    r"^обновл[её]н\s+\d{2}\.\d{2}\.\d{4}\s+\d{2}:\d{2}\s*\n?",
                    "",
                    desc_text or "",
                    flags=re.IGNORECASE,
                ).strip()
                update_line = f"обновлён {stamp}"
                final_desc = f"{update_line}\n\n{clean_desc}" if clean_desc else update_line
                desc_view.setVisibility(View.VISIBLE)
                try:
                    sb = SpannableStringBuilder(final_desc)
                    gray_key = getattr(Theme, "key_windowBackgroundWhiteGrayText2", None)
                    if gray_key is None:
                        gray_key = getattr(
                            Theme,
                            "key_windowBackgroundWhiteGrayText",
                            Theme.key_windowBackgroundWhiteBlackText,
                        )
                    gray_color = Theme.getColor(gray_key)
                    sb.setSpan(
                        ForegroundColorSpan(gray_color),
                        0,
                        len(update_line),
                        Spanned.SPAN_EXCLUSIVE_EXCLUSIVE,
                    )
                    desc_view.setText(sb)
                except Exception:
                    desc_view.setText(final_desc)
            except Exception:
                pass

    class _GenericPluginViewHook(MethodHook):
        def __init__(self, plugin):
            self.plugin = plugin

        def after_hooked_method(self, param):
            return

    class _InstallSurfaceHook(MethodHook):
        def __init__(self, plugin):
            self.plugin = plugin

        def after_hooked_method(self, param):
            return

    class _OpenForViewHook(MethodHook):
        def __init__(self, plugin):
            self.plugin = plugin

        def before_hooked_method(self, param):
            return

    class _EnginePathHook(MethodHook):
        def __init__(self, plugin):
            self.plugin = plugin

        def before_hooked_method(self, param):
            return

    class _InstallSuccessBulletinHook(MethodHook):
        def __init__(self, plugin):
            self.plugin = plugin

        def before_hooked_method(self, param):
            return

    def _process_fill_items(self, items):
        self._ensure_pills_container()
        plugin_items = []
        before_plugin_items = []
        after_plugin_items = []
        seen_plugin_item = False
        size = items.size()
        for i in range(size):
            item = items.get(i)
            if self._is_our_custom_item(item):
                continue
            plugin = self._item_plugin(item)
            if plugin is not None:
                seen_plugin_item = True
                plugin_items.append(item)
            else:
                if seen_plugin_item:
                    after_plugin_items.append(item)
                else:
                    before_plugin_items.append(item)

        plugin_items = self._filter_plugin_items(plugin_items)
        plugin_items = self._sort_plugin_items(plugin_items)
        show_empty_state = self._selected_folder_id != "all" and len(plugin_items) == 0

        before_plugin_items = self._trim_trailing_spaces(before_plugin_items)
        after_plugin_items = self._trim_leading_spaces(after_plugin_items)

        items.clear()
        for item in before_plugin_items:
            items.add(item)

        if self._pills_container is not None:
            try:
                pills_item = UItem.asFullyCustom(self._pills_container)
                insert_pos = items.size()
                items.add(insert_pos, pills_item)
            except Exception:
                pass

        if show_empty_state:
            empty_view = self._build_empty_folder_view(self._selected_folder_id)
            if empty_view is not None:
                try:
                    items.add(UItem.asFullyCustom(empty_view))
                except Exception:
                    pass
        else:
            if plugin_items:
                top_gap = self._make_space_item(
                    self._plugins_top_gap_dp() if self._is_modern_spacing_fix_target() else 4
                )
                if top_gap is not None:
                    items.add(top_gap)
            for idx, item in enumerate(plugin_items):
                if idx > 0 and self._is_modern_spacing_fix_target():
                    inter_gap = self._make_space_item(2)
                    if inter_gap is not None:
                        items.add(inter_gap)
                items.add(item)
        for item in after_plugin_items:
            items.add(item)

    def _build_empty_folder_view(self, folder_id):
        folder = self._find_folder(folder_id)
        if folder is None:
            return None
        context = self._stored_context
        if context is None:
            return None

        root = LinearLayout(context)
        root.setOrientation(LinearLayout.VERTICAL)
        empty_height = int(AndroidUtilities.dp(420))
        try:
            display_h = int(getattr(AndroidUtilities.displaySize, "y", 0) or 0)
            if display_h > 0:
                empty_height = max(empty_height, int(display_h * 0.72))
        except Exception:
            pass
        root.setLayoutParams(
            ViewGroup.LayoutParams(
                ViewGroup.LayoutParams.MATCH_PARENT,
                empty_height,
            )
        )
        root.setPadding(
            int(AndroidUtilities.dp(16)),
            int(AndroidUtilities.dp(16)),
            int(AndroidUtilities.dp(16)),
            int(AndroidUtilities.dp(16)),
        )

        top_spacer = View(context)
        root.addView(
            top_spacer,
            LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.MATCH_PARENT,
                0,
                1.0,
            ),
        )

        content = LinearLayout(context)
        content.setOrientation(LinearLayout.VERTICAL)
        content.setGravity(Gravity.CENTER_HORIZONTAL)
        root.addView(
            content,
            LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.MATCH_PARENT,
                LinearLayout.LayoutParams.WRAP_CONTENT,
            ),
        )

        title = TextView(context)
        title.setText("Плагинов пока нету")
        title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
        title.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
        title.setGravity(Gravity.CENTER)
        title.setSingleLine(False)
        content.addView(
            title,
            LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.MATCH_PARENT,
                LinearLayout.LayoutParams.WRAP_CONTENT,
            ),
        )

        add_btn = TextView(context)
        add_btn.setText("Добавить плагины")
        add_btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
        add_btn.setGravity(Gravity.CENTER)
        add_btn.setTextColor(
            Theme.getColor(
                getattr(Theme, "key_actionBarTabActiveText", Theme.key_windowBackgroundWhiteBlackText)
            )
        )
        add_bg = GradientDrawable()
        add_bg.setCornerRadius(float(AndroidUtilities.dp(12)))
        active = Theme.getColor(Theme.key_actionBarTabLine)
        add_bg.setColor(self._with_alpha(active, 0x52))
        add_bg.setStroke(int(AndroidUtilities.dp(1)), self._with_alpha(active, 0xA8))
        add_btn.setBackground(add_bg)
        add_btn.setPadding(
            int(AndroidUtilities.dp(14)),
            int(AndroidUtilities.dp(10)),
            int(AndroidUtilities.dp(14)),
            int(AndroidUtilities.dp(10)),
        )
        add_btn.setOnClickListener(
            OnClickListener(lambda _v: self._open_folder_plugins_editor(folder_id))
        )
        lp = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.WRAP_CONTENT,
            LinearLayout.LayoutParams.WRAP_CONTENT,
        )
        lp.setMargins(0, int(AndroidUtilities.dp(12)), 0, 0)
        lp.gravity = Gravity.CENTER_HORIZONTAL
        content.addView(add_btn, lp)

        bottom_spacer = View(context)
        root.addView(
            bottom_spacer,
            LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.MATCH_PARENT,
                0,
                1.0,
            ),
        )
        return root

    def _is_our_custom_item(self, item):
        for attr in ("customView", "view", "fullyCustomView"):
            try:
                if getattr(item, attr) == self._pills_container:
                    return True
            except Exception:
                pass
        return False

    def _is_space_item(self, item):
        if item is None:
            return False
        try:
            view_type = getattr(item, "viewType", None)
            if view_type is None:
                view_type = self._read_field_hierarchy(item, "viewType")
            if view_type is not None and int(view_type) == 28:
                return True
        except Exception:
            pass
        try:
            int_value = int(getattr(item, "intValue", 0) or 0)
        except Exception:
            int_value = 0
        try:
            transparent = bool(getattr(item, "transparent", False))
        except Exception:
            transparent = False
        try:
            text = str(getattr(item, "text", "") or "")
        except Exception:
            text = ""
        try:
            has_object = getattr(item, "object", None) is not None
        except Exception:
            has_object = False
        return int_value > 0 and transparent and not text and not has_object

    def _trim_trailing_spaces(self, arr):
        out = list(arr or [])
        while out and self._is_space_item(out[-1]):
            out.pop()
        return out

    def _trim_leading_spaces(self, arr):
        out = list(arr or [])
        while out and self._is_space_item(out[0]):
            out.pop(0)
        return out

    def _make_space_item(self, height_dp):
        try:
            h = int(AndroidUtilities.dp(float(height_dp)))
            if h <= 0:
                return None
            item = UItem.asSpace(h)
            try:
                setattr(item, "transparent", True)
            except Exception:
                pass
            return item
        except Exception:
            return None

    def _is_modern_spacing_fix_target(self):
        if self._modern_spacing_fix_target is not None:
            return bool(self._modern_spacing_fix_target)
        try:
            uitem_cls = find_class("org.telegram.ui.Components.UItem")
            if uitem_cls is None:
                self._modern_spacing_fix_target = False
                return False
            for m in uitem_cls.getClass().getDeclaredMethods():
                try:
                    if str(m.getName() or "") != "asSpace":
                        continue
                    if len(m.getParameterTypes()) == 2:
                        self._modern_spacing_fix_target = True
                        return True
                except Exception:
                    continue
            self._modern_spacing_fix_target = False
            return False
        except Exception:
            self._modern_spacing_fix_target = False
            return False

    def _plugins_top_gap_dp(self):
        return 7

    def _is_plugin_like_obj(self, obj):
        try:
            if obj is None:
                return False
            cls_name = ""
            try:
                cls_name = str(obj.getClass().getName() or "")
            except Exception:
                cls_name = ""
            if "com.exteragram.messenger.plugins.Plugin" in cls_name:
                return True
            has_id = False
            has_name = False
            try:
                has_id = bool(str(obj.getId() or ""))
            except Exception:
                has_id = False
            try:
                _ = obj.getName()
                has_name = True
            except Exception:
                has_name = False
            return has_id and has_name
        except Exception:
            return False

    def _item_plugin(self, item):
        if item is None:
            return None
        try:
            plugin = getattr(item, "plugin", None)
        except Exception:
            plugin = None
        if self._is_plugin_like_obj(plugin):
            return plugin
        try:
            obj = getattr(item, "object", None)
        except Exception:
            obj = None
        if self._is_plugin_like_obj(obj):
            return obj
        try:
            plugin = self._read_field_hierarchy(item, "plugin")
        except Exception:
            plugin = None
        if self._is_plugin_like_obj(plugin):
            return plugin
        try:
            obj = self._read_field_hierarchy(item, "object")
        except Exception:
            obj = None
        if self._is_plugin_like_obj(obj):
            return obj
        return None

    def _filter_plugin_items(self, plugin_items):
        if self._selected_folder_id == "all":
            return plugin_items
        folder = self._find_folder(self._selected_folder_id)
        if not folder:
            self._selected_folder_id = "all"
            self._save_state()
            return plugin_items

        included = set(folder.get("plugins", []) or [])
        if not included:
            return []

        filtered = []
        for item in plugin_items:
            pid = self._plugin_id(self._item_plugin(item))
            if pid and pid in included:
                filtered.append(item)
        return filtered

    def _sort_plugin_items(self, plugin_items):
        mode = self._sort_mode
        if mode == "default":
            return plugin_items
        if mode == "name_asc":
            return sorted(plugin_items, key=lambda i: self._plugin_name(self._item_plugin(i)))
        if mode == "name_desc":
            return sorted(
                plugin_items,
                key=lambda i: self._plugin_name(self._item_plugin(i)),
                reverse=True,
            )
        if mode == "enabled_first":
            return sorted(
                plugin_items,
                key=lambda i: (
                    0 if self._plugin_enabled(self._item_plugin(i)) else 1,
                    self._plugin_name(self._item_plugin(i)),
                ),
            )
        if mode == "recent":
            return sorted(
                plugin_items,
                key=lambda i: self._plugin_mtime(self._plugin_id(self._item_plugin(i))),
                reverse=True,
            )
        return plugin_items

    def _plugin_id(self, plugin):
        try:
            return str(plugin.getId())
        except Exception:
            return ""

    def _plugin_name_raw(self, plugin):
        try:
            return str(plugin.getName() or "")
        except Exception:
            return ""

    def _is_self_plugin(self, plugin):
        if plugin is None:
            return False
        pid = self._plugin_id(plugin)
        if pid and pid == __id__:
            return True
        pname = self._plugin_name_raw(plugin).strip().lower()
        if pname and pname == __name__.strip().lower():
            return True
        return False

    def _mark_pending_self_install(self, ttl_seconds=120):
        try:
            ttl = float(ttl_seconds or 0)
        except Exception:
            ttl = 0.0
        ttl = max(10.0, ttl)
        self._pending_self_install_until = max(
            float(self._pending_self_install_until or 0.0),
            time.time() + ttl,
        )

    def _has_pending_self_install(self):
        try:
            return time.time() <= float(self._pending_self_install_until or 0.0)
        except Exception:
            return False

    def _plugin_name(self, plugin):
        try:
            return str(plugin.getName() or "").lower()
        except Exception:
            return ""

    def _plugin_enabled(self, plugin):
        try:
            return bool(plugin.isEnabled())
        except Exception:
            return False

    def _plugin_mtime(self, plugin_id):
        if not plugin_id:
            return 0
        try:
            controller = PluginsController.getInstance()
            plugin_path = controller.getPluginPath(plugin_id)
            if not plugin_path:
                return 0
            from java.io import File

            f = File(plugin_path)
            if not f.exists():
                return 0
            return int(f.lastModified())
        except Exception:
            return 0

    def _get_self_avatar_bitmap(self):
        if self._self_avatar_bitmap is not None:
            return self._self_avatar_bitmap
        if not SELF_AVATAR_B64:
            return None
        try:
            data = AndroidBase64.decode(SELF_AVATAR_B64, AndroidBase64.DEFAULT)
            bitmap = BitmapFactory.decodeByteArray(data, 0, len(data))
            self._self_avatar_bitmap = bitmap
            return bitmap
        except Exception as e:
            self._dbg(f"avatar decode error: {e}")
            return None

    def _extract_plugin_arg(self, args):
        if args is None:
            return None
        for arg in args:
            if arg is None:
                continue
            try:
                pid = str(arg.getId() or "")
                if pid:
                    return arg
            except Exception:
                pass
        return None

    def _extract_install_params_arg(self, args):
        if args is None:
            return None
        for arg in args:
            if arg is None:
                continue
            try:
                class_name = str(arg.getClass().getName() or "")
                if "PluginInstallParams" in class_name:
                    return arg
            except Exception:
                pass
        return None

    def _extract_validation_result_arg(self, args):
        if args is None:
            return None
        for arg in args:
            if arg is None:
                continue
            try:
                class_name = str(arg.getClass().getName() or "")
                if "PluginValidationResult" in class_name:
                    return arg
            except Exception:
                pass
        return None

    def _plugin_from_validation_result(self, validation_result):
        if validation_result is None:
            return None
        try:
            plugin = self._read_field_hierarchy(validation_result, "plugin")
            if plugin is not None:
                return plugin
        except Exception:
            pass
        return None

    def _args_contain_self_plugin_ref(self, args):
        if args is None:
            return False
        for arg in args:
            if arg is None:
                continue
            try:
                text = str(arg).lower()
            except Exception:
                text = ""
            if not text:
                continue
            if __id__ in text or "sorter_plus" in text:
                return True
            if self._is_self_plugin_file(text):
                return True
        return False

    def _read_field_hierarchy(self, obj, field_name):
        if obj is None:
            return None
        cls = obj.getClass()
        while cls is not None:
            try:
                f = cls.getDeclaredField(field_name)
                f.setAccessible(True)
                return f.get(obj)
            except Exception:
                pass
            try:
                cls = cls.getSuperclass()
            except Exception:
                break
        return None

    def _is_self_plugin_file(self, file_path):
        path = str(file_path or "").strip()
        if not path:
            return False
        lower = path.lower()
        if __id__ in lower or "sorter_plus" in lower:
            return True
        try:
            if not os.path.exists(path):
                return False
            with open(path, "rb") as f:
                head = f.read(8192).decode("utf-8", "ignore")
            if re.search(
                r'__id__\s*=\s*["\']%s["\']' % re.escape(__id__),
                head,
                flags=re.IGNORECASE,
            ):
                return True
        except Exception:
            pass
        return False

    def _install_param_file_path(self, install_params):
        if install_params is None:
            return ""
        for field_name in ("filePath", "path", "pluginPath"):
            try:
                value = self._read_field_hierarchy(install_params, field_name)
                if value:
                    return str(value)
            except Exception:
                pass
        return ""

    def _is_self_install_context(self, install_params):
        if install_params is None:
            return False
        file_path = self._install_param_file_path(install_params)
        if self._is_self_plugin_file(file_path):
            return True
        for field_name in ("id", "pluginId", "plugin_id", "name", "pluginName", "title"):
            try:
                value = self._read_field_hierarchy(install_params, field_name)
                text = str(value or "").strip().lower()
                if text and (__id__ in text or "sorter+" in text):
                    return True
            except Exception:
                pass
        return False

    def _collect_image_views(self, root):
        out = []
        if root is None:
            return out
        stack = [root]
        while stack:
            view = stack.pop()
            if view is None:
                continue
            try:
                class_name = str(view.getClass().getName() or "")
            except Exception:
                class_name = ""
            if class_name == "android.widget.ImageView":
                out.append(view)
            try:
                count = int(view.getChildCount())
            except Exception:
                count = 0
            if count > 0:
                for i in range(count):
                    try:
                        stack.append(view.getChildAt(i))
                    except Exception:
                        pass
        return out

    def _collect_backup_image_views(self, root):
        out = []
        if root is None:
            return out
        stack = [root]
        while stack:
            view = stack.pop()
            if view is None:
                continue
            class_name = ""
            try:
                class_name = str(view.getClass().getName() or "")
            except Exception:
                class_name = ""
            if class_name == "org.telegram.ui.Components.BackupImageView":
                out.append(view)
            try:
                count = int(view.getChildCount())
            except Exception:
                count = 0
            if count > 0:
                for i in range(count):
                    try:
                        stack.append(view.getChildAt(i))
                    except Exception:
                        pass
        return out

    def _view_area(self, view):
        if view is None:
            return 0
        try:
            w = int(view.getWidth())
            h = int(view.getHeight())
            if w > 0 and h > 0:
                return w * h
        except Exception:
            pass
        try:
            lp = view.getLayoutParams()
            if lp is not None:
                w = int(getattr(lp, "width", 0) or 0)
                h = int(getattr(lp, "height", 0) or 0)
                if w > 0 and h > 0:
                    return w * h
        except Exception:
            pass
        return 0

    def _view_hierarchy_root(self, obj):
        if obj is None:
            return None
        for field_name in ("container", "customView", "containerView", "contentView", "sheetContainer", "rootView"):
            view = get_private_field(obj, field_name)
            if view is not None:
                return view
            view = self._read_field_hierarchy(obj, field_name)
            if view is not None:
                return view
        return None

    def _apply_avatar_on_install_surface(self, sheet_obj):
        bitmap = self._get_self_avatar_bitmap()
        if bitmap is None or sheet_obj is None:
            return
        root = self._view_hierarchy_root(sheet_obj)
        if root is None:
            return
        backup_views = self._collect_backup_image_views(root)
        min_side = int(AndroidUtilities.dp(28))
        min_area = min_side * min_side
        candidates = [v for v in backup_views if self._view_area(v) >= min_area]
        if not candidates:
            candidates = backup_views
        if not candidates:
            image_views = self._collect_image_views(root)
            candidates = [v for v in image_views if self._view_area(v) >= min_area]
            if not candidates:
                candidates = image_views
        if not candidates:
            return
        target = None
        best_area = -1
        for v in candidates:
            area = self._view_area(v)
            if area > best_area:
                best_area = area
                target = v
        if target is None:
            return
        self._apply_bitmap_to_image_view(target, bitmap)

    def _show_self_install_success_bulletin(self, base_fragment, plugin_obj, is_update):
        bitmap = self._get_self_avatar_bitmap()
        if bitmap is None or base_fragment is None:
            return
        plugin_name = ""
        try:
            plugin_name = str(plugin_obj.getName() or "")
        except Exception:
            plugin_name = __name__
        title = "Плагин обновлён" if is_update else "Плагин установлен"
        text = f"{title}: {plugin_name}"

        def _run():
            try:
                factory = BulletinFactory.of(base_fragment)
                context = None
                try:
                    context = base_fragment.getParentActivity()
                except Exception:
                    context = self._stored_context
                if context is None:
                    return
                drawable = BitmapDrawable(context.getResources(), bitmap)
                factory.createSimpleBulletin(drawable, text).show()
            except Exception as e:
                self._dbg(f"custom success bulletin error: {e}")

        run_on_ui_thread(_run)

    def _plugin_icon_view(self, cell):
        for name in ("imageView", "iconView", "avatarImageView", "pluginImageView"):
            view = get_private_field(cell, name)
            if view is not None:
                return view
        try:
            fields = cell.getClass().getDeclaredFields()
            for field in fields:
                field.setAccessible(True)
                value = field.get(cell)
                if value is None:
                    continue
                class_name = str(value.getClass().getName() or "")
                if class_name == "android.widget.ImageView":
                    return value
        except Exception:
            pass
        try:
            images = self._collect_image_views(cell)
            if images:
                return images[0]
        except Exception:
            pass
        return None

    def _apply_bitmap_to_image_view(self, image_view, bitmap):
        if image_view is None or bitmap is None:
            return
        try:
            image_view.clearColorFilter()
        except Exception:
            pass
        try:
            image_view.setImageBitmap(bitmap)
        except Exception:
            pass

    def _apply_self_avatar(self, cell):
        bitmap = self._get_self_avatar_bitmap()
        if bitmap is None or cell is None:
            return
        icon = self._plugin_icon_view(cell)
        if icon is None:
            return
        self._apply_bitmap_to_image_view(icon, bitmap)

    def _ensure_pills_container(self):
        if self._pills_container is not None:
            return
        context = self._stored_context
        if context is None:
            return

        outer = FrameLayout(context)
        outer.setLayoutParams(
            ViewGroup.LayoutParams(
                ViewGroup.LayoutParams.MATCH_PARENT,
                ViewGroup.LayoutParams.WRAP_CONTENT,
            )
        )

        root = LinearLayout(context)
        root.setOrientation(LinearLayout.VERTICAL)
        root.setPadding(0, 0, 0, int(AndroidUtilities.dp(2)))
        root.setLayoutParams(
            FrameLayout.LayoutParams(
                FrameLayout.LayoutParams.MATCH_PARENT,
                FrameLayout.LayoutParams.WRAP_CONTENT,
            )
        )

        scroll = HorizontalScrollView(context)
        scroll.setHorizontalScrollBarEnabled(False)
        scroll.setClipToPadding(False)
        scroll.setFillViewport(True)
        scroll.setLayoutParams(
            LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.MATCH_PARENT,
                LinearLayout.LayoutParams.WRAP_CONTENT,
            )
        )
        scroll.setPadding(
            int(AndroidUtilities.dp(0)),
            int(AndroidUtilities.dp(5)),
            int(AndroidUtilities.dp(0)),
            int(AndroidUtilities.dp(2)),
        )
        scroll.setBackgroundColor(Color.TRANSPARENT)
        try:
            scroll.setClipChildren(False)
        except Exception:
            pass

        layout = LinearLayout(context)
        layout.setOrientation(LinearLayout.HORIZONTAL)
        layout.setLayoutParams(
            ViewGroup.LayoutParams(
                ViewGroup.LayoutParams.MATCH_PARENT,
                ViewGroup.LayoutParams.WRAP_CONTENT,
            )
        )
        layout.setPadding(
            int(AndroidUtilities.dp(8)),
            int(AndroidUtilities.dp(4)),
            int(AndroidUtilities.dp(8)),
            int(AndroidUtilities.dp(2)),
        )
        try:
            layout.setClipToPadding(False)
            layout.setClipChildren(False)
        except Exception:
            pass
        scroll.addView(layout)

        sort_plate = TextView(context)
        sort_plate.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
        sort_plate.setGravity(Gravity.CENTER_VERTICAL | Gravity.LEFT)
        sort_plate.setPadding(
            int(AndroidUtilities.dp(10)),
            int(AndroidUtilities.dp(4)),
            int(AndroidUtilities.dp(10)),
            int(AndroidUtilities.dp(4)),
        )
        sort_lp = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.WRAP_CONTENT,
            LinearLayout.LayoutParams.WRAP_CONTENT,
        )
        sort_lp.setMargins(int(AndroidUtilities.dp(8)), int(AndroidUtilities.dp(1)), 0, 0)
        sort_plate.setLayoutParams(sort_lp)
        sort_bg = GradientDrawable()
        sort_bg.setCornerRadius(float(AndroidUtilities.dp(12)))
        sort_bg.setColor(Color.TRANSPARENT)
        sort_plate.setBackground(sort_bg)
        sort_plate.setOnClickListener(OnClickListener(lambda _: self._open_sort_dialog()))
        sort_plate.setOnLongClickListener(
            OnLongClickListener(lambda _: self._open_sort_dialog() or True)
        )

        sort_row = LinearLayout(context)
        sort_row.setOrientation(LinearLayout.HORIZONTAL)
        sort_row.setGravity(Gravity.LEFT | Gravity.CENTER_VERTICAL)
        sort_row.setLayoutParams(
            LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.MATCH_PARENT,
                LinearLayout.LayoutParams.WRAP_CONTENT,
            )
        )
        sort_row.addView(sort_plate)

        root.addView(scroll)
        root.addView(sort_row)
        outer.addView(root)

        self._pills_container = outer
        self._pills_layout = layout
        self._pills_scroll = scroll
        self._sort_plate = sort_plate
        self._pill_meta = []

    def _rebuild_pills(self):
        if self._pills_layout is None:
            return

        self._pills_layout.removeAllViews()
        self._pill_meta = []

        all_pill = self._create_pill("Все", "msg_folders")
        self._bind_pill(all_pill, "all", "all", "msg_folders")
        self._pills_layout.addView(all_pill)

        for folder in self._folders:
            pill = self._create_pill(folder.get("name", "Папка"), folder.get("icon", "msg_folder"))
            self._bind_pill(
                pill,
                "folder",
                folder.get("id", ""),
                folder.get("icon", "msg_folder"),
            )
            self._pills_layout.addView(pill)

        add_pill = self._create_add_pill()
        self._bind_pill(add_pill, "add", "add", "")
        self._pills_layout.addView(add_pill)

        self._update_pills_visual_state()
        self._update_sort_plate()

    def _create_pill(self, text, icon_name):
        context = self._stored_context
        pill = TextView(context)
        pill.setText(text)
        pill.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
        pill.setGravity(Gravity.CENTER)
        pill.setSingleLine(True)
        pill.setMaxLines(1)
        pill.setEllipsize(TextUtils.TruncateAt.END)
        pill.setPadding(
            int(AndroidUtilities.dp(13)),
            0,
            int(AndroidUtilities.dp(13)),
            0,
        )
        lp = LinearLayout.LayoutParams(
            int(AndroidUtilities.dp(PILL_WIDTH_DP)),
            int(AndroidUtilities.dp(PILL_HEIGHT_DP)),
        )
        lp.setMargins(int(AndroidUtilities.dp(4)), int(AndroidUtilities.dp(1)), int(AndroidUtilities.dp(4)), int(AndroidUtilities.dp(1)))
        pill.setLayoutParams(lp)

        bg = GradientDrawable()
        bg.setCornerRadius(float(AndroidUtilities.dp(PILL_HEIGHT_DP / 2.0)))
        pill.setBackground(bg)
        self._set_pill_icon(pill, icon_name, Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
        return pill

    def _set_pill_icon(self, view, icon_name, tint_color):
        try:
            if not icon_name:
                view.setCompoundDrawables(None, None, None, None)
                view.setCompoundDrawablePadding(0)
                return
            icon_res = getattr(R_tg.drawable, icon_name, 0)
            if not icon_res:
                return
            drawable = self._stored_context.getResources().getDrawable(icon_res)
            if drawable is None:
                return
            size = int(AndroidUtilities.dp(14))
            drawable.setBounds(0, 0, size, size)
            try:
                drawable.setTint(tint_color)
            except Exception:
                pass
            view.setCompoundDrawables(drawable, None, None, None)
            view.setCompoundDrawablePadding(int(AndroidUtilities.dp(6)))
        except Exception:
            pass

    def _create_add_pill(self):
        context = self._stored_context
        pill = TextView(context)
        pill.setText("+")
        pill.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 20)
        pill.setGravity(Gravity.CENTER)
        pill.setIncludeFontPadding(False)
        pill.setPadding(0, 0, 0, 0)
        try:
            pill.setTranslationY(float(AndroidUtilities.dp(2)))
        except Exception:
            pass
        pill.setSingleLine(True)
        lp = LinearLayout.LayoutParams(
            int(AndroidUtilities.dp(PILL_HEIGHT_DP)),
            int(AndroidUtilities.dp(PILL_HEIGHT_DP)),
        )
        lp.setMargins(int(AndroidUtilities.dp(4)), int(AndroidUtilities.dp(1)), int(AndroidUtilities.dp(4)), int(AndroidUtilities.dp(1)))
        pill.setLayoutParams(lp)
        bg = GradientDrawable()
        bg.setCornerRadius(float(AndroidUtilities.dp(12)))
        pill.setBackground(bg)
        return pill

    def _bind_pill(self, view, kind, value, icon_name):
        self._pill_meta.append(
            {
                "view": view,
                "kind": kind,
                "value": value,
                "icon": icon_name,
            }
        )
        view.setOnClickListener(OnClickListener(lambda _: self._on_pill_click(kind, value, view)))
        view.setOnLongClickListener(
            OnLongClickListener(lambda _: self._on_pill_long_click(kind, value, view))
        )

    def _on_pill_click(self, kind, value, view):
        self._animate_pill_tap(view)
        if kind == "add":
            self._start_create_folder_flow()
            return
        if kind in ("all", "folder"):
            self._selected_folder_id = value
            self._save_state()
            self._update_pills_visual_state()
            self._refresh_plugins_list()

    def _on_pill_long_click(self, kind, value, view):
        try:
            view.performHapticFeedback(HapticFeedbackConstants.LONG_PRESS)
        except Exception:
            pass

        if kind == "folder":
            self._show_folder_actions(value)
            return True
        if kind == "add":
            self._start_create_folder_flow()
            return True
        return False

    def _animate_pill_tap(self, view):
        try:
            view.animate().cancel()
            view.setScaleX(0.96)
            view.setScaleY(0.96)
            view.animate().scaleX(1.0).scaleY(1.0).setDuration(150).start()
        except Exception:
            pass

    def _update_pills_visual_state(self):
        for meta in self._pill_meta:
            view = meta["view"]
            kind = meta["kind"]
            value = meta["value"]
            icon_name = meta["icon"]

            selected = kind in ("all", "folder") and self._selected_folder_id == value
            normal_bg = Theme.getColor(Theme.key_windowBackgroundWhite)
            selected_base = Theme.getColor(Theme.key_actionBarTabLine)
            stroke = Theme.getColor(Theme.key_divider)
            bg = view.getBackground()
            fill_color = normal_bg
            if isinstance(bg, GradientDrawable):
                if selected:
                    fill_color = self._with_alpha(selected_base, 0x52)
                    bg.setStroke(
                        int(AndroidUtilities.dp(1)),
                        self._with_alpha(selected_base, 0xAA),
                    )
                else:
                    bg.setStroke(int(AndroidUtilities.dp(1)), stroke)
                bg.setColor(fill_color)

            selected_text = Theme.getColor(
                getattr(Theme, "key_actionBarTabActiveText", Theme.key_windowBackgroundWhiteBlackText)
            )
            normal_text = Theme.getColor(Theme.key_windowBackgroundWhiteBlackText)
            text_color = selected_text if selected else normal_text
            view.setTextColor(text_color)
            self._set_pill_icon(view, icon_name, text_color)
            view.setAlpha(1.0 if selected else 0.97)
            view.setScaleY(1.0)
        self._update_sort_plate()

    def _with_alpha(self, color, alpha):
        return Color.argb(
            int(alpha) & 0xFF,
            Color.red(int(color)),
            Color.green(int(color)),
            Color.blue(int(color)),
        )

    def _ideal_text_color(self, color):
        r = Color.red(int(color))
        g = Color.green(int(color))
        b = Color.blue(int(color))
        yiq = (299 * r + 587 * g + 114 * b) / 1000.0
        return Color.BLACK if yiq >= 160 else Color.WHITE

    def _sort_mode_title(self):
        for key, title in SORT_MODES:
            if key == self._sort_mode:
                return title
        return SORT_MODES[0][1]

    def _update_sort_plate(self):
        plate = self._sort_plate
        if plate is None:
            return
        fill = Color.TRANSPARENT
        bg = plate.getBackground()
        if isinstance(bg, GradientDrawable):
            bg.setColor(fill)
        text_color = Theme.getColor(Theme.key_windowBackgroundWhiteBlackText)
        plate.setTextColor(text_color)
        plate.setText(f"Сортировка: {self._sort_mode_title()}  ▾")
        plate.setVisibility(View.VISIBLE)

    def _to_charseq_array(self, values):
        StringCls = jclass("java.lang.String")
        return jarray(StringCls)([str(v) for v in values])

    def _make_item_click_listener(self, fn):
        iface = find_class("android.content.DialogInterface$OnClickListener")
        if not iface:
            return None
        Proxy = dynamic_proxy(iface)

        class _Listener(Proxy):
            def onClick(self, dialog, which):
                fn(dialog, int(which))

        return _Listener()

    def _make_button_click_listener(self, fn):
        iface = find_class("org.telegram.ui.ActionBar.AlertDialog$OnButtonClickListener")
        if not iface:
            return None
        Proxy = dynamic_proxy(iface)

        class _Listener(Proxy):
            def onClick(self, dialog, which):
                fn(dialog, int(which))

        return _Listener()

    def _parse_color(self, hex_color, fallback):
        try:
            return Color.parseColor(str(hex_color))
        except Exception:
            return fallback

    def _open_sort_dialog(self):
        context = self._dialog_context()
        if context is None:
            return

        options = []
        for key, title in SORT_MODES:
            prefix = "● " if key == self._sort_mode else "○ "
            options.append(prefix + title)

        builder = AlertDialog.Builder(context)
        builder.setTitle("Сортировка")
        builder.setItems(
            self._to_charseq_array(options),
            self._make_item_click_listener(
                lambda _d, which: self._set_sort_mode(SORT_MODES[int(which)][0])
            ),
        )
        builder.setNegativeButton("Отмена", None)
        builder.create().show()

    def _set_sort_mode(self, mode):
        self._sort_mode = mode
        self._save_state()
        self._update_pills_visual_state()
        self._refresh_plugins_list()

    def _show_folder_actions(self, folder_id):
        folder = self._find_folder(folder_id)
        if not folder:
            return
        context = self._dialog_context()
        if context is None:
            return

        options = ["Редактировать", "Плагины в папке", "Удалить папку"]

        builder = AlertDialog.Builder(context)
        builder.setTitle(folder.get("name", "Папка"))
        builder.setItems(
            self._to_charseq_array(options),
            self._make_item_click_listener(
                lambda _d, which: self._on_folder_action(folder_id, int(which))
            ),
        )
        builder.setNegativeButton("Отмена", None)
        builder.create().show()

    def _on_folder_action(self, folder_id, index):
        if index == 0:
            self._start_edit_folder_flow(folder_id)
        elif index == 1:
            self._open_folder_plugins_editor(folder_id)
        elif index == 2:
            self._confirm_delete_folder(folder_id)

    def _start_create_folder_flow(self):
        self._ask_folder_name(
            title="Новая папка",
            default_name="Новая папка",
            callback=lambda name: self._pick_folder_icon(lambda icon: self._create_folder(name, icon)),
        )

    def _start_edit_folder_flow(self, folder_id):
        folder = self._find_folder(folder_id)
        if not folder:
            return

        self._ask_folder_name(
            title="Редактировать папку",
            default_name=folder.get("name", "Папка"),
            callback=lambda name: self._pick_folder_icon(
                lambda icon: self._update_folder(folder_id, name, icon),
                initial=folder.get("icon", "msg_folder"),
            ),
        )

    def _ask_folder_name(self, title, default_name, callback):
        context = self._dialog_context()
        if context is None:
            return

        edit = EditText(context)
        edit.setText(default_name or "")
        edit.setHint("Название папки")
        edit.setSingleLine(True)
        edit.setSelectAllOnFocus(True)
        self._style_input_edittext(edit)

        builder = AlertDialog.Builder(context)
        builder.setTitle(title)
        builder.setView(edit)
        builder.setPositiveButton(
            "Далее",
            self._make_button_click_listener(
                lambda _d, _w: callback((str(edit.getText()) or "").strip() or "Папка")
            ),
        )
        builder.setNegativeButton("Отмена", None)
        builder.create().show()

    def _pick_folder_icon(self, callback, initial=None):
        context = self._dialog_context()
        if context is None:
            return

        icon_choices = self._available_icon_presets()
        builder = AlertDialog.Builder(context)
        builder.setTitle("Иконка папки")
        grid_scroll = ScrollView(context)
        grid_root = LinearLayout(context)
        grid_root.setOrientation(LinearLayout.VERTICAL)
        grid_root.setPadding(
            int(AndroidUtilities.dp(8)),
            int(AndroidUtilities.dp(6)),
            int(AndroidUtilities.dp(8)),
            int(AndroidUtilities.dp(6)),
        )
        grid_scroll.addView(
            grid_root,
            ViewGroup.LayoutParams(
                ViewGroup.LayoutParams.MATCH_PARENT,
                ViewGroup.LayoutParams.WRAP_CONTENT,
            ),
        )

        selected_bg = Theme.getColor(Theme.key_actionBarTabLine)
        normal_bg = Theme.getColor(Theme.key_windowBackgroundWhite)
        normal_stroke = Theme.getColor(Theme.key_divider)
        icon_tint = Theme.getColor(Theme.key_windowBackgroundWhiteBlackText)
        per_row = 6
        row = None
        dialog_holder = [None]

        for idx, (icon_name, _label) in enumerate(icon_choices):
            if idx % per_row == 0:
                row = LinearLayout(context)
                row.setOrientation(LinearLayout.HORIZONTAL)
                row.setLayoutParams(
                    LinearLayout.LayoutParams(
                        LinearLayout.LayoutParams.MATCH_PARENT,
                        LinearLayout.LayoutParams.WRAP_CONTENT,
                    )
                )
                row.setPadding(0, 0, 0, int(AndroidUtilities.dp(6)))
                grid_root.addView(row)

            cell = LinearLayout(context)
            cell.setGravity(Gravity.CENTER)
            cell.setLayoutParams(
                LinearLayout.LayoutParams(
                    0,
                    int(AndroidUtilities.dp(44)),
                    1.0,
                )
            )
            cell_lp = cell.getLayoutParams()
            cell_lp.setMargins(int(AndroidUtilities.dp(2)), 0, int(AndroidUtilities.dp(2)), 0)
            cell.setLayoutParams(cell_lp)

            cell_bg = GradientDrawable()
            cell_bg.setCornerRadius(float(AndroidUtilities.dp(10)))
            if icon_name == initial:
                cell_bg.setColor(self._with_alpha(selected_bg, 0x52))
                cell_bg.setStroke(int(AndroidUtilities.dp(1)), self._with_alpha(selected_bg, 0xA8))
            else:
                cell_bg.setColor(normal_bg)
                cell_bg.setStroke(int(AndroidUtilities.dp(1)), normal_stroke)
            cell.setBackground(cell_bg)

            icon_res = getattr(R_tg.drawable, icon_name, 0)
            if icon_res:
                iv = ImageView(context)
                iv.setImageResource(icon_res)
                iv.setColorFilter(icon_tint)
                cell.addView(
                    iv,
                    LinearLayout.LayoutParams(
                        int(AndroidUtilities.dp(20)),
                        int(AndroidUtilities.dp(20)),
                    ),
                )
            cell.setOnClickListener(
                OnClickListener(
                    lambda _v, icon_name=icon_name: self._on_icon_pick(
                        icon_name, callback, dialog_holder
                    )
                )
            )
            row.addView(cell)

        builder.setView(grid_scroll)
        builder.setNegativeButton("Отмена", None)
        dialog_holder[0] = builder.create()
        dialog_holder[0].show()

    def _on_icon_pick(self, icon_name, callback, dialog_holder):
        callback(icon_name)
        try:
            if dialog_holder and dialog_holder[0]:
                dialog_holder[0].dismiss()
        except Exception:
            pass

    def _style_input_edittext(self, edit):
        try:
            edit.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
        except Exception:
            pass
        try:
            edit.setHintTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteHintText))
        except Exception:
            pass

    def _create_folder(self, name, icon):
        folder_id = f"folder_{int(time.time() * 1000)}_{self._folder_counter}"
        self._folder_counter += 1
        self._folders.append(
            {
                "id": folder_id,
                "name": name,
                "icon": icon,
                "color": "",
                "plugins": [],
            }
        )
        self._selected_folder_id = folder_id
        self._save_state()
        self._rebuild_pills()
        self._refresh_plugins_list()
        run_on_ui_thread(lambda: BulletinHelper.show_success("Папка создана"))

    def _update_folder(self, folder_id, name, icon):
        folder = self._find_folder(folder_id)
        if not folder:
            return
        folder["name"] = name
        folder["icon"] = icon
        self._save_state()
        self._rebuild_pills()
        self._refresh_plugins_list()
        run_on_ui_thread(lambda: BulletinHelper.show_success("Папка обновлена"))

    def _confirm_delete_folder(self, folder_id):
        folder = self._find_folder(folder_id)
        if not folder:
            return
        context = self._dialog_context()
        if context is None:
            return

        builder = AlertDialog.Builder(context)
        builder.setTitle("Удалить папку?")
        builder.setMessage(folder.get("name", "Папка"))
        builder.setPositiveButton(
            "Удалить",
            self._make_button_click_listener(lambda _d, _w: self._delete_folder(folder_id)),
        )
        builder.setNegativeButton("Отмена", None)
        builder.create().show()

    def _delete_folder(self, folder_id):
        self._folders = [f for f in self._folders if f.get("id") != folder_id]
        if self._selected_folder_id == folder_id:
            self._selected_folder_id = "all"
        self._save_state()
        self._rebuild_pills()
        self._refresh_plugins_list()
        run_on_ui_thread(lambda: BulletinHelper.show_success("Папка удалена"))

    def _open_folder_plugins_editor(self, folder_id):
        folder = self._find_folder(folder_id)
        if not folder:
            return

        all_plugins = self._list_plugins()
        if not all_plugins:
            run_on_ui_thread(lambda: BulletinHelper.show_error("Плагины не найдены"))
            return

        selected = set(folder.get("plugins", []))
        context = self._dialog_context()
        if context is None:
            return

        options = []
        for pid, name in all_plugins:
            mark = "✓" if pid in selected else "○"
            options.append(f"{mark} {name}")

        def on_select(_d, which):
            idx = int(which)
            if idx < 0 or idx >= len(all_plugins):
                return
            pid = all_plugins[idx][0]
            if pid in selected:
                selected.remove(pid)
            else:
                selected.add(pid)
            folder["plugins"] = sorted(selected)
            self._save_state()
            self._refresh_plugins_list()
            run_on_ui_thread(lambda: self._open_folder_plugins_editor(folder_id))

        builder = AlertDialog.Builder(context)
        builder.setTitle(f"{folder.get('name', 'Папка')} • плагины")
        builder.setItems(
            self._to_charseq_array(options),
            self._make_item_click_listener(on_select),
        )
        builder.setNegativeButton("Закрыть", None)
        builder.create().show()

    def _list_plugins(self):
        result = []
        try:
            controller = PluginsController.getInstance()
            plugins_map = controller.plugins
            keys = plugins_map.keySet().toArray()
            for key in keys:
                plugin = plugins_map.get(key)
                if plugin is None:
                    continue
                pid = str(plugin.getId())
                name = str(plugin.getName() or pid)
                result.append((pid, name))
        except Exception as e:
            self._dbg(f"_list_plugins error: {e}")
        result.sort(key=lambda x: x[1].lower())
        return result

    def _refresh_plugins_list(self):
        activity = self._stored_activity
        if activity is None:
            return

        def _run():
            try:
                list_view = get_private_field(activity, "listView")
                if list_view and list_view.adapter:
                    list_view.adapter.update(True)
            except Exception as e:
                self._dbg(f"refresh error: {e}")

        run_on_ui_thread(_run)

    def _find_folder(self, folder_id):
        for folder in self._folders:
            if folder.get("id") == folder_id:
                return folder
        return None

    def _available_icon_presets(self):
        out = []
        for icon_name, label in ICON_PRESETS:
            try:
                if getattr(R_tg.drawable, icon_name, 0):
                    out.append((icon_name, label))
            except Exception:
                pass
        if not out:
            out = [("msg_folder", "Папка")]
        return out

    def _dialog_context(self):
        if self._stored_context is not None:
            return self._stored_context
        fragment = get_last_fragment()
        if fragment:
            try:
                return fragment.getParentActivity()
            except Exception:
                return None
        return None

    def _load_state(self):
        self._folders = []
        self._selected_folder_id = str(self.get_setting("selected_folder_id", "all") or "all")
        self._sort_mode = str(self.get_setting("sort_mode", "default") or "default")
        self._folder_counter = int(self.get_setting("folder_counter", 0) or 0)

        raw = self.get_setting("folders_json", "")
        if not raw:
            return
        try:
            data = json.loads(raw)
            if isinstance(data, list):
                cleaned = []
                for folder in data:
                    if not isinstance(folder, dict):
                        continue
                    fid = str(folder.get("id", "")).strip()
                    if not fid:
                        continue
                    cleaned.append(
                        {
                            "id": fid,
                            "name": str(folder.get("name", "Папка")),
                            "icon": str(folder.get("icon", "msg_folder")),
                            "color": str(folder.get("color", "#4F8CFF")),
                            "plugins": list(folder.get("plugins", []) or []),
                        }
                    )
                self._folders = cleaned
        except Exception as e:
            self._dbg(f"load_state error: {e}")
            self._folders = []

    def _save_state(self):
        self.set_setting("folders_json", json.dumps(self._folders, ensure_ascii=False))
        self.set_setting("selected_folder_id", self._selected_folder_id)
        self.set_setting("sort_mode", self._sort_mode)
        self.set_setting("folder_counter", int(self._folder_counter))
