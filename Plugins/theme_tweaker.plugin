__id__          = "theme_tweaker"
__name__        = "Theme Tweaker"
__author__      = "@sokolovskybio"
__description__ = "Color editor: HSV picker, live apply, wallpapers, import/export"
__version__     = "1.UI.0"
__min_version__ = "12.4.1"
__icon__        = "Furries_by_TherianOperator_2_by_TgEmodziBot/8"

import colorsys, json, os, shutil, time
from android_utils import run_on_ui_thread, OnClickListener, OnLongClickListener
from base_plugin import BasePlugin, MethodHook
from client_utils import get_last_fragment
from ui.bulletin import BulletinHelper
from ui.settings import Divider, Header, Switch, Text
from hook_utils import find_class
from java import dynamic_proxy, jclass, jarray, jint

def _show_toast(msg):
    try:
        from android.widget import Toast
        from org.telegram.messenger import ApplicationLoader
        ctx = ApplicationLoader.applicationContext
        if ctx:
            run_on_ui_thread(lambda: Toast.makeText(ctx, str(msg), 1).show())
    except Exception:
        pass

def _s32(c):
    c = int(c) & 0xFFFFFFFF
    return c - 0x100000000 if c & 0x80000000 else c

def _hsv_to_argb(h, s, v, a=255):
    r, g, b = colorsys.hsv_to_rgb(h / 360., s, v)
    return _s32((a << 24) | (int(r*255) << 16) | (int(g*255) << 8) | int(b*255))

def _argb_to_hsv(color):
    c = int(color) & 0xFFFFFFFF
    a = (c >> 24) & 0xFF
    r, g, b = ((c>>16)&0xFF)/255., ((c>>8)&0xFF)/255., (c&0xFF)/255.
    h, s, v = colorsys.rgb_to_hsv(r, g, b)
    return h*360., s, v, a

def _to_hex(color):
    c = int(color) & 0xFFFFFFFF
    a, r, g, b = (c>>24)&0xFF, (c>>16)&0xFF, (c>>8)&0xFF, c&0xFF
    return f"#{a:02X}{r:02X}{g:02X}{b:02X}"

def _from_hex(s):
    s = s.strip().lstrip("#")
    try:
        if len(s) == 6: return _s32((0xFF << 24) | int(s, 16))
        if len(s) == 8: return _s32(int(s, 16))
    except Exception: pass
    return None

def _T():
    from org.telegram.ui.ActionBar import Theme; return Theme

def _get_color(key_name):
    try:
        T = _T(); k = getattr(T, f"key_{key_name}", None)
        if k is not None: return int(T.getColor(k))
    except Exception: pass
    return _s32(0xFF808080)

def _set_color(key_name, color, save=False):
    # ВАЖНО: Мы ВСЕГДА используем save=False. 
    # Это гарантирует, что файл темы на диске никогда не будет поврежден.
    try:
        T = _T(); k = getattr(T, f"key_{key_name}", None)
        if k is not None: T.setColor(k, color, save)
    except Exception: pass

def _notify_theme_changed():
    try:
        from org.telegram.messenger import NotificationCenter
        nc = NotificationCenter.getGlobalInstance()
        empty_args = jarray(jclass("java.lang.Object"))([])
        for attr in ("themeChanged", "didSetNewTheme", "notificationThemeChanged"):
            id_ = getattr(NotificationCenter, attr, None)
            if id_ is not None:
                nc.postNotificationName(id_, empty_args)
    except Exception: pass

def _theme_info():
    try: return _T().getActiveTheme()
    except Exception: return None

def _theme_name():
    ti = _theme_info()
    if ti and ti.name:
        return str(ti.name).replace(" ", "_").replace("/", "_")
    return "default"

def _theme_display():
    ti = _theme_info()
    if ti and ti.name: return str(ti.name)
    return "default"

def _get_activity():
    try:
        frag = get_last_fragment()
        if frag is not None:
            act = frag.getParentActivity()
            if act is not None: return act
    except Exception: pass
    try:
        from org.telegram.messenger import ApplicationLoader
        return ApplicationLoader.applicationContext
    except Exception: pass
    return None

def _screen_dims():
    try:
        from android.util import DisplayMetrics
        dm = DisplayMetrics()
        _get_activity().getWindowManager().getDefaultDisplay().getMetrics(dm)
        return dm.widthPixels, dm.heightPixels
    except Exception: return 1080, 1920

def _circ(c, bc=0, bw=0):
    from android.graphics.drawable import GradientDrawable
    d = GradientDrawable()
    d.setShape(GradientDrawable.OVAL)
    d.setColor(c)
    if bw > 0: d.setStroke(bw, bc)
    return d

def _hs_bmp(w, h):
    if w <= 0: w = 1
    if h <= 0: h = 1
    from android.graphics import Bitmap, Canvas, LinearGradient, Paint, Shader
    bmp = Bitmap.createBitmap(w, h, Bitmap.Config.ARGB_8888)
    cv = Canvas(bmp)
    p = Paint(Paint.ANTI_ALIAS_FLAG)
    
    hues =[0, 60, 120, 180, 240, 300, 360]
    for i in range(len(hues)-1):
        x1 = float(i * w / (len(hues)-1))
        x2 = float((i+1) * w / (len(hues)-1))
        colors = jarray(jint)([_hsv_to_argb(hues[i], 1., 1.), _hsv_to_argb(hues[i+1], 1., 1.)])
        p.setShader(LinearGradient(x1, 0., x2, 0., colors, None, Shader.TileMode.CLAMP))
        cv.drawRect(x1, 0., x2, float(h), p)
        
    colors2 = jarray(jint)([_s32(0xFFFFFFFF), _s32(0x00FFFFFF)])
    p.setShader(LinearGradient(0., 0., 0., float(h), colors2, None, Shader.TileMode.CLAMP))
    cv.drawRect(0., 0., float(w), float(h), p)
    
    p.setShader(None)
    return bmp

def _show_picker(ctx, key_name, orig_color, saved_color, on_save):
    try:
        from android.graphics.drawable import GradientDrawable
        from android.text import InputType, TextWatcher
        from android.util import TypedValue
        from android.view import Gravity, MotionEvent, View, ViewTreeObserver
        from android.widget import FrameLayout, LinearLayout, TextView, ImageView
        from org.telegram.messenger import AndroidUtilities
        from org.telegram.ui.ActionBar import Theme, AlertDialog
        from org.telegram.ui.Components import EditTextBoldCursor

        keep_alive =[]

        dp = AndroidUtilities.dp
        PAD = dp(16)
        SQ = dp(170)
        PTR = dp(16)
        HH = dp(24)
        HPS = dp(6)

        h0, s0, v0, a0 = _argb_to_hsv(saved_color)
        st = {"h": h0, "s": s0, "v": v0, "a": a0, "upd": False}
        cur = lambda: _hsv_to_argb(st["h"], st["s"], st["v"], st["a"])

        root = LinearLayout(ctx)
        root.setOrientation(LinearLayout.VERTICAL)
        root.setPadding(PAD, PAD, PAD, PAD)

        title_tv = TextView(ctx)
        title_tv.setText(key_name)
        title_tv.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
        title_tv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 18)
        title_tv.setTypeface(AndroidUtilities.getTypeface(AndroidUtilities.TYPEFACE_ROBOTO_MEDIUM))
        title_tv.setPadding(0, 0, 0, dp(16))
        root.addView(title_tv)

        split = LinearLayout(ctx)
        split.setOrientation(LinearLayout.HORIZONTAL)

        sq_f = FrameLayout(ctx)
        sq_f.setLayoutParams(LinearLayout.LayoutParams(SQ, SQ))
        bg_shape = GradientDrawable()
        bg_shape.setCornerRadius(dp(6))
        bg_shape.setColor(Theme.getColor(Theme.key_windowBackgroundGray))
        sq_f.setBackground(bg_shape)
        sq_f.setClipToOutline(True)

        sq_v = ImageView(ctx)
        sq_v.setLayoutParams(FrameLayout.LayoutParams(SQ, SQ))
        sq_v.setScaleType(ImageView.ScaleType.FIT_XY)
        sq_v.setImageBitmap(_hs_bmp(SQ, SQ))
        
        sq_p = View(ctx)
        sq_p.setLayoutParams(FrameLayout.LayoutParams(PTR, PTR))
        sq_p.setElevation(dp(2))
        
        sq_f.addView(sq_v)
        sq_f.addView(sq_p)
        split.addView(sq_f)

        right_col = LinearLayout(ctx)
        right_col.setOrientation(LinearLayout.VERTICAL)
        rlp = LinearLayout.LayoutParams(0, -2, 1.0)
        rlp.leftMargin = dp(16)
        right_col.setLayoutParams(rlp)

        prev_row = LinearLayout(ctx)
        prev_row.setOrientation(LinearLayout.HORIZONTAL)
        prev_row.setLayoutParams(LinearLayout.LayoutParams(-1, dp(48)))

        def _make_sq_prev():
            v = View(ctx)
            v.setLayoutParams(LinearLayout.LayoutParams(0, -1, 1.0))
            return v

        sq_old = _make_sq_prev()
        lp_old = sq_old.getLayoutParams()
        lp_old.rightMargin = dp(4)
        sq_old.setLayoutParams(lp_old)
        bg_old = GradientDrawable()
        bg_old.setColor(orig_color)
        bg_old.setCornerRadius(dp(6))
        bg_old.setStroke(dp(1), Theme.getColor(Theme.key_divider))
        sq_old.setBackground(bg_old)
        prev_row.addView(sq_old)

        sq_new = _make_sq_prev()
        lp_new = sq_new.getLayoutParams()
        lp_new.leftMargin = dp(4)
        sq_new.setLayoutParams(lp_new)
        bg_new = GradientDrawable()
        bg_new.setCornerRadius(dp(6))
        bg_new.setStroke(dp(1), Theme.getColor(Theme.key_divider))
        sq_new.setBackground(bg_new)
        prev_row.addView(sq_new)

        right_col.addView(prev_row)

        hex_et = EditTextBoldCursor(ctx)
        hex_et.setHint("HEX код")
        hex_et.setInputType(InputType.TYPE_CLASS_TEXT | InputType.TYPE_TEXT_FLAG_CAP_CHARACTERS | InputType.TYPE_TEXT_FLAG_NO_SUGGESTIONS)
        hex_et.setSingleLine(True)
        hex_et.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
        hex_et.setHintTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteHintText))
        hex_et.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
        hex_et.setPadding(dp(8), dp(8), dp(8), dp(8))
        bg_et = GradientDrawable()
        bg_et.setColor(Theme.getColor(Theme.key_windowBackgroundGray))
        bg_et.setCornerRadius(dp(6))
        hex_et.setBackground(bg_et)
        hlp_et = LinearLayout.LayoutParams(-1, -2)
        hlp_et.topMargin = dp(12)
        hex_et.setLayoutParams(hlp_et)
        right_col.addView(hex_et)

        val_f = FrameLayout(ctx)
        hlp = LinearLayout.LayoutParams(-1, HH)
        hlp.topMargin = dp(16)
        val_f.setLayoutParams(hlp)
        val_f.setBackground(bg_shape)
        val_f.setClipToOutline(True)

        val_track = View(ctx)
        val_track.setLayoutParams(FrameLayout.LayoutParams(-1, HH))
        
        val_ptr = View(ctx)
        v_ptr_lp = FrameLayout.LayoutParams(HPS, HH + dp(6))
        v_ptr_lp.topMargin = -dp(3)
        val_ptr.setLayoutParams(v_ptr_lp)
        ptr_bg = GradientDrawable()
        ptr_bg.setColor(_s32(0xFFFFFFFF))
        ptr_bg.setCornerRadius(dp(3))
        ptr_bg.setStroke(dp(1), _s32(0xFF888888))
        val_ptr.setBackground(ptr_bg)
        val_ptr.setElevation(dp(2))

        val_f.addView(val_track)
        val_f.addView(val_ptr)
        right_col.addView(val_f)

        split.addView(right_col)
        root.addView(split)

        btn_container = LinearLayout(ctx)
        btn_container.setOrientation(LinearLayout.VERTICAL)
        btn_container.setLayoutParams(LinearLayout.LayoutParams(-1, -2))
        btn_container.setPadding(0, dp(24), 0, 0)

        btn_row1 = LinearLayout(ctx)
        btn_row1.setOrientation(LinearLayout.HORIZONTAL)
        btn_row1.setLayoutParams(LinearLayout.LayoutParams(-1, -2))

        btn_row2 = LinearLayout(ctx)
        btn_row2.setOrientation(LinearLayout.HORIZONTAL)
        btn_row2.setLayoutParams(LinearLayout.LayoutParams(-1, -2))
        btn_row2.setPadding(0, dp(8), 0, 0)

        def _mk_btn(text, is_primary, action):
            tv = TextView(ctx)
            tv.setText(text)
            tv.setGravity(Gravity.CENTER)
            tv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
            tv.setTypeface(AndroidUtilities.getTypeface(AndroidUtilities.TYPEFACE_ROBOTO_MEDIUM))
            tv.setLayoutParams(LinearLayout.LayoutParams(0, dp(38), 1.0))

            bg = GradientDrawable()
            bg.setCornerRadius(dp(6))
            if is_primary:
                tv.setTextColor(Theme.getColor(Theme.key_featuredStickers_buttonText))
                bg.setColor(Theme.getColor(Theme.key_featuredStickers_addButton))
            else:
                tv.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlueText4))
                bg.setColor(0)
                bg.setStroke(dp(1), Theme.getColor(Theme.key_divider))

            tv.setBackground(bg)
            
            clicker = OnClickListener(lambda v: action())
            tv.setOnClickListener(clicker)
            keep_alive.append(clicker)
            return tv

        builder = AlertDialog.Builder(ctx)
        builder.setView(root)
        dialog = builder.create()

        def _on_cancel_dialog(d):
            try:
                _set_color(key_name, saved_color, save=False)
                run_on_ui_thread(_notify_theme_changed)
            except: pass

        def _do_save():
            c = cur()
            on_save(c)
            BulletinHelper.show_success(f"Сохранено: {_to_hex(c)}")
            dialog.dismiss()

        def _do_cancel():
            _on_cancel_dialog(dialog)
            dialog.dismiss()

        def _do_prev():
            _set_st(*_argb_to_hsv(saved_color))

        def _do_orig():
            _set_st(*_argb_to_hsv(orig_color))

        btn_save = _mk_btn("Сохранить", True, _do_save)
        btn_cancel = _mk_btn("Отмена", False, _do_cancel)
        btn_prev = _mk_btn("К предыдущему", False, _do_prev)
        btn_orig = _mk_btn("К исходному", False, _do_orig)

        lp_cancel = btn_cancel.getLayoutParams()
        lp_cancel.leftMargin = dp(8)
        btn_cancel.setLayoutParams(lp_cancel)

        lp_orig = btn_orig.getLayoutParams()
        lp_orig.leftMargin = dp(8)
        btn_orig.setLayoutParams(lp_orig)

        btn_row1.addView(btn_save)
        btn_row1.addView(btn_cancel)
        btn_row2.addView(btn_prev)
        btn_row2.addView(btn_orig)

        btn_container.addView(btn_row1)
        btn_container.addView(btn_row2)
        root.addView(btn_container)
        
        CancelListener = find_class("android.content.DialogInterface$OnCancelListener")
        class _CancelListenerProxy(dynamic_proxy(CancelListener)):
            def onCancel(self, d):
                _on_cancel_dialog(d)

        cancel_proxy = _CancelListenerProxy()
        dialog.setOnCancelListener(cancel_proxy)
        keep_alive.append(cancel_proxy)

        last_update = [0]
        def _apply_live(force=False):
            c = cur()
            _set_color(key_name, c, save=False)
            now = time.time()
            if force or (now - last_update[0] > 0.05):
                _notify_theme_changed()
                last_update[0] = now

        def _set_st(h, s, v, a):
            st.update({"h": h, "s": s, "v": v, "a": a})
            run_on_ui_thread(_ref)
            run_on_ui_thread(lambda: _apply_live(True))

        def _ref():
            x = int(st["h"] / 360. * SQ) - PTR // 2
            y = int(st["s"] * SQ) - PTR // 2
            lp = FrameLayout.LayoutParams(PTR, PTR)
            lp.leftMargin = max(0, min(x, SQ - PTR))
            lp.topMargin = max(0, min(y, SQ - PTR))
            sq_p.setLayoutParams(lp)

            ptr_d = GradientDrawable()
            ptr_d.setShape(GradientDrawable.OVAL)
            ptr_d.setColor(_hsv_to_argb(st["h"], st["s"], 1.0))
            ptr_d.setStroke(dp(2), _s32(0xFFFFFFFF))
            sq_p.setBackground(ptr_d)

            val_w = val_track.getWidth()
            if val_w > 0:
                color_v1 = _hsv_to_argb(st["h"], st["s"], 1.)
                colors = jarray(jint)([_s32(0xFF000000), color_v1])
                track_bg = GradientDrawable(GradientDrawable.Orientation.LEFT_RIGHT, colors)
                val_track.setBackground(track_bg)

                x2 = int(st["v"] * val_w) - HPS // 2
                hlp = FrameLayout.LayoutParams(HPS, HH + dp(6))
                hlp.topMargin = -dp(3)
                hlp.leftMargin = max(0, min(x2, val_w - HPS))
                val_ptr.setLayoutParams(hlp)

            c = cur()
            bg_new.setColor(c)
            sq_new.invalidate()

            st["upd"] = True
            hex_str = _to_hex(c)
            if str(hex_et.getText()) != hex_str:
                hex_et.setText(hex_str)
                hex_et.setSelection(hex_et.getText().length())
            st["upd"] = False

        OnGlobalLayoutListener = find_class("android.view.ViewTreeObserver$OnGlobalLayoutListener")
        class _LayoutListener(dynamic_proxy(OnGlobalLayoutListener)):
            def onGlobalLayout(self):
                try:
                    val_track.getViewTreeObserver().removeOnGlobalLayoutListener(self)
                except: pass
                run_on_ui_thread(_ref)
                
        layout_listener = _LayoutListener()
        val_track.getViewTreeObserver().addOnGlobalLayoutListener(layout_listener)
        keep_alive.append(layout_listener)

        OnTouchListener = find_class("android.view.View$OnTouchListener")
        class _SqT(dynamic_proxy(OnTouchListener)):
            def onTouch(self, v, ev):
                from android.view import MotionEvent
                action = ev.getAction()
                if action in (MotionEvent.ACTION_DOWN, MotionEvent.ACTION_MOVE):
                    w = sq_f.getWidth() if sq_f.getWidth() > 0 else SQ
                    h_sq = sq_f.getHeight() if sq_f.getHeight() > 0 else SQ
                    st["h"] = max(0., min(359.99, float(ev.getX()) / w * 360.))
                    st["s"] = max(0., min(1., float(ev.getY()) / h_sq))
                    run_on_ui_thread(_ref)
                    run_on_ui_thread(lambda: _apply_live(False))
                elif action == MotionEvent.ACTION_UP:
                    run_on_ui_thread(lambda: _apply_live(True))
                return True

        class _ValT(dynamic_proxy(OnTouchListener)):
            def onTouch(self, v, ev):
                from android.view import MotionEvent
                action = ev.getAction()
                if action in (MotionEvent.ACTION_DOWN, MotionEvent.ACTION_MOVE):
                    w = val_track.getWidth() if val_track.getWidth() > 0 else 1
                    st["v"] = max(0., min(1., float(ev.getX()) / w))
                    run_on_ui_thread(_ref)
                    run_on_ui_thread(lambda: _apply_live(False))
                elif action == MotionEvent.ACTION_UP:
                    run_on_ui_thread(lambda: _apply_live(True))
                return True

        TextWatcher = find_class("android.text.TextWatcher")
        class _HexW(dynamic_proxy(TextWatcher)):
            def afterTextChanged(self, e):
                if st["upd"]: return
                text = str(e.toString())
                if not text.startswith("#"):
                    st["upd"] = True
                    hex_et.setText("#" + text.replace("#", ""))
                    hex_et.setSelection(hex_et.getText().length())
                    st["upd"] = False
                    text = "#" + text.replace("#", "")
                
                c = _from_hex(text)
                if c is not None:
                    h, s, v, a = _argb_to_hsv(c)
                    st.update({"h": h, "s": s, "v": v, "a": a})
                    run_on_ui_thread(_ref)
                    run_on_ui_thread(lambda: _apply_live(True))
            def beforeTextChanged(self, s, a, b, c): pass
            def onTextChanged(self, s, a, b, c): pass

        sq_t = _SqT()
        sq_v.setOnTouchListener(sq_t)
        sq_f.setOnTouchListener(sq_t)
        keep_alive.append(sq_t)
        
        val_t = _ValT()
        val_track.setOnTouchListener(val_t)
        val_f.setOnTouchListener(val_t)
        keep_alive.append(val_t)
        
        hex_w = _HexW()
        hex_et.addTextChangedListener(hex_w)
        keep_alive.append(hex_w)

        dialog.show()
        
        DismissListener = find_class("android.content.DialogInterface$OnDismissListener")
        class _DismissListenerProxy(dynamic_proxy(DismissListener)):
            def onDismiss(self, d):
                keep_alive.clear()
        dismiss_proxy = _DismissListenerProxy()
        dialog.setOnDismissListener(dismiss_proxy)
        keep_alive.append(dismiss_proxy)
        
        try: dialog.setCanceledOnTouchOutside(True)
        except Exception: pass
        run_on_ui_thread(_ref, 100)

    except Exception as e:
        import traceback
        err = traceback.format_exc()
        _show_toast(f"Ошибка редактора: {e}")

THEME_KEYS = {
    "Фон и интерфейс":[
