        ("chat_inBubbleSelected", "Фон выделенного входящего сообщения"),
        ("chat_outBubble", "Фон исходящего сообщения"),
        ("chat_outBubbleGradient", "Градиент исходящего сообщения (верх)"),
        ("chat_outBubbleGradient2", "Градиент исходящего сообщения (низ)"),
        ("chat_outBubbleSelected", "Фон выделенного исходящего сообщения"),
    ],
    "Текст сообщений":[
        ("chat_messageTextIn", "Текст внутри входящего сообщения"),
        ("chat_messageTextOut", "Текст внутри исходящего сообщения"),
        ("chat_inTimeText", "Время отправки входящего сообщения"),
        ("chat_outTimeText", "Время отправки исходящего сообщения"),
    ],
    "Статус отправки (Галочки)":[
        ("chat_outSentCheck", "Галочки (доставлено)"),
        ("chat_outSentCheckRead", "Галочки (прочитано)"),
        ("chat_mediaSentCheck", "Галочки поверх медиа (фото/видео)"),
    ],
    "Цитаты и ответы":[
        ("chat_inReplyLine", "Вертикальная линия ответа (входящие)"),
        ("chat_outReplyLine", "Вертикальная линия ответа (исходящие)"),
        ("chat_inReplyNameText", "Имя автора в ответе (входящие)"),
        ("chat_outReplyNameText", "Имя автора в ответе (исходящие)"),
        ("chat_inReplyMessageText", "Текст ответа (входящие)"),
        ("chat_outReplyMessageText", "Текст ответа (исходящие)"),
    ],
    "Элементы управления":[
        ("switchTrack", "Фон выключенного переключателя"),
        ("switchTrackChecked", "Фон включенного переключателя"),
        ("radioBackground", "Невыбранная радио-кнопка"),
        ("radioBackgroundChecked", "Выбранная радио-кнопка"),
        ("player_progressBackground", "Фон полосы воспроизведения аудио"),
        ("player_progress", "Заполненная часть полосы аудио"),
    ],
}

def _show_keys(ctx, category, keys, pr):
    from org.telegram.ui.ActionBar import BottomSheet, Theme
    from android.widget import LinearLayout, ScrollView, TextView
    from android.view import Gravity, HapticFeedbackConstants, View
    from android.util import TypedValue
    from org.telegram.messenger import AndroidUtilities

    keep_alive =[]
    dp = AndroidUtilities.dp

    builder = BottomSheet.Builder(ctx)
    builder.setApplyTopPadding(False)

    scroll = ScrollView(ctx)
    ll = LinearLayout(ctx)
    ll.setOrientation(LinearLayout.VERTICAL)
    scroll.addView(ll)

    header = LinearLayout(ctx)
    header.setOrientation(LinearLayout.HORIZONTAL)
    header.setGravity(Gravity.CENTER_VERTICAL)
    header.setPadding(dp(16), dp(16), dp(16), dp(8))

    back_btn = TextView(ctx)
    back_btn.setText("← Назад")
    back_btn.setTextColor(Theme.getColor(Theme.key_dialogTextLink))
    back_btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
    back_btn.setTypeface(AndroidUtilities.getTypeface(AndroidUtilities.TYPEFACE_ROBOTO_MEDIUM))
    back_btn.setPadding(0, dp(4), dp(16), dp(4))
    back_clicker = OnClickListener(lambda v: (builder.getDismissRunnable().run(), run_on_ui_thread(lambda: _show_cats(ctx, pr))))
    back_btn.setOnClickListener(back_clicker)
    keep_alive.append(back_clicker)
    header.addView(back_btn)

    title = TextView(ctx)
    title.setText(category)
    title.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
    title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 18)
    title.setTypeface(AndroidUtilities.getTypeface(AndroidUtilities.TYPEFACE_ROBOTO_MEDIUM))
    header.addView(title)
    ll.addView(header)

    for kn, kd in keys:
        row = LinearLayout(ctx)
        row.setOrientation(LinearLayout.HORIZONTAL)
        row.setGravity(Gravity.CENTER_VERTICAL)
        row.setPadding(dp(20), dp(12), dp(20), dp(12))
        row.setBackground(Theme.createSelectorDrawable(Theme.getColor(Theme.key_listSelector), 2))

        chip = View(ctx)
        clp = LinearLayout.LayoutParams(dp(36), dp(36))
        clp.rightMargin = dp(16)
        chip.setLayoutParams(clp)
        chip.setBackground(_circ(pr._get_saved(kn), Theme.getColor(Theme.key_divider), dp(1)))
        row.addView(chip)

        col = LinearLayout(ctx)
        col.setOrientation(LinearLayout.VERTICAL)
        col.setLayoutParams(LinearLayout.LayoutParams(0, -2, 1.0))

        ntv = TextView(ctx)
        ntv.setText(kn)
        ntv.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
        ntv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
        ntv.setTypeface(AndroidUtilities.getTypeface(AndroidUtilities.TYPEFACE_ROBOTO_MEDIUM))

        dtv = TextView(ctx)
        dtv.setText(kd)
        dtv.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
        dtv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)

        col.addView(ntv)
        col.addView(dtv)
        row.addView(col)
        ll.addView(row)

        def _mk(n, d, ch):
            def _open():
                try:
                    orig  = pr._get_orig(n)
                    saved = pr._get_saved(n)
                    def _apply(nc):
                        pr._backup_and_set_color(n, nc, orig)
                        run_on_ui_thread(_notify_theme_changed)
                        ch.setBackground(_circ(nc, Theme.getColor(Theme.key_divider), dp(1)))
                    run_on_ui_thread(lambda: _show_picker(ctx, n, orig, saved, _apply))
                except Exception as e:
                    _show_toast(f"Error: {e}")

            def _copy():
                try:
                    hex_code = _to_hex(pr._get_saved(n))
                    AndroidUtilities.addToClipboard(hex_code)
                    BulletinHelper.show_success(f"Цвет {hex_code} скопирован")
                except: pass

            def _click(v):
                _open()

            def _long(v):
                try: v.performHapticFeedback(HapticFeedbackConstants.LONG_PRESS)
                except Exception: pass
                _copy()
                return True
                
            return _click, _long

        c, lc = _mk(kn, kd, chip)
        clicker = OnClickListener(c)
        long_clicker = OnLongClickListener(lc)
        row.setOnClickListener(clicker)
        row.setOnLongClickListener(long_clicker)
        keep_alive.extend([clicker, long_clicker])

    builder.setCustomView(scroll)
    sheet = builder.show()
    
    DismissListener = find_class("android.content.DialogInterface$OnDismissListener")
    class _DismissListenerProxy(dynamic_proxy(DismissListener)):
        def onDismiss(self, d):
            keep_alive.clear()
    dismiss_proxy = _DismissListenerProxy()
    sheet.setOnDismissListener(dismiss_proxy)
    keep_alive.append(dismiss_proxy)

def _show_cats(ctx, pr):
    from org.telegram.ui.ActionBar import BottomSheet, Theme
    from android.widget import LinearLayout, ScrollView, TextView
    from android.view import Gravity
    from android.util import TypedValue
    from org.telegram.messenger import AndroidUtilities

    keep_alive =[]
    dp = AndroidUtilities.dp

    builder = BottomSheet.Builder(ctx)
    builder.setApplyTopPadding(False)

    scroll = ScrollView(ctx)
    ll = LinearLayout(ctx)
    ll.setOrientation(LinearLayout.VERTICAL)
    scroll.addView(ll)

    title = TextView(ctx)
    title.setText("Редактор темы")
    title.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
    title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 20)
    title.setTypeface(AndroidUtilities.getTypeface(AndroidUtilities.TYPEFACE_ROBOTO_MEDIUM))
    title.setPadding(dp(20), dp(20), dp(20), dp(10))
    ll.addView(title)

    sub = TextView(ctx)
    sub.setText(f"Тема: {_theme_display()}")
    sub.setTextColor(Theme.getColor(Theme.key_dialogTextGray3))
    sub.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
    sub.setPadding(dp(20), 0, dp(20), dp(10))
    ll.addView(sub)

    for cat, keys in THEME_KEYS.items():
        changed = sum(1 for k, _ in keys if pr.get_setting(pr._pk(k), None) is not None)

        row = LinearLayout(ctx)
        row.setOrientation(LinearLayout.HORIZONTAL)
        row.setGravity(Gravity.CENTER_VERTICAL)
        row.setPadding(dp(20), dp(14), dp(20), dp(14))
        row.setBackground(Theme.createSelectorDrawable(Theme.getColor(Theme.key_listSelector), 2))

        ttv = TextView(ctx)
        ttv.setText(cat)
        ttv.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
        ttv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
        ttv.setLayoutParams(LinearLayout.LayoutParams(0, -2, 1.0))
        row.addView(ttv)

        if changed > 0:
            badge = TextView(ctx)
            badge.setText(str(changed))
            badge.setTextColor(_s32(0xFFFFFFFF))
            badge.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
            badge.setGravity(Gravity.CENTER)
            badge.setBackground(_circ(Theme.getColor(Theme.key_windowBackgroundWhiteBlueHeader)))
            badge.setLayoutParams(LinearLayout.LayoutParams(dp(24), dp(24)))
            row.addView(badge)

        ll.addView(row)

        def _mk(cn, ks):
            def _click(v):
                builder.getDismissRunnable().run()
                run_on_ui_thread(lambda: _show_keys(ctx, cn, ks, pr))
            return _click

        clicker = OnClickListener(_mk(cat, keys))
        row.setOnClickListener(clicker)
        keep_alive.append(clicker)

    builder.setCustomView(scroll)
    sheet = builder.show()
    
    DismissListener = find_class("android.content.DialogInterface$OnDismissListener")
    class _DismissListenerProxy(dynamic_proxy(DismissListener)):
        def onDismiss(self, d):
            keep_alive.clear()
    dismiss_proxy = _DismissListenerProxy()
    sheet.setOnDismissListener(dismiss_proxy)
    keep_alive.append(dismiss_proxy)

def _save_wallpapers(out_dir):
    slug  = _theme_name()
    os.makedirs(out_dir, exist_ok=True)

    try:
        from android.graphics import Bitmap, Canvas
        from java.io import FileOutputStream
        from org.telegram.ui.ActionBar import Theme
        import shutil
        
        drawable = Theme.getCachedWallpaper()
        if not drawable:
            ti = Theme.getActiveTheme()
            if ti:
                try:
                    path_field = ti.getClass().getDeclaredField("pathToWallpaper")
                    path_field.setAccessible(True)
                    path = path_field.get(ti)
                    if path and os.path.exists(path):
                        ext = ".jpg" if path.endswith(".jpg") else ".png"
                        dst = os.path.join(out_dir, f"wall_{slug}{ext}")
                        shutil.copy2(path, dst)
                        return [dst]
                except Exception: pass
            raise RuntimeError(f"No wallpaper found for theme \"{_theme_display()}\".")
            
        width = drawable.getIntrinsicWidth()
        height = drawable.getIntrinsicHeight()
        
        if width <= 0 or height <= 0:
            sw, sh = _screen_dims()
            width, height = sw, sh
            
        bmp = Bitmap.createBitmap(width, height, Bitmap.Config.ARGB_8888)
        canvas = Canvas(bmp)
        drawable.setBounds(0, 0, width, height)
        drawable.draw(canvas)
        
        dst = os.path.join(out_dir, f"wall_{slug}.png")
        out_stream = FileOutputStream(dst)
        bmp.compress(Bitmap.CompressFormat.PNG, 100, out_stream)
        out_stream.flush()
        out_stream.close()
        
        return[dst]
        
    except Exception as e:
        raise RuntimeError(f"Failed to save wallpaper: {e}")

_WALL_DIR    = "/sdcard/Download/exteraGram"
_IMPORT_PATH = "/sdcard/Download/tt_import.json"

class ThemeTweakerPlugin(BasePlugin):

    def __init__(self):
        super().__init__()
        self._hook_refs =[]
        self._is_applying = False

    def on_plugin_load(self):
        self._hook_theme()
        self._hook_theme_activity()
        run_on_ui_thread(self._reapply_memory_only)

    def on_plugin_unload(self):
        for ref in self._hook_refs:
            try: self.unhook_method(ref)
            except Exception: pass
        self._hook_refs.clear()

    def create_settings(self):
        return[
            Header(text="Редактор темы"),
            Divider(text=f"Активная тема: {_theme_display()}"),
            Header(text="Действия"),
            Text(text="Открыть Color Editor", icon="msg_edit",
                 on_click=lambda v: run_on_ui_thread(self._open_editor)),
            Header(text="Данные"),
            Text(text="Экспорт переопределений", icon="msg_share",
                 on_click=lambda v: run_on_ui_thread(self._export)),
            Text(text="Импорт переопределений", icon="msg_download",
                 on_click=lambda v: run_on_ui_thread(self._import_data)),
            Text(text="Сохранить обои темы", icon="msg_picture",
                 on_click=lambda v: run_on_ui_thread(self._save_wall)),
            Text(text="Сбросить переопределения", icon="msg_delete", red=True,
                 on_click=lambda v: run_on_ui_thread(self._reset_confirm)),
        ]

    def _pk(self, k): return f"tt_{_theme_name()}_{k}"

    def _get_orig(self, k):
        backup_key = f"tt_backup_{_theme_name()}_{k}"
        raw = self.get_setting(backup_key, None)
        if raw is not None:
            c = _from_hex(str(raw))
            if c is not None: return c
        return _get_color(k)

    def _get_saved(self, k):
        raw = self.get_setting(self._pk(k), None)
        if raw is not None:
            c = _from_hex(str(raw))
            if c is not None: return c
        return _get_color(k)

    def _backup_and_set_color(self, key_name, new_color, orig_color):
        backup_key = f"tt_backup_{_theme_name()}_{key_name}"
        if self.get_setting(backup_key, None) is None:
            self.set_setting(backup_key, _to_hex(orig_color))
            
        self.set_setting(self._pk(key_name), _to_hex(new_color))
        _set_color(key_name, new_color, save=False)

    def _reapply_memory_only(self):
        try:
            for keys in THEME_KEYS.values():
                for kn, _ in keys:
                    raw = self.get_setting(self._pk(kn), None)
                    if raw is not None:
                        c = _from_hex(str(raw))
                        if c is not None:
                            _set_color(kn, c, save=False)
        except Exception: pass

    def _hook_theme(self):
        try:
            tc = find_class("org.telegram.ui.ActionBar.Theme")
            if not tc: return
            
            class ApplyThemeHook(dynamic_proxy(MethodHook)):
                def __init__(self, plugin):
                    self.plugin = plugin
                    super().__init__()
                def after_hooked_method(self, param):
                    if getattr(self.plugin, "_is_applying", False): return
                    self.plugin._is_applying = True
                    try:
                        self.plugin._reapply_memory_only()
                    finally:
                        self.plugin._is_applying = False
            
            hook_obj = ApplyThemeHook(self)
            
            for m in tc.getDeclaredMethods():
                name = str(m.getName())
                if name in ("applyTheme", "applyThemeFile", "loadCurrentTheme", "applyCurrentTheme", "checkAutoNightThemeConditions"):
                    try:
                        m.setAccessible(True)
                        ref = self.hook_method(m, hook_obj)
                        if ref:
                            self._hook_refs.append(ref)
                    except Exception: pass
        except Exception as e:
            self.log(f"Theme hook error: {e}")

    def _hook_theme_activity(self):
        try:
            theme_activity_class = find_class("org.telegram.ui.ThemeActivity")
            if not theme_activity_class: return
            
            pr = self
            class ThemeActivityCreateViewHook(dynamic_proxy(MethodHook)):
                def __init__(self):
                    super().__init__()
                def after_hooked_method(self, param):
                    try:
                        activity = param.thisObject
                        action_bar = getattr(activity, "actionBar", None)
                        if not action_bar:
                            try:
                                ab_field = activity.getClass().getSuperclass().getDeclaredField("actionBar")
                                ab_field.setAccessible(True)
                                action_bar = ab_field.get(activity)
                            except: pass
                            
                        if action_bar:
                            menu = action_bar.createMenu()
                            from org.telegram.messenger import R
                            try: icon = R.drawable.msg_theme
                            except:
                                try: icon = R.drawable.msg_colors
                                except: icon = R.drawable.msg_edit 
                            
                            item = menu.addItem(999, icon)
                            
                            def on_click(v):
                                run_on_ui_thread(pr._open_editor)
                                
                            clicker = OnClickListener(on_click)
                            item.setOnClickListener(clicker)
                            item._c = clicker
                    except Exception: pass
                        
            refs = self.hook_all_methods(theme_activity_class, "createView", ThemeActivityCreateViewHook())
            if refs:
                if isinstance(refs, list):
                    self._hook_refs.extend(refs)
                else:
                    self._hook_refs.append(refs)
        except Exception: pass

    def _open_editor(self):
        ctx = _get_activity()
        if ctx is None:
            _show_toast("Cannot get activity context"); return
        try:
            _show_cats(ctx, self)
        except Exception as e:
            import traceback
            err = traceback.format_exc()
            _show_toast(f"Ошибка открытия редактора: {e}")
            print(err)

    def _export(self):
        try:
            data = {}
            for keys in THEME_KEYS.values():
                for kn, _ in keys:
                    raw = self.get_setting(self._pk(kn), None)
                    if raw: data[kn] = raw
            if not data: BulletinHelper.show_info("No overrides to export"); return
            tn = _theme_name(); path = f"/sdcard/Download/tt_{tn}.json"
            os.makedirs(os.path.dirname(path), exist_ok=True)
            with open(path, "w", encoding="utf-8") as f:
                json.dump({"theme": tn, "colors": data}, f, indent=2, ensure_ascii=False)
            BulletinHelper.show_info(f"Exported {len(data)} colors\n{path}")
        except Exception as e: _show_toast(f"Export error: {e}")

    def _import_data(self):
        try:
            if not os.path.exists(_IMPORT_PATH):
                _show_toast(f"File not found:\n{_IMPORT_PATH}"); return
            with open(_IMPORT_PATH, "r", encoding="utf-8") as f: payload = json.load(f)
            cnt = 0
            for kn, hv in payload.get("colors", {}).items():
                c = _from_hex(str(hv))
                if c is not None: 
                    orig = self._get_orig(kn)
                    self._backup_and_set_color(kn, c, orig)
                    cnt += 1
            _notify_theme_changed()
            BulletinHelper.show_success(f"Imported {cnt} colors")
        except Exception as e: _show_toast(f"Import error: {e}")

    def _save_wall(self):
        try:
            saved = _save_wallpapers(_WALL_DIR)
            BulletinHelper.show_success(f"Saved {len(saved)} wallpaper(s)\n{_WALL_DIR}/")
        except Exception as e:
            _show_toast(str(e))

    def _reset_confirm(self):
        pr = self
        ctx = _get_activity()
        if ctx is None: return
        from org.telegram.ui.ActionBar import AlertDialog, Theme
        from android.util import TypedValue; from android.widget import TextView
        from org.telegram.messenger import AndroidUtilities
        dp = AndroidUtilities.dp
        
        builder = AlertDialog.Builder(ctx)
        builder.setTitle("Сбросить?")
        
        msg = TextView(ctx)
        msg.setText(f"Все переопределения плагина для темы \"{_theme_display()}\" будут удалены, а исходные цвета восстановлены.")
        msg.setTextColor(Theme.getColor(Theme.key_dialogTextGray3))
        msg.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14.)
        msg.setPadding(dp(24), dp(4), dp(24), dp(8))
        builder.setView(msg)
        
        def _do(d, w):
            for keys in THEME_KEYS.values():
                for kn, _ in keys:
                    self.set_setting(self._pk(kn), None)
                    self.set_setting(f"tt_backup_{_theme_name()}_{kn}", None)
            
            try:
                T = _T()
                ti = T.getActiveTheme()
                if ti is not None:
                    self._is_applying = True
                    T.applyTheme(ti, False)
                    self._is_applying = False
            except Exception: pass
            
            BulletinHelper.show_success("Тема сброшена к исходным цветам")
            d.dismiss()
            
        builder.setPositiveButton("Сбросить", _do)
        builder.setNegativeButton("Отмена", lambda d, w: d.dismiss())
        builder.show()