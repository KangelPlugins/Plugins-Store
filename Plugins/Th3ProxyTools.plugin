def _jlist_to_py(jl) -> list:
    out = []
    try:
        n = jl.size()
        for i in range(n):
            out.append(jl.get(i))
    except Exception as e:
        log(f"th3pt: jlist {e}")
    return out


def _post_proxy_check_done(info):
    try:
        NotificationCenter.getGlobalInstance().postNotificationName(
            NotificationCenter.proxyCheckDone, info
        )
    except Exception:
        pass


def _secret_to_bytes(secret) -> bytes:
    s = str(secret or "").strip()
    if not s:
        return b""
    try:
        if re.fullmatch(r"[0-9a-fA-F]+", s) and len(s) % 2 == 0:
            return bytes.fromhex(s)
    except Exception:
        pass
    try:
        t = s.replace("-", "+").replace("_", "/")
        t += "=" * (-len(t) % 4)
        return base64.b64decode(t)
    except Exception:
        pass
    return b""


# default badge emoji per badge_key (user-overridable via settings: badge_<key>)
BADGE_DEFAULTS = {
    "faketls_good": "🛡️",
    "faketls": "🔒",
    "secured": "➿",
    "plain": "⚠️",
    "socks": "🧦",
}


def _classify_proxy(info) -> dict:
    """Classify a ProxyInfo by obfuscation type (anti-DPI inspector). `badge_key` selects the
    (user-overridable) emoji; `badge` is the built-in default for that key."""
    b = _secret_to_bytes(getattr(info, "secret", ""))
    if not b:
        return {"type": "socks", "domain": "", "badge_key": "socks",
                "badge": BADGE_DEFAULTS["socks"], "score": 0, "label": "SOCKS5"}
    first = b[0]
    n = len(b)
    # a plain MTProto secret is exactly 16 raw bytes with NO type prefix — length must win
    # over a coincidental 0xEE/0xDD first byte (each ~1/256 of plain secrets), else a plain
    # proxy is mislabeled FakeTLS and survives the destructive "keep only FakeTLS" filter
    if n == 16:
        return {"type": "plain", "domain": "", "badge_key": "plain",
                "badge": BADGE_DEFAULTS["plain"], "score": 1, "label": "MTProto (plain)"}
    if first == 0xEE and n >= 17:
        dom = ""
        try:
            dom = b[17:].decode("utf-8", "replace").strip()
        except Exception:
            dom = ""
        good = bool(dom) and any(dom == d or dom.endswith("." + d) for d in _GOOD_FRONTS)
        if good:
            return {"type": "faketls", "domain": dom, "badge_key": "faketls_good",
                    "badge": BADGE_DEFAULTS["faketls_good"], "score": 4, "label": f"FakeTLS · {dom}"}
        return {"type": "faketls", "domain": dom, "badge_key": "faketls",
                "badge": BADGE_DEFAULTS["faketls"], "score": 3, "label": f"FakeTLS · {dom or '?'}"}
    if first == 0xDD and n == 17:
        return {"type": "secured", "domain": "", "badge_key": "secured",
                "badge": BADGE_DEFAULTS["secured"], "score": 2, "label": "MTProto (random-pad)"}
    return {"type": "plain", "domain": "", "badge_key": "plain",
            "badge": BADGE_DEFAULTS["plain"], "score": 1, "label": "MTProto (plain)"}


def _build_faketls_secret(key_bytes: bytes, domain: str) -> str:
    return "ee" + key_bytes.hex() + domain.encode("utf-8").hex()


# ═══════════════════════════════════════════════════════════════════
#   Real proxy checks in pure Python (stdlib only — Chaquopy-safe).
#   Bypasses Telegram's engine: actually performs the MTProto/FakeTLS/SOCKS
#   handshake to prove the proxy works. Verified vs gotd golden vector +
#   NIST AES KATs. Sources: gotd/td mtproxy/faketls, alexbers/mtprotoproxy,
#   Telethon/pyrogram obfuscated transport, core.telegram.org transports.
# ═══════════════════════════════════════════════════════════════════

