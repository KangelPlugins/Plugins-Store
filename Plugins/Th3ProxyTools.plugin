# ── action-bar menu item ids ──
MENU_PING_ALL_ID = 999_001
MENU_SORT_ID = 999_002
MENU_IMPORT_ID = 999_003
MENU_EXPORT_ID = 999_004
MENU_MANAGE_ID = 999_005

# ── ping modes ──
MODE_FAST = 0    # real MTProto/FakeTLS/SOCKS handshake in pure Python, high concurrency (default)
MODE_NATIVE = 1  # delegate to Telegram's own checkProxyList (thorough but slow, 4 at a time)

# ── ping tuning ──
NATIVE_CONCURRENCY = 4  # native checkProxy is hard-capped at PROXY_CONNECTIONS_COUNT=4
# native checkProxy owns its own ~5s/phase timeout and reliably calls back within ~10-15s;
# our watchdog is only a backstop for the rare never-returns case, so it must be GENEROUS —
# reaping early just marks slow-but-working MTProto proxies as dead (false negatives).
NATIVE_WATCHDOG_S = 30
# native mode polls stock's results; if no new proxy completes for this long, the rest are
# stuck in Telegram's native check queue (engine limitation) — finish instead of waiting it out
NATIVE_STALL_MS = 20000
TIMEOUTS = [3, 5, 8, 10, 15]            # fast mode only — native timeout is engine-owned
CONCURRENCY = [8, 16, 32, 48, 64]       # fast mode only — native is hard-capped at 4
GEO_TTL_DAYS = [1, 3, 7, 14, 30]

# ── ping colour buckets (ARGB) — tuned for MTProto handshake RTTs (higher than raw TCP) ──
COLOR_FAST = 0xFF4CAF50
COLOR_MID = 0xFFFF9800
COLOR_SLOW = 0xFFF44336
PING_FAST_MS = 500
PING_MID_MS = 1500

