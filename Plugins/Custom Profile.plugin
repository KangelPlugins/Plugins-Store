class _OnDrawHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin
        self._err = False

    def before_hooked_method(self, param):
        try:
            self.plugin.apply_before_draw(param)
        except Exception as e:
            if not self._err:
                self._err = True
                self.plugin.log(f"[cpb] before draw error: {e}")


class _BgPaintHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin
        self._err = False

    def after_hooked_method(self, param):
        try:
            self.plugin.apply_after_bg_paint(param)
        except Exception as e:
            if not self._err:
                self._err = True
                self.plugin.log(f"[cpb] bg paint error: {e}")


class _ActivityResultHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin

    def after_hooked_method(self, param):
        try:
            self.plugin.on_activity_result(param)
        except Exception as e:
            self.plugin.log(f"[cpb] activity result error: {e}")


class _ProfileMenuHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin
        self._err = False

    def after_hooked_method(self, param):
        try:
            self.plugin.add_profile_menu(param)
        except Exception as e:
            if not self._err:
                self._err = True
                self.plugin.log(f"[cpb] profile menu hook error: {e}")


class _AvatarDrawHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin
        self._err = False

    def before_hooked_method(self, param):
        try:
            self.plugin.avatar_draw_before(param)
        except Exception as e:
            if not self._err:
                self._err = True
                self.plugin.log(f"[cpb] avatar draw before error: {e}")

    def after_hooked_method(self, param):
        try:
            self.plugin.avatar_draw_after(param)
        except Exception as e:
            if not self._err:
                self._err = True
                self.plugin.log(f"[cpb] avatar draw after error: {e}")


class CustomProfileBannerPlugin(BasePlugin):
    def on_plugin_load(self):
        self._unhooks = []
        self._fields = {}
        self._av_layer = None
        self._cur_own = False
        self._ab_cls = None
        self._au_cls = None
        self._webview = None
        self._web_client = None
        self._dialog = None
        self._menu_pa_ids = set()
        self._menu_listeners = []
        self._settings_frag_cls = None
        self._app_ver = None

        self._bmp = None
        self._shader = None
        self._grad_shader = None
        self._grad_sig = None
        self._active_shader = None
        self._remote = {}
        self._remote_check = {}
        self._last_recheck_uid = 0
        self._filesdir = ""
        self._enabled = bool(self.get_setting(KEY_ENABLED, True))
        self._share_enabled = bool(self.get_setting(KEY_SHARE_ENABLED, False))
        self._show_emoji = bool(self.get_setting(KEY_EMOJI, True))
        self._avatar_shape = int(self.get_setting(KEY_AVATAR_SHAPE, 0))
        self._avatar_radius = int(self.get_setting(KEY_AVATAR_RADIUS, 18))
        self._avatar_round = int(self.get_setting(KEY_AVATAR_ROUND, 0))
        self._avatar_custom = self.get_setting(KEY_AVATAR_CUSTOM, "") or ""
        self._avatar_custom_pts = self._parse_custom_pts(self._avatar_custom)
        self._av_last_r = None
        self._banner_mode = int(self.get_setting(KEY_BANNER_MODE, 0))
        self._banner_color = self._color_setting(KEY_BANNER_COLOR, DEF_BANNER_COLOR)

        self._grad_type = int(self.get_setting(KEY_GRAD_TYPE, 0))
        self._grad_dir = int(self.get_setting(KEY_GRAD_DIR, 0))
        self._grad_angle = int(self.get_setting(KEY_GRAD_ANGLE, 0))
        self._grad_c1 = self._color_setting(KEY_GRAD_C1, DEF_GRAD_C1)
        self._grad_c2 = self._color_setting(KEY_GRAD_C2, DEF_GRAD_C2)
        self._grad_c3 = self._color_setting(KEY_GRAD_C3, DEF_GRAD_C3)
        self._grad_use3 = bool(self.get_setting(KEY_GRAD_USE3, False))
        self._grad_radius = int(self.get_setting(KEY_GRAD_RADIUS, 100))
        self._grad_count = int(self.get_setting(KEY_GRAD_COUNT, 3 if self._grad_use3 else 2))
        self._banner_alpha = int(self.get_setting(KEY_BANNER_ALPHA, 100))
        self._banner_fade = int(self.get_setting(KEY_BANNER_FADE, 0))
        self._banner_fade_angle = int(self.get_setting(KEY_BANNER_FADE_ANGLE, 0))
        self._banner_fade_radius = int(self.get_setting(KEY_BANNER_FADE_RADIUS, 100))
        self._bg_alpha = int(self.get_setting(KEY_BG_ALPHA, 100))
        self._bg_fade = int(self.get_setting(KEY_BG_FADE, 0))
        self._bg_fade_angle = int(self.get_setting(KEY_BG_FADE_ANGLE, 0))
        self._bg_fade_radius = int(self.get_setting(KEY_BG_FADE_RADIUS, 100))
        self._grad_cx = float(self.get_setting(KEY_GRAD_CX, 0.5))
        self._grad_cy = float(self.get_setting(KEY_GRAD_CY, 0.5))
        self._banner_fade_cx = float(self.get_setting(KEY_BANNER_FADE_CX, 0.5))
        self._banner_fade_cy = float(self.get_setting(KEY_BANNER_FADE_CY, 0.5))
        self._bg_fade_cx = float(self.get_setting(KEY_BG_FADE_CX, 0.5))
        self._bg_fade_cy = float(self.get_setting(KEY_BG_FADE_CY, 0.5))
        self._bmp_src = None
        self._banner_img_dirty = True

        self._bg_enabled = bool(self.get_setting(KEY_BG_ENABLED, False))
        self._bg_mode = int(self.get_setting(KEY_BG_MODE, 0))
        self._bg_color = self._color_setting(KEY_BG_COLOR, DEF_BG_COLOR)
        self._bg_bmp = None
        self._bg_drawable = None
        self._bg_dirty = True
        self._bg_applied = False
        self._snapshot = ""
        self._snap_ts = 0.0
        self._snap_busy = False
        self._snap_path = ""
        self._preview_fragment = None
        self._preview_view = None

        try:
            self._ab_cls = find_class(ACTION_BAR)
            self._au_cls = find_class(ANDROID_UTILS)
        except Exception as e:
            self.log(f"[cpb] static class lookup failed: {e}")

        # Sanitize any previously stored null values. The host copies plugin
        # settings into a ConcurrentHashMap when opening the settings screen,
        # and a null value there throws NullPointerException (crash). We never
        # store None, and we scrub any legacy null left by older builds.
        for _k in (KEY_BANNER_PATH, KEY_BG_PATH):
            try:
                if self.get_setting(_k, "") is None:
                    self.set_setting(_k, "")
            except Exception:
                pass

        banner_path = self.get_setting(KEY_BANNER_PATH, "")
        if banner_path:
            try:
                self._load_banner_bitmap(banner_path)
            except Exception as e:
                self.log(f"[cpb] load saved banner failed: {e}")

        bg_path = self.get_setting(KEY_BG_PATH, "")
        if bg_path:
            try:
                self._bg_bmp = self._decode_downsampled(bg_path)
            except Exception as e:
                self.log(f"[cpb] load saved bg failed: {e}")

        try:
            from org.telegram.messenger import ApplicationLoader
            _base = ApplicationLoader.applicationContext.getFilesDir().getAbsolutePath()
            self._snap_path = _base + "/cpb_profile_snap.jpg"
            if os.path.exists(self._snap_path):
                self._snapshot = self._file_to_data_uri(self._snap_path)
        except Exception as e:
            self.log(f"[cpb] snap load failed: {e}")

        try:
            top_cls = find_class(TOP_VIEW)
            if top_cls is None:
                self.log("[cpb] TopView class NOT found")
            else:
                u1 = self.hook_all_methods(top_cls, "onDraw", _OnDrawHook(self))
                if u1:
                    self._unhooks += list(u1)
                try:
                    u2 = self.hook_all_methods(top_cls, "updateBackgroundPaint", _BgPaintHook(self))
                    if u2:
                        self._unhooks += list(u2)
                except Exception as e:
                    self.log(f"[cpb] updateBackgroundPaint hook skipped: {e}")
        except Exception as e:
            self.log(f"[cpb] TopView hook failed: {e}")

        try:
            la_cls = find_class(LAUNCH_ACTIVITY)
            if la_cls is not None:
                u3 = self.hook_all_methods(la_cls, "onActivityResult", _ActivityResultHook(self))
                if u3:
                    self._unhooks += list(u3)
        except Exception as e:
            self.log(f"[cpb] onActivityResult hook failed: {e}")

        try:
            pa_cls = find_class("org.telegram.ui.ProfileActivity")
            if pa_cls is not None:
                u4 = self.hook_all_methods(pa_cls, "createView", _ProfileMenuHook(self))
                if u4:
                    self._unhooks += list(u4)
        except Exception as e:
            self.log(f"[cpb] ProfileActivity menu hook failed: {e}")

        try:
            av_cls = find_class("org.telegram.ui.ProfileActivity$AvatarImageView")
            if av_cls is None:
                self.log("[cpb] AvatarImageView class NOT found")
            else:
                u5 = self.hook_all_methods(av_cls, "onDraw", _AvatarDrawHook(self))
                u5l = list(u5) if u5 else []
                self._unhooks += u5l
                self.log(f"[cpb] AvatarImageView onDraw hooked n={len(u5l)}")
        except Exception as e:
            self.log(f"[cpb] AvatarImageView onDraw hook failed: {e}")

        self.log(f"[cpb] loaded mode={self._banner_mode} banner={'y' if self._bmp else 'n'} bg={self._bg_enabled}")

    # ================= reflection helpers =================
    def _field(self, obj, name):
        cls = obj.getClass()
        key = (cls, name)
        f = self._fields.get(key)
        if f is None:
            f = cls.getDeclaredField(name)
            f.setAccessible(True)
            self._fields[key] = f
        return f

    def _header_height(self, pa):
        extra = self._field(pa, "extraHeight").getFloat(pa)
        search = self._field(pa, "searchTransitionOffset").getInt(pa)
        ab_h = self._ab_cls.getCurrentActionBarHeight()
        sb_h = self._au_cls.statusBarHeight
        return float(ab_h) + float(sb_h) + float(extra) + float(search)

    def _update_bitmap_matrix(self, width, v10):
        if self._shader is None or self._bmp is None:
            return
        from android.graphics import Matrix
        if width <= 0:
            return
        if v10 <= 0:
            v10 = float(width)
        bw = float(self._bmp.getWidth())
        bh = float(self._bmp.getHeight())
        if bw <= 0 or bh <= 0:
            return
        sx = float(width) / bw
        sy = float(v10) / bh
        s = sx if sx > sy else sy
        m = Matrix()
        m.setScale(s, s)
        m.postTranslate((float(width) - bw * s) / 2.0, (float(v10) - bh * s) / 2.0)
        self._shader.setLocalMatrix(m)

    def _banner_sig(self):
        return (self._banner_mode, self._grad_type,
                int(getattr(self, "_grad_angle", 0)),
                int(getattr(self, "_grad_radius", 100)),
                int(getattr(self, "_grad_count", 2)),
                round(float(getattr(self, "_grad_cx", 0.5)), 3),
                round(float(getattr(self, "_grad_cy", 0.5)), 3),
                self._banner_color, self._grad_c1, self._grad_c2,
                self._grad_c3)

    def _build_unit_shader(self):
        from java import jint, jfloat, jarray
        from android.graphics import LinearGradient, RadialGradient, Shader
        import math
        tile = Shader.TileMode.CLAMP
        if self._banner_mode == 1:
            cols = jarray(jint)([self._banner_color, self._banner_color])
            pos = jarray(jfloat)([0.0, 1.0])
            return LinearGradient(0.0, 0.0, 1.0, 0.0, cols, pos, tile)
        count = int(getattr(self, "_grad_count", 2))
        color_list = [self._grad_c1, self._grad_c2]
        if count >= 3:
            color_list.append(self._grad_c3)
        cols = jarray(jint)(color_list)
        if len(color_list) == 3:
            pos = jarray(jfloat)([0.0, 0.5, 1.0])
        else:
            pos = jarray(jfloat)([0.0, 1.0])
        radius = int(getattr(self, "_grad_radius", 100))
        if radius < 20:
            radius = 20
        if radius > 200:
            radius = 200
        rfrac = radius / 100.0
        gt = self._grad_type
        if gt == 1:
            r = 0.5 * rfrac
            if r <= 0.0:
                r = 0.5
            cx = float(getattr(self, "_grad_cx", 0.5))
            cy = float(getattr(self, "_grad_cy", 0.5))
            return RadialGradient(cx, cy, r, cols, pos, tile)
        ang = float(int(getattr(self, "_grad_angle", 0)) % 360)
        rad = ang * math.pi / 180.0
        dx = math.sin(rad)
        dy = -math.cos(rad)
        hl = 0.5 * rfrac
        x0 = 0.5 - dx * hl
        y0 = 0.5 - dy * hl
        x1 = 0.5 + dx * hl
        y1 = 0.5 + dy * hl
        return LinearGradient(x0, y0, x1, y1, cols, pos, tile)

    def _ensure_banner_shader(self, width, v10):
        mode = self._banner_mode
        if mode == 0:
            if getattr(self, "_banner_img_dirty", False):
                self._rebuild_banner_bitmap()
            if self._bmp is None:
                return None
            if self._shader is None:
                from android.graphics import BitmapShader, Shader
                self._shader = BitmapShader(self._bmp, Shader.TileMode.CLAMP, Shader.TileMode.CLAMP)
            self._update_bitmap_matrix(width, v10)
            return self._shader
        sig = self._banner_sig()
        if self._grad_shader is None or self._grad_sig != sig:
            self._grad_shader = self._build_unit_shader()
            self._grad_sig = sig
        if self._grad_shader is not None:
            from android.graphics import Matrix
            w = float(width) if width and width > 0 else 1.0
            h = float(v10) if v10 and v10 > 0 else w
            m = Matrix()
            m.setScale(w, h)
            self._grad_shader.setLocalMatrix(m)
        return self._grad_shader

    # ================= draw hooks =================
    def _is_own_profile(self, pa):
        try:
            args = pa.getArguments()
            if args is None:
                return False
            viewed = int(args.getLong("user_id", 0))
            if viewed == 0:
                return False
            uc = find_class("org.telegram.messenger.UserConfig")
            try:
                acc = int(pa.getCurrentAccount())
            except Exception:
                acc = int(uc.selectedAccount)
            me = int(uc.getInstance(acc).getClientUserId())
            return viewed == me
        except Exception:
            return False

    def _viewed_uid(self, pa):
        try:
            args = pa.getArguments()
            if args is None:
                return 0
            return int(args.getLong("user_id", 0))
        except Exception:
            return 0

    def _files_dir(self):
        d = getattr(self, "_filesdir", "")
        if d:
            return d
        try:
            from org.telegram.messenger import ApplicationLoader
            d = ApplicationLoader.applicationContext.getFilesDir().getAbsolutePath()
            self._filesdir = d
            return d
        except Exception:
            return ""

    def _http_get_bytes(self, url):
        import urllib.request, urllib.error
        req = urllib.request.Request(url, method="GET")
        try:
            resp = urllib.request.urlopen(req, timeout=25)
            return resp.getcode(), resp.read()
        except urllib.error.HTTPError as he:
            return he.code, b""
        except Exception as e:
            self.log(f"[cpb] http get failed: {e}")
            return 0, b""

    def _build_unit_shader_cfg(self, cfg):
        from java import jint, jfloat, jarray
        from android.graphics import LinearGradient, RadialGradient, Shader
        import math
        tile = Shader.TileMode.CLAMP
        mode = int(cfg.get("banner_mode", 0))
        if mode == 1:
            col = self._parse_color(cfg.get("banner_color", "#FF3390EC"))
            if col is None:
                col = -16777216
            cols = jarray(jint)([col, col])
            pos = jarray(jfloat)([0.0, 1.0])
            return LinearGradient(0.0, 0.0, 1.0, 0.0, cols, pos, tile)
        count = int(cfg.get("grad_count", 2))
        def pc(key, dflt):
            c = self._parse_color(cfg.get(key, dflt))
            return c if c is not None else -16777216
        color_list = [pc("grad_c1", "#FF2B5876"), pc("grad_c2", "#FF4E4376")]
        if count >= 3:
            color_list.append(pc("grad_c3", "#FF8E2DE2"))
        cols = jarray(jint)(color_list)
        if len(color_list) == 3:
            pos = jarray(jfloat)([0.0, 0.5, 1.0])
        else:
            pos = jarray(jfloat)([0.0, 1.0])
        radius = int(cfg.get("grad_radius", 100))
        if radius < 20:
            radius = 20
        if radius > 200:
            radius = 200
        rfrac = radius / 100.0
        gt = int(cfg.get("grad_type", 0))
        if gt == 1:
            r = 0.5 * rfrac
            if r <= 0.0:
                r = 0.5
            cx = float(cfg.get("grad_cx", 0.5))
            cy = float(cfg.get("grad_cy", 0.5))
            return RadialGradient(cx, cy, r, cols, pos, tile)
        ang = float(int(cfg.get("grad_angle", 0)) % 360)
        rad = ang * math.pi / 180.0
        dx = math.sin(rad)
        dy = -math.cos(rad)
        hl = 0.5 * rfrac
        return LinearGradient(0.5 - dx * hl, 0.5 - dy * hl, 0.5 + dx * hl, 0.5 + dy * hl, cols, pos, tile)

    def _fetch_remote(self, uid, view):
        try:
            base = VPS_BASE
            code, raw = self._http_get_bytes(base + "/api/profile?uid=" + str(uid))
            if code == 404:
                self._remote[uid] = {"state": "empty"}
                self.log(f"[cpb] remote {uid}: empty")
                return
            if code != 200:
                self._remote[uid] = {"state": "error"}
                self.log(f"[cpb] remote {uid}: profile http {code}")
                return
            cfg = json.loads(raw.decode("utf-8", "replace"))
            bg_col = self._parse_color(cfg.get("bg_color", "#FF000000"))
            entry = {
                "state": "ready",
                "cfg": cfg,
                "ts": int(cfg.get("ts", 0)),
                "enabled": bool(cfg.get("banner_enabled", True)),
                "show_emoji": bool(cfg.get("show_emoji", True)),
                "mode": int(cfg.get("banner_mode", 0)),
                "bmp": None,
                "shader": None,
                "grad_shader": None,
                "bg_enabled": bool(cfg.get("bg_enabled", False)),
                "bg_mode": int(cfg.get("bg_mode", 0)),
                "bg_color": bg_col if bg_col is not None else -16777216,
                "bg_bmp": None,
                "bg_drawable": None,
            }
            fd = self._files_dir()
            if entry["enabled"]:
                if entry["mode"] == 0:
                    icode, ibytes = self._http_get_bytes(base + "/api/image?uid=" + str(uid))
                    if icode == 200 and ibytes and fd:
                        path = fd + "/cpb_remote_" + str(uid) + ".img"
                        try:
                            with open(path, "wb") as f:
                                f.write(ibytes)
                            src = self._decode_downsampled(path)
                            proc = self._process_bitmap(
                                src,
                                int(cfg.get("banner_alpha", 100)),
                                int(cfg.get("banner_fade", 0)),
                                int(cfg.get("banner_fade_angle", 0)),
                                int(cfg.get("banner_fade_radius", 100)),
                                float(cfg.get("banner_fade_cx", 0.5)),
                                float(cfg.get("banner_fade_cy", 0.5)),
                            )
                            from android.graphics import BitmapShader, Shader
                            entry["bmp"] = proc
                            entry["shader"] = BitmapShader(proc, Shader.TileMode.CLAMP, Shader.TileMode.CLAMP)
                        except Exception as e:
                            self.log(f"[cpb] remote {uid}: banner decode failed: {e}")
                    else:
                        self.log(f"[cpb] remote {uid}: banner image http {icode}")
                else:
                    try:
                        entry["grad_shader"] = self._build_unit_shader_cfg(cfg)
                    except Exception as e:
                        self.log(f"[cpb] remote {uid}: grad build failed: {e}")
            if entry["bg_enabled"] and entry["bg_mode"] == 1:
                bcode, bbytes = self._http_get_bytes(base + "/api/image?uid=" + str(uid) + "&kind=bg")
                if bcode == 200 and bbytes and fd:
                    bpath = fd + "/cpb_remote_bg_" + str(uid) + ".img"
                    try:
                        with open(bpath, "wb") as f:
                            f.write(bbytes)
                        entry["bg_bmp"] = self._decode_downsampled(bpath)
                    except Exception as e:
                        self.log(f"[cpb] remote {uid}: bg decode failed: {e}")
                        entry["bg_enabled"] = False
                else:
                    self.log(f"[cpb] remote {uid}: bg image http {bcode}")
                    entry["bg_enabled"] = False
            has_banner = bool(entry["enabled"] and (entry["shader"] is not None or entry["grad_shader"] is not None))
            has_bg = bool(entry["bg_enabled"] and (entry["bg_mode"] == 0 or entry["bg_bmp"] is not None))
            if not has_banner and not has_bg:
                entry["state"] = "empty"
            self._remote[uid] = entry
            self.log(f"[cpb] remote {uid}: ready banner={has_banner} bg={has_bg}")
            self._invalidate_view_later(view)
        except Exception as e:
            self._remote[uid] = {"state": "error"}
            self.log(f"[cpb] remote {uid}: fetch failed: {e}")

    def _maybe_recheck_remote(self, uid, view):
        try:
            import time as _t
            now = _t.monotonic()
            if not hasattr(self, "_remote_check") or self._remote_check is None:
                self._remote_check = {}
            changed_view = (uid != getattr(self, "_last_recheck_uid", 0))
            self._last_recheck_uid = uid
            last = self._remote_check.get(uid, 0.0)
            if (not changed_view) and (now - last < 6.0):
                return
            self._remote_check[uid] = now
            import threading
            threading.Thread(target=lambda: self._recheck_remote(uid, view), daemon=True).start()
        except Exception:
            pass

    def _recheck_remote(self, uid, view):
        try:
            base = VPS_BASE
            code, raw = self._http_get_bytes(base + "/api/profile?uid=" + str(uid))
            cur = self._remote.get(uid) or {}
            old_ts = int(cur.get("ts", -1))
            if code == 404:
                if cur.get("state") != "empty" or old_ts != -1:
                    self._remote[uid] = {"state": "empty", "ts": -1}
                    self.log(f"[cpb] remote {uid}: became empty")
                    self._invalidate_view_later(view)
                return
            if code != 200:
                return
            cfg = json.loads(raw.decode("utf-8", "replace"))
            new_ts = int(cfg.get("ts", 0))
            if new_ts != old_ts:
                self.log(f"[cpb] remote {uid}: changed ts {old_ts}->{new_ts}, refetching")
                self._fetch_remote(uid, view)
        except Exception as e:
            self.log(f"[cpb] remote {uid}: recheck failed: {e}")

    def _start_remote_fetch(self, uid, view):
        try:
            import threading
            threading.Thread(target=lambda: self._fetch_remote(uid, view), daemon=True).start()
            self.log(f"[cpb] remote {uid}: fetching")
        except Exception as e:
            self.log(f"[cpb] remote fetch thread failed: {e}")

    def _invalidate_view_later(self, view):
        try:
            if view is None:
                return
            run_on_ui_thread(lambda: self._safe_invalidate(view))
        except Exception:
            pass

    def _safe_invalidate(self, view):
        try:
            view.invalidate()
        except Exception:
            pass

    def _remote_shader(self, entry, width, v10):
        mode = int(entry.get("mode", 0))
        if mode == 0:
            bmp = entry.get("bmp")
            sh = entry.get("shader")
            if bmp is None or sh is None:
                return None
            from android.graphics import Matrix
            if width <= 0:
                return sh
            vv = v10 if v10 and v10 > 0 else float(width)
            bw = float(bmp.getWidth())
            bh = float(bmp.getHeight())
            if bw <= 0 or bh <= 0:
                return sh
            sx = float(width) / bw
            sy = float(vv) / bh
            s = sx if sx > sy else sy
            m = Matrix()
            m.setScale(s, s)
            m.postTranslate((float(width) - bw * s) / 2.0, (float(vv) - bh * s) / 2.0)
            sh.setLocalMatrix(m)
            return sh
        sh = entry.get("grad_shader")
        if sh is None:
            return None
        from android.graphics import Matrix
        w = float(width) if width and width > 0 else 1.0
        h = float(v10) if v10 and v10 > 0 else w
        m = Matrix()
        m.setScale(w, h)
        sh.setLocalMatrix(m)
        return sh

    def _build_bg_drawable_cfg(self, context_view, entry):
        from java import jint
        from android.graphics.drawable import ColorDrawable, BitmapDrawable
        cfg = entry.get("cfg", {})
        mode = int(entry.get("bg_mode", 0))
        if mode == 1:
            base_bmp = entry.get("bg_bmp")
            if base_bmp is None:
                return None
            bmp = base_bmp
            try:
                tw = int(context_view.getWidth())
                th = int(context_view.getHeight())
            except Exception:
                tw = th = 0
            if tw <= 0 or th <= 0:
                return None
            try:
                cropped = self._center_crop_bitmap(base_bmp, tw, th)
                if cropped is not None:
                    bmp = cropped
            except Exception as e:
                self.log(f"[cpb] remote bg crop failed: {e}")
            try:
                bmp = self._process_bitmap(
                    bmp,
                    int(cfg.get("bg_alpha", 100)),
                    int(cfg.get("bg_fade", 0)),
                    int(cfg.get("bg_fade_angle", 0)),
                    int(cfg.get("bg_fade_radius", 100)),
                    float(cfg.get("bg_fade_cx", 0.5)),
                    float(cfg.get("bg_fade_cy", 0.5)),
                )
            except Exception as e:
                self.log(f"[cpb] remote bg process failed: {e}")
            return BitmapDrawable(context_view.getResources(), bmp)
        col = entry.get("bg_color")
        if col is None:
            col = -16777216
        return ColorDrawable(jint(col))

    def _apply_remote_background(self, pa, entry):
        if not entry.get("bg_enabled"):
            return
        list_view = self._field(pa, "listView").get(pa)
        if list_view is None:
            return
        mode = int(entry.get("bg_mode", 0))
        if mode == 1 and entry.get("bg_bmp") is None:
            return
        try:
            cwh = (int(list_view.getWidth()), int(list_view.getHeight()))
        except Exception:
            cwh = (0, 0)
        if mode == 1 and (cwh[0] <= 0 or cwh[1] <= 0):
            return
        d = entry.get("bg_drawable")
        if d is None or (mode == 1 and cwh != entry.get("bg_crop_wh")):
            d = self._build_bg_drawable_cfg(list_view, entry)
            if d is None:
                return
            entry["bg_drawable"] = d
            if mode == 1:
                entry["bg_crop_wh"] = cwh
            list_view.setBackground(d)
            return
        cur = list_view.getBackground()
        if cur is None or not cur.equals(d):
            list_view.setBackground(d)

    def _field_super(self, obj, name):
        cls = obj.getClass()
        key = (cls, name)
        f = self._fields.get(key)
        if f is not None:
            return f
        c = cls
        while c is not None:
            try:
                f = c.getDeclaredField(name)
                f.setAccessible(True)
                self._fields[key] = f
                return f
            except Exception:
                try:
                    c = c.getSuperclass()
                except Exception:
                    c = None
        raise Exception("field not found: " + name)

    def _av_write_radius(self, ir, r):
        f = None
        try:
            f = self._field_super(ir, "roundRadius")
        except Exception:
            f = None
        if f is not None:
            try:
                cur = f.get(ir)
                try:
                    ln = len(cur)
                except Exception:
                    ln = -1
                if ln >= 0:
                    for i in range(ln):
                        cur[i] = r
                    return True
                f.setInt(ir, int(r))
                return True
            except Exception as e:
                if not getattr(self, "_avatar_err3", False):
                    self._avatar_err3 = True
                    self.log(f"[cpb] avatar roundRadius field error: {e}")
        try:
            ir.setRoundRadius(r)
        except Exception as e:
            if not getattr(self, "_avatar_err2", False):
                self._avatar_err2 = True
                self.log(f"[cpb] avatar setRoundRadius error: {e}")
        return False

    def _apply_avatar_shape(self, pa):
        av = None
        try:
            av = self._field(pa, "avatarImage").get(pa)
        except Exception as e:
            if not getattr(self, "_avatar_err", False):
                self._avatar_err = True
                self.log(f"[cpb] avatar field error: {e}")
            return
        if av is None:
            return
        from org.telegram.messenger import AndroidUtilities
        shape = int(getattr(self, "_avatar_shape", 0))
        if shape == 2 or shape >= 3:
            r = 0
        elif shape == 1:
            rad = max(0, min(64, int(getattr(self, "_avatar_radius", 18))))
            r = int(AndroidUtilities.dp(float(rad)))
        else:
            r = int(AndroidUtilities.dp(200.0))
        try:
            ir = av.getImageReceiver()
        except Exception:
            ir = None
        if ir is None:
            return
        self._av_write_radius(ir, r)
        try:
            pe = self._field_super(av, "progressToExpand")
            expand = float(pe.getFloat(av))
        except Exception:
            expand = 0.0
        if expand <= 0.01:
            try:
                fe = self._field_super(av, "roundRadiusExpand")
                if int(fe.getInt(av)) != int(r):
                    fe.setInt(av, int(r))
                    try:
                        av.invalidate()
                    except Exception:
                        pass
            except Exception as e:
                if not getattr(self, "_avatar_err4", False):
                    self._avatar_err4 = True
                    self.log(f"[cpb] roundRadiusExpand error: {e}")
        if getattr(self, "_av_last_r", None) != r:
            self._av_last_r = r
            try:
                av.invalidate()
            except Exception:
                pass

    def _parse_custom_pts(self, s):
        try:
            import json as _json
            arr = _json.loads(s) if s else []
        except Exception:
            return []
        out = []
        for it in arr:
            try:
                x = float(it[0])
                y = float(it[1])
                x = 0.0 if x < 0.0 else (1.0 if x > 1.0 else x)
                y = 0.0 if y < 0.0 else (1.0 if y > 1.0 else y)
                out.append((x, y))
            except Exception:
                pass
        return out

    def _build_shape_path(self, shape, w, h):
        import math
        from android.graphics import Path
        p = Path()
        cx = w / 2.0
        cy = h / 2.0
        R = (w if w < h else h) / 2.0

        def poly(n, rot):
            for i in range(n):
                a = rot + 2.0 * math.pi * i / n
                x = cx + R * math.cos(a)
                y = cy + R * math.sin(a)
                if i == 0:
                    p.moveTo(float(x), float(y))
                else:
                    p.lineTo(float(x), float(y))
            p.close()

        if shape == 3:
            poly(6, -math.pi / 2.0)
        elif shape == 4:
            poly(5, -math.pi / 2.0)
        elif shape == 5:
            n = 5
            inner = R * 0.42
            for i in range(2 * n):
                rad = R if (i % 2 == 0) else inner
                a = -math.pi / 2.0 + math.pi * i / n
                x = cx + rad * math.cos(a)
                y = cy + rad * math.sin(a)
                if i == 0:
                    p.moveTo(float(x), float(y))
                else:
                    p.lineTo(float(x), float(y))
            p.close()
        elif shape == 6:
            steps = 72
            raw = []
            for i in range(steps + 1):
                t = 2.0 * math.pi * i / steps
                hx = 16.0 * (math.sin(t) ** 3)
                hy = (13.0 * math.cos(t) - 5.0 * math.cos(2.0 * t)
                      - 2.0 * math.cos(3.0 * t) - math.cos(4.0 * t))
                raw.append((hx, hy))
            mx = max(abs(a) for a, b in raw)
            my = max(abs(b) for a, b in raw)
            sc = R / (mx if mx > my else my)
            for i, (hx, hy) in enumerate(raw):
                x = cx + hx * sc
                y = cy - hy * sc
                if i == 0:
                    p.moveTo(float(x), float(y))
                else:
                    p.lineTo(float(x), float(y))
            p.close()
        elif shape == 7:
            n = 8
            inner = R * 0.80
            a0 = -math.pi / 2.0
            sx = cx + inner * math.cos(a0)
            sy = cy + inner * math.sin(a0)
            p.moveTo(float(sx), float(sy))
            for i in range(n):
                amid = a0 + 2.0 * math.pi * (i + 0.5) / n
                anext = a0 + 2.0 * math.pi * (i + 1) / n
                bx = cx + R * math.cos(amid)
                by = cy + R * math.sin(amid)
                nx = cx + inner * math.cos(anext)
                ny = cy + inner * math.sin(anext)
                p.quadTo(float(bx), float(by), float(nx), float(ny))
            p.close()
        elif shape == 8:
            pts = getattr(self, "_cur_custom_pts", None) or []
            if len(pts) >= 3:
                for i, (nx, ny) in enumerate(pts):
                    x = nx * w
                    y = ny * h
                    if i == 0:
                        p.moveTo(float(x), float(y))
                    else:
                        p.lineTo(float(x), float(y))
                p.close()
            else:
                p.addCircle(float(cx), float(cy), float(R), Path.Direction.CW)
        else:
            p.addCircle(float(cx), float(cy), float(R), Path.Direction.CW)
        rr = int(getattr(self, "_cur_round", getattr(self, "_avatar_round", 0)))
        if rr > 0 and shape != 0:
            try:
                from android.graphics import Paint as _Paint, CornerPathEffect, Path as _Path2
                eff = CornerPathEffect(float(rr) / 100.0 * R)
                _pt = _Paint()
                _pt.setPathEffect(eff)
                out = _Path2()
                if _pt.getFillPath(p, out):
                    return out
            except Exception as e:
                if not getattr(self, "_avround_err", False):
                    self._avround_err = True
                    self.log(f"[cpb] corner round error: {e}")
        return p

    def avatar_draw_before(self, param):
        if not getattr(self, "_avdbg1", False):
            self._avdbg1 = True
            try:
                self.log("[cpb] avdraw before fired own=%s shape=%s" % (getattr(self, "_cur_own", None), getattr(self, "_avatar_shape", 0)))
            except Exception:
                pass
        shape = int(getattr(self, "_cur_shape", 0))
        if shape < 3:
            return
        view = param.thisObject
        try:
            pe = self._field_super(view, "progressToExpand")
            if float(pe.getFloat(view)) > 0.01:
                return
        except Exception:
            pass
        w = int(view.getWidth())
        h = int(view.getHeight())
        if w <= 0 or h <= 0:
            return
        canvas = param.args[0]
        try:
            path = self._build_shape_path(shape, w, h)
        except Exception as e:
            self._av_layer = None
            if not getattr(self, "_avpath_err", False):
                self._avpath_err = True
                self.log(f"[cpb] avatar path build error: {e}")
            return
        try:
            sc = canvas.save()
            canvas.clipPath(path)
            self._av_layer = ("clip", sc, None)
            if not getattr(self, "_avdbg3", False):
                self._avdbg3 = True
                self.log("[cpb] avdraw mode=clip w=%d h=%d" % (w, h))
        except Exception as e2:
            self._av_layer = None
            if not getattr(self, "_avclip_err", False):
                self._avclip_err = True
                self.log(f"[cpb] avatar clipPath failed: {e2}")

    def avatar_draw_after(self, param):
        lay = getattr(self, "_av_layer", None)
        if not lay:
            return
        self._av_layer = None
        mode = lay[0]
        canvas = param.args[0]
        if mode == "layer":
            rc = lay[1]
            path = lay[2]
            try:
                from android.graphics import Paint
                from java import jclass
                PDX = jclass("android.graphics.PorterDuffXfermode")
                PDM = jclass("android.graphics.PorterDuff$Mode")
                paint = Paint(Paint.ANTI_ALIAS_FLAG)
                paint.setXfermode(PDX(PDM.DST_IN))
                canvas.drawPath(path, paint)
            except Exception as e:
                if not getattr(self, "_avmask_err", False):
                    self._avmask_err = True
                    self.log(f"[cpb] avatar mask draw error: {e}")
            finally:
                try:
                    canvas.restoreToCount(rc)
                except Exception:
                    pass
        else:
            try:
                canvas.restoreToCount(lay[1])
            except Exception:
                pass

    def apply_before_draw(self, param):
        top_view = param.thisObject
        pa = self._field(top_view, "this$0").get(top_view)
        own = self._is_own_profile(pa)
        self._cur_own = own
        self._cur_shape = 0
        self._cur_round = 0
        self._cur_custom_pts = []
        if own:
            self._cur_shape = int(getattr(self, "_avatar_shape", 0))
            self._cur_round = int(getattr(self, "_avatar_round", 0))
            self._cur_custom_pts = getattr(self, "_avatar_custom_pts", None) or []
        else:
            try:
                _uid = self._viewed_uid(pa)
                _ent = self._remote.get(_uid) if _uid and _uid > 0 else None
                if _ent and _ent.get("state") == "ready":
                    _rc = _ent.get("cfg") or {}
                    self._cur_shape = int(_rc.get("avatar_shape", 0))
                    self._cur_round = int(_rc.get("avatar_round", 0))
                    self._cur_custom_pts = self._parse_custom_pts(_rc.get("avatar_custom", ""))
            except Exception:
                pass
        if own:
            try:
                self._apply_avatar_shape(pa)
            except Exception:
                pass

        paint = self._field(top_view, "paint").get(top_view)
        shader = None
        if own and self._enabled:
            width = top_view.getMeasuredWidth()
            v10 = self._header_height(pa)
            if v10 <= 0:
                v10 = float(width)
            try:
                shader = self._ensure_banner_shader(width, v10)
            except Exception as e:
                if not getattr(self, "_shader_err", False):
                    self._shader_err = True
                    self.log(f"[cpb] shader build error: {e}")
                shader = None
        elif not own:
            try:
                uid = self._viewed_uid(pa)
                if uid > 0:
                    entry = self._remote.get(uid)
                    if entry is not None and entry.get("state") != "loading":
                        self._maybe_recheck_remote(uid, top_view)
                    if entry is None:
                        self._remote[uid] = {"state": "loading"}
                        self._start_remote_fetch(uid, top_view)
                    elif entry.get("state") == "ready":
                        width = top_view.getMeasuredWidth()
                        v10 = self._header_height(pa)
                        if v10 <= 0:
                            v10 = float(width)
                        shader = self._remote_shader(entry, width, v10)
            except Exception as e:
                if not getattr(self, "_remote_err", False):
                    self._remote_err = True
                    self.log(f"[cpb] remote draw error: {e}")
                shader = None
        if shader is not None:
            paint.setShader(shader)
            self._active_shader = shader
        else:
            paint.setShader(None)
            self._active_shader = None

        if own:
            if not self._show_emoji:
                try:
                    self._field(top_view, "hasEmoji").setBoolean(top_view, False)
                except Exception:
                    pass
        else:
            try:
                e = self._remote.get(self._viewed_uid(pa))
                if e and e.get("state") == "ready" and not e.get("show_emoji", True):
                    self._field(top_view, "hasEmoji").setBoolean(top_view, False)
            except Exception:
                pass

        if own:
            try:
                self._apply_profile_background(pa)
            except Exception:
                pass
        else:
            try:
                e2 = self._remote.get(self._viewed_uid(pa))
                if e2 and e2.get("state") == "ready" and e2.get("bg_enabled"):
                    self._apply_remote_background(pa, e2)
            except Exception:
                pass

    def apply_after_bg_paint(self, param):
        shader = self._active_shader
        if shader is None:
            return
        top_view = param.thisObject
        bg = self._field(top_view, "backgroundPaint").get(top_view)
        bg.setShader(shader)

    def _apply_profile_background(self, pa):
        list_view = self._field(pa, "listView").get(pa)
        if list_view is None:
            return
        if not self._bg_enabled:
            if self._bg_applied:
                try:
                    theme = find_class(THEME)
                    col = pa.getThemedColor(theme.key_windowBackgroundGray)
                    list_view.setBackgroundColor(col)
                except Exception:
                    pass
                self._bg_applied = False
                self._bg_drawable = None
                self._bg_dirty = True
            return
        if self._bg_mode == 1:
            try:
                cwh = (int(list_view.getWidth()), int(list_view.getHeight()))
                if cwh[0] > 0 and cwh[1] > 0 and cwh != getattr(self, "_bg_crop_wh", None):
                    self._bg_dirty = True
            except Exception:
                pass
        if self._bg_dirty or self._bg_drawable is None:
            d = self._build_bg_drawable(list_view)
            if d is None:
                return
            self._bg_drawable = d
            self._bg_dirty = False
            list_view.setBackground(d)
            self._bg_applied = True
            return
        cur = list_view.getBackground()
        if cur is None or not cur.equals(self._bg_drawable):
            list_view.setBackground(self._bg_drawable)
            self._bg_applied = True

    def _build_bg_drawable(self, context_view):
        from java import jint
        from android.graphics.drawable import ColorDrawable, BitmapDrawable
        if self._bg_mode == 1:
            if self._bg_bmp is None:
                return None
            bmp = self._bg_bmp
            try:
                tw = int(context_view.getWidth())
                th = int(context_view.getHeight())
            except Exception:
                tw = th = 0
            if tw <= 0 or th <= 0:
                return None
            try:
                cropped = self._center_crop_bitmap(self._bg_bmp, tw, th)
                if cropped is not None:
                    bmp = cropped
            except Exception as e:
                self.log(f"[cpb] bg crop failed: {e}")
            self._bg_crop_wh = (tw, th)
            try:
                bmp = self._process_bitmap(
                    bmp,
                    int(getattr(self, "_bg_alpha", 100)),
                    int(getattr(self, "_bg_fade", 0)),
                    int(getattr(self, "_bg_fade_angle", 0)),
                    int(getattr(self, "_bg_fade_radius", 100)),
                    float(getattr(self, "_bg_fade_cx", 0.5)),
                    float(getattr(self, "_bg_fade_cy", 0.5)),
                )
            except Exception as e:
                self.log(f"[cpb] bg process failed: {e}")
            return BitmapDrawable(context_view.getResources(), bmp)
        return ColorDrawable(jint(self._bg_color))

    def _center_crop_bitmap(self, bmp, tw, th):
        from android.graphics import Bitmap, Canvas, Matrix, Paint
        bw = float(bmp.getWidth())
        bh = float(bmp.getHeight())
        if bw <= 0 or bh <= 0:
            return None
        sx = float(tw) / bw
        sy = float(th) / bh
        s = sx if sx > sy else sy
        out = Bitmap.createBitmap(int(tw), int(th), Bitmap.Config.ARGB_8888)
        c = Canvas(out)
        m = Matrix()
        m.setScale(s, s)
        m.postTranslate((float(tw) - bw * s) / 2.0, (float(th) - bh * s) / 2.0)
        p = Paint()
        try:
            p.setFilterBitmap(True)
        except Exception:
            pass
        c.drawBitmap(bmp, m, p)
        return out

    # ================= image loading =================
    def _decode_downsampled(self, path):
        from android.graphics import BitmapFactory
        bounds = BitmapFactory.Options()
        bounds.inJustDecodeBounds = True
        BitmapFactory.decodeFile(path, bounds)
        w = bounds.outWidth
        h = bounds.outHeight
        if w <= 0 or h <= 0:
            raise ValueError("could not decode image bounds")
        sample = 1
        while (w // sample) > MAX_DIM or (h // sample) > MAX_DIM:
            sample *= 2
        opts = BitmapFactory.Options()
        opts.inSampleSize = sample
        bmp = BitmapFactory.decodeFile(path, opts)
        if bmp is None:
            raise ValueError("decodeFile returned None")
        return bmp

    def _load_banner_bitmap(self, path):
        bmp = self._decode_downsampled(path)
        self._bmp_src = bmp
        self._banner_img_dirty = True
        self._rebuild_banner_bitmap()

    def _rebuild_banner_bitmap(self):
        from android.graphics import BitmapShader, Shader
        srcbmp = getattr(self, "_bmp_src", None)
        if srcbmp is None:
            self._bmp = None
            self._shader = None
            self._banner_img_dirty = False
            return
        try:
            proc = self._process_bitmap(
                srcbmp,
                int(getattr(self, "_banner_alpha", 100)),
                int(getattr(self, "_banner_fade", 0)),
                int(getattr(self, "_banner_fade_angle", 0)),
                int(getattr(self, "_banner_fade_radius", 100)),
                float(getattr(self, "_banner_fade_cx", 0.5)),
                float(getattr(self, "_banner_fade_cy", 0.5)),
            )
        except Exception as e:
            self.log(f"[cpb] banner process failed: {e}")
            proc = srcbmp
        self._bmp = proc
        self._shader = BitmapShader(proc, Shader.TileMode.CLAMP, Shader.TileMode.CLAMP)
        self._banner_img_dirty = False

    def _process_bitmap(self, srcbmp, alpha, fade, angle, radius, cx=0.5, cy=0.5):
        from java import jint, jfloat, jarray
        from android.graphics import (Bitmap, Canvas, Paint, LinearGradient,
                                       RadialGradient, Shader, PorterDuff,
                                       PorterDuffXfermode)
        import math
        if alpha >= 100 and fade == 0:
            return srcbmp
        w = int(srcbmp.getWidth())
        h = int(srcbmp.getHeight())
        if w <= 0 or h <= 0:
            return srcbmp
        out = Bitmap.createBitmap(w, h, Bitmap.Config.ARGB_8888)
        c = Canvas(out)
        p = Paint()
        try:
            p.setFilterBitmap(True)
        except Exception:
            pass
        av = int(max(0, min(100, alpha)) * 255 / 100)
        p.setAlpha(av)
        c.drawBitmap(srcbmp, 0.0, 0.0, p)
        if fade != 0:
            rr = max(20, min(200, radius)) / 100.0
            cols = jarray(jint)([-1, 0x00FFFFFF])
            pos = jarray(jfloat)([0.0, 1.0])
            tile = Shader.TileMode.CLAMP
            if fade == 2:
                big = w if w > h else h
                r = 0.5 * rr * big
                if r <= 0.0:
                    r = float(big)
                sh = RadialGradient(w * cx, h * cy, r, cols, pos, tile)
            else:
                ang = float(int(angle) % 360)
                rad = ang * math.pi / 180.0
                dx = math.sin(rad)
                dy = -math.cos(rad)
                hl = 0.5 * rr
                x0 = (0.5 - dx * hl) * w
                y0 = (0.5 - dy * hl) * h
                x1 = (0.5 + dx * hl) * w
                y1 = (0.5 + dy * hl) * h
                sh = LinearGradient(x0, y0, x1, y1, cols, pos, tile)
            mp = Paint()
            mp.setShader(sh)
            mp.setXfermode(PorterDuffXfermode(PorterDuff.Mode.DST_IN))
            c.drawRect(0.0, 0.0, float(w), float(h), mp)
        return out

    def _get_activity(self):
        frag = get_last_fragment()
        if frag is None:
            return None
        return frag.getParentActivity()

    def _start_pick(self, request_code, title):
        from android.content import Intent
        activity = self._get_activity()
        if activity is None:
            return
        intent = Intent(Intent.ACTION_GET_CONTENT)
        intent.setType("image/*")
        intent.addCategory(Intent.CATEGORY_OPENABLE)
        activity.startActivityForResult(Intent.createChooser(intent, title), request_code)

    def on_activity_result(self, param):
        code = int(param.args[0])
        result = int(param.args[1])
        data = param.args[2]
        if code not in (PICK_BANNER_CODE, PICK_BG_CODE):
            return
        if result != -1 or data is None:
            return
        uri = data.getData()
        if uri is None:
            return
        activity = param.thisObject
        if code == PICK_BANNER_CODE:
            dest = self._copy_uri_to_file(activity, uri, "custom_profile_banner.img")
            if not dest:
                return
            try:
                self._load_banner_bitmap(dest)
                self.set_setting(KEY_BANNER_PATH, dest)
                self._push_image("banner")
            except Exception as e:
                self.log(f"[cpb] banner decode failed: {e}")
        else:
            dest = self._copy_uri_to_file(activity, uri, "custom_profile_bg.img")
            if not dest:
                return
            try:
                self._bg_bmp = self._decode_downsampled(dest)
                self.set_setting(KEY_BG_PATH, dest)
                self._bg_dirty = True
                self._push_image("bg")
            except Exception as e:
                self.log(f"[cpb] bg decode failed: {e}")

    def _copy_uri_to_file(self, context, uri, name):
        from java import jbyte, jarray
        from java.io import FileOutputStream
        try:
            resolver = context.getContentResolver()
            istream = resolver.openInputStream(uri)
            if istream is None:
                return None
            dest = context.getFilesDir().getAbsolutePath() + "/" + name
            fos = FileOutputStream(dest)
            buf = jarray(jbyte)(8192)
            while True:
                n = istream.read(buf)
                if n is None or n <= 0:
                    break
                fos.write(buf, 0, n)
            fos.flush()
            fos.close()
            istream.close()
            return dest
        except Exception as e:
            self.log(f"[cpb] copy uri failed: {e}")
            return None

    def _toast(self, text):
        def _show():
            try:
                if BulletinHelper is not None:
                    BulletinHelper.show_info(text)
            except Exception:
                pass
        run_on_ui_thread(_show)

    # ================= color helpers =================
    def _parse_color(self, s):
        if s is None:
            return None
        from android.graphics import Color
        try:
            s = str(s).strip()
            if not s.startswith("#"):
                s = "#" + s
            return Color.parseColor(s)
        except Exception:
            return None

    def _color_setting(self, key, default_hex):
        c = self._parse_color(self.get_setting(key, default_hex))
        if c is None:
            c = self._parse_color(default_hex)
        return c if c is not None else -16777216

    def _hex(self, color):
        return "#%08X" % (int(color) & 0xFFFFFFFF)

    def _css_rgba(self, c, fallback):
        if c is None:
            return fallback
        c = int(c)
        a = (c >> 24) & 0xFF
        r = (c >> 16) & 0xFF
        g = (c >> 8) & 0xFF
        b = c & 0xFF
        return "rgba(%d,%d,%d,%.3f)" % (r, g, b, a / 255.0)

    def _theme_color(self, key, default):
        try:
            t = find_class(THEME)
            return int(t.getColor(getattr(t, key)))
        except Exception:
            return default

    # ================= WebView settings UI =================
    def _bitmap_to_data_uri(self, bmp, max_px=PREVIEW_DIM):
        from java.io import ByteArrayOutputStream
        from android.graphics import Bitmap
        from android.util import Base64
        w = bmp.getWidth()
        h = bmp.getHeight()
        big = w if w > h else h
        if big > max_px and big > 0:
            scale = float(max_px) / float(big)
            nw = max(1, int(w * scale))
            nh = max(1, int(h * scale))
            small = Bitmap.createScaledBitmap(bmp, nw, nh, True)
        else:
            small = bmp
        stream = ByteArrayOutputStream()
        small.compress(Bitmap.CompressFormat.JPEG, 82, stream)
        data = Base64.encodeToString(stream.toByteArray(), Base64.NO_WRAP)
        return "data:image/jpeg;base64," + str(data)

    def _image_data_uri(self, which):
        bmp = self._bmp if which == "banner" else self._bg_bmp
        if bmp is None:
            return ""
        try:
            return self._bitmap_to_data_uri(bmp)
        except Exception as e:
            self.log(f"[cpb] preview encode failed: {e}")
            return ""

    def _file_to_data_uri(self, path):
        try:
            from android.util import Base64
            from java.io import FileInputStream, ByteArrayOutputStream
            from java import jbyte, jarray
            fis = FileInputStream(path)
            bos = ByteArrayOutputStream()
            buf = jarray(jbyte)(8192)
            while True:
                n = fis.read(buf)
                if n is None or n <= 0:
                    break
                bos.write(buf, 0, n)
            fis.close()
            data = Base64.encodeToString(bos.toByteArray(), Base64.NO_WRAP)
            return "data:image/jpeg;base64," + str(data)
        except Exception:
            return ""

    def _encode_and_save(self, bmp, path, max_px):
        from java.io import ByteArrayOutputStream, FileOutputStream
        from android.graphics import Bitmap
        from android.util import Base64
        w = bmp.getWidth()
        h = bmp.getHeight()
        big = w if w > h else h
        if big > max_px and big > 0:
            scale = float(max_px) / float(big)
            small = Bitmap.createScaledBitmap(bmp, max(1, int(w * scale)), max(1, int(h * scale)), True)
        else:
            small = bmp
        stream = ByteArrayOutputStream()
        small.compress(Bitmap.CompressFormat.JPEG, 84, stream)
        arr = stream.toByteArray()
        try:
            if path:
                fos = FileOutputStream(path)
                fos.write(arr)
                fos.flush()
                fos.close()
        except Exception:
            pass
        data = Base64.encodeToString(arr, Base64.NO_WRAP)
        return "data:image/jpeg;base64," + str(data)

    def _maybe_capture(self, pa):
        import time
        if getattr(self, "_snap_busy", False):
            return
        if (time.time() - getattr(self, "_snap_ts", 0.0)) < 2.0:
            return
        self._snap_busy = True
        self._snap_ts = time.time()
        self._capture_profile(pa)

    def _capture_profile(self, pa):
        def _run():
            try:
                from android.graphics import Bitmap, Canvas
                from java import jint
                view = None
                try:
                    view = pa.getFragmentView()
                except Exception:
                    view = None
                if view is None:
                    try:
                        view = self._field(pa, "fragmentView").get(pa)
                    except Exception:
                        view = None
                if view is None:
                    return
                w = int(view.getWidth())
                h = int(view.getHeight())
                if w <= 0 or h <= 0:
                    return
                bmp = Bitmap.createBitmap(w, h, Bitmap.Config.ARGB_8888)
                canvas = Canvas(bmp)
                try:
                    bgc = pa.getThemedColor(find_class(THEME).key_windowBackgroundGray)
                    canvas.drawColor(jint(bgc))
                except Exception:
                    pass
                view.draw(canvas)
                uri = self._encode_and_save(bmp, getattr(self, "_snap_path", ""), 900)
                try:
                    bmp.recycle()
                except Exception:
                    pass
                if uri:
                    self._snapshot = uri
                    self._push_snapshot()
            except Exception as e:
                self.log(f"[cpb] snapshot failed: {e}")
            finally:
                self._snap_busy = False
        run_on_ui_thread(_run)

    def _push_snapshot(self):
        wv = self._webview
        if wv is None:
            return
        uri = getattr(self, "_snapshot", "") or ""
        if not uri:
            return
        js = "window.cpbSetSnapshot && cpbSetSnapshot(%s);" % json.dumps(uri)
        def _run():
            try:
                wv.evaluateJavascript(js, None)
            except Exception:
                pass
        run_on_ui_thread(_run)

    def _profile_info(self):
        info = {"name": "", "initials": "", "avatar": ""}
        try:
            uc = find_class("org.telegram.messenger.UserConfig")
            acc = uc.selectedAccount
            user = uc.getInstance(acc).getCurrentUser()
            if user is None:
                return info
            fn = user.first_name or ""
            ln = user.last_name or ""
            name = (str(fn) + " " + str(ln)).strip()
            info["name"] = name or "Профиль"
            ini = ""
            if fn:
                ini += str(fn)[0]
            if ln:
                ini += str(ln)[0]
            if not ini and name:
                ini = name[0]
            info["initials"] = ini.upper()
            try:
                un = getattr(user, "username", None)
                info["username"] = str(un) if un else ""
            except Exception:
                info["username"] = ""
            try:
                ph = getattr(user, "phone", None)
                info["phone"] = ("+" + str(ph)) if ph else ""
            except Exception:
                info["phone"] = ""
            try:
                photo = user.photo
                if photo is not None and photo.photo_small is not None:
                    fl = find_class("org.telegram.messenger.FileLoader").getInstance(acc)
                    f = fl.getPathToAttach(photo.photo_small, True)
                    if f is not None and f.exists():
                        bmp = self._decode_downsampled(f.getAbsolutePath())
                        info["avatar"] = self._bitmap_to_data_uri(bmp, 220)
            except Exception as e:
                self.log(f"[cpb] avatar load failed: {e}")
        except Exception as e:
            self.log(f"[cpb] profile info failed: {e}")
        return info

    def _push_image(self, which):
        wv = self._webview
        if wv is None:
            return
        uri = self._image_data_uri(which)
        js = "window.cpbSetImage && cpbSetImage(%s,%s);" % (json.dumps(which), json.dumps(uri))

        def _run():
            try:
                wv.evaluateJavascript(js, None)
            except Exception:
                try:
                    wv.loadUrl("javascript:" + js)
                except Exception:
                    pass
        run_on_ui_thread(_run)

    def _install_html_file(self):
        from org.telegram.messenger import ApplicationLoader
        ctx = ApplicationLoader.applicationContext
        base = ctx.getFilesDir().getAbsolutePath()
        d = os.path.join(base, "cpb_ui")
        try:
            os.makedirs(d, exist_ok=True)
        except Exception:
            pass
        path = os.path.join(d, "index.html")
        html = self._build_html()
        with open(path, "w", encoding="utf-8") as w:
            w.write(html)
        self._html_path = path
        return path

    def _start_title_poll(self):
        import threading
        self._poll_gen = getattr(self, "_poll_gen", 0) + 1
        gen = self._poll_gen
        self._poll_active = True
        self._last_seq = 0
        def _loop():
            import time
            while getattr(self, "_poll_active", False) and getattr(self, "_poll_gen", 0) == gen:
                try:
                    run_on_ui_thread(self._poll_once)
                except Exception:
                    pass
                time.sleep(0.12)
        threading.Thread(target=_loop, daemon=True).start()

    def _poll_once(self):
        wv = self._webview
        if wv is None:
            return
        try:
            att = bool(wv.isAttachedToWindow())
        except Exception:
            att = True
        if att:
            self._was_attached = True
        elif getattr(self, "_was_attached", False):
            # view was shown and is now detached -> settings screen closed
            self._poll_active = False
            self._webview = None
            self._inline_container = None
            self._destroy_preview()
            return
        try:
            t = wv.getTitle()
        except Exception:
            return
        if not t:
            return
        t = str(t)
        if not t.startswith("CPBMSG:"):
            return
        try:
            rest = t[len("CPBMSG:"):]
            seq_str, cmd = rest.split(":", 1)
            seq = int(seq_str)
        except Exception:
            return
        if seq <= getattr(self, "_last_seq", 0):
            return
        self._last_seq = seq
        try:
            self._on_bridge_url(cmd)
        except Exception as e:
            self.log(f"[cpb] bridge err: {e}")

    def _my_user_id(self):
        try:
            uc = find_class("org.telegram.messenger.UserConfig")
            acc = int(uc.selectedAccount)
            return int(uc.getInstance(acc).getClientUserId())
        except Exception as e:
            self.log(f"[cpb] my uid failed: {e}")
            return 0

    def _collect_config(self):
        return {
            "v": 1,
            "banner_enabled": bool(self._enabled),
            "show_emoji": bool(self._show_emoji),
            "banner_mode": int(self._banner_mode),
            "banner_color": self._hex(self._banner_color),
            "grad_type": int(self._grad_type),
            "grad_angle": int(getattr(self, "_grad_angle", 0)),
            "grad_c1": self._hex(self._grad_c1),
            "grad_c2": self._hex(self._grad_c2),
            "grad_c3": self._hex(self._grad_c3),
            "grad_use3": bool(self._grad_use3),
            "grad_radius": int(getattr(self, "_grad_radius", 100)),
            "grad_count": int(getattr(self, "_grad_count", 2)),
            "banner_alpha": int(getattr(self, "_banner_alpha", 100)),
            "banner_fade": int(getattr(self, "_banner_fade", 0)),
            "banner_fade_angle": int(getattr(self, "_banner_fade_angle", 0)),
            "banner_fade_radius": int(getattr(self, "_banner_fade_radius", 100)),
            "banner_fade_cx": float(getattr(self, "_banner_fade_cx", 0.5)),
            "banner_fade_cy": float(getattr(self, "_banner_fade_cy", 0.5)),
            "grad_cx": float(getattr(self, "_grad_cx", 0.5)),
            "grad_cy": float(getattr(self, "_grad_cy", 0.5)),
            "bg_enabled": bool(self._bg_enabled),
            "bg_mode": int(self._bg_mode),
            "bg_color": self._hex(self._bg_color),
            "bg_alpha": int(getattr(self, "_bg_alpha", 100)),
            "bg_fade": int(getattr(self, "_bg_fade", 0)),
            "bg_fade_angle": int(getattr(self, "_bg_fade_angle", 0)),
            "bg_fade_radius": int(getattr(self, "_bg_fade_radius", 100)),
            "bg_fade_cx": float(getattr(self, "_bg_fade_cx", 0.5)),
            "bg_fade_cy": float(getattr(self, "_bg_fade_cy", 0.5)),
            "avatar_shape": int(getattr(self, "_avatar_shape", 0)),
            "avatar_radius": int(getattr(self, "_avatar_radius", 18)),
            "avatar_round": int(getattr(self, "_avatar_round", 0)),
            "avatar_custom": getattr(self, "_avatar_custom", "") or "",
        }

    def _set_share(self, on):
        self._share_enabled = bool(on)
        try:
            self.set_setting(KEY_SHARE_ENABLED, self._share_enabled)
        except Exception:
            pass
        self.log(f"[cpb] share_enabled={self._share_enabled}")
        if self._share_enabled:
            self._on_publish()

    def _on_publish(self):
        try:
            import threading
            threading.Thread(target=self._publish_my_profile, daemon=True).start()
        except Exception as e:
            self.log(f"[cpb] publish thread failed: {e}")

    def _http_post_json(self, url, body_bytes, headers):
        import urllib.request, urllib.error
        req = urllib.request.Request(url, data=body_bytes, method="POST")
        for k, v in headers.items():
            req.add_header(k, v)
        try:
            resp = urllib.request.urlopen(req, timeout=25)
            data = resp.read().decode("utf-8", "replace")
            return resp.getcode(), data
        except urllib.error.HTTPError as he:
            try:
                data = he.read().decode("utf-8", "replace")
            except Exception:
                data = ""
            return he.code, data

    def _notify_publish(self, ok, msg):
        wv = self._webview
        if wv is not None:
            js = "window.cpbPublishResult && cpbPublishResult(%s,%s);" % ("true" if ok else "false", json.dumps(msg))
            def _run():
                try:
                    wv.evaluateJavascript(js, None)
                except Exception as e:
                    self.log(f"[cpb] publish result js failed: {e}")
            run_on_ui_thread(_run)
        else:
            try:
                self._toast(msg)
            except Exception:
                pass

    def _vps_publish(self, cfg, banner_path, bg_path=""):
        try:
            import base64
            img_b64 = ""
            if banner_path and os.path.exists(banner_path):
                try:
                    with open(banner_path, "rb") as f:
                        img_b64 = base64.b64encode(f.read()).decode("ascii")
                except Exception as e:
                    self.log(f"[cpb] read banner image failed: {e}")
            bg_b64 = ""
            if bg_path and os.path.exists(bg_path):
                try:
                    with open(bg_path, "rb") as f:
                        bg_b64 = base64.b64encode(f.read()).decode("ascii")
                except Exception as e:
                    self.log(f"[cpb] read bg image failed: {e}")
            body = {
                "token": VPS_TOKEN,
                "uid": int(cfg.get("uid", 0)),
                "config": cfg,
                "image_b64": img_b64,
                "image_bg_b64": bg_b64,
            }
            raw = json.dumps(body, ensure_ascii=True).encode("utf-8")
            url = VPS_BASE + "/api/publish"
            self.log(f"[cpb] vps publish -> {url} bytes={len(raw)} img={'y' if img_b64 else 'n'} bg={'y' if bg_b64 else 'n'}")
            code, data = self._http_post_json(url, raw, {"Content-Type": "application/json"})
            self.log(f"[cpb] vps publish resp {code}: {data[:180]}")
            if code == 200:
                self._notify_publish(True, "\u041f\u0440\u043e\u0444\u0438\u043b\u044c \u043e\u043f\u0443\u0431\u043b\u0438\u043a\u043e\u0432\u0430\u043d")
            else:
                self._notify_publish(False, "\u041e\u0448\u0438\u0431\u043a\u0430 \u043f\u0443\u0431\u043b\u0438\u043a\u0430\u0446\u0438\u0438: " + str(code))
        except Exception as e:
            self.log(f"[cpb] vps publish failed: {e}")
            try:
                self._notify_publish(False, "\u041e\u0448\u0438\u0431\u043a\u0430 \u043f\u0443\u0431\u043b\u0438\u043a\u0430\u0446\u0438\u0438")
            except Exception:
                pass

    def _publish_my_profile(self):
        try:
            if not getattr(self, "_share_enabled", False):
                self.log("[cpb] publish skipped: share disabled")
                return
            cfg = self._collect_config()
            cfg["uid"] = self._my_user_id()
            import time as _t
            cfg["ts"] = int(_t.time())
            payload = CFG_TAG + " " + json.dumps(cfg, ensure_ascii=True)
            banner_path = self.get_setting(KEY_BANNER_PATH, "") if int(self._banner_mode) == 0 else ""
            bg_path = self.get_setting(KEY_BG_PATH, "") if (bool(self._bg_enabled) and int(self._bg_mode) == 1) else ""
            self.log(f"[cpb] publish start uid={cfg['uid']} mode={self._banner_mode} img={'y' if banner_path else 'n'} bg={'y' if bg_path else 'n'} len={len(payload)}")
            try:
                self.set_setting(KEY_LAST_PUB_SIG, payload[:80])
            except Exception:
                pass
            self._vps_publish(cfg, banner_path if (banner_path and os.path.exists(banner_path)) else "", bg_path if (bg_path and os.path.exists(bg_path)) else "")
            self.log("[cpb] publish done")
        except Exception as e:
            self.log(f"[cpb] publish failed: {e}")

    def _on_bridge_url(self, url):
        from android.net import Uri
        uri = Uri.parse(url)
        host = uri.getHost()
        if host == "apply":
            self._apply_state(uri)
        elif host == "pick":
            self._pick_target(uri.getQueryParameter("target"))
        elif host == "clear":
            self._clear_target(uri.getQueryParameter("target"))
        elif host == "close":
            self._close_editor()
        elif host == "h":
            self._resize_inline(uri.getQueryParameter("v"))
        elif host == "publish":
            self._on_publish()
        elif host == "share":
            self._set_share(uri.getQueryParameter("on") == "1")
        elif host == "padrect":
            self._set_pad_rect(uri)

    def _set_pad_rect(self, uri):
        try:
            xs = uri.getQueryParameter("x")
            if xs is None:
                self._pad_rect = None
                return
            x = float(xs)
            y = float(uri.getQueryParameter("y"))
            w = float(uri.getQueryParameter("w"))
            h = float(uri.getQueryParameter("h"))
            if x < 0 or w <= 0 or h <= 0:
                self._pad_rect = None
            else:
                self._pad_rect = (x, y, w, h)
        except Exception:
            self._pad_rect = None

    def _resize_inline(self, v):
        try:
            css_px = int(float(v))
        except Exception:
            return
        from org.telegram.messenger import AndroidUtilities
        hpx = AndroidUtilities.dp(css_px)
        minh = AndroidUtilities.dp(180)
        if hpx < minh:
            hpx = minh
        cont = getattr(self, "_inline_container", None)
        if cont is None:
            return
        def _run():
            try:
                lp = cont.getLayoutParams()
                if lp is not None and lp.height != hpx:
                    lp.height = hpx
                    cont.setLayoutParams(lp)
                    cont.requestLayout()
                    p = cont.getParent()
                    if p is not None:
                        try:
                            p.requestLayout()
                        except Exception:
                            pass
            except Exception as e:
                self.log(f"[cpb] resize failed: {e}")
        run_on_ui_thread(_run)

    def _pick_target(self, target):
        if target == "banner":
            self._start_pick(PICK_BANNER_CODE, "Изображение баннера")
        elif target == "bg":
            self._start_pick(PICK_BG_CODE, "Изображение фона")

    def _clear_target(self, target):
        if target == "banner":
            self._bmp = None
            self._shader = None
            self.set_setting(KEY_BANNER_PATH, "")
            self._push_image("banner")
        elif target == "bg":
            self._bg_bmp = None
            self.set_setting(KEY_BG_PATH, "")
            self._bg_dirty = True
            self._push_image("bg")

    def _apply_state(self, uri):
        def q(name):
            v = uri.getQueryParameter(name)
            return v if v is not None else ""

        def qf(name, cur):
            v = q(name)
            try:
                return float(v)
            except Exception:
                return cur

        def qi(name, cur):
            v = q(name)
            try:
                return int(v)
            except Exception:
                return cur

        def qb(name):
            return q(name) == "1"

        def qc(name, cur):
            c = self._parse_color(q(name))
            return c if c is not None else cur

        self._enabled = qb("banner_enabled")
        self._show_emoji = qb("show_emoji")
        self._avatar_shape = qi("avatar_shape", int(getattr(self, "_avatar_shape", 0)))
        self._avatar_radius = qi("avatar_radius", int(getattr(self, "_avatar_radius", 18)))
        self._avatar_round = qi("avatar_round", int(getattr(self, "_avatar_round", 0)))
        _cust = q("avatar_custom")
        self._avatar_custom = _cust
        self._avatar_custom_pts = self._parse_custom_pts(_cust)
        self._av_last_r = None
        self._banner_mode = qi("banner_mode", self._banner_mode)
        self._banner_color = qc("banner_color", self._banner_color)
        self._grad_type = qi("grad_type", self._grad_type)
        self._grad_dir = qi("grad_dir", self._grad_dir)
        self._grad_angle = qi("grad_angle", int(getattr(self, "_grad_angle", 0)))
        self._grad_c1 = qc("grad_c1", self._grad_c1)
        self._grad_c2 = qc("grad_c2", self._grad_c2)
        self._grad_c3 = qc("grad_c3", self._grad_c3)
        self._grad_use3 = qb("grad_use3")
        self._grad_radius = qi("grad_radius", int(getattr(self, "_grad_radius", 100)))
        self._grad_count = qi("grad_count", int(getattr(self, "_grad_count", 2)))
        self._grad_use3 = self._grad_count >= 3
        self._banner_alpha = qi("banner_alpha", int(getattr(self, "_banner_alpha", 100)))
        self._banner_fade = qi("banner_fade", int(getattr(self, "_banner_fade", 0)))
        self._banner_fade_angle = qi("banner_fade_angle", int(getattr(self, "_banner_fade_angle", 0)))
        self._banner_fade_radius = qi("banner_fade_radius", int(getattr(self, "_banner_fade_radius", 100)))
        self._bg_alpha = qi("bg_alpha", int(getattr(self, "_bg_alpha", 100)))
        self._bg_fade = qi("bg_fade", int(getattr(self, "_bg_fade", 0)))
        self._bg_fade_angle = qi("bg_fade_angle", int(getattr(self, "_bg_fade_angle", 0)))
        self._bg_fade_radius = qi("bg_fade_radius", int(getattr(self, "_bg_fade_radius", 100)))
        self._grad_cx = qf("grad_cx", float(getattr(self, "_grad_cx", 0.5)))
        self._grad_cy = qf("grad_cy", float(getattr(self, "_grad_cy", 0.5)))
        self._banner_fade_cx = qf("banner_fade_cx", float(getattr(self, "_banner_fade_cx", 0.5)))
        self._banner_fade_cy = qf("banner_fade_cy", float(getattr(self, "_banner_fade_cy", 0.5)))
        self._bg_fade_cx = qf("bg_fade_cx", float(getattr(self, "_bg_fade_cx", 0.5)))
        self._bg_fade_cy = qf("bg_fade_cy", float(getattr(self, "_bg_fade_cy", 0.5)))
        self._bg_enabled = qb("bg_enabled")
        self._bg_mode = qi("bg_mode", self._bg_mode)
        self._bg_color = qc("bg_color", self._bg_color)

        self._grad_sig = None
        self._bg_dirty = True
        self._banner_img_dirty = True

        self.set_setting(KEY_ENABLED, self._enabled)
        self.set_setting(KEY_EMOJI, self._show_emoji)
        self.set_setting(KEY_AVATAR_SHAPE, self._avatar_shape)
        self.set_setting(KEY_AVATAR_RADIUS, self._avatar_radius)
        self.set_setting(KEY_AVATAR_ROUND, int(getattr(self, "_avatar_round", 0)))
        self.set_setting(KEY_AVATAR_CUSTOM, getattr(self, "_avatar_custom", "") or "")
        self.set_setting(KEY_BANNER_MODE, self._banner_mode)
        self.set_setting(KEY_BANNER_COLOR, self._hex(self._banner_color))
        self.set_setting(KEY_GRAD_TYPE, self._grad_type)
        self.set_setting(KEY_GRAD_DIR, self._grad_dir)
        self.set_setting(KEY_GRAD_ANGLE, int(getattr(self, "_grad_angle", 0)))
        self.set_setting(KEY_GRAD_C1, self._hex(self._grad_c1))
        self.set_setting(KEY_GRAD_C2, self._hex(self._grad_c2))
        self.set_setting(KEY_GRAD_C3, self._hex(self._grad_c3))
        self.set_setting(KEY_GRAD_USE3, self._grad_use3)
        self.set_setting(KEY_GRAD_RADIUS, self._grad_radius)
        self.set_setting(KEY_GRAD_COUNT, self._grad_count)
        self.set_setting(KEY_BANNER_ALPHA, self._banner_alpha)
        self.set_setting(KEY_BANNER_FADE, self._banner_fade)
        self.set_setting(KEY_BANNER_FADE_ANGLE, self._banner_fade_angle)
        self.set_setting(KEY_BANNER_FADE_RADIUS, self._banner_fade_radius)
        self.set_setting(KEY_BG_ALPHA, self._bg_alpha)
        self.set_setting(KEY_BG_FADE, self._bg_fade)
        self.set_setting(KEY_BG_FADE_ANGLE, self._bg_fade_angle)
        self.set_setting(KEY_BG_FADE_RADIUS, self._bg_fade_radius)
        self.set_setting(KEY_GRAD_CX, self._grad_cx)
        self.set_setting(KEY_GRAD_CY, self._grad_cy)
        self.set_setting(KEY_BANNER_FADE_CX, self._banner_fade_cx)
        self.set_setting(KEY_BANNER_FADE_CY, self._banner_fade_cy)
        self.set_setting(KEY_BG_FADE_CX, self._bg_fade_cx)
        self.set_setting(KEY_BG_FADE_CY, self._bg_fade_cy)
        self.set_setting(KEY_BG_ENABLED, self._bg_enabled)
        self.set_setting(KEY_BG_MODE, self._bg_mode)
        self.set_setting(KEY_BG_COLOR, self._hex(self._bg_color))

        self._refresh_preview()

    def _build_webview(self, ctx=None):
        from android.webkit import WebView, WebViewClient, WebSettings
        from java import jint
        if ctx is None:
            ctx = self._get_activity()
        if ctx is None:
            raise RuntimeError("no activity")
        try:
            WebView.setWebContentsDebuggingEnabled(True)
        except Exception:
            pass
        wv = WebView(ctx)
        st = wv.getSettings()
        st.setJavaScriptEnabled(True)
        try:
            st.setDomStorageEnabled(True)
        except Exception:
            pass
        try:
            st.setAllowFileAccess(True)
            st.setAllowContentAccess(True)
            st.setAllowFileAccessFromFileURLs(True)
            st.setAllowUniversalAccessFromFileURLs(False)
        except Exception:
            pass
        try:
            st.setCacheMode(WebSettings.LOAD_NO_CACHE)
            wv.clearCache(True)
        except Exception:
            pass
        bgc = self._theme_color("key_windowBackgroundWhite", -1)
        try:
            wv.setBackgroundColor(jint(bgc))
        except Exception:
            pass
        try:
            wv.setWebViewClient(WebViewClient())
        except Exception:
            pass
        self._webview = wv
        self._install_html_file()
        return wv

    def _build_inline_webview(self, context):
        # Build the WebView as a settings-list cell (no dialog, no button).
        from android.view import ViewGroup
        from android.widget import FrameLayout
        from org.telegram.messenger import AndroidUtilities
        # kill any previous poll before creating a fresh view
        self._poll_active = False
        self._was_attached = False
        wv = self._build_webview(context)
        try:
            wv.setNestedScrollingEnabled(True)
        except Exception:
            pass
        self._pad_rect = None
        try:
            from java import dynamic_proxy
            from android.view import View as _View
            _plugin = self
            class _PadTouch(dynamic_proxy(_View.OnTouchListener)):
                def onTouch(self, v, ev):
                    try:
                        act = ev.getActionMasked()
                        if act == 0:
                            r = getattr(_plugin, "_pad_rect", None)
                            if r and r[0] >= 0:
                                x = ev.getX()
                                y = ev.getY()
                                if r[0] <= x <= r[0] + r[2] and r[1] <= y <= r[1] + r[3]:
                                    par = v.getParent()
                                    if par is not None:
                                        par.requestDisallowInterceptTouchEvent(True)
                        elif act == 1 or act == 3:
                            par = v.getParent()
                            if par is not None:
                                par.requestDisallowInterceptTouchEvent(False)
                    except Exception:
                        pass
                    return False
            wv.setOnTouchListener(_PadTouch())
        except Exception as e:
            self.log(f"[cpb] pad touch listener failed: {e}")
        h = AndroidUtilities.dp(420)
        MP = ViewGroup.LayoutParams.MATCH_PARENT
        container = FrameLayout(context)
        container.setLayoutParams(ViewGroup.LayoutParams(MP, h))
        wv.setLayoutParams(FrameLayout.LayoutParams(MP, MP))
        container.addView(wv)
        self._inline_container = container
        try:
            from android.webkit import WebView as _WV
            wv.setVerticalScrollBarEnabled(False)
            wv.setOverScrollMode(_WV.OVER_SCROLL_NEVER)
        except Exception:
            pass
        try:
            wv.loadUrl("file://" + self._html_path)
        except Exception as e:
            self.log(f"[cpb] loadUrl failed: {e}")
        self._start_title_poll()
        return container

    def _build_profile_preview(self, context):
        from android.view import ViewGroup
        from android.widget import FrameLayout, TextView
        from android.os import Bundle
        from org.telegram.messenger import AndroidUtilities, UserConfig
        from org.telegram.ui import ProfileActivity
        MP = ViewGroup.LayoutParams.MATCH_PARENT
        container = FrameLayout(context)
        container.setLayoutParams(ViewGroup.LayoutParams(MP, AndroidUtilities.dp(560)))
        self._destroy_preview()
        try:
            frag = get_last_fragment()
            nav = frag.getParentLayout() if frag is not None else None
            acc = UserConfig.selectedAccount
            uid = UserConfig.getInstance(acc).getClientUserId()
            args = Bundle()
            args.putLong("user_id", uid)
            pa = ProfileActivity(args)
            self._preview_fragment = pa
            if nav is not None:
                try:
                    pa.setParentLayout(nav)
                except Exception:
                    pass
            try:
                pa.setInPreviewMode(True)
            except Exception:
                pass
            try:
                created = bool(pa.onFragmentCreate())
            except Exception as e:
                self.log(f"[cpb] onFragmentCreate failed: {e}")
                created = False
            if not created:
                raise RuntimeError("onFragmentCreate returned false")
            view = pa.createView(context)
            if view is None:
                raise RuntimeError("createView returned None")
            try:
                p = view.getParent()
                if p is not None:
                    p.removeView(view)
            except Exception:
                pass
            view.setLayoutParams(FrameLayout.LayoutParams(MP, MP))
            container.addView(view)
            self._preview_view = view
            try:
                pa.onResume()
            except Exception:
                pass
            try:
                pa.onBecomeFullyVisible()
            except Exception:
                pass
            self._refresh_preview()
        except Exception as e:
            self.log(f"[cpb] profile preview build failed: {e}")
            self._destroy_preview()
            try:
                container.removeAllViews()
            except Exception:
                pass
            try:
                container.setLayoutParams(ViewGroup.LayoutParams(MP, AndroidUtilities.dp(120)))
            except Exception:
                pass
            tv = TextView(context)
            tv.setText("Живой предпросмотр профиля недоступен")
            try:
                tv.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(16), AndroidUtilities.dp(16), AndroidUtilities.dp(16))
            except Exception:
                pass
            container.addView(tv)
        return container

    def _refresh_preview(self):
        pv = getattr(self, "_preview_view", None)
        if pv is None:
            return
        def _r():
            try:
                self._invalidate_tree(pv)
            except Exception:
                pass
        run_on_ui_thread(_r)

    def _invalidate_tree(self, v):
        try:
            v.invalidate()
        except Exception:
            pass
        try:
            n = v.getChildCount()
        except Exception:
            return
        for i in range(n):
            try:
                self._invalidate_tree(v.getChildAt(i))
            except Exception:
                pass

    def _destroy_preview(self):
        pa = getattr(self, "_preview_fragment", None)
        self._preview_fragment = None
        self._preview_view = None
        if pa is None:
            return
        def _r():
            try:
                pa.onPause()
            except Exception:
                pass
            try:
                pa.onFragmentDestroy()
            except Exception:
                pass
        run_on_ui_thread(_r)

    def _build_html(self):
        state = {
            "banner_enabled": bool(self._enabled),
            "show_emoji": bool(self._show_emoji),
            "avatar_shape": int(getattr(self, "_avatar_shape", 0)),
            "avatar_radius": int(getattr(self, "_avatar_radius", 18)),
            "avatar_round": int(getattr(self, "_avatar_round", 0)),
            "avatar_custom": getattr(self, "_avatar_custom", "") or "",
            "banner_mode": int(self._banner_mode),
            "banner_color": self._hex(self._banner_color),
            "grad_type": int(self._grad_type),
            "grad_dir": int(self._grad_dir),
            "grad_angle": int(getattr(self, "_grad_angle", 0)),
            "grad_c1": self._hex(self._grad_c1),
            "grad_c2": self._hex(self._grad_c2),
            "grad_c3": self._hex(self._grad_c3),
            "grad_use3": bool(self._grad_use3),
            "grad_radius": int(getattr(self, "_grad_radius", 100)),
            "grad_count": int(getattr(self, "_grad_count", 2)),
            "banner_alpha": int(getattr(self, "_banner_alpha", 100)),
            "banner_fade": int(getattr(self, "_banner_fade", 0)),
            "banner_fade_angle": int(getattr(self, "_banner_fade_angle", 0)),
            "banner_fade_radius": int(getattr(self, "_banner_fade_radius", 100)),
            "bg_alpha": int(getattr(self, "_bg_alpha", 100)),
            "bg_fade": int(getattr(self, "_bg_fade", 0)),
            "bg_fade_angle": int(getattr(self, "_bg_fade_angle", 0)),
            "bg_fade_radius": int(getattr(self, "_bg_fade_radius", 100)),
            "grad_cx": float(getattr(self, "_grad_cx", 0.5)),
            "grad_cy": float(getattr(self, "_grad_cy", 0.5)),
            "banner_fade_cx": float(getattr(self, "_banner_fade_cx", 0.5)),
            "banner_fade_cy": float(getattr(self, "_banner_fade_cy", 0.5)),
            "bg_fade_cx": float(getattr(self, "_bg_fade_cx", 0.5)),
            "bg_fade_cy": float(getattr(self, "_bg_fade_cy", 0.5)),
            "bg_enabled": bool(self._bg_enabled),
            "bg_mode": int(self._bg_mode),
            "bg_color": self._hex(self._bg_color),
            "share_enabled": bool(getattr(self, "_share_enabled", False)),
        }
        init = {
            "state": state,
            "images": {
                "banner": self._image_data_uri("banner"),
                "bg": self._image_data_uri("bg"),
            },
            "profile": self._profile_info(),
            "snapshot": getattr(self, "_snapshot", "") or "",
        }
        init_json = json.dumps(init)
        cssvars = ":root{" + \
            "--bg:" + self._css_rgba(self._theme_color("key_windowBackgroundWhite", None), "#1e1e1e") + ";" + \
            "--text:" + self._css_rgba(self._theme_color("key_windowBackgroundWhiteBlackText", None), "#ffffff") + ";" + \
            "--muted:" + self._css_rgba(self._theme_color("key_windowBackgroundWhiteGrayText", None), "#9aa0a6") + ";" + \
            "--accent:" + self._css_rgba(self._theme_color("key_windowBackgroundWhiteBlueText", None), "#3390ec") + ";" + \
            "--gray:" + self._css_rgba(self._theme_color("key_windowBackgroundGray", None), "#101010") + ";" + \
            "--card:" + self._css_rgba(self._theme_color("key_dialogBackground", None), "#2a2a2a") + ";" + \
            "}"
        html = _HTML_TEMPLATE.replace("/*__CSSVARS__*/", cssvars).replace("/*__INIT__*/", init_json)
        # Native live profile preview is shown above; hide the HTML mock preview.
        html = html.replace('<div class="preview">', '<div class="preview" style="display:none">')
        # Inline mode: no dialog to close, so hide the "Done" button.
        html = html.replace('<button class="x" id="btnClose">', '<button class="x" id="btnClose" style="display:none">')
        return html

    def _open_editor(self, *args):
        def _run():
            try:
                self._show_editor_dialog()
            except Exception as e:
                self.log(f"[cpb] open editor failed: {e}")
                self._toast(f"Не удалось открыть редактор: {e}")
        run_on_ui_thread(_run)

    def _show_editor_dialog(self):
        from android.app import Dialog
        from android.view import Window, ViewGroup, Gravity, View
        from android.widget import LinearLayout
        from android.graphics.drawable import ColorDrawable, GradientDrawable
        from android.graphics import Color
        from org.telegram.messenger import AndroidUtilities
        from java import jint, jarray, jfloat
        activity = self._get_activity()
        if activity is None:
            raise RuntimeError("no activity")
        wv = self._build_webview(activity)
        MP = ViewGroup.LayoutParams.MATCH_PARENT
        # compact but roomy: ~58%% of screen height, clamped
        try:
            dm = activity.getResources().getDisplayMetrics()
            screen_h = int(dm.heightPixels)
        except Exception:
            screen_h = AndroidUtilities.dp(640)
        panel_h = int(screen_h * 0.58)
        min_h = AndroidUtilities.dp(340)
        max_h = AndroidUtilities.dp(520)
        if panel_h < min_h:
            panel_h = min_h
        if panel_h > max_h:
            panel_h = max_h
        bgc = self._theme_color("key_windowBackgroundWhite", -1)
        r = float(AndroidUtilities.dp(16))
        panel_bg = GradientDrawable()
        try:
            panel_bg.setColor(jint(bgc))
            panel_bg.setCornerRadii(jarray(jfloat)([r, r, r, r, 0.0, 0.0, 0.0, 0.0]))
        except Exception:
            pass
        root = LinearLayout(activity)
        try:
            root.setOrientation(LinearLayout.VERTICAL)
        except Exception:
            pass
        root.setLayoutParams(ViewGroup.LayoutParams(MP, MP))
        try:
            root.setBackground(panel_bg)
        except Exception:
            try:
                root.setBackgroundColor(jint(bgc))
            except Exception:
                pass
        try:
            handle = View(activity)
            hb = GradientDrawable()
            hb.setColor(jint(self._theme_color("key_windowBackgroundWhiteGrayText", -6710887)))
            hb.setCornerRadius(float(AndroidUtilities.dp(3)))
            handle.setBackground(hb)
            hlp = LinearLayout.LayoutParams(AndroidUtilities.dp(36), AndroidUtilities.dp(4))
            hlp.gravity = Gravity.CENTER_HORIZONTAL
            hlp.topMargin = AndroidUtilities.dp(8)
            hlp.bottomMargin = AndroidUtilities.dp(6)
            handle.setLayoutParams(hlp)
            root.addView(handle)
        except Exception as e:
            self.log(f"[cpb] sheet handle failed: {e}")
        wvlp = LinearLayout.LayoutParams(MP, 0)
        try:
            wvlp.weight = 1.0
        except Exception:
            pass
        wv.setLayoutParams(wvlp)
        root.addView(wv)
        dlg = Dialog(activity)
        try:
            dlg.requestWindowFeature(Window.FEATURE_NO_TITLE)
        except Exception:
            pass
        dlg.setContentView(root)
        try:
            dlg.setCanceledOnTouchOutside(True)
        except Exception:
            pass
        self._dialog = dlg
        dlg.show()
        w = dlg.getWindow()
        if w is not None:
            try:
                w.setBackgroundDrawable(ColorDrawable(Color.TRANSPARENT))
                w.setLayout(MP, panel_h)
                w.setGravity(Gravity.BOTTOM)
                try:
                    w.setDimAmount(0.25)
                except Exception:
                    pass
            except Exception as e:
                self.log(f"[cpb] sheet window failed: {e}")
        try:
            wv.loadUrl("file://" + self._html_path)
        except Exception as e:
            self.log(f"[cpb] loadUrl failed: {e}")
        self._start_title_poll()

    def _close_editor(self):
        dlg = getattr(self, "_dialog", None)
        self._dialog = None
        self._webview = None
        self._poll_active = False
        if dlg is None:
            return
        def _run():
            try:
                dlg.dismiss()
            except Exception:
                pass
        run_on_ui_thread(_run)

    def _app_version_tuple(self):
        if self._app_ver is not None:
            return self._app_ver
        name = None
        try:
            from org.telegram.messenger import ApplicationLoader
            ctx = ApplicationLoader.applicationContext
            if ctx is None:
                ctx = self._get_activity()
            if ctx is not None:
                info = ctx.getPackageManager().getPackageInfo(ctx.getPackageName(), 0)
                name = info.versionName
        except Exception as e:
            self.log(f"[cpb] app version detect failed: {e}")
        v = self._parse_ver(name)
        self.log(f"[cpb] app versionName={name} parsed={v}")
        self._app_ver = v
        return v

    def _parse_ver(self, name):
        try:
            if not name:
                return None
            s = str(name)
            parts = []
            cur = ""
            for ch in s:
                if ch.isdigit():
                    cur += ch
                else:
                    if cur:
                        parts.append(int(cur))
                        cur = ""
                    if len(parts) >= 3:
                        break
            if cur and len(parts) < 3:
                parts.append(int(cur))
            if not parts:
                return None
            while len(parts) < 3:
                parts.append(0)
            return (parts[0], parts[1], parts[2])
        except Exception:
            return None

    def _is_new_app_version(self):
        v = self._app_version_tuple()
        if v is None:
            return SimpleSettingFactory is not None and Custom is not None
        return v >= (12, 8, 1)

    def _menu_activate(self):
        # Always open our own in-profile editor. Reflectively opening
        # exteraGram's native PluginSettingsActivity left a zombie fragment
        # subscribed to NotificationCenter with a null plugin, which crashed
        # the app on the next plugin install/reload.
        self._open_editor()

    def _open_plugin_settings(self):
        def _run():
            ok = False
            try:
                ok = self._present_settings_fragment()
            except Exception as e:
                self.log(f"[cpb] open plugin settings failed: {e}")
                ok = False
            if not ok:
                self.log("[cpb] settings screen unavailable, opening dialog")
                try:
                    self._show_editor_dialog()
                except Exception as e:
                    self.log(f"[cpb] fallback dialog failed: {e}")
        run_on_ui_thread(_run)

    def _present_settings_fragment(self):
        last = get_last_fragment()
        if last is None:
            return False
        frag = self._make_settings_fragment()
        if frag is None:
            return False
        last.presentFragment(frag)
        return True

    def _get_plugin_java(self):
        from java import jclass
        controllers = [
            "com.exteragram.messenger.plugins.PluginsController",
            "com.exteragram.messenger.plugins.PluginsManager",
            "com.exteragram.messenger.plugins.Plugins",
        ]
        for cn in controllers:
            try:
                C = jclass(cn)
            except Exception:
                continue
            inst = None
            for gm in ("getInstance", "getGlobalInstance"):
                try:
                    inst = getattr(C, gm)()
                    if inst is not None:
                        break
                except Exception:
                    inst = None
            targets = [inst] if inst is not None else []
            targets.append(C)
            for tgt in targets:
                for m in ("getPlugin", "getPluginById", "findPlugin", "getLoadedPlugin"):
                    try:
                        pj = getattr(tgt, m)(__id__)
                        if pj is not None:
                            self.log(f"[cpb] plugin java via {cn}.{m}")
                            return pj
                    except Exception:
                        pass
        return None

    def _make_settings_fragment(self):
        # Disabled: constructing the native PluginSettingsActivity via reflection
        # created a zombie fragment (null plugin) that crashed the app on the
        # next plugin install. The in-profile editor is the settings UI.
        return None
        from java import jclass
        pobj = None
        try:
            pobj = self._get_plugin_java()
        except Exception as e:
            self.log(f"[cpb] get plugin java failed: {e}")
        classes = []
        if getattr(self, "_settings_frag_cls", None):
            classes.append(self._settings_frag_cls)
        classes += [
            "com.exteragram.messenger.plugins.ui.PluginSettingsActivity",
            "com.exteragram.messenger.plugins.ui.PluginIntroActivity",
            "com.exteragram.messenger.plugins.PluginSettingsActivity",
            "com.exteragram.messenger.plugins.ui.PluginsActivity",
        ]
        for cn in classes:
            Kls = None
            try:
                Kls = find_class(cn)
            except Exception:
                Kls = None
            if Kls is None:
                continue
            try:
                for c in Kls.getDeclaredConstructors():
                    self.log(f"[cpb] {cn} ctor: {c.toString()}")
            except Exception:
                pass
            try:
                C = jclass(cn)
            except Exception:
                continue
            args = []
            if pobj is not None:
                args.append(pobj)
            args.append(__id__)
            args.append(None)
            for arg in args:
                try:
                    inst = C() if arg is None else C(arg)
                    if inst is not None:
                        self.log(f"[cpb] settings fragment opened via {cn}")
                        return inst
                except Exception as e:
                    self.log(f"[cpb] ctor {cn} failed: {e}")
        return None

    def _create_settings_fallback(self):
        # Older exteraGram SDKs (e.g. 12.5.x) do not expose SimpleSettingFactory,
        # so the embedded WebView editor cannot be rendered in this list. Degrade
        # gracefully instead of crashing the whole plugin import.
        items = []
        try:
            if Header is not None:
                items.append(Header(text="Custom Profile"))
            if Text is not None:
                items.append(Text(
                    text="Настройки этого плагина — в вашем профиле. Откройте свой профиль → меню «⋮» → «Оформить профиль»."))
        except Exception as e:
            self.log(f"[cpb] fallback settings failed: {e}")
        return items

    def create_settings(self) -> List[Any]:
        try:
            _hf = get_last_fragment()
            if _hf is not None:
                _hc = _hf.getClass()
                self._settings_frag_cls = _hc.getName()
                self.log(f"[cpb] create_settings host fragment: {self._settings_frag_cls}")
                try:
                    for _c in _hc.getDeclaredConstructors():
                        self.log(f"[cpb] host frag ctor: {_c.toString()}")
                except Exception:
                    pass
        except Exception as e:
            self.log(f"[cpb] host fragment capture failed: {e}")
        if not self._is_new_app_version():
            return self._create_settings_fallback()
        if SimpleSettingFactory is None or Custom is None:
            return self._create_settings_fallback()
        plugin = self

        def _cv_prev(context, list_view, current_account, class_guid, resources_provider):
            try:
                return plugin._build_profile_preview(context)
            except Exception as e:
                plugin.log(f"[cpb] profile preview cell failed: {e}")
                from android.widget import TextView
                tv = TextView(context)
                tv.setText("Предпросмотр недоступен")
                return tv

        def _cv(context, list_view, current_account, class_guid, resources_provider):
            try:
                return plugin._build_inline_webview(context)
            except Exception as e:
                plugin.log(f"[cpb] inline webui failed: {e}")
                from android.widget import TextView
                tv = TextView(context)
                tv.setText("Не удалось загрузить WebUI")
                return tv

        def _bind(view, item, divider, adapter, list_view):
            return None

        # keep strong references so the factories/closures are not GC'd
        self._preview_factory = SimpleSettingFactory(
            _cv_prev, _bind, is_clickable=False, is_shadow=False
        )
        self._web_factory = SimpleSettingFactory(
            _cv, _bind, is_clickable=False, is_shadow=False
        )
        return [
            Header(text="Custom Profile Banner"),
            Custom(factory=self._preview_factory.instance.java),
            Custom(factory=self._web_factory.instance.java),
        ]

    def _deep_field(self, obj, name):
        try:
            cls = obj.getClass()
        except Exception:
            return None
        while cls is not None:
            try:
                f = cls.getDeclaredField(name)
                f.setAccessible(True)
                return f.get(obj)
            except Exception:
                pass
            try:
                cls = cls.getSuperclass()
            except Exception:
                return None
        return None

    def add_profile_menu(self, param):
        try:
            pa = param.thisObject
        except Exception:
            return
        if pa is None:
            return
        try:
            if not self._is_own_profile(pa):
                return
        except Exception:
            return
        try:
            key = int(pa.hashCode())
        except Exception:
            key = id(pa)
        if key in getattr(self, "_menu_pa_ids", set()):
            return
        action_bar = self._deep_field(pa, "actionBar")
        if action_bar is None:
            self.log("[cpb] profile actionBar not found")
            return
        from android.view import View
        from java import dynamic_proxy
        plugin = self

        class _MenuClick(dynamic_proxy(View.OnClickListener)):
            def __init__(self, item):
                super().__init__()
                self._item = item

            def onClick(self, v):
                try:
                    if self._item is not None:
                        self._item.closeSubMenu()
                except Exception:
                    pass
                try:
                    plugin._menu_activate()
                except Exception as e:
                    plugin.log(f"[cpb] menu click failed: {e}")

        added = False
        try:
            other = self._deep_field(pa, "otherItem")
            if other is not None:
                sub = other.addSubItem(CPB_MENU_ID, "\u041e\u0444\u043e\u0440\u043c\u0438\u0442\u044c \u043f\u0440\u043e\u0444\u0438\u043b\u044c")
                listener = _MenuClick(other)
                self._menu_listeners.append(listener)
                sub.setOnClickListener(listener)
                added = True
        except Exception as e:
            self.log(f"[cpb] add profile subitem failed: {e}")
            added = False
        if not added:
            try:
                menu = action_bar.createMenu()
                item = menu.addItem(CPB_MENU_ID, "\u270e")
                listener = _MenuClick(item)
                self._menu_listeners.append(listener)
                item.setOnClickListener(listener)
                added = True
            except Exception as e:
                self.log(f"[cpb] add profile bar item failed: {e}")
        if added:
            self._menu_pa_ids.add(key)
            if len(self._menu_pa_ids) > 256:
                self._menu_pa_ids.clear()
            self.log("[cpb] profile menu item added")

    def on_plugin_unload(self):
        self._webview = None
        self._menu_listeners = []
        self._menu_pa_ids = set()
        try:
            self._destroy_preview()
        except Exception:
            pass
        for u in getattr(self, "_unhooks", []):
            try:
                self.unhook_method(u)
            except Exception:
                pass
        self._unhooks = []


_HTML_TEMPLATE = "<!DOCTYPE html>\n<html><head><meta charset=\"utf-8\">\n<title>cpb</title>\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no\">\n<style>\n/*__CSSVARS__*/\n* { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }\nhtml,body { margin:0; padding:0; background:var(--bg); color:var(--text);\n  font-family:-apple-system, Roboto, Segoe UI, sans-serif; font-size:15px; }\n.wrap { padding:12px 14px 40px; max-width:640px; margin:0 auto; }\n.preview { position:relative; padding:8px 0 12px; background:var(--bg); }\n.topbar{display:flex;align-items:center;justify-content:space-between;padding:6px 2px 10px;}\n.ttl{font-weight:700;font-size:16px;}\n.x{background:var(--accent);color:#fff;border:none;border-radius:9px;padding:9px 18px;font-weight:600;font-size:14px;}\n.phone { border-radius:16px; overflow:hidden; border:1px solid rgba(128,128,128,.22);\n  box-shadow:0 6px 22px rgba(0,0,0,.28); }\n\n/* --- Telegram (Web K) style profile preview --- */\n.tgp { border-radius:14px; overflow:hidden; background:var(--bg);\n  border:1px solid rgba(128,128,128,.16); box-shadow:0 6px 24px rgba(0,0,0,.32); }\n.tgp-hero { position:relative; width:100%; aspect-ratio:3 / 2; max-height:300px;\n  background:linear-gradient(#53606e,#384654); background-size:cover; background-position:center;\n  overflow:hidden; display:flex; flex-direction:column; }\n#phEmoji { position:absolute; inset:0; z-index:0; pointer-events:none; opacity:.20; font-size:24px;\n  line-height:42px; letter-spacing:12px; word-spacing:6px; overflow:hidden; padding:12px;\n  color:rgba(255,255,255,.92); }\n.tgp-gtop { position:absolute; left:0; right:0; top:0; height:64px; z-index:2;\n  background:linear-gradient(to top, rgba(0,0,0,0), rgba(0,0,0,.28)); }\n.tgp-tabs { position:absolute; top:8px; left:10px; right:10px; z-index:3; display:flex; gap:3px; }\n.tgp-tabs i { flex:1; height:2px; border-radius:2px; background:rgba(255,255,255,.4); }\n.tgp-tabs i.on { background:#fff; }\n.tgp-scrim { position:absolute; left:0; right:0; bottom:0; height:62%; z-index:2;\n  background:linear-gradient(to bottom, rgba(0,0,0,0), rgba(0,0,0,.62)); }\n.tgp-info { position:relative; z-index:3; margin-top:auto; display:flex; align-items:flex-end;\n  gap:12px; padding:12px 16px 14px; }\n.tgp-avatar { flex:0 0 auto; width:72px; height:72px; border-radius:50%;\n  background:linear-gradient(#5caffa,#408acf); background-size:cover; background-position:center;\n  box-shadow:0 2px 10px rgba(0,0,0,.42);\n  display:flex; align-items:center; justify-content:center; font-size:30px; font-weight:600; color:#fff; }\n.tgp-meta { flex:1; min-width:0; padding-bottom:4px; }\n.tgp-name { display:flex; align-items:center; gap:6px; color:#fff; font-weight:500;\n  font-size:21px; line-height:1.2; text-shadow:0 1px 6px rgba(0,0,0,.55); }\n.tgp-name .nm { overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }\n.tgp-badge { flex:0 0 auto; font-size:16px; }\n.tgp-status { display:flex; align-items:center; gap:5px; color:rgba(255,255,255,.85);\n  font-size:13px; margin-top:3px; text-shadow:0 1px 4px rgba(0,0,0,.55); }\n.tgp-star { color:#f1c40f; font-size:13px; }\n.tgp-body { background:var(--gray); background-size:cover; background-position:center;\n  padding:10px; min-height:130px; }\n.tgp-sect { background:var(--card); border-radius:12px; overflow:hidden;\n  box-shadow:0 1px 4px rgba(0,0,0,.16); }\n.tgp-row { display:flex; align-items:flex-start; gap:18px; padding:10px 16px; position:relative; }\n.tgp-row + .tgp-row:before { content:\"\"; position:absolute; left:54px; right:0; top:0;\n  height:1px; background:rgba(128,128,128,.16); }\n.tgp-ic { flex:0 0 auto; width:20px; text-align:center; font-size:17px; color:var(--muted); margin-top:2px; }\n.tgp-rt { min-width:0; }\n.tgp-rt b { font-weight:400; font-size:15px; color:var(--text); display:block; word-break:break-word; }\n.tgp-rt span { font-size:13px; color:var(--muted); display:block; margin-top:1px; }\n.tgp-rt a { color:var(--accent); text-decoration:none; }\n.mocklbl,.reallbl { font-size:12px; text-transform:uppercase; letter-spacing:.05em;\n  color:var(--muted); margin:2px 2px 6px; font-weight:700; }\n.realimg { width:100%; display:block; border-radius:14px; border:1px solid rgba(128,128,128,.16);\n  box-shadow:0 6px 24px rgba(0,0,0,.32); margin-bottom:16px; }\n.realhint { font-size:12px; color:var(--muted); padding:8px 2px 0; }\n\n/* --- controls --- */\nh3 { font-size:13px; text-transform:uppercase; letter-spacing:.06em; color:var(--accent);\n  margin:20px 2px 8px; font-weight:700; }\n.card { background:var(--card); border-radius:14px; padding:4px 14px; }\n.row { display:flex; align-items:center; gap:12px; padding:12px 0; border-bottom:1px solid rgba(128,128,128,.16); }\n.row:last-child { border-bottom:none; }\n.row .lbl { flex:1; }\n.row .lbl b { font-weight:600; }\n.row .lbl span { display:block; font-size:12px; color:var(--muted); margin-top:2px; }\n.switch { position:relative; width:48px; height:28px; flex:0 0 auto; }\n.switch input { opacity:0; width:0; height:0; }\n.slider { position:absolute; inset:0; background:rgba(128,128,128,.4); border-radius:28px; transition:.2s; }\n.slider:before { content:\"\"; position:absolute; width:22px; height:22px; left:3px; top:3px;\n  background:#fff; border-radius:50%; transition:.2s; box-shadow:0 1px 3px rgba(0,0,0,.4); }\n.switch input:checked + .slider { background:var(--accent); }\n.switch input:checked + .slider:before { transform:translateX(20px); }\n.seg { display:flex; gap:6px; flex-wrap:wrap; padding:10px 0; }\n.seg button { flex:1 1 auto; min-width:44px; padding:9px 8px; border-radius:10px; border:1px solid rgba(128,128,128,.3);\n  background:transparent; color:var(--text); font-size:13px; font-weight:600; display:flex; align-items:center; justify-content:center; }\n.seg button svg { width:22px; height:22px; display:block; }\n.seg button.active { background:var(--accent); border-color:var(--accent); color:#fff; }\n.colorRow { display:flex; align-items:center; gap:12px; padding:12px 0; border-bottom:1px solid rgba(128,128,128,.16); }\n.colorRow:last-child { border-bottom:none; }\n.colorRow .lbl { flex:1; }\n.colorRow input[type=color] { width:44px; height:34px; border:none; background:none; padding:0; border-radius:8px; }\n.colorRow input[type=range] { width:110px; accent-color:var(--accent); }\n.hex { font-size:12px; color:var(--muted); font-family:monospace; width:78px; text-align:right; }\n.btnrow { display:flex; gap:10px; padding:12px 0; }\n.btn { flex:1; padding:11px; border-radius:10px; border:none; font-weight:600; font-size:14px; background:var(--accent); color:#fff; }\n.btn.sec { background:rgba(128,128,128,.22); color:var(--text); }\n.btn.danger { background:rgba(229,57,53,.16); color:#e53935; }\n.hint { font-size:12px; color:var(--muted); padding:8px 2px 0; }\n.sw{ width:46px; height:30px; border-radius:8px; border:1px solid rgba(128,128,128,.45); padding:0;\n  background-image: linear-gradient(var(--c,#000),var(--c,#000)),\n    conic-gradient(#c9c9c9 25%,#fff 0 50%,#c9c9c9 0 75%,#fff 0);\n  background-size:auto, 12px 12px; background-position:center; }\n.cp-toast{ position:fixed; left:16px; right:16px; bottom:20px; margin:0 auto; max-width:520px; z-index:130; padding:13px 16px; border-radius:12px; color:#fff; font-size:14px; font-weight:600; text-align:center; box-shadow:0 10px 34px rgba(0,0,0,.45); opacity:0; transform:translateY(18px); transition:opacity .22s, transform .22s; pointer-events:none; background:rgba(45,55,72,.97); } .cp-toast.on{ opacity:1; transform:translateY(0); } .cp-toast.okk{ background:rgba(38,150,74,.97); } .cp-toast.errr{ background:rgba(200,60,60,.97); } .cp-dim{ position:fixed; inset:0; z-index:50; background:rgba(0,0,0,.55); display:none;\n  align-items:center; justify-content:center; padding:18px; }\n.cp-dim.on{ display:flex; }\n.cp{ width:100%; max-width:340px; background:var(--card); border-radius:16px; padding:14px;\n  box-shadow:0 20px 60px rgba(0,0,0,.5); }\n.cp-sv{ position:relative; width:100%; height:170px; border-radius:12px; overflow:hidden; touch-action:none; }\n.cp-thumb{ position:absolute; width:18px; height:18px; border-radius:50%; border:2px solid #fff;\n  box-shadow:0 0 0 1px rgba(0,0,0,.4); transform:translate(-50%,-50%); pointer-events:none; }\n#cpHue,#cpAlpha{ width:100%; -webkit-appearance:none; appearance:none; height:14px; border-radius:8px; margin:0; }\n#cpHue{ margin-top:14px; background:linear-gradient(to right,#f00,#ff0,#0f0,#0ff,#00f,#f0f,#f00); }\n.cp-alpha{ margin-top:12px; border-radius:8px;\n  background-image:conic-gradient(#c9c9c9 25%,#fff 0 50%,#c9c9c9 0 75%,#fff 0); background-size:12px 12px; }\n#cpAlpha{ background:linear-gradient(to right, rgba(0,0,0,0), var(--ac,#000)); }\n.cp input[type=range]::-webkit-slider-thumb{ -webkit-appearance:none; width:20px; height:20px; border-radius:50%;\n  background:#fff; border:1px solid rgba(0,0,0,.35); box-shadow:0 1px 4px rgba(0,0,0,.4); }\n.cp-foot{ display:flex; align-items:center; gap:10px; margin-top:14px; }\n.cp-prev{ width:34px; height:34px; border-radius:8px; border:1px solid rgba(128,128,128,.4); flex:0 0 auto;\n  background-image:linear-gradient(var(--pc,#000),var(--pc,#000)),conic-gradient(#c9c9c9 25%,#fff 0 50%,#c9c9c9 0 75%,#fff 0);\n  background-size:auto,12px 12px; }\n.cp-hex{ flex:1; min-width:0; background:var(--bg); color:var(--text); border:1px solid rgba(128,128,128,.4);\n  border-radius:8px; padding:9px 10px; font-family:monospace; font-size:14px; }\n.angleRow{ display:flex; gap:16px; align-items:center; padding:12px 0; }\n.dial{ position:relative; width:76px; height:76px; flex:0 0 auto; border-radius:50%;\n  background:radial-gradient(circle at 50% 50%, rgba(128,128,128,.14), rgba(128,128,128,.05));\n  border:1px solid rgba(128,128,128,.3); touch-action:none; }\n.dial:before{ content:\"\"; position:absolute; left:50%; top:50%; width:6px; height:6px; margin:-3px;\n  border-radius:50%; background:var(--muted); }\n.dial-h{ position:absolute; width:14px; height:14px; margin:-7px; border-radius:50%;\n  background:var(--accent); box-shadow:0 0 0 3px rgba(0,0,0,.15); }\n.angmeta{ flex:1; min-width:0; }\n.angval{ font-weight:600; font-size:15px; margin-bottom:6px; }\n.angrange{ width:100%; accent-color:var(--accent); }\n.angpresets{ display:flex; flex-wrap:wrap; gap:6px; margin-top:8px; }\n.angpresets button{ width:34px; height:30px; border-radius:8px; border:1px solid rgba(128,128,128,.3);\n  background:transparent; color:var(--text); font-size:15px; }\n.padwrap{ display:flex; gap:16px; align-items:flex-start; padding:14px 0; }\n.pad{ position:relative; width:150px; height:150px; flex:0 0 auto; border-radius:14px;  background:radial-gradient(circle at 50% 50%, rgba(128,128,128,.14), rgba(128,128,128,.05));  border:1px solid rgba(128,128,128,.3); touch-action:none; overflow:hidden; -webkit-user-select:none; user-select:none; -webkit-touch-callout:none; }\n.pad-svg{ position:absolute; inset:0; width:100%; height:100%; }\n.pad-linel{ stroke:var(--accent); stroke-width:2.6; stroke-linecap:round; }\n.pad-ringc{ stroke:var(--accent); stroke-width:2; fill:rgba(128,128,128,.06); }\n.pad-dot{ fill:var(--muted); }\n.pad-stop{ stroke:#fff; stroke-width:1; }\n.pad-h{ position:absolute; width:18px; height:18px; border-radius:50%; background:var(--accent);  border:2px solid #fff; box-shadow:0 1px 5px rgba(0,0,0,.5); transform:translate(-50%,-50%);  left:50%; top:10%; pointer-events:none; }\n.padmeta{ flex:1; min-width:0; }\n.padval{ font-weight:600; font-size:15px; margin-bottom:8px; }\n.mini{ display:block; font-size:12px; color:var(--muted); margin:10px 0 2px; }\n.rng{ width:100%; accent-color:var(--accent); touch-action:none; }\n.rng2{ flex:1; accent-color:var(--accent); touch-action:none; }\n.tabs{ position:sticky; top:0; z-index:20; display:flex; gap:6px; padding:6px; margin:0 0 14px; background:var(--card); border-radius:14px; box-shadow:0 3px 14px rgba(0,0,0,.18); }\n.tabs .tb{ flex:1; padding:12px 6px; border-radius:10px; border:none; background:transparent; color:var(--muted); font-size:14px; font-weight:700; letter-spacing:.2px; transition:background .15s,color .15s; }\n.tabs .tb.active{ background:var(--accent); color:#fff; box-shadow:0 2px 8px rgba(0,0,0,.28); }\n.sec{ display:none; }\n.sec.on{ display:block; }\n.sec h3:first-child{ margin-top:6px; }\n</style></head>\n<body>\n<div class=\"wrap\">\n  <div class=\"preview\">\n    <div id=\"realWrap\" style=\"display:none\">\n      <div class=\"reallbl\">\u0412\u0430\u0448 \u043f\u0440\u043e\u0444\u0438\u043b\u044c</div>\n      <img id=\"phSnap\" class=\"realimg\" alt=\"\">\n    </div>\n    <div id=\"mockWrap\">\n    <div class=\"mocklbl\">\u041f\u0440\u0435\u0434\u043f\u0440\u043e\u0441\u043c\u043e\u0442\u0440 \u0438\u0437\u043c\u0435\u043d\u0435\u043d\u0438\u0439 \u0431\u0430\u043d\u043d\u0435\u0440\u0430</div>\n    <div class=\"tgp\">\n      <div class=\"tgp-hero\" id=\"phBanner\">\n        <div id=\"phEmoji\">\u2728 \u2b50 \u2728 \u2b50 \u2728 \u2b50 \u2728 \u2b50 \u2728 \u2b50 \u2728 \u2b50 \u2728 \u2b50 \u2728 \u2b50 \u2728 \u2b50 \u2728 \u2b50 \u2728 \u2b50</div>\n        <div class=\"tgp-gtop\"></div>\n        <div class=\"tgp-tabs\"><i class=\"on\"></i><i></i><i></i></div>\n        <div class=\"tgp-scrim\"></div>\n        <div class=\"tgp-info\">\n          <div class=\"tgp-avatar\" id=\"phAvatar\">&#128100;</div>\n          <div class=\"tgp-meta\">\n            <div class=\"tgp-name\"><span class=\"nm\" id=\"phNameTxt\">\u041f\u0440\u043e\u0444\u0438\u043b\u044c</span><span class=\"tgp-badge\">&#11088;</span></div>\n            <div class=\"tgp-status\"><span class=\"tgp-star\">&#9733;</span><span id=\"phStatus\">\u0431\u044b\u043b(\u0430) \u043d\u0435\u0434\u0430\u0432\u043d\u043e</span></div>\n          </div>\n        </div>\n      </div>\n      <div class=\"tgp-body\" id=\"phBody\">\n        <div class=\"tgp-sect\">\n          <div class=\"tgp-row\"><span class=\"tgp-ic\">&#128241;</span><div class=\"tgp-rt\"><b id=\"phPhone\">+7 900 000 00 00</b><span>\u0422\u0435\u043b\u0435\u0444\u043e\u043d</span></div></div>\n          <div class=\"tgp-row\"><span class=\"tgp-ic\">@</span><div class=\"tgp-rt\"><b id=\"phUser\">@username</b><span>\u0418\u043c\u044f \u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044f</span></div></div>\n          <div class=\"tgp-row\"><span class=\"tgp-ic\">&#8505;</span><div class=\"tgp-rt\"><b>\u0420\u0430\u0441\u0441\u043a\u0430\u0436\u0438\u0442\u0435 \u043e \u0441\u0435\u0431\u0435</b><span>\u041e \u0441\u0435\u0431\u0435</span></div></div>\n          <div class=\"tgp-row\"><span class=\"tgp-ic\">&#127874;</span><div class=\"tgp-rt\"><b>13 \u0430\u043f\u0440\u0435\u043b\u044f</b><span>\u0414\u0435\u043d\u044c \u0440\u043e\u0436\u0434\u0435\u043d\u0438\u044f</span></div></div>\n        </div>\n      </div>\n    </div>\n    </div>\n    <div class=\"realhint\" id=\"snapHint\">\u041e\u0442\u043a\u0440\u043e\u0439\u0442\u0435 \u0441\u0432\u043e\u0439 \u043f\u0440\u043e\u0444\u0438\u043b\u044c \u043e\u0434\u0438\u043d \u0440\u0430\u0437, \u0447\u0442\u043e\u0431\u044b \u0437\u0430\u0433\u0440\u0443\u0437\u0438\u0442\u044c \u0440\u0435\u0430\u043b\u044c\u043d\u044b\u0439 \u0441\u043d\u0438\u043c\u043e\u043a.</div>\n  </div>\n\n<div class=\"tabs\"><button class=\"tb active\" data-t=\"banner\">Баннер</button><button class=\"tb\" data-t=\"avatar\">Аватар</button><button class=\"tb\" data-t=\"bg\">Фон</button><button class=\"tb\" data-t=\"share\">Обмен</button></div>\n  <div class=\"sec on\" id=\"sec_banner\">\n  <h3>\u0411\u0430\u043d\u043d\u0435\u0440 \u043f\u0440\u043e\u0444\u0438\u043b\u044f</h3>\n  <div class=\"card\">\n    <div class=\"row\"><div class=\"lbl\"><b>\u0412\u043a\u043b\u044e\u0447\u0438\u0442\u044c \u0431\u0430\u043d\u043d\u0435\u0440</b><span>\u0417\u0430\u043c\u0435\u043d\u044f\u0442\u044c \u0444\u043e\u043d \u0448\u0430\u043f\u043a\u0438 \u043f\u0440\u043e\u0444\u0438\u043b\u044f</span></div>\n      <label class=\"switch\"><input type=\"checkbox\" id=\"sw_banner\"><span class=\"slider\"></span></label></div>\n    <div id=\"bannerBody\">\n      <div class=\"seg\" id=\"seg_banner_mode\">\n        <button data-g=\"banner_mode\" data-v=\"0\">\u0418\u0437\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u0435</button>\n        <button data-g=\"banner_mode\" data-v=\"1\">\u0426\u0432\u0435\u0442</button>\n        <button data-g=\"banner_mode\" data-v=\"2\">\u0413\u0440\u0430\u0434\u0438\u0435\u043d\u0442</button>\n      </div>\n      <div id=\"ban_img_grp\">\n        <div class=\"btnrow\">\n          <button class=\"btn\" id=\"pick_banner\">\u0412\u044b\u0431\u0440\u0430\u0442\u044c \u0438\u0437\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u0435</button>\n          <button class=\"btn danger\" id=\"clear_banner\">\u0421\u0431\u0440\u043e\u0441\u0438\u0442\u044c</button>\n        </div>\n        <div class=\"colorRow\"><div class=\"lbl\"><b>\u041f\u0440\u043e\u0437\u0440\u0430\u0447\u043d\u043e\u0441\u0442\u044c</b><span>\u041e\u0431\u0449\u0430\u044f \u043d\u0435\u043f\u0440\u043e\u0437\u0440\u0430\u0447\u043d\u043e\u0441\u0442\u044c</span></div>\n          <input type=\"range\" min=\"0\" max=\"100\" id=\"banAlpha\" class=\"rng2\"><span class=\"hex\" id=\"l_banAlpha\">100%</span></div>\n        <div class=\"seg\" id=\"seg_banner_fade\">\n          <button data-g=\"banner_fade\" data-v=\"0\">\u0411\u0435\u0437 \u0437\u0430\u0442\u0443\u0445\u0430\u043d\u0438\u044f</button>\n          <button data-g=\"banner_fade\" data-v=\"1\">\u041b\u0438\u043d\u0435\u0439\u043d\u043e\u0435</button>\n          <button data-g=\"banner_fade\" data-v=\"2\">\u0420\u0430\u0434\u0438\u0430\u043b\u044c\u043d\u043e\u0435</button>\n        </div>\n        <div class=\"padwrap\" id=\"banFadeRow\">\n          <div class=\"pad\" id=\"bfpad\">\n            <svg class=\"pad-svg\" viewBox=\"0 0 100 100\" preserveAspectRatio=\"none\">\n              <circle class=\"pad-ringc\" id=\"bfpadRing\" cx=\"50\" cy=\"50\" r=\"30\"></circle>\n              <line class=\"pad-linel\" id=\"bfpadLine\" x1=\"50\" y1=\"50\" x2=\"50\" y2=\"10\"></line>\n              <circle class=\"pad-dot\" cx=\"50\" cy=\"50\" r=\"2.6\"></circle>\n            </svg>\n            <div class=\"pad-h\" id=\"bfpadH\"></div>\n          </div>\n          <div class=\"padmeta\">\n            <div class=\"padval\"><span id=\"bfAng\">0</span> deg &middot; <span id=\"bfRad\">100</span>%</div>\n            <label class=\"mini\" id=\"bfAngLbl\">\u041d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0435 \u0437\u0430\u0442\u0443\u0445\u0430\u043d\u0438\u044f</label>\n            <input type=\"range\" min=\"0\" max=\"360\" id=\"bfAngR\" class=\"rng\">\n            <label class=\"mini\">\u0420\u0430\u0437\u043c\u0435\u0440</label>\n            <input type=\"range\" min=\"20\" max=\"200\" id=\"bfRadR\" class=\"rng\">\n          </div>\n        </div>\n      </div>\n      <div id=\"ban_color_grp\">\n        <div class=\"colorRow\"><div class=\"lbl\"><b>\u0426\u0432\u0435\u0442 \u0431\u0430\u043d\u043d\u0435\u0440\u0430</b></div>\n          <button class=\"sw\" id=\"sw_banner_color\"></button><span class=\"hex\" id=\"l_banner_color\"></span></div>\n      </div>\n      <div id=\"ban_grad_grp\">\n        <div class=\"seg\" id=\"seg_grad_type\">\n          <button data-g=\"grad_type\" data-v=\"0\">\u041b\u0438\u043d\u0435\u0439\u043d\u044b\u0439</button>\n          <button data-g=\"grad_type\" data-v=\"1\">\u0420\u0430\u0434\u0438\u0430\u043b\u044c\u043d\u044b\u0439</button>\n        </div>\n        <div class=\"padwrap\" id=\"gradPadRow\">\n          <div class=\"pad\" id=\"gpad\">\n            <svg class=\"pad-svg\" viewBox=\"0 0 100 100\" preserveAspectRatio=\"none\">\n              <circle class=\"pad-ringc\" id=\"gpadRing\" cx=\"50\" cy=\"50\" r=\"30\"></circle>\n              <line class=\"pad-linel\" id=\"gpadLine\" x1=\"50\" y1=\"50\" x2=\"50\" y2=\"10\"></line>\n              <circle class=\"pad-dot\" cx=\"50\" cy=\"50\" r=\"2.6\"></circle>\n              <circle class=\"pad-stop\" id=\"gs0\" r=\"3.4\" cx=\"50\" cy=\"50\"></circle>\n              <circle class=\"pad-stop\" id=\"gs1\" r=\"3.4\" cx=\"50\" cy=\"50\"></circle>\n              <circle class=\"pad-stop\" id=\"gs2\" r=\"3.4\" cx=\"50\" cy=\"50\"></circle>\n            </svg>\n            <div class=\"pad-h\" id=\"gpadH\"></div>\n          </div>\n          <div class=\"padmeta\">\n            <div class=\"padval\"><span id=\"gpAng\">0</span> deg &middot; <span id=\"gpRad\">100</span>%</div>\n            <label class=\"mini\" id=\"gpAngLbl\">\u041d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0435</label>\n            <input type=\"range\" min=\"0\" max=\"360\" id=\"gpAngR\" class=\"rng\">\n            <label class=\"mini\">\u0420\u0430\u0434\u0438\u0443\u0441</label>\n            <input type=\"range\" min=\"20\" max=\"200\" id=\"gpRadR\" class=\"rng\">\n            <label class=\"mini\">\u041a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u043e \u0446\u0432\u0435\u0442\u043e\u0432</label>\n            <div class=\"seg\" id=\"seg_grad_count\">\n              <button data-g=\"grad_count\" data-v=\"2\">2</button>\n              <button data-g=\"grad_count\" data-v=\"3\">3</button>\n            </div>\n          </div>\n        </div>\n        <div class=\"colorRow\"><div class=\"lbl\"><b>\u0426\u0432\u0435\u0442 1</b></div>\n          <button class=\"sw\" id=\"sw_grad_c1\"></button><span class=\"hex\" id=\"l_grad_c1\"></span></div>\n        <div class=\"colorRow\"><div class=\"lbl\"><b>\u0426\u0432\u0435\u0442 2</b></div>\n          <button class=\"sw\" id=\"sw_grad_c2\"></button><span class=\"hex\" id=\"l_grad_c2\"></span></div>\n        <div class=\"colorRow\" id=\"grad_c3_row\"><div class=\"lbl\"><b>\u0426\u0432\u0435\u0442 3</b></div>\n          <button class=\"sw\" id=\"sw_grad_c3\"></button><span class=\"hex\" id=\"l_grad_c3\"></span></div>\n      </div>\n      <div class=\"row\"><div class=\"lbl\"><b>\u041f\u043e\u043a\u0430\u0437\u044b\u0432\u0430\u0442\u044c \u044d\u043c\u043e\u0434\u0437\u0438</b><span>\u042d\u043c\u043e\u0434\u0437\u0438 \u043f\u043e\u0432\u0435\u0440\u0445 \u0431\u0430\u043d\u043d\u0435\u0440\u0430 (\u043f\u0435\u0440\u0435\u043e\u0442\u043a\u0440\u043e\u0439\u0442\u0435 \u043f\u0440\u043e\u0444\u0438\u043b\u044c)</span></div>\n        <label class=\"switch\"><input type=\"checkbox\" id=\"sw_emoji\"><span class=\"slider\"></span></label></div>\n    </div>\n  </div>\n\n</div>\n  <div class=\"sec\" id=\"sec_avatar\">\n  <h3>Аватар</h3>\n  <div class=\"card\">\n    <div class=\"seg\" id=\"seg_avatar_shape\">\n      <button data-g=\"avatar_shape\" data-v=\"0\" title=\"Круг\"><svg viewBox='0 0 24 24' fill='currentColor'><circle cx='12' cy='12' r='9'/></svg></button>\n      <button data-g=\"avatar_shape\" data-v=\"1\" title=\"Скруглённый\"><svg viewBox='0 0 24 24' fill='currentColor'><rect x='3.5' y='3.5' width='17' height='17' rx='5.5'/></svg></button>\n      <button data-g=\"avatar_shape\" data-v=\"2\" title=\"Квадрат\"><svg viewBox='0 0 24 24' fill='currentColor'><rect x='3.5' y='3.5' width='17' height='17' rx='1.5'/></svg></button>\n      <button data-g=\"avatar_shape\" data-v=\"3\" title=\"Шестиугольник\"><svg viewBox='0 0 24 24' fill='currentColor'><polygon points='12,3 19.79,7.5 19.79,16.5 12,21 4.21,16.5 4.21,7.5'/></svg></button>\n      <button data-g=\"avatar_shape\" data-v=\"4\" title=\"Пятиугольник\"><svg viewBox='0 0 24 24' fill='currentColor'><polygon points='12,3 20.56,9.22 17.29,19.28 6.71,19.28 3.44,9.22'/></svg></button>\n      <button data-g=\"avatar_shape\" data-v=\"5\" title=\"Звезда\"><svg viewBox='0 0 24 24' fill='currentColor'><polygon points='12,3 14.23,8.93 20.56,9.22 15.61,13.17 17.29,19.28 12,15.8 6.71,19.28 8.39,13.17 3.44,9.22 9.77,8.93'/></svg></button>\n      <button data-g=\"avatar_shape\" data-v=\"6\" title=\"Сердце\"><svg viewBox='0 0 24 24' fill='currentColor'><path d='M12 20.3l-1.4-1.3C5.4 14.3 2 11.3 2 7.6 2 5 4 3 6.5 3c1.7 0 3.3 .9 4.2 2.3l.3 .4 .3-.4C12.2 3.9 13.8 3 15.5 3 18 3 20 5 20 7.6c0 3.7-3.4 6.7-8.6 11.4L12 20.3z'/></svg></button>\n      <button data-g=\"avatar_shape\" data-v=\"7\" title=\"Цветок\"><svg viewBox='0 0 24 24' fill='currentColor'><circle cx='12' cy='6' r='3.1'/><circle cx='17.2' cy='9' r='3.1'/><circle cx='17.2' cy='15' r='3.1'/><circle cx='12' cy='18' r='3.1'/><circle cx='6.8' cy='15' r='3.1'/><circle cx='6.8' cy='9' r='3.1'/><circle cx='12' cy='12' r='3.4'/></svg></button>\n      <button data-g=\"avatar_shape\" data-v=\"8\" title=\"Своя\"><svg viewBox='0 0 24 24' fill='currentColor'><path d='M3 17.2V21h3.8L17.8 10 14 6.2 3 17.2z'/><path d='M20.7 7.1c.4-.4 .4-1 0-1.4l-2.4-2.4c-.4-.4-1-.4-1.4 0L15 5.2 18.8 9l1.9-1.9z'/></svg></button>\n    </div>\n    <div class=\"colorRow\" id=\"avRadRow\"><div class=\"lbl\"><b>Радиус углов</b><span>Для скруглённой формы</span></div>\n      <input type=\"range\" min=\"0\" max=\"64\" id=\"avRad\" class=\"rng2\"><span class=\"hex\" id=\"l_avRad\">18</span></div>\n    <div class=\"colorRow\" id=\"avRoundRow\"><div class=\"lbl\"><b>Скругление углов</b><span>Сглаживание углов формы</span></div>\n      <input type=\"range\" min=\"0\" max=\"100\" id=\"avRound\" class=\"rng2\"><span class=\"hex\" id=\"l_avRound\">0</span></div>\n    <div id=\"avDrawRow\">\n      <div class=\"mini\">Нарисуйте свою форму пальцем</div>\n      <div class=\"pad\" id=\"avDraw\" style=\"width:100%;aspect-ratio:1/1;\">\n        <svg class=\"pad-svg\" id=\"avDrawSvg\" viewBox=\"0 0 100 100\" preserveAspectRatio=\"none\"><polygon id=\"avDrawPoly\" points=\"\" fill=\"rgba(90,175,250,.25)\" stroke=\"var(--accent)\" stroke-width=\"1.5\"></polygon></svg>\n      </div>\n      <div class=\"btnrow\"><button class=\"btn sec\" id=\"avDrawClear\">Очистить</button></div>\n      <div class=\"hint\">Обведите контур замкнутой линией — точки соединятся автоматически. Ползунок «Скругление углов» сглаживает контур.</div>\n    </div>\n    <div class=\"hint\">Форма применяется только к вашему профилю. Переоткройте профиль, чтобы увидеть изменение.</div>\n  </div>\n\n</div>\n  <div class=\"sec\" id=\"sec_bg\">\n  <h3>\u0424\u043e\u043d \u043f\u0440\u043e\u0444\u0438\u043b\u044f (\u0438\u043d\u0442\u0435\u0440\u0444\u0435\u0439\u0441)</h3>\n  <div class=\"card\">\n    <div class=\"row\"><div class=\"lbl\"><b>\u0412\u043a\u043b\u044e\u0447\u0438\u0442\u044c \u0441\u0432\u043e\u0439 \u0444\u043e\u043d</b><span>\u041e\u0431\u0449\u0438\u0439 \u0444\u043e\u043d \u0437\u0430 \u0441\u043f\u0438\u0441\u043a\u043e\u043c \u043f\u0440\u043e\u0444\u0438\u043b\u044f</span></div>\n      <label class=\"switch\"><input type=\"checkbox\" id=\"sw_bg\"><span class=\"slider\"></span></label></div>\n    <div id=\"bgBody\">\n      <div class=\"seg\" id=\"seg_bg_mode\">\n        <button data-g=\"bg_mode\" data-v=\"0\">\u0426\u0432\u0435\u0442</button>\n        <button data-g=\"bg_mode\" data-v=\"1\">\u0418\u0437\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u0435</button>\n      </div>\n      <div id=\"bgc_color_grp\">\n        <div class=\"colorRow\"><div class=\"lbl\"><b>\u0426\u0432\u0435\u0442 \u0444\u043e\u043d\u0430</b></div>\n          <button class=\"sw\" id=\"sw_bg_color\"></button><span class=\"hex\" id=\"l_bg_color\"></span></div>\n      </div>\n      <div id=\"bgc_img_grp\">\n        <div class=\"btnrow\">\n          <button class=\"btn\" id=\"pick_bg\">\u0412\u044b\u0431\u0440\u0430\u0442\u044c \u0438\u0437\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u0435</button>\n          <button class=\"btn danger\" id=\"clear_bg\">\u0421\u0431\u0440\u043e\u0441\u0438\u0442\u044c</button>\n        </div>\n        <div class=\"colorRow\"><div class=\"lbl\"><b>\u041f\u0440\u043e\u0437\u0440\u0430\u0447\u043d\u043e\u0441\u0442\u044c</b><span>\u041e\u0431\u0449\u0430\u044f \u043d\u0435\u043f\u0440\u043e\u0437\u0440\u0430\u0447\u043d\u043e\u0441\u0442\u044c</span></div>\n          <input type=\"range\" min=\"0\" max=\"100\" id=\"bgAlpha\" class=\"rng2\"><span class=\"hex\" id=\"l_bgAlpha\">100%</span></div>\n        <div class=\"seg\" id=\"seg_bg_fade\">\n          <button data-g=\"bg_fade\" data-v=\"0\">\u0411\u0435\u0437 \u0437\u0430\u0442\u0443\u0445\u0430\u043d\u0438\u044f</button>\n          <button data-g=\"bg_fade\" data-v=\"1\">\u041b\u0438\u043d\u0435\u0439\u043d\u043e\u0435</button>\n          <button data-g=\"bg_fade\" data-v=\"2\">\u0420\u0430\u0434\u0438\u0430\u043b\u044c\u043d\u043e\u0435</button>\n        </div>\n        <div class=\"padwrap\" id=\"bgFadeRow\">\n          <div class=\"pad\" id=\"bgfpad\">\n            <svg class=\"pad-svg\" viewBox=\"0 0 100 100\" preserveAspectRatio=\"none\">\n              <circle class=\"pad-ringc\" id=\"bgfpadRing\" cx=\"50\" cy=\"50\" r=\"30\"></circle>\n              <line class=\"pad-linel\" id=\"bgfpadLine\" x1=\"50\" y1=\"50\" x2=\"50\" y2=\"10\"></line>\n              <circle class=\"pad-dot\" cx=\"50\" cy=\"50\" r=\"2.6\"></circle>\n            </svg>\n            <div class=\"pad-h\" id=\"bgfpadH\"></div>\n          </div>\n          <div class=\"padmeta\">\n            <div class=\"padval\"><span id=\"bgfAng\">0</span> deg &middot; <span id=\"bgfRad\">100</span>%</div>\n            <label class=\"mini\" id=\"bgfAngLbl\">\u041d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0435 \u0437\u0430\u0442\u0443\u0445\u0430\u043d\u0438\u044f</label>\n            <input type=\"range\" min=\"0\" max=\"360\" id=\"bgfAngR\" class=\"rng\">\n            <label class=\"mini\">\u0420\u0430\u0437\u043c\u0435\u0440</label>\n            <input type=\"range\" min=\"20\" max=\"200\" id=\"bgfRadR\" class=\"rng\">\n          </div>\n        </div>\n      </div>\n    </div>\n    <div class=\"hint\">\u041a\u0430\u0440\u0442\u043e\u0447\u043a\u0438 \u043f\u0440\u043e\u0444\u0438\u043b\u044f \u0438\u043c\u0435\u044e\u0442 \u0441\u0432\u043e\u0439 \u0444\u043e\u043d, \u043f\u043e\u044d\u0442\u043e\u043c\u0443 \u0446\u0432\u0435\u0442/\u043a\u0430\u0440\u0442\u0438\u043d\u043a\u0430 \u0432\u0438\u0434\u043d\u044b \u0432 \u043f\u0440\u043e\u043c\u0435\u0436\u0443\u0442\u043a\u0430\u0445 \u0438 \u043f\u043e \u043a\u0440\u0430\u044f\u043c.</div>\n  </div>\n\n</div>\n  <div class=\"sec\" id=\"sec_share\">\n  <h3>\u041e\u0431\u043c\u0435\u043d \u043f\u0440\u043e\u0444\u0438\u043b\u044f\u043c\u0438</h3>\n  <div class=\"card\">\n    <div class=\"row\"><div class=\"lbl\"><b>\u0414\u0435\u043b\u0438\u0442\u044c\u0441\u044f \u043c\u043e\u0438\u043c \u043f\u0440\u043e\u0444\u0438\u043b\u0435\u043c</b><span>\u041f\u0443\u0431\u043b\u0438\u043a\u043e\u0432\u0430\u0442\u044c \u043e\u0444\u043e\u0440\u043c\u043b\u0435\u043d\u0438\u0435 \u043d\u0430 \u0441\u0435\u0440\u0432\u0435\u0440</span></div>\n      <label class=\"switch\"><input type=\"checkbox\" id=\"sw_share\"><span class=\"slider\"></span></label></div>\n    <div class=\"btnrow\"><button class=\"btn\" id=\"btn_publish\">\u041e\u043f\u0443\u0431\u043b\u0438\u043a\u043e\u0432\u0430\u0442\u044c \u043c\u043e\u0439 \u043f\u0440\u043e\u0444\u0438\u043b\u044c</button></div>\n    <div class=\"hint\">\u041e\u0442\u043f\u0440\u0430\u0432\u043b\u044f\u0435\u0442 \u043a\u0430\u0440\u0442\u0438\u043d\u043a\u0443 \u0431\u0430\u043d\u043d\u0435\u0440\u0430 \u0438 \u043d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0438, \u0447\u0442\u043e\u0431\u044b \u0434\u0440\u0443\u0433\u0438\u0435 \u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u0438 \u043f\u043b\u0430\u0433\u0438\u043d\u0430 \u0432\u0438\u0434\u0435\u043b\u0438 \u0432\u0430\u0448 \u043f\u0440\u043e\u0444\u0438\u043b\u044c.</div>\n  </div>\n  </div>\n</div>\n\n<script>\nvar INIT = /*__INIT__*/;\nvar S = INIT.state;\nif(S.grad_angle==null) S.grad_angle=0;\nif(S.grad_radius==null) S.grad_radius=100;\nif(S.grad_count==null) S.grad_count=(S.grad_use3?3:2);\nif(S.grad_use3==null) S.grad_use3=(S.grad_count>=3);\nif(S.banner_alpha==null) S.banner_alpha=100;\nif(S.banner_fade==null) S.banner_fade=0;\nif(S.banner_fade_angle==null) S.banner_fade_angle=0;\nif(S.banner_fade_radius==null) S.banner_fade_radius=100;\nif(S.bg_alpha==null) S.bg_alpha=100;\nif(S.bg_fade==null) S.bg_fade=0;\nif(S.bg_fade_angle==null) S.bg_fade_angle=0;\nif(S.bg_fade_radius==null) S.bg_fade_radius=100;\nif(S.avatar_shape==null) S.avatar_shape=0;\nif(S.avatar_radius==null) S.avatar_radius=18;\nif(S.avatar_round==null) S.avatar_round=0;\nif(S.avatar_custom==null) S.avatar_custom=\"\";\n  if(S.grad_cx==null) S.grad_cx=0.5;\n  if(S.grad_cy==null) S.grad_cy=0.5;\n  if(S.banner_fade_cx==null) S.banner_fade_cx=0.5;\n  if(S.banner_fade_cy==null) S.banner_fade_cy=0.5;\n  if(S.bg_fade_cx==null) S.bg_fade_cx=0.5;\n  if(S.bg_fade_cy==null) S.bg_fade_cy=0.5;\nvar IMG = INIT.images || {banner:\"\", bg:\"\"};\nvar SNAP = INIT.snapshot || \"\";\nvar padRefreshers=[];\nvar colorRefreshers={};\nfunction $(id){ return document.getElementById(id); }\nfunction alphaOf(a){ return parseInt(a.slice(1,3),16); }\nfunction rgbOf(a){ return \"#\"+a.slice(3); }\nfunction mkArgb(rgb, al){ var h = al.toString(16).toUpperCase(); if(h.length<2) h=\"0\"+h; return \"#\"+h+rgb.slice(1).toUpperCase(); }\nfunction css(a){ var al=alphaOf(a)/255, r=parseInt(a.slice(3,5),16), g=parseInt(a.slice(5,7),16), b=parseInt(a.slice(7,9),16); return \"rgba(\"+r+\",\"+g+\",\"+b+\",\"+al+\")\"; }\n\nvar __seq=0, __q=[], __busy=false;\nfunction bridge(u){ __q.push(u); __flush(); }\nfunction __flush(){ if(__busy||!__q.length) return; __busy=true; var u=__q.shift(); __seq++;\n  try { document.title = \"CPBMSG:\" + __seq + \":\" + u; } catch(e){}\n  setTimeout(function(){ __busy=false; __flush(); }, 150); }\nvar __lastH=0;\nfunction reportHeight(){ var b=document.body; if(!b) return; var h=Math.ceil(b.offsetHeight)+2;\n  if(!h || Math.abs(h-__lastH)<2) return; __lastH=h; bridge(\"cpb://h?v=\"+h); reportPadRect(); }\nfunction scheduleHeight(){ requestAnimationFrame(reportHeight); setTimeout(reportHeight,60); }\n\nfunction gradientCss(){\n  var cols=[css(S.grad_c1), css(S.grad_c2)];\n  if(S.grad_count>=3) cols.push(css(S.grad_c3));\n  var list=cols.join(\",\");\n  var rad=(S.grad_radius==null?100:S.grad_radius);\n  if(S.grad_type==1){ var gcx=(S.grad_cx==null?0.5:S.grad_cx)*100, gcy=(S.grad_cy==null?0.5:S.grad_cy)*100; return \"radial-gradient(circle \"+(rad/2)+\"% at \"+gcx+\"% \"+gcy+\"%,\"+list+\")\"; }\n  var ang=(S.grad_angle==null?0:S.grad_angle);\n  return \"linear-gradient(\"+ang+\"deg,\"+list+\")\";\n}\nfunction applyBanner(){\n  var el=$(\"phBanner\");\n  if(S.banner_mode==0){\n    if(IMG.banner){ el.style.backgroundImage=\"url('\"+IMG.banner+\"')\"; el.style.backgroundColor=\"\"; }\n    else { el.style.backgroundImage=\"\"; el.style.backgroundColor=\"#8a8a8a\"; }\n    el.style.opacity=(S.banner_alpha==null?1:S.banner_alpha/100);\n  } else if(S.banner_mode==1){\n    el.style.backgroundImage=\"none\"; el.style.backgroundColor=css(S.banner_color); el.style.opacity=1;\n  } else {\n    el.style.backgroundImage=gradientCss(); el.style.backgroundColor=\"\"; el.style.opacity=1;\n  }\n  $(\"phEmoji\").style.display = S.show_emoji ? \"block\" : \"none\";\n}\nfunction applyBg(){\n  var el=$(\"phBody\");\n  if(!S.bg_enabled){ el.style.backgroundImage=\"none\"; el.style.backgroundColor=\"var(--gray)\"; el.style.opacity=1; return; }\n  if(S.bg_mode==1){\n    if(IMG.bg){ el.style.backgroundImage=\"url('\"+IMG.bg+\"')\"; el.style.backgroundColor=\"\"; }\n    else { el.style.backgroundImage=\"none\"; el.style.backgroundColor=\"#666\"; }\n    el.style.opacity=(S.bg_alpha==null?1:S.bg_alpha/100);\n  } else { el.style.backgroundImage=\"none\"; el.style.backgroundColor=css(S.bg_color); el.style.opacity=1; }\n}\nfunction show(id,on){ var e=$(id); if(e) e.style.display = on ? \"\" : \"none\"; }\nvar AV_CLIP={3:\"polygon(50.00% 0.00%, 93.30% 25.00%, 93.30% 75.00%, 50.00% 100.00%, 6.70% 75.00%, 6.70% 25.00%)\",4:\"polygon(50.00% 0.00%, 97.55% 34.55%, 79.39% 90.45%, 20.61% 90.45%, 2.45% 34.55%)\",5: