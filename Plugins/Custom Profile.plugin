def _ui_optional(_name):
    # Some symbols (e.g. SimpleSettingFactory) only exist on newer SDKs.
    # Never let a missing name crash the whole plugin import.
    try:
        return getattr(_uisettings, _name)
    except Exception:
        return None


Custom = _ui_optional("Custom")
SimpleSettingFactory = _ui_optional("SimpleSettingFactory")
Header = _ui_optional("Header")
Text = _ui_optional("Text")
