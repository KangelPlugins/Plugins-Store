[0]; if(t){ pt(t.clientX,t.clientY); e.preventDefault(); } } }, {passive:false});\n    window.addEventListener(\"touchend\", function(){ down=false; });\n    window.addEventListener(\"touchcancel\", function(){ down=false; });\n    el.addEventListener(\"mousedown\", function(e){ down=true; pt(e.clientX,e.clientY); e.preventDefault(); });\n    window.addEventListener(\"mousemove\", function(e){ if(down){ pt(e.clientX,e.clientY); e.preventDefault(); } });\n    window.addEventListener(\"mouseup\", function(){ down=false; });\n  }\n}\nfunction makePad(o){\n  function ref(){\n    var ang=(S[o.af]==null?0:S[o.af]), rad=(S[o.rf]==null?100:S[o.rf]);\n    var radial=o.isRadial();\n    var frac=Math.min(1, rad/200), R=46;\n    var cx=(o.cxf&&S[o.cxf]!=null?S[o.cxf]:0.5), cy=(o.cyf&&S[o.cyf]!=null?S[o.cyf]:0.5);\n    var ccx=cx*100, ccy=cy*100;\n    var rr=ang*Math.PI/180, ux=Math.sin(rr), uy=-Math.cos(rr);\n    var hx, hy;\n    if(radial){ hx=ccx; hy=ccy; } else { hx=50+ux*frac*R; hy=50+uy*frac*R; }\n    if(o.hand){ o.hand.style.left=hx+\"%\"; o.hand.style.top=hy+\"%\"; }\n    if(o.line){ o.line.style.display=radial?\"none\":\"\"; if(!radial){ o.line.setAttribute(\"x1\",(50-ux*frac*R)); o.line.setAttribute(\"y1\",(50-uy*frac*R)); o.line.setAttribute(\"x2\",hx); o.line.setAttribute(\"y2\",hy); } }\n    if(o.ring){ o.ring.style.display=radial?\"\":\"none\"; if(radial){ o.ring.setAttribute(\"cx\",ccx); o.ring.setAttribute(\"cy\",ccy); o.ring.setAttribute(\"r\",(frac*R)); } }\n    if(o.angEl) o.angEl.textContent=Math.round(ang);\n    if(o.radEl) o.radEl.textContent=Math.round(rad);\n    if(o.angR && +o.angR.value!==Math.round(ang)) o.angR.value=Math.round(ang);\n    if(o.radR && +o.radR.value!==Math.round(rad)) o.radR.value=Math.round(rad);\n    if(o.onRef) o.onRef(ang,rad,radial,frac,ux,uy,R,cx,cy);\n  }\n  if(o.pad) bindDrag(o.pad, function(px,py){\n    if(o.isRadial() && o.cxf){\n      S[o.cxf]=Math.max(0, Math.min(1, px));\n      S[o.cyf]=Math.max(0, Math.min(1, py));\n    } else {\n      var x=px-0.5, y=py-0.5;\n      var ang=Math.atan2(x,-y)*180/Math.PI; if(ang<0) ang+=360;\n      var d=Math.min(0.5, Math.sqrt(x*x+y*y))/0.5;\n      S[o.af]=Math.round(ang);\n      S[o.rf]=Math.max(20, Math.min(200, Math.round(d*200)));\n    }\n    ref(); render(); sync();\n  });\n  if(o.angR) o.angR.addEventListener(\"input\", function(){ S[o.af]=parseInt(this.value)||0; ref(); render(); sync(); });\n  if(o.radR) o.radR.addEventListener(\"input\", function(){ S[o.rf]=parseInt(this.value)||100; ref(); render(); sync(); });\n  padRefreshers.push(ref);\n  return ref;\n}\nfunction gradStops(ang,rad,radial,frac,ux,uy,R,cx,cy){\n  var count=(S.grad_count>=3?3:2);\n  var cs=[S.grad_c1,S.grad_c2,S.grad_c3];\n  var ids=[\"gs0\",\"gs1\",\"gs2\"];\n  var ccx=(cx==null?0.5:cx)*100, ccy=(cy==null?0.5:cy)*100;\n  var sx=50-ux*frac*R, sy=50-uy*frac*R, ex=50+ux*frac*R, ey=50+uy*frac*R;\n  for(var i=0;i<3;i++){ var el=$(ids[i]); if(!el) continue;\n    if(i>=count){ el.style.display=\"none\"; continue; } el.style.display=\"\";\n    var t=count>1?i/(count-1):0, x, y;\n    if(radial){ x=ccx+ux*t*frac*R; y=ccy+uy*t*frac*R; }\n    else { x=sx+(ex-sx)*t; y=sy+(ey-sy)*t; }\n    el.setAttribute(\"cx\",x); el.setAttribute(\"cy\",y); el.setAttribute(\"fill\", css(cs[i]));\n  }\n}\nfunction initGradPad(){\n  makePad({ pad:$(\"gpad\"), hand:$(\"gpadH\"), line:$(\"gpadLine\"), ring:$(\"gpadRing\"),\n    angEl:$(\"gpAng\"), radEl:$(\"gpRad\"), angR:$(\"gpAngR\"), radR:$(\"gpRadR\"),\n    af:\"grad_angle\", rf:\"grad_radius\", cxf:\"grad_cx\", cyf:\"grad_cy\", isRadial:function(){ return S.grad_type==1; }, onRef:gradStops });\n}\nfunction initFadePads(){\n  makePad({ pad:$(\"bfpad\"), hand:$(\"bfpadH\"), line:$(\"bfpadLine\"), ring:$(\"bfpadRing\"),\n    angEl:$(\"bfAng\"), radEl:$(\"bfRad\"), angR:$(\"bfAngR\"), radR:$(\"bfRadR\"),\n    af:\"banner_fade_angle\", rf:\"banner_fade_radius\", cxf:\"banner_fade_cx\", cyf:\"banner_fade_cy\", isRadial:function(){ return S.banner_fade==2; }