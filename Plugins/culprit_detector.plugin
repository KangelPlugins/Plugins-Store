                elif not _resolved_any:
                    _ureason = "unresolved-native: no frame resolved to a module (anon/JIT/unmapped)"
                else:
                    _ureason = "unresolved-native: top fault frame unmapped"
                rec["confidence"] = "low"
                rec["unattributed_reason"] = _ureason
                try:
                    _ha_top = (rec.get("top_so") or "").lower()
                    _ha_managed = bool(rec.get("managed_frame")) or bool(rec.get("managed_mod")) or any(_x in _ha_top for _x in (".oat", ".art", ".odex", "dalvik-cache"))
                    _ha_inproc = (rec.get("corroboration") == "inprocess_only") or (rec.get("tombstone_source") == "inprocess_native_dump")
                    if _ha_managed:
                        rec["advisory_kind"] = "managed_art_sigsegv"
                        rec["native_advisory"] = ("вероятно ART/managed SIGSEGV (top_so=%s%s) -- краш внутри среды ART, не в нативном коде плагина%s" % (rec.get("top_so") or "?", (", managed_mod=%s" % rec.get("managed_mod")) if rec.get("managed_mod") else "", " [только in-process дамп: logcat запечатан хостом]" if _ha_inproc else ""))
                        _log("Block#4C +HA: managed/ART SIGSEGV advisory -> %s" % rec["native_advisory"])
                except Exception as _eha:
