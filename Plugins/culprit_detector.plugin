def _gate_verdict_log(rec, when):
    try:
        _log("============= PRE-IMPORT/GATE VERDICT (%s) =============" % when)
        cul = rec.get("culprit"); conf = rec.get("confidence")
        if cul and cul != "unknown":
            _log("ВИНОВНИК ВОРОТ ЗАГРУЗКИ: %r conf=%s kind=%s src=%s" % (cul, conf, rec.get("kind"), rec.get("src")))
        else:
            _log("ВИНОВНИК ВОРОТ ЗАГРУЗКИ: неизвестен (kind=%s)" % rec.get("kind"))
        _log("  причина: %s" % rec.get("reason"))
        pf = rec.get("py_file")
        if pf: _log("  модуль: %s:%s" % (pf, rec.get("py_line")))
        ex = rec.get("extra")
        if ex: _log("  детали: %s" % ex)
        ec = rec.get("exc_cls")
        if ec and ec != "?": _log("  исключение: %s: %s" % (ec, rec.get("exc_msg")))
        _log("=======================================================")
    except Exception: pass

def _b11_scan(reason="scan"):
    if not _BLOCK11_ON: return
    try:
        sm = _b11_safe_mode()
        if sm is True:
            _record_gate_fail(None, "safe-mode",
                              "движок в SAFE-MODE -> плагины не загружаются (тихо, без исключения)",
                              extra="ExteraConfig.getPluginsSafeMode()=true")
    except Exception: pass
    rt_sdk = _b11_runtime_sdk()
    entries = _b11_plugin_entries()
    for ent in entries:
        try:
            pid = str(ent.getKey())
            pj = ent.getValue()
        except Exception:
            continue
        if pj is None: continue
        err = _b11_attr(pj, "getError", "error")
        if err is not None:
            try: _intern(pid); _save_known(pid)
            except Exception: pass
            _record_gate_fail(pid, "error",
                              "движок проглотил исключение загрузки (plugins[%s].error)" % pid, thr=err)
            continue
        try:
            if _b11_is_loaded(pid): continue
        except Exception: pass
        psdk = _b11_attr(pj, "getSdkVersion", "sdkVersion")
        psdk = str(psdk) if psdk is not None else ""
        pav = _b11_attr(pj, "getAppVersion", "appVersion")
        pav = str(pav) if pav is not None else ""
        req = _b11_attr(pj, "getRequirements", "requirements")
        try: req = list(req) if req is not None else []
        except Exception: req = []
        if rt_sdk and psdk and psdk != rt_sdk and rt_sdk != "unknown":
            _record_gate_fail(pid, "sdk-version",
                              "несовпадение sdk_version (плагин=%s, рантайм=%s) -> вероятная тихая не-загрузка" % (psdk, rt_sdk),
                              extra="app_version(min)=%s requirements=%s" % (pav or "-", req or "-"))

def _b11_install_scan():
    for delay in (3.0, 8.0):
        try:
            t = threading.Timer(delay, lambda d=delay: _b11_scan("post-load+%ss" % int(d)))
            t.daemon = True; t.start()
        except Exception as e:
            try: _log("Block#11: scan timer err: %s" % e)
            except Exception: pass

def _jc(name):
    try:
        return jclass(name)
    except Exception:
        try:
            from java import jclass as _j
            return _j(name)
        except Exception:
            return None

def _oom_path(name=None):
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, name or _OOM_FILE_NAME).getAbsolutePath()
    except Exception:
        return None

def _java_mem():
    ju = -1; jm = -1; nh = -1
    try:
        rt = _jc("java.lang.Runtime").getRuntime()
        jm = int(rt.maxMemory()); ju = int(rt.totalMemory()) - int(rt.freeMemory())
    except Exception:
        pass
    try:
        nh = int(_jc("android.os.Debug").getNativeHeapAllocatedSize())
    except Exception:
        pass
    return ju, jm, nh

_UNTAGGED_LABEL = "⟨untagged⟩"

def _oom_verdict(odump):
    try:
        top = list(odump.get("top") or [])
    except Exception:
        top = []
    untagged = 0; real = []; total_attr = 0
    for kv in top:
        try:
            name = kv[0]; b = int(kv[1])
        except Exception:
            continue
        if b < 0: b = 0
        total_attr += b
        if name == _UNTAGGED_LABEL:
            untagged += b
        else:
            real.append((name, b))
    real.sort(key=lambda x: x[1], reverse=True)
    denom = total_attr if total_attr > 0 else 1
    culprit = real[0][0] if real else None
    culprit_bytes = real[0][1] if real else 0
    second_bytes = real[1][1] if len(real) > 1 else 0
    share = float(culprit_bytes) / float(denom)
    untagged_share = float(untagged) / float(denom)
    margin = (float(culprit_bytes - second_bytes) / float(culprit_bytes)) if culprit_bytes > 0 else 0.0
    try:
        rate = float(odump.get("rate_mbps") or 0.0)
    except Exception:
        rate = 0.0
    tagged_total = total_attr - untagged
    tagged_share = (float(culprit_bytes) / float(tagged_total)) if tagged_total > 0 else 0.0
    if culprit is None:
        conf = "low"
        display = _UNTAGGED_LABEL if untagged > 0 else None
        reason_detail = "no_attribution"
    elif untagged > culprit_bytes:
        if rate >= 15.0 and tagged_share >= 0.80 and culprit_bytes > 524288:
            conf = "medium"
            display = culprit
            reason_detail = "async_download_pattern"
        elif rate >= 50.0 and culprit_bytes > 262144:
            conf = "low"
            display = culprit
            reason_detail = "rate_suspect"
        else:
            conf = "low"
            display = _UNTAGGED_LABEL
            reason_detail = "untagged_dominates"
    elif share >= 0.60 and untagged_share <= 0.25 and margin >= 0.50:
        conf = "high"; display = culprit; reason_detail = "clear_leader"
    elif share >= 0.30 and untagged_share <= 0.50:
        conf = "medium"; display = culprit; reason_detail = "probable_leader"
    else:
        conf = "low"; display = culprit; reason_detail = "weak_leader"
    is_unt = (display == _UNTAGGED_LABEL)
    display_bytes = untagged if is_unt else culprit_bytes
    display_share = untagged_share if is_unt else share
    return {"culprit": display, "top_named": culprit, "top_named_bytes": culprit_bytes,
            "culprit_bytes": culprit_bytes, "second_bytes": second_bytes,
            "margin": round(margin, 4), "share": round(share, 4),
            "display_bytes": display_bytes, "display_share": round(display_share, 4),
            "untagged_bytes": untagged, "untagged_share": round(untagged_share, 4),
            "rate_mbps": round(rate, 2), "reason": odump.get("reason"),
            "reason_detail": reason_detail, "confidence": conf}

def _oom_verdict_log(odump, where):
    try:
        v = _oom_verdict(odump)
    except Exception as e:
        try: _log(f"OOM verdict err: {e}")
        except Exception: pass
        return None
    cul = v.get("culprit")
    if cul is None:
        return v
    _OOM_RD_TXT = {
        "untagged_dominates": "untagged dominates; named plugin too small to explain OOM",
        "no_attribution": "no attribution; all memory untagged (raw threads / Part A .so)",
        "clear_leader": "clear leader",
        "probable_leader": "probable leader",
        "weak_leader": "weak leader; low confidence",
        "async_download_pattern": "async HTTP/network: plugin dominates tagged; untagged = urllib3/TCP/JNI buffers outside scope",
        "rate_suspect": "fast growth rate with active named plugin; untagged dominates",
    }
    rd = v.get("reason_detail")
    _log("================ OOM VERDICT (%s) ================" % where)
    _log("ВИНОВНИК OOM(память): %r conf=%s доля=%.0f%% (%dB) отрыв=%.0f%% rate=%sMB/s untagged=%.0f%% reason=%s" % (
        cul, v["confidence"], v["display_share"]*100.0, v["display_bytes"],
        v["margin"]*100.0, v["rate_mbps"], v["untagged_share"]*100.0, v.get("reason")))
    if cul == _UNTAGGED_LABEL:
        tn = v.get("top_named"); tnb = int(v.get("top_named_bytes") or 0)
        if tn:
            _log("  top_named=%s %dB" % (tn, tnb))
        _log("  reason: %s" % _OOM_RD_TXT.get(rd, rd))
        _log("  → виновник по памяти не определён достоверно (named-плагин не объясняет OOM)")
    elif rd in ("async_download_pattern", "rate_suspect"):
        tn = v.get("top_named"); tnb = int(v.get("top_named_bytes") or 0)
        unt = int(v.get("untagged_bytes") or 0)
        _async_ratio = round(float(unt) / float(tnb), 1) if tnb > 0 else 0.0
        _named_pct = round(float(tnb) / float(tnb + unt) * 100.0, 1) if (tnb + unt) > 0 else 0.0
        _log("  named=%s %dB untagged=%dB async_ratio=%.1fx named_pct=%.1f%%" % (
            tn, tnb, unt, _async_ratio, _named_pct))
        _log("  reason: %s" % _OOM_RD_TXT.get(rd, rd))
        _log("  → виновник определён по async-паттерну: буферы HTTP-загрузки вне scope падают в untagged")
    else:
        _log("  reason: %s" % _OOM_RD_TXT.get(rd, rd))
    _log("=================================================")
    return v

def _oom_persist(rec):
    try:
        hp = _oom_path("oom_dump_%d.json" % rec["ts"])
        if hp:
            _atomic_json_write(hp, rec)
    except Exception:
        pass
    p = _oom_path()
    if not p: return
    _atomic_json_write(p, rec)

def _oom_log_dump(rec):
    m = rec.get("mem", {})
    pc = m.get("pct"); pcs = round(pc*100,1) if (pc is not None and pc>=0) else -1
    _log("================ PRE-OOM DUMP ================")
    _log(f'PRE-OOM trigger: reason={rec.get("reason")} rate={rec.get("rate_mbps")}MB/s')
    _log(f'  mem: src={m.get("src")} used={m.get("used")}B limit={m.get("limit")}B pct={pcs}%')
    _log(f'  rss={m.get("rss")}B native_heap={m.get("native_heap")}B java={m.get("java_used")}/{m.get("java_max")}B cgroup={m.get("cg_cur")}/{m.get("cg_max")}B')
    _log(f'  tracked: cd_total={m.get("cd_total")}B live={rec.get("native_live")} dropped={rec.get("dropped")}')
    if rec.get("direct_total") is not None:
        _log(f'  direct(NIO off-heap): live={rec.get("direct_live_total")}B cumulative={rec.get("direct_total")}B untagged_live={rec.get("direct_live_untagged")}B')
    _log(f'  TOP-{_OOM_TOPN} consumers (plugin: bytes [native_live+direct_live]):')
    for i, kv in enumerate(rec.get("top", [])):
        try: _log(f'    #{i+1} {kv[0]}: {int(kv[1])}B')
        except Exception: pass
    try: _oom_verdict_log(rec, "live")
    except Exception: pass
    _log("==============================================")

def _read_and_clear_oom_dump():
    p = _oom_path()
    if not p: return None
    rec = None
    try:
        if os.path.exists(p):
            with open(p, "r", encoding="utf-8") as f:
                rec = json.load(f)
    except Exception:
        rec = None
    try:
        if os.path.exists(p): os.remove(p)
    except Exception:
        pass
    return rec

import struct as _struct
_OOM_HDR_FMT = "<II12q4i"
_OOM_HDR_LEN = _struct.calcsize(_OOM_HDR_FMT)
_OOM_TOP_FMT = "<iiq"
_OOM_TOP_LEN = _struct.calcsize(_OOM_TOP_FMT)
_OOM_MAGIC = 0x4F4F4D32

def _oom_sentinel_path():
    return _oom_path(_OOM_SENTINEL_NAME)

def _oom_decode_sentinel(blob):
    if not blob or len(blob) < _OOM_HDR_LEN:
        return None
    h = _struct.unpack_from(_OOM_HDR_FMT, blob, 0)
    (magic, ver, ts_ms, used, limit, rate_milli, cd_total, untagged, live_count,
        dropped, dropped_bytes, rss, cg_cur, cg_max, reason, src, topn, _pad) = h
    if magic != _OOM_MAGIC:
        return None
    topn = max(0, min(int(topn), 64))
    tops = []
    off = _OOM_HDR_LEN
    for _ in range(topn):
        if off + _OOM_TOP_LEN > len(blob): break
        idx, _p, b = _struct.unpack_from(_OOM_TOP_FMT, blob, off)
        off += _OOM_TOP_LEN
        if idx >= 0 and b > 0:
            tops.append((int(idx), int(b)))
    return {"ver": int(ver), "ts_ms": int(ts_ms), "used": int(used), "limit": int(limit),
            "rate_mbps": (rate_milli / 1000.0), "cd_total": int(cd_total),
            "untagged": int(untagged), "live_count": int(live_count),
            "dropped": int(dropped), "dropped_bytes": int(dropped_bytes),
            "rss": int(rss), "cg_cur": int(cg_cur), "cg_max": int(cg_max),
            "reason_bits": int(reason), "src_code": int(src), "tops": tops}

def _direct_pm_path():
    return _oom_path(_DIRECT_PM_NAME)

def _direct_premortem_dump():
    try:
        p = _direct_pm_path()
        if not p: return
        d = _direct_snapshot()
        d["ts"] = int(time.time() * 1000)
        _atomic_json_write(p, d)
    except Exception:
        pass

def _direct_premortem_read_and_clear():
    try:
        p = _direct_pm_path()
        if not p: return None
        d = None
        if os.path.exists(p):
            with open(p, "r", encoding="utf-8") as f:
                d = json.load(f)
        try:
            if os.path.exists(p): os.remove(p)
        except Exception: pass
        return d
    except Exception:
        return None

def _oom_sentinel_to_rec(s, merge_direct=False, direct_snap=None):
    src = {0: "cgroup", 1: "rss", 2: "none", 3: "meminfo"}.get(s["src_code"], "native")
    used = s["used"]; limit = s["limit"]
    pct = (float(used) / float(limit)) if (limit and limit > 0 and used >= 0) else -1.0
    ju, jm, nh = (-1, -1, -1)
    try: ju, jm, nh = _java_mem()
    except Exception: pass
    m = {"used": used, "limit": limit, "src": src, "pct": pct,
         "java_used": ju, "java_max": jm, "native_heap": nh,
         "rss": s["rss"], "cg_cur": s["cg_cur"], "cg_max": s["cg_max"],
         "cd_total": s["cd_total"]}
    top = []
    for idx, b in s["tops"]:
        nm = _resolve_idx(idx) or ("idx%d" % idx)
        top.append([nm, int(b)])
    if s["untagged"] > 0:
        top.append([_UNTAGGED_LABEL, int(s["untagged"])])
    direct_fields = {}
    _ds = direct_snap if direct_snap is not None else (_direct_snapshot() if merge_direct else None)
    if _ds is not None:
        _cum = direct_snap is not None
        try:
            if _cum:
                _by = _ds.get("by_pid") or {}; _unt = int(_ds.get("untagged", 0) or 0)
            else:
                _by = _ds.get("live_by_pid") or {}; _unt = int(_ds.get("live_untagged", 0) or 0)
            _combined = {}
            for _nm, _b in top:
                _combined[_nm] = _combined.get(_nm, 0) + int(_b)
            for _pid, _b in _by.items():
                _combined[_pid] = _combined.get(_pid, 0) + int(_b)
            if _unt > 0:
                _combined[_UNTAGGED_LABEL] = _combined.get(_UNTAGGED_LABEL, 0) + _unt
            top = [[_k, _v] for _k, _v in _combined.items()]
            direct_fields = {
                "direct_total": int(_ds.get("total", 0) or 0), "direct_untagged": int(_ds.get("untagged", 0) or 0),
                "direct_live_total": int(_ds.get("live_total", 0) or 0), "direct_live_untagged": int(_ds.get("live_untagged", 0) or 0),
                "direct_merged": ("cumulative" if _cum else "live"),
            }
        except Exception:
            direct_fields = {}
    top.sort(key=lambda kv: kv[1], reverse=True)
    top = top[:_OOM_TOPN]
    rbits = s["reason_bits"]; hit = []
    if rbits & 1: hit.append("pct>=%d%%" % int(_OOM_PCT*100))
    if rbits & 2: hit.append("rate>=%dMB/s" % int(_OOM_RATE_MBPS))
    rec = {"had_oom": True, "reason": "+".join(hit) or "native", "ts": s["ts_ms"],
           "mem": m, "rate_mbps": round(s["rate_mbps"], 2),
           "thr_pct": _OOM_PCT, "thr_rate_mbps": _OOM_RATE_MBPS,
           "top": top, "native_total": s["cd_total"], "native_live": s["live_count"],
           "dropped": s["dropped"], "dropped_bytes": s["dropped_bytes"], "src": "native"}
    if direct_fields: rec.update(direct_fields)
    try: rec["verdict"] = _oom_verdict(rec)
    except Exception: pass
    return rec

def _oom_consume_native(where, do_log=True):
    p = _oom_sentinel_path()
    if not p: return None
    blob = None
    try:
        if os.path.exists(p):
            with open(p, "rb") as f:
                blob = f.read()
    except Exception:
        blob = None
    try:
        if os.path.exists(p): os.remove(p)
    except Exception:
        pass
    if not blob: return None
    s = _oom_decode_sentinel(blob)
    if not s: return None
    if where in ("live", "settings"):
        rec = _oom_sentinel_to_rec(s, merge_direct=True)
    elif where == "boot":
        _pm = _direct_premortem_read_and_clear()
        if _pm is not None:
            try:
                if abs(int(_pm.get("ts", 0)) - int(s.get("ts_ms", 0))) > 120000: _pm = None
            except Exception: pass
        rec = _oom_sentinel_to_rec(s, direct_snap=_pm)
    else:
        rec = _oom_sentinel_to_rec(s)
    try: _oom_persist(rec)
    except Exception: pass
    if do_log:
        try: _oom_log_dump(rec)
        except Exception: pass
    return rec

def _oom_consume_loop(stop_evt):
    last_seq = 0
    try:
        if _OOM_NATIVE_OK and _NLIB is not None:
            last_seq = int(_NLIB.cd_oom_seq())
    except Exception:
        last_seq = 0
    while not stop_evt.is_set():
        stop_evt.wait(_OOM_POLL_S)
        if stop_evt.is_set(): break
        try:
            if not (_OOM_NATIVE_OK and _NLIB is not None): continue
            seq = int(_NLIB.cd_oom_seq())
            if seq != last_seq:
                last_seq = seq
                _oom_consume_native("live", do_log=True)
        except Exception as e:
            try: _log(f"Block#6 consume err: {e}")
            except Exception: pass


def _read_and_clear_crash_verdict():
    p = _crash_path()
    if not p: return None
    rec = None
    try:
        if os.path.exists(p):
            with open(p, "r", encoding="utf-8") as f:
                rec = json.load(f)
    except Exception:
        rec = None
    try:
        if os.path.exists(p): os.remove(p)
    except Exception:
        pass
    return rec

_BLOCK4A_ON = True
_BLOCK4B_ON = True
_XPOSED_BRIDGE_CLASSES = (
    "de.robv.android.xposed.XposedBridge",
    "com.taobao.android.dexposed.DexposedBridge",
)
_HOOK_FRAMEWORK_PROBES = [
    ("de.robv.android.xposed.XposedBridge", "sHookedMethodCallbacks"),
    ("com.taobao.android.dexposed.DexposedBridge", "sHookedMethodCallbacks"),
    ("top.canyie.pine.Pine", "sHookListeners"),
    ("top.canyie.pine.PineConfig", None),
    ("me.weishu.epic.art.Epic", None),
    ("com.swift.sandhook.SandHook", None),
    ("org.lsposed.lsplant.LSPlant", None),
    ("org.lsposed.lspd.core.Main", None),
    ("io.github.libxposed.api.XposedInterface", None),
    ("lab.galaxy.yahfa.HookMain", None),
    ("com.exteragram.messenger.plugins.PythonPluginsEngine", None),
]

def _class_obj(cn):
    try:
        return jclass("java.lang.Class").forName(cn)
    except Exception:
        return None

def _probe_hook_frameworks():
    found = []
    for cn, fld in _HOOK_FRAMEWORK_PROBES:
        cls = _class_obj(cn)
        if cls is None:
            continue
        info = cn
        if fld:
            try:
                f = cls.getDeclaredField(fld); f.setAccessible(True); v = f.get(None)
                try: sz = v.size()
                except Exception:
                    try: sz = len(v)
                    except Exception: sz = "?"
                info += f" [{fld}={sz}]"
            except Exception as e:
                info += f" [{fld}:нет поля]"
        found.append(info)
    return found

def _safe_str(o):
    try: return str(o)
    except Exception:
        try: return o.toString()
        except Exception: return ""

def _plugin_classloaders():
    out = {}
    try:
        PC = jclass("com.exteragram.messenger.plugins.PluginsController")
        controller = PC.getInstance()
        plugins = controller.getPlugins() if controller is not None else None
        if plugins is None: return out
        for e in _entryset_snapshot(plugins):
            try:
                pid = _safe_str(e.getKey()); inst = e.getValue()
                cl = inst.getClass().getClassLoader() if inst is not None else None
                if cl is not None: out[_safe_str(cl)] = pid
            except Exception: pass
    except Exception: pass
    return out

def _entryset_snapshot(m):
    last = None
    for _ in range(4):
        try: return list(m.entrySet().toArray())
        except Exception as e: last = e
    try: _log("entrySet snapshot failed: %s" % last)
    except Exception: pass
    return []

def _xposed_field_value():
    for cn in _XPOSED_BRIDGE_CLASSES:
        try:
            cls = _class_obj(cn)
            if cls is None: continue
            f = cls.getDeclaredField("sHookedMethodCallbacks")
            f.setAccessible(True)
            v = f.get(None)
            if v is not None: return v, cn
        except Exception: continue
    return None, None

def _cb_array(callbacks):
    for getter in ("getSnapshot", "toArray"):
        try:
            a = getattr(callbacks, getter)()
            if a is not None: return a
        except Exception: pass
    return []

def _build_hook_owner_map():
    res = {}
    m, cn = _xposed_field_value()
    if m is None:
        st = "lsplant-no-jmap" if _class_obj("de.robv.android.xposed.XposedBridge") is not None else "no-xposed"
        return res, 0, st
    try:
        clmap = _plugin_classloaders(); known = _load_known()
        for e in _entryset_snapshot(m):
            try:
                member = e.getKey(); callbacks = e.getValue()
                dcl = member.getDeclaringClass().getName()
                try: mname = member.getName()
                except Exception: mname = "<init>"
                key = dcl + "." + mname
                owner = None
                for cb in _cb_array(callbacks):
                    try:
                        cl = cb.getClass().getClassLoader(); rep = _safe_str(cl)
                        if rep in clmap: owner = clmap[rep]; break
                        owner = _map_stack_to_id(rep, known) or _map_stack_to_id(cb.getClass().getName(), known)
                        if owner: break
                    except Exception: pass
                res[key] = owner
            except Exception: pass
    except Exception:
        return res, len(res), "err"
    return res, len(res), "ok"

def _hook_owner_for_frames(frames):
    if not _BLOCK4A_ON: return None, None, None, {"status": "off"}
    omap, n, status = _build_hook_owner_map()
    meta = {"n": n, "status": status}
    if not omap: return None, None, None, meta
    for fr in frames:
        if fr in omap and omap[fr]: return omap[fr], fr, "exact", meta
    simple = {}
    for k, v in omap.items():
        try:
            cls, mth = k.rsplit(".", 1); simple[(_simple(cls), mth)] = (v, k)
        except Exception: pass
    for fr in frames:
        try:
            cls, mth = fr.rsplit(".", 1); t = (_simple(cls), mth)
            if t in simple and simple[t][0]: return simple[t][0], simple[t][1], "simple", meta
        except Exception: pass
    by_method = {}
    for k, v in omap.items():
        if not v: continue
        try: mth = k.rsplit(".", 1)[1]
        except Exception: continue
        by_method.setdefault(mth, set()).add((v, k))
    for fr in frames:
        if not _is_hook_frame(fr): continue
        try: mth = fr.rsplit(".", 1)[1]
        except Exception: continue
        hits = by_method.get(mth)
        if hits and len(hits) == 1:
            v, k = next(iter(hits))
            return v, k, "hook-method", meta
    for fr in frames:
        if fr in omap: return None, fr, "method-only", meta
    return None, None, None, meta

def _plugin_loaders():
    out = []
    try:
        PC = jclass("com.exteragram.messenger.plugins.PluginsController")
        controller = PC.getInstance()
        plugins = controller.getPlugins() if controller is not None else None
        if plugins is None: return out
        for e in _entryset_snapshot(plugins):
            try:
                pid = _safe_str(e.getKey()); inst = e.getValue()
                cl = inst.getClass().getClassLoader() if inst is not None else None
                if cl is not None: out.append((cl, _safe_str(cl), pid))
            except Exception: pass
    except Exception: pass
    return out

def _classloader_culprit(frames):
    if not _BLOCK4B_ON: return None, None, {"status": "off"}
    loaders = _plugin_loaders()
    meta = {"n": len(loaders), "status": ("no-loaders" if not loaders else "ok")}
    if not loaders: return None, None, meta
    repr2pids = {}
    for (cl, rep, pid) in loaders:
        repr2pids.setdefault(rep, set()).add(pid)
    ambig = 0
    for fr in frames:
        cn = fr.rsplit(".", 1)[0] if "." in fr else fr
        if _is_system_class(cn): continue
        for (cl, rep, pid) in loaders:
            try:
                kls = cl.loadClass(cn)
            except Exception:
                continue
            try:
                drep = _safe_str(kls.getClassLoader())
            except Exception:
                drep = None
            if drep is None: continue
            pids = repr2pids.get(drep)
            if not pids: continue
            if len(pids) == 1:
                if ambig: meta["ambiguous"] = ambig
                return next(iter(pids)), fr, meta
            ambig += 1; break
    if ambig: meta["ambiguous"] = ambig
    return None, None, meta

def _b16_push_verdict(kind, rec):
    if not _B16_ON: return
    try:
        conf = rec.get("confidence")
        if conf not in ("high", "medium"): return
        e = {"kind": kind, "culprit": rec.get("culprit"), "confidence": conf,
             "where": rec.get("where"), "exc_cls": rec.get("exc_cls"),
             "exc_msg": rec.get("exc_msg"), "py_file": rec.get("py_file"),
             "py_line": rec.get("py_line"), "ts": rec.get("ts") or int(time.time() * 1000)}
        with _RECENT_VERDICTS_LOCK:
            _RECENT_VERDICTS.append(e)
            if len(_RECENT_VERDICTS) > _RECENT_MAX:
                del _RECENT_VERDICTS[:-_RECENT_MAX]
    except Exception:
        pass

def _b16_disk_candidates():
    out = []
    try:
        srcs = (("cb", _cb_verdict_path), ("bg", _bg_verdict_path), ("ui", _ui_verdict_path), ("fut", _fut_verdict_path), ("async", _async_verdict_path), ("pyerr", _pyerr_verdict_path))
    except Exception:
        srcs = ()
    for kind, pathfn in srcs:
        try:
            p = pathfn()
            if not p or not os.path.exists(p): continue
            with open(p, "r", encoding="utf-8") as f:
                arr = list(json.load(f))
            for r in arr[-12:]:
                try:
                    out.append({"kind": kind, "culprit": r.get("culprit"),
                                "confidence": r.get("confidence"), "where": r.get("where"),
                                "exc_cls": r.get("exc_cls"), "exc_msg": r.get("exc_msg"),
                                "py_file": r.get("py_file"), "py_line": r.get("py_line"),
                                "ts": r.get("ts")})
                except Exception: pass
        except Exception:
            pass
    return out

def _b16_exc_match(crash_exc_cls, crash_exc_msg, v_exc_cls, v_exc_msg):
    cm = str(crash_exc_msg or "")
    vm = str(v_exc_msg or "")
    vc = str(v_exc_cls or "")
    if vm and (vm == cm or vm in cm or cm.endswith(vm)):
        return True
    combo = ("%s: %s" % (vc, vm)) if vm else vc
    if combo and (combo == cm or combo in cm or cm.endswith(combo)):
        return True
    return False

def _b16_correlate(rec):
    try:
        if not _B16_ON or not isinstance(rec, dict): return rec
        crash_ts = rec.get("ts") or int(time.time() * 1000)
        cx = rec.get("exc_cls"); cm = rec.get("exc_msg")
        cands = []
        try:
            with _RECENT_VERDICTS_LOCK:
                cands = list(_RECENT_VERDICTS)
        except Exception:
            cands = []
        try:
            cands = cands + _b16_disk_candidates()
        except Exception:
            pass
        top_pid = None
        try:
            nm = rec.get("native_mem")
            if isinstance(nm, dict): top_pid = nm.get("top_pid")
        except Exception:
            top_pid = None
        try:
            frames = rec.get("stack_top") or []
        except Exception:
            frames = []
        best = None; best_ts = -1
        best_py = None; best_py_ts = -1
        for v in cands:
            try:
                if v.get("confidence") != "high": continue
                vts = v.get("ts")
                if vts is None: continue
                if abs(int(crash_ts) - int(vts)) > _B16_CORR_WINDOW_MS: continue
                if _b16_exc_match(cx, cm, v.get("exc_cls"), v.get("exc_msg")):
                    if int(vts) > best_ts:
                        best = v; best_ts = int(vts)
                elif v.get("kind") == "pyerr":
                    if int(vts) > best_py_ts:
                        best_py = v; best_py_ts = int(vts)
            except Exception:
                pass
        if best is None and best_py is not None:
            best = best_py; best_ts = best_py_ts
        if best is None:
            try:
                cms = str(cm or "")
                if "_chaquopyGetDict" in cms or "_chaquopyGetType" in cms:
                    q1 = cms.find("'") + 1
                    q2 = cms.find("'", q1) if q1 > 0 else -1
                    cls_name = cms[q1:q2] if (q1 > 0 and q2 > q1) else None
                    if cls_name:
                        entry = _B14_IFACE_OWNER.get(cls_name)
                        if entry:
                            zowner, zts = entry
                            if abs(int(crash_ts) - int(zts)) < _B16_ZOMBIE_WINDOW_MS:
                                rec["correlated"] = {
                                    "from": "zombie_proxy",
                                    "culprit": zowner,
                                    "confidence": "medium",
                                    "where": "proxy.invoke/fromJava",
                                    "proxy_class": cls_name,
                                    "match": "iface_owner+window",
                                    "age_ms": abs(int(crash_ts) - int(zts))}
                                cur_pid = rec.get("crashed_plugin_id")
                                cur_conf = rec.get("confidence")
                                weak = (
                                    (cur_conf != "high") or (not cur_pid) or
                                    (cur_pid == "unknown") or
                                    (isinstance(cur_pid, str) and
                                     cur_pid.startswith("<python>"))
                                )
                                if weak:
                                    rec["crashed_plugin_id_native"] = cur_pid
                                    rec["crashed_plugin_id"] = zowner
                                    rec["confidence"] = "medium"
                                    rec["src"] = "zombie_proxy/" + cls_name
            except Exception: pass
            return rec
        culprit = best.get("culprit")
        if not culprit or culprit == "unknown": return rec
        sig = ["exc", "window"]
        try:
            if top_pid and top_pid == culprit: sig.append("top_pid")
        except Exception: pass
        try:
            for fr in frames:
                if isinstance(fr, str) and culprit in fr:
                    sig.append("stack"); break
        except Exception: pass
        rec["correlated"] = {
            "from": (best.get("kind") or "cb") + "_verdict", "culprit": culprit,
            "confidence": best.get("confidence"), "where": best.get("where"),
            "py_file": best.get("py_file"), "py_line": best.get("py_line"),
            "match": "+".join(sig), "age_ms": abs(int(crash_ts) - best_ts),
        }
        cur_pid = rec.get("crashed_plugin_id")
        cur_conf = rec.get("confidence")
        weak = (cur_conf != "high") or (not cur_pid) or (cur_pid == "unknown") or (isinstance(cur_pid, str) and cur_pid.startswith("<python>"))
        if weak:
            rec["crashed_plugin_id_native"] = cur_pid
            rec["crashed_plugin_id"] = culprit
            rec["confidence"] = "high"
            rec["src"] = "correlated/" + (best.get("kind") or "cb")
        return rec
    except Exception:
        return rec

def _b16_correlate_boot(rec, cands):
    try:
        if not _B16_ON or not isinstance(rec, dict) or not cands:
            return rec
        cur_pid = rec.get("crashed_plugin_id"); cur_conf = rec.get("confidence")
        weak = (cur_conf != "high") or (not cur_pid) or (cur_pid == "unknown") or (isinstance(cur_pid, str) and cur_pid.startswith("<python>"))
        if not weak:
            return rec
        crash_ts = rec.get("ts") or int(time.time() * 1000)
        cx = rec.get("exc_cls"); cm = rec.get("exc_msg")
        best = None; best_ts = -1; best_py = None; best_py_ts = -1
        for v in cands:
            try:
                if v.get("confidence") != "high":
                    continue
                vts = v.get("ts")
                if vts is None:
                    continue
                if abs(int(crash_ts) - int(vts)) > _B16_CORR_WINDOW_MS:
                    continue
                if _b16_exc_match(cx, cm, v.get("exc_cls"), v.get("exc_msg")):
                    if int(vts) > best_ts:
                        best = v; best_ts = int(vts)
                elif v.get("kind") == "pyerr":
                    if int(vts) > best_py_ts:
                        best_py = v; best_py_ts = int(vts)
            except Exception:
                pass
        if best is None and best_py is not None:
            best = best_py; best_ts = best_py_ts
        if best is None:
            return rec
        culprit = best.get("culprit")
        if not culprit or culprit == "unknown":
            return rec
        rec["crashed_plugin_id_native"] = cur_pid
        rec["crashed_plugin_id"] = culprit
        rec["confidence"] = "high"
        rec["src"] = "correlated-boot/" + (best.get("kind") or "py")
        rec["correlated"] = {"from": (best.get("kind") or "py") + "_verdict", "culprit": culprit,
                             "confidence": best.get("confidence"), "where": best.get("where"),
                             "py_file": best.get("py_file"), "py_line": best.get("py_line"),
                             "match": "boot+window", "age_ms": abs(int(crash_ts) - int(best_ts))}
        return rec
    except Exception:
        return rec


def _capture_crash(thread, ex):
    crash_ts = int(time.time() * 1000)
    tid = None
    if _NATIVE_OK and _NLIB is not None:
        try: tid = int(_NLIB.cd_gettid())
        except Exception: tid = None
    if tid is None:
        try: tid = int(thread.getId())
        except Exception: tid = None
    idx_tid = _reg_get(tid)
    pid_tid = _resolve_idx(idx_tid) if (idx_tid is not None and idx_tid >= 0) else None
    crumb_raw = None
    try:
        crumb_raw = _CRUMB.read_prev() if _CRUMB is not None else None
    except Exception:
        crumb_raw = None
    pid_crumb = None; crumb_fresh = False; crumb_age = None
    if crumb_raw:
        try:
            parts = crumb_raw.split("\t")
            pid_crumb = parts[0]; cts = int(parts[2]); crumb_age = crash_ts - cts
            if 0 <= crumb_age <= _CRUMB_FRESH_MS: crumb_fresh = True
        except Exception:
            pid_crumb = crumb_raw.split("\t")[0] if "\t" in crumb_raw else crumb_raw
    frames = []
    try:
        st = ex.getStackTrace()
        if st is not None:
            for el in st:
                try: frames.append(el.getClassName() + "." + el.getMethodName())
                except Exception: pass
    except Exception:
        pass
    via_hook = any(_is_hook_frame(f) for f in frames)
    hooked_method = None
    if via_hook:
        for f in frames:
            if _is_hook_frame(f) and "LSPHooker_" in f:
                try: hooked_method = f.rsplit(".", 1)[1]
                except Exception: hooked_method = _short_method(f)
                break
        if not hooked_method:
            for f in frames:
                if f.startswith("org.telegram."):
                    hooked_method = _short_method(f); break
    culprit_frame = _stack_culprit(frames)
    pid_stack = _map_stack_to_id(culprit_frame, _known_union()) if culprit_frame else None
    pid_4a = None; hook4a_method = None; hook4a_kind = None; hook4a_meta = {}
    try:
        pid_4a, hook4a_method, hook4a_kind, hook4a_meta = _hook_owner_for_frames(frames)
    except Exception as _e4a:
        hook4a_meta = {"status": "err:%s" % _e4a}
    pid_4b = None; cl4b_frame = None; cl4b_meta = {}
    try:
        pid_4b, cl4b_frame, cl4b_meta = _classloader_culprit(frames)
    except Exception as _e4b:
        cl4b_meta = {"status": "err:%s" % _e4b}
    pid_4c = None; cl4c_frame = None; cl4c_meta = {}
    try:
        pid_4c, cl4c_frame, cl4c_meta = _loader_culprit(frames)
    except Exception as _e4c:
        cl4c_meta = {"status": "err:%s" % _e4c}
    pid_stack_strong = pid_stack if (pid_stack and culprit_frame and not _is_obfuscated(culprit_frame)) else None
    if pid_tid:
        pid = pid_tid; src = "tid"; conf = "high"
    elif pid_stack_strong:
        pid = pid_stack_strong; src = "stack"; conf = "high"
    elif pid_4c:
        pid = pid_4c; src = "loader"; conf = "high"
    elif pid_4b:
        pid = pid_4b; src = "classloader"; conf = "high"
    elif pid_4a:
        pid = pid_4a; src = "hookmap"; conf = "high"
    elif pid_stack:
        pid = pid_stack; src = "stack"; conf = "medium"
    elif culprit_frame:
        pid = _pkg_of(culprit_frame); src = "stack-pkg"; conf = "low"
    elif crumb_fresh and pid_crumb:
        pid = pid_crumb; src = "breadcrumb"; conf = "low"
    else:
        pid = "unknown"; src = ("hook-obfuscated" if via_hook else "none"); conf = "none"
    exc_cls = ""; exc_msg = ""; tname = ""
    try: exc_cls = ex.getClass().getName()
    except Exception: pass
    try:
        m = ex.getMessage(); exc_msg = str(m) if m is not None else ""
    except Exception: pass
    try: tname = thread.getName()
    except Exception: pass
    is_selftest = (_SELFTEST_MARK in (exc_msg or "")) or (tname == _SELFTEST_TNAME)
    nat = None
    if _NATIVE_OK and _NLIB is not None:
        try:
            b = ctypes.c_int64(0)
            ti = int(_NLIB.cd_top1(ctypes.byref(b)))
            nat = {"top_idx": ti, "top_pid": (_resolve_idx(ti) if ti >= 0 else None),
                   "top_bytes": int(b.value), "total": int(_NLIB.cd_total())}
        except Exception:
            nat = None
    rec = {
        "had_crash": True, "crashed_plugin_id": pid, "src": src, "confidence": conf,
        "exc_cls": exc_cls, "exc_msg": exc_msg, "thread": tname,
        "via_hook": via_hook, "hooked_method": hooked_method,
        "pid_tid": pid_tid, "reg_idx": idx_tid, "reg_backend": registry_info()["backend"],
        "pid_stack": pid_stack, "culprit_frame": culprit_frame,
        "pid_4a": pid_4a, "hook4a_method": hook4a_method, "hook4a_kind": hook4a_kind, "hook4a_meta": hook4a_meta,
        "pid_4b": pid_4b, "cl4b_frame": cl4b_frame, "cl4b_meta": cl4b_meta,
        "pid_4c": pid_4c, "cl4c_frame": cl4c_frame, "cl4c_meta": cl4c_meta,
        "pid_crumb": pid_crumb, "crumb_fresh": crumb_fresh, "crumb_age_ms": crumb_age, "crumb": crumb_raw,
        "stack_top": frames[:40], "native_mem": nat, "ts": crash_ts,
    }
    rec = _b16_correlate(rec)
    _write_crash_verdict(rec)
    return is_selftest

_UEH_IFACE = None
try:
    _UEH_IFACE = jclass("java.lang.Thread$UncaughtExceptionHandler")
except Exception:
    _UEH_IFACE = None
_HANDLER_CLASS = None
if _UEH_IFACE is not None:
    try:
        from java import dynamic_proxy
        class _CrashHandler(dynamic_proxy(_UEH_IFACE)):
            def __init__(self, prev):
                super().__init__(); self._prev = prev
            def uncaughtException(self, thread, ex):
                swallow = False
                try: swallow = _capture_crash(thread, ex)
                except Exception: swallow = False
                if not swallow:
                    try:
                        if self._prev is not None:
                            self._prev.uncaughtException(thread, ex)
                    except Exception: pass
        _HANDLER_CLASS = _CrashHandler
    except Exception:
        _HANDLER_CLASS = None

_RUNNABLE_IFACE = None
try:
    _RUNNABLE_IFACE = jclass("java.lang.Runnable")
except Exception:
    _RUNNABLE_IFACE = None
_SELFTEST_RUNNABLE_CLASS = None
if _RUNNABLE_IFACE is not None:
    try:
        from java import dynamic_proxy as _dp2
        class _SelfTestRunnable(dynamic_proxy(_RUNNABLE_IFACE)):
            def run(self):
                try:
                    _publish_tid("__selftest__")
                    if _CRUMB is not None:
                        _CRUMB.write("__selftest__", "selftest:crash")
                except Exception: pass
                raise RuntimeError(_SELFTEST_MARK + " Culprit Detector self-test (преднамеренный uncaught)")
        _SELFTEST_RUNNABLE_CLASS = _SelfTestRunnable
    except Exception:
        _SELFTEST_RUNNABLE_CLASS = None

_PREV_UEH = None
_OUR_UEH = None

_SUICIDE_TL = threading.local()
def _pm_thread_name():
    try:
        if _JThread is not None: return str(_JThread.currentThread().getName())
    except Exception: pass
    return ""
def _pm_java_stack(maxn=28):
    out = []
    try:
        if _JThread is None: return out
        st = _JThread.currentThread().getStackTrace()
        for e in list(st)[:maxn]:
            try:
                out.append("%s.%s(%s:%s)" % (e.getClassName(), e.getMethodName(), e.getFileName(), e.getLineNumber()))
            except Exception: pass
    except Exception: pass
    return out
def _pm_scan_stack(frames):
    try: known = _load_known()
    except Exception: known = []
    if not known: return None
    for fr in frames:
        low = fr.lower()
        for pid in known:
            if pid and pid.lower() in low: return pid
    for fr in frames:
        fsq = _squash(fr)
        for pid in known:
            ps = _squash(pid)
            if ps and len(ps) >= 4 and ps in fsq: return pid
    return None
def _pm_python_stack(maxn=48):
    out = []
    try:
        import traceback as _tb
        for fr in _tb.extract_stack()[-maxn:]:
            try:
                fn = getattr(fr, "filename", None); nm = getattr(fr, "name", None)
                if fn is None: fn = fr[0]; nm = fr[2]
                out.append("%s::%s" % (fn, nm))
            except Exception: pass
    except Exception: pass
    return out
def _pm_scan_py(pyframes):
    try: known = _load_known()
    except Exception: known = []
    if not known: return None
    for fr in pyframes:
        low = fr.lower()
        if "culprit" in low: continue
        for pid in known:
            if pid and pid != _SELF_ID and pid.lower() in low: return pid
    for fr in pyframes:
        if "culprit" in fr.lower(): continue
        fsq = _squash(fr)
        for pid in known:
            if pid == _SELF_ID: continue
            ps = _squash(pid)
            if ps and len(ps) >= 4 and ps in fsq: return pid
    return None
_PM_TEARDOWN = ("uncaughtException", "dispatchUncaughtException", "KillApplicationHandler")
def _pm_is_teardown(frames):
    try:
        for fr in frames:
            for mk in _PM_TEARDOWN:
                if mk in fr: return True
    except Exception: pass
    return False
def _record_suicide(method_tag, param):
    if getattr(_SUICIDE_TL, "busy", False): return
    _SUICIDE_TL.busy = True
    try:
        jstack = _pm_java_stack(28)
        if _pm_is_teardown(jstack):
            _log("pre-mortem: killProcess в crash-teardown — пропуск (вердикт у _capture_crash)")
            return
        try: _direct_premortem_dump()
        except Exception: pass
        argval = None
        try:
            a = param.args
            if a is not None and len(a) >= 1 and a[0] is not None: argval = int(a[0])
        except Exception: pass
        tid = _cur_tid()
        pid = None; src = "self-kill"
        try:
            c = get_culprit_for_tid(tid)
            if c and c != "unknown": pid = c; src = "self-kill/active"
        except Exception: pass
        pyframes = _pm_python_stack(48)
        pid_py = _pm_scan_py(pyframes)
        if pid is None and pid_py: pid = pid_py; src = "self-kill/pystack"
        crumb_pid = None; crumb_fresh = False; crumb_age = None
        try:
            raw = _CRUMB.read_prev() if _CRUMB is not None else None
            if raw:
                parts = raw.split("\t")
                crumb_pid = parts[0] if parts else None
                if len(parts) >= 3:
                    crumb_age = int(time.time()*1000) - int(parts[2])
                    crumb_fresh = (0 <= crumb_age <= _CRUMB_FRESH_MS)
        except Exception: pass
        if pid is None and crumb_fresh and crumb_pid: pid = crumb_pid; src = "self-kill/breadcrumb"
        if pid is None:
            jpid = _pm_scan_stack(jstack)
            if jpid: pid = jpid; src = "self-kill/jstack"
        if pid is None: pid = "unknown"
        conf = "high" if src in ("self-kill/active", "self-kill/pystack") else ("medium" if pid != "unknown" else "none")
        rec = {
            "had_crash": True, "crashed_plugin_id": pid, "src": src, "confidence": conf,
            "exc_cls": "ProcessTermination", "exc_msg": "%s(%s)" % (method_tag, argval),
            "thread": _pm_thread_name(), "via_hook": False, "hooked_method": method_tag,
            "self_kill": True, "kill_method": method_tag, "kill_arg": argval,
            "pid_stack": (pid if src == "self-kill/active" else None),
            "pid_crumb": crumb_pid, "crumb_fresh": crumb_fresh, "crumb_age_ms": crumb_age,
            "py_stack": pyframes[:40], "pid_py": pid_py,
            "stack_top": jstack[:40], "ts": int(time.time()*1000),
        }
        rec = _b16_correlate(rec)
        _write_crash_verdict(rec)
        _log("PRE-MORTEM %s(%s): виновник=%r src=%s conf=%s" % (method_tag, argval, pid, src, conf))
    except Exception as _se:
        try: _log("pre-mortem record err: %s" % _se)
        except Exception: pass
    finally:
        try: _SUICIDE_TL.busy = False
        except Exception: pass
class _HookKillProcess(MethodHook):
    def before_hooked_method(self, param):
        try: _record_suicide("Process.killProcess", param)
        except Exception: pass
class _HookSystemExit(MethodHook):
    def before_hooked_method(self, param):
        try: _record_suicide("System.exit", param)
        except Exception: pass
class _HookRuntimeHalt(MethodHook):
    def before_hooked_method(self, param):
        try: _record_suicide("Runtime.halt", param)
        except Exception: pass
class _HookRuntimeExit(MethodHook):
    def before_hooked_method(self, param):
        try: _record_suicide("Runtime.exit", param)
        except Exception: pass

class _ExecHook(MethodHook):
    def before_hooked_method(self, param):
        if getattr(_REENTRY, "busy", False):
            _REENTRY.last_pushed = False; return
        _REENTRY.busy = True; pushed = False
        try:
            args = param.args
            n = len(args) if args is not None else 0
            if n == 0: return
            a0 = args[0]
            pid = str(a0) if a0 is not None else "unknown"
            if len(pid) > 80: pid = pid[:80]
            where = ""
            if n > 3:
                a3 = args[3]; a2 = args[2]
                pn = str(a3) if a3 is not None else ""
                cn = _simple(str(a2)) if a2 is not None else ""
                where = (pn + ":" + cn) if cn else pn
            if _CRUMB is not None: _CRUMB.write(pid, where)
            pushed = _scoped_set(pid)
            _note_first(pid, where)
        except Exception:
            pass
        finally:
            try: _REENTRY.last_pushed = pushed
            except Exception: pass
            _REENTRY.busy = False
    def after_hooked_method(self, param):
        try:
            if getattr(_REENTRY, "last_pushed", False):
                _scoped_clear(); _REENTRY.last_pushed = False
        except Exception: pass

class _ExecCbHook(MethodHook):
    def __init__(self, factory):
        self._factory = factory
    def before_hooked_method(self, param):
        if not _BLOCK9_ON: return
        try:
            a = param.args
            if a is not None and len(a) >= 6:
                scoped = _hook_scope_pid()
                a[5] = self._factory(a[5], scoped)
        except Exception:
            pass

_REGISTRY = {}; _REG_LOCK = threading.Lock()
_LOAD_TL = threading.local()
def _load_tl_stk():
    s = getattr(_LOAD_TL, "stk", None)
    if s is None: s = _LOAD_TL.stk = []
    return s
_REG_LOADERS = []; _REG_LOADERS_LOCK = threading.Lock(); _REG_LOADERS_MAX = 256
class _LoadHook(MethodHook):
    def before_hooked_method(self, param):
        pushed = False
        try:
            args = param.args
            if args is not None and len(args) >= 1 and args[0] is not None:
                pid = str(args[0])
                if len(pid) > 80: pid = pid[:80]
                pushed = _scoped_set(pid)
        except Exception:
            pushed = False
        _load_tl_stk().append(pushed)
    def after_hooked_method(self, param):
        try:
            args = param.args
            if args is None or len(args) < 1: return
            a0 = args[0]
            if a0 is None: return
            pid = str(a0)
            if len(pid) > 80: pid = pid[:80]
            try: _thr = param.getThrowable()
            except Exception: _thr = None
            if _thr is not None:
                try: _intern(pid); _save_known(pid)
                except Exception: pass
                try: _record_load_fail(pid, _thr, "loadPlugin")
                except Exception: pass
                return
            has_inst = len(args) > 2 and args[2] is not None
            with _REG_LOCK:
                seen = pid in _REGISTRY
                _REGISTRY[pid] = {"t": int(time.time()), "inst": has_inst}
            if not seen:
                _save_known(pid); _intern(pid)
                _log(f"loadPlugin: {pid} inst={has_inst} (registry={len(_REGISTRY)})")
                try: _kick_load_resweep(pid)
                except Exception: pass
        except Exception as e:
            _log(f"loadPlugin err: {e}")
        finally:
            try:
                stk = _load_tl_stk()
                if stk and stk.pop():
                    _scoped_clear()
            except Exception: pass

def _appev_pid_from_args(args):
    if not args: return None
    try: n = len(args)
    except Exception: return None
    for i in range(n):
        a = args[i]
        if a is None: continue
        try: s = str(a)
        except Exception: continue
        if (not s) or len(s) > 80: continue
        if (s in _REGISTRY) or (s in _PID_IDX): return s
    for i in range(n):
        a = args[i]
        if a is None: continue
        for attr in ("getId", "getPluginId", "id"):
            try:
                v = getattr(a, attr, None)
                v = v() if callable(v) else v
                if v is None: continue
                sv = str(v)
                if sv and len(sv) <= 80 and ((sv in _REGISTRY) or (sv in _PID_IDX)): return sv
            except Exception:
                pass
    return None

class _AppEventHook(MethodHook):
    def after_hooked_method(self, param):
        try: thr = param.getThrowable()
        except Exception: thr = None
        if thr is None: return
        try: pid = _appev_pid_from_args(param.args)
        except Exception: pid = None
        try: _record_load_fail(pid, thr, "executeOnAppEvent")
        except Exception: pass


def _java_lang_class(name):
    try:
        return jclass("java.lang.Class").forName(name)
    except Exception:
        pass
    try:
        c = find_class(name)
        if c is None: return None
        try: return c.getClass()
        except Exception: return c
    except Exception:
        return None

_B24_REGISTERED = 0
_B24_TL = threading.local()
def _b24_stack():
    s = getattr(_B24_TL, "s", None)
    if s is None: s = _B24_TL.s = []
    return s
def _b24_owner_pidx():
    try:
        if _B4C_OK and _NLIB is not None:
            p = int(_NLIB.cd_active_plugin())
            if p >= 0: return p
    except Exception: pass
    try:
        prov = _provenance_pid(None, 2)
        if prov and prov != _SELF_ID and prov != __id__:
            return int(_intern(prov))
    except Exception: pass
    return -1
def _b24_register_loader(obj, pidx):
    global _B24_REGISTERED
    if obj is None or pidx is None or pidx < 0: return
    try:
        lid = int(jclass("java.lang.System").identityHashCode(obj))
    except Exception:
        return
    if _NLIB is not None:
        try: _NLIB.cd_register_loader(ctypes.c_int64(lid), ctypes.c_int32(pidx))
        except Exception: pass
    try: rep = _safe_str(obj)
    except Exception: rep = None
    with _REG_LOADERS_LOCK:
        for (_o, _r, _p) in _REG_LOADERS:
            if _r == rep and _p == pidx: return
        _REG_LOADERS.append((obj, rep, pidx))
        _B24_REGISTERED += 1
        if len(_REG_LOADERS) > _REG_LOADERS_MAX:
            del _REG_LOADERS[0:len(_REG_LOADERS) - _REG_LOADERS_MAX]

class _LoaderHook(MethodHook):
    def before_hooked_method(self, param):
        try: _b24_stack().append(_b24_owner_pidx())
        except Exception:
            try: _b24_stack().append(-1)
            except Exception: pass
    def after_hooked_method(self, param):
        pidx = -1
        try: pidx = _b24_stack().pop()
        except Exception: pidx = -1
        if not (_B4C_OK and _NLIB is not None): return
        try:
            obj = getattr(param, "thisObject", None)
            if obj is None: return
            if pidx is None or pidx < 0:
                pidx = _b24_owner_pidx()
            if pidx is None or pidx < 0: return
            _b24_register_loader(obj, pidx)
        except Exception: pass

_B23_LOCK = threading.RLock()
_B23_BYTES = {}
_B23_COUNT = {}
_B23_PEAK = {}
_B23_OOM = {}
_B23_RING = []
_B23_INSTALLED = 0

def _b23_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _B23_FILE_NAME).getAbsolutePath()
    except Exception:
        return None

def _b23_owner_pid():
    try:
        if _B4C_OK and _NLIB is not None:
            p = int(_NLIB.cd_active_plugin())
            if p >= 0:
                pid = _resolve_idx(p)
                if pid and pid != _SELF_ID and pid != __id__: return pid
    except Exception: pass
    try:
        pid = get_culprit_for_tid(_cur_tid())
        if pid and pid != _SELF_ID and pid != __id__: return pid
    except Exception: pass
    try:
        prov = _provenance_pid(None, 2)
        if prov and prov != _SELF_ID and prov != __id__: return prov
    except Exception: pass
    return None

_B23_BPP = {"ALPHA_8": 1, "RGB_565": 2, "ARGB_4444": 2, "ARGB_8888": 4, "RGBA_F16": 8, "HARDWARE": 4, "RGBA_1010102": 4}

def _b23_args_ints(args):
    out = []
    for a in (args or []):
        try:
            iv = int(a)
            if iv > 0: out.append(iv)
        except Exception:
            pass
    return out

def _b23_args_est(args):
    ints = _b23_args_ints(args)
    bpp = 4
    for a in (args or []):
        try:
            nm = a.name()
            for k, v in _B23_BPP.items():
                if k in nm: bpp = v; break
        except Exception:
            pass
    ints.sort(reverse=True)
    if len(ints) >= 2:
        return ints[0] * ints[1] * bpp
    return -1

def _b23_result_bytes(param):
    try:
        r = param.getResult()
        if r is None: return -1
        try: return int(r.getAllocationByteCount())
        except Exception: pass
        try: return int(r.getByteCount())
        except Exception: pass
    except Exception: pass
    return -1

def _b23_record(pid, nbytes, kind, oom, dims):
    if pid is None: pid = _UNTAGGED_LABEL
    with _B23_LOCK:
        if nbytes and nbytes > 0:
            _B23_BYTES[pid] = _B23_BYTES.get(pid, 0) + int(nbytes)
            if int(nbytes) > _B23_PEAK.get(pid, 0): _B23_PEAK[pid] = int(nbytes)
        _B23_COUNT[pid] = _B23_COUNT.get(pid, 0) + 1
        if oom: _B23_OOM[pid] = _B23_OOM.get(pid, 0) + 1
        if oom or (nbytes and nbytes >= _B23_BIG_BYTES):
            _B23_RING.append((int(time.time() * 1000), pid, int(nbytes) if (nbytes and nbytes > 0) else -1, kind, dims))
            if len(_B23_RING) > _B23_RING_MAX:
                del _B23_RING[0:len(_B23_RING) - _B23_RING_MAX]

def b23_snapshot(top=10):
    with _B23_LOCK:
        pairs = sorted(_B23_BYTES.items(), key=lambda kv: kv[1], reverse=True)
        return {
            "by_pid": pairs[:top],
            "count": dict(_B23_COUNT),
            "peak": dict(_B23_PEAK),
            "oom": dict(_B23_OOM),
            "recent": list(_B23_RING[-top:]),
            "installed_hooks": _B23_INSTALLED,
        }

def _b23_is_oom(thr):
    try:
        if thr is None: return None
        try: nm = thr.getClass().getName()
        except Exception: nm = _safe_str(thr)
        if nm and "OutOfMemory" in nm:
            return nm
    except Exception: pass
    return None

def _b23_write_oom(pid, nbytes, kind, dims, thr_name):
    p = _b23_path()
    if not p: return
    try:
        snap = b23_snapshot(top=_OOM_TOPN)
        rec = {
            "had_bitmap_oom": True,
            "ts": int(time.time() * 1000),
            "version": __version__,
            "culprit": pid or _UNTAGGED_LABEL,
            "attempted_bytes": int(nbytes) if (nbytes and nbytes > 0) else -1,
            "kind": kind, "dims": dims, "throwable": thr_name,
            "confidence": ("high" if (pid and pid != _UNTAGGED_LABEL) else "low"),
            "reason": (("OOM при выделении %s%s%s") % (
                (kind or "bitmap"),
                (" %s" % dims) if dims else "",
                ((" (~%d МБ)" % (int(nbytes) // (1024*1024))) if (nbytes and nbytes > 0) else ""),
            )),
            "ledger": snap,
        }
        _atomic_json_write(p, rec)
        _log("================ BITMAP OOM VERDICT (Block#23) ================")
        _log("ВИНОВНИК OOM(bitmap): %r kind=%s ~%sB dims=%s thr=%s" % (
            pid or _UNTAGGED_LABEL, kind,
            (int(nbytes) if (nbytes and nbytes > 0) else "?"), dims, thr_name))
        _log("==============================================================")
    except Exception as e:
        try: _log("Block#23 write oom err: %s" % e)
        except Exception: pass

_B23_DEDUP_WINDOW_MS = 250
_B23_DEDUP_MAX = 32
_B23_TL = threading.local()

def _b23_identity(obj):
    try:
        if obj is None: return None
        return int(jclass("java.lang.System").identityHashCode(obj))
    except Exception:
        return None

def _b23_seen_recently(key):
    if key is None:
        return False
    now = int(time.time() * 1000)
    store = getattr(_B23_TL, "seen", None)
    if store is None:
        store = []; _B23_TL.seen = store
    cut = now - _B23_DEDUP_WINDOW_MS
    if store:
        store[:] = [(k, t) for (k, t) in store if t >= cut]
    for (k, t) in store:
        if k == key:
            return True
    store.append((key, now))
    if len(store) > _B23_DEDUP_MAX:
        del store[0:len(store) - _B23_DEDUP_MAX]
    return False

def _b23_after(kind, param):
    if not _B23_ON: return
    try:
        thr = None
        try: thr = param.getThrowable()
        except Exception: thr = None
        oom_name = _b23_is_oom(thr)
        try:
            _dkey = _b23_identity(thr) if oom_name is not None else _b23_identity(param.getResult())
        except Exception:
            _dkey = None
        if _b23_seen_recently(_dkey):
            return
        pid = _b23_owner_pid()
        if oom_name is not None:
            args = getattr(param, "args", None)
            nbytes = _b23_args_est(args)
            dims = None
            try:
                ints = _b23_args_ints(args)
                if len(ints) >= 2:
                    ints.sort(reverse=True); dims = "%dx%d" % (ints[0], ints[1])
            except Exception: pass
            _b23_record(pid, nbytes, kind, True, dims)
            _b23_write_oom(pid, nbytes, kind, dims, oom_name)
            return
        nbytes = _b23_result_bytes(param)
        _b23_record(pid, nbytes, kind, False, None)
    except Exception:
        pass

class _BitmapCreateHook(MethodHook):
    def after_hooked_method(self, param): _b23_after("createBitmap", param)

class _BitmapScaleHook(MethodHook):
    def after_hooked_method(self, param): _b23_after("createScaledBitmap", param)

class _BitmapCopyHook(MethodHook):
    def after_hooked_method(self, param): _b23_after("copy", param)

def _loader_culprit(frames):
    if not _B4C_OK: return None, None, {"status": "off"}
    with _REG_LOADERS_LOCK:
        loaders = list(_REG_LOADERS)
    meta = {"n": len(loaders), "status": ("no-loaders" if not loaders else "ok")}
    if not loaders: return None, None, meta
    for fr in frames:
        cn = fr.rsplit(".", 1)[0] if "." in fr else fr
        if _is_system_class(cn): continue
        for (obj, rep, pidx) in loaders:
            try:
                kls = obj.loadClass(cn)
            except Exception:
                continue
            try:
                drep = _safe_str(kls.getClassLoader())
            except Exception:
                drep = None
            if drep is not None and drep == rep:
                pid = _resolve_idx(pidx)
                if pid:
                    return pid, fr, meta
    return None, None, meta


_SIG_NAME = {4: "SIGILL", 6: "SIGABRT", 7: "SIGBUS", 8: "SIGFPE", 11: "SIGSEGV"}

def _classify_native_cause(signo, si_code=None, fault_addr=None):
    try:
        if signo is None: return "unknown"
        return _SIG_NAME.get(signo, "signo=%s" % signo)
    except Exception:
        return "unknown"

_SYS_SO_PREFIXES = ("/system/", "/apex/", "/vendor/", "/product/", "/system_ext/",
                    "/odm/", "/data/app/", "/linkerconfig/", "/bionic/")
_SELF_SO_HINTS = ("libculprit", "libshadowhook")
_BY_MOD_RE = re.compile(r"(/\S+?\.so|\b[\w.\-]+\.so)(?=$|[+\s)])")

def _frame_module_path(frame_line):
    m = _BY_MOD_RE.search(frame_line or "")
    return m.group(1) if m else None

def _is_app_private_so(path):
    if not path: return False
    low = path.lower()
    if any(h in low for h in _SELF_SO_HINTS): return False
    for pre in _SYS_SO_PREFIXES:
        if path.startswith(pre): return False
    if path.startswith("/data/data/") or re.match(r"^/data/user/\d+/", path):
        return True
    if any(seg in path for seg in ("/files/", "/cache/", "/code_cache/", "/no_backup/")):
        return True
    return False

def _so_owner_from_path(path):
    soname = path.rsplit("/", 1)[-1]
    stem = soname[:-3] if soname.lower().endswith(".so") else soname
    try: known = list(_load_known() or [])
    except Exception: known = []
    comps = set(c for c in path.split("/") if c)
    for pid in known:
        if not pid: continue
        if pid in comps or stem == pid or stem == ("lib" + pid):
            return pid, "high"
    mapped = None
    try: mapped = _map_stack_to_id(soname, known) or _map_stack_to_id(path, known)
    except Exception: mapped = None
    if mapped: return mapped, "high"
    return "<so:%s>" % soname, "medium"

def _read_native_crash():
    try:
        p = _native_crash_path()
        if not p or not os.path.exists(p): return None
        with open(p, "r", encoding="utf-8", errors="replace") as f:
            raw = f.read()
        if "CULPRIT_NATIVE_CRASH" not in raw:
            try: os.remove(p)
            except Exception: pass
            return None
        _parts = raw.split("CULPRIT_NATIVE_CRASH")
        _last_full = None
        for _part in _parts[1:]:
            _block = "CULPRIT_NATIVE_CRASH" + _part
            _end = _block.find("\nEND")
            if _end != -1:
                _last_full = _block[:_end + 4] + "\n"
        if _last_full is None:
            return None
        raw = _last_full
        rec = {"raw": raw[-4000:], "signo": None, "active_pid": None, "culprit_pid": None, "pid_src": None, "pid_resolve_src": None, "pid_choice_src": None, "pid": None, "si_code": None, "fault_addr": None, "cause": None, "foreign_so": None, "foreign_app_private": None, "foreign_so_conf": None, "fso_src": None, "top_so": None, "host_so": None, "host_native": None, "culprit_kind": None, "op_stamps": {}, "frames": []}
        for line in raw.splitlines():
            line = line.strip()
            if line.startswith("signo="):
                for tok in line.split():
                    if tok.startswith("signo="):
                        try: rec["signo"] = int(tok.split("=", 1)[1])
                        except Exception: pass
                    elif tok.startswith("active_pid="):
                        try: rec["active_pid"] = int(tok.split("=", 1)[1])
                        except Exception: pass
                    elif tok.startswith("culprit_pid="):
                        try: rec["culprit_pid"] = int(tok.split("=", 1)[1])
                        except Exception: pass
                    elif tok.startswith("pid_src="):
                        rec["pid_src"] = tok.split("=", 1)[1]
                    elif tok.startswith("code="):
                        try: rec["si_code"] = int(tok.split("=", 1)[1])
                        except Exception: pass
                    elif tok.startswith("addr="):
                        _v = tok.split("=", 1)[1]
                        try: rec["fault_addr"] = int(_v, 16) if _v.lower().startswith("0x") else int(_v)
                        except Exception: pass
                    elif tok.startswith("cause="):
                        rec["cause"] = tok.split("=", 1)[1]
                    elif tok.startswith("foreign_so="):
                        rec["foreign_so"] = tok.split("=", 1)[1]
                    elif tok.startswith("foreign_app_private="):
                        _fv = tok.split("=", 1)[1]
                        rec["foreign_app_private"] = _fv not in ("0", "", "false", "False", "no")
                    elif tok.startswith("fso_src="):
                        rec["fso_src"] = tok.split("=", 1)[1]
                    elif tok.startswith("top_so="):
                        rec["top_so"] = tok.split("=", 1)[1]
                    elif tok.startswith("host_so="):
                        rec["host_so"] = tok.split("=", 1)[1]
                    elif tok.startswith("host_native="):
                        _hv = tok.split("=", 1)[1]
                        rec["host_native"] = _hv not in ("0", "", "false", "False", "no")
                    elif tok.startswith("op_") and "=" in tok:
                        try:
                            _opd, _opv = tok.split("=", 1)
                            _opd = _opd[3:]
                            _opp = _opv.split("|")
                            _opa = int(_opp[1]) if len(_opp) > 1 and _opp[1] != "" else None
                            if _opd and _opp and _opp[0] and _opa is not None:
                                rec["op_stamps"][_opd] = {"owner": _opp[0], "age_ms": _opa, "api": (_opp[2] if len(_opp) > 2 else None)}
                        except Exception: pass
            elif line.startswith("#"):
                rec["frames"].append(line)
        rec["frame_type"] = _classify_crash_frames(rec.get("frames"))
        _c_native_by = bool(rec.get("cause"))
        c_pid = rec.get("culprit_pid")
        a_pid = rec.get("active_pid")
        _ordered = []
        if a_pid is not None and a_pid >= 0:
            _ordered.append((a_pid, "scope"))
        if c_pid is not None and c_pid >= 0 and c_pid != a_pid:
            _ordered.append((c_pid, "culprit_pid"))
        for _idx_val, _choice in _ordered:
            nm = _resolve_idx(_idx_val)
            _rsrc = "memory"
            if nm is None:
                nm = _resolve_idx_durable(_idx_val)
                _rsrc = "sidecar" if nm is not None else None
            if nm is not None:
                rec["pid"] = nm; rec["pid_resolve_src"] = _rsrc; rec["pid_choice_src"] = _choice
                break
        if rec.get("pid") is None:
            try:
                top_mod = None
                by_src = "c-native"
                _fso = rec.get("foreign_so")
                _fap = rec.get("foreign_app_private")
                if _fso and _fap is not False:
                    top_mod = _fso
                if top_mod:
                    owner, conf = _so_owner_from_path(top_mod)
                    rec["pid"] = owner
                    rec["pid_choice_src"] = "so_path"
                    rec["pid_resolve_src"] = "so_app_private"
                    rec["foreign_so"] = top_mod
                    rec["foreign_so_conf"] = conf
                    _log("Block#4C +BY(native-so/%s): untagged нативный краш отнесён по ПУТИ верхнего .so -> плагин=%r (module=%s cause=%s fso_src=%s) -- ЭВРИСТИКА conf=%s"
                         % (by_src, owner, top_mod, rec.get("cause"), rec.get("fso_src"), conf))
            except Exception as _eby:
                _log("Block#4C +BY native-so err: %s" % _eby)
        if rec.get("pid") is None:
            try:
                try: crash_ts = int(os.path.getmtime(p) * 1000)
                except Exception: crash_ts = None
                if crash_ts is not None:
                    ct = rec.get("frame_type")
                    cands = []
                    _native_ops = rec.get("op_stamps") or {}
                    rec["op_stamp_src"] = "native" if _native_ops else "none"
                    _dn2ot = {"gpu": "rs", "gl": "gl", "anim": "anim", "mvel": "mvel",
                              "binder": "binder", "camera": "camera", "mediacodec": "mediacodec"}
                    for _dn, _st in _native_ops.items():
                        _ot = _dn2ot.get(_dn)
                        _age = _st.get("age_ms"); _ow = _st.get("owner")
                        if _ot and _ow and _age is not None and _age >= 0:
                            cands.append((_ot, crash_ts - int(_age), _ow))
                    if ct is not None:
                        if ct == "gpu":
                            cands = [c for c in cands if c[0] in ("rs", "gl")]
                        else:
                            cands = [c for c in cands if c[0] == ct]
                    best = None
                    for otype, op_ts, owner in cands:
                        if not owner or owner == _SELF_ID or owner == __id__: continue
                        if op_ts <= 0: continue
                        age = crash_ts - op_ts
                        if 0 <= age <= _GPU_OP_WINDOW_MS and (best is None or op_ts > best[1]):
                            best = (otype, op_ts, owner, age)
                    if best is not None:
                        otype, op_ts, owner, age = best
                        frame_match = (ct == otype) or (ct == "gpu" and otype in ("rs", "gl"))
                        if otype == "rs":
                            choice = "gpu_lib" if frame_match else "gpu_recent"; resolve = "gpu_sidecar"
                        elif otype == "gl":
                            choice = "gl_op" if frame_match else "gl_recent"; resolve = "gl_sidecar"
                        elif otype == "anim":
                            choice = "anim_op" if frame_match else "anim_recent"; resolve = "anim_sidecar"
                        elif otype == "mvel":
                            choice = "mvel_op" if frame_match else "mvel_recent"; resolve = "mvel_sidecar"
                        elif otype == "binder":
                            choice = "binder_op" if frame_match else "binder_recent"; resolve = "binder_sidecar"
                        elif otype == "camera":
                            choice = "camera_op" if frame_match else "camera_recent"; resolve = "camera_sidecar"
                        else:
                            choice = "mediacodec_op" if frame_match else "mediacodec_recent"; resolve = "mediacodec_sidecar"
                        rec["pid"] = owner
                        rec["pid_choice_src"] = choice
                        rec["pid_resolve_src"] = resolve
                        rec["gpu_lib_hint"] = (_gpu_frames_hit_rs(rec.get("frames")) if otype == "rs" else None)
                        rec["gpu_op_age_ms"] = age
                        _corr_prefix = {"rs": "+BI(rs)", "gl": "+BW(gl)", "anim": "+BL(anim)", "mvel": "+BN(mvel)", "binder": "+BT(binder)", "camera": "+BU(camera)", "mediacodec": "+BV(mediacodec)"}.get(otype, "+BL(gap9+anim)")
                        _log("Block#4C %s: untagged нативный краш скоррелирован -> плагин=%r (type=%s choice=%s frame_match=%s age=%sms) -- ЭВРИСТИКА conf=%s"
                             % (_corr_prefix, owner, otype, choice, frame_match, age, ("high" if frame_match else "medium")))
            except Exception as _eg:
                _log("Block#4C +BL correlate err: %s" % _eg)
        if rec.get("pid") is None and rec.get("host_native") and rec.get("host_so"):
            _hb = rec.get("host_so") or ""
            rec["culprit_kind"] = "host"
            rec["host_so_owner"] = _hb.rsplit("/", 1)[-1] if _hb else None
            rec["pid_choice_src"] = "host_so"
            rec["pid_resolve_src"] = "host_native"
            _log("Block#4C +CJ(host-native): краш в собственном native хоста -> host_so=%s fso_src=%s cause=%s (culprit_kind=host, не плагин)"
                 % (rec.get("host_so"), rec.get("fso_src"), rec.get("cause")))
        if rec.get("culprit_kind") is None:
            rec["culprit_kind"] = "plugin" if rec.get("pid") is not None else "system"
        if rec.get("pid") is not None and a_pid is not None and a_pid >= 0 and c_pid is not None and c_pid >= 0 and a_pid != c_pid:
            _log(f"Block#4C: scope(active_pid={a_pid}) и culprit_pid={c_pid} рас��одятся -> вы��ран источник '{rec.get('pid_choice_src')}' (плагин={rec.get('pid')!r})")
        try:
            if rec.get("ts") is None:
                try: rec["ts"] = int(os.path.getmtime(p) * 1000)
                except Exception: rec["ts"] = int(time.time() * 1000)
        except Exception: pass
        try:
            if rec.get("confidence") is None:
                _ck = rec.get("culprit_kind")
                if _ck == "plugin" and rec.get("pid") is not None:
                    rec["confidence"] = "high"
                elif _ck == "host" and rec.get("host_so"):
                    rec["confidence"] = "high"
        except Exception: pass
        try:
            _ncvp = _native_crash_verdict_path()
            if _ncvp:
                _atomic_json_write(_ncvp, rec)
                _log("Block#4C: native_crash_verdict.json записан (kind=%s plugin=%r host_so=%r signo=%s cause=%s)"
                     % (rec.get("culprit_kind"), rec.get("pid"), rec.get("host_so"), rec.get("signo"), rec.get("cause")))
        except Exception as _env:
            _log("native_crash_verdict write err: %s" % _env)

        try: os.remove(p)
        except Exception: pass
        return rec
    except Exception as e:
        _log(f"native crash read err: {e}")
        return None

def _get_declared_methods(cls, label=""):
    if cls is None: return []
    try:
        return list(cls.getDeclaredMethods())
    except Exception:
        try:
            return list(cls.getClass().getDeclaredMethods())
        except Exception as e:
            _log(f"getDeclaredMethods failed for {label}: {e}"); return []

import sys as _sys, functools as _functools, gc as _gc

_ENTRY_CBS = (
    "on_plugin_load", "on_plugin_unload", "on_settings_changed", "create_settings",
    "on_send_message_hook", "pre_request_hook", "post_request_hook",
    "on_update_hook", "on_updates_hook", "on_app_event", "on_app_update",
)
_B_TAGGED_FLAG = "__culprit_scoped__"

def _canonical_pid(obj):
    mod_name = getattr(type(obj), "__module__", None)
    mod = _sys.modules.get(mod_name) if mod_name else None
    pid = getattr(mod, "__id__", None) if mod is not None else None
    return pid or mod_name or "unknown"

def _pid_of_module(mod_name):
    if not mod_name: return None
    try:
        mod = _sys.modules.get(mod_name)
    except Exception:
        mod = None
    if mod is None: return None
    pid = getattr(mod, "__id__", None)
    if isinstance(pid, str) and pid and pid != _SELF_ID and pid != __id__:
        return pid
    return None

def _pid_of_callable(fn):
    try:
        return _pid_of_module(getattr(fn, "__module__", None))
    except Exception:
        return None

def _provenance_pid(thread_obj=None, depth=0):
    try:
        if thread_obj is not None:
            tgt = getattr(thread_obj, "_target", None)
            if tgt is not None:
                pid = _pid_of_callable(tgt)
                if pid: return pid
            pid = _pid_of_module(getattr(type(thread_obj), "__module__", None))
            if pid: return pid
    except Exception:
        pass
    try:
        f = _sys._getframe(1 + int(depth))
    except Exception:
        f = None
    seen = 0
    while f is not None and seen < 40:
        try:
            g = f.f_globals
            pid = _pid_of_module(g.get("__name__"))
            if pid is None:
                _id = g.get("__id__")
                if isinstance(_id, str) and _id and _id != _SELF_ID and _id != __id__:
                    pid = _id
            if pid:
                return pid
        except Exception:
            pass
        try: f = f.f_back
        except Exception: f = None
        seen += 1
    return None

_UI_CB_ATTRS = ("on_click", "on_change", "on_value_change", "on_toggle", "callback", "on_select", "on_long_click")
_UI_CONTAINER_ATTRS = ("elements", "children", "items", "rows", "cells", "views", "subviews", "content", "body")
_UI_FACTORY_ATTRS = ("create_sub_fragment", "create_fragment", "build_fragment", "create_page", "sub_fragment")
def _wrap_ui_callbacks(pid, items, _depth=0, _seen=None):
    if _depth > 8: return
    if _seen is None: _seen = set()
    try:
        if items is None: return
        seq = list(items) if isinstance(items, (list, tuple)) else [items]
    except Exception:
        seq = None
    if not seq: return
    for it in seq:
        if it is None: continue
        try:
            k = id(it)
            if k in _seen: continue
            _seen.add(k)
        except Exception:
            pass
        for attr in _UI_CB_ATTRS:
            try:
                cb = getattr(it, attr, None)
            except Exception:
                cb = None
            if cb is None or not callable(cb): continue
            if getattr(cb, _B_TAGGED_FLAG, False): continue
            try: setattr(it, attr, _wrap_entry(pid, cb))
            except Exception: pass
        for fattr in _UI_FACTORY_ATTRS:
            try:
                fac = getattr(it, fattr, None)
            except Exception:
                fac = None
            if fac is None or not callable(fac): continue
            if getattr(fac, _B_TAGGED_FLAG, False): continue
            try: setattr(it, fattr, _wrap_settings_factory(pid, fac))
            except Exception: pass
        for cattr in _UI_CONTAINER_ATTRS:
            try:
                child = getattr(it, cattr, None)
            except Exception:
                child = None
            if child is None or callable(child): continue
            if isinstance(child, (str, bytes)): continue
            try: _wrap_ui_callbacks(pid, child, _depth + 1, _seen)
            except Exception: pass

def _wrap_settings_factory(pid, fn):
    if getattr(fn, _B_TAGGED_FLAG, False):
        return fn
    @_functools.wraps(fn)
    def _w(*a, **kw):
        pushed = _scoped_set(pid)
        try:
            items = fn(*a, **kw)
        finally:
            if pushed: _scoped_clear()
        try: _wrap_ui_callbacks(pid, items)
        except Exception: pass
        return items
    try: setattr(_w, _B_TAGGED_FLAG, True)
    except Exception: pass
    return _w

def _wrap_entry(pid, fn):
    if getattr(fn, _B_TAGGED_FLAG, False):
        return fn
    @_functools.wraps(fn)
    def _w(*a, **kw):
        pushed = _scoped_set(pid)
        try:
            return fn(*a, **kw)
        finally:
            if pushed: _scoped_clear()
    try: setattr(_w, _B_TAGGED_FLAG, True)
    except Exception: pass
    return _w

_SETTINGS_CTOR_HOOKED = False
_SETTINGS_ITEM_CLASSNAMES = ("Text", "Switch", "Selector", "Input", "Slider", "Header", "Divider", "Category", "Card", "Custom", "Toggle", "Button")
def _seed_settings_item(it):
    try:
        pid = _provenance_pid(None, 1)
    except Exception:
        pid = None
    if not pid or pid == _SELF_ID or pid == __id__:
        return
    for attr in _UI_CB_ATTRS:
        try: cb = getattr(it, attr, None)
        except Exception: cb = None
        if cb is None or not callable(cb): continue
        if getattr(cb, _B_TAGGED_FLAG, False): continue
        try: setattr(it, attr, _wrap_entry(pid, cb))
        except Exception: pass
    for fattr in _UI_FACTORY_ATTRS:
        try: fac = getattr(it, fattr, None)
        except Exception: fac = None
        if fac is None or not callable(fac): continue
        if getattr(fac, _B_TAGGED_FLAG, False): continue
        try: setattr(it, fattr, _wrap_settings_factory(pid, fac))
        except Exception: pass
def _install_settings_ctor_scope():
    global _SETTINGS_CTOR_HOOKED
    if _SETTINGS_CTOR_HOOKED:
        return
    uis = None
    try:
        uis = _sys.modules.get("ui.settings")
        if uis is None:
            import ui.settings as uis
    except Exception as e:
        _log("Gap8 settings-ctor: ui.settings unavailable: %r" % e)
        return
    n = 0
    for nm in dir(uis):
        try: cls = getattr(uis, nm, None)
        except Exception: cls = None
        if not isinstance(cls, type):
            continue
        mod = getattr(cls, "__module__", "") or ""
        if not (mod.startswith("ui.settings") or nm in _SETTINGS_ITEM_CLASSNAMES):
            continue
        orig = cls.__dict__.get("_culprit_orig_init", None)
        if orig is None:
            orig = cls.__dict__.get("__init__", None)
            if orig is None:
                continue
            try: cls._culprit_orig_init = orig
            except Exception: pass
        def _make(orig_init):
            def _patched(self, *a, **kw):
                orig_init(self, *a, **kw)
                try: _seed_settings_item(self)
                except Exception: pass
            return _patched
        try:
            cls.__init__ = _make(orig); n += 1
        except Exception:
            pass
    _SETTINGS_CTOR_HOOKED = True
    _log("Gap8/+BH settings-ctor scope: обёрнуто классов ui.settings=%d (on_change/on_click/create_sub_fragment тегируются в источнике)" % n)

_GPU_OP_FILE = "gpu_op.json"
_GPU_OP_WINDOW_MS = 8000
_GPU_HOOK_INSTALLED = 0
_GPU_LAST = {"owner": None, "ts": 0, "api": None}
_GPU_LOCK = threading.Lock()
_GPU_LAST_WRITE_TS = 0
_GPU_LAST_WRITE_OWNER = None
_GPU_WRITE_MIN_INTERVAL_MS = 1000
_GPU_WRITE_N = 0
_GPU_RS_LIB_HINTS = ("librs", "libRS", "rs_jni", "rsjni", "RSCpuRef", "RSDriver", "renderscript",
                     "libGLES", "libEGL", "libgpu", "libvulkan", "GLESv", "adreno", "mali",
                     "PowerVR", "rsdScript", "ScriptC")

_OP_DOMAIN_IDX = {"gpu": 0, "anim": 1, "mvel": 2, "binder": 3, "camera": 4, "mediacodec": 5, "gl": 6}
_OP_OWNER_MAX = 64
_OP_API_MAX = 48
_OP_NATIVE_OK = False

def _op_mark_native(domain, owner, api):
    if not _OP_NATIVE_OK or _NLIB is None or not _CTYPES_OK:
        return False
    try:
        d = _OP_DOMAIN_IDX.get(domain)
        if d is None:
            return False
        ob = str(owner or "").replace(" ", "_").encode("utf-8")[:_OP_OWNER_MAX - 1]
        ab = str(api or "").replace(" ", "_").encode("utf-8")[:_OP_API_MAX - 1]
        return int(_NLIB.cd_op_mark(ctypes.c_int32(d), ctypes.c_char_p(ob), ctypes.c_char_p(ab))) == 0
    except Exception:
        return False

def _gpu_op_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _GPU_OP_FILE).getAbsolutePath()
    except Exception:
        return None

def _gpu_mark(owner, api):
    if not owner or owner == _SELF_ID or owner == __id__:
        return
    try:
        rec = {"owner": owner, "ts": int(time.time() * 1000), "api": api}
        _op_mark_native("gpu", owner, api)
        with _GPU_LOCK:
            _GPU_LAST.update(rec)
    except Exception as _egm:
        try: _log("Block#4C +CE(gpu): gpu_mark err: %s" % _egm)
        except Exception: pass

def _gpu_owner_now():
    try:
        cur = _reg_get(_cur_tid())
        if cur is not None and cur >= 0:
            nm = _resolve_idx(cur)
            if nm and nm != _SELF_ID and nm != __id__:
                return nm
    except Exception:
        pass
    try:
        prov = _provenance_pid(None, 2)
        if prov and prov != _SELF_ID and prov != __id__:
            return prov
    except Exception:
        pass
    return None

def _gpu_read_op():
    try:
        p = _gpu_op_path()
        if not p or not os.path.exists(p): return None
        with open(p, "r", encoding="utf-8") as f:
            d = json.load(f)
        if isinstance(d, dict) and d.get("owner"): return d
    except Exception:
        pass
    return None

def _gpu_frames_hit_rs(frames):
    try:
        for fr in (frames or []):
            for h in _GPU_RS_LIB_HINTS:
                if h in fr:
                    return h
    except Exception:
        pass
    return None

