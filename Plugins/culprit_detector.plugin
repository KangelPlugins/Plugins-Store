        _log("Block#30: put killguard.txt nedostupen -- propusk"); return
    _pw = _aw_mirror_path(p) or p
    try:
        rc = int(_NLIB.cd_kg_start(_pw.encode("utf-8")))
    except Exception as e:
        _log("Block#30 cd_kg_start err: %s" % e); return
    if rc < 0:
        _log("Block#30: cd_kg_start vernul %d -- libc kill/exit ne zacepilis" % rc); return
    _B30_STARTED = True
    _log("Block#30: kill-guard установлен (libc kill/tgkill/exit/_exit/_Exit), хуков=%d -> %s" % (rc, _pw))
    try: _b30_read_sentinel("post-start")
    except Exception: pass

def _b30_stop():
