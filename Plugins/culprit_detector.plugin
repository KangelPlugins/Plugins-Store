                _CAMERA_HOOK_INSTALLED = 0
                _log("Block#4C +IN(camera-native): nativnyj put nedostupen ili selftest ne proshel -- Python-folbek UDALEN, camera op-stamp propuschen")
        except Exception as e:
            _log("Block#4C +IN(camera-native) install err: %s" % e)
    def _install_mediacodec_op_hook(self):
        global _MEDIACODEC_HOOK_INSTALLED
