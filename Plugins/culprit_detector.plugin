    def _install_b23_bitmap_hook(self):
        global _B23_INSTALLED
        if not _B23_ON:
            _log("Block#23: отключён (_B23_ON=False)"); return
        try:
            self._b23_unhooks = getattr(self, "_b23_unhooks", [])
            cls = _java_lang_class("android.graphics.Bitmap")
            if cls is None:
                _log("Block#23: android.graphics.Bitmap не найден — пропуск"); return
            try: methods = list(cls.getDeclaredMethods())
            except Exception: methods = []
            hooked = 0
            for m in methods:
                try:
                    nm = m.getName()
                    if nm == "createBitmap": hk = _BitmapCreateHook()
                    elif nm == "createScaledBitmap": hk = _BitmapScaleHook()
                    elif nm == "copy": hk = _BitmapCopyHook()
                    else: continue
                    try: m.setAccessible(True)
                    except Exception: pass
                    self._b23_unhooks.append(self.hook_method(m, hk, priority=_PRIO_MAX))
                    hooked += 1
                except Exception: pass
            _B23_INSTALLED = hooked
            _log("Block#23: Bitmap alloc hooks (createBitmap/createScaledBitmap/copy): %d" % hooked)
        except Exception as e:
            _log("Block#23 install err: %s" % e)

