                    _md_sk = None
                    try:
                        _md_vp = _kg_verdict_path()
                        if not (_md_vp and os.path.exists(_md_vp)):
                            try: _b30_read_sentinel("md-correlate")
                            except Exception: pass
                            _md_vp = _kg_verdict_path()
                        if _md_vp and os.path.exists(_md_vp):
                            with open(_md_vp, "r") as _mf:
                                _md_sk = json.load(_mf)
                    except Exception:
                        _md_sk = None
                    _md_ok = False
                    if isinstance(_md_sk, dict) and _md_sk.get("event_type") == "selfkill_blocked":
                        _md_cts = rec.get("crash_ts"); _md_bts = _md_sk.get("ts")
                        try:
                            if _md_cts is not None and _md_bts is not None:
                                _md_ok = abs(int(_md_cts) - int(_md_bts)) <= _MD_VERDICT_FRESH_MS
                            elif _md_cts is None:
                                _md_ok = (time.time() - os.path.getmtime(_md_vp)) * 1000.0 <= _MD_VERDICT_FRESH_MS
                        except Exception:
                            _md_ok = False
                    if not _md_ok:
                        try:
                            _md_hb = _md_hist_best(rec.get("crash_ts"))
                            if _md_hb is not None:
                                _md_sk = _md_hb; _md_ok = True
                        except Exception: pass
                    if _md_ok:
                        _md_cul = _deidx_name(_md_sk.get("culprit"))
                        rec["pid"] = _md_cul
                        rec["culprit_kind"] = "plugin" if _md_cul else "system"
                        rec["confidence"] = "medium"
                        rec["native_subtype"] = "selfkill_aftermath"
                        rec["pid_choice_src"] = "selfkill-aftermath"
                        rec["pid_resolve_src"] = "kg-correlated"
                        rec["unattributed_reason"] = None
                        rec["selfkill_aftermath"] = {
                            "block_ts": _md_sk.get("ts"), "block_culprit": _md_cul,
                            "vector": _md_sk.get("vector"), "signal": _md_sk.get("signal"),
                            "api": _md_sk.get("api"),
                        }
                        _log("Block#4C +MD: SIGILL wholly in JVM/ART runtime (%s) with fresh selfkill_blocked this session -> aftermath of blocked noreturn-exit; culprit=%r (conf=medium)" % (_md_where, _md_cul))
                    else:
                        rec["confidence"] = "low"
                        rec["unattributed_reason"] = "runtime-abort: SIGILL wholly in JVM/ART runtime (%s) without fresh selfkill_blocked -- runtime abort / not a standalone plugin crash" % _md_where
                        _log("Block#4C +MD: SIGILL in JVM/ART runtime (%s), no fresh selfkill -> runtime_abort_suspect, conf=low" % _md_where)
        except Exception as _emd:
            _log("Block#4C +MD err: %s" % _emd)

        try:
            if rec.get("tombstone_source") == "inprocess_native_dump" and rec.get("frames"):
                _tb = _parse_debuggerd_tombstone(fault_addr=rec.get("fault_addr"),
                                                 signo=rec.get("signo"),
                                                 crash_ts=rec.get("crash_ts") or rec.get("ts"))
                if _tb:
                    _mt_sym = _tombstone_symbolized_frames(_tb)
                    rec["symbolized_by"] = "debuggerd"
                    rec["corroboration"] = "tombstone_confirmed"
                    rec["tombstone_debuggerd"] = _tb
                    if rec.get("event_ts") is None:
                        _ev = _tb.get("event_ts") or _tb.get("logcat_ts")
                        if _ev is not None:
                            try: rec["event_ts"] = int(_ev)
                            except Exception: pass
                    rec["frames_symbolized"] = _mt_sym
                    try:
                        if any(_is_hook_frame(_hf) for _hf in _mt_sym):
                            rec["hook_involved"] = True
                    except Exception:
                        pass
                    if _tb.get("thread_name"):
                        rec["crash_thread_name"] = _tb["thread_name"]
                    _mt_top = None
                    for _f in (_tb.get("frames") or []):
                        if _f.get("symbol"):
                            _mt_top = _f.get("symbol"); break
                    if _mt_top:
                        rec["tombstone_top_symbol"] = _mt_top
                    _mt_skew = _tombstone_base_skew(rec.get("frames"), _tb)
                    if _mt_skew is not None:
                        rec["inproc_base_skew"] = int(_mt_skew)
                        rec["inproc_base_skew_hex"] = hex(int(_mt_skew) & ((1 << 64) - 1))
                    _mt_cls = _tombstone_symbol_class(_tb.get("frames"))
                    _so_msg = (rec.get("abort_message") or rec.get("abort_msg") or "")
                    if "stackoverflow" in _so_msg.lower():
                        rec["native_subtype"] = "stack_overflow"
                        rec["stack_overflow"] = True
                        rec["managed_interpreter_fault"] = False
                        _log("Block#4C +SO: abort_message=StackOverflowError -> native_subtype=stack_overflow (перекрывает frame-scan %r)" % _mt_cls)
                    elif _mt_cls and not rec.get("native_subtype"):
                        rec["native_subtype"] = _mt_cls
                        rec["managed_interpreter_fault"] = True
                    rec["tombstone_debuggerd"] = {
                        "thread_name": _tb.get("thread_name"), "tid": _tb.get("tid"),
                        "pid": _tb.get("pid"), "process": _tb.get("process"),
                        "abi": _tb.get("abi"), "build_fingerprint": _tb.get("build_fingerprint"),
                        "total_frames": _tb.get("total_frames"), "frames": _mt_sym,
                        "fault_addr": _tb.get("fault_addr"), "signo": _tb.get("signo"),
                        "code": _tb.get("code"),
                        "event_ts": _tb.get("logcat_ts"),
                    }
                    try:
                        _mt_cts = rec.get("crash_ts") or rec.get("ts")
                        if _tb.get("logcat_ts") is not None and _mt_cts is not None:
                            rec["tombstone_time_age_ms"] = abs(int(_tb["logcat_ts"]) - int(_mt_cts))
                        if _tb.get("match_score") is not None:
                            rec["tombstone_match_score"] = int(_tb["match_score"])
                    except Exception:
                        pass
                    rec["tombstone_norm_version"] = 2
                    _log("Block#4C +MT: debuggerd tombstone symbolized (thread=%r top=%r frames=%d skew=%s subtype=%r)"
                         % (rec.get("crash_thread_name"), rec.get("tombstone_top_symbol"),
                            len(_mt_sym), rec.get("inproc_base_skew_hex"), rec.get("native_subtype")))
                elif rec.get("corroboration") is None:
                    rec["corroboration"] = "inprocess_only"
        except Exception as _emt:
            _log("Block#4C +MT tombstone-mine err: %s" % _emt)
        try:
            if rec.get("confidence") is None and rec.get("culprit_kind") == "system" and rec.get("pid") is None:
                _resolved_any = any(("+0x" in _fr) for _fr in (rec.get("frames") or []))
                if rec.get("symbolized_by") == "debuggerd":
                    _tsym = rec.get("tombstone_top_symbol") or "?"
                    _tthr = rec.get("crash_thread_name") or "?"
                    if rec.get("managed_interpreter_fault"):
                        _ureason = "managed-metadata corruption: fault in ART interpreter (%s) on thread %r -- corrupted class/field pointer (native/JNI/hook misuse), not plugin-attributable [debuggerd-symbolized]" % (_tsym, _tthr)
                    else:
                        _ureason = "system native fault in %s on thread %r -- not plugin-attributable [debuggerd-symbolized]" % (_tsym, _tthr)
                elif rec.get("maps_trunc"):
                    _ureason = "unresolved-native: maps snapshot truncated (maps_n=%s) -- raise CD_MAPS_MAX" % rec.get("maps_n")
                elif not _resolved_any:
                    _ureason = "unresolved-native: no frame resolved to a module (anon/JIT/unmapped)"
                else:
                    _ureason = "unresolved-native: top fault frame unmapped"
                rec["confidence"] = "low"
                rec["unattributed_reason"] = _ureason
                try:
                    _ha_top = (rec.get("top_so") or "").lower()
                    _ha_managed = bool(rec.get("managed_frame")) or bool(rec.get("managed_mod")) or any(_x in _ha_top for _x in (".oat", ".art", ".odex", "dalvik-cache"))
                    _ha_inproc = (rec.get("corroboration") == "inprocess_only") or (rec.get("tombstone_source") == "inprocess_native_dump")
                    if _ha_managed:
                        rec["advisory_kind"] = "managed_art_sigsegv"
                        rec["native_advisory"] = ("вероятно ART/managed SIGSEGV (top_so=%s%s) -- краш внутри среды ART, не в нативном коде плагина%s" % (rec.get("top_so") or "?", (", managed_mod=%s" % rec.get("managed_mod")) if rec.get("managed_mod") else "", " [только in-process дамп: logcat запечатан хостом]" if _ha_inproc else ""))
                        _log("Block#4C +HA: managed/ART SIGSEGV advisory -> %s" % rec["native_advisory"])
                except Exception as _eha:
                    try: _log("Block#4C +HA advisory err: %s" % _eha)
                    except Exception: pass
                _log("Block#4C +DK: неатрибутированный нативный краш -> conf=low (%s; signo=%s cause=%s frames=%d maps_n=%s maps_trunc=%s)"
                     % (_ureason, rec.get("signo"), rec.get("cause"), len(rec.get("frames") or []), rec.get("maps_n"), rec.get("maps_trunc")))
        except Exception as _edk:
            _log("Block#4C +DK annotate err: %s" % _edk)
        try:
            if rec.get("abort_family") == "art_heap_corruption" and rec.get("pid") is None:
                _is_managed_heap_corruption(rec)
        except Exception as _eis:
            _log("Block#4C +IS heap-corruption err: %s" % _eis)
        try:
            _attach_heap_corruption_leads(rec)
        except Exception as _ehl:
            _log("Block#4C +KG heap-corruption-leads err: %s" % _ehl)
        try:
            if rec.get("pid") is None and rec.get("pid_resolve_src") == "bridge_scope_miss":
                _io_bridge_crash_attribute(rec)
        except Exception as _eio:
            _log("Block#4C +IO bridge-attrib err: %s" % _eio)
        try:
            _ncvp = _native_crash_verdict_path()
            if _ncvp:
                _atomic_json_write(_ncvp, rec)
                _log("Block#4C: native_crash_verdict.json записан (kind=%s plugin=%r host_so=%r signo=%s cause=%s)"
                     % (rec.get("culprit_kind"), rec.get("pid"), rec.get("host_so"), rec.get("signo"), rec.get("cause")))
        except Exception as _env:
            _log("native_crash_verdict write err: %s" % _env)
        try:
            _nhp = File(_DIR, _NATIVE_CRASH_HISTORY_NAME).getAbsolutePath()
            _nhist = []
            _nhrp = _rc_read_path(_nhp)
            if _nhrp:
                try:
                    with open(_nhrp, "r", encoding="utf-8") as _fnh: _nhist = list(json.load(_fnh))
                except Exception: _nhist = []
            _rts = rec.get("ts")
            if not any(isinstance(_h, dict) and _h.get("ts") == _rts for _h in _nhist):
                _nhist.append(rec)
                _atomic_json_write(_nhp, _nhist[-_NATIVE_CRASH_HISTORY_MAX:], _NATIVE_CRASH_HISTORY_MAX)
                _log("Block#4C +GO: native_crash_history.json дополнен (signo=%s cause=%s -> всего=%d)"
                     % (rec.get("signo"), rec.get("cause"), min(len(_nhist), _NATIVE_CRASH_HISTORY_MAX)))
        except Exception as _enh:
            _log("native_crash_history write err: %s" % _enh)

        try: os.remove(_rp)
        except Exception: pass
        return rec
    except Exception as e:
        _log(f"native crash read err: {e}")
        return None
    finally:
        if "_rp" in locals() and _rp:
            try: os.remove(_rp)
            except Exception: pass

def _get_declared_methods(cls, label=""):
    if cls is None: return []
    try:
        return list(cls.getDeclaredMethods())
    except Exception:
        try:
            return list(cls.getMethods())
        except Exception as e:
            _log(f"getDeclaredMethods failed for {label}: {e}"); return []

import sys as _sys, functools as _functools, gc as _gc

_ENTRY_CBS = (
    "on_plugin_load", "on_plugin_unload", "on_settings_changed", "create_settings",
    "on_send_message_hook", "pre_request_hook", "post_request_hook",
    "on_update_hook", "on_updates_hook", "on_app_event", "on_app_update",
)
_B_TAGGED_FLAG = "__culprit_scoped__"

def _canonical_pid(obj):
    mod_name = getattr(type(obj), "__module__", None)
    mod = _sys.modules.get(mod_name) if mod_name else None
    pid = getattr(mod, "__id__", None) if mod is not None else None
    return pid or mod_name or "unknown"

def _pid_of_module(mod_name):
    if not mod_name: return None
    try:
        mod = _sys.modules.get(mod_name)
    except Exception:
        mod = None
    if mod is None: return None
    pid = getattr(mod, "__id__", None)
    if isinstance(pid, str) and pid and pid != _SELF_ID and pid != __id__:
        return pid
    return None

def _pid_of_module_pkg(mod_name):
    pid = _pid_of_module(mod_name)
    if pid:
        return pid
    nm = mod_name or ""
    seen = 0
    while "." in nm and seen < 16:
        seen += 1
        nm = nm.rpartition(".")[0]
        if not nm:
            break
        pid = _pid_of_module(nm)
        if pid:
            return pid
    return None

def _pid_of_callable(fn):
    try:
        return _pid_of_module(getattr(fn, "__module__", None))
    except Exception:
        return None

def _provenance_pid(thread_obj=None, depth=0):
    try:
        if thread_obj is not None:
            tgt = getattr(thread_obj, "_target", None)
            if tgt is not None:
                pid = _pid_of_callable(tgt)
                if pid: return pid
            pid = _pid_of_module(getattr(type(thread_obj), "__module__", None))
            if pid: return pid
    except Exception:
        pass
    try:
        f = _sys._getframe(1 + int(depth))
    except Exception:
        f = None
    seen = 0
    while f is not None and seen < 40:
        try:
            g = f.f_globals
            pid = _pid_of_module(g.get("__name__"))
            if pid is None:
                _id = g.get("__id__")
                if isinstance(_id, str) and _id and _id != _SELF_ID and _id != __id__:
                    pid = _id
            if pid:
                return pid
        except Exception:
            pass
        try: f = f.f_back
        except Exception: f = None
        seen += 1
    return None

_UI_CB_ATTRS = ("on_click", "on_change", "on_value_change", "on_toggle", "callback", "on_select", "on_long_click")
_UI_CONTAINER_ATTRS = ("elements", "children", "items", "rows", "cells", "views", "subviews", "content", "body")
_UI_FACTORY_ATTRS = ("create_sub_fragment", "create_fragment", "build_fragment", "create_page", "sub_fragment")
def _wrap_ui_callbacks(pid, items, _depth=0, _seen=None):
    if _depth > 8: return
    if _seen is None: _seen = set()
    try:
        if items is None: return
        seq = list(items) if isinstance(items, (list, tuple)) else [items]
    except Exception:
        seq = None
    if not seq: return
    for it in seq:
        if it is None: continue
        try:
            k = id(it)
            if k in _seen: continue
            _seen.add(k)
        except Exception:
            pass
        for attr in _UI_CB_ATTRS:
            try:
                cb = getattr(it, attr, None)
            except Exception:
                cb = None
            if cb is None or not callable(cb): continue
            if getattr(cb, _B_TAGGED_FLAG, False): continue
            try: setattr(it, attr, _wrap_entry(pid, cb, attr in _UI_CLICK_ATTRS))
            except Exception: pass
        for fattr in _UI_FACTORY_ATTRS:
            try:
                fac = getattr(it, fattr, None)
            except Exception:
                fac = None
            if fac is None or not callable(fac): continue
            if getattr(fac, _B_TAGGED_FLAG, False): continue
            try: setattr(it, fattr, _wrap_settings_factory(pid, fac))
            except Exception: pass
        for cattr in _UI_CONTAINER_ATTRS:
            try:
                child = getattr(it, cattr, None)
            except Exception:
                child = None
            if child is None or callable(child): continue
            if isinstance(child, (str, bytes)): continue
            try: _wrap_ui_callbacks(pid, child, _depth + 1, _seen)
            except Exception: pass

def _wrap_settings_factory(pid, fn):
    if getattr(fn, _B_TAGGED_FLAG, False):
        return fn
    @_functools.wraps(fn)
    def _w(*a, **kw):
        pushed = _scoped_set(pid)
        try:
            items = fn(*a, **kw)
        finally:
            if pushed: _scoped_clear()
        try: _wrap_ui_callbacks(pid, items)
        except Exception: pass
        return items
    try: setattr(_w, _B_TAGGED_FLAG, True)
    except Exception: pass
    return _w

def _wrap_entry(pid, fn, ui_click=False):
    if getattr(fn, _B_TAGGED_FLAG, False):
        return fn
    @_functools.wraps(fn)
    def _w(*a, **kw):
        pushed = _scoped_set(pid)
        if ui_click:
            try: _ui_click_enter(pid)
            except Exception: pass
        try:
            return fn(*a, **kw)
        finally:
            if ui_click:
                try: _ui_click_leave()
                except Exception: pass
            if pushed: _scoped_clear()
    try: setattr(_w, _B_TAGGED_FLAG, True)
    except Exception: pass
    return _w

_SETTINGS_CTOR_HOOKED = False
_SETTINGS_ITEM_CLASSNAMES = ("Text", "Switch", "Selector", "Input", "Slider", "Header", "Divider", "Category", "Card", "Custom", "Toggle", "Button")
_SETTINGS_PATCHED = []


def _seed_settings_item(it):
    try:
        pid = _provenance_pid(None, 1)
    except Exception:
        pid = None
    if not pid or pid == _SELF_ID or pid == __id__:
        return
    for attr in _UI_CB_ATTRS:
        try: cb = getattr(it, attr, None)
        except Exception: cb = None
        if cb is None or not callable(cb): continue
        if getattr(cb, _B_TAGGED_FLAG, False): continue
        try: setattr(it, attr, _wrap_entry(pid, cb, attr in _UI_CLICK_ATTRS))
        except Exception: pass
    for fattr in _UI_FACTORY_ATTRS:
        try: fac = getattr(it, fattr, None)
        except Exception: fac = None
        if fac is None or not callable(fac): continue
        if getattr(fac, _B_TAGGED_FLAG, False): continue
        try: setattr(it, fattr, _wrap_settings_factory(pid, fac))
        except Exception: pass
def _install_settings_ctor_scope():
    global _SETTINGS_CTOR_HOOKED
    if _SETTINGS_CTOR_HOOKED:
        return
    uis = None
    try:
        uis = _sys.modules.get("ui.settings")
        if uis is None:
            import ui.settings as uis
    except Exception as e:
        _log("Gap8 settings-ctor: ui.settings unavailable: %r" % e)
        return
    n = 0
    for nm in dir(uis):
        try: cls = getattr(uis, nm, None)
        except Exception: cls = None
        if not isinstance(cls, type):
            continue
        mod = getattr(cls, "__module__", "") or ""
        if not (mod.startswith("ui.settings") or nm in _SETTINGS_ITEM_CLASSNAMES):
            continue
        orig = cls.__dict__.get("_culprit_orig_init", None)
        if orig is None:
            orig = cls.__dict__.get("__init__", None)
            if orig is None:
                continue
            try: cls._culprit_orig_init = orig
            except Exception: pass
        def _make(orig_init):
            def _patched(self, *a, **kw):
                orig_init(self, *a, **kw)
                try: _seed_settings_item(self)
                except Exception: pass
            return _patched
        try:
            _w = _make(orig)
            cls.__init__ = _w
            try: _SETTINGS_PATCHED.append((cls, orig, _w))
            except Exception: pass
            n += 1
        except Exception:
            pass
    _SETTINGS_CTOR_HOOKED = True
    _log("Gap8/+BH settings-ctor scope: обёрнуто классов ui.settings=%d (on_change/on_click/create_sub_fragment тегируются в источнике)" % n)

_GPU_OP_WINDOW_MS = 8000
_GPU_RS_LIB_HINTS = ("librs", "libRS", "rs_jni", "rsjni", "RSCpuRef", "RSDriver", "renderscript",
                     "libGLES", "libEGL", "libgpu", "libvulkan", "GLESv", "adreno", "mali",
                     "PowerVR", "rsdScript", "ScriptC")

_OP_DOMAIN_IDX = {"gpu": 0, "anim": 1, "mvel": 2, "binder": 3, "camera": 4, "mediacodec": 5, "gl": 6, "looper": 7, "xphook": 8, "bitmap": 9}

_OP_OWNER_MAX = 64
_OP_API_MAX = 48
_OP_NATIVE_OK = False
_MVEL_NATIVE_OK = False
_ANIM_NATIVE_OK = False
_ANIM_NATIVE_ON = True
_ANIM_ENTRY_OFFSET = 0
_LOOPER_NATIVE_OK = False
_LOOPER_NATIVE_ON = True
_HANDLER_NATIVE_OK = False
_HANDLER_NATIVE_ON = True
_HANDLER_NATIVE_ACTIVE = False
_POST_NATIVE_OK = False
_POST_NATIVE_ON = True
_POST_NATIVE_ACTIVE = False
_NOTIF_NATIVE_OK = False
_NOTIF_NATIVE_ON = True
_NOTIF_NATIVE_ACTIVE = False
_LOOPER_NATIVE_ACTIVE = False
_LOOPER_ENTRY_OFFSET = 0
_VERDICT_NATIVE_OK = False
_VERDICT_DEDUP = {}
_PSA_CLASS = "com.exteragram.messenger.plugins.ui.PluginSettingsActivity"
_PSA_DISPATCH_METHODS = ("onClick", "onLongClick")
_PSA_PLUGIN_ATTRS = ("getPlugin", "plugin", "currentPlugin", "mPlugin", "getPluginId", "pluginId", "shortcutId")
_PSA_ID_ATTRS = ("getId", "id", "pluginId", "getName", "name")
_PSA_TL = threading.local()

def _psa_tl_stk():
    s = getattr(_PSA_TL, "stk", None)
    if s is None: s = _PSA_TL.stk = []
    return s

def _psa_resolve_pid(inst):
    if inst is None: return None
    for _fn in _PSA_PLUGIN_ATTRS:
        try: v = getattr(inst, _fn, None)
        except Exception: continue
        if v is None: continue
        try:
            if callable(v): v = v()
        except Exception: continue
        if v is None: continue
        pid = v if isinstance(v, str) else None
        if pid is None:
            for _an in _PSA_ID_ATTRS:
                try: a = getattr(v, _an, None)
                except Exception: continue
                if a is None: continue
                try:
                    if callable(a): a = a()
                except Exception: continue
                if isinstance(a, str) and a: pid = a; break
        if isinstance(pid, str) and pid:
            try: pid = _canon_pid(pid)
            except Exception: pass
            if isinstance(pid, str) and pid and pid not in (_SELF_ID, __id__):
                return pid
    return None

class _PsaScopeHook(MethodHook):
    def before_hooked_method(self, param):
        pushed = False
        try:
            pid = _psa_resolve_pid(getattr(param, "thisObject", None))
            if pid: pushed = bool(_scoped_set(pid))
        except Exception:
            pushed = False
        try: _psa_tl_stk().append(pushed)
        except Exception: pass
    def after_hooked_method(self, param):
        try:
            st = _psa_tl_stk()
            if st and st.pop(): _scoped_clear()
        except Exception:
            pass

_KZ_MO_AMBIG = "\x00ambig"
_KZ_MO_CAP = 512
_KZ_MO_LOCK = threading.Lock()
_KZ_MO_MAP = {}

def _kz_mo_note(mname, pid):
    if not mname or not pid: return
    if pid in (_SELF_ID, __id__): return
    if "." in mname or " " in mname: return
    try:
        with _KZ_MO_LOCK:
            cur = _KZ_MO_MAP.get(mname)
            if cur is None:
                if len(_KZ_MO_MAP) < _KZ_MO_CAP:
                    _KZ_MO_MAP[mname] = pid
            elif cur != pid and cur != _KZ_MO_AMBIG:
                _KZ_MO_MAP[mname] = _KZ_MO_AMBIG
    except Exception:
        pass

def _kz_mo_lookup(jframes):
    try:
        for _f in (jframes or []):
            if "LSPHooker_." not in _f: continue
            _mn = _f.split("LSPHooker_.", 1)[1].split("(", 1)[0].strip()
            if not _mn: continue
            _o = _KZ_MO_MAP.get(_mn)
            if _o and _o != _KZ_MO_AMBIG:
                return _o, _mn
    except Exception:
        pass
    return None, None

_IU_BRIDGE_NAMES = ("PyMethodHook", "com.exteragram.messenger.plugins.xposed",
                    "HookCallbackDispatcher", "XposedBridge", "callThrowsNative",
                    "LSPHooker_")

def _iu_stack_is_bridge(jframes, component):
    
    try:
        if component and any(_s in component for _s in _IU_BRIDGE_NAMES):
            return True
        for _f in (jframes or [])[:8]:
            if any(_s in _f for _s in _IU_BRIDGE_NAMES):
                return True
    except Exception:
        pass
    return False

def _iu_bridge_owner(jframes, waited_ms):
    
    try:
        _op = _b20_owner_from_op(int(waited_ms) + 2500)
        if _op and _op.get("owner"):
            return _op.get("owner"), ("op:" + str(_op.get("domain") or "?"))
    except Exception:
        pass
    try:
        _o, _fr, _how, _meta = _hook_owner_for_frames(jframes or [])
        if _o and _o not in (_SELF_ID, __id__):
            return _o, ("hook-map:" + str(_how))
    except Exception:
        pass
    try:
        _o2, _mn2 = _kz_mo_lookup(jframes)
        if _o2:
            return _o2, ("reg-map:" + str(_mn2))
    except Exception:
        pass
    try:
        for _f in (jframes or []):
            _cls = _f.split("(", 1)[0].rsplit(".", 1)[0] if "(" in _f else _f
            _pid = _map_stack_to_id(_cls, _known_union()) if _cls else None
            if _pid and _pid not in (_SELF_ID, __id__):
                return _pid, "stack-loader"
    except Exception:
        pass
    return None, None

def _op_family_native_install(dom):
    
    _U = dom.upper()
    if not (globals().get("_%s_NATIVE_ON" % _U, True) and globals().get("_%s_NATIVE_OK" % _U, False)
            and _NLIB is not None and _CTYPES_OK):
        return (False, 0)
    off = int(globals().get("_%s_ENTRY_OFFSET" % _U, 0) or 0)
    try:
        _self = getattr(_NLIB, "cd_%s_selftest" % dom)
        _inst = getattr(_NLIB, "cd_%s_install" % dom)
    except Exception:
        return (False, 0)
    try:
        _ok = int(_self(ctypes.c_int32(off)))
    except Exception:
        _ok = 0
    if _ok <= 0:
        return (False, 0)
    try:
        _n = int(_inst(ctypes.c_int32(off)))
    except Exception:
        _n = 0
    if _n > 0:
        return (True, _n)
    return (False, 0)

def _mvel_native_diag():
    try:
        if _NLIB is None or not _CTYPES_OK or not hasattr(_NLIB, "cd_mvel_diag"):
            return None
        _cap = 10
        _buf = (ctypes.c_int64 * _cap)()
        _w = int(_NLIB.cd_mvel_diag(_buf, ctypes.c_int(_cap)))
        if _w <= 0:
            return None
        _r = [int(_buf[i]) for i in range(min(_w, _cap))]
        return _r + [0] * max(0, _cap - len(_r))
    except Exception:
        return None

