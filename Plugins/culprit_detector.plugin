def _b19_build_struct(maxf, pathmax):
    c = ctypes
    class B19Event(c.Structure):
        _fields_ = [("tid", c.c_int64),
                    ("ts_ms", c.c_int64),
                    ("symbol", c.c_int32),
                    ("nframes", c.c_int32),
                    ("lines", c.c_int32 * maxf),
                    ("files", (c.c_char * pathmax) * maxf)]
    return B19Event

def _b19_init(lib):
    global _B19_OK, _B19Event, _B19_RING_CAP, _B19_REC_SIZE, _B19_MAX_FRAMES, _B19_PATH_MAX, _B19_EVBUF, _B19_EVADDR
    c = ctypes
    needed = ("cd_b19_start", "cd_b19_stop", "cd_b19_ring_addr", "cd_b19_ring_cap",
              "cd_b19_rec_size", "cd_b19_max_frames", "cd_b19_path_max",
              "cd_b19_committed", "cd_b19_running", "cd_b19_read_event")
    if not all(hasattr(lib, n) for n in needed):
        _B19_OK = False
        _log("Block#19: cd_b19_* нет в .so (старый бинарь) — JNI-py-атрибуция отключена")
        return False
    try:
        lib.cd_b19_start.restype = c.c_int
        lib.cd_b19_stop.restype = c.c_int
        lib.cd_b19_ring_addr.restype = c.c_uint64
        lib.cd_b19_ring_cap.restype = c.c_int32
        lib.cd_b19_rec_size.restype = c.c_int32
        lib.cd_b19_max_frames.restype = c.c_int32
        lib.cd_b19_path_max.restype = c.c_int32
        lib.cd_b19_committed.restype = c.c_int64
        lib.cd_b19_running.restype = c.c_int
        lib.cd_b19_read_event.restype = c.c_int
        lib.cd_b19_read_event.argtypes = [c.c_int64, c.c_void_p]
        lib.cd_b19_eventfd.restype = c.c_int
        lib.cd_b19_event_wake.restype = c.c_int
        for opt in ("cd_b19_boundary_hits", "cd_b19_tb_captures", "cd_b19_dropped"):
            try: getattr(lib, opt).restype = c.c_int64
            except Exception: pass
        _B19_MAX_FRAMES = int(lib.cd_b19_max_frames())
        _B19_PATH_MAX = int(lib.cd_b19_path_max())
        _B19_REC_SIZE = int(lib.cd_b19_rec_size())
        _B19_RING_CAP = int(lib.cd_b19_ring_cap())
        if _B19_MAX_FRAMES <= 0 or _B19_PATH_MAX <= 0 or _B19_RING_CAP <= 0:
            _B19_OK = False
            _log("Block#19: невалидные размеры от натива — отключаю")
            return False
        _B19Event = _b19_build_struct(_B19_MAX_FRAMES, _B19_PATH_MAX)
        if c.sizeof(_B19Event) != _B19_REC_SIZE:
            _B19_OK = False
            _log("Block#19: размер записи не совпал (py=%d native=%d) — отключаю" % (c.sizeof(_B19Event), _B19_REC_SIZE))
            return False
        _B19_EVBUF = _B19Event()
        _B19_EVADDR = c.addressof(_B19_EVBUF)
        _B19_OK = True
        _log("Block#19: cd_b19_* ок (cap=%d rec=%dB maxf=%d path=%d)" % (_B19_RING_CAP, _B19_REC_SIZE, _B19_MAX_FRAMES, _B19_PATH_MAX))
        return True
    except Exception as e:
        _B19_OK = False
        _log("Block#19 init err: %s: %s" % (type(e).__name__, e))
        return False

def _b19_cstr(arr):
    try:
        return bytes(arr).split(b"\x00", 1)[0].decode("utf-8", "replace")
    except Exception:
        return ""

def _b19_file_plugin_map():
    m = {}
    try:
        for mod in list(_sys.modules.values()):
            try:
                pid = getattr(mod, "__id__", None)
                fn = getattr(mod, "__file__", None)
                if not (isinstance(pid, str) and pid and isinstance(fn, str) and fn):
                    continue
                if pid == _SELF_ID or pid == __id__:
                    continue
                try: pid = _canon_pid(pid)
                except Exception: pass
                m[fn] = pid
                try: m[os.path.abspath(fn)] = pid
                except Exception: pass
                try: m[os.path.basename(fn)] = pid
                except Exception: pass
            except Exception: pass
    except Exception as e:
        try: _log("Block#19: file->plugin map build err: %s: %s" % (type(e).__name__, e))
        except Exception: pass
    if not m:
        try: _log("Block#19: file->plugin map ПУСТА -- атрибуция Python-ошибок уйдёт в untagged")
        except Exception: pass
    return m

def _b19_culprit_from_event(ev, fmap):
    n = int(ev.nframes)
    if n > _B19_MAX_FRAMES: n = _B19_MAX_FRAMES
    deepest_file = None; deepest_line = -1
    if n > 0:
        deepest_file = _b19_cstr(ev.files[n - 1]); deepest_line = int(ev.lines[n - 1])
    pid = None; pfile = None; pline = -1
    for i in range(n - 1, -1, -1):
        f = _b19_cstr(ev.files[i])
        cand = fmap.get(f)
        if cand is None:
            try: cand = fmap.get(os.path.basename(f))
            except Exception: cand = None
        if isinstance(cand, str) and cand:
            pid = cand; pfile = f; pline = int(ev.lines[i]); break
    return pid, pfile, pline, deepest_file, deepest_line

