                ("android.hardware.camera2.impl.CameraDeviceImpl", ("createCaptureSession", "createCaptureSessionByOutputConfigurations")),
                ("android.hardware.camera2.CameraCaptureSession", ("setRepeatingRequest", "setRepeatingBurst", "capture", "captureBurst")),
                ("android.hardware.camera2.impl.CameraCaptureSessionImpl", ("setRepeatingRequest", "setRepeatingBurst", "capture", "captureBurst")),
            )
            hooked = 0
            for cls_name, meth_names in targets:
                cls = _java_lang_class(cls_name)
                if cls is None:
                    continue
                try: methods = list(cls.getDeclaredMethods())
                except Exception: methods = []
                for m in methods:
                    try:
                        if m.getName() not in meth_names:
                            continue
                        if not _method_hookable(m):
                            continue
                        try: m.setAccessible(True)
                        except Exception: pass
                        self._camera_unhooks.append(self.hook_method(m, _CameraOpHook(), priority=_PRIO_MAX))
                        hooked += 1
                    except Exception:
                        pass
            _CAMERA_HOOK_INSTALLED = hooked
            if hooked:
                _log("Block#4C +BU(camera): Camera2 op-stamp hooks (CameraManager.openCamera/CameraDevice.createCaptureSession/CameraCaptureSession.setRepeatingRequest+capture): %d" % hooked)
            else:
                _log("Block#4C +BU(camera): android.hardware.camera2 классы недоступны (плагин без Camera2 или нет разрешения) -- пропуск")
        except Exception as e:
            _log("Block#4C +BU(camera) install err: %s" % e)

