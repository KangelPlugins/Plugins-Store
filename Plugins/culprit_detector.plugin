                try: methods = list(cls.getDeclaredMethods())
                except Exception: methods = []
                for m in methods:
                    try:
                        if m.getName() not in meth_names:
                            continue
                        try: m.setAccessible(True)
                        except Exception: pass
                        self._gl_unhooks.append(self.hook_method(m, _GlOpHook(), priority=_PRIO_MAX))
                        hooked += 1
                    except Exception:
                        pass
            _GL_HOOK_INSTALLED = hooked
            if hooked:
                _log("Block#4C +BW(gl): GL render-thread op-stamp hooks (GLSurfaceView.setRenderer/requestRender/queueEvent + EGL14.eglCreateContext/eglMakeCurrent/eglCreateWindowSurface): %d" % hooked)
            else:
                _log("Block#4C +BW(gl): android.opengl.GLSurfaceView/EGL14 классы недоступны -- пропуск")
        except Exception as e:
            _log("Block#4C +BW(gl) install err: %s" % e)

    def _install_loader_hook(self):
        if not (_B4C_OK and _NLIB is not None):
            _log("Block#4C: натив без #4C-символов — хук загрузчика пропущен"); return
        try:
            self._loader_unhooks = getattr(self, "_loader_unhooks", [])
            cls = _java_lang_class("dalvik.system.BaseDexClassLoader")
            if cls is None:
                _log("Block#4C: BaseDexClassLoader не найден — пропуск"); return
            hooked = 0
            for ctor in list(cls.getDeclaredConstructors()):
                try:
                    ctor.setAccessible(True)
                    self._loader_unhooks.append(self.hook_method(ctor, _LoaderHook(), priority=_PRIO_MAX))
                    hooked += 1
                except Exception: pass
            _log(f"Block#4C: хук конструкторов BaseDexClassLoader: {hooked}")
        except Exception as e:
            _log(f"Block#4C install loader-hook err: {e}")

    def _install_appevent(self):
        try:
            self._appevent_unhooks = getattr(self, "_appevent_unhooks", [])
            engine = find_class("com.exteragram.messenger.plugins.PythonPluginsEngine")
            if engine is None: _log("appevent: engine class not found"); return
            installed = 0
            for m in _get_declared_methods(engine, "PythonPluginsEngine"):
                try:
                    if m.getName() != "executeOnAppEvent": continue
                    try: m.setAccessible(True)
                    except Exception: pass
                    self._appevent_unhooks.append(self.hook_method(m, _AppEventHook(), priority=_PRIO_MAX))
                    installed += 1
                except Exception as e:
                    _log(f"scan executeOnAppEvent err: {e}")
            _log(f"Block#8: executeOnAppEvent hook installed: {installed}")
        except Exception as e:
            _log(f"install executeOnAppEvent err: {e}")

    def _install_execute(self):
        try:
            engine = find_class("com.exteragram.messenger.plugins.PythonPluginsEngine")
            if engine is None: _log("engine class not found"); return
            installed = 0
            for m in _get_declared_methods(engine, "PythonPluginsEngine"):
                try:
                    if m.getName() != "executeHook": continue
                    ps = m.getParameterTypes()
                    if len(ps) != 6 or ps[0].getName() != "java.lang.String": continue
                    try: m.setAccessible(True)
                    except Exception: pass
                    self._exec_unhooks.append(self.hook_method(m, _ExecHook(), priority=_PRIO_MAX))
                    installed += 1
                except Exception as e:
                    _log(f"scan executeHook err: {e}")
            _log(f"executeHook(String) hook installed: {installed}")
        except Exception as e:
            _log(f"install executeHook err: {e}")

    def _install_exec_errcb(self):
        if not _BLOCK9_ON: return
        self._execcb_unhooks = getattr(self, "_execcb_unhooks", [])
        try:
            from java import dynamic_proxy
        except Exception as e:
            _log("Block#9: dynamic_proxy недоступен — пропуск: %s" % e); return
        try:
            from org.telegram.messenger import Utilities
        except Exception as e:
            _log("Block#9: Utilities недоступен — пропуск: %s" % e); return
        try:
            iface = Utilities.Callback
        except Exception as e:
            _log("Block#9: Utilities.Callback недоступен — пропуск: %s" % e); return
        try:
            class _ExecErrCb(dynamic_proxy(iface)):
                def __init__(self, orig, scoped):
                    super().__init__()
                    self._orig = orig
                    self._scoped = scoped
                def run(self, py_exception):
                    try: _record_hook_fail(py_exception, "executeHook", self._scoped)
                    except Exception: pass
                    try:
                        if self._orig is not None: self._orig.run(py_exception)
                    except Exception: pass
            def _factory(orig, scoped): return _ExecErrCb(orig, scoped)
        except Exception as e:
            _log("Block#9: proxy build err: %s" % e); return
        try:
            engine = find_class("com.exteragram.messenger.plugins.PythonPluginsEngine")
            if engine is None: _log("Block#9: engine class not found"); return
            installed = 0
            for m in _get_declared_methods(engine, "PythonPluginsEngine"):
                try:
                    if m.getName() != "executeHook": continue
                    ps = m.getParameterTypes()
                    if len(ps) != 6: continue
                    if ps[0].getName() != "com.chaquo.python.PyObject": continue
                    try: m.setAccessible(True)
                    except Exception: pass
                    self._execcb_unhooks.append(self.hook_method(m, _ExecCbHook(_factory), priority=_PRIO_MAX))
                    installed += 1
                except Exception as e:
                    _log("Block#9: scan executeHook err: %s" % e)
            _log("Block#9: executeHook(PyObject) error-cb installed: %d" % installed)
        except Exception as e:
            _log("Block#9: install err: %s" % e)

    def _install_loadplugin(self):
        try:
            engine = find_class("com.exteragram.messenger.plugins.PythonPluginsEngine")
            if engine is None: return
            hooked = 0
            for m in _get_declared_methods(engine, "PythonPluginsEngine"):
                try:
                    if m.getName() != "loadPlugin": continue
                    try: m.setAccessible(True)
                    except Exception: pass
                    self._load_unhooks.append(self.hook_method(m, _LoadHook(), priority=_PRIO_MAX))
                    hooked += 1
                except Exception as e:
                    _log(f"scan loadPlugin err: {e}")
            _log(f"loadPlugin hook installed on {hooked} overload(s)")
        except Exception as e:
            _log(f"install loadPlugin err: {e}")

    _UI_VERDICT_SOURCES = [
        ("native_crash_verdict.json", "КРАШ (нативный)", "💥", "уронил приложение нативным сбоем", None),
        ("crash_verdict.json",        "КРАШ приложения", "❌", "уронил приложение", None),
        ("crash_verdict_persisted.json", "КРАШ приложения", "❌", "уронил приложение", None),
        ("anr_verdict.json",          "ЗАВИСАНИЕ (ANR)", "🦊", "заморозил интерфейс", ("had_anr",)),
        ("oom_dump*.json",            "НЕХВАТКА ПАМЯТИ (OOM)", "🧠", "съел память", ("had_oom",)),
        ("b23_bitmap_oom*.json",      "OOM от картинок", "🧠", "съел память картинками", None),
        ("bg_verdict.json",           "СБОЙ в фоне", "⚠️", "упал в фоновом потоке", ("had_bg_fail",)),
        ("cb_verdict.json",           "СБОЙ в колбэке", "⚠️", "упал в колбэке", ("had_cb_fail",)),
        ("ui_verdict.json",           "СБОЙ в интерфейсе", "⚠️", "упал в обработчике UI", None),
        ("dispatch_verdict.json",     "СБОЙ диспетчера", "⚠️", "упал в диспетчере", None),
        ("future_verdict.json",       "СБОЙ Future", "⚠️", "упал в Future", None),
        ("async_verdict.json",        "СБОЙ asyncio", "⚠️", "упал в asyncio", None),
        ("pyerr_verdict.json",        "ОШИБКА Python", "⚠️", "выбросил ошибку Python", ("had_pyerr_fail",)),
        ("load_verdict.json",         "СБОЙ ЗАГРУЗКИ", "🔌", "упал при загрузке/импорте", None),
        ("hook_verdict.json",         "СБОЙ ХУКА", "🪝", "вызвал ошибку внутри Xposed-хука", None),
        ("leak_verdict.json",         "УТЕЧКА VIEW", "🩸", "оставил висеть view после выгрузки", None),
        ("gate_verdict.json",         "БЛОКИРОВКА", "⛔", "не прошёл проверку при старте", None),
        ("cxa_verdict.json",          "C++ ИСКЛЮЧЕНИЕ", "💣", "выбросил C++ исключение", None),
        ("globalref_verdict.json",    "УТЕЧКА JNI-ССЫЛОК", "🩸", "переполнил таблицу JNI global-references", None),
    ]

    def _t(self, s):
        return _cd_tr(s)

    def _ui_conf_label(self, c):
        try:
            c = str(c or "").lower()
        except Exception:
            c = ""
        if c.startswith("high") or c == "высокая": return self._t("🟢 высокая")
        if c.startswith("med") or c == "средняя":  return self._t("🟡 средняя")
        if c.startswith("low") or c == "низкая":   return self._t("🟠 низкая")
        return "⚪️ —"

    def _ui_when(self, ts):
        try:
            import time as _t
            if ts is None: return "—"
            if isinstance(ts, str):
                if "-" in ts and ":" in ts: return ts[5:16].replace("-", ".")
                ts = float(ts)
            ts = float(ts)
            if ts > 1e11: ts = ts / 1000.0
            return _t.strftime("%d.%m %H:%M", _t.localtime(ts))
        except Exception:
            return "—"

    def _ui_pretty_plugin(self, name):
        try:
            s = str(name or "").strip()
            if not s: return self._t("неизвестный плагин")
            if "/" in s: s = s.rsplit("/", 1)[1]
            if s.endswith(".py"): s = s[:-3]
            return self._t(s)
        except Exception:
            return self._t("неизвестный плагин")

    def _ui_extract(self, d, src):
        try:
            fname, label, emoji, what, gate = src
            if not isinstance(d, dict): return None
            if gate and not any(bool(d.get(g)) for g in gate): return None
            vd = d.get("verdict") if isinstance(d.get("verdict"), dict) else {}
            def _g(k):
                v = d.get(k)
                if v is None: v = vd.get(k)
                return v
            ck = d.get("culprit_kind")
            is_native = (fname == "native_crash_verdict.json")
            if isinstance(ck, str) and ck == "system" and not is_native:
                return None
            culprit = (d.get("culprit") or d.get("crashed_plugin_id")
                       or vd.get("culprit") or _g("top_named")
                       or d.get("pid") or d.get("plugin")
                       or d.get("py_module") or d.get("scoped_pid")
                       or d.get("owner"))
            if not culprit and isinstance(ck, str):
                if ck.startswith("plugin:"):
                    culprit = ck.split(":", 1)[1]
                elif ck == "host":
                    culprit = d.get("host_so_owner") or "host"
            if not culprit:
                top = d.get("top")
                if isinstance(top, list) and top:
                    try:
                        first = top[0]
                        culprit = first[0] if isinstance(first, (list, tuple)) else first
                    except Exception:
                        culprit = None
            if not culprit and is_native:
                culprit = _UNTAGGED_LABEL
            if not culprit: return None
            reason = _g("reason")
            try:
                db = vd.get("display_bytes") or vd.get("culprit_bytes")
                sh = vd.get("display_share") or vd.get("share")
                if db:
                    mb = float(db) / 1048576.0
                    human = self._t("съел %.0f МБ") % mb
                    if sh:
                        human += " (%.0f%%)" % (float(sh) * 100.0)
                    _rd = vd.get("reason_detail") or ""
                    if _rd == "async_download_pattern":
                        _unt = vd.get("untagged_bytes") or 0
                        _tnb = vd.get("culprit_bytes") or 0
                        _ar = round(float(_unt) / float(_tnb), 1) if _tnb > 0 else 0.0
                        human += " +async×%.1f" % _ar
                    elif _rd == "rate_suspect":
                        human += self._t(" (подозрев.)")
                    reason = human
            except Exception:
                pass
            if not reason:
                if d.get("cause"): reason = str(d.get("cause"))
                elif d.get("exc_cls"): reason = "%s: %s" % (d.get("exc_cls"), d.get("exc_msg"))
                elif d.get("stalled_ms"): reason = self._t("интерфейс не отвечал %s мс") % d.get("stalled_ms")
                elif vd.get("reason_detail"): reason = str(vd.get("reason_detail"))
                elif d.get("summary"): reason = str(d.get("summary"))
                else: reason = ""
            where = ""
            if d.get("py_file"):
                pf = str(d.get("py_file")).split("/")[-1]
                where = pf + ((":" + str(d.get("py_line"))) if d.get("py_line") else "")
            elif d.get("host_so"):
                where = self._t("нативная библиотека: ") + str(d.get("host_so")).split("/")[-1]
            elif _g("where"):
                where = str(_g("where"))
            ts = d.get("ts")
            tss = 0
            try:
                if isinstance(ts, (int, float)):
                    tss = float(ts) / 1000.0 if ts > 1e11 else float(ts)
                elif isinstance(ts, str):
                    import time as _t2
                    if "-" in ts and ":" in ts:
                        tss = _t2.mktime(_t2.strptime(ts, "%Y-%m-%d %H:%M:%S"))
                    else:
                        tss = float(ts)
                        if tss > 1e11: tss = tss / 1000.0
            except Exception:
                tss = 0
            return {"label": self._t(label), "emoji": emoji, "what": self._t(what),
                    "culprit": self._ui_pretty_plugin(culprit),
                    "conf": self._ui_conf_label(_g("confidence")),
                    "reason": reason, "where": where, "ts": ts, "ts_sort": tss}
        except Exception:
            return None

    def _ui_wrap(self, s, width=36):
        try:
            s = str(s or "")
        except Exception:
            s = ""
        if not s:
            return [""]
        out = []
        line = ""
        for word in s.split(" "):
            w = word
            while len(w) > width:
                if line:
                    out.append(line)
                    line = ""
                out.append(w[:width])
                w = w[width:]
            if not line:
                line = w
            elif len(line) + 1 + len(w) <= width:
                line = line + " " + w
            else:
                out.append(line)
                line = w
        if line:
            out.append(line)
        return out or [""]

    def _ui_field(self, rows, title, body, icon, accent=False):
        try:
            lines = self._ui_wrap(body, 36)
        except Exception:
            lines = [str(body or "")]
        try:
            rows.append(Text(text=title, subtext=lines[0], icon=icon, accent=accent))
            for ln in lines[1:]:
                rows.append(Text(text="", subtext=ln, icon=icon))
        except Exception:
            rows.append(Text(text=title, icon=icon))

    def _ui_collect_culprits(self):
        cards = []
        try:
            import os, json, glob
            for src in self._UI_VERDICT_SOURCES:
                pattern = _DIR + "/" + src[0]
                try:
                    paths = glob.glob(pattern)
                except Exception:
                    paths = []
                for p in paths:
                    try:
                        with open(p, "r", encoding="utf-8", errors="replace") as fh:
                            d = json.load(fh)
                    except Exception:
                        continue
                    items = d if isinstance(d, list) else [d]
                    for it in items:
                        card = self._ui_extract(it, src)
                        if card: cards.append(card)
        except Exception as e:
            _log("ui collect culprits err: %s" % e)
        try:
            seen = set(); uniq = []
            for c in cards:
                k = (c.get("label"), c.get("culprit"), c.get("ts"))
                if k in seen: continue
                seen.add(k); uniq.append(c)
            cards = uniq
        except Exception:
            pass
        try:
            cards.sort(key=lambda c: c.get("ts_sort") or 0, reverse=True)
        except Exception:
            pass
        return cards

    def _ui_clear(self, *a):
        n = 0
        try:
            import os, glob
            patterns = [s[0] for s in self._UI_VERDICT_SOURCES] + [_NATIVE_CRASH_NAME, _OOM_SENTINEL_NAME]
            for nm in patterns:
                for p in glob.glob(_DIR + "/" + nm):
                    try:
                        if os.path.exists(p):
                            os.remove(p); n += 1
                    except Exception: pass
            _log("UI: очищено вердиктов=%d" % n)
        except Exception as e:
            _log("ui clear err: %s" % e)
        try:
            from ui.bulletin import BulletinHelper
            BulletinHelper.show_success(self._t("Очищено: %d. Переоткрой настройки.") % n)
        except Exception:
            pass

    def _ui_refresh_pending(self):
        try:
            _oom_consume_native("settings", do_log=False)
        except Exception:
            pass
        try:
            _read_native_crash()
        except Exception:
            pass
        try:
            _read_globalref_overflow(logcat=False)
        except Exception:
            pass

    def _ui_copy_results(self, *a):
        """Copy all culprit verdicts to clipboard."""
        try:
            cards = self._ui_collect_culprits()
            if not cards:
                try:
                    from ui.bulletin import BulletinHelper
                    BulletinHelper.show_info(self._t("Нет результатов для копирования"))
                except Exception:
                    pass
                return
            lines = []
            lines.append("=" * 70)
            lines.append(self._t("🕵️ Culprit Detector — Результаты анализа виновников"))
            lines.append(self._t("Версия: %s") % __version__)
            lines.append(self._t("Найдено виновников: %d") % len(cards))
            lines.append("=" * 70)
            lines.append("")
            for i, c in enumerate(cards, 1):
                lines.append("[%d] %s %s" % (i, c.get("emoji", ""), c.get("label", "-")))
                lines.append(self._t("  Виноват: %s") % c.get("culprit", "?"))
                if c.get("reason"):
                    lines.append(self._t("  Что случилось: %s") % c["reason"])
                lines.append(self._t("  Когда: %s") % self._ui_when(c.get("ts", 0)))
                lines.append(self._t("  Уверенность: %s") % c.get("conf", "?"))
                if c.get("where"):
                    lines.append(self._t("  Где: %s") % c["where"])
                lines.append("")
            lines.append("=" * 70)
            text = "\n".join(lines)
            
            try:
                from java import jclass
                Context = jclass("android.content.Context")
                ClipboardManager = jclass("android.content.ClipboardManager")
                ClipData = jclass("android.content.ClipData")
                AppLoader = jclass("org.telegram.messenger.ApplicationLoader")
                ctx = AppLoader.applicationContext
                clipboard = ctx.getSystemService(Context.CLIPBOARD_SERVICE)
                clip = ClipData.newPlainText("Culprit Detector Results", text)
                clipboard.setPrimaryClip(clip)
                _log("UI: copied %d results to clipboard (%d chars)" % (len(cards), len(text)))
                try:
                    from ui.bulletin import BulletinHelper
                    BulletinHelper.show_success(self._t("Скопировано результатов: %d") % len(cards))
                except Exception:
                    pass
            except Exception as e:
                _log("UI copy error: %s" % e)
                try:
                    from ui.bulletin import BulletinHelper
                    BulletinHelper.show_error(self._t("Ошибка копирования: %s") % str(e)[:40])
                except Exception:
                    pass
        except Exception as e:
            _log("_ui_copy_results err: %s" % e)

    def _ui_culprits_subpage(self):
        try:
            self._ui_refresh_pending()
        except Exception:
            pass
        rows = [Header(text=self._t("🕵️ Кто виноват — результаты"))]
        try:
            cards = self._ui_collect_culprits()
        except Exception:
            cards = []
        if not cards:
            rows.append(Text(text=self._t("✅ Чисто — виновники не найдены"), subtext=self._t("Если приложение крашнется, зависнет"), icon="msg_info", accent=True))
            rows.append(Text(text="", subtext=self._t("или съест память — здесь появится"), icon="msg_info", accent=True))
            rows.append(Text(text="", subtext=self._t("бажный плагин с понятным описанием."), icon="msg_info", accent=True))
        else:
            rows.append(Text(text=self._t("🔴 Найдено виновников: %d (новые сверху)") % len(cards), icon="msg_report", accent=True))
            for c in cards[:6]:
                rows.append(Divider())
                self._ui_field(rows, "%s %s" % (c["emoji"], c["label"]), self._t("Виноват: %s") % c["culprit"], "msg_block", True)
                detail = c["reason"] if c["reason"] else (self._t("Плагин %s") % c["what"])
                self._ui_field(rows, self._t("Что случилось"), detail, "msg_info", False)
                rows.append(Text(text=self._t("Когда · уверенность"), subtext="%s   •   %s" % (self._ui_when(c["ts"]), c["conf"]), icon="msg_recent"))
                if c["where"]:
                    self._ui_field(rows, self._t("Где"), c["where"], "msg_location", False)
            rows.append(Divider())
            rows.append(Text(text=self._t("🗑 Очистить результаты"), icon="msg_delete", accent=True, on_click=self._ui_clear))
            rows.append(Text(text=self._t("📋 Скопировать результаты"), icon="msg_copy", accent=True, on_click=self._ui_copy_results))
        return rows

    def create_settings(self):
        if not _UI_OK: return []
        try:
            self._ui_refresh_pending()
        except Exception:
            pass
        rows = [Header(text=self._t("🔎 Кто виноват в проблемах"))]
        rows.append(Text(text=self._t("🕵️ Покажи виновных"), icon="msg_report", accent=True, create_sub_fragment=self._ui_culprits_subpage))
        rows.append(Divider())
        rows.append(Text(f"v.{__version__}", icon="msg_info"))
        rows.append(Text(f"{__author__}", icon="msg_info"))
        return rows

def create_plugin(): return Plugin()

_UI_VERDICT_SOURCES = Plugin._UI_VERDICT_SOURCES
