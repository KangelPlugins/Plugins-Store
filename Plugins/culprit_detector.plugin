class _AppEventHook(MethodHook):
    def before_hooked_method(self, param):
        try: pid = _appev_pid_from_args(param.args)
        except Exception: pid = None
        armed = False
        if pid:
            try:
                if _CRUMB is not None: _CRUMB.write(pid, "executeOnAppEvent")
                armed = _scoped_set(pid)
            except Exception: armed = False
        try: _appev_scope_stack().append(armed)
        except Exception: pass
    def after_hooked_method(self, param):
        try:
            _st = _appev_scope_stack()
            if _st and _st.pop(): _scoped_clear()
        except Exception: pass
        try: thr = param.getThrowable()
        except Exception: thr = None
        if thr is None: return
        try: pid = _appev_pid_from_args(param.args)
        except Exception: pid = None
        try: _record_load_fail(pid, thr, "executeOnAppEvent")
        except Exception: pass


def _java_lang_class(name):
    try:
        return jclass("java.lang.Class").forName(name)
    except BaseException:
        pass
    try:
        c = jclass(name)
        if c is None: return None
        try: return c.getClass()
        except BaseException: return c
    except BaseException:
        return None

def _method_hookable(m):
    try:
        mods = int(m.getModifiers())
    except Exception:
        return False
    return (mods & 0x0400) == 0 and (mods & 0x0100) == 0

_B24_TL = threading.local()
def _b24_stack():
    s = getattr(_B24_TL, "s", None)
    if s is None: s = _B24_TL.s = []
    return s
def _b24_owner_pidx():
    try:
        if _B4C_OK and _NLIB is not None:
            p = int(_NLIB.cd_active_plugin())
            if p >= 0: return p
    except Exception: pass
    try:
        prov = _provenance_pid(None, 2)
        if prov and prov != _SELF_ID and prov != __id__:
            return int(_intern(prov))
    except Exception: pass
    return -1
def _b24_register_loader(obj, pidx):
    if obj is None or pidx is None or pidx < 0: return
    try:
        lid = int(jclass("java.lang.System").identityHashCode(obj))
    except Exception:
        return
    if _NLIB is not None:
        try: _NLIB.cd_register_loader(ctypes.c_int64(lid), ctypes.c_int32(pidx))
        except Exception: pass
    try: rep = _safe_str(obj)
    except Exception: rep = None
    with _REG_LOADERS_LOCK:
        for (_o, _r, _p) in _REG_LOADERS:
            if _r == rep and _p == pidx: return
        _REG_LOADERS[:] = [_e for _e in _REG_LOADERS if _e[2] != pidx]
        _REG_LOADERS.append((obj, rep, pidx))
        if len(_REG_LOADERS) > _REG_LOADERS_MAX:
            del _REG_LOADERS[0:len(_REG_LOADERS) - _REG_LOADERS_MAX]

class _LoaderHook(MethodHook):
    def before_hooked_method(self, param):
        try: _b24_stack().append(_b24_owner_pidx())
        except Exception:
            try: _b24_stack().append(-1)
            except Exception: pass
    def after_hooked_method(self, param):
        pidx = -1
        try: pidx = _b24_stack().pop()
        except Exception: pidx = -1
        if not (_B4C_OK and _NLIB is not None): return
        try:
            obj = getattr(param, "thisObject", None)
            if obj is None: return
            if pidx is None or pidx < 0:
                pidx = _b24_owner_pidx()
            if pidx is None or pidx < 0: return
            _b24_register_loader(obj, pidx)
        except Exception: pass

_B23_LOCK = threading.RLock()
_B23_BYTES = {}
_B23_COUNT = {}
_B23_PEAK = {}
_B23_OOM = {}
_B23_RING = []
_B23_INSTALLED = 0

def _b23_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _B23_FILE_NAME).getAbsolutePath()
    except Exception:
        return None

def _b23_owner_pid():
    try:
        if _B4C_OK and _NLIB is not None:
            p = int(_NLIB.cd_active_plugin())
            if p >= 0:
                pid = _resolve_idx(p)
                if pid and pid != _SELF_ID and pid != __id__: return pid
    except Exception: pass
    try:
        pid = get_culprit_for_tid(_cur_tid())
        if pid and pid != _SELF_ID and pid != __id__: return pid
    except Exception: pass
    try:
        prov = _provenance_pid(None, 2)
        if prov and prov != _SELF_ID and prov != __id__: return prov
    except Exception: pass
    return None

_B23_BPP = {"ALPHA_8": 1, "RGB_565": 2, "ARGB_4444": 2, "ARGB_8888": 4, "RGBA_F16": 8, "HARDWARE": 4, "RGBA_1010102": 4}

def _b23_args_ints(args):
    out = []
    for a in (args or []):
        try:
            iv = int(a)
            if iv > 0: out.append(iv)
        except Exception:
            pass
    return out

def _b23_args_est(args):
    ints = _b23_args_ints(args)
    bpp = 4
    for a in (args or []):
        try:
            nm = a.name()
            for k, v in _B23_BPP.items():
                if k in nm: bpp = v; break
        except Exception:
            pass
    ints.sort(reverse=True)
    if len(ints) >= 2:
        return ints[0] * ints[1] * bpp
    return -1


def _b23_record(pid, nbytes, kind, oom, dims):
    if pid is None: pid = _UNTAGGED_LABEL
    with _B23_LOCK:
        if nbytes and nbytes > 0:
            _B23_BYTES[pid] = _B23_BYTES.get(pid, 0) + int(nbytes)
            if int(nbytes) > _B23_PEAK.get(pid, 0): _B23_PEAK[pid] = int(nbytes)
        _B23_COUNT[pid] = _B23_COUNT.get(pid, 0) + 1
        if oom: _B23_OOM[pid] = _B23_OOM.get(pid, 0) + 1
        if oom or (nbytes and nbytes >= _B23_BIG_BYTES):
            _B23_RING.append((int(time.time() * 1000), pid, int(nbytes) if (nbytes and nbytes > 0) else -1, kind, dims))
            if len(_B23_RING) > _B23_RING_MAX:
                del _B23_RING[0:len(_B23_RING) - _B23_RING_MAX]

def b23_snapshot(top=10):
    with _B23_LOCK:
        pairs = sorted(_B23_BYTES.items(), key=lambda kv: kv[1], reverse=True)
        return {
            "by_pid": pairs[:top],
            "count": dict(_B23_COUNT),
            "peak": dict(_B23_PEAK),
            "oom": dict(_B23_OOM),
            "recent": list(_B23_RING[-top:]),
            "installed_hooks": _B23_INSTALLED,
        }

def _b23_is_oom(thr):
    try:
        if thr is None: return None
        try: nm = thr.getClass().getName()
        except Exception: nm = _safe_str(thr)
        if nm and "OutOfMemory" in nm:
            return nm
    except Exception: pass
    return None

def _b23_write_oom(pid, nbytes, kind, dims, thr_name):
    p = _b23_path()
    if not p: return
    try:
        snap = b23_snapshot(top=_OOM_TOPN)
        rec = {
            "had_bitmap_oom": True,
            "event_type": "bitmap_oom", "dropbox_tag": "client_oom_leak", "tombstone_norm_version": 1,
            "ts": int(time.time() * 1000),
            "version": __version__,
            "culprit": pid or _UNTAGGED_LABEL,
            "attempted_bytes": int(nbytes) if (nbytes and nbytes > 0) else -1,
            "kind": kind, "dims": dims, "throwable": thr_name,
            "confidence": ("high" if (pid and pid != _UNTAGGED_LABEL) else "low"),
            "reason": (("OOM при выделении %s%s%s") % (
                (kind or "bitmap"),
                (" %s" % dims) if dims else "",
                ((" (~%d МБ)" % (int(nbytes) // (1024*1024))) if (nbytes and nbytes > 0) else ""),
            )),
            "ledger": snap,
        }
        try:
            hp = p.replace(".json", "_%d.json" % rec["ts"])
            if hp and hp != p: _atomic_json_write(hp, rec)
        except Exception: pass
        _atomic_json_write(p, rec)
        _log("================ BITMAP OOM VERDICT (Block#23) ================")
        _log("ВИНОВНИК OOM(bitmap): %r kind=%s ~%s dims=%s thr=%s" % (
            pid or _UNTAGGED_LABEL, kind,
            (("%.1f МБ" % (int(nbytes)/1048576.0)) if (nbytes and nbytes > 0) else "?"), dims, thr_name))
        _log("==============================================================")
    except Exception as e:
        try: _log("Block#23 write oom err: %s" % e)
        except Exception: pass

_B23_DEDUP_WINDOW_MS = 250
_B23_DEDUP_MAX = 32
_B23_TL = threading.local()

def _b23_identity(obj):
    try:
        if obj is None: return None
        return int(jclass("java.lang.System").identityHashCode(obj))
    except Exception:
        return None

def _b23_seen_recently(key):
    if key is None:
        return False
    now = int(time.time() * 1000)
    store = getattr(_B23_TL, "seen", None)
    if store is None:
        store = []; _B23_TL.seen = store
    cut = now - _B23_DEDUP_WINDOW_MS
    if store:
        store[:] = [(k, t) for (k, t) in store if t >= cut]
    for (k, t) in store:
        if k == key:
            return True
    store.append((key, now))
    if len(store) > _B23_DEDUP_MAX:
        del store[0:len(store) - _B23_DEDUP_MAX]
    return False

_B23_STAMP_ON = True

def _b23_op_stamp(kind):
    if not _B23_STAMP_ON: return
    try:
        if not (_OP_NATIVE_OK and _NLIB is not None and _CTYPES_OK and hasattr(_NLIB, "cd_op_mark_bitmap")):
            return
        try: idx = int(_NLIB.cd_active_plugin())
        except Exception: return
        if idx < 0: return
        try:
            _NLIB.cd_op_mark_bitmap(("#%d" % idx).encode("utf-8"), (kind or "bitmap").encode("utf-8"))
        except Exception: pass
    except Exception:
        pass

def _b23_after(kind, param):
    if not _B23_ON: return
    try:
        _b23_op_stamp(kind)
        thr = None
        try: thr = param.getThrowable()
        except Exception: thr = None
        if thr is None:
            return
        oom_name = _b23_is_oom(thr)
        if oom_name is None:
            return
        try: _dkey = _b23_identity(thr)
        except Exception: _dkey = None
        if _b23_seen_recently(_dkey):
            return
        pid = _b23_owner_pid()
        args = getattr(param, "args", None)
        nbytes = _b23_args_est(args)
        dims = None
        try:
            ints = _b23_args_ints(args)
            if len(ints) >= 2:
                ints.sort(reverse=True); dims = "%dx%d" % (ints[0], ints[1])
        except Exception: pass
        _b23_record(pid, nbytes, kind, True, dims)
        _b23_write_oom(pid, nbytes, kind, dims, oom_name)
    except Exception:
        pass

class _BitmapCreateHook(MethodHook):
    def after_hooked_method(self, param): _b23_after("createBitmap", param)

class _BitmapScaleHook(MethodHook):
    def after_hooked_method(self, param): _b23_after("createScaledBitmap", param)

class _BitmapCopyHook(MethodHook):
    def after_hooked_method(self, param): _b23_after("copy", param)

def _loader_culprit(frames):
    if not _B4C_OK: return None, None, {"status": "off"}
    with _REG_LOADERS_LOCK:
        loaders = list(_REG_LOADERS)
    meta = {"n": len(loaders), "status": ("no-loaders" if not loaders else "ok")}
    if not loaders: return None, None, meta
    for fr in frames:
        cn = fr.rsplit(".", 1)[0] if "." in fr else fr
        if _is_system_class(cn): continue
        for (obj, rep, pidx) in loaders:
            try:
                kls = obj.loadClass(cn)
            except Exception:
                continue
            try:
                drep = _safe_str(kls.getClassLoader())
            except Exception:
                drep = None
            if drep is not None and drep == rep:
                pid = _resolve_idx(pidx)
                if pid:
                    return pid, fr, meta
    return None, None, meta




def _so_owner_from_path(path):
    soname = path.rsplit("/", 1)[-1]
    stem = soname[:-3] if soname.lower().endswith(".so") else soname
    try: known = list(_known_union() or [])
    except Exception:
        try: known = list(_load_known() or [])
        except Exception: known = []
    comp_list = [c for c in path.split("/") if c]
    comps = set(comp_list)
    for pid in known:
        if not pid: continue
        if pid in comps or stem == pid or stem == ("lib" + pid):
            return pid, "high"
    try:
        _PRIV_ROOTS = ("cache", "code_cache", "files", "no_backup", "app_culprit", "lib", "arm64", "arm64-v8a")
        _so_idx = None
        for _i, _c in enumerate(comp_list):
            if _c == soname: _so_idx = _i
        if _so_idx is not None:
            cand = None
            for _j in range(_so_idx - 1, -1, -1):
                _seg = comp_list[_j]
                if _seg in _PRIV_ROOTS or "." in _seg:
                    continue
                if _seg in known:
                    return _seg, "high"
                if _seg.lower().startswith("culprit") or _seg.lower().startswith("plugin"):
                    cand = cand or _seg
            if cand: return cand, "medium"
    except Exception:
        pass
    mapped = None
    try: mapped = _map_stack_to_id(soname, known) or _map_stack_to_id(path, known)
    except Exception: mapped = None
    if mapped: return mapped, "medium"
    return "<so:%s>" % soname, "medium"

_IO_CORR_WINDOW_MS = 15000

def _crash_flood_correlate(ts):
    
    best = None; best_dt = None
    try:
        _p = _hx_flood_path()
        if _p and os.path.exists(_p):
            with open(_p, "r", encoding="utf-8") as _f: _fl = list(json.load(_f))
            for _it in _fl:
                if not isinstance(_it, dict): continue
                _cts = _it.get("ts")
                if _cts is None: continue
                _dt = abs(int(ts) - int(_cts))
                if _dt > _IO_CORR_WINDOW_MS: continue
                _cul = _it.get("culprit") or _it.get("culprit_pkg")
                if not _cul: continue
                if best is None or _dt < best_dt:
                    best_dt = _dt
                    best = {"culprit": _cul, "src": "correlated-flood",
                            "choice": "io-flood-correlated", "conf": "medium", "prio": 3,
                            "basis": ("hook-exception flood (%s / %s) %dms from crash on the "
                                      "dispatch path -- likely source of the null passed to the "
                                      "JNI call" % (_cul, _it.get("exc_cls") or "?", _dt))}
    except Exception:
        pass
    try:
        for _cv in _b16_disk_candidates():
            if _cv.get("confidence") != "high": continue
            _cts = _cv.get("ts")
            if _cts is None: continue
            _dt = abs(int(ts) - int(_cts))
            if _dt > _IO_CORR_WINDOW_MS: continue
            _cul = _cv.get("culprit")
            if not _cul or _cul == "unknown": continue
            if best is None or _dt < best_dt:
                best_dt = _dt
                best = {"culprit": _cul, "src": "correlated-pyerr",
                        "choice": "io-pyerr-correlated", "conf": "medium", "prio": 4,
                        "basis": ("high-confidence %s verdict (%s) %dms from crash"
                                  % (_cv.get("kind") or "pyerr", _cul, _dt))}
    except Exception:
        pass
    return best

def _crash_op_owner(rec):
    
    try:
        _ops = rec.get("op_stamps") or {}
        if not isinstance(_ops, dict) or not _ops:
            return None
        best = None; best_age = None
        for _dom, _info in _ops.items():
            try:
                if isinstance(_info, dict):
                    _own = _info.get("owner", _info.get("idx"))
                    _age = _info.get("age_ms")
                else:
                    _own = _info; _age = None
                if _own is None: continue
                _own = str(_own)
                if _own[:1] == "#" and _own[1:].isdigit():
                    _nm = _resolve_idx(int(_own[1:])) or _resolve_idx_durable(int(_own[1:]))
                    _own = _nm if (isinstance(_nm, str) and _nm) else ""
                if not _own or _own in (_SELF_ID, __id__): continue
                if best is None or (_age is not None and (best_age is None or _age < best_age)):
                    best = (_own, _dom); best_age = _age
            except Exception:
                continue
        if not best:
            return None
        return {"culprit": best[0], "src": "op-stamp-thread",
                "choice": "io-op-thread", "conf": "low", "prio": 1,
                "basis": ("faulting thread's last native op-stamp owner (domain=%s) -- "
                          "thread-scope fallback, not proven" % best[1])}
    except Exception:
        return None

def _io_bridge_crash_attribute(rec):
    
    _ts = rec.get("ts") or int(time.time() * 1000)
    _msg = (rec.get("abort_message") or rec.get("abort_msg") or "")
    _is_null = ("obj == null" in _msg) or ("CallNonvirtual" in _msg and "null" in _msg)
    rec["bridge_jni_abort"] = True
    if rec.get("abort_family") == "jni_detected_error" and (_is_null or "CallNonvirtual" in _msg):
        rec["bridge_crash_kind"] = "jni_null_object_call"
        rec["reason"] = ("Python-плагин вызвал Java-метод на null-объекте через Chaquopy-мост (%s); ART CheckJNI аварийно завершил процесс (SIGABRT)"
                         % (rec.get("bridge_so") or "libchaquopy_java.so"))
    else:
        rec["bridge_crash_kind"] = "jni_bridge_abort"
        rec["reason"] = rec.get("reason") or ("нативный краш на Python->Java мосту (%s)"
                                              % (rec.get("bridge_so") or "bridge"))
    cands = []
    _fc = _crash_flood_correlate(_ts)
    if _fc: cands.append(_fc)
    _op = _crash_op_owner(rec)
    if _op: cands.append(_op)
    if not cands:
        try:
            _iu_pid = rec.get("culprit_pid")
            if not (isinstance(_iu_pid, int) and _iu_pid >= 0):
                _iu_pid = rec.get("active_pid")
            if isinstance(_iu_pid, int) and _iu_pid >= 0:
                _iu_nm = _resolve_idx(_iu_pid) or _resolve_idx_durable(_iu_pid)
                if isinstance(_iu_nm, str) and _iu_nm and _iu_nm not in (_SELF_ID, __id__):
                    _iu_conf = "medium" if (rec.get("corroboration") == "tombstone_confirmed") else "low"
                    cands.append({"culprit": _iu_nm, "src": "active-pid", "choice": "io-active-pid",
                                  "conf": _iu_conf, "prio": 2,
                                  "basis": ("C-resolved active/culprit pid=%d (%s) on the faulting thread; "
                                            "scope cold on first crash of session -- tombstone-corroborated "
                                            "active-pid fallback" % (_iu_pid, _iu_nm))})
                    _log("Block#4C +IU(bridge): scope cold, adopting active/culprit pid=%d -> %r (conf=%s)"
                         % (_iu_pid, _iu_nm, _iu_conf))
        except Exception as _eiu:
            _log("Block#4C +IU active-pid fallback err: %s" % _eiu)
    if not cands:
        rec["bridge_attribution"] = "no_candidate"
        rec["confidence"] = "low"
        _log("Block#4C +IO(bridge): JNI-bridge crash, no candidate -> untagged/low (kind=%s)"
             % rec.get("bridge_crash_kind"))
        return
    cands.sort(key=lambda c: c.get("prio", 0), reverse=True)
    _best = cands[0]
    rec["pid_native_bridge"] = None
    rec["pid"] = _best.get("culprit")
    rec["culprit_kind"] = "plugin"
    rec["pid_src"] = _best.get("src")
    rec["pid_choice_src"] = _best.get("choice")
    rec["confidence"] = _best.get("conf", "low")
    rec["bridge_attribution"] = _best.get("choice")
    rec["bridge_candidates"] = cands
    rec["correlated_not_proven"] = (_best.get("conf") != "high")
    rec["culprit_basis"] = _best.get("basis")
    _log("Block#4C +IO(bridge): JNI-bridge crash attributed to %r via %s (conf=%s, cands=%d)"
         % (rec.get("pid"), rec.get("pid_choice_src"), rec.get("confidence"), len(cands)))

def _native_crash_moment_evidence(rec):
    
    out = ["", "=" * 60, "[+IP native-crash evidence (stitched from native dump)]"]
    for _k in ("signal_desc", "signal_name", "cause", "abort_family", "abort_message",
               "bridge", "bridge_so", "crash_so", "host_so_owner", "culprit_kind",
               "pid", "confidence", "bridge_crash_kind", "bridge_attribution",
               "correlated_not_proven", "reason", "culprit_basis"):
        _v = rec.get(_k)
        if _v not in (None, "", -1):
            out.append("%s=%s" % (_k, _v))
    _cs = rec.get("bridge_candidates")
    if isinstance(_cs, list) and _cs:
        out.append("candidates:")
        for _c in _cs[:4]:
            try: out.append("  %s via %s (%s)" % (_c.get("culprit"), _c.get("choice"), _c.get("conf")))
            except Exception: pass
    _fr = rec.get("frames") or []
    if _fr:
        out.append("top_frames:")
        for _f in _fr[:16]:
            out.append("  %s" % _f)
    return out

_HX_RESOLU_RE = re.compile(r"Failed resolution of:\s*L([\w/$]+);")
_HX_CNF_RE = re.compile(r"(?:ClassNotFoundException|NoClassDefFoundError):\s+([\w.$]+)")
def _hx_extract_missing(line):
    
    try:
        line = line or ""
        m = _HX_RESOLU_RE.search(line)
        if m:
            return m.group(1).replace("/", ".")
        m = _HX_CNF_RE.search(line)
        if m:
            g = m.group(1)
            if g and g != "Failed" and "." in g:
                return g.replace("/", ".")
        return None
    except Exception:
        return None

_TL_OUTDATED_PREFIXES = ("org.telegram.tgnet.TLRPC$TL_", "org.telegram.tgnet.TLRPC$",
                         "org.telegram.tgnet.tl.")
_TL_REMOVED_KNOWN = frozenset(("org.telegram.tgnet.TLRPC$TL_updateEditMessage",))
def _hx_api_incompat(missing_class):
    
    if not missing_class:
        return (False, None)
    if missing_class in _TL_REMOVED_KNOWN:
        return (True, "high")
    for _p in _TL_OUTDATED_PREFIXES:
        if missing_class.startswith(_p):
            return (True, "high")
    return (False, None)

def _is_managed_heap_corruption(rec):
    
    rec["heap_corruption"] = True
    rec["reason"] = ("ART повредил managed-heap (GC нашёл невалидную ссылку): "
                     "обычно это JNI/native мисюз (устаревший jobject, use-after-free, "
                     "битая global-ref); GC падает позже на чужом потоке, стек чисто ART")
    _ts = rec.get("ts") or int(time.time() * 1000)
    _fc = _crash_flood_correlate(_ts)
    if _fc:
        rec["pid"] = _fc.get("culprit")
        rec["culprit_kind"] = "plugin"
        rec["pid_src"] = _fc.get("src")
        rec["pid_choice_src"] = "is-correlated"
        rec["confidence"] = "medium"
        rec["correlated_not_proven"] = True
        rec["culprit_basis"] = "managed-heap corruption + " + (_fc.get("basis") or "correlated activity")
        rec["heap_corruption_candidates"] = [_fc]
        _log("Block#4C +IS: managed-heap corruption correlated -> %r (medium, not proven)" % rec.get("pid"))
    else:
        rec["heap_corruption_suspect"] = True
        rec["confidence"] = "low"
        if not rec.get("unattributed_reason"):
            rec["unattributed_reason"] = ("managed-heap corruption (GC invalid-ref), pure-ART stack, no correlated "
                                          "flood/pyerr -- likely JNI/native misuse by a native plugin, unattributable from stack")
        _log("Block#4C +IS: managed-heap corruption, no correlate -> heap_corruption_suspect/low")

_MT_MANAGED_SYM_SUBSTR = ("nterp", "mterp", "executenterp", "execute_nterp",
                          "art::interpreter", "artinterpret", "interpreter::",
                          "executeswitchimpl")
_MT_TS_FAULT_RE = re.compile(r"signal\s+(\d+)\b.*?\bcode\s+(-?\d+)\b.*?fault addr\s+(0x[0-9a-fA-F]+)")
_MT_TS_THREAD_RE = re.compile(r"pid:\s*(\d+),\s*tid:\s*(\d+),\s*name:\s*(.*?)\s*>>>\s*(\S+)\s*<<<")
_MT_TS_FRAME_RE = re.compile(r"#(\d+)\s+pc\s+([0-9a-fA-F]+)\s+(.*)$")
_MT_TS_SYM_RE = re.compile(r"^(\S+)\s+\(([^)]*)\)")
_MT_TS_BUILDID_RE = re.compile(r"BuildId:\s*([0-9a-fA-F]+)")
_MT_TS_PCREG_RE = re.compile(r"\bpc\s+([0-9a-fA-F]{8,16})\b")

def _mt_strip_logline(ln):
    try:
        m = _B28_PREFIX_RE.match(ln)
        if m:
            return m.group(1)
    except Exception:
        pass
    return ln

def _mt_parse_block(blk):
    info = {"signo": None, "code": None, "fault_addr": None, "thread_name": None,
            "pid": None, "tid": None, "abi": None, "build_fingerprint": None,
            "process": None, "cmdline": None, "pc_reg": None, "frames": [],
            "total_frames": None}
    for pl in blk:
        s = (pl or "").strip()
        if not s:
            continue
        if s.startswith("Build fingerprint:"):
            info["build_fingerprint"] = s.split(":", 1)[1].strip().strip("'")
        elif s.startswith("ABI:"):
            info["abi"] = s.split(":", 1)[1].strip().strip("'")
        elif s.startswith("Cmdline:"):
            info["cmdline"] = s.split(":", 1)[1].strip()
        elif s.startswith("pid:") and ">>>" in s:
            m = _MT_TS_THREAD_RE.search(s)
            if m:
                try: info["pid"] = int(m.group(1))
                except Exception: pass
                try: info["tid"] = int(m.group(2))
                except Exception: pass
                info["thread_name"] = (m.group(3) or "").strip()
                info["process"] = m.group(4)
        elif s.startswith("signal "):
            m = _MT_TS_FAULT_RE.search(s)
            if m:
                try: info["signo"] = int(m.group(1))
                except Exception: pass
                try: info["code"] = int(m.group(2))
                except Exception: pass
                try: info["fault_addr"] = int(m.group(3), 16)
                except Exception: pass
        elif s.startswith("lr ") or ("pc " in s and " sp " in s):
            mm = _MT_TS_PCREG_RE.search(s)
            if mm:
                try: info["pc_reg"] = int(mm.group(1), 16)
                except Exception: pass
        elif "total frames" in s:
            try: info["total_frames"] = int(s.split()[0])
            except Exception: pass
        else:
            fm = _MT_TS_FRAME_RE.search(s)
            if fm:
                fr = {"idx": None, "off": None, "module": None, "symbol": None,
                      "sym_off": None, "buildid": None, "raw": fm.group(3).strip(),
                      "kind": None}
                try: fr["idx"] = int(fm.group(1))
                except Exception: pass
                try: fr["off"] = int(fm.group(2), 16)
                except Exception: pass
                rest = fr["raw"]
                bid = _MT_TS_BUILDID_RE.search(rest)
                if bid:
                    fr["buildid"] = bid.group(1)
                sm = _MT_TS_SYM_RE.match(rest)
                if sm:
                    fr["module"] = sm.group(1)
                    _symfull = (sm.group(2) or "").strip()
                    fr["symbol"] = _symfull
                    if "+" in _symfull:
                        fr["sym_off"] = _symfull.rsplit("+", 1)[1]
                    fr["kind"] = "module"
                else:
                    _toks = rest.split()
                    fr["module"] = _toks[0] if _toks else rest
                    fr["kind"] = "anon"
                _mod = (fr["module"] or "")
                if _mod.startswith("/memfd") or _mod.startswith("[anon") or ("jit-cache" in _mod) or ("dalvik" in _mod):
                    fr["kind"] = "anon"
                    fr["symbol"] = None
                info["frames"].append(fr)
    return info


def _mod_is_art(m):
    
    try:
        return bool(m) and ("libart" in m.lower())
    except Exception:
        return False


def _slot_is_foreign(cls, mod):
    
    if cls == 1:
        return False
    if cls == 4:
        return True
    if cls in (2, 3):
        return not _mod_is_art(mod)
    return False


def _resolve_gref_top(rows):
    
    try:
        best_idx = None; best_cnt = 0
        for row in (rows or []):
            if not isinstance(row, (list, tuple)) or len(row) < 2:
                continue
            try:
                idx = int(row[0]); cnt = int(row[1])
            except Exception:
                continue
            if cnt > best_cnt:
                best_cnt = cnt; best_idx = idx
        if best_idx is None or best_idx < 0:
            return (None, None, 0)
        owner = _resolve_idx(best_idx) or _resolve_idx_durable(best_idx)
        return (owner, best_idx, best_cnt)
    except Exception:
        return (None, None, 0)


def _attach_heap_corruption_leads(rec):
    
    try:
        if not rec.get("heap_corruption"):
            return
        leads = []
        live_available = bool(rec.get("map_available"))
        churn_available = bool(rec.get("gref_running")
                               and rec.get("gref_new_hook_active")
                               and not rec.get("gref_stopping")
                               and not rec.get("foreign_chain_new"))
        if live_available:
            owner, oidx, ocnt = _resolve_gref_top(rec.get("gref_live_top"))
            if owner and ocnt > 0:
                lead = {"kind": "gref_live", "owner": owner, "owner_idx": oidx,
                        "count": ocnt, "confidence": "low", "culprit": False}
                cav = []
                if rec.get("owner_mapping_anomaly"):
                    cav.append("owner_mapping_anomaly: duplicate insert probe -- owner may be ambiguous")
                if rec.get("gref_live_partial"):
                    cav.append("live_partial: pre-hook refs + stop/re-arm gaps (coverage_gaps=%s) -- live set not guaranteed complete"
                               % rec.get("gref_coverage_gaps"))
                if cav:
                    lead["caveat"] = "; ".join(cav)
                leads.append(lead)
        else:
            rec.setdefault("gref_attribution_caveats", []).append(
                "heap-corruption gref_live lead suppressed -- live-ref map degraded")
        if churn_available:
            ch_owner, ch_idx, ch_cnt = _resolve_gref_top(rec.get("gref_churn_top"))
            if ch_owner and ch_cnt > 0:
                leads.append({"kind": "gref_churn", "owner": ch_owner, "owner_idx": ch_idx,
                              "count": ch_cnt, "confidence": "low", "culprit": False,
                              "note": "creation churn, not live holders"})
        else:
            rec.setdefault("gref_attribution_caveats", []).append(
                "heap-corruption gref_churn lead suppressed -- NewGlobalRef hook not active")
        if leads:
            rec["heap_corruption_leads"] = leads
    except Exception:
        pass


def _apply_gref_v2(rec, gref):
    
    if not isinstance(gref, dict):
        return
    def _i(k, dv=0):
        try:
            v = gref.get(k)
            return int(v) if v is not None else dv
        except Exception:
            return dv
    def _b(k):
        return bool(_i(k, 0))
    rec["gref_schema_v"] = _i("v", 1)
    rec["gref_live_total"] = _i("live_total")
    rec["gref_live_untagged"] = _i("live_untagged")
    rec["gref_live_top"] = gref.get("live_top") if isinstance(gref.get("live_top"), list) else []
    rec["gref_churn_top"] = gref.get("churn_top") if isinstance(gref.get("churn_top"), list) else []
    rec["detector_gmap_insert_overflow"] = _i("overflow")
    rec["gref_del_untracked"] = _i("del_untracked")
    rec["gref_duplicate_probe_hits"] = _i("duplicate_probe_hits", _i("duplicate_insert"))
    rec["gref_duplicate_insert"] = rec["gref_duplicate_probe_hits"]
    rec["gref_new_hook_active"] = _b("new_hook_active")
    rec["gref_delete_hook_active"] = _b("delete_hook_active")
    rec["gref_live_scanned"] = _i("live_scanned")
    rec["gref_churn_scanned"] = _i("churn_scanned")
    rec["gref_live_partial"] = _b("live_partial")
    rec["gref_coverage_gaps"] = _i("coverage_gaps")
    rec["gref_arm_generation"] = _i("arm_generation")
    rec["gref_arm_mono_ns"] = _i("arm_mono_ns")
    rec["gmap_present"] = _b("gmap_present")
    rec["gmap_init_guard"] = _b("gmap_init_guard")
    rec["gref_running"] = _b("running")
    rec["gref_stopping"] = _b("stopping")
    rec["foreign_chain_new"] = _b("foreign_new")
    rec["foreign_chain_delete"] = _b("foreign_del")
    rec["gref_snapshot_consistency"] = gref.get("consistency") or "fuzzy_atomic"
    rec["gref_snapshot_transactional"] = bool(gref.get("transactional"))
    _audit = gref.get("audit")
    if isinstance(_audit, dict):
        rec["gref_hook_audit"] = {
            "state": _audit.get("state"),
            "generation": _audit.get("gen"),
            "mono_ns": _audit.get("mono_ns"),
            "new_slot_class": _audit.get("new_slot_cls"),
            "del_slot_class": _audit.get("del_slot_cls"),
            "new_forward_class": _audit.get("new_fwd_cls"),
            "del_forward_class": _audit.get("del_fwd_cls"),
            "new_slot_module": _audit.get("new_slot_mod"),
            "del_slot_module": _audit.get("del_slot_mod"),
            "new_forward_module": _audit.get("new_fwd_mod"),
            "del_forward_module": _audit.get("del_fwd_mod"),
            "new_slot_target": _audit.get("new_slot_target"),
            "del_slot_target": _audit.get("del_slot_target"),
            "new_forward": _audit.get("new_forward"),
            "del_forward": _audit.get("del_forward"),
        }
        _audit_ok = (_audit.get("state") == "current")
        _nsc = _audit.get("new_slot_cls"); _dsc = _audit.get("del_slot_cls")
        rec["gref_audit_state"] = _audit.get("state")
        rec["gref_hooks_self_owned"] = bool(_audit_ok and _nsc == 1 and _dsc == 1
                                            and rec["gref_new_hook_active"] and rec["gref_delete_hook_active"])
        rec["gref_hooks_foreign_present"] = bool(_audit_ok and (
            _slot_is_foreign(_nsc, _audit.get("new_slot_mod"))
            or _slot_is_foreign(_dsc, _audit.get("del_slot_mod"))))
    else:
        rec["gref_audit_state"] = None
        rec["gref_hooks_self_owned"] = False
        rec["gref_hooks_foreign_present"] = False
    map_available = (rec["gmap_present"] and rec["gref_running"]
                     and not rec["gref_stopping"]
                     and not rec["foreign_chain_new"]
                     and not rec["foreign_chain_delete"]
                     and rec["gref_new_hook_active"]
                     and rec["gref_delete_hook_active"])
    rec["map_available"] = bool(map_available)
    rec["map_degraded"] = bool((not map_available) or rec["detector_gmap_insert_overflow"] > 0)
    rec["owner_mapping_anomaly"] = bool(rec["gref_duplicate_probe_hits"] > 0)
    if rec["map_degraded"]:
        if rec["detector_gmap_insert_overflow"] > 0:
            _why = "insert_overflow"
        elif not (rec["gref_new_hook_active"] and rec["gref_delete_hook_active"]):
            _why = "hook_not_active(new=%d,del=%d)" % (int(rec["gref_new_hook_active"]), int(rec["gref_delete_hook_active"]))
        elif rec["foreign_chain_new"] or rec["foreign_chain_delete"]:
            _why = "foreign_chained"
        else:
            _why = "not_armed"
        rec.setdefault("gref_attribution_caveats", []).append(
            "live-ref map degraded (%s) -- gref live/top counts may be stale/incomplete" % _why)
    if rec["owner_mapping_anomaly"]:
        rec.setdefault("gref_attribution_caveats", []).append(
            "duplicate insert probe (%d) -- a JNI handle value was re-mapped; owner attribution ambiguous" % rec["gref_duplicate_probe_hits"])


def _parse_abort_structured(rec):
    
    import re
    msg = rec.get("abort_message") or rec.get("abort_msg") or ""
    if not msg:
        return
    low = msg.lower()
    fields = {}
    def _first_hex(*pats):
        for p in pats:
            m = re.search(p, msg, re.IGNORECASE)
            if m:
                try:
                    return int(m.group(1), 16), m.group(1)
                except Exception:
                    pass
        return None, None
    def _first_int(*pats):
        for p in pats:
            m = re.search(p, msg, re.IGNORECASE)
            if m:
                g = m.group(1)
                try:
                    return (int(g, 16) if g.lower().startswith("0x") else int(g)), g
                except Exception:
                    pass
        return None, None
    inv_v, inv_s = _first_hex(r"invalid reference\s+\(?(0x[0-9a-f]+)",
                              r"mark invalid reference\s+\(?(0x[0-9a-f]+)",
                              r"tried\s+to\s+mark\s+\(?(0x[0-9a-f]+)",
                              r"invalid\s+(?:object\s+)?reference\b[^0-9a-fx]*(0x[0-9a-f]+)",
                              r"\bref\s*=\s*(0x[0-9a-f]+)")
    if inv_v is not None:
        fields["invalid_ref"] = inv_v
        fields["invalid_ref_hex"] = inv_s
    hold_v, hold_s = _first_int(r"holder\s*=\s*(0x[0-9a-f]+)", r"holder\s*=\s*(\d+)")
    if hold_v is not None:
        fields["holder"] = hold_v
        fields["holder_repr"] = hold_s
    cls_v, cls_s = _first_hex(r"\bclass\s*=\s*(0x[0-9a-f]+)", r"expected class\s+\(?(0x[0-9a-f]+)")
    if cls_v is not None:
        fields["ref_class_ptr"] = cls_v
    if fields:
        rec["abort_extracted_fields"] = fields
    rec["abort_parse_version"] = 1
    _gc_mark = bool(re.search(r"\bgc\s+tried\s+to\s+mark\b", low) or re.search(r"\btried\s+to\s+mark\b", low))
    _checkjni = bool(re.search(r"\bcheckjni\b", low) or "jni_abort" in low)
    _jni_err = bool(re.search(r"\bjni\b", low) and re.search(r"\b(error|detected|abort)\b", low))
    _jni_detected = ("jni detected error" in low)
    _inv_ref = bool(re.search(r"\binvalid\s+(?:object\s+)?reference\b", low))
    rec["abort_flags"] = {
        "jni_detected_error": _jni_detected,
        "jni_error_generic": _jni_err,
        "checkjni": _checkjni,
        "gc_mark_invalid_ref": _gc_mark,
    }
    if _gc_mark or _inv_ref:
        rec["abort_parse_family"] = "gc_invalid_reference"
    elif _checkjni or _jni_err:
        rec["abort_parse_family"] = "jni_error"
    elif "heap corruption" in low:
        rec["abort_parse_family"] = "heap_corruption"
    else:
        rec["abort_parse_family"] = "other"
    if _gc_mark:
        rec.setdefault("abort_subtype", "gc_mark_invalid_reference")
    elif _inv_ref:
        rec.setdefault("abort_subtype", "invalid_reference")
    elif "heap corruption" in low:
        rec.setdefault("abort_subtype", "heap_corruption")
    if inv_v is not None:
        if inv_v == 0:
            ref_class = "null"
            causes = ["zero_overwrite", "uninitialized_slot",
                      "cleared_weak_reference", "metadata_corruption"]
        elif 0 < inv_v <= 0x1000:
            ref_class = "small_non_pointer"
            causes = ["integer_or_byte_overwrite", "truncated_reference",
                      "poison_or_sentinel", "corrupted_compressed_reference"]
        else:
            ref_class = "unknown"
            causes = ["stale_reference", "metadata_corruption", "unknown"]
        rec["invalid_ref_class"] = ref_class
        rec["invalid_ref_possible_causes"] = causes
        rec["classification_confidence"] = "low"
        rec["cause_proven"] = False
        rec["cause_method"] = "abort_message_structural_only"


def _parse_debuggerd_tombstone(fault_addr=None, signo=None, crash_ts=None):
    try:
        texts = _b28_read_logcat(prefilter=False)
    except Exception:
        texts = []
    if not texts:
        return None
    payloads = []
    for t in texts:
        if not t:
            continue
        for ln in t.splitlines():
            if " F DEBUG" in ln:
                payloads.append({"ts": _b28_logcat_event_ts(ln, crash_ts),
                                 "line": _mt_strip_logline(ln)})
    if not payloads:
        return None
    blocks = []; cur = []; cur_ts = None
    for item in payloads:
        pl = item.get("line"); pts = item.get("ts")
        if "*** *** ***" in (pl or ""):
            if cur:
                blocks.append({"ts": cur_ts, "lines": cur}); cur = []; cur_ts = None
            if pts is not None:
                cur_ts = pts
            continue
        if cur_ts is None and pts is not None:
            cur_ts = pts
        cur.append(pl)
    if cur:
        blocks.append({"ts": cur_ts, "lines": cur})
    if not blocks:
        blocks = [{"ts": None, "lines": [p.get("line") for p in payloads]}]
    _mask = (1 << 56) - 1
    best = None; best_score = -1; best_age = None
    for blk in blocks:
        info = _mt_parse_block(blk.get("lines") or [])
        if not info or not info.get("frames"):
            continue
        info["logcat_ts"] = blk.get("ts")
        score = 0
        if signo is not None and info.get("signo") == signo:
            score += 1
        if fault_addr is not None and info.get("fault_addr") is not None:
            if (int(info["fault_addr"]) & _mask) == (int(fault_addr) & _mask):
                score += 2
        time_age = None
        if crash_ts is not None and info.get("logcat_ts") is not None:
            try:
                time_age = abs(int(info["logcat_ts"]) - int(crash_ts))
            except Exception:
                time_age = None
        if time_age is not None:
            if time_age > 120000:
                continue
            if time_age <= 5000:
                score += 4
            elif time_age <= 30000:
                score += 3
            else:
                score += 2
        if score > best_score:
            best_score = score; best = info; best_age = time_age
        elif score == best_score and time_age is not None:
            if best_age is None or time_age < best_age:
                best = info; best_age = time_age
    if best is None:
        return None
    if (signo is not None or fault_addr is not None) and best_score <= 0:
        return None
    try:
        best["match_score"] = int(best_score)
    except Exception:
        pass
    return best

def _tombstone_symbol_class(tb_frames):
    for f in tb_frames or []:
        sym = (f.get("symbol") or "").lower()
        if not sym:
            continue
        for sub in _MT_MANAGED_SYM_SUBSTR:
            if sub in sym:
                return "managed_metadata_corruption"
    return None

def _tombstone_base_skew(inproc_frames, tb):
    try:
        tb_top = None
        for f in (tb.get("frames") or []):
            if f.get("kind") == "module" and f.get("module") and f.get("off") is not None:
                tb_top = f; break
        if not tb_top:
            return None
        tb_mod = tb_top["module"].rsplit("/", 1)[-1]
        for fr in (inproc_frames or []):
            if "+0x" not in fr:
                continue
            _mo = fr.split("+0x", 1)
            _modpart = _mo[0].rsplit(" ", 1)[-1].rsplit("/", 1)[-1]
            if _modpart != tb_mod:
                continue
            try:
                _ipoff = int("0x" + _mo[1].split()[0], 16)
            except Exception:
                continue
            return int(tb_top["off"]) - _ipoff
        return None
    except Exception:
        return None

def _tombstone_symbolized_frames(tb):
    out = []
    for f in (tb.get("frames") or []):
        try:
            _i = f.get("idx")
            _pfx = ("#%d " % _i) if _i is not None else ""
            if f.get("kind") == "module" and f.get("symbol"):
                out.append("%s%s (%s)" % (_pfx, f["module"].rsplit("/", 1)[-1], f["symbol"]))
            else:
                out.append("%s%s" % (_pfx, f.get("raw") or f.get("module") or "?"))
        except Exception:
            pass
    return out


def _read_native_crash():
    try:
        p = _native_crash_path()
        if not p: return None
        _pe = False
        try: _pe = os.path.exists(p)
        except Exception: _pe = False
        if not _pe:
            try:
                _mp = _aw_mirror_path(p)
                _pe = bool(_mp) and os.path.exists(_mp)
            except Exception: _pe = False
        if not _pe: return None
        _rp = _rc_take_path(p)
        if not _rp: return None
        try: _nc_mtime_ms = int(os.path.getmtime(_rp) * 1000)
        except Exception: _nc_mtime_ms = None
        with open(_rp, "r", encoding="utf-8", errors="replace") as f:
            raw = f.read()
        if "CULPRIT_NATIVE_CRASH" not in raw:
            try: os.remove(_rp)
            except Exception: pass
            return None
        _parts = raw.split("CULPRIT_NATIVE_CRASH")
        _last_full = None
        for _part in _parts[1:]:
            _block = "CULPRIT_NATIVE_CRASH" + _part
            _end = _block.find("\nEND")
            if _end != -1:
                _last_full = _block[:_end + 4] + "\n"
        if _last_full is None:
            try:
                if not os.path.exists(p): os.rename(_rp, p)
                else: os.remove(_rp)
            except Exception: pass
            return None
        raw = _last_full
        rec = {"raw": raw[-4000:], "signo": None, "active_pid": None, "culprit_pid": None, "pid_src": None, "pid_resolve_src": None, "pid_choice_src": None, "pid": None, "si_code": None, "fault_addr": None, "cause": None, "foreign_so": None, "foreign_app_private": None, "foreign_so_conf": None, "fso_src": None, "top_so": None, "host_so": None, "host_native": None, "maps_n": None, "maps_trunc": None, "culprit_kind": None, "op_stamps": {}, "native_emit": None, "native_emit_raw": None, "native_emit_truncated": None, "top_idx": None, "top_bytes": None, "gref_top_idx": None, "anr_owner": None, "anr_stalled_ms": None, "frames": [], "abort_msg": None, "fingerprint": None, "build_fingerprint": None, "abort_message": None, "abort_message_src": None, "signal_name": None, "signal_code_name": None, "signal_desc": None, "event_type": None, "abort_family": None, "dropbox_tag": None, "tombstone_tag": None, "tombstone_source": None, "tombstone_norm_version": None}
        for line in raw.splitlines():
            line = line.strip()
            if line.startswith("signo="):
                for tok in line.split():
                    if tok.startswith("signo="):
                        try: rec["signo"] = int(tok.split("=", 1)[1])
                        except Exception: pass
