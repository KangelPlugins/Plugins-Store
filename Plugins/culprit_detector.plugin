def _b19_record(ev, fmap):
    if not _BLOCK19_ON: return
    pid, pfile, pline, dfile, dline = _b19_culprit_from_event(ev, fmap)
    sym = _B19_SYM.get(int(ev.symbol), "?")
    if not pid:
        return
    if pid == _SELF_ID or pid == __id__: return
    reason = "py-exception across JNI boundary (%s)" % sym
    now = int(time.time() * 1000)
    key = "%s|%s|%s" % (pid, pline, sym)
    try:
        with _PYERR_SEEN_LOCK:
            if now - _PYERR_SEEN.get(key, 0) < _PYERR_DEDUP_MS: return
            _PYERR_SEEN[key] = now
    except Exception: pass
    rec = {"had_pyerr_fail": True, "culprit": pid, "src": "py-frame/jni-boundary",
           "confidence": "high", "where": "jni-boundary", "symbol": sym,
           "py_module": pid, "py_file": pfile, "py_line": pline,
           "deepest_file": dfile, "deepest_line": dline, "reason": reason,
           "exc_cls": None, "exc_msg": None, "ts": now}
    try: _b16_push_verdict("pyerr", rec)
    except Exception: pass
    try: _pyerr_verdict_log(rec, "live")
    except Exception: pass
    try: _persist_pyerr_fail(rec)
    except Exception: pass

def _b19_poll_loop(stop):
    global _B19_NEXT
    if not (_B19_OK and _NLIB is not None and _B19Event is not None and _B19_RING_ADDR):
        return
    cap = _B19_RING_CAP; rec_size = _B19_REC_SIZE; base = int(_B19_RING_ADDR)
    fmap = {}; fmap_ts = 0
    while not stop.is_set():
        try:
            committed = int(_NLIB.cd_b19_committed())
            if committed > _B19_NEXT:
                now = int(time.time() * 1000)
                if (now - fmap_ts) > 1500 or not fmap:
                    fmap = _b19_file_plugin_map(); fmap_ts = now
                start = _B19_NEXT
                if committed - start > cap:
                    start = committed - cap
                for seq in range(start, committed):
                    try:
                        ev = _B19Event.from_address(base + (seq % cap) * rec_size)
                        _b19_record(ev, fmap)
                    except Exception: pass
                _B19_NEXT = committed
        except Exception: pass
        stop.wait(_B19_POLL_S)

def _b19_start():
    global _B19_STARTED, _B19_STOP, _B19_THREAD, _B19_RING_ADDR
    if not _BLOCK19_ON:
        _log("Block#19: otkljuchen (_BLOCK19_ON=False)"); return
    if not (_B19_OK and _NATIVE_OK and _NLIB is not None):
        _log("Block#19: натив/символы недоступны -- пропуск"); return
    if _B19_STARTED: return
    try:
        hooks = int(_NLIB.cd_b19_start())
    except Exception as e:
        _log("Block#19 cd_b19_start err: %s" % e); return
    if hooks <= 0:
        _log("Block#19: cd_b19_start вернул %d хуков -- JNI/py граница не зацепилась" % hooks); return
    try: _B19_RING_ADDR = int(_NLIB.cd_b19_ring_addr())
    except Exception: _B19_RING_ADDR = 0
    if not _B19_RING_ADDR:
        _log("Block#19: ring_addr=0 -- otkljuchaju")
        try: _NLIB.cd_b19_stop()
        except Exception: pass
        return
    _B19_STOP = threading.Event()
    _B19_THREAD = threading.Thread(target=_b19_poll_loop, args=(_B19_STOP,), name="culprit-b19", daemon=True)
    _B19_THREAD.start()
    _B19_STARTED = True
    _log("Block#19: ustanovlen (hookov %d/3, ring@0x%x cap=%d) -> %s" % (hooks, _B19_RING_ADDR, _B19_RING_CAP, _PYERR_FILE_NAME))

def _b19_stop():
    global _B19_STARTED
    if not _B19_STARTED: return
    try:
        if _B19_STOP is not None: _B19_STOP.set()
        if _B19_THREAD is not None: _B19_THREAD.join(timeout=2.0)
    except Exception: pass
    try:
        if _NLIB is not None: _NLIB.cd_b19_stop()
    except Exception: pass
    _B19_STARTED = False
    _log("Block#19: снят (cd_b19_stop)")


