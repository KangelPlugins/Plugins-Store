def _wref_make(o):
    try: return weakref.ref(o)
    except Exception: return o
def _wref_get(r):
    try: return r() if isinstance(r, weakref.ReferenceType) else r
    except Exception: return r
def _prune_dead_wrefs(lst):
    try:
        i = 0
        for t in lst:
            r = t[0]
            if isinstance(r, weakref.ReferenceType) and r() is None: continue
            lst[i] = t; i += 1
        del lst[i:]
    except Exception: pass
_ENTRY_PATCHED = []
def _instrument_entrypoints():
    n = 0
    try:
        objs = _gc.get_objects()
    except Exception:
        return 0
    for obj in objs:
        try:
            if not isinstance(obj, BasePlugin):
                continue
            pid = _canonical_pid(obj)
            if pid == _SELF_ID or pid == __id__:
                continue
            for cb in _ENTRY_CBS:
                fn = getattr(obj, cb, None)
                if fn is None or not callable(fn):
                    continue
                if getattr(fn, _B_TAGGED_FLAG, False):
                    continue
                try:
                    wrapped = _wrap_settings_factory(pid, fn) if cb == "create_settings" else _wrap_entry(pid, fn)
                    setattr(obj, cb, wrapped); n += 1
                    try:
                        _prune_dead_wrefs(_ENTRY_PATCHED)
                        _ENTRY_PATCHED.append((_wref_make(obj), cb, _wref_make(wrapped)))
                    except Exception: pass
                except Exception:
                    pass
        except Exception:
            pass
    if n:
        _log(f"PartB scope-widen: обёрнуто entry-колбэков={n}")
    return n

_THREAD_SHIM_ON = False
_PARTB_TIMER = None
_THREAD_SHIM_INSTALLED = None
def _native_thread_inherit():
    try:
        if _NATIVE_OK and _NLIB is not None and hasattr(_NLIB, "cd_thread_inherit_ok"):
            return int(_NLIB.cd_thread_inherit_ok()) == 1
    except Exception:
        pass
    return False

def _install_thread_shim():
    global _THREAD_SHIM_ON, _THREAD_SHIM_INSTALLED
    if _THREAD_SHIM_ON:
        return
    if False and _native_thread_inherit():
        _log("PartB: наследование тега потоков обеспечивает натив (Part A) — Python-shim не нужен")
        _THREAD_SHIM_ON = True
        return
    try:
        _cur_start = threading.Thread.start
        if getattr(_cur_start, "_culprit_shim", False):
            _orig_start = getattr(_cur_start, "_culprit_prev", None) or getattr(threading.Thread, "_culprit_orig_start", None) or _cur_start
        else:
            _orig_start = _cur_start
            if getattr(threading.Thread, "_culprit_orig_start", None) is None:
                try: threading.Thread._culprit_orig_start = _cur_start
                except Exception: pass
        def _tagged_start(self):
            try:
                parent = _reg_get(_cur_tid())
            except Exception:
                parent = None
            tag_name = None
            if parent is not None and parent >= 0:
                try: tag_name = _resolve_idx(parent)
                except Exception: tag_name = None
            if tag_name is None:
                try: prov = _provenance_pid(self, 1)
                except Exception: prov = None
                if prov is not None:
                    tag_name = prov
            if tag_name is not None and not getattr(self, "_culprit_wrapped", False):
                _real_run = self.run
                def _run_wrapper(_rr=_real_run, _pid=tag_name):
                    pushed = False
                    try:
                        pushed = _scoped_set(_pid)
                        return _rr()
                    finally:
                        if pushed:
                            try: _scoped_clear()
                            except Exception: pass
                        try:
                            _s = self
                            if _s is not None:
                                try: del _s.run
                                except Exception: pass
                                try: _s._culprit_wrapped = False
                                except Exception: pass
                        except Exception: pass
                try:
                    self.run = _run_wrapper
                    self._culprit_wrapped = True
                except Exception:
                    pass
            try:
                return _orig_start(self)
            except Exception:
                try:
                    if getattr(self, "_culprit_wrapped", False):
                        try: del self.run
                        except Exception: pass
                        self._culprit_wrapped = False
                except Exception: pass
                raise
        _tagged_start._culprit_shim = True
        _tagged_start._culprit_prev = _orig_start
        threading.Thread.start = _tagged_start
        threading.Thread._culprit_shim = True
        _THREAD_SHIM_INSTALLED = _tagged_start
        _THREAD_SHIM_ON = True
        _log("PartB/E: Python thread-shim (пере)привязан к текущему load (rebind-safe); нативный Part A (cd_thread_inherit_ok)=%s" % ("ON" if _native_thread_inherit() else "OFF"))
    except Exception as e:
        _log(f"PartB thread-shim err: {e}")

def _partb_install():
    try:
        _install_thread_shim()
    except Exception as e:
        _log(f"PartB thread-shim install err: {e}")
    try:
        _install_settings_ctor_scope()
    except Exception as e:
        _log(f"Gap8 settings-ctor install err: {e}")
    try:
        _instrument_entrypoints()
        global _PARTB_TIMER
        try:
            if _PARTB_TIMER is not None: _PARTB_TIMER.cancel()
        except Exception: pass
        _PARTB_TIMER = threading.Timer(2.5, _instrument_entrypoints)
        _PARTB_TIMER.daemon = True; _PARTB_TIMER.start()
    except Exception as e:
        _log(f"PartB install err: {e}")

def _partb_uninstall():
    global _PARTB_TIMER, _THREAD_SHIM_ON, _THREAD_SHIM_INSTALLED
    try:
        if _PARTB_TIMER is not None:
            _PARTB_TIMER.cancel()
            _PARTB_TIMER = None
    except Exception as e:
        _log(f"PartB timer cancel err: {e}")
    try:
        _orig_start = (getattr(_THREAD_SHIM_INSTALLED, "_culprit_prev", None) if _THREAD_SHIM_INSTALLED is not None else None) or getattr(threading.Thread, "_culprit_orig_start", None)
        if (_orig_start is not None and _THREAD_SHIM_INSTALLED is not None
                and threading.Thread.start is _THREAD_SHIM_INSTALLED):
            threading.Thread.start = _orig_start
            try: threading.Thread._culprit_shim = False
            except Exception: pass
        elif _THREAD_SHIM_INSTALLED is not None and threading.Thread.start is not _THREAD_SHIM_INSTALLED:
            _log("PartB: thread-shim обёрнут поверх другим плагином — оставляю как есть (revert пропущен)")
        _THREAD_SHIM_INSTALLED = None
        _THREAD_SHIM_ON = False
    except Exception as e:
        _log(f"PartB thread-shim uninstall err: {e}")
    try:
        global _SETTINGS_CTOR_HOOKED
        for _cls, _orig, _w in list(_SETTINGS_PATCHED):
            try:
                if _cls.__dict__.get("__init__") is _w:
                    _cls.__init__ = _orig
            except Exception: pass
        _SETTINGS_PATCHED.clear()
        _SETTINGS_CTOR_HOOKED = False
    except Exception as e:
        _log(f"Gap8 settings-ctor uninstall err: {e}")
    try:
        for _tup in list(_ENTRY_PATCHED):
            try:
                _obj = _wref_get(_tup[0])
                if _obj is None: continue
                _cb = _tup[1]
                _ourw = _wref_get(_tup[2]) if len(_tup) > 2 else None
                if _ourw is not None and getattr(_obj, _cb, None) is _ourw:
                    _orig = getattr(_ourw, "__wrapped__", None)
                    if _orig is not None:
                        setattr(_obj, _cb, _orig)
                    else:
                        try: delattr(_obj, _cb)
                        except Exception: pass
            except Exception: pass
        _ENTRY_PATCHED.clear()
    except Exception as e:
        _log(f"PartB entrypoint uninstall err: {e}")


try:
    from base_plugin import MethodReplacement as _MethodReplacement
except Exception:
    _MethodReplacement = None

_BLOCK10_ON = True
_B10_FLAG = "__culprit_hookwrap__"
_B10_METHODS = ("before_hooked_method", "after_hooked_method", "replace_hooked_method")
_B10_PATCHED = {}
_B10_WRAPPED_CLASSES = []
_B10_WRAP_LOCK = threading.Lock()
_B10_TIMERS = []

def _b10_owner_from_module(mod_name):
    if not mod_name:
        return None
    try:
        mod = _sys.modules.get(mod_name)
    except Exception:
        mod = None
    pid = getattr(mod, "__id__", None) if mod is not None else None
    if not (isinstance(pid, str) and pid):
        pid = _canon_pid(mod_name)
    if pid == _SELF_ID or pid == __id__:
        return None
    return pid

def _b10_pyframe_culprit(exc, owner):
    try:
        tb = getattr(exc, "__traceback__", None)
    except Exception:
        tb = None
    best = (None, None, -1)
    best_owner = None
    while tb is not None:
        try:
            f = tb.tb_frame; g = f.f_globals
            mod = g.get("__name__") or ""
            fn = g.get("__file__") or ((mod + ".py") if mod else None)
            ln = tb.tb_lineno
        except Exception:
            mod = ""; fn = None; ln = -1
        pid = None
        if mod and mod != _SELF_ID and mod != __id__:
            try:
                mobj = _sys.modules.get(mod)
                cand = getattr(mobj, "__id__", None) if mobj is not None else None
                if not (isinstance(cand, str) and cand):
                    c2 = _canon_pid(mod)
                    if isinstance(c2, str) and c2 and c2 != mod:
                        cand = c2
                if isinstance(cand, str) and cand and cand != _SELF_ID and cand != __id__:
                    pid = cand
            except Exception:
                pid = None
        if pid is not None:
            best = (pid, fn, int(ln) if ln is not None else -1)
            if owner and pid == owner:
                best_owner = (pid, fn, int(ln) if ln is not None else -1)
        try: tb = tb.tb_next
        except Exception: tb = None
    return best_owner if best_owner is not None else best

def _b10_record(owner, exc, where):
    if not _BLOCK10_ON:
        return
    try: exc_cls = type(exc).__name__
    except Exception: exc_cls = "?"
    try: exc_msg = str(exc)
    except Exception: exc_msg = None
    reason = ("%s: %s" % (exc_cls, exc_msg)) if exc_msg else exc_cls
    py_mod, py_file, py_line = _b10_pyframe_culprit(exc, owner)
    if py_mod:
        culprit = py_mod; src = "py-frame/" + where; conf = "high"
    elif owner:
        culprit = owner; src = "scope/" + where; conf = "medium"
    else:
        culprit = "unknown"; src = "none"; conf = "low"
    _rate_pm, _rate_n = _exc_rate_record(culprit)
    rec = {"had_hook_fail": True, "culprit": culprit, "src": src, "confidence": conf,
           "where": where, "scoped_pid": owner, "py_module": py_mod,
           "py_file": py_file, "py_line": py_line, "reason": reason,
           "throws_per_min": _rate_pm, "throws_in_window": _rate_n,
           "high_rate": bool(_rate_pm >= _EXC_RATE_HOT),
           "exc_cls": exc_cls, "exc_msg": exc_msg, "ts": int(time.time() * 1000)}
    key = "%s|%s|%s" % (culprit, reason, where); now = rec["ts"]
    try:
        with _HOOK_SEEN_LOCK:
            if now - _HOOK_SEEN.get(key, 0) < _HOOK_DEDUP_MS:
                return
            _HOOK_SEEN[key] = now
    except Exception:
        pass
    try: _hook_verdict_log(rec, "live")
    except Exception: pass
    try: _persist_hook_fail(rec)
    except Exception: pass

def _b10_make_wrapper(orig, name):
    @_functools.wraps(orig)
    def _w(self, *a, **kw):
        owner = None
        try:
            owner = _b10_owner_from_module(getattr(type(self), "__module__", None))
        except Exception:
            owner = None
        method_name = None
        method_key = None
        if a:
            try:
                _m = a[0].method
                method_name = str(_m.getName())
                try:
                    method_key = str(_m.toGenericString())
                except Exception:
                    try:
                        method_key = "%s.%s" % (str(_m.getDeclaringClass().getName()), method_name)
                    except Exception:
                        method_key = method_name
            except Exception:
                method_name = None
                method_key = None
        _reentry_ok = True
        _reentry_key = None
        try:
            _reentry_ok, _reentry_key = _b10_reentry_enter(owner, name, method_key)
        except Exception:
            _reentry_ok, _reentry_key = True, None
        if not _reentry_ok:
            return None
        _passive = False
        if _B10_PASSIVE_SCOPE_SKIP and owner is not None and method_name:
            try:
                _passive = _b10_passive_scope_skip(owner, method_name, method_key)
            except Exception:
                _passive = False
        pushed = False
        if owner is not None and not _passive:
            try: pushed = _scoped_set(owner)
            except Exception: pushed = False
            if name == "before_hooked_method":
                try: _scoped_arm(owner)
                except Exception: pass
        if _BLOCK28_ON and owner is not None and a:
            try:
                _param_obj = a[0]
                _mname_java = str(_param_obj.method.getName())
                if _mname_java in _B28_HOT_METHODS:
                    _b28_reg_hot_hook(owner, _mname_java, persist=True)
                    try: _b28_hit(owner, _mname_java)
                    except Exception: pass
            except Exception:
                pass
        try:
            return orig(self, *a, **kw)
        except BaseException as e:
            if owner is not None:
                try:
                    if method_key and _b10_shape_getter(method_name):
                        _b10_passive_mark_force(owner, method_key, method_name, "python_exception")
                except Exception: pass
                try: _b10_record(owner, e, name)
                except Exception: pass
            raise
        finally:
            if pushed:
                try: _scoped_clear()
                except Exception: pass
            if name == "after_hooked_method":
                try: _scoped_arm_clear()
                except Exception: pass
            try:
                if _reentry_key:
                    _b10_reentry_leave(_reentry_key)
            except Exception: pass
    try:
        setattr(_w, _B10_FLAG, True)
        hf = getattr(orig, "__hook_filters__", None)
        if hf is not None:
            try: _w.__hook_filters__ = dict(hf) if isinstance(hf, dict) else hf
            except Exception: pass
    except Exception:
        pass
    return _w

def _b10_wrap_class(cls):
    if cls is None:
        return 0
    try:
        mod = getattr(cls, "__module__", None)
        if mod == _SELF_ID or mod == __id__ or mod == "base_plugin":
            return 0
    except Exception:
        pass
    n = 0
    for name in _B10_METHODS:
        try:
            fn = cls.__dict__.get(name)
        except Exception:
            fn = None
        if fn is None or not callable(fn):
            continue
        if getattr(fn, _B10_FLAG, False):
            continue
        try:
            wrapped = _b10_make_wrapper(fn, name)
            setattr(cls, name, wrapped)
            with _B10_WRAP_LOCK:
                _prune_dead_wrefs(_B10_WRAPPED_CLASSES)
                _B10_WRAPPED_CLASSES.append((_wref_make(cls), name, fn, wrapped))
            n += 1
        except Exception:
            pass
    return n

def _b10_all_subclasses(root):
    out = []
    try:
        subs = list(root.__subclasses__())
    except Exception:
        subs = []
    for s in subs:
        out.append(s)
        out.extend(_b10_all_subclasses(s))
    return out

def _b10_sweep(reason="sweep"):
    bases = [MethodHook]
    if _MethodReplacement is not None:
        bases.append(_MethodReplacement)
    seen = set(); total = 0; classes = 0
    for b in bases:
        for cls in [b] + _b10_all_subclasses(b):
            try: k = id(cls)
            except Exception: k = None
            if k in seen: continue
            seen.add(k)
            c = _b10_wrap_class(cls)
            if c: classes += 1; total += c
    if total:
        _log(f"Block#10 {reason}: обёрнуто классов-хуков={classes} методов={total}")
    return total

def _b10_wrap_functional(fn):
    if fn is None or not callable(fn) or getattr(fn, _B10_FLAG, False):
        return fn
    _mod0 = getattr(fn, "__module__", None)
    if _mod0 is None:
        try:
            if isinstance(fn, _functools.partial):
                _mod0 = getattr(fn.func, "__module__", None)
            elif hasattr(fn, "__call__"):
                _mod0 = getattr(fn.__call__, "__module__", None)
        except Exception:
            pass
    try:
        owner0 = _b10_owner_from_module(_mod0)
    except Exception:
        owner0 = None
    @_functools.wraps(fn)
    def _w(*a, **kw):
        pushed = False
        if owner0 is not None:
            try: pushed = _scoped_set(owner0)
            except Exception: pushed = False
        try:
            return fn(*a, **kw)
        except BaseException as e:
            if owner0 is not None:
                try: _b10_record(owner0, e, "functional")
                except Exception: pass
            raise
        finally:
            if pushed:
                try: _scoped_clear()
                except Exception: pass
    try: setattr(_w, _B10_FLAG, True)
    except Exception: pass
    return _w

def _b10_is_hook_instance(obj):
    if obj is None or isinstance(obj, type):
        return False
    try:
        if isinstance(obj, MethodHook):
            return True
    except Exception:
        pass
    try:
        if _MethodReplacement is not None and isinstance(obj, _MethodReplacement):
            return True
    except Exception:
        pass
    try:
        return any(callable(getattr(obj, n, None)) for n in _B10_METHODS)
    except Exception:
        return False

_B10_INSTALLED = {}
def _b10_patch_basehooks():
    if not hasattr(BasePlugin, "hook_method"):
        _log("Block#10: BasePlugin.hook_method не найден — monkeypatch пропущен"); return 0
    patched = 0
    for mname in ("hook_method", "hook_all_methods", "hook_all_constructors"):
        orig = getattr(BasePlugin, mname, None)
        if orig is None or getattr(orig, _B10_FLAG, False):
            continue
        def _make(orig=orig, mname=mname):
            @_functools.wraps(orig)
            def _patched(self, *a, **kw):
                try:
                    for arg in list(a) + list(kw.values()):
                        if _b10_is_hook_instance(arg):
                            try: _b10_wrap_class(type(arg))
                            except Exception: pass
                    for fk in ("before", "after", "replace"):
                        if fk in kw and callable(kw[fk]):
                            try: kw[fk] = _b10_wrap_functional(kw[fk])
                            except Exception: pass
                except Exception:
                    pass
                if _BLOCK28_ON and mname in ("hook_method", "hook_all_methods") and a:
                    try:
                        m_obj = a[0]
                        mname_java = None
                        try: mname_java = str(m_obj.getName())
                        except Exception: pass
                        if mname_java and mname_java in _B28_HOT_METHODS:
                            pid = _canonical_pid(self)
                            if pid and pid != _SELF_ID:
                                _b28_reg_hot_hook(pid, mname_java, persist=True)
                    except Exception:
                        pass
                return orig(self, *a, **kw)
            try: setattr(_patched, _B10_FLAG, True)
            except Exception: pass
            return _patched
        try:
            _w = _make()
            setattr(BasePlugin, mname, _w)
            _B10_PATCHED[mname] = orig
            _B10_INSTALLED[mname] = _w
            patched += 1
        except Exception as e:
            _log(f"Block#10: monkeypatch {mname} err: {e}")
    if patched:
        _log(f"Block#10: monkeypatch BasePlugin.* установлен ({patched}/3)")
    return patched

def _b10_unpatch():
    for _t in _B10_TIMERS:
        try: _t.cancel()
        except Exception: pass
    _B10_TIMERS.clear()
    for mname, orig in list(_B10_PATCHED.items()):
        try:
            cur = getattr(BasePlugin, mname, None)
            if cur is not None and cur is _B10_INSTALLED.get(mname):
                setattr(BasePlugin, mname, orig)
        except Exception: pass
    _B10_PATCHED.clear()
    _B10_INSTALLED.clear()
    with _B10_WRAP_LOCK:
        items = list(_B10_WRAPPED_CLASSES); _B10_WRAPPED_CLASSES.clear()
    for tup in items:
        try:
            cls = _wref_get(tup[0])
            if cls is None: continue
            name, orig_fn = tup[1], tup[2]
            our_w = tup[3] if len(tup) > 3 else None
            cur = cls.__dict__.get(name)
            if cur is not None and (cur is our_w if our_w is not None else getattr(cur, _B10_FLAG, False)):
                setattr(cls, name, orig_fn)
        except Exception:
            pass

def _cp_reclaim_basehooks():
    try:
        BP = BasePlugin
    except Exception:
        return 0
    flags = (_B10_FLAG, _B12_FLAG)
    def _ours(fn):
        for f in flags:
            try:
                if getattr(fn, f, False):
                    return True
            except Exception:
                pass
        return False
    n = 0
    for mname in ("hook_method", "hook_all_methods", "hook_all_constructors", "add_menu_item"):
        try:
            cur = getattr(BP, mname, None)
            if cur is None or not _ours(cur):
                continue
            base = cur; hops = 0
            while base is not None and _ours(base) and hops < 12:
                nxt = getattr(base, "__wrapped__", None)
                if nxt is None or nxt is base:
                    break
                base = nxt; hops += 1
            if base is not None and base is not cur and not _ours(base):
                setattr(BP, mname, base); n += 1
        except Exception:
            pass
    if n:
        _log("cooperative-patch: reclaimed %d stale BasePlugin wrapper(s) from a prior load (+AZ)" % n)
    return n

def _b10_install():
    if not _BLOCK10_ON:
        _log("Block#10: отключён (_BLOCK10_ON=False)"); return
    try: _b10_patch_basehooks()
    except Exception as e: _log(f"Block#10 patch err: {e}")
    try: _b10_sweep("boot-sweep")
    except Exception as e: _log(f"Block#10 sweep err: {e}")
    try:
        t = threading.Timer(2.5, lambda: _b10_sweep("re-sweep"))
        t.daemon = True; t.start()
        _B10_TIMERS.append(t)
    except Exception as e:
        _log(f"Block#10 re-sweep schedule err: {e}")


_BLOCK12_ON = True
_B12_FLAG = "__culprit_uiwrap__"
_B12_PATCHED = {}
_B12_WRAPPED_CLASSES = []
_B12_WRAP_LOCK = threading.Lock()
_B12_TIMERS = []
_UI_FILE_NAME = "ui_verdict.json"
_UI_FAILS_MAX = 20
_UI_DEDUP_MS = 4000
_UI_SEEN = {}; _UI_SEEN_LOCK = threading.Lock()
_UI_MENU_CB_KEYS = ("on_click", "condition", "label", "text", "on_long_click")
_UI_DELEGATE_METHS = ("on_attached", "on_detached", "on_size_changed", "on_destroy", "create_view")
_UI_UNAMBIG = ("on_attached", "on_detached", "on_size_changed")

def _ui_verdict_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _UI_FILE_NAME).getAbsolutePath()
    except Exception:
        return None

def _ui_verdict_log(rec, when):
    try:
        _log("============= UI CALLBACK VERDICT (%s) =============" % when)
        cul = rec.get("culprit"); conf = rec.get("confidence")
        if cul and cul != "unknown":
            _log("ВИНОВНИК UI-КОЛБЭКА: %r conf=%s where=%s src=%s" % (cul, conf, rec.get("where"), rec.get("src")))
        else:
            _log("ВИНОВНИК UI-КОЛБЭКА: неизвестен (where=%s) — нет имени модуля в стеке" % rec.get("where"))
        _log("  причина: %s" % rec.get("reason"))
        pf = rec.get("py_file")
        if pf: _log("  модуль: %s:%s" % (pf, rec.get("py_line")))
        sp = rec.get("scoped_pid")
        if sp and sp != cul: _log("  scope-плагин(tid): %s" % sp)
        _log("  исключение: %s: %s" % (rec.get("exc_cls"), rec.get("exc_msg")))
        _log("===================================================")
    except Exception: pass

def _persist_ui_fail(rec):
    p = _ui_verdict_path()
    if not p: return
    _PERSIST_IO_LOCK.acquire()
    try:
        cur = []
        if os.path.exists(p):
            try:
                with open(p, "r", encoding="utf-8") as f: cur = list(json.load(f))
            except Exception: cur = []
        cur.append(rec)
        _atomic_json_write(p, cur, _UI_FAILS_MAX)
    except Exception: pass
    finally:
        try: _PERSIST_IO_LOCK.release()
        except Exception: pass

def _read_and_clear_ui_fails():
    p = _ui_verdict_path()
    if not p: return []
    out = []
    _rp = _rc_take_path(p)
    try:
        if _rp:
            with open(_rp, "r", encoding="utf-8") as f: out = list(json.load(f))
    except Exception: out = []
    if _rp:
        try: os.remove(_rp)
        except Exception: pass
    return out

def _b12_record(owner, exc, surface, meth):
    if not _BLOCK12_ON:
        return
    try: exc_cls = type(exc).__name__
    except Exception: exc_cls = "?"
    try: exc_msg = str(exc)
    except Exception: exc_msg = None
    reason = ("%s: %s" % (exc_cls, exc_msg)) if exc_msg else exc_cls
    where = "%s.%s" % (surface, meth)
    py_mod, py_file, py_line = _b10_pyframe_culprit(exc, owner)
    if py_mod:
        culprit = py_mod; src = "py-frame/" + where; conf = "high"
    elif owner:
        culprit = owner; src = "scope/" + where; conf = "medium"
    else:
        culprit = "unknown"; src = "none"; conf = "low"
    rec = {"had_ui_fail": True, "event_type": "ui_exception", "dropbox_tag": "data_app_crash", "tombstone_norm_version": 1, "culprit": culprit, "src": src, "confidence": conf,
           "surface": surface, "method": meth, "where": where, "scoped_pid": owner,
           "py_module": py_mod, "py_file": py_file, "py_line": py_line, "reason": reason,
           "exc_cls": exc_cls, "exc_msg": exc_msg, "ts": int(time.time() * 1000)}
    key = "%s|%s|%s" % (culprit, reason, where); now = rec["ts"]
    try:
        with _UI_SEEN_LOCK:
            if now - _UI_SEEN.get(key, 0) < _UI_DEDUP_MS:
                return
            _UI_SEEN[key] = now
    except Exception:
        pass
    try: _b16_push_verdict("ui", rec)
    except Exception: pass
    try: _ui_verdict_log(rec, "live")
    except Exception: pass
    try: _persist_ui_fail(rec)
    except Exception: pass

def _b12_make_wrapper(orig, surface, meth):
    @_functools.wraps(orig)
    def _w(self, *a, **kw):
        owner = None
        try:
            owner = _b10_owner_from_module(getattr(type(self), "__module__", None))
        except Exception:
            owner = None
        pushed = False
        if owner is not None:
            try: pushed = _scoped_set(owner)
            except Exception: pushed = False
        try:
            return orig(self, *a, **kw)
        except BaseException as e:
            if owner is not None:
                try: _b12_record(owner, e, surface, meth)
                except Exception: pass
            raise
        finally:
            if pushed:
                try: _scoped_clear()
                except Exception: pass
    try: setattr(_w, _B12_FLAG, True)
    except Exception: pass
    return _w

def _b12_wrap_menu_cb(owner, fn, meth):
    if fn is None or not callable(fn) or getattr(fn, _B12_FLAG, False):
        return fn
    @_functools.wraps(fn)
    def _w(*a, **kw):
        pushed = False
        if owner is not None:
            try: pushed = _scoped_set(owner)
            except Exception: pushed = False
        _uic = (owner is not None) and (meth in _UI_CLICK_ATTRS)
        if _uic:
            try: _ui_click_enter(owner)
            except Exception: pass
        try:
            return fn(*a, **kw)
        except BaseException as e:
            if owner is not None:
                try: _b12_record(owner, e, "menu", meth)
                except Exception: pass
            raise
        finally:
            if _uic:
                try: _ui_click_leave()
                except Exception: pass
            if pushed:
                try: _scoped_clear()
                except Exception: pass
    try: setattr(_w, _B12_FLAG, True)
    except Exception: pass
    return _w

def _b12_wrap_class(cls):
    if cls is None:
        return 0
    try:
        mod = getattr(cls, "__module__", None)
        if mod == _SELF_ID or mod == __id__ or mod == "base_plugin" or mod == "client_utils":
            return 0
    except Exception:
        pass
    try:
        defined = [m for m in _UI_DELEGATE_METHS if callable(cls.__dict__.get(m))]
    except Exception:
        defined = []
    if not defined:
        return 0
    multi = len(defined) >= 2
    n = 0
    for name in defined:
        if not (multi or name in _UI_UNAMBIG):
            continue
        try:
            fn = cls.__dict__.get(name)
        except Exception:
            fn = None
        if fn is None or not callable(fn) or getattr(fn, _B12_FLAG, False):
            continue
        try:
            wrapped = _b12_make_wrapper(fn, "universal", name)
            setattr(cls, name, wrapped)
            with _B12_WRAP_LOCK:
                _prune_dead_wrefs(_B12_WRAPPED_CLASSES)
                _B12_WRAPPED_CLASSES.append((_wref_make(cls), name, fn, wrapped))
            n += 1
        except Exception:
            pass
    return n

def _b12_sweep(reason="sweep"):
    classes = 0; total = 0; seen = set()
    try: mods = list(_sys.modules.items())
    except Exception: mods = []
    for mname, mod in mods:
        if mod is None: continue
        try: pid = getattr(mod, "__id__", None)
        except Exception: pid = None
        if not (isinstance(pid, str) and pid): continue
        if pid == _SELF_ID or pid == __id__: continue
        names = {mname}
        try:
            nm = getattr(mod, "__name__", None)
            if nm: names.add(nm)
        except Exception: pass
        try: members = list(vars(mod).values())
        except Exception: members = []
        for obj in members:
            if not isinstance(obj, type): continue
            try:
                if getattr(obj, "__module__", None) not in names: continue
            except Exception: continue
            try: k = id(obj)
            except Exception: k = None
            if k in seen: continue
            seen.add(k)
            c = _b12_wrap_class(obj)
            if c: classes += 1; total += c
    if total:
        _log(f"Block#12 {reason}: обёрнуто UI-классов={classes} методов={total}")
    return total

_B12_INSTALLED = {}
def _b12_patch_menu():
    if not hasattr(BasePlugin, "add_menu_item"):
        _log("Block#12: BasePlugin.add_menu_item не найден — menu patch пропущен"); return 0
    orig = getattr(BasePlugin, "add_menu_item", None)
    if orig is None or getattr(orig, _B12_FLAG, False):
        return 0
    @_functools.wraps(orig)
    def _patched(self, *a, **kw):
        owner = None
        try:
            owner = _b10_owner_from_module(getattr(type(self), "__module__", None))
        except Exception:
            owner = None
        if owner is not None:
            try:
                for arg in a:
                    if isinstance(arg, dict):
                        for k in list(arg.keys()):
                            if k in _UI_MENU_CB_KEYS and callable(arg.get(k)):
                                try: arg[k] = _b12_wrap_menu_cb(owner, arg[k], k)
                                except Exception: pass
                for k in list(kw.keys()):
                    if k in _UI_MENU_CB_KEYS and callable(kw.get(k)):
                        try: kw[k] = _b12_wrap_menu_cb(owner, kw[k], k)
                        except Exception: pass
            except Exception:
                pass
        return orig(self, *a, **kw)
    try: setattr(_patched, _B12_FLAG, True)
    except Exception: pass
    try: setattr(_patched, "__wrapped__", orig)
    except Exception: pass
    try:
        setattr(BasePlugin, "add_menu_item", _patched)
        _B12_PATCHED["add_menu_item"] = orig
        _B12_INSTALLED["add_menu_item"] = _patched
        _log("Block#12: monkeypatch BasePlugin.add_menu_item установлен")
        return 1
    except Exception as e:
        _log(f"Block#12: menu patch err: {e}"); return 0

def _b12_unpatch():
    for _t in _B12_TIMERS:
        try: _t.cancel()
        except Exception: pass
    _B12_TIMERS.clear()
    for mname, orig in list(_B12_PATCHED.items()):
        try:
            cur = getattr(BasePlugin, mname, None)
            if cur is not None and cur is _B12_INSTALLED.get(mname):
                setattr(BasePlugin, mname, orig)
        except Exception: pass
    _B12_PATCHED.clear()
    _B12_INSTALLED.clear()
    with _B12_WRAP_LOCK:
        items = list(_B12_WRAPPED_CLASSES); _B12_WRAPPED_CLASSES.clear()
    for tup in items:
        try:
            cls = _wref_get(tup[0])
            if cls is None: continue
            name, orig_fn = tup[1], tup[2]
            our_w = tup[3] if len(tup) > 3 else None
            cur = cls.__dict__.get(name)
            if cur is not None and (cur is our_w if our_w is not None else getattr(cur, _B12_FLAG, False)):
                setattr(cls, name, orig_fn)
        except Exception:
            pass

_LOADSWEEP_LOCK = threading.Lock()
_LOADSWEEP_TIMER = None
_LOADSWEEP_DELAY = 1.5
def _kick_load_resweep(pid):
    global _LOADSWEEP_TIMER
    def _run():
        try: _b10_sweep("load-resweep")
        except Exception as e: _log("Block#10 load-resweep err: %s" % e)
        try: _b12_sweep("load-resweep")
        except Exception as e: _log("Block#12 load-resweep err: %s" % e)
        try: _b14_sweep("load-resweep")
        except Exception as e: _log("Block#14 load-resweep err: %s" % e)
        try: _b11_scan("load-resweep")
        except Exception as e: _log("Block#11 load-resweep err: %s" % e)
    try:
        with _LOADSWEEP_LOCK:
            t = _LOADSWEEP_TIMER
            if t is not None:
                try: t.cancel()
                except Exception: pass
            nt = threading.Timer(_LOADSWEEP_DELAY, _run)
            nt.daemon = True
            _LOADSWEEP_TIMER = nt
            nt.start()
    except Exception as e:
        _log("load-resweep schedule err: %s" % e)

def _b12_install():
    if not _BLOCK12_ON:
        _log("Block#12: отключён (_BLOCK12_ON=False)"); return
    try: _b12_patch_menu()
    except Exception as e: _log(f"Block#12 menu patch err: {e}")
    try: _b12_sweep("boot-sweep")
    except Exception as e: _log(f"Block#12 sweep err: {e}")
    for _delay in (3.0, 8.0):
        try:
            t = threading.Timer(_delay, lambda d=_delay: _b12_sweep("re-sweep@%.0fs" % d))
            t.daemon = True; t.start()
            _B12_TIMERS.append(t)
        except Exception as e:
            _log(f"Block#12 re-sweep schedule err: {e}")

_BLOCK13_ON = True
_BG_FILE_NAME = "bg_verdict.json"
_BG_FAILS_MAX = 20
_BG_DEDUP_MS = 4000
_BG_SEEN = {}; _BG_SEEN_LOCK = threading.Lock()
_BG_PREV_EXCEPTHOOK = None
_BG_PREV_UNRAISABLE = None
_BG_INSTALLED = False

def _bg_verdict_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _BG_FILE_NAME).getAbsolutePath()
    except Exception:
        return None

def _bg_verdict_log(rec, when):
    try:
        _log("============= BACKGROUND VERDICT (%s) =============" % when)
        cul = rec.get("culprit"); conf = rec.get("confidence")
        if cul and cul != "unknown":
            _log("ВИНОВНИК ФОНА: %r conf=%s where=%s src=%s" % (cul, conf, rec.get("where"), rec.get("src")))
        else:
            _log("ВИНОВНИК ФОНА: неизвестен (where=%s) — нет имени модуля в стеке/теге" % rec.get("where"))
        tn = rec.get("thread_name")
        if tn: _log("  поток: %s" % tn)
        _log("  причина: %s" % rec.get("reason"))
        pf = rec.get("py_file")
        if pf: _log("  модуль: %s:%s" % (pf, rec.get("py_line")))
        sp = rec.get("scoped_pid")
        if sp and sp != cul: _log("  scope-плагин(tid): %s" % sp)
        _log("  исключение: %s: %s" % (rec.get("exc_cls"), rec.get("exc_msg")))
        _log("==================================================")
    except Exception: pass

def _persist_bg_fail(rec):
    p = _bg_verdict_path()
    if not p: return
    _PERSIST_IO_LOCK.acquire()
    try:
        cur = []
        if os.path.exists(p):
            try:
                with open(p, "r", encoding="utf-8") as f: cur = list(json.load(f))
            except Exception: cur = []
        cur.append(rec)
        _atomic_json_write(p, cur, _BG_FAILS_MAX)
    except Exception: pass
    finally:
        try: _PERSIST_IO_LOCK.release()
        except Exception: pass

def _read_and_clear_bg_fails():
    p = _bg_verdict_path()
    if not p: return []
    out = []
    _rp = _rc_take_path(p)
    try:
        if _rp:
            with open(_rp, "r", encoding="utf-8") as f: out = list(json.load(f))
    except Exception: out = []
    if _rp:
        try: os.remove(_rp)
        except Exception: pass
    return out

def _bg_record(exc, where, thread_obj=None, thread_name=None):
    if not _BLOCK13_ON:
        return
    try: exc_cls = type(exc).__name__
    except Exception: exc_cls = "?"
    try: exc_msg = str(exc)
    except Exception: exc_msg = None
    reason = ("%s: %s" % (exc_cls, exc_msg)) if exc_msg else exc_cls
    py_mod = None; py_file = None; py_line = None
    try:
        py_mod, py_file, py_line = _b10_pyframe_culprit(exc, None)
    except Exception:
        py_mod = None
    scoped = None
    try:
        c = get_culprit_for_tid(_cur_tid())
        if c and c != "unknown" and c != _SELF_ID and c != __id__:
            scoped = c
    except Exception:
        scoped = None
    prov = None
    if py_mod is None and scoped is None:
        try:
            prov = _provenance_pid(thread_obj, 1)
            if prov in (_SELF_ID, __id__): prov = None
        except Exception:
            prov = None
    if py_mod:
        culprit = py_mod; src = "py-frame/" + where; conf = "high"
    elif scoped:
        culprit = scoped; src = "scope/" + where; conf = "medium"
    elif prov:
        culprit = prov; src = "provenance/" + where; conf = "medium"
    else:
        culprit = "unknown"; src = "none"; conf = "low"
    if culprit == _SELF_ID or culprit == __id__:
        return
    rec = {"had_bg_fail": True, "event_type": "background_exception", "dropbox_tag": "data_app_crash", "tombstone_norm_version": 1, "culprit": culprit, "src": src, "confidence": conf,
           "where": where, "thread_name": thread_name, "scoped_pid": scoped,
           "py_module": py_mod, "py_file": py_file, "py_line": py_line, "reason": reason,
           "exc_cls": exc_cls, "exc_msg": exc_msg, "ts": int(time.time() * 1000)}
    key = "%s|%s|%s" % (culprit, reason, where); now = rec["ts"]
    try:
        with _BG_SEEN_LOCK:
            if now - _BG_SEEN.get(key, 0) < _BG_DEDUP_MS:
                return
            _BG_SEEN[key] = now
    except Exception:
        pass
    try: _b16_push_verdict("bg", rec)
    except Exception: pass
    try: _bg_verdict_log(rec, "live")
    except Exception: pass
    try: _persist_bg_fail(rec)
    except Exception: pass

def _bg_excepthook(args):
    try:
        exc = getattr(args, "exc_value", None)
        et = getattr(args, "exc_type", None)
        thr = getattr(args, "thread", None)
        tname = None
        try: tname = getattr(thr, "name", None)
        except Exception: tname = None
        if exc is not None and et is not SystemExit:
            _bg_where = "thread"
            try:
                if isinstance(thr, threading.Timer):
                    _bg_where = "timer"
            except Exception:
                _bg_where = "thread"
            _bg_record(exc, _bg_where, thread_obj=thr, thread_name=tname)
    except Exception:
        pass
    try:
        prev = _BG_PREV_EXCEPTHOOK
        if prev is not None and prev is not _bg_excepthook:
            prev(args)
    except Exception:
        pass
_bg_excepthook._culprit_bg = True

def _bg_unraisablehook(unr):
    try:
        exc = getattr(unr, "exc_value", None)
        if exc is not None:
            _bg_record(exc, "unraisable", thread_obj=None, thread_name=None)
    except Exception:
        pass
    try:
        prev = _BG_PREV_UNRAISABLE
        if prev is not None and prev is not _bg_unraisablehook:
            prev(unr)
    except Exception:
        pass
_bg_unraisablehook._culprit_bg = True

def _b13_install():
    global _BG_PREV_EXCEPTHOOK, _BG_PREV_UNRAISABLE, _BG_INSTALLED
    if not _BLOCK13_ON:
        _log("Block#13: отключён (_BLOCK13_ON=False)"); return
    n = 0
    try:
        cur = getattr(threading, "excepthook", None)
        if cur is not None:
            if not getattr(cur, "_culprit_bg", False):
                _BG_PREV_EXCEPTHOOK = cur
            threading.excepthook = _bg_excepthook
            n += 1
    except Exception as e:
        _log(f"Block#13 excepthook install err: {e}")
    try:
        cur = getattr(_sys, "unraisablehook", None)
        if cur is not None:
            if not getattr(cur, "_culprit_bg", False):
                _BG_PREV_UNRAISABLE = cur
            _sys.unraisablehook = _bg_unraisablehook
            n += 1
    except Exception as e:
        _log(f"Block#13 unraisablehook install err: {e}")
    _BG_INSTALLED = n > 0
    _log("Block#13: фоновые хуки установлены (threading.excepthook + sys.unraisablehook): %d/2 -> %s" % (n, _BG_FILE_NAME))

def _b13_uninstall():
    global _BG_INSTALLED
    try:
        if getattr(threading, "excepthook", None) is _bg_excepthook and _BG_PREV_EXCEPTHOOK is not None:
            threading.excepthook = _BG_PREV_EXCEPTHOOK
    except Exception: pass
    try:
        if getattr(_sys, "unraisablehook", None) is _bg_unraisablehook and _BG_PREV_UNRAISABLE is not None:
            _sys.unraisablehook = _BG_PREV_UNRAISABLE
    except Exception: pass
    _BG_INSTALLED = False


_BLOCK14_ON = True
_CB_FILE_NAME = "cb_verdict.json"
_CB_FAILS_MAX = 20
_CB_DEDUP_MS = 4000
_CB_SEEN = {}; _CB_SEEN_LOCK = threading.Lock()
_B14_FLAG = "__culprit_cbwrap__"
_B14_PATCHED = []
_B14_WRAPPED_CLASSES = []
_B14_WRAP_LOCK = threading.Lock()
_B14_TIMERS = []
_B14_NCD = None
_B14_PROXY_BASE = None
_B14_NCD_RAW = None
_B14_CU_FUNCS = ("run_on_queue", "send_request", "run_on_ui_thread", "RunnableFactory", "OnCopy")
_B14_CB_ARGPOS = {"client_utils.send_request": 1}
_B14_KWARG_ONLY = "__kwarg_only__"
_B14_CB_PARAM_NAMES = ("callback","cb","on_click","onclick","action","handler","listener","on_complete","on_error","on_success","on_dismiss","on_done","delegate","run","runnable","fn","func","whenDone","on_select")
_B14_AU_FACTORIES = ("R", "OnClickListener", "OnLongClickListener", "run_on_ui_thread", "RunnableFactory", "OnCopy")
_B14_IFACE_OWNER = {}
_B14_SDK_MODS = ("client_utils", "android_utils", "base_plugin", "extera_utils", "extera_utils.classes", "ui.alert", "ui.bulletin")
_B14_REC_TL = threading.local()
_BLOCK15_ON = True
_B15_RD_IFACE = None
_B15_DYNPROXY = None
_B15_PROXY_CLS = None
_B15_RDT_IFACE = None
_B15_RDT_PROXY_CLS = None

def _cb_verdict_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _CB_FILE_NAME).getAbsolutePath()
    except Exception:
        return None

def _cb_verdict_log(rec, when):
    try:
        _log("============= CALLBACK VERDICT (%s) =============" % when)
        cul = rec.get("culprit"); conf = rec.get("confidence")
        if cul and cul != "unknown":
            _log("ВИНОВНИК КОЛБЭКА: %r conf=%s where=%s src=%s" % (cul, conf, rec.get("where"), rec.get("src")))
        else:
            _log("ВИНОВНИК КОЛБЭКА: неизвестен (where=%s)" % rec.get("where"))
        _log("  причина: %s" % rec.get("reason"))
        pf = rec.get("py_file")
        if pf: _log("  modul: %s:%s" % (pf, rec.get("py_line")))
        sp = rec.get("scoped_pid")
        if sp and sp != cul: _log("  scope-plugin(tid): %s" % sp)
        _log("  iskljuchenie: %s: %s" % (rec.get("exc_cls"), rec.get("exc_msg")))
        _log("=================================================")
    except Exception: pass

def _persist_cb_fail(rec):
    p = _cb_verdict_path()
    if not p:
        _log("Block#15 cbpersist: нет пути -- пропуск"); return
    _PERSIST_IO_LOCK.acquire()
    try:
        cur = []
        if os.path.exists(p):
            try:
                with open(p, "r", encoding="utf-8") as f: cur = list(json.load(f))
            except Exception: cur = []
        cur.append(rec)
        if len(cur) > _CB_FAILS_MAX: cur = cur[-_CB_FAILS_MAX:]
        _atomic_json_write(p, cur)
        _log("Block#15 cbpersist: zapisano %d zapisej -> %s" % (len(cur), _CB_FILE_NAME))
    except Exception as e:
        _log("Block#15 cbpersist err: %s: %s" % (type(e).__name__, e))
    finally:
        try: _PERSIST_IO_LOCK.release()
        except Exception: pass

def _read_and_clear_cb_fails():
    p = _cb_verdict_path()
    if not p: return []
    out = []
    _rp = _rc_take_path(p)
    try:
        if _rp:
            with open(_rp, "r", encoding="utf-8") as f: out = list(json.load(f))
    except Exception: out = []
    if _rp:
        try: os.remove(_rp)
        except Exception: pass
    return out

def _b14_record(owner, exc, surface, meth=None):
    if not _BLOCK14_ON: return
    try: _B14_REC_TL.last_exc = id(exc)
    except Exception: pass
    try: exc_cls = type(exc).__name__
    except Exception: exc_cls = "?"
    try: exc_msg = str(exc)
    except Exception: exc_msg = None
    reason = ("%s: %s" % (exc_cls, exc_msg)) if exc_msg else exc_cls
    try: _B14_REC_TL.last_exc_str = reason
    except Exception: pass
    where = ("%s.%s" % (surface, meth)) if meth else surface
    py_mod, py_file, py_line = _b10_pyframe_culprit(exc, owner)
    if py_mod:
        culprit = py_mod; src = "py-frame/" + where; conf = "high"
    elif owner:
        culprit = owner; src = "scope/" + where; conf = "medium"
    else:
        culprit = "unknown"; src = "none"; conf = "low"
    rec = {"had_cb_fail": True, "event_type": "callback_exception", "dropbox_tag": "data_app_crash", "tombstone_norm_version": 1, "culprit": culprit, "src": src, "confidence": conf,
           "surface": surface, "method": meth, "where": where, "scoped_pid": owner,
           "py_module": py_mod, "py_file": py_file, "py_line": py_line, "reason": reason,
           "exc_cls": exc_cls, "exc_msg": exc_msg, "ts": int(time.time() * 1000)}
    key = "%s|%s|%s" % (culprit, reason, where); now = rec["ts"]
    try:
        with _CB_SEEN_LOCK:
            if now - _CB_SEEN.get(key, 0) < _CB_DEDUP_MS: return
            _CB_SEEN[key] = now
    except Exception: pass
    try: _b16_push_verdict("cb", rec)
    except Exception: pass
    try: _cb_verdict_log(rec, "live")
    except Exception: pass
    try: _persist_cb_fail(rec)
    except Exception: pass

def _b14_caller_owner(max_up=14):
    try: f = _sys._getframe(2)
    except Exception: return None
    n = 0
    while f is not None and n < max_up:
        try:
            g = f.f_globals; mod = g.get("__name__") or ""
        except Exception: mod = ""
        if mod and mod not in _B14_SDK_MODS and mod != _SELF_ID and mod != __id__:
            try: ow = _b10_owner_from_module(mod)
            except Exception: ow = None
            if ow: return ow
        try: f = f.f_back
        except Exception: f = None
        n += 1
    return None

def _b14_wrap_cb(owner, fn, surface, meth=None):
    if fn is None or not callable(fn) or getattr(fn, _B14_FLAG, False):
        return fn
    def _w(*a, **kw):
        pushed = False
        if owner is not None:
            try: pushed = _scoped_set(owner)
            except Exception: pushed = False
        try:
            return fn(*a, **kw)
        except BaseException as e:
            try: _b19_exc_ring_put(e)
            except Exception: pass
            if owner is not None:
                try: _b14_record(owner, e, surface, meth)
                except Exception: pass
            raise
        finally:
            if pushed:
                try: _scoped_clear()
                except Exception: pass
    try: _functools.update_wrapper(_w, fn)
    except Exception: pass
    try: setattr(_w, _B14_FLAG, True)
    except Exception: pass
    return _w

def _b14_make_func_patch(orig, surface):
    argpos = _B14_CB_ARGPOS.get(surface)
    @_functools.wraps(orig)
    def _patched(*a, **kw):
        owner = None
        try: owner = _b14_caller_owner()
        except Exception: owner = None
        if owner is not None:
            try:
                a = list(a)
                if argpos is _B14_KWARG_ONLY:
                    pass
                elif argpos is not None:
                    if argpos < len(a) and callable(a[argpos]) and not isinstance(a[argpos], type):
                        a[argpos] = _b14_wrap_cb(owner, a[argpos], surface)
                else:
                    for i in range(len(a)):
                        if callable(a[i]) and not isinstance(a[i], type):
                            a[i] = _b14_wrap_cb(owner, a[i], surface)
                            break
                for k in list(kw.keys()):
                    v = kw.get(k)
                    if callable(v) and not isinstance(v, type) and k in ("callback","fn","func","on_complete","on_error","runnable","r","delegate","listener","action","on_click","handler"):
                        kw[k] = _b14_wrap_cb(owner, v, surface, k)
            except Exception: pass
        result = orig(*a, **kw)
        if owner is not None:
            try:
                fn_name = surface.rsplit(".", 1)[-1]
                if fn_name in ("RunnableFactory", "OnCopy", "R",
                               "OnClickListener", "OnLongClickListener"):
                    _ts = int(time.time() * 1000)
                    _B14_IFACE_OWNER[fn_name] = (owner, _ts)
                    try:
                        if result is not None:
                            _rcn = type(result).__name__
                            if _rcn and _rcn != fn_name:
                                _B14_IFACE_OWNER[_rcn] = (owner, _ts)
                                for _rv in (_rcn.lstrip("_"), _rcn.rsplit("$", 1)[-1]):
                                    if _rv and _rv != _rcn:
                                        _B14_IFACE_OWNER[_rv] = (owner, _ts)
                    except Exception: pass
            except Exception: pass
        return result
    try: setattr(_patched, _B14_FLAG, True)
    except Exception: pass
    return _patched

def _b14_import(name):
    try:
        m = _sys.modules.get(name)
        if m is not None: return m
    except Exception: pass
    try:
        import importlib
        return importlib.import_module(name)
    except Exception:
        return None

def _b14_patch_module(mod, mod_name, names):
    n = 0
    for nm in names:
        try: orig = getattr(mod, nm, None)
        except Exception: orig = None
        if orig is None or not callable(orig) or getattr(orig, _B14_FLAG, False):
            continue
        surface = "%s.%s" % (mod_name, nm)
        try:
            patched = _b14_make_func_patch(orig, surface)
            setattr(mod, nm, patched)
            with _B14_WRAP_LOCK:
                _B14_PATCHED.append((mod, nm, orig, patched))
            n += 1
        except Exception as e:
            _log("Block#14: patch %s err: %s" % (surface, e))
    if n: _log("Block#14: %s obernuto funkcij=%d" % (mod_name, n))
    return n

def _b14_wrap_method(cls, meth_name, surface):
    try: raw = cls.__dict__.get(meth_name)
    except Exception: raw = None
    if raw is None or isinstance(raw, (staticmethod, classmethod, property)):
        return 0
    fn = raw
    if not callable(fn) or getattr(fn, _B14_FLAG, False):
        return 0
    def _make(orig_fn, surf, mname):
        def _w(self, *a, **kw):
            ow = None
            try: ow = _b10_owner_from_module(getattr(type(self), "__module__", None))
            except Exception: ow = None
            pushed = False
            if ow is not None:
                try: pushed = _scoped_set(ow)
                except Exception: pushed = False
            try:
                return orig_fn(self, *a, **kw)
            except BaseException as e:
                if ow is not None:
                    try: _b14_record(ow, e, surf, mname)
                    except Exception: pass
                raise
            finally:
                if pushed:
                    try: _scoped_clear()
                    except Exception: pass
        try: _functools.update_wrapper(_w, orig_fn)
        except Exception: pass
        try: setattr(_w, _B14_FLAG, True)
        except Exception: pass
        return _w
    try:
        _w = _make(fn, surface, meth_name)
        setattr(cls, meth_name, _w)
        with _B14_WRAP_LOCK:
            _prune_dead_wrefs(_B14_WRAPPED_CLASSES)
            _B14_WRAPPED_CLASSES.append((_wref_make(cls), meth_name, fn, _w))
        return 1
    except Exception:
        return 0

def _b14_register_cb_methods(holder, mod_name):
    import inspect as _inspect
    names = []
    for nm in dir(holder):
        if nm.startswith("_"): continue
        try: fn = getattr(holder, nm, None)
        except Exception: fn = None
        if fn is None or not callable(fn) or isinstance(fn, type): continue
        pos = None; has_cb_kw = False
        try:
            params = list(_inspect.signature(fn).parameters.values())
        except Exception:
            continue
        idx = 0
        for p in params:
            if p.kind in (p.VAR_POSITIONAL, p.VAR_KEYWORD): continue
            if p.name in _B14_CB_PARAM_NAMES:
                has_cb_kw = True
                if p.kind in (p.POSITIONAL_ONLY, p.POSITIONAL_OR_KEYWORD): pos = idx
                break
            if p.kind in (p.POSITIONAL_ONLY, p.POSITIONAL_OR_KEYWORD): idx += 1
        if pos is None and not has_cb_kw: continue
        surface = "%s.%s" % (mod_name, nm)
        _B14_CB_ARGPOS[surface] = pos if pos is not None else _B14_KWARG_ONLY
        names.append(nm)
    if names:
        _b14_patch_module(holder, mod_name, names)
        _log("Block#14: %s cb-metodov zaregano=%d (argpos-pinned)" % (mod_name, len(names)))
    return len(names)

def _b14_sweep(reason="sweep"):
    if not _BLOCK14_ON: return 0
    ncd = _B14_NCD; pbase = _B14_PROXY_BASE; ncd_raw = _B14_NCD_RAW
    if ncd is None and pbase is None and ncd_raw is None: return 0
    ncd_n = 0; proxy_n = 0; total = 0; seen = set()
    try: mods = list(_sys.modules.items())
    except Exception: mods = []
    for mname, mod in mods:
        if mod is None: continue
        try: pid = getattr(mod, "__id__", None)
        except Exception: pid = None
        if not (isinstance(pid, str) and pid): continue
        if pid == _SELF_ID or pid == __id__: continue
        names = {mname}
        try:
            nm = getattr(mod, "__name__", None)
            if nm: names.add(nm)
        except Exception: pass
        try: members = list(vars(mod).values())
        except Exception: members = []
        for obj in members:
            if not isinstance(obj, type): continue
            try:
                if getattr(obj, "__module__", None) not in names: continue
            except Exception: continue
            try: k = id(obj)
            except Exception: k = None
            if k in seen: continue
            seen.add(k)
            is_ncd = False
            if ncd is not None:
                try: is_ncd = issubclass(obj, ncd) and obj is not ncd
                except Exception: is_ncd = False
            if (not is_ncd) and (ncd_raw is not None):
                try: is_ncd = issubclass(obj, ncd_raw) and obj is not ncd_raw
                except Exception: is_ncd = False
            has_drn = False
            try: has_drn = callable(obj.__dict__.get("didReceivedNotification"))
            except Exception: has_drn = False
            if has_drn or is_ncd:
                if has_drn:
                    c = _b14_wrap_method(obj, "didReceivedNotification", "notification")
                    if c: ncd_n += c; total += c
            if pbase is not None:
                try: is_proxy = issubclass(obj, pbase) and obj is not pbase
                except Exception: is_proxy = False
                if is_proxy:
                    try: meth_names = [m for m, v in list(obj.__dict__.items())
                                       if (not m.startswith("_")) and callable(v) and m != "didReceivedNotification"
                                       and not isinstance(v, (staticmethod, classmethod, property))
                                       and not getattr(v, _B14_FLAG, False)]
                    except Exception: meth_names = []
                    for m in meth_names:
                        c = _b14_wrap_method(obj, m, "proxy")
                        if c: proxy_n += c; total += c
    if total:
        _log("Block#14 %s: notification-metodov=%d proxy-metodov=%d" % (reason, ncd_n, proxy_n))
    return total

def _rebind_imported_sdk_funcs(tag="boot"):
    try:
        with _B14_WRAP_LOCK:
            patched = list(_B14_PATCHED)
    except Exception:
        patched = []
    if not patched:
        return 0
    pairs = []
    for tup in patched:
        try:
            mod, nm, orig = tup[0], tup[1], tup[2]
            wrapped = getattr(mod, nm, None)
            if wrapped is not None and wrapped is not orig and getattr(wrapped, _B14_FLAG, False):
                pairs.append((nm, orig, wrapped))
        except Exception:
            pass
    if not pairs:
        return 0
    n = 0; mods_touched = 0
    try: mods = list(_sys.modules.items())
    except Exception: mods = []
    for mod_name, mod in mods:
        try:
            pid = _pid_of_module_pkg(mod_name)
        except Exception:
            pid = None
        if not (isinstance(pid, str) and pid and pid != _SELF_ID and pid != __id__):
            continue
        touched = False
        for (nm, orig, wrapped) in pairs:
            try:
                cur = getattr(mod, nm, None)
                if cur is orig:
                    setattr(mod, nm, wrapped); n += 1; touched = True
            except Exception:
                pass
        if touched: mods_touched += 1
    if n:
        _log("Block#14 +BI bound-import rebind (%s): перепривязано имён=%d в плагин-модулях=%d (захваченные 'from client_utils import ...' до патча)" % (tag, n, mods_touched))
    return n

def _b14_install():
    global _B14_NCD, _B14_PROXY_BASE, _B14_NCD_RAW
    if not _BLOCK14_ON:
        _log("Block#14: отключён (_BLOCK14_ON=False)"); return
    cu = _b14_import("client_utils")
    if cu is not None:
        try: _b14_patch_module(cu, "client_utils", _B14_CU_FUNCS)
        except Exception as e: _log("Block#14 client_utils patch err: %s" % e)
        try: _B14_NCD = getattr(cu, "NotificationCenterDelegate", None)
        except Exception: _B14_NCD = None
    else:
        _log("Block#14: client_utils не импортирован")
    au = _b14_import("android_utils")
    if au is not None:
        try: _b14_patch_module(au, "android_utils", _B14_AU_FACTORIES)
        except Exception as e: _log("Block#14 android_utils patch err: %s" % e)
        
    ua = _b14_import("ui.alert")
    if ua is not None:
        try:
            adb = getattr(ua, "AlertDialogBuilder", None)
            if adb is not None:
                _b14_patch_module(adb, "ui.alert.AlertDialogBuilder", 
                                  ("set_positive_button", "set_negative_button", "set_neutral_button", "set_items"))
        except Exception as e: _log("Block#14 ui.alert patch err: %s" % e)

    ub = _b14_import("ui.bulletin")
    if ub is not None:
        try:
            bh = getattr(ub, "BulletinHelper", None)
            if bh is not None:
                _b14_register_cb_methods(bh, "ui.bulletin.BulletinHelper")
        except Exception as e: _log("Block#14 ui.bulletin patch err: %s" % e)

    ec = _b14_import("extera_utils.classes")
    if ec is None: ec = _b14_import("extera_utils")
    if ec is not None:
        try: _B14_PROXY_BASE = getattr(ec, "Base", None)
        except Exception: _B14_PROXY_BASE = None
    try:
        _B14_NCD_RAW = jclass("org.telegram.messenger.NotificationCenter$NotificationCenterDelegate")
        _log("Block#14: raw NCD iface resolved: %r" % (_B14_NCD_RAW,))
    except Exception as e:
        _B14_NCD_RAW = None
        _log("Block#14: raw NCD iface unavailable: %s: %s" % (type(e).__name__, e))
    try: _b14_sweep("boot-sweep")
    except Exception as e: _log("Block#14 sweep err: %s" % e)
    try: _rebind_imported_sdk_funcs("boot-sweep")
    except Exception as e: _log("Block#14 bound-rebind err: %s" % e)
    for _delay in (3.0, 8.0):
        try:
            t = threading.Timer(_delay, lambda d=_delay: (_b14_sweep("re-sweep@%.0fs" % d), _rebind_imported_sdk_funcs("re-sweep@%.0fs" % d)))
            t.daemon = True; t.start()
            _B14_TIMERS.append(t)
        except Exception as e:
            _log("Block#14 re-sweep schedule err: %s" % e)
    _log("Block#14: установлен (queue/request/ui-thread/listeners/notification/proxy) -> %s" % _CB_FILE_NAME)

def _b14_unpatch():
    for _t in _B14_TIMERS:
        try: _t.cancel()
        except Exception: pass
    _B14_TIMERS.clear()
    with _B14_WRAP_LOCK:
        funcs = list(_B14_PATCHED); _B14_PATCHED.clear()
        classes = list(_B14_WRAPPED_CLASSES); _B14_WRAPPED_CLASSES.clear()
    for tup in funcs:
        try:
            mod, nm, orig = tup[0], tup[1], tup[2]
            our_w = tup[3] if len(tup) > 3 else None
            cur = getattr(mod, nm, None)
            if cur is not None and (cur is our_w if our_w is not None else getattr(cur, _B14_FLAG, False)):
                setattr(mod, nm, orig)
        except Exception: pass
    for tup in classes:
        try:
            cls = _wref_get(tup[0])
            if cls is None: continue
            nm, orig_fn = tup[1], tup[2]
            our_w = tup[3] if len(tup) > 3 else None
            cur = cls.__dict__.get(nm)
            if cur is not None and (cur is our_w if our_w is not None else getattr(cur, _B14_FLAG, False)):
                setattr(cls, nm, orig_fn)
        except Exception: pass
    try: _mods = list(_sys.modules.items())
    except Exception: _mods = []
    for _mn, _mod in _mods:
        if _mod is None: continue
        for _tup in funcs:
            try:
                _nm = _tup[1]; _orig = _tup[2]
                _ourw = _tup[3] if len(_tup) > 3 else None
                _cur = getattr(_mod, _nm, None)
                if _cur is not None and (_cur is _ourw if _ourw is not None else getattr(_cur, _B14_FLAG, False)):
                    setattr(_mod, _nm, _orig)
            except Exception: pass


_HX_SELF_CRASH_NAME = "self_crash_verdict.json"
_HX_SELF_CRASH_SEEN = {}
def _hx_is_self_proxy_marshal(e):
    try:
        s = ""
        try: s = str(e)
        except Exception: s = ""
        if not s: return False
        return ("RequestDelegate" in s and ".run" in s
                and "argument" in s and ("java.lang.Object" in s or "IllegalArgument" in s))
    except Exception:
        return False

def _hx_self_crash_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _HX_SELF_CRASH_NAME).getAbsolutePath()
    except Exception:
        return None

def _hx_self_crash_emit(owner, e):
    try:
        now = int(time.time() * 1000)
    except Exception:
        now = 0
    try:
        s = ""
        try: s = str(e)
        except Exception: s = ""
        iface = "RequestDelegateTimestamp" if "RequestDelegateTimestamp" in s else "RequestDelegate"
        ecls = type(e).__name__ if e is not None else None
        key = "%s|%s" % (iface, ecls)
        if now - _HX_SELF_CRASH_SEEN.get(key, 0) < 120000: return
        _HX_SELF_CRASH_SEEN[key] = now
        rec = {"had_self_crash": True, "event_type": "self_proxy_crash",
               "culprit": "culprit_detector (self)", "culprit_kind": "self",
               "src": "block15/%s" % iface, "where": "proxy.run-forward",
               "confidence": "high", "scope_owner": owner, "exc_cls": ecls,
               "reason": ("detector %s proxy failed to marshal a forwarded call (arg typed "
                          "java.lang.Object); re-raising would crash the host network thread "
                          "(FATAL: stageQueue) -- swallowed to keep host alive; FIX proxy signature") % iface,
               "detail": s[:300], "arg2_type": ("java.lang.Object" if "java.lang.Object" in s else None),
               "recovered": False, "host_saved": True, "ts": now}
        p = _hx_self_crash_path()
        if not p: return
        _PERSIST_IO_LOCK.acquire()
        try:
            cur = []
            if os.path.exists(p):
                try:
                    with open(p, "r", encoding="utf-8") as f: cur = list(json.load(f))
                except Exception: cur = []
            cur.append(rec)
            _atomic_json_write(p, cur, 20)
            _log("+HY SELF-CRASH: %s proxy marshal fail swallowed (host kept alive) -> %s" % (iface, _HX_SELF_CRASH_NAME))
        except Exception:
            pass
        finally:
            try: _PERSIST_IO_LOCK.release()
            except Exception: pass
    except Exception:
        pass

_IA_CAST = None
_IA_TLOBJECT_CLS = None
_IA_TLERROR_CLS = None
_IA_ENV_TRIED = False
_IA_RECOVERED_N = 0
def _ia_cast_env():
    global _IA_CAST, _IA_TLOBJECT_CLS, _IA_TLERROR_CLS, _IA_ENV_TRIED
    if _IA_ENV_TRIED:
        return (_IA_CAST, _IA_TLOBJECT_CLS, _IA_TLERROR_CLS)
    _IA_ENV_TRIED = True
    try:
        from java import cast as _c
        _IA_CAST = _c
    except Exception:
        _IA_CAST = None
    try:
        _IA_TLOBJECT_CLS = jclass("org.telegram.tgnet.TLObject")
    except Exception:
        _IA_TLOBJECT_CLS = None
    try:
        _IA_TLERROR_CLS = jclass("org.telegram.tgnet.TLRPC$TL_error")
    except Exception:
        _IA_TLERROR_CLS = None
    return (_IA_CAST, _IA_TLOBJECT_CLS, _IA_TLERROR_CLS)
def _ia_is_real_marshal(e):
    try:
        s = str(e) or ""
    except Exception:
        return False
    if "has type" not in s or "expected" not in s:
        return False
    try:
        got = s.split("has type", 1)[1].split(",", 1)[0]
        exp = s.split("expected", 1)[1]
    except Exception:
        return False
    if "java.lang.Object" not in got:
        return False
    if "java.lang.Object" in exp:
        return False
    return ("tgnet" in exp) or ("TLRPC" in exp) or ("TL_error" in exp)
def _ia_typed_forward(orig, args):
    global _IA_RECOVERED_N
    c, tlobj, tlerr = _ia_cast_env()
    if c is None or tlerr is None or orig is None:
        return (False, None)
    try:
        a = list(args)
        if len(a) >= 1 and a[0] is not None and tlobj is not None:
            try: a[0] = c(tlobj, a[0])
            except Exception: pass
        if len(a) >= 2 and a[1] is not None:
            try: a[1] = c(tlerr, a[1])
            except Exception: pass
        res = orig.run(*a)
        _IA_RECOVERED_N += 1
        try: _log("+IA typed-cast recovered: re-forwarded RequestDelegate.run after arg2 marshal fail (host+callback saved) n=%d" % _IA_RECOVERED_N)
        except Exception: pass
        return (True, res)
    except BaseException:
        return (False, None)
def _b15_precast(response, error):
    c, tlobj, tlerr = _ia_cast_env()
    r = response; e = error
    if c is not None:
        if r is not None and tlobj is not None:
            try: r = c(tlobj, r)
            except Exception: r = response
        if e is not None and tlerr is not None:
            try: e = c(tlerr, e)
            except Exception: e = error
    return (r, e)

def _b15_build_proxy_class():
    RD = _B15_RD_IFACE; DP = _B15_DYNPROXY
    if RD is None or DP is None: return None
    try:
        class _CulpritReqDelegate(DP(RD)):
            def __init__(self, orig, owner):
                super().__init__()
                self._orig = orig; self._owner = owner
            def run(self, response, error):
                pushed = False; owner = self._owner
                if owner is not None:
                    try: pushed = _scoped_set(owner)
                    except Exception: pushed = False
                try:
                    _pr, _pe = _b15_precast(response, error)
                    return self._orig.run(_pr, _pe)
                except BaseException as e:
                    _is_self_marshal = _hx_is_self_proxy_marshal(e)
                    if _BLOCK15_ON:
                        already = False
                        try:
                            already = (getattr(_B14_REC_TL, "last_exc", None) == id(e))
                            _B14_REC_TL.last_exc = None
                            last_err = getattr(_B14_REC_TL, "last_exc_str", None)
                            _B14_REC_TL.last_exc_str = None
                            if not already and last_err and last_err in str(e):
                                already = True
                        except Exception: already = False
                        if not already and not _is_self_marshal:
                            try: _b14_record(owner, e, "connections_manager.sendRequest")
                            except Exception: pass
                    if _is_self_marshal:
                        if _ia_is_real_marshal(e):
                            _ia_ok, _ia_res = _ia_typed_forward(self._orig, (response, error))
                            if _ia_ok:
                                return _ia_res
                        try: _hx_self_crash_emit(owner, e)
                        except Exception: pass
                        return None
                    raise
                finally:
                    if pushed:
                        try: _scoped_clear()
                        except Exception: pass
        return _CulpritReqDelegate
    except Exception as e:
        _log("Block#15: proxy class build err: %s: %s" % (type(e).__name__, e)); return None

def _b15_build_proxy_class_ts():
    RDT = _B15_RDT_IFACE; DP = _B15_DYNPROXY
    if RDT is None or DP is None: return None
    try:
        class _CulpritReqDelegateTS(DP(RDT)):
            def __init__(self, orig, owner):
                super().__init__()
