            PC.setPluginEnabled(str(_SELF_ID), True)
            return True
        except Exception:
            pass
    except Exception:
        pass
    return False

def _b31_write_file(path, data):
    if not path: return False
    try:
        tmp = path + ".tmp"
        with open(tmp, "wb") as f:
            f.write(data); f.flush()
            try: os.fsync(f.fileno())
            except Exception: pass
        try:
            os.replace(tmp, path)
        except Exception:
            with open(path, "wb") as f2:
                f2.write(data); f2.flush()
                try: os.fsync(f2.fileno())
                except Exception: pass
            try: os.remove(tmp)
            except Exception: pass
        return True
    except Exception as e:
        _log("Block#31 write err: %s" % e)
        return False

_b31_last_src_sig = None

def _b31_backup_self():
    global _b31_last_src_sig
    try:
        sp = _self_plugin_path(); bp = _self_backup_path()
        if not sp or not bp: return False
        if not File(sp).exists(): return False
        try:
            st = os.stat(sp)
            sig = (getattr(st, "st_mtime_ns", int(st.st_mtime * 1000000000)), st.st_size)
        except Exception:
            sig = None
        if sig is not None and sig == _b31_last_src_sig:
            try:
                if File(bp).exists() and os.path.getsize(bp) > 0:
                    return True
            except Exception:
                pass
        with open(sp, "rb") as f: data = f.read()
        if not data: return False
        ok = _b31_write_file(bp, data)
        if ok and sig is not None:
            _b31_last_src_sig = sig
        return ok
    except Exception as e:
        _log("Block#31 backup err: %s" % e)
        return False

def _b31_resurrect():
    try:
        sp = _self_plugin_path(); bp = _self_backup_path()
        if not sp or not bp: return False
        if File(sp).exists(): return False
        if not File(bp).exists(): return False
        with open(bp, "rb") as f: data = f.read()
        if not data: return False
        if not _b31_write_file(sp, data): return False
        _log("Block#31: detector .py восстановлен из бэкапа -> %s" % sp)
        try: _b31_enable_pref()
        except Exception: pass
        try:
            vp = _fg_verdict_path()
            if vp:
                verdict = {"kind": "detector_resurrected", "from": bp, "to": sp,
                           "culprit": _UNTAGGED_LABEL,
                           "reason": "Детектор был удалён и автоматически восстановил себя из резервной копии (.bak.py)",
                           "confidence": "high", "detector": "Block#31 self-resurrect",
                           "version": __version__, "ts": int(time.time() * 1000), "tag": "boot"}
                _atomic_json_write(vp, verdict)
        except Exception: pass
        return True
    except Exception as e:
        _log("Block#31 resurrect err: %s" % e)
        return False

_B31_WD_THREAD = None
_B31_WD_STOP_EVT = threading.Event()
_B31_WD_STOPPED = False
_B31_WD_LOCK = threading.Lock()
_B31_WD_INTERVAL = 1.0
_B31_WD_GRACE = 2.5
_b31_missing_since = None

def _b31_reset_native_sentinel():
    try:
        if _NLIB is not None and hasattr(_NLIB, "cd_fg_reset_sentinel"):
            _NLIB.cd_fg_reset_sentinel()
    except Exception:
        pass

def _b31_clear_sentinel(reason):
    try:
        p = _fg_sentinel_path()
        _mp = _aw_mirror_path(p) if p else None
        if p and (File(p).exists() or (_mp and File(_mp).exists())):
            _rc_remove_both(p)
            _log("Block#31: stale fileguard sentinel discarded (%s)" % reason)
    except Exception:
        pass
    _b31_reset_native_sentinel()

def _b31_native_read():
    if not (_WD_NATIVE_OK and _NLIB is not None):
        return None
    try:
        buf = (ctypes.c_int64 * 8)()
        got = int(_NLIB.cd_wd_read(buf, 8))
        if got < 8:
            return None
        return {"src_present": bool(buf[0]), "src_mtime_ns": int(buf[1]),
                "src_size": int(buf[2]), "bak_present": bool(buf[3]),
                "bak_size": int(buf[4]), "sentinel_present": bool(buf[5]),
                "missing_ms": int(buf[6]), "ts_ms": int(buf[7])}
    except Exception:
        return None

def _b31_native_wd_start():
    if not (_WD_NATIVE_OK and _NATIVE_OK and _NLIB is not None):
        return False
    try:
        if int(_NLIB.cd_wd_running()):
            return True
    except Exception:
        pass
    sp = _self_plugin_path(); bp = _self_backup_path(); se = _aw_mirror_path(_fg_sentinel_path()) or _fg_sentinel_path()
    try:
        rc = int(_NLIB.cd_wd_start((sp or "").encode("utf-8"),
                                   (bp or "").encode("utf-8"),
                                   (se or "").encode("utf-8"),
                                   int(_B31_WD_INTERVAL * 1000)))
        if rc >= 0:
            _log("Block#31: нативный off-GIL watchdog запущен (+DS, period=%dms)" % int(_B31_WD_INTERVAL * 1000))
            return True
    except Exception as e:
        _log("Block#31 native wd start err: %s" % e)
    return False

_B31_INSTALL_TEMP_SUFFIXES = (".tmp", ".part", ".partial", ".download", ".dl", ".new", ".writing", ".crdownload", "~")
_B31_INSTALL_FRESH_S = 12.0

def _b31_fresh(p):
    try:
        return (time.time() - os.path.getmtime(p)) <= _B31_INSTALL_FRESH_S
    except Exception:
        return False

def _b31_install_in_progress():
    try:
        sp = _self_plugin_path()
        if not sp: return False
        d = os.path.dirname(sp) or _DIR
        base = os.path.basename(sp)
        for suf in _B31_INSTALL_TEMP_SUFFIXES:
            try:
                cand = os.path.join(d, base + suf)
                if os.path.exists(cand) and _b31_fresh(cand):
                    return True
            except Exception: pass
        try:
            for nm in os.listdir(d):
                if nm.lower().endswith(_B31_INSTALL_TEMP_SUFFIXES) and _b31_fresh(os.path.join(d, nm)):
                    return True
        except Exception: pass
    except Exception: pass
    return False

def _b31_watchdog_tick():
    global _b31_missing_since
    _gil_begin(_GIL_B31)
    try:
        snap = _b31_native_read()
        if snap is not None:
            if snap["src_present"]:
                if _b31_missing_since is not None:
                    _b31_missing_since = None
                if snap["sentinel_present"]:
                    try: _b31_read_sentinel("watchdog-blocked")
                    except Exception: pass
                    _b31_clear_sentinel("file present")
                if (snap["src_mtime_ns"], snap["src_size"]) != _b31_last_src_sig:
                    try: _b31_backup_self()
                    except Exception: pass
            else:
                if (snap["missing_ms"] / 1000.0) >= _B31_WD_GRACE:
                    if _b31_install_in_progress():
                        try: _log("Block#31: .py нет, но рядом свежий temp установки -- восстановление отложено")
                        except Exception: pass
                    else:
                        if _b31_resurrect():
                            try: _b31_read_sentinel("watchdog")
                            except Exception: pass
                            _b31_reset_native_sentinel()
                        _b31_missing_since = None
        else:
            pass
    except Exception as e:
        _log("Block#31 watchdog tick err: %s" % e)
    finally:
        _gil_end(_GIL_B31)

def _b31_watchdog_loop():
    while not _B31_WD_STOP_EVT.is_set():
        if _B31_WD_STOP_EVT.wait(_B31_WD_INTERVAL): break
        if not _BLOCK31_ON or globals().get("_B31_WD_STOPPED", False): break
        try: _b31_watchdog_tick()
        except Exception as e:
            try: _log("Block#31 watchdog loop err: %s" % e)
            except Exception: pass

def _b31_watchdog_arm():
    global _B31_WD_THREAD
    if not _BLOCK31_ON or globals().get("_B31_WD_STOPPED", False): return
    try:
        with _B31_WD_LOCK:
            t = _B31_WD_THREAD
            if t is not None and t.is_alive():
                return
            _B31_WD_STOP_EVT.clear()
            _B31_WD_THREAD = threading.Thread(target=_b31_watchdog_loop, name="cd-b31-wd", daemon=True)
            _B31_WD_THREAD.start()
    except Exception as e:
        _log("Block#31 watchdog arm err: %s" % e)

def _b31_watchdog_stop():
    global _B31_WD_THREAD, _b31_missing_since, _B31_WD_STOPPED
    try:
        if _WD_NATIVE_OK and _NLIB is not None and int(_NLIB.cd_wd_running()):
            _NLIB.cd_wd_stop()
    except Exception:
        pass
    _B31_WD_STOPPED = True
    _B31_WD_STOP_EVT.set()
    try:
        with _B31_WD_LOCK:
            t = _B31_WD_THREAD
            _B31_WD_THREAD = None
        if t is not None and t is not threading.current_thread():
            try: t.join(timeout=2.0)
            except Exception: pass
        _b31_missing_since = None
    except Exception:
        pass

def _b31_decl(lib):
    global _B31_OK
    c = ctypes
    needed = ("cd_fg_protect", "cd_fg_start", "cd_fg_running")
    if not all(hasattr(lib, n) for n in needed):
        _B31_OK = False
        _log("Block#31: cd_fg_* нет в .so (старый бинарь) -- file-guard отключён")
        return False
    lib.cd_fg_protect.argtypes = [c.c_char_p]; lib.cd_fg_protect.restype = c.c_int
    lib.cd_fg_start.argtypes = [c.c_char_p]; lib.cd_fg_start.restype = c.c_int
    if hasattr(lib, "cd_fg_stop"): lib.cd_fg_stop.restype = c.c_int
    lib.cd_fg_running.restype = c.c_int
    if hasattr(lib, "cd_fg_arm"):
        lib.cd_fg_arm.argtypes = [c.c_int]; lib.cd_fg_arm.restype = c.c_int
    if hasattr(lib, "cd_fg_is_armed"):
        lib.cd_fg_is_armed.restype = c.c_int
    if hasattr(lib, "cd_fg_count"):
        lib.cd_fg_count.restype = c.c_int
    for opt in ("cd_fg_seen", "cd_fg_blocked"):
        if hasattr(lib, opt): getattr(lib, opt).restype = c.c_int64
    if hasattr(lib, "cd_fg_reset_sentinel"):
        lib.cd_fg_reset_sentinel.restype = c.c_int
    _B31_OK = True
    return True

def _b31_init(lib):
    if not _BLOCK31_ON:
        _log("Block#31: отключён (_BLOCK31_ON=False)"); return
    try:
        _b31_decl(lib)
    except Exception as e:
        _log("Block#31 decl err: %s" % e)

def _b31_start():
    global _B31_STARTED, _B31_WD_STOPPED
    if not _BLOCK31_ON: return
    _B31_WD_STOPPED = False
    try: _b31_native_wd_start()
    except Exception: pass
    try: _b31_backup_self()
    except Exception: pass
    try: _b31_watchdog_arm()
    except Exception: pass
    if not (_B31_OK and _NATIVE_OK and _NLIB is not None):
        _log("Block#31: натив/символы недоступны -- только бэкап"); return
    if _B31_STARTED: return
    sp = _self_plugin_path()
    if not sp:
        _log("Block#31: put detektora ne razreshen -- propusk"); return
    try:
        rc = int(_NLIB.cd_fg_protect(sp.encode("utf-8")))
        if rc < 0: _log("Block#31: cd_fg_protect vernul %d" % rc)
    except Exception as e:
        _log("Block#31 cd_fg_protect err: %s" % e); return
    p = _fg_sentinel_path()
    _pw = _aw_mirror_path(p) or p
    try:
        rc2 = int(_NLIB.cd_fg_start((_pw or "").encode("utf-8")))
    except Exception as e:
        _log("Block#31 cd_fg_start err: %s" % e); return
    if rc2 < 0:
        _log("Block#31: cd_fg_start vernul %d -- libc rename/unlink ne zacepilis" % rc2); return
    _B31_STARTED = True
    _log("Block#31: file-guard установлен (libc rename/renameat/unlink/unlinkat), хуков=%d, защищён=%s" % (rc2, sp))
    try: _b31_read_sentinel("post-start")
    except Exception: pass

def _b31_stop():
    global _B31_STARTED
    try: _b31_watchdog_stop()
    except Exception: pass
    if not _B31_STARTED: return
    try:
        if _NLIB is not None: _NLIB.cd_fg_stop()
    except Exception: pass
    _B31_STARTED = False
    _log("Block#31: snjat (cd_fg_stop)")

def _b31_parse_sentinel(text):
    rec = {}
    try:
        for line in text.splitlines():
            line = line.strip()
            if not line or line in ("CULPRIT_FILEGUARD", "END"): continue
            for tok in line.split(" "):
                if "=" in tok:
                    k, v = tok.split("=", 1)
                    rec[k] = v
    except Exception:
        pass
    return rec

def _b31_read_sentinel(tag):
    if not _BLOCK31_ON: return None
    p = _fg_sentinel_path()
    if not p: return None
    _rp = _rc_take_path(p)
    if not _rp: return None
    try:
        with open(_rp, "r", encoding="utf-8", errors="replace") as f:
            text = f.read()
    except Exception:
        return None
    finally:
        try: os.remove(_rp)
        except Exception: pass
    rec = _b31_parse_sentinel(text)
    if not rec: return None
    owner_id = rec.get("owner_id") or ""
    if owner_id in ("(?)", ""): owner_id = ""
    try: idx = int(rec.get("owner_idx", "-1"))
    except Exception: idx = -1
    name = owner_id or _resolve_idx_durable(idx) or (("idx#%d" % idx) if idx >= 0 else "unknown")
    name = _deidx_name(name)
    api = rec.get("api", "?")
    path = rec.get("path", "?")
    try: ts = int(rec.get("ts", "0"))
    except Exception: ts = int(time.time() * 1000)
    low = name.lower()
    dropper = ("netprotector" in low) or ("netblocker" in low) or ("shikatu" in low)
    verdict = {"event_type": "file_delete_blocked", "dropbox_tag": "self_protection", "tombstone_norm_version": 1, "kind": "detector_erase_blocked", "culprit": name, "owner_idx": idx,
               "api": api, "path": path, "vector": "os.replace/os.remove on detector .py",
               "dropper_signature": dropper, "neutralized": True,
               "confidence": "high", "detector": "Block#31 native file-guard",
               "version": __version__, "ts": ts, "tag": tag}
    vp = _fg_verdict_path()
    if vp:
        try:
            if not _atomic_json_write(vp, verdict):
                _log("Block#31 verdict write returned False")
        except Exception as e:
            _log("Block#31 verdict write err: %s" % e)
    _log("=============== DETECTOR ERASE NEUTRALIZED (Block#31) ===============")
    _log("  culprit=%s api=%s path=%s" % (name, api, path))
    _log("  detector .py survived; verdict -> %s" % _FG_VERDICT_NAME)
    _log("====================================================================")
    try:
        _b16_push_verdict("detector_erase_blocked", {"culprit": name, "confidence": "high", "where": api, "ts": ts})
    except Exception:
        pass
    return verdict

