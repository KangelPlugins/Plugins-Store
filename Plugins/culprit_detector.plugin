    except Exception:
        pass
    lib.cd_live_count.restype = c.c_int64
    lib.cd_snapshot.argtypes = [c.POINTER(c.c_int64), c.c_int32]; lib.cd_snapshot.restype = c.c_int
    lib.cd_top1.argtypes = [c.POINTER(c.c_int64)]; lib.cd_top1.restype = c.c_int32
    try:
        lib.cd_thread_inherit_ok.restype = c.c_int
    except Exception:
        pass
    try:
        lib.cd_reg_publish_tid.argtypes = [c.c_int64, c.c_int32]; lib.cd_reg_publish_tid.restype = c.c_int
        lib.cd_reg_clear_tid.argtypes = [c.c_int64]; lib.cd_reg_clear_tid.restype = c.c_int
        lib.cd_reg_lookup_tid.argtypes = [c.c_int64]; lib.cd_reg_lookup_tid.restype = c.c_int32
        lib.cd_reg_selftest.restype = c.c_int
        lib.cd_reg_live.restype = c.c_int64
    except Exception:
        pass
    global _OP_NATIVE_OK
    try:
        if hasattr(lib, "cd_op_mark"):
            lib.cd_op_mark.argtypes = [c.c_int32, c.c_char_p, c.c_char_p]; lib.cd_op_mark.restype = c.c_int
            _OP_NATIVE_OK = True
        else:
            _OP_NATIVE_OK = False
    except Exception:
        _OP_NATIVE_OK = False
    global _OOM_NATIVE_OK
    try:
        if hasattr(lib, "cd_oom_start"):
            lib.cd_oom_start.argtypes = [c.c_char_p, c.c_int32, c.c_int32, c.c_int32, c.c_int32, c.c_int32]
            lib.cd_oom_start.restype = c.c_int
            lib.cd_oom_stop.restype = c.c_int
            lib.cd_oom_seq.restype = c.c_int64
            lib.cd_oom_running.restype = c.c_int
            lib.cd_oom_snap_size.restype = c.c_int32
            lib.cd_oom_topn_max.restype = c.c_int32
            _OOM_NATIVE_OK = True
        else:
            _OOM_NATIVE_OK = False
    except Exception:
        _OOM_NATIVE_OK = False
    global _ANR_NATIVE_OK
    try:
        if hasattr(lib, "cd_anr_start"):
            lib.cd_anr_start.argtypes = [c.c_int32, c.c_int32, c.c_int32]; lib.cd_anr_start.restype = c.c_int
            lib.cd_anr_stop.restype = c.c_int
            lib.cd_anr_running.restype = c.c_int
            lib.cd_anr_ping.restype = c.c_int
            lib.cd_anr_ack.restype = c.c_int
            lib.cd_anr_inflight.restype = c.c_int
            lib.cd_anr_stall_seq.restype = c.c_int64
            lib.cd_anr_stalled_ms.restype = c.c_int64
            if hasattr(lib, "cd_anr_owner"):
                lib.cd_anr_owner.restype = c.c_int32
            _ANR_NATIVE_OK = True
        else:
            _ANR_NATIVE_OK = False
    except Exception:
        _ANR_NATIVE_OK = False
    global _GREF_NATIVE_OK
    try:
        if hasattr(lib, "cd_gref_start"):
            lib.cd_gref_start.restype = c.c_int
            lib.cd_gref_stop.restype = c.c_int
            lib.cd_gref_running.restype = c.c_int
            lib.cd_gref_tags.restype = c.c_int32
            lib.cd_gref_total.restype = c.c_int64
            lib.cd_gref_untagged.restype = c.c_int64
            lib.cd_gref_count.argtypes = [c.c_int32]; lib.cd_gref_count.restype = c.c_int64
            lib.cd_gref_top1.argtypes = [c.POINTER(c.c_int64)]; lib.cd_gref_top1.restype = c.c_int32
            lib.cd_gref_snapshot.argtypes = [c.POINTER(c.c_int64), c.c_int32]; lib.cd_gref_snapshot.restype = c.c_int
            _GREF_NATIVE_OK = True
        else:
            _GREF_NATIVE_OK = False
    except Exception:
        _GREF_NATIVE_OK = False

def _b4c_decl(lib):
    c = ctypes
    lib.cd_lt_init.argtypes = [c.c_int32]; lib.cd_lt_init.restype = c.c_int
    lib.cd_register_loader.argtypes = [c.c_int64, c.c_int32]; lib.cd_register_loader.restype = c.c_int
    lib.cd_loader_pid.argtypes = [c.c_int64]; lib.cd_loader_pid.restype = c.c_int32
    lib.cd_lt_count.restype = c.c_int32
    lib.cd_lt_clear.restype = None
    lib.cd_set_active_plugin.argtypes = [c.c_int32]; lib.cd_set_active_plugin.restype = None
    lib.cd_clear_active_plugin.restype = None
    lib.cd_active_plugin.restype = c.c_int32
    try: lib.cd_reset_active_plugin.restype = None
    except Exception: pass
    lib.cd_install_crash_handler.argtypes = [c.c_char_p]; lib.cd_install_crash_handler.restype = c.c_int
    lib.cd_uninstall_crash_handler.restype = None
    lib.cd_uw_selftest.restype = c.c_int
    if hasattr(lib, "cd_set_host_lib_dir"):
        lib.cd_set_host_lib_dir.argtypes = [c.c_char_p]; lib.cd_set_host_lib_dir.restype = c.c_int

