_NLIB = None
_NATIVE_OK = False
_SO_NAME = "libculprit.so"
_SO_ABI_EXPECT = 13
_B4C_OK = False
_SCOPE_OK = False
_LT_SLOTS = 1024
_NATIVE_CRASH_NAME = "native_crash.txt"
_NATIVE_CRASH_VERDICT_NAME = "native_crash_verdict.json"
_NATIVE_CRASH_HISTORY_NAME = "native_crash_history.json"
_NATIVE_CRASH_HISTORY_MAX = 32
_CRASH_VERDICT_DURABLE_NAME = "crash_verdict_persisted.json"
_KG_SENTINEL_NAME = "killguard.txt"
_KG_VERDICT_NAME = "selfkill_blocked_verdict.json"
_KG_HISTORY_NAME = "selfkill_blocked_history.json"
_BLOCK30_ON = True
_B30_OK = False
_B30_STARTED = False
_FG_SENTINEL_NAME = "fileguard.txt"
_FG_VERDICT_NAME = "fileguard_blocked_verdict.json"
