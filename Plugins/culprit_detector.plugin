def _read_and_clear_bg_fails():
    p = _bg_verdict_path()
    if not p: return []
    out = []
    _rp = _rc_take_path(p)
    try:
        if _rp:
            with open(_rp, "r", encoding="utf-8") as f: out = list(json.load(f))
    except Exception: out = []
    if _rp:
        try: os.remove(_rp)
        except Exception: pass
    return out

def _bg_record(exc, where, thread_obj=None, thread_name=None):
    if not _BLOCK13_ON:
        return
    try: exc_cls = type(exc).__name__
    except Exception: exc_cls = "?"
    try: exc_msg = str(exc)
    except Exception: exc_msg = None
    reason = ("%s: %s" % (exc_cls, exc_msg)) if exc_msg else exc_cls
    py_mod = None; py_file = None; py_line = None
    try:
        py_mod, py_file, py_line = _b10_pyframe_culprit(exc, None)
    except Exception:
        py_mod = None
    scoped = None
    try:
        c = get_culprit_for_tid(_cur_tid())
        if c and c != "unknown" and c != _SELF_ID and c != __id__:
            scoped = c
    except Exception:
        scoped = None
    prov = None
    if py_mod is None and scoped is None:
        try:
            prov = _provenance_pid(thread_obj, 1)
            if prov in (_SELF_ID, __id__): prov = None
        except Exception:
            prov = None
    if py_mod:
        culprit = py_mod; src = "py-frame/" + where; conf = "high"
    elif scoped:
        culprit = scoped; src = "scope/" + where; conf = "medium"
    elif prov:
        culprit = prov; src = "provenance/" + where; conf = "medium"
    else:
        culprit = "unknown"; src = "none"; conf = "low"
    if culprit == _SELF_ID or culprit == __id__:
        return
    rec = {"had_bg_fail": True, "event_type": "background_exception", "dropbox_tag": "data_app_crash", "tombstone_norm_version": 1, "culprit": culprit, "src": src, "confidence": conf,
           "where": where, "thread_name": thread_name, "scoped_pid": scoped,
           "py_module": py_mod, "py_file": py_file, "py_line": py_line, "reason": reason,
           "exc_cls": exc_cls, "exc_msg": exc_msg, "ts": int(time.time() * 1000)}
    key = "%s|%s|%s" % (culprit, reason, where); now = rec["ts"]
    try:
        with _BG_SEEN_LOCK:
            if now - _BG_SEEN.get(key, 0) < _BG_DEDUP_MS:
                return
            _BG_SEEN[key] = now
    except Exception:
        pass
    try: _b16_push_verdict("bg", rec)
    except Exception: pass
    try: _bg_verdict_log(rec, "live")
    except Exception: pass
    try: _persist_bg_fail(rec)
    except Exception: pass

def _bg_excepthook(args):
    try:
        exc = getattr(args, "exc_value", None)
        et = getattr(args, "exc_type", None)
        thr = getattr(args, "thread", None)
        tname = None
        try: tname = getattr(thr, "name", None)
        except Exception: tname = None
        if exc is not None and et is not SystemExit:
            _bg_where = "thread"
            try:
                if isinstance(thr, threading.Timer):
                    _bg_where = "timer"
            except Exception:
                _bg_where = "thread"
            _bg_record(exc, _bg_where, thread_obj=thr, thread_name=tname)
    except Exception:
        pass
    try:
        prev = _BG_PREV_EXCEPTHOOK
        if prev is not None and prev is not _bg_excepthook:
            prev(args)
    except Exception:
        pass
_bg_excepthook._culprit_bg = True

def _bg_unraisablehook(unr):
    try:
        exc = getattr(unr, "exc_value", None)
        if exc is not None:
            _bg_record(exc, "unraisable", thread_obj=None, thread_name=None)
    except Exception:
        pass
    try:
        prev = _BG_PREV_UNRAISABLE
        if prev is not None and prev is not _bg_unraisablehook:
            prev(unr)
    except Exception:
        pass
_bg_unraisablehook._culprit_bg = True

def _b13_install():
    global _BG_PREV_EXCEPTHOOK, _BG_PREV_UNRAISABLE, _BG_INSTALLED
    if not _BLOCK13_ON:
        _log("Block#13: отключён (_BLOCK13_ON=False)"); return
    n = 0
    try:
        cur = getattr(threading, "excepthook", None)
        if cur is not None:
            if not getattr(cur, "_culprit_bg", False):
                _BG_PREV_EXCEPTHOOK = cur
            threading.excepthook = _bg_excepthook
            n += 1
    except Exception as e:
        _log(f"Block#13 excepthook install err: {e}")
    try:
        cur = getattr(_sys, "unraisablehook", None)
        if cur is not None:
            if not getattr(cur, "_culprit_bg", False):
                _BG_PREV_UNRAISABLE = cur
            _sys.unraisablehook = _bg_unraisablehook
            n += 1
    except Exception as e:
        _log(f"Block#13 unraisablehook install err: {e}")
    _BG_INSTALLED = n > 0
    _log("Block#13: фоновые хуки установлены (threading.excepthook + sys.unraisablehook): %d/2 -> %s" % (n, _BG_FILE_NAME))

def _b13_uninstall():
    global _BG_INSTALLED
    try:
        if getattr(threading, "excepthook", None) is _bg_excepthook and _BG_PREV_EXCEPTHOOK is not None:
            threading.excepthook = _BG_PREV_EXCEPTHOOK
    except Exception: pass
    try:
        if getattr(_sys, "unraisablehook", None) is _bg_unraisablehook and _BG_PREV_UNRAISABLE is not None:
            _sys.unraisablehook = _BG_PREV_UNRAISABLE
    except Exception: pass
    _BG_INSTALLED = False

_BLOCK14_ON = True
_CB_FILE_NAME = "cb_verdict.json"
_CB_FAILS_MAX = 20
_CB_DEDUP_MS = 4000
_CB_SEEN = {}; _CB_SEEN_LOCK = threading.Lock()
_B14_FLAG = "__culprit_cbwrap__"
_B14_PATCHED = []
_B14_WRAPPED_CLASSES = []
_B14_WRAP_LOCK = threading.Lock()
_B14_TIMERS = []
_B14_NCD = None
_B14_PROXY_BASE = None
_B14_NCD_RAW = None
_B14_CU_FUNCS = ("run_on_queue", "send_request", "run_on_ui_thread", "RunnableFactory", "OnCopy")
_B14_CB_ARGPOS = {"client_utils.send_request": 1}
_B14_KWARG_ONLY = "__kwarg_only__"
_B14_CB_PARAM_NAMES = ("callback","cb","on_click","onclick","action","handler","listener","on_complete","on_error","on_success","on_dismiss","on_done","delegate","run","runnable","fn","func","whenDone","on_select")
_B14_AU_FACTORIES = ("R", "OnClickListener", "OnLongClickListener", "run_on_ui_thread", "RunnableFactory", "OnCopy")
_B14_IFACE_OWNER = {}
_B14_SDK_MODS = ("client_utils", "android_utils", "base_plugin", "extera_utils", "extera_utils.classes", "ui.alert", "ui.bulletin")
_B14_REC_TL = threading.local()
_BLOCK15_ON = True
_B15_RD_IFACE = None
_B15_DYNPROXY = None
_B15_PROXY_CLS = None
_B15_RDT_IFACE = None
_B15_RDT_PROXY_CLS = None

def _cb_verdict_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _CB_FILE_NAME).getAbsolutePath()
    except Exception:
        return None

def _cb_verdict_log(rec, when):
    try:
        _log("============= CALLBACK VERDICT (%s) =============" % when)
        cul = rec.get("culprit"); conf = rec.get("confidence")
        if cul and cul != "unknown":
            _log("ВИНОВНИК КОЛБЭКА: %r conf=%s where=%s src=%s" % (cul, conf, rec.get("where"), rec.get("src")))
        else:
            _log("ВИНОВНИК КОЛБЭКА: неизвестен (where=%s)" % rec.get("where"))
        _log("  причина: %s" % rec.get("reason"))
        pf = rec.get("py_file")
        if pf: _log("  modul: %s:%s" % (pf, rec.get("py_line")))
        sp = rec.get("scoped_pid")
        if sp and sp != cul: _log("  scope-plugin(tid): %s" % sp)
        _log("  iskljuchenie: %s: %s" % (rec.get("exc_cls"), rec.get("exc_msg")))
        _log("=================================================")
    except Exception: pass

def _persist_cb_fail(rec):
    p = _cb_verdict_path()
    if not p:
        _log("Block#15 cbpersist: нет пути -- пропуск"); return
    _PERSIST_IO_LOCK.acquire()
    try:
        cur = []
        if os.path.exists(p):
            try:
                with open(p, "r", encoding="utf-8") as f: cur = list(json.load(f))
            except Exception: cur = []
        cur.append(rec)
        if len(cur) > _CB_FAILS_MAX: cur = cur[-_CB_FAILS_MAX:]
        _atomic_json_write(p, cur)
        _log("Block#15 cbpersist: zapisano %d zapisej -> %s" % (len(cur), _CB_FILE_NAME))
    except Exception as e:
        _log("Block#15 cbpersist err: %s: %s" % (type(e).__name__, e))
    finally:
        try: _PERSIST_IO_LOCK.release()
        except Exception: pass

def _read_and_clear_cb_fails():
    p = _cb_verdict_path()
    if not p: return []
    out = []
    _rp = _rc_take_path(p)
    try:
        if _rp:
            with open(_rp, "r", encoding="utf-8") as f: out = list(json.load(f))
    except Exception: out = []
    if _rp:
        try: os.remove(_rp)
        except Exception: pass
    return out

def _b14_record(owner, exc, surface, meth=None):
    if not _BLOCK14_ON: return
    try: _B14_REC_TL.last_exc = id(exc)
    except Exception: pass
    try: exc_cls = type(exc).__name__
    except Exception: exc_cls = "?"
    try: exc_msg = str(exc)
    except Exception: exc_msg = None
    reason = ("%s: %s" % (exc_cls, exc_msg)) if exc_msg else exc_cls
    try: _B14_REC_TL.last_exc_str = reason
    except Exception: pass
    where = ("%s.%s" % (surface, meth)) if meth else surface
    py_mod, py_file, py_line = _b10_pyframe_culprit(exc, owner)
    if py_mod:
        culprit = py_mod; src = "py-frame/" + where; conf = "high"
    elif owner:
        culprit = owner; src = "scope/" + where; conf = "medium"
    else:
        culprit = "unknown"; src = "none"; conf = "low"
    rec = {"had_cb_fail": True, "event_type": "callback_exception", "dropbox_tag": "data_app_crash", "tombstone_norm_version": 1, "culprit": culprit, "src": src, "confidence": conf,
           "surface": surface, "method": meth, "where": where, "scoped_pid": owner,
           "py_module": py_mod, "py_file": py_file, "py_line": py_line, "reason": reason,
           "exc_cls": exc_cls, "exc_msg": exc_msg, "ts": int(time.time() * 1000)}
    key = "%s|%s|%s" % (culprit, reason, where); now = rec["ts"]
    try:
        with _CB_SEEN_LOCK:
            if now - _CB_SEEN.get(key, 0) < _CB_DEDUP_MS: return
            _CB_SEEN[key] = now
    except Exception: pass
    try: _b16_push_verdict("cb", rec)
    except Exception: pass
    try: _cb_verdict_log(rec, "live")
    except Exception: pass
    try: _persist_cb_fail(rec)
    except Exception: pass

def _b14_caller_owner(max_up=14):
    try: f = _sys._getframe(2)
    except Exception: return None
    n = 0
    while f is not None and n < max_up:
        try:
            g = f.f_globals; mod = g.get("__name__") or ""
        except Exception: mod = ""
        if mod and mod not in _B14_SDK_MODS and mod != _SELF_ID and mod != __id__:
            try: ow = _b10_owner_from_module(mod)
            except Exception: ow = None
            if ow: return ow
        try: f = f.f_back
        except Exception: f = None
        n += 1
    return None

def _b14_wrap_cb(owner, fn, surface, meth=None):
    if fn is None or not callable(fn) or getattr(fn, _B14_FLAG, False):
        return fn
    def _w(*a, **kw):
        pushed = False
        if owner is not None:
            try: pushed = _scoped_set(owner)
            except Exception: pushed = False
        try:
            return fn(*a, **kw)
        except BaseException as e:
            if owner is not None:
                try: _b14_record(owner, e, surface, meth)
                except Exception: pass
            raise
        finally:
            if pushed:
                try: _scoped_clear()
                except Exception: pass
    try: _functools.update_wrapper(_w, fn)
    except Exception: pass
    try: setattr(_w, _B14_FLAG, True)
    except Exception: pass
    return _w

def _b14_make_func_patch(orig, surface):
    argpos = _B14_CB_ARGPOS.get(surface)
    @_functools.wraps(orig)
    def _patched(*a, **kw):
        owner = None
        try: owner = _b14_caller_owner()
        except Exception: owner = None
        if owner is not None:
            try:
                a = list(a)
                if argpos is _B14_KWARG_ONLY:
                    pass
                elif argpos is not None:
                    if argpos < len(a) and callable(a[argpos]) and not isinstance(a[argpos], type):
                        a[argpos] = _b14_wrap_cb(owner, a[argpos], surface)
                else:
                    for i in range(len(a)):
                        if callable(a[i]) and not isinstance(a[i], type):
                            a[i] = _b14_wrap_cb(owner, a[i], surface)
                            break
                for k in list(kw.keys()):
                    v = kw.get(k)
                    if callable(v) and not isinstance(v, type) and k in ("callback","fn","func","on_complete","on_error","runnable","r","delegate","listener","action","on_click","handler"):
                        kw[k] = _b14_wrap_cb(owner, v, surface, k)
            except Exception: pass
        result = orig(*a, **kw)
        if owner is not None:
            try:
                fn_name = surface.rsplit(".", 1)[-1]
                if fn_name in ("RunnableFactory", "OnCopy", "R",
                               "OnClickListener", "OnLongClickListener"):
                    _ts = int(time.time() * 1000)
                    _B14_IFACE_OWNER[fn_name] = (owner, _ts)
                    try:
                        if result is not None:
                            _rcn = type(result).__name__
                            if _rcn and _rcn != fn_name:
                                _B14_IFACE_OWNER[_rcn] = (owner, _ts)
                    except Exception: pass
            except Exception: pass
        return result
    try: setattr(_patched, _B14_FLAG, True)
    except Exception: pass
    return _patched

def _b14_import(name):
    try:
        m = _sys.modules.get(name)
        if m is not None: return m
    except Exception: pass
    try:
        import importlib
        return importlib.import_module(name)
    except Exception:
        return None

def _b14_patch_module(mod, mod_name, names):
    n = 0
    for nm in names:
        try: orig = getattr(mod, nm, None)
        except Exception: orig = None
        if orig is None or not callable(orig) or getattr(orig, _B14_FLAG, False):
            continue
        surface = "%s.%s" % (mod_name, nm)
        try:
            patched = _b14_make_func_patch(orig, surface)
            setattr(mod, nm, patched)
            with _B14_WRAP_LOCK:
                _B14_PATCHED.append((mod, nm, orig, patched))
            n += 1
        except Exception as e:
            _log("Block#14: patch %s err: %s" % (surface, e))
    if n: _log("Block#14: %s obernuto funkcij=%d" % (mod_name, n))
    return n

def _b14_wrap_method(cls, meth_name, surface):
    try: raw = cls.__dict__.get(meth_name)
    except Exception: raw = None
    if raw is None or isinstance(raw, (staticmethod, classmethod, property)):
        return 0
    fn = raw
    if not callable(fn) or getattr(fn, _B14_FLAG, False):
        return 0
    def _make(orig_fn, surf, mname):
        def _w(self, *a, **kw):
            ow = None
            try: ow = _b10_owner_from_module(getattr(type(self), "__module__", None))
            except Exception: ow = None
            pushed = False
            if ow is not None:
                try: pushed = _scoped_set(ow)
                except Exception: pushed = False
            try:
                return orig_fn(self, *a, **kw)
            except BaseException as e:
                if ow is not None:
                    try: _b14_record(ow, e, surf, mname)
                    except Exception: pass
                raise
            finally:
                if pushed:
                    try: _scoped_clear()
                    except Exception: pass
        try: _functools.update_wrapper(_w, orig_fn)
        except Exception: pass
        try: setattr(_w, _B14_FLAG, True)
        except Exception: pass
        return _w
    try:
        _w = _make(fn, surface, meth_name)
        setattr(cls, meth_name, _w)
        with _B14_WRAP_LOCK:
            _prune_dead_wrefs(_B14_WRAPPED_CLASSES)
            _B14_WRAPPED_CLASSES.append((_wref_make(cls), meth_name, fn, _w))
        return 1
    except Exception:
        return 0

def _b14_register_cb_methods(holder, mod_name):
    import inspect as _inspect
    names = []
    for nm in dir(holder):
        if nm.startswith("_"): continue
        try: fn = getattr(holder, nm, None)
        except Exception: fn = None
        if fn is None or not callable(fn) or isinstance(fn, type): continue
        pos = None; has_cb_kw = False
        try:
            params = list(_inspect.signature(fn).parameters.values())
        except Exception:
            continue
        idx = 0
        for p in params:
            if p.kind in (p.VAR_POSITIONAL, p.VAR_KEYWORD): continue
            if p.name in _B14_CB_PARAM_NAMES:
                has_cb_kw = True
                if p.kind in (p.POSITIONAL_ONLY, p.POSITIONAL_OR_KEYWORD): pos = idx
                break
            if p.kind in (p.POSITIONAL_ONLY, p.POSITIONAL_OR_KEYWORD): idx += 1
        if pos is None and not has_cb_kw: continue
        surface = "%s.%s" % (mod_name, nm)
        _B14_CB_ARGPOS[surface] = pos if pos is not None else _B14_KWARG_ONLY
        names.append(nm)
    if names:
        _b14_patch_module(holder, mod_name, names)
        _log("Block#14: %s cb-metodov zaregano=%d (argpos-pinned)" % (mod_name, len(names)))
    return len(names)

def _b14_sweep(reason="sweep"):
    if not _BLOCK14_ON: return 0
    ncd = _B14_NCD; pbase = _B14_PROXY_BASE; ncd_raw = _B14_NCD_RAW
    if ncd is None and pbase is None and ncd_raw is None: return 0
    ncd_n = 0; proxy_n = 0; total = 0; seen = set()
    try: mods = list(_sys.modules.items())
    except Exception: mods = []
    for mname, mod in mods:
        if mod is None: continue
        try: pid = getattr(mod, "__id__", None)
        except Exception: pid = None
        if not (isinstance(pid, str) and pid): continue
        if pid == _SELF_ID or pid == __id__: continue
        names = {mname}
        try:
            nm = getattr(mod, "__name__", None)
            if nm: names.add(nm)
        except Exception: pass
        try: members = list(vars(mod).values())
        except Exception: members = []
        for obj in members:
            if not isinstance(obj, type): continue
            try:
                if getattr(obj, "__module__", None) not in names: continue
            except Exception: continue
            try: k = id(obj)
            except Exception: k = None
            if k in seen: continue
            seen.add(k)
            is_ncd = False
            if ncd is not None:
                try: is_ncd = issubclass(obj, ncd) and obj is not ncd
                except Exception: is_ncd = False
            if (not is_ncd) and (ncd_raw is not None):
                try: is_ncd = issubclass(obj, ncd_raw) and obj is not ncd_raw
                except Exception: is_ncd = False
            has_drn = False
            try: has_drn = callable(obj.__dict__.get("didReceivedNotification"))
            except Exception: has_drn = False
            if has_drn or is_ncd:
                if has_drn:
                    c = _b14_wrap_method(obj, "didReceivedNotification", "notification")
                    if c: ncd_n += c; total += c
            if pbase is not None:
                try: is_proxy = issubclass(obj, pbase) and obj is not pbase
                except Exception: is_proxy = False
                if is_proxy:
                    try: meth_names = [m for m, v in list(obj.__dict__.items())
                                       if (not m.startswith("_")) and callable(v) and m != "didReceivedNotification"
                                       and not isinstance(v, (staticmethod, classmethod, property))
                                       and not getattr(v, _B14_FLAG, False)]
                    except Exception: meth_names = []
                    for m in meth_names:
                        c = _b14_wrap_method(obj, m, "proxy")
                        if c: proxy_n += c; total += c
    if total:
        _log("Block#14 %s: notification-metodov=%d proxy-metodov=%d" % (reason, ncd_n, proxy_n))
    return total

def _rebind_imported_sdk_funcs(tag="boot"):
    try:
        with _B14_WRAP_LOCK:
            patched = list(_B14_PATCHED)
    except Exception:
        patched = []
    if not patched:
        return 0
    pairs = []
    for tup in patched:
        try:
            mod, nm, orig = tup[0], tup[1], tup[2]
            wrapped = getattr(mod, nm, None)
            if wrapped is not None and wrapped is not orig and getattr(wrapped, _B14_FLAG, False):
                pairs.append((nm, orig, wrapped))
        except Exception:
            pass
    if not pairs:
        return 0
    n = 0; mods_touched = 0
    try: mods = list(_sys.modules.items())
    except Exception: mods = []
    for mod_name, mod in mods:
        try:
            pid = _pid_of_module_pkg(mod_name)
        except Exception:
            pid = None
        if not (isinstance(pid, str) and pid and pid != _SELF_ID and pid != __id__):
            continue
        touched = False
        for (nm, orig, wrapped) in pairs:
            try:
                cur = getattr(mod, nm, None)
                if cur is orig:
                    setattr(mod, nm, wrapped); n += 1; touched = True
            except Exception:
                pass
        if touched: mods_touched += 1
    if n:
        _log("Block#14 +BI bound-import rebind (%s): перепривязано имён=%d в плагин-модулях=%d (захваченные 'from client_utils import ...' до патча)" % (tag, n, mods_touched))
    return n

def _b14_install():
    global _B14_NCD, _B14_PROXY_BASE, _B14_NCD_RAW
    if not _BLOCK14_ON:
        _log("Block#14: отключён (_BLOCK14_ON=False)"); return
    cu = _b14_import("client_utils")
    if cu is not None:
        try: _b14_patch_module(cu, "client_utils", _B14_CU_FUNCS)
        except Exception as e: _log("Block#14 client_utils patch err: %s" % e)
        try: _B14_NCD = getattr(cu, "NotificationCenterDelegate", None)
        except Exception: _B14_NCD = None
    else:
        _log("Block#14: client_utils не импортирован")
    au = _b14_import("android_utils")
    if au is not None:
        try: _b14_patch_module(au, "android_utils", _B14_AU_FACTORIES)
        except Exception as e: _log("Block#14 android_utils patch err: %s" % e)
        
    ua = _b14_import("ui.alert")
    if ua is not None:
        try:
            adb = getattr(ua, "AlertDialogBuilder", None)
            if adb is not None:
                _b14_patch_module(adb, "ui.alert.AlertDialogBuilder", 
                                  ("set_positive_button", "set_negative_button", "set_neutral_button", "set_items"))
        except Exception as e: _log("Block#14 ui.alert patch err: %s" % e)

    ub = _b14_import("ui.bulletin")
    if ub is not None:
        try:
            bh = getattr(ub, "BulletinHelper", None)
            if bh is not None:
                _b14_register_cb_methods(bh, "ui.bulletin.BulletinHelper")
        except Exception as e: _log("Block#14 ui.bulletin patch err: %s" % e)

    ec = _b14_import("extera_utils.classes")
    if ec is None: ec = _b14_import("extera_utils")
    if ec is not None:
        try: _B14_PROXY_BASE = getattr(ec, "Base", None)
        except Exception: _B14_PROXY_BASE = None
    try:
        _B14_NCD_RAW = jclass("org.telegram.messenger.NotificationCenter$NotificationCenterDelegate")
        _log("Block#14: raw NCD iface resolved: %r" % (_B14_NCD_RAW,))
    except Exception as e:
        _B14_NCD_RAW = None
        _log("Block#14: raw NCD iface unavailable: %s: %s" % (type(e).__name__, e))
    try: _b14_sweep("boot-sweep")
    except Exception as e: _log("Block#14 sweep err: %s" % e)
    try: _rebind_imported_sdk_funcs("boot-sweep")
    except Exception as e: _log("Block#14 bound-rebind err: %s" % e)
    for _delay in (3.0, 8.0):
        try:
            t = threading.Timer(_delay, lambda d=_delay: (_b14_sweep("re-sweep@%.0fs" % d), _rebind_imported_sdk_funcs("re-sweep@%.0fs" % d)))
            t.daemon = True; t.start()
            _B14_TIMERS.append(t)
        except Exception as e:
            _log("Block#14 re-sweep schedule err: %s" % e)
    _log("Block#14: установлен (queue/request/ui-thread/listeners/notification/proxy) -> %s" % _CB_FILE_NAME)

def _b14_unpatch():
    for _t in _B14_TIMERS:
        try: _t.cancel()
        except Exception: pass
    _B14_TIMERS.clear()
    with _B14_WRAP_LOCK:
        funcs = list(_B14_PATCHED); _B14_PATCHED.clear()
        classes = list(_B14_WRAPPED_CLASSES); _B14_WRAPPED_CLASSES.clear()
    for tup in funcs:
        try:
            mod, nm, orig = tup[0], tup[1], tup[2]
            our_w = tup[3] if len(tup) > 3 else None
            cur = getattr(mod, nm, None)
            if cur is not None and (cur is our_w if our_w is not None else getattr(cur, _B14_FLAG, False)):
                setattr(mod, nm, orig)
        except Exception: pass
    for tup in classes:
        try:
            cls = _wref_get(tup[0])
            if cls is None: continue
            nm, orig_fn = tup[1], tup[2]
            our_w = tup[3] if len(tup) > 3 else None
            cur = cls.__dict__.get(nm)
            if cur is not None and (cur is our_w if our_w is not None else getattr(cur, _B14_FLAG, False)):
                setattr(cls, nm, orig_fn)
        except Exception: pass
    try: _mods = list(_sys.modules.items())
    except Exception: _mods = []
    for _mn, _mod in _mods:
        if _mod is None: continue
        for _tup in funcs:
            try:
                _nm = _tup[1]; _orig = _tup[2]
                _ourw = _tup[3] if len(_tup) > 3 else None
                _cur = getattr(_mod, _nm, None)
                if _cur is not None and (_cur is _ourw if _ourw is not None else getattr(_cur, _B14_FLAG, False)):
                    setattr(_mod, _nm, _orig)
            except Exception: pass

def _b15_build_proxy_class():
    RD = _B15_RD_IFACE; DP = _B15_DYNPROXY
    if RD is None or DP is None: return None
    try:
        class _CulpritReqDelegate(DP(RD)):
            def __init__(self, orig, owner):
                super().__init__()
                self._orig = orig; self._owner = owner
            def run(self, response, error):
                pushed = False; owner = self._owner
                if owner is not None:
                    try: pushed = _scoped_set(owner)
                    except Exception: pushed = False
                try:
                    return self._orig.run(response, error)
                except BaseException as e:
                    if _BLOCK15_ON:
                        already = False
                        try:
                            already = (getattr(_B14_REC_TL, "last_exc", None) == id(e))
                            _B14_REC_TL.last_exc = None
                            last_err = getattr(_B14_REC_TL, "last_exc_str", None)
                            _B14_REC_TL.last_exc_str = None
                            if not already and last_err and last_err in str(e):
                                already = True
                        except Exception: already = False
                        if not already:
                            try: _b14_record(owner, e, "connections_manager.sendRequest")
                            except Exception: pass
                    raise
                finally:
                    if pushed:
                        try: _scoped_clear()
                        except Exception: pass
        return _CulpritReqDelegate
    except Exception as e:
        _log("Block#15: proxy class build err: %s: %s" % (type(e).__name__, e)); return None

def _b15_build_proxy_class_ts():
    RDT = _B15_RDT_IFACE; DP = _B15_DYNPROXY
    if RDT is None or DP is None: return None
    try:
        class _CulpritReqDelegateTS(DP(RDT)):
            def __init__(self, orig, owner):
                super().__init__()
                self._orig = orig; self._owner = owner
            def run(self, response, error, timestamp):
                pushed = False; owner = self._owner
                if owner is not None:
                    try: pushed = _scoped_set(owner)
                    except Exception: pushed = False
                try:
                    return self._orig.run(response, error, timestamp)
                except BaseException as e:
                    if _BLOCK15_ON:
                        already = False
                        try:
                            already = (getattr(_B14_REC_TL, "last_exc", None) == id(e))
                            _B14_REC_TL.last_exc = None
                            last_err = getattr(_B14_REC_TL, "last_exc_str", None)
                            _B14_REC_TL.last_exc_str = None
                            if not already and last_err and last_err in str(e):
                                already = True
                        except Exception: already = False
                        if not already:
                            try: _b14_record(owner, e, "connections_manager.sendRequest")
                            except Exception: pass
                    raise
                finally:
                    if pushed:
                        try: _scoped_clear()
                        except Exception: pass
        return _CulpritReqDelegateTS
    except Exception as e:
        _log("Block#15: TS proxy class build err: %s: %s" % (type(e).__name__, e)); return None

class _SendRequestHook(MethodHook):
    def __init__(self, targets):
        self._targets = list(targets)
    def before_hooked_method(self, param):
        if not _BLOCK15_ON: return
        try:
            a = param.args
            if a is None: return
            owner = None
            try: owner = _b14_caller_owner()
            except Exception: owner = None
            if owner is None:
                try: owner = _hook_scope_pid()
                except Exception: owner = None
            if owner is None:
                return
            for (idx, kind) in self._targets:
                try:
                    if idx >= len(a): continue
                    d = a[idx]
                    if d is None: continue
                    cls = _B15_RDT_PROXY_CLS if kind == "rdt" else _B15_PROXY_CLS
                    if cls is None: continue
                    a[idx] = cls(d, owner)
                except Exception: pass
        except Exception:
            pass

_B15_DIAG = True
_B15_DIAG_DONE = False
def _b15_diag_dump(cls):
    global _B15_DIAG_DONE
    if not _B15_DIAG or _B15_DIAG_DONE:
        return
    _B15_DIAG_DONE = True
    seen = {}
    n = 0
    for m in list(cls.getDeclaredMethods()):
        try:
            if m.getName() != "sendRequest":
                continue
            n += 1
            pts = list(m.getParameterTypes())
            names = []
            for p in pts:
                try: names.append(p.getName())
                except Exception: names.append("?")
            _log("Block#15.1 diag: sendRequest[%d] (%s)" % (n, ", ".join(names)))
            for p in pts:
                try:
                    pn = p.getName()
                    sn = pn.rsplit(".", 1)[-1].rsplit("$", 1)[-1]
                    if ("Delegate" not in sn) and ("QuickAck" not in sn):
                        continue
                    if pn in seen:
                        continue
                    seen[pn] = True
                    is_if = False
                    try: is_if = bool(p.isInterface())
                    except Exception: is_if = False
                    sigs = []
                    try:
                        for dm in list(p.getDeclaredMethods()):
                            try:
                                dn = []
                                for dp in list(dm.getParameterTypes()):
                                    try: dn.append(dp.getName())
                                    except Exception: dn.append("?")
                                rt = "?"
                                try: rt = dm.getReturnType().getName()
                                except Exception: pass
                                sigs.append("%s %s(%s)" % (rt, dm.getName(), ", ".join(dn)))
                            except Exception: pass
                    except Exception: pass
                    _log("Block#15.1 diag:   iface %s (interface=%s) methods=[%s]" % (pn, is_if, " | ".join(sigs)))
                except Exception: pass
        except Exception: pass
    _log("Block#15.1 diag: total sendRequest overloads=%d delegate-ifaces=%d" % (n, len(seen)))

def _b15_install(plugin):
    global _B15_RD_IFACE, _B15_DYNPROXY, _B15_PROXY_CLS, _B15_RDT_IFACE, _B15_RDT_PROXY_CLS
    plugin._sendreq_unhooks = getattr(plugin, "_sendreq_unhooks", [])
    if not _BLOCK15_ON:
        _log("Block#15: отключён (_BLOCK15_ON=False)"); return
    try:
        from java import dynamic_proxy as _dp
        _B15_DYNPROXY = _dp
    except Exception as e:
        _log("Block#15: dynamic_proxy недоступен: %s: %s" % (type(e).__name__, e)); return
    try:
        _B15_RD_IFACE = jclass("org.telegram.tgnet.RequestDelegate")
    except Exception as e:
        _B15_RD_IFACE = None
        _log("Block#15: RequestDelegate iface unavailable: %s: %s" % (type(e).__name__, e)); return
    ok_sam = False
    try:
        rc = _java_lang_class("org.telegram.tgnet.RequestDelegate")
        if rc is not None:
            for m in list(rc.getDeclaredMethods()):
                try:
                    if m.getName() == "run" and len(m.getParameterTypes()) == 2:
                        ok_sam = True; break
                except Exception: pass
    except Exception: pass
    if not ok_sam:
        _log("Block#15: RequestDelegate.run(2) не подтверждён -- пропуск (без угадывания)"); return
    _B15_PROXY_CLS = _b15_build_proxy_class()
    if _B15_PROXY_CLS is None:
        _log("Block#15: proxy class не построен -- пропуск"); return
    try:
        _B15_RDT_IFACE = jclass("org.telegram.tgnet.RequestDelegateTimestamp")
    except Exception as e:
        _B15_RDT_IFACE = None
        _log("Block#15.1: RequestDelegateTimestamp iface unavailable: %s: %s" % (type(e).__name__, e))
    if _B15_RDT_IFACE is not None:
        ok_ts = False
        try:
            rtc = _java_lang_class("org.telegram.tgnet.RequestDelegateTimestamp")
            if rtc is not None:
                for _mm in list(rtc.getDeclaredMethods()):
                    try:
                        if _mm.getName() == "run" and len(_mm.getParameterTypes()) == 3:
                            ok_ts = True; break
                    except Exception: pass
        except Exception: pass
        if ok_ts:
            _B15_RDT_PROXY_CLS = _b15_build_proxy_class_ts()
            if _B15_RDT_PROXY_CLS is None:
                _log("Block#15.1: TS proxy не построен -- RDT-слоты пропущены")
        else:
            _log("Block#15.1: RequestDelegateTimestamp.run(3) не подтверждён -- RDT-слоты пропущены")
    hooked = 0; overloads = 0; rdt_slots = 0
    try:
        cls = _java_lang_class("org.telegram.tgnet.ConnectionsManager")
        if cls is None:
            _log("Block#15: ConnectionsManager class не найден -- пропуск"); return
        try: _b15_diag_dump(cls)
        except Exception as _de: _log("Block#15.1 diag err: %s: %s" % (type(_de).__name__, _de))
        for m in list(cls.getDeclaredMethods()):
            try:
                if m.getName() != "sendRequest": continue
                overloads += 1
                pts = list(m.getParameterTypes())
                targets = []
                for i in range(len(pts)):
                    try:
                        pn = pts[i].getName()
                        if pn.endswith("RequestDelegateTimestamp"):
                            if _B15_RDT_PROXY_CLS is not None: targets.append((i, "rdt"))
                        elif pn.endswith("RequestDelegate"):
                            targets.append((i, "rd"))
                    except Exception: pass
                if not targets: continue
                rdt_slots += sum(1 for (_i, _k) in targets if _k == "rdt")
                try: m.setAccessible(True)
                except Exception: pass
                plugin._sendreq_unhooks.append(plugin.hook_method(m, _SendRequestHook(targets), priority=_PRIO_MAX))
                hooked += 1
            except Exception: pass
    except Exception as e:
        _log("Block#15: ConnectionsManager hook err: %s: %s" % (type(e).__name__, e)); return
    _log("Block#15: установлен (ConnectionsManager.sendRequest delegate-wrap): hooked=%d/%d overloads (rdt-slots=%d) -> %s" % (hooked, overloads, rdt_slots, _CB_FILE_NAME))

_BLOCK25_ON = True
_DISP_FILE_NAME = "dispatch_verdict.json"
_DISP_FAILS_MAX = 20
_DISP_DEDUP_MS = 4000
_DISP_SEEN = {}; _DISP_SEEN_LOCK = threading.Lock()
_B25_HOST_LOADER = None
_B25_HOST_LOADER_OBJ = None
_B25_HOST_DISPATCH = "org.telegram.messenger.NotificationCenter"
_B25_DISPATCH_METHODS = ("postNotificationNameInternal",)
_B25_HANDLER_ON = True
_B25_HANDLER_CLASS = "android.os.Handler"
_B25_HANDLER_METHODS = ("dispatchMessage",)
_B25_FW_PREFIXES = (
    "java.", "javax.", "android.", "androidx.", "kotlin.", "kotlinx.",
    "dalvik.", "libcore.", "sun.", "jdk.", "com.android.", "com.google.",
    "com.chaquo.", "j$.", "org.json.", "okhttp3.", "okio.", "retrofit2.",
)

def _b25_is_fw(cn):
    if not cn: return True
    if "culprit" in cn.lower(): return True
    for p in _B25_FW_PREFIXES:
        if cn.startswith(p): return True
    return False

def _b25_resolve_host_loader():
    global _B25_HOST_LOADER, _B25_HOST_LOADER_OBJ
    try:
        ctx = _app_context()
        cl = ctx.getClassLoader() if ctx is not None else None
        if cl is not None:
            _B25_HOST_LOADER_OBJ = cl; _B25_HOST_LOADER = _safe_str(cl); return True
    except Exception: pass
    try:
        rc = _java_lang_class(_B25_HOST_DISPATCH)
        cl = rc.getClassLoader() if rc is not None else None
        if cl is not None:
            _B25_HOST_LOADER_OBJ = cl; _B25_HOST_LOADER = _safe_str(cl); return True
    except Exception: pass
    return False

def _b25_attr_frames(frames):
    if not frames:
        return "system", None
    try:
        pid, fr, _m = _loader_culprit(frames)
        if pid: return "plugin:%s" % pid, fr
    except Exception: pass
    try:
        pid2, fr2, _m2 = _classloader_culprit(frames)
        if pid2: return "plugin:%s" % pid2, fr2
    except Exception: pass
    hl = _B25_HOST_LOADER; hlo = _B25_HOST_LOADER_OBJ
    if hlo is not None and hl is not None:
        for fr in frames:
            cn = fr.rsplit(".", 1)[0] if "." in fr else fr
            if _b25_is_fw(cn): continue
            try:
                kls = hlo.loadClass(cn)
                drep = _safe_str(kls.getClassLoader())
                if drep == hl:
                    return "host", fr
            except Exception:
                pass
    return "system", (frames[0] if frames else None)

def _b25_frames_of(thr):
    frames = []
    try:
        st = thr.getStackTrace()
        if st is not None:
            for el in st:
                try: frames.append(el.getClassName() + "." + el.getMethodName())
                except Exception: pass
    except Exception: pass
    return frames

def _b25_classify_throwable(thr):
    try: chain = _thr_chain(thr)
    except Exception: chain = []
    try:
        mod, _f, _l = _py_module_from_throwable(chain)
        if mod:
            ow = _b10_owner_from_module(mod)
            if ow: return "plugin:%s" % ow, ("<python>." + mod), ow
    except Exception: pass
    frames = []
    for (_c, _m, exc) in (chain or [(None, None, thr)]):
        try: frames.extend(_b25_frames_of(exc))
        except Exception: pass
    kind, where = _b25_attr_frames(frames)
    owner = kind.split(":", 1)[1] if kind.startswith("plugin:") else None
    return kind, where, owner

def _dispatch_verdict_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _DISP_FILE_NAME).getAbsolutePath()
    except Exception:
        return None

def _persist_dispatch(rec):
    p = _dispatch_verdict_path()
    if not p: return
    _PERSIST_IO_LOCK.acquire()
    try:
        cur = []
        if os.path.exists(p):
            try:
                with open(p, "r", encoding="utf-8") as f: cur = list(json.load(f))
            except Exception: cur = []
        cur.append(rec)
        if len(cur) > _DISP_FAILS_MAX: cur = cur[-_DISP_FAILS_MAX:]
        _atomic_json_write(p, cur)
    except Exception as e:
        _log("Block#25 persist err: %s: %s" % (type(e).__name__, e))
    finally:
        try: _PERSIST_IO_LOCK.release()
        except Exception: pass

def _read_and_clear_dispatch():
    p = _dispatch_verdict_path()
    if not p: return []
    out = []
    _rp = _rc_take_path(p)
    try:
        if _rp:
            with open(_rp, "r", encoding="utf-8") as f: out = list(json.load(f))
    except Exception: out = []
    if _rp:
        try: os.remove(_rp)
        except Exception: pass
    return out

def _b25_record(thr, surface):
    if not _BLOCK25_ON: return
    try: kind, where, owner = _b25_classify_throwable(thr)
    except Exception: kind, where, owner = "system", None, None
    try: exc_cls = thr.getClass().getName()
    except Exception: exc_cls = "?"
    try: exc_msg = thr.getMessage()
    except Exception: exc_msg = None
    reason = ("%s: %s" % (exc_cls, exc_msg)) if exc_msg else exc_cls
    rec = {"had_dispatch_fail": True, "event_type": "dispatch_exception", "dropbox_tag": "data_app_crash", "tombstone_norm_version": 1, "culprit_kind": kind, "owner": owner,
           "surface": surface, "where": where, "reason": reason,
           "confidence": ("high" if owner else ("medium" if kind == "host" else "low")),
           "exc_cls": exc_cls, "exc_msg": exc_msg, "ts": int(time.time() * 1000)}
    key = "%s|%s|%s" % (kind, reason, where); now = rec["ts"]
    try:
        with _DISP_SEEN_LOCK:
            if now - _DISP_SEEN.get(key, 0) < _DISP_DEDUP_MS: return
            _DISP_SEEN[key] = now
    except Exception: pass
    try:
        _log("Block#25 DISPATCH VERDICT (%s): culprit_kind=%s where=%s -- %s" % (surface, kind, where, reason))
    except Exception: pass
    try: _persist_dispatch(rec)
    except Exception: pass

class _NcDispatchHook(MethodHook):
    def after_hooked_method(self, param):
        if not _BLOCK25_ON: return
        try: thr = param.getThrowable()
        except Exception: thr = None
        if thr is None: return
        try: _b25_record(thr, "notification")
        except Exception: pass

def _b25_try_native_handler():
    global _HANDLER_NATIVE_ACTIVE
    if _HANDLER_NATIVE_ACTIVE:
        return True
    if not (_HANDLER_NATIVE_ON and _HANDLER_NATIVE_OK and _NLIB is not None and _CTYPES_OK):
        return False
    try:
        if int(_NLIB.cd_handler_running()) == 1:
            _HANDLER_NATIVE_ACTIVE = True
            return True
        st = int(_NLIB.cd_handler_selftest(0))
        if st <= 0:
            _log("Block#25N: native handler selftest=%d -> неактивно" % st)
            return False
        n = int(_NLIB.cd_handler_install(0))
        if n > 0:
            _HANDLER_NATIVE_ACTIVE = True
            _log("Block#25N: нативный Handler.dispatchMessage interceptor=%d (GIL-free, без Python-bounce)" % n)
            return True
        _log("Block#25N: native handler install=%d -> неактивно" % n)
        return False
    except Exception as e:
        _log("Block#25N: native handler err: %s -> неактивно" % e)
        return False

def _b25_native_handler_uninstall():
    global _HANDLER_NATIVE_ACTIVE
    if not _HANDLER_NATIVE_ACTIVE:
        return False
    try:
        if _NLIB is not None and _HANDLER_NATIVE_OK:
            _NLIB.cd_handler_unhook()
    except Exception as e:
        _log("Block#25N: native handler unhook err: %s" % e)
    _HANDLER_NATIVE_ACTIVE = False
    _log("Block#25N: нативный Handler interceptor снят")
    return True


def _b25_install(plugin):
    plugin._b25_unhooks = getattr(plugin, "_b25_unhooks", [])
    if not _BLOCK25_ON:
        _log("Block#25: отключён (_BLOCK25_ON=False)"); return
    if not _b25_resolve_host_loader():
        _log("Block#25: host classloader не разрешён -- host-атрибуция OFF (plugin/system только)")
    hooked = 0
    try:
        cls = _java_lang_class(_B25_HOST_DISPATCH)
        if cls is None:
            _log("Block#25: NotificationCenter class не найден -- пропуск"); return
        for m in list(cls.getDeclaredMethods()):
            try:
                if m.getName() not in _B25_DISPATCH_METHODS: continue
                try: m.setAccessible(True)
                except Exception: pass
                plugin._b25_unhooks.append(plugin.hook_method(m, _NcDispatchHook(), priority=_PRIO_MAX))
                hooked += 1
            except Exception: pass
    except Exception as e:
        _log("Block#25: NotificationCenter hook err: %s: %s" % (type(e).__name__, e)); return
    handler_hooked = 0
    if _B25_HANDLER_ON:
        if _b25_try_native_handler():
            _log("Block#25: Handler.dispatchMessage -> нативный interceptor (GIL-free)")
        else:
            _log("Block#25: «Глубокий хук UI» требует пересобранный .so (cd_handler_*); Python-фолбек удалён -> неактивно")
    _log("Block#25: установлен (host-dispatch attribution: postNotificationNameInternal=%d handler=%d host_loader=%s) -> %s"
         % (hooked, handler_hooked, "ON" if _B25_HOST_LOADER else "OFF", _DISP_FILE_NAME))


_FUT_FILE_NAME = "future_verdict.json"
_FUT_FAILS_MAX = 20
_FUT_DEDUP_MS = 4000
_FUT_SEEN = {}; _FUT_SEEN_LOCK = threading.Lock()
_B17_FLAG = "_culprit_b17"
_B17_WRAP_LOCK = threading.Lock()
_B17_PATCHED = []
_B17_INSTALLED = False
_BLOCK17_ON = True

def _fut_verdict_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _FUT_FILE_NAME).getAbsolutePath()
    except Exception:
        return None

def _fut_verdict_log(rec, when):
    try:
        _log("============= FUTURE VERDICT (%s) =============" % when)
        cul = rec.get("culprit"); conf = rec.get("confidence")
        if cul and cul != "unknown":
            _log("ВИНОВНИК FUTURE: %r conf=%s where=%s src=%s" % (cul, conf, rec.get("where"), rec.get("src")))
        else:
            _log("ВИНОВНИК FUTURE: неизвестен (where=%s)" % rec.get("where"))
        _log("  причина: %s" % rec.get("reason"))
        pf = rec.get("py_file")
        if pf: _log("  modul: %s:%s" % (pf, rec.get("py_line")))
        sp = rec.get("scoped_pid")
        if sp and sp != cul: _log("  scope-plugin(tid): %s" % sp)
        _log("  iskljuchenie: %s: %s" % (rec.get("exc_cls"), rec.get("exc_msg")))
        _log("===============================================")
    except Exception: pass

def _persist_fut_fail(rec):
    p = _fut_verdict_path()
    if not p:
        _log("Block#17 futpersist: нет пути -- пропуск"); return
    _PERSIST_IO_LOCK.acquire()
    try:
