def _instrument_entrypoints():
    n = 0
    try:
        objs = _gc.get_objects()
    except Exception:
        return 0
    for obj in objs:
        try:
            if not isinstance(obj, BasePlugin):
                continue
            pid = _canonical_pid(obj)
            if pid == _SELF_ID or pid == __id__:
                continue
            for cb in _ENTRY_CBS:
                fn = getattr(obj, cb, None)
                if fn is None or not callable(fn):
                    continue
                if getattr(fn, _B_TAGGED_FLAG, False):
                    continue
                try:
                    wrapped = _wrap_settings_factory(pid, fn) if cb == "create_settings" else _wrap_entry(pid, fn)
                    setattr(obj, cb, wrapped); n += 1
                except Exception:
                    pass
        except Exception:
            pass
    if n:
        _log(f"PartB scope-widen: обёрнуто entry-колбэков={n}")
    return n

_THREAD_SHIM_ON = False
_PARTB_TIMER = None
_THREAD_SHIM_INSTALLED = None
def _native_thread_inherit():
    try:
        if _NATIVE_OK and _NLIB is not None and hasattr(_NLIB, "cd_thread_inherit_ok"):
            return int(_NLIB.cd_thread_inherit_ok()) == 1
    except Exception:
        pass
    return False

def _install_thread_shim():
    global _THREAD_SHIM_ON, _THREAD_SHIM_INSTALLED
    if _THREAD_SHIM_ON:
        return
    if False and _native_thread_inherit():
        _log("PartB: наследование тега потоков обеспечивает натив (Part A) — Python-shim не нужен")
        _THREAD_SHIM_ON = True
        return
    try:
        _orig_start = getattr(threading.Thread, "_culprit_orig_start", None)
        if _orig_start is None:
            _orig_start = threading.Thread.start
            try: threading.Thread._culprit_orig_start = _orig_start
            except Exception: pass
        def _tagged_start(self):
            try:
                parent = _reg_get(_cur_tid())
            except Exception:
                parent = None
            tag_name = None
            if parent is not None and parent >= 0:
                try: tag_name = _resolve_idx(parent)
                except Exception: tag_name = None
            if tag_name is None:
                try: prov = _provenance_pid(self, 1)
                except Exception: prov = None
                if prov is not None:
                    tag_name = prov
            if tag_name is not None and not getattr(self, "_culprit_wrapped", False):
                _real_run = self.run
                def _run_wrapper(_rr=_real_run, _pid=tag_name):
                    pushed = False
                    try:
                        pushed = _scoped_set(_pid)
                        return _rr()
                    finally:
                        if pushed:
                            try: _scoped_clear()
                            except Exception: pass
                try:
                    self.run = _run_wrapper
                    self._culprit_wrapped = True
                except Exception:
                    pass
            return _orig_start(self)
        threading.Thread.start = _tagged_start
        threading.Thread._culprit_shim = True
        _THREAD_SHIM_INSTALLED = _tagged_start
        _THREAD_SHIM_ON = True
        _log("PartB/E: Python thread-shim (пере)привязан к текущему load (rebind-safe, интерим до пересборки .so с Part A)")
    except Exception as e:
        _log(f"PartB thread-shim err: {e}")

def _partb_install():
    try:
        _install_thread_shim()
    except Exception as e:
        _log(f"PartB thread-shim install err: {e}")
    try:
        _install_settings_ctor_scope()
    except Exception as e:
        _log(f"Gap8 settings-ctor install err: {e}")
    try:
        _instrument_entrypoints()
        global _PARTB_TIMER
        try:
            if _PARTB_TIMER is not None: _PARTB_TIMER.cancel()
        except Exception: pass
        _PARTB_TIMER = threading.Timer(2.5, _instrument_entrypoints)
        _PARTB_TIMER.daemon = True; _PARTB_TIMER.start()
    except Exception as e:
        _log(f"PartB install err: {e}")

def _partb_uninstall():
    global _PARTB_TIMER, _THREAD_SHIM_ON, _THREAD_SHIM_INSTALLED
    try:
        if _PARTB_TIMER is not None:
            _PARTB_TIMER.cancel()
            _PARTB_TIMER = None
    except Exception as e:
        _log(f"PartB timer cancel err: {e}")
    try:
        _orig_start = getattr(threading.Thread, "_culprit_orig_start", None)
        if (_orig_start is not None and _THREAD_SHIM_INSTALLED is not None
                and threading.Thread.start is _THREAD_SHIM_INSTALLED):
            threading.Thread.start = _orig_start
            try: threading.Thread._culprit_shim = False
            except Exception: pass
        elif _THREAD_SHIM_INSTALLED is not None and threading.Thread.start is not _THREAD_SHIM_INSTALLED:
            _log("PartB: thread-shim обёрнут поверх другим плагином — оставляю как есть (revert пропущен)")
        _THREAD_SHIM_INSTALLED = None
        _THREAD_SHIM_ON = False
    except Exception as e:
        _log(f"PartB thread-shim uninstall err: {e}")


try:
    from base_plugin import MethodReplacement as _MethodReplacement
except Exception:
    _MethodReplacement = None

_BLOCK10_ON = True
_B10_FLAG = "__culprit_hookwrap__"
_B10_METHODS = ("before_hooked_method", "after_hooked_method", "replace_hooked_method")
_B10_PATCHED = {}
_B10_WRAPPED_CLASSES = []
_B10_WRAP_LOCK = threading.Lock()
_B10_TIMERS = []

def _b10_owner_from_module(mod_name):
    if not mod_name:
        return None
    try:
        mod = _sys.modules.get(mod_name)
    except Exception:
        mod = None
    pid = getattr(mod, "__id__", None) if mod is not None else None
    if not (isinstance(pid, str) and pid):
        pid = _canon_pid(mod_name)
    if pid == _SELF_ID or pid == __id__:
        return None
    return pid

def _b10_pyframe_culprit(exc, owner):
    try:
        tb = getattr(exc, "__traceback__", None)
    except Exception:
        tb = None
    best = (None, None, -1)
    best_owner = None
    while tb is not None:
        try:
            f = tb.tb_frame; g = f.f_globals
            mod = g.get("__name__") or ""
            fn = g.get("__file__") or ((mod + ".py") if mod else None)
            ln = tb.tb_lineno
        except Exception:
            mod = ""; fn = None; ln = -1
        pid = None
        if mod and mod != _SELF_ID and mod != __id__:
            try:
                mobj = _sys.modules.get(mod)
                cand = getattr(mobj, "__id__", None) if mobj is not None else None
                if not (isinstance(cand, str) and cand):
                    c2 = _canon_pid(mod)
                    if isinstance(c2, str) and c2 and c2 != mod:
                        cand = c2
                if isinstance(cand, str) and cand and cand != _SELF_ID and cand != __id__:
                    pid = cand
            except Exception:
                pid = None
        if pid is not None:
            best = (pid, fn, int(ln) if ln is not None else -1)
            if owner and pid == owner:
                best_owner = (pid, fn, int(ln) if ln is not None else -1)
        try: tb = tb.tb_next
        except Exception: tb = None
    return best_owner if best_owner is not None else best

def _b10_record(owner, exc, where):
    if not _BLOCK10_ON:
        return
    try: exc_cls = type(exc).__name__
    except Exception: exc_cls = "?"
    try: exc_msg = str(exc)
    except Exception: exc_msg = None
    reason = ("%s: %s" % (exc_cls, exc_msg)) if exc_msg else exc_cls
    py_mod, py_file, py_line = _b10_pyframe_culprit(exc, owner)
    if py_mod:
        culprit = py_mod; src = "py-frame/" + where; conf = "high"
    elif owner:
        culprit = owner; src = "scope/" + where; conf = "medium"
    else:
        culprit = "unknown"; src = "none"; conf = "low"
    rec = {"had_hook_fail": True, "culprit": culprit, "src": src, "confidence": conf,
           "where": where, "scoped_pid": owner, "py_module": py_mod,
           "py_file": py_file, "py_line": py_line, "reason": reason,
           "exc_cls": exc_cls, "exc_msg": exc_msg, "ts": int(time.time() * 1000)}
    key = "%s|%s|%s" % (culprit, reason, where); now = rec["ts"]
    try:
        with _HOOK_SEEN_LOCK:
            if now - _HOOK_SEEN.get(key, 0) < _HOOK_DEDUP_MS:
                return
            _HOOK_SEEN[key] = now
    except Exception:
        pass
    try: _hook_verdict_log(rec, "live")
    except Exception: pass
    try: _persist_hook_fail(rec)
    except Exception: pass

def _b10_make_wrapper(orig, name):
    @_functools.wraps(orig)
    def _w(self, *a, **kw):
        owner = None
        try:
            owner = _b10_owner_from_module(getattr(type(self), "__module__", None))
        except Exception:
            owner = None
        pushed = False
        if owner is not None:
            try: pushed = _scoped_set(owner)
            except Exception: pushed = False
        if _BLOCK28_ON and owner is not None and a:
            try:
                _param_obj = a[0]
                _mname_java = str(_param_obj.method.getName())
                if _mname_java in _B28_HOT_METHODS:
                    _b28_reg_hot_hook(owner, _mname_java, persist=True)
            except Exception:
                pass
        try:
            return orig(self, *a, **kw)
        except BaseException as e:
            if owner is not None:
                try: _b10_record(owner, e, name)
                except Exception: pass
            raise
        finally:
            if pushed:
                try: _scoped_clear()
                except Exception: pass
    try:
        setattr(_w, _B10_FLAG, True)
        hf = getattr(orig, "__hook_filters__", None)
        if hf is not None:
            try: _w.__hook_filters__ = dict(hf) if isinstance(hf, dict) else hf
            except Exception: pass
    except Exception:
        pass
    return _w

def _b10_wrap_class(cls):
    if cls is None:
        return 0
    try:
        mod = getattr(cls, "__module__", None)
        if mod == _SELF_ID or mod == __id__ or mod == "base_plugin":
            return 0
    except Exception:
        pass
    n = 0
    for name in _B10_METHODS:
        try:
            fn = cls.__dict__.get(name)
        except Exception:
            fn = None
        if fn is None or not callable(fn):
            continue
        if getattr(fn, _B10_FLAG, False):
            continue
        try:
            wrapped = _b10_make_wrapper(fn, name)
            setattr(cls, name, wrapped)
            with _B10_WRAP_LOCK:
                _B10_WRAPPED_CLASSES.append((cls, name, fn, wrapped))
            n += 1
        except Exception:
            pass
    return n

def _b10_all_subclasses(root):
    out = []
    try:
        subs = list(root.__subclasses__())
    except Exception:
        subs = []
    for s in subs:
        out.append(s)
        out.extend(_b10_all_subclasses(s))
    return out

def _b10_sweep(reason="sweep"):
    bases = [MethodHook]
    if _MethodReplacement is not None:
        bases.append(_MethodReplacement)
    seen = set(); total = 0; classes = 0
    for b in bases:
        for cls in [b] + _b10_all_subclasses(b):
            try: k = id(cls)
            except Exception: k = None
            if k in seen: continue
            seen.add(k)
            c = _b10_wrap_class(cls)
            if c: classes += 1; total += c
    if total:
        _log(f"Block#10 {reason}: обёрнуто классов-хуков={classes} методов={total}")
    return total

def _b10_wrap_functional(fn):
    if fn is None or not callable(fn) or getattr(fn, _B10_FLAG, False):
        return fn
    try:
        owner0 = _b10_owner_from_module(getattr(fn, "__module__", None))
    except Exception:
        owner0 = None
    @_functools.wraps(fn)
    def _w(*a, **kw):
        pushed = False
        if owner0 is not None:
            try: pushed = _scoped_set(owner0)
            except Exception: pushed = False
        try:
            return fn(*a, **kw)
        except BaseException as e:
            if owner0 is not None:
                try: _b10_record(owner0, e, "functional")
                except Exception: pass
            raise
        finally:
            if pushed:
                try: _scoped_clear()
                except Exception: pass
    try: setattr(_w, _B10_FLAG, True)
    except Exception: pass
    return _w

def _b10_is_hook_instance(obj):
    if obj is None or isinstance(obj, type):
        return False
    try:
        if isinstance(obj, MethodHook):
            return True
    except Exception:
        pass
    try:
        if _MethodReplacement is not None and isinstance(obj, _MethodReplacement):
            return True
    except Exception:
        pass
    try:
        return any(callable(getattr(obj, n, None)) for n in _B10_METHODS)
    except Exception:
        return False

_B10_INSTALLED = {}
def _b10_patch_basehooks():
    if not hasattr(BasePlugin, "hook_method"):
        _log("Block#10: BasePlugin.hook_method не найден — monkeypatch пропущен"); return 0
    patched = 0
    for mname in ("hook_method", "hook_all_methods", "hook_all_constructors"):
        orig = getattr(BasePlugin, mname, None)
        if orig is None or getattr(orig, _B10_FLAG, False):
            continue
        def _make(orig=orig, mname=mname):
            @_functools.wraps(orig)
            def _patched(self, *a, **kw):
                try:
                    for arg in list(a) + list(kw.values()):
                        if _b10_is_hook_instance(arg):
                            try: _b10_wrap_class(type(arg))
                            except Exception: pass
                    for fk in ("before", "after"):
                        if fk in kw and callable(kw[fk]):
                            try: kw[fk] = _b10_wrap_functional(kw[fk])
                            except Exception: pass
                except Exception:
                    pass
                if _BLOCK28_ON and mname in ("hook_method", "hook_all_methods") and a:
                    try:
                        m_obj = a[0]
                        mname_java = None
                        try: mname_java = str(m_obj.getName())
                        except Exception: pass
                        if mname_java and mname_java in _B28_HOT_METHODS:
                            pid = _canonical_pid(self)
                            if pid and pid != _SELF_ID:
                                _b28_reg_hot_hook(pid, mname_java, persist=True)
                    except Exception:
                        pass
                return orig(self, *a, **kw)
            try: setattr(_patched, _B10_FLAG, True)
            except Exception: pass
            return _patched
        try:
            _w = _make()
            setattr(BasePlugin, mname, _w)
            _B10_PATCHED[mname] = orig
            _B10_INSTALLED[mname] = _w
            patched += 1
        except Exception as e:
            _log(f"Block#10: monkeypatch {mname} err: {e}")
    if patched:
        _log(f"Block#10: monkeypatch BasePlugin.* установлен ({patched}/3)")
    return patched

def _b10_unpatch():
    for _t in _B10_TIMERS:
        try: _t.cancel()
        except Exception: pass
    _B10_TIMERS.clear()
    for mname, orig in list(_B10_PATCHED.items()):
        try:
            cur = getattr(BasePlugin, mname, None)
            if cur is not None and cur is _B10_INSTALLED.get(mname):
                setattr(BasePlugin, mname, orig)
        except Exception: pass
    _B10_PATCHED.clear()
    _B10_INSTALLED.clear()
    with _B10_WRAP_LOCK:
        items = list(_B10_WRAPPED_CLASSES); _B10_WRAPPED_CLASSES.clear()
    for tup in items:
        try:
            cls, name, orig_fn = tup[0], tup[1], tup[2]
            our_w = tup[3] if len(tup) > 3 else None
            cur = cls.__dict__.get(name)
            if cur is not None and (cur is our_w if our_w is not None else getattr(cur, _B10_FLAG, False)):
                setattr(cls, name, orig_fn)
        except Exception:
            pass

def _cp_reclaim_basehooks():
    try:
        BP = BasePlugin
    except Exception:
        return 0
    flags = (_B10_FLAG, _B12_FLAG)
    def _ours(fn):
        for f in flags:
            try:
                if getattr(fn, f, False):
                    return True
            except Exception:
                pass
        return False
    n = 0
    for mname in ("hook_method", "hook_all_methods", "hook_all_constructors", "add_menu_item"):
        try:
            cur = getattr(BP, mname, None)
            if cur is None or not _ours(cur):
                continue
            base = cur; hops = 0
            while base is not None and _ours(base) and hops < 12:
                nxt = getattr(base, "__wrapped__", None)
                if nxt is None or nxt is base:
                    break
                base = nxt; hops += 1
            if base is not None and base is not cur and not _ours(base):
                setattr(BP, mname, base); n += 1
        except Exception:
            pass
    if n:
        _log("cooperative-patch: reclaimed %d stale BasePlugin wrapper(s) from a prior load (+AZ)" % n)
    return n

def _b10_install():
    if not _BLOCK10_ON:
        _log("Block#10: отключён (_BLOCK10_ON=False)"); return
    try: _b10_patch_basehooks()
    except Exception as e: _log(f"Block#10 patch err: {e}")
    try: _b10_sweep("boot-sweep")
    except Exception as e: _log(f"Block#10 sweep err: {e}")
    try:
        t = threading.Timer(2.5, lambda: _b10_sweep("re-sweep"))
        t.daemon = True; t.start()
        _B10_TIMERS.append(t)
    except Exception as e:
        _log(f"Block#10 re-sweep schedule err: {e}")


_BLOCK12_ON = True
_B12_FLAG = "__culprit_uiwrap__"
_B12_PATCHED = {}
_B12_WRAPPED_CLASSES = []
_B12_WRAP_LOCK = threading.Lock()
_B12_TIMERS = []
_UI_FILE_NAME = "ui_verdict.json"
_UI_FAILS_MAX = 20
_UI_DEDUP_MS = 4000
_UI_SEEN = {}; _UI_SEEN_LOCK = threading.Lock()
_UI_MENU_CB_KEYS = ("on_click", "condition", "label", "text", "on_long_click")
_UI_DELEGATE_METHS = ("on_attached", "on_detached", "on_size_changed", "on_destroy", "create_view")
_UI_UNAMBIG = ("on_attached", "on_detached", "on_size_changed")

def _ui_verdict_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _UI_FILE_NAME).getAbsolutePath()
    except Exception:
        return None

def _ui_verdict_log(rec, when):
    try:
        _log("============= UI CALLBACK VERDICT (%s) =============" % when)
        cul = rec.get("culprit"); conf = rec.get("confidence")
        if cul and cul != "unknown":
            _log("ВИНОВНИК UI-КОЛБЭКА: %r conf=%s where=%s src=%s" % (cul, conf, rec.get("where"), rec.get("src")))
        else:
            _log("ВИНОВНИК UI-КОЛБЭКА: неизвестен (where=%s) — нет имени модуля в стеке" % rec.get("where"))
        _log("  причина: %s" % rec.get("reason"))
        pf = rec.get("py_file")
        if pf: _log("  модуль: %s:%s" % (pf, rec.get("py_line")))
        sp = rec.get("scoped_pid")
        if sp and sp != cul: _log("  scope-плагин(tid): %s" % sp)
        _log("  исключение: %s: %s" % (rec.get("exc_cls"), rec.get("exc_msg")))
        _log("===================================================")
    except Exception: pass

def _persist_ui_fail(rec):
    p = _ui_verdict_path()
    if not p: return
    try:
        cur = []
        if os.path.exists(p):
            try:
                with open(p, "r", encoding="utf-8") as f: cur = list(json.load(f))
            except Exception: cur = []
        cur.append(rec)
        _atomic_json_write(p, cur, _UI_FAILS_MAX)
    except Exception: pass

def _read_and_clear_ui_fails():
    p = _ui_verdict_path()
    if not p: return []
    out = []
    try:
        if os.path.exists(p):
            with open(p, "r", encoding="utf-8") as f: out = list(json.load(f))
    except Exception: out = []
    try:
        if os.path.exists(p): os.remove(p)
    except Exception: pass
    return out

def _b12_record(owner, exc, surface, meth):
    if not _BLOCK12_ON:
        return
    try: exc_cls = type(exc).__name__
    except Exception: exc_cls = "?"
    try: exc_msg = str(exc)
    except Exception: exc_msg = None
    reason = ("%s: %s" % (exc_cls, exc_msg)) if exc_msg else exc_cls
    where = "%s.%s" % (surface, meth)
    py_mod, py_file, py_line = _b10_pyframe_culprit(exc, owner)
    if py_mod:
        culprit = py_mod; src = "py-frame/" + where; conf = "high"
    elif owner:
        culprit = owner; src = "scope/" + where; conf = "medium"
    else:
        culprit = "unknown"; src = "none"; conf = "low"
    rec = {"had_ui_fail": True, "culprit": culprit, "src": src, "confidence": conf,
           "surface": surface, "method": meth, "where": where, "scoped_pid": owner,
           "py_module": py_mod, "py_file": py_file, "py_line": py_line, "reason": reason,
           "exc_cls": exc_cls, "exc_msg": exc_msg, "ts": int(time.time() * 1000)}
    key = "%s|%s|%s" % (culprit, reason, where); now = rec["ts"]
    try:
        with _UI_SEEN_LOCK:
            if now - _UI_SEEN.get(key, 0) < _UI_DEDUP_MS:
                return
            _UI_SEEN[key] = now
    except Exception:
        pass
    try: _b16_push_verdict("ui", rec)
    except Exception: pass
    try: _ui_verdict_log(rec, "live")
    except Exception: pass
    try: _persist_ui_fail(rec)
    except Exception: pass

def _b12_make_wrapper(orig, surface, meth):
    @_functools.wraps(orig)
    def _w(self, *a, **kw):
        owner = None
        try:
            owner = _b10_owner_from_module(getattr(type(self), "__module__", None))
        except Exception:
            owner = None
        pushed = False
        if owner is not None:
            try: pushed = _scoped_set(owner)
            except Exception: pushed = False
        try:
            return orig(self, *a, **kw)
        except BaseException as e:
            if owner is not None:
                try: _b12_record(owner, e, surface, meth)
                except Exception: pass
            raise
        finally:
            if pushed:
                try: _scoped_clear()
                except Exception: pass
    try: setattr(_w, _B12_FLAG, True)
    except Exception: pass
    return _w

def _b12_wrap_menu_cb(owner, fn, meth):
    if fn is None or not callable(fn) or getattr(fn, _B12_FLAG, False):
        return fn
    @_functools.wraps(fn)
    def _w(*a, **kw):
        pushed = False
        if owner is not None:
            try: pushed = _scoped_set(owner)
            except Exception: pushed = False
        try:
            return fn(*a, **kw)
        except BaseException as e:
            if owner is not None:
                try: _b12_record(owner, e, "menu", meth)
                except Exception: pass
            raise
        finally:
            if pushed:
                try: _scoped_clear()
                except Exception: pass
    try: setattr(_w, _B12_FLAG, True)
    except Exception: pass
    return _w

def _b12_wrap_class(cls):
    if cls is None:
        return 0
    try:
        mod = getattr(cls, "__module__", None)
        if mod == _SELF_ID or mod == __id__ or mod == "base_plugin" or mod == "client_utils":
            return 0
    except Exception:
        pass
    try:
        defined = [m for m in _UI_DELEGATE_METHS if callable(cls.__dict__.get(m))]
    except Exception:
        defined = []
    if not defined:
        return 0
    multi = len(defined) >= 2
    n = 0
    for name in defined:
        if not (multi or name in _UI_UNAMBIG):
            continue
        try:
            fn = cls.__dict__.get(name)
        except Exception:
            fn = None
        if fn is None or not callable(fn) or getattr(fn, _B12_FLAG, False):
            continue
        try:
            wrapped = _b12_make_wrapper(fn, "universal", name)
            setattr(cls, name, wrapped)
            with _B12_WRAP_LOCK:
                _B12_WRAPPED_CLASSES.append((cls, name, fn, wrapped))
            n += 1
        except Exception:
            pass
    return n

def _b12_sweep(reason="sweep"):
    classes = 0; total = 0; seen = set()
    try: mods = list(_sys.modules.items())
    except Exception: mods = []
    for mname, mod in mods:
        if mod is None: continue
        try: pid = getattr(mod, "__id__", None)
        except Exception: pid = None
        if not (isinstance(pid, str) and pid): continue
        if pid == _SELF_ID or pid == __id__: continue
        names = {mname}
        try:
            nm = getattr(mod, "__name__", None)
            if nm: names.add(nm)
        except Exception: pass
        try: members = list(vars(mod).values())
        except Exception: members = []
        for obj in members:
            if not isinstance(obj, type): continue
            try:
                if getattr(obj, "__module__", None) not in names: continue
            except Exception: continue
            try: k = id(obj)
            except Exception: k = None
            if k in seen: continue
            seen.add(k)
            c = _b12_wrap_class(obj)
            if c: classes += 1; total += c
    if total:
        _log(f"Block#12 {reason}: обёрнуто UI-классов={classes} м��то��о��={total}")
    return total

_B12_INSTALLED = {}
def _b12_patch_menu():
    if not hasattr(BasePlugin, "add_menu_item"):
        _log("Block#12: BasePlugin.add_menu_item не найден — menu patch пропущен"); return 0
    orig = getattr(BasePlugin, "add_menu_item", None)
    if orig is None or getattr(orig, _B12_FLAG, False):
        return 0
    @_functools.wraps(orig)
    def _patched(self, *a, **kw):
        owner = None
        try:
            owner = _b10_owner_from_module(getattr(type(self), "__module__", None))
        except Exception:
            owner = None
        if owner is not None:
            try:
                for arg in a:
                    if isinstance(arg, dict):
                        for k in list(arg.keys()):
                            if k in _UI_MENU_CB_KEYS and callable(arg.get(k)):
                                try: arg[k] = _b12_wrap_menu_cb(owner, arg[k], k)
                                except Exception: pass
                for k in list(kw.keys()):
                    if k in _UI_MENU_CB_KEYS and callable(kw.get(k)):
                        try: kw[k] = _b12_wrap_menu_cb(owner, kw[k], k)
                        except Exception: pass
            except Exception:
                pass
        return orig(self, *a, **kw)
    try: setattr(_patched, _B12_FLAG, True)
    except Exception: pass
    try: setattr(_patched, "__wrapped__", orig)
    except Exception: pass
    try:
        setattr(BasePlugin, "add_menu_item", _patched)
        _B12_PATCHED["add_menu_item"] = orig
        _B12_INSTALLED["add_menu_item"] = _patched
        _log("Block#12: monkeypatch BasePlugin.add_menu_item установлен")
        return 1
    except Exception as e:
        _log(f"Block#12: menu patch err: {e}"); return 0

def _b12_unpatch():
    for _t in _B12_TIMERS:
        try: _t.cancel()
        except Exception: pass
    _B12_TIMERS.clear()
    for mname, orig in list(_B12_PATCHED.items()):
        try:
            cur = getattr(BasePlugin, mname, None)
            if cur is not None and cur is _B12_INSTALLED.get(mname):
                setattr(BasePlugin, mname, orig)
        except Exception: pass
    _B12_PATCHED.clear()
    _B12_INSTALLED.clear()
    with _B12_WRAP_LOCK:
        items = list(_B12_WRAPPED_CLASSES); _B12_WRAPPED_CLASSES.clear()
    for tup in items:
        try:
            cls, name, orig_fn = tup[0], tup[1], tup[2]
            our_w = tup[3] if len(tup) > 3 else None
            cur = cls.__dict__.get(name)
            if cur is not None and (cur is our_w if our_w is not None else getattr(cur, _B12_FLAG, False)):
                setattr(cls, name, orig_fn)
        except Exception:
            pass

_LOADSWEEP_LOCK = threading.Lock()
_LOADSWEEP_TIMER = None
_LOADSWEEP_DELAY = 1.5
def _kick_load_resweep(pid):
    global _LOADSWEEP_TIMER
    def _run():
        try: _b10_sweep("load-resweep")
        except Exception as e: _log("Block#10 load-resweep err: %s" % e)
        try: _b12_sweep("load-resweep")
        except Exception as e: _log("Block#12 load-resweep err: %s" % e)
        try: _b14_sweep("load-resweep")
        except Exception as e: _log("Block#14 load-resweep err: %s" % e)
    try:
        with _LOADSWEEP_LOCK:
            t = _LOADSWEEP_TIMER
            if t is not None:
                try: t.cancel()
                except Exception: pass
            nt = threading.Timer(_LOADSWEEP_DELAY, _run)
            nt.daemon = True
            _LOADSWEEP_TIMER = nt
            nt.start()
    except Exception as e:
        _log("load-resweep schedule err: %s" % e)

def _b12_install():
    if not _BLOCK12_ON:
        _log("Block#12: отключён (_BLOCK12_ON=False)"); return
    try: _b12_patch_menu()
    except Exception as e: _log(f"Block#12 menu patch err: {e}")
    try: _b12_sweep("boot-sweep")
    except Exception as e: _log(f"Block#12 sweep err: {e}")
    for _delay in (3.0, 8.0):
        try:
            t = threading.Timer(_delay, lambda d=_delay: _b12_sweep("re-sweep@%.0fs" % d))
            t.daemon = True; t.start()
            _B12_TIMERS.append(t)
        except Exception as e:
            _log(f"Block#12 re-sweep schedule err: {e}")

