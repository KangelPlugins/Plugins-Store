def _b20_loop_native(stop, evfd=-1, seq0=-1):
    global _DN_MIDSTALL_SNAPSHOT
    last_seq = seq0
    if last_seq < 0:
        try: last_seq = int(_NLIB.cd_anr_stall_seq())
        except Exception: last_seq = 0
    if evfd < 0:
        try: evfd = int(_NLIB.cd_anr_eventfd())
        except Exception: evfd = -1
    last_ping = 0.0
    last_beat = 0.0
    _infl_since = None
    _mid = []
    ev = 0
    while not stop.is_set():
        try:
            try: ev |= int(_NLIB.cd_anr_events_take())
            except Exception: pass
            now = time.monotonic()
            try: inflight = int(_NLIB.cd_anr_inflight())
            except Exception: inflight = 1
            if (now - last_ping) * 1000.0 >= _B20_PING_MS and not inflight:
                _b20_post_ping(); last_ping = now
            if (now - last_beat) * 1000.0 >= _B20_BEAT_MS:
                _b20_post_beat(); last_beat = now
            if inflight:
                if _infl_since is None: _infl_since = last_ping if last_ping > 0.0 else now
                if ev & 2:
                    _held = (now - _infl_since) * 1000.0
                    try:
                        _jf, _pn, _cmp = _dn_capture_java_ui_stack()
                        if _jf:
                            _ks = _dn_capture_kernel_state(globals().get("_B33_UI_TID"))
                            _mid.append({"held_ms": _held, "jframes": _jf, "plugin_n": _pn, "component": _cmp, "kernel": _ks, "scope_owner": _dn_live_scope_owner()})
                            if len(_mid) > _DN_MIDSTALL_MAX: _mid = _mid[-_DN_MIDSTALL_MAX:]
                    except Exception: pass
            else:
                _infl_since = None
                if _mid and not (ev & 1): _mid = []
            if ev & 1:
                try: seq = int(_NLIB.cd_anr_stall_seq())
                except Exception: seq = last_seq
                if seq != last_seq:
                    last_seq = seq
                    try: waited = int(_NLIB.cd_anr_stalled_ms())
                    except Exception: waited = _B20_TIMEOUT_MS
                    _DN_MIDSTALL_SNAPSHOT = list(_mid)
                    _gil_begin(_GIL_B20)
                    try:
                        _b20_report_stall(waited)
                    finally:
                        _gil_end(_GIL_B20)
            ev = 0
            _tn = time.monotonic()
            timo = max(0.05, _B20_BEAT_MS / 1000.0 - (_tn - last_beat))
            if not inflight:
                _wp = max(0.05, _B20_PING_MS / 1000.0 - (_tn - last_ping))
                if _wp < timo: timo = _wp
            try:
                if select.select([evfd], [], [], timo)[0]:
                    try: os.read(evfd, 8)
                    except Exception: pass
            except Exception:
                stop.wait(timo)
        except Exception as e:
            try: _log("Block#20 native loop err: %r" % e)
            except Exception: pass
            stop.wait(0.25)

def _b20_start():
    global _B20_THREAD, _B20_NATIVE, _B20_BEAT_INFLIGHT
    _B20_BEAT_INFLIGHT = False
    if not _B20_ON:
        _log("Block#20: disabled"); return
    if not _b20_setup_handler():
        _log("Block#20: setup failed -> ANR watchdog OFF"); return
    _B20_NATIVE = bool(_ANR_NATIVE_OK and _NLIB is not None)
    if not _B20_NATIVE:
        _log("Block#20: native ANR (cd_anr_start) missing -> watchdog OFF (rebuild .so)"); return
    _B20_STOP.clear()
    _a20fd = -1
    try:
        _a20fd = int(_NLIB.cd_anr_eventfd())
    except Exception:
        _a20fd = -1
    _a20seq0 = -1
    try:
        _a20seq0 = int(_NLIB.cd_anr_stall_seq())
    except Exception:
        _a20seq0 = -1
    try:
        _NLIB.cd_anr_mid_cfg(int(_DN_MIDSTALL_AFTER_MS), int(_DN_MIDSTALL_EVERY_MS))
    except Exception:
        pass
    try:
        rc = int(_NLIB.cd_anr_start(int(_B20_TIMEOUT_MS), int(_B20_MAX_PLAUSIBLE_MS), 250))
    except Exception as e:
        _log("Block#20: cd_anr_start err: %r -> watchdog OFF" % e); return
    if rc < 0:
        _log("Block#20: cd_anr_start rc=%d -> watchdog OFF" % rc); return
    _B20_THREAD = threading.Thread(target=_b20_loop_native, args=(_B20_STOP, _a20fd, _a20seq0), name="culprit-anr", daemon=True)
    _B20_THREAD.start()
    _log("Block#20 ANR watchdog: start ping=%dms timeout=%dms detect=C/native (Tier 2b, event-wake) -> %s" % (
        _B20_PING_MS, _B20_TIMEOUT_MS, _ANR_FILE_NAME))

def _b20_stop():
    global _B20_THREAD, _B20_BEAT_INFLIGHT
    _B20_BEAT_INFLIGHT = False
    try:
        _B20_STOP.set()
        if _NLIB is not None:
            try: _NLIB.cd_anr_event_wake()
            except Exception: pass
        t = _B20_THREAD
        if t is not None: t.join(timeout=2.0)
        if _B20_NATIVE and _NLIB is not None:
            try: _NLIB.cd_anr_stop()
            except Exception: pass
        _B20_THREAD = None
        try:
            if _B20_HANDLER is not None: _B20_HANDLER.removeCallbacksAndMessages(None)
        except Exception: pass
        globals()["_B20_PING"] = None; globals()["_B20_BEAT"] = None; globals()["_B20_HANDLER"] = None
        globals()["_B20_BEAT_INFLIGHT"] = False
        _log("Block#20 ANR watchdog: stopped (callbacks cleared)")
    except Exception:
        pass

class Plugin(BasePlugin):
    def on_plugin_load(self):
        global _CRUMB
        _init_log(); _log(f"Culprit Detector v{__version__} loading")
        try: _aw_cleanup_stale_tmp()
        except Exception: pass
        try: _b28_apply_settings(self)
        except Exception as _eb28s: _log("Block#28 settings restore err: %s" % _eb28s)
        try: _cp_reclaim_basehooks()
        except Exception as _ecp: _log("cooperative-patch reclaim err: %s" % _ecp)
        _load_pidindex(); _log(f"Block#2 pid-index restored: {len(_IDX_PID)} entries")
        info = registry_info()
        _log(f"Block#2 реестр: backend={info['backend']} addr=0x{info['addr']:x} "
             f"slots={info['slots']} slot={info['slot_bytes']}B layout={info['layout']} v{info['version']}")
        _selftest_registry()
        _load_native()
        if globals().get("_ABI_FAIL", False):
            _log("Culprit Detector: ABI mismatch -- detector loaded but inert (+DT). Rebuild/embed current libculprit.so (ABI %d)." % _SO_ABI_EXPECT)
            return
        try:
            if _NATIVE_OK and _NLIB is not None:
                _NLIB.cd_reset_active_plugin(); _log("Block#5/TLS active-стек сброшен (reset)")
        except Exception:
            pass
        try:
            _omap, _on, _ost = _build_hook_owner_map()
            _owners = sorted(set(v for v in _omap.values() if v))
            _log(f"Block#4A карта хуков: методов={_on} статус={_ost} владельцы={_owners}")
            _log(f"Block#4A фреймворки хуков: {_probe_hook_frameworks()}")
            _ldrs = _plugin_loaders()
            _log(f"Block#4B classloader-карта(boot): загрузчиков={len(_ldrs)} уникальных={len(set(r for _,r,_ in _ldrs))}")
        except Exception as _e:
            _log(f"Block#4A карта err: {_e}")
        _CRUMB = _CrumbFile()
        prev = _CRUMB.read_prev()
        _log(f"PREVIOUS breadcrumb: {prev!r}" if prev else "PREVIOUS breadcrumb: none")
        try:
            self._install_crash_handler()
        except Exception as _eeh:
            try: _log("Block#5 +EH ранний арм UEH err: %s" % _eeh)
            except Exception: pass
        self._boot_verdict()
        self._exec_unhooks = []; self._execcb_unhooks = []; self._load_unhooks = []; self._loader_unhooks = []; self._suicide_unhooks = []; self._appevent_unhooks = []; self._psa_unhooks = []
        self._install_execute(); self._install_exec_errcb(); self._install_loadplugin(); self._install_appevent(); self._install_psa_scope(); self._install_crash_handler(); self._install_loader_hook(); self._install_b24_dexhook(); self._install_b27_view_hook(); self._install_b28c_proxy_hook(); self._install_b23_bitmap_hook(); self._install_gpu_rs_hook(); self._install_anim_op_hook(); self._install_mvel_op_hook(); self._install_binder_op_hook(); self._install_camera_op_hook(); self._install_mediacodec_op_hook(); self._install_gl_op_hook(); self._install_looper_barrier_hook(); self._install_suicide_hook(); self._install_direct_hook(); self._install_thread_start_hook(); self._coexist_selfcheck()
        _log(f"v{__version__} ready (tid registry + crash verdict + native malloc-tags={_NATIVE_OK})")
        try:
            _partb_install()
        except Exception as _eb:
            _log(f"PartB install err: {_eb}")
        try:
            _b10_install()
        except Exception as _eb10:
            _log(f"Block#10 install err: {_eb10}")
        try:
            _b12_install()
        except Exception as _eb12:
            _log(f"Block#12 install err: {_eb12}")
        try:
            _b13_install()
        except Exception as _eb13:
            _log(f"Block#13 install err: {_eb13}")
        try:
            _b14_install()
        except Exception as _eb14:
            _log(f"Block#14 install err: {_eb14}")
        try:
            _b15_install(self)
        except Exception as _eb15:
            _log(f"Block#15 install err: {_eb15}")
        try:
            _b25_install(self)
        except Exception as _eb25:
            _log(f"Block#25 install err: {_eb25}")
        try:
            _b17_install()
        except Exception as _eb17:
            _log(f"Block#17 install err: {_eb17}")
        try:
            _b18_install()
        except Exception as _eb18:
            _log(f"Block#18 install err: {_eb18}")
        try:
            _b19_start()
        except Exception as _eb19:
            _log(f"Block#19 install err: {_eb19}")
        try:
            _b26_start()
        except Exception as _eb26:
            _log(f"Block#26 install err: {_eb26}")
        try:
            _b30_start()
        except Exception as _eb30kg:
            _log(f"Block#30 install err: {_eb30kg}")
        try:
            _b31_start()
        except Exception as _eb31fg:
            _log(f"Block#31 install err: {_eb31fg}")
        try:
            _b20_start()
        except Exception as _eb20:
            _log(f"Block#20 install err: {_eb20}")
        try:
            _b29_start()
        except Exception as _eb29:
            _log(f"Block#29 install err: {_eb29}")
        try:
            _b33_start()
        except Exception as _eb33:
            _log(f"Block#33 install err: {_eb33}")
        try:
            _b28_start()
        except Exception as _eb28:
            _log(f"Block#28 install err: {_eb28}")
        try:
            _b11_install_scan()
            _b11p_install()
        except Exception as _eb11:
            _log(f"Block#11 install err: {_eb11}")
        try:
            if _OOM_NATIVE_OK and _NLIB is not None:
                _osp = _oom_sentinel_path()
                if _osp:
                    _osw = _aw_mirror_path(_osp) or _osp
                    _b6fd = -1
                    try:
                        _b6fd = int(_NLIB.cd_b6_eventfd())
                    except Exception:
                        _b6fd = -1
                    _b6_seq0 = -1
                    _b6_trim0 = -1
                    _b6_lowmem0 = -1
                    try:
                        _b6_seq0 = int(_NLIB.cd_oom_seq())
                        _b6_trim0 = int(_NLIB.cd_trim_seq())
                        _b6_lowmem0 = int(_NLIB.cd_lowmem_seq())
                    except Exception:
                        pass
                    rc = int(_NLIB.cd_oom_start(_osw.encode("utf-8"),
                        int(_OOM_PCT * 1000), int(_OOM_RATE_MBPS), int(_OOM_POLL_S * 1000),
                        int(_OOM_TOPN), int(_OOM_COOLDOWN_S * 1000)))
                    if rc < 0:
                        _log("Block#6 pre-OOM watchdog: native cd_oom_start failed rc=%d — detection disabled" % rc)
                    else:
                        self._oom_stop = threading.Event()
                        self._oom_thread = threading.Thread(target=_oom_consume_loop, args=(self._oom_stop, _b6fd, _b6_seq0, _b6_trim0, _b6_lowmem0), name="culprit-oom-fmt", daemon=True)
                        self._oom_thread.start()
                        try:
                            if _LEAK_NATIVE_OK and _NLIB is not None and hasattr(_NLIB, "cd_leak_start"):
                                lrc = int(_NLIB.cd_leak_start(30000, 40, 12, 600, 1800, 700))
                                if lrc < 0:
                                    _log("Block#6D client leak watchdog (native): start failed rc=%d" % lrc)
                                else:
                                    _log("Block#6D client leak watchdog (native): started rc=%d" % lrc)
                        except Exception as _el:
                            _log("Block#6D leak start err: %s" % _el)
                        _log(f"Block#6 pre-OOM watchdog (native): rc={rc} poll={_OOM_POLL_S}s pct>={int(_OOM_PCT*100)}% rate>={int(_OOM_RATE_MBPS)}MB/s top={_OOM_TOPN} sentinel={_osw}")
                else:
                    _log("Block#6 pre-OOM watchdog: sentinel path unavailable — detection disabled")
            else:
                _log("Block#6 pre-OOM watchdog: native cd_oom_start unavailable (rebuild .so) — detection disabled")
        except Exception as _eo:
            _log(f"Block#6 watchdog start err: {_eo}")
        try:
            _b6_register_trim_callbacks()
        except Exception as _e6c:
            _log(f"Block#6C register err: {_e6c}")

    def on_plugin_unload(self):
        global _OUR_UEH, _PREV_UEH
        _log("Culprit Detector unloading")
        try: _b10_passive_flush_if_dirty(force=True)
        except Exception: pass
        try: _b25_native_notif_uninstall()
        except Exception: pass
        try: _b25_native_handler_uninstall()
        except Exception: pass
        try:
            for _t in _B11_TIMERS:
                try: _t.cancel()
                except Exception: pass
            _B11_TIMERS.clear()
        except Exception: pass
        try: _b11p_uninstall()
        except Exception: pass
        try:
            try:
                _log("Block#27: final force sweep (on_plugin_unload)")
                _b27_sweep(force_all=True)
            except Exception as _e27:
                try: _log("Block#27 final sweep err: %s" % _e27)
                except Exception: pass
            if _B27_REAPER_STOP is not None: _B27_REAPER_STOP.set()
            if _B27_REAPER is not None:
                try: _B27_REAPER.join(timeout=2.0)
                except Exception: pass
            globals()["_B27_REAPER"] = None; globals()["_B27_REAPER_STOP"] = None
        except Exception: pass
        try: _b17_uninstall()
        except Exception: pass
        try: _b18_uninstall()
        except Exception: pass
        try: _b19_stop()
        except Exception: pass
        try: _b26_stop()
        except Exception: pass
        try: _b20_stop()
        except Exception: pass
        try: _b29_stop()
        except Exception: pass
        try: _b33_stop()
        except Exception: pass
        try: _b28_stop()
        except Exception: pass
        try: _b30_stop()
        except Exception: pass
        try: _b31_stop()
        except Exception: pass
        try:
            if globals().get("_B28C_NATIVE_STOP") is not None:
                globals()["_B28C_NATIVE_STOP"].set()
            t = globals().get("_B28C_NATIVE_THREAD")
            if t is not None:
                try: t.join(timeout=2.0)
                except Exception: pass
            globals()["_B28C_NATIVE_THREAD"] = None
            globals()["_B28C_NATIVE_STOP"] = None
        except Exception as _e28c:
            _log("Block#28C flush stop err: %s" % _e28c)
        try:
            if _OOM_NATIVE_OK and _NLIB is not None:
                try: _NLIB.cd_oom_stop()
                except Exception: pass
                try:
                    if _LEAK_NATIVE_OK and _NLIB is not None and hasattr(_NLIB, "cd_leak_stop"): _NLIB.cd_leak_stop()
                except Exception: pass
            if getattr(self, "_oom_stop", None) is not None: self._oom_stop.set()
            try:
                if _NLIB is not None: _NLIB.cd_b6_event_wake()
            except Exception: pass
            t = getattr(self, "_oom_thread", None)
            if t is not None: t.join(timeout=2.0)
            _log("Block#6 pre-OOM watchdog: stop")
        except Exception as _eo:
            _log(f"Block#6 watchdog stop err: {_eo}")
        try:
            _b6_unregister_trim_callbacks()
        except Exception as _e6cu:
            _log(f"Block#6C unregister err: {_e6cu}")
        try:
            if _NA_NATIVE_OK and _NLIB is not None and hasattr(_NLIB, "cd_na_dump"):
                _na_dump("unload")
        except Exception: pass
        try:
            if _NLIB is not None and hasattr(_NLIB, "cd_gref_stop"):
                _NLIB.cd_gref_stop()
                _log("Block#28C: NewGlobalRef hook restored (cd_gref_stop)")
        except Exception as _egr:
            _log("Block#28C cd_gref_stop err: %s" % _egr)
        try:
            if _NATIVE_OK and _NLIB is not None:
                _NLIB.cd_stop(); _log("Block#3 натив: хуки сняты (cd_stop)")
        except Exception as e:
            _log(f"Block#3 cd_stop err: {e}")
        try:
            if _OUR_UEH is not None and _JThread is not None:
                _JThread.setDefaultUncaughtExceptionHandler(_PREV_UEH)
                _log("crash handler restored to previous"); _OUR_UEH = None
        except Exception as e:
            _log(f"crash handler restore err: {e}")
        try:
            if _B4C_OK and _NLIB is not None:
                _NLIB.cd_uninstall_crash_handler()
        except Exception: pass
        for u in (getattr(self, "_exec_unhooks", []) + getattr(self, "_execcb_unhooks", []) + getattr(self, "_load_unhooks", []) + getattr(self, "_loader_unhooks", []) + getattr(self, "_suicide_unhooks", []) + getattr(self, "_direct_unhooks", []) + getattr(self, "_tstart_unhooks", []) + getattr(self, "_appevent_unhooks", []) + getattr(self, "_psa_unhooks", []) + getattr(self, "_sendreq_unhooks", []) + getattr(self, "_b23_unhooks", []) + getattr(self, "_gpu_unhooks", []) + getattr(self, "_anim_unhooks", []) + getattr(self, "_mvel_unhooks", []) + getattr(self, "_binder_unhooks", []) + getattr(self, "_camera_unhooks", []) + getattr(self, "_mediacodec_unhooks", []) + getattr(self, "_gl_unhooks", []) + getattr(self, "_b25_unhooks", []) + getattr(self, "_b27_unhooks", []) + getattr(self, "_b28c_unhooks", [])):
            try: self.unhook_method(u)
            except Exception as e: _log(f"unhook err: {e}")
        try:
            if _DIRECT_REAPER_STOP is not None: _DIRECT_REAPER_STOP.set()
            if _DIRECT_REAPER is not None:
                try: _DIRECT_REAPER.join(timeout=2.0)
                except Exception: pass
            globals()["_DIRECT_REAPER"] = None
            globals()["_DIRECT_REAPER_STOP"] = None
            globals()["_DIRECT_RQ"] = None
            globals()["_WeakReference"] = None
            globals()["_SysClass"] = None
            try:
                with _DIRECT_REG_LOCK:
                    _DIRECT_REGS.clear()
            except Exception as _er: _log(f"direct regs reset err: {_er}")
            try:
                with _DIRECT_LOCK:
                    _DIRECT_LIVE.clear()
                    globals()["_DIRECT_LIVE_TOTAL"] = 0
                    globals()["_DIRECT_LIVE_UNTAGGED"] = 0
            except Exception as _el: _log(f"direct live reset err: {_el}")
        except Exception as e: _log(f"reaper stop err: {e}")
        try:
            _b10_unpatch()
            _log("Block#10: обёртки сняты")
        except Exception as e: _log(f"Block#10 unpatch err: {e}")
        try:
            _b12_unpatch()
        except Exception as e: _log(f"Block#12 unpatch err: {e}")
        try:
            _b13_uninstall()
            _log("Block#13: background hooks restored")
        except Exception as e: _log(f"Block#13 uninstall err: {e}")
        try:
            _b14_unpatch()
            _log("Block#14: callback wraps reverted")
        except Exception as e: _log(f"Block#14 unpatch err: {e}")
        try:
            _partb_uninstall()
            _log("PartB: uninstalled (timer cancelled, thread-shim reverted)")
        except Exception as e: _log(f"PartB uninstall err: {e}")
        try:
            global _LOADSWEEP_TIMER
            with _LOADSWEEP_LOCK:
                if _LOADSWEEP_TIMER is not None:
                    _LOADSWEEP_TIMER.cancel()
                    _LOADSWEEP_TIMER = None
            _log("load-resweep timer cancelled")
        except Exception as e: _log(f"load-resweep timer cancel err: {e}")

    def _boot_verdict(self):
        try:
            _b30_read_sentinel("boot")
        except Exception as _e30b:
            _log(f"boot killguard read err: {_e30b}")
        try:
            _b31_clear_sentinel("boot: detector present")
        except Exception as _e31b:
            _log(f"boot fileguard clear err: {_e31b}")
        try:
            _b31_resurrect()
        except Exception as _e31r:
            _log(f"boot resurrect err: {_e31r}")
        try:
            try: _oom_consume_native("boot", do_log=False)
            except Exception: pass
            odump = _read_and_clear_oom_dump()
            if odump and odump.get("had_oom"):
                m = odump.get("mem", {})
                pc = m.get("pct"); pcs = round(pc*100,1) if (pc is not None and pc>=0) else -1
                _log("============== PRE-OOM IN PREVIOUS SESSION ==============")
                _log(f'PRE-OOM DUMP: reason={odump.get("reason")} rate={odump.get("rate_mbps")}MB/s pct={pcs}%')
                _log(f'  used={m.get("used")}B limit={m.get("limit")}B rss={m.get("rss")}B cd_total={m.get("cd_total")}B')
                _log("  TOP consumers:")
                for i, kv in enumerate((odump.get("top") or [])[:_OOM_TOPN]):
                    try: _log(f'    #{i+1} {kv[0]}: {int(kv[1])}B')
                    except Exception: pass
                try: _oom_verdict_log(odump, "prev-session")
                except Exception: pass
                _log("========================================================")
        except Exception as _eo:
            _log(f"boot oom read err: {_eo}")
        try:
            _oom_check_killcount("boot")
        except Exception as _eck:
            _log(f"boot client-oom check err: {_eck}")
        try:
            fails = _read_and_clear_load_fails()
            if fails:
                _log("===== LOAD/IMPORT FAILURES IN PREVIOUS SESSION (%d) =====" % len(fails))
                for fr in fails:
                    try: _load_verdict_log(fr, "prev-session")
                    except Exception: pass
                _log("========================================================")
        except Exception as _elf:
            _log(f"boot load-fail read err: {_elf}")
        try:
            hfails = _read_and_clear_hook_fails()
            if hfails:
                _log("===== RUNTIME HOOK FAILURES IN PREVIOUS SESSION (%d) =====" % len(hfails))
                for hr in hfails:
                    try: _hook_verdict_log(hr, "prev-session")
                    except Exception: pass
                _log("=========================================================")
        except Exception as _ehf:
            _log(f"boot hook-fail read err: {_ehf}")
        try:
            ufails = _read_and_clear_ui_fails()
            if ufails:
                _log("===== UI CALLBACK FAILURES IN PREVIOUS SESSION (%d) =====" % len(ufails))
                for ur in ufails:
                    try: _ui_verdict_log(ur, "prev-session")
                    except Exception: pass
                _log("========================================================")
        except Exception as _euf:
            _log(f"boot ui-fail read err: {_euf}")
        try:
            cbfails = _read_and_clear_cb_fails()
            if cbfails:
                _log("===== JAVA-CALLBACK FAILURES IN PREVIOUS SESSION (%d) =====" % len(cbfails))
                for cr in cbfails:
                    try: _cb_verdict_log(cr, "prev-session")
                    except Exception: pass
                _log("==========================================================")
        except Exception as _ecf:
            _log(f"boot cb-fail read err: {_ecf}")
        try:
            futfails = _read_and_clear_fut_fails()
            if futfails:
                _log("===== FUTURE FAILURES IN PREVIOUS SESSION (%d) =====" % len(futfails))
                for fr in futfails:
                    try: _fut_verdict_log(fr, "prev-session")
                    except Exception: pass
                _log("===================================================")
        except Exception as _eff:
            _log(f"boot fut-fail read err: {_eff}")
        try:
            asyncfails = _read_and_clear_async_fails()
            if asyncfails:
                _log("===== ASYNCIO FAILURES IN PREVIOUS SESSION (%d) =====" % len(asyncfails))
                for ar in asyncfails:
                    try: _async_verdict_log(ar, "prev-session")
                    except Exception: pass
                _log("====================================================")
        except Exception as _eaf:
            _log(f"boot async-fail read err: {_eaf}")
        try:
            pyerrfails = _read_and_clear_pyerr_fails()
            if pyerrfails:
                _log("===== JNI-BOUNDARY PY-EXCEPTION FAILURES IN PREVIOUS SESSION (%d) =====" % len(pyerrfails))
                for pr in pyerrfails:
                    try: _pyerr_verdict_log(pr, "prev-session")
                    except Exception: pass
                _log("=====================================================================")
        except Exception as _epf:
            _log(f"boot pyerr-fail read err: {_epf}")
        try:
            bfails = _read_and_clear_bg_fails()
            if bfails:
                _log("===== BACKGROUND FAILURES IN PREVIOUS SESSION (%d) =====" % len(bfails))
                for br in bfails:
                    try: _bg_verdict_log(br, "prev-session")
                    except Exception: pass
                _log("=======================================================")
        except Exception as _ebf:
            _log(f"boot bg-fail read err: {_ebf}")
        try:
            gfails = _read_and_clear_gate_fails()
            if gfails:
                _log("===== PRE-IMPORT/GATE FAILURES IN PREVIOUS SESSION (%d) =====" % len(gfails))
                for gr in gfails:
                    try: _gate_verdict_log(gr, "prev-session")
                    except Exception: pass
                _log("============================================================")
        except Exception as _egf:
            _log(f"boot gate-fail read err: {_egf}")
        try:
            dfails = _read_and_clear_dispatch()
            if dfails:
                _log("===== HOST-DISPATCH FAILURES IN PREVIOUS SESSION (%d) =====" % len(dfails))
                for dr in dfails:
                    try:
                        kind = dr.get("culprit_kind")
                        owner = dr.get("owner")
                        disp = f"plugin:{owner}" if owner else kind
                        _log("ВИНОВНИК ДИСПЕТЧЕРА: %s where=%s surface=%s" % (disp, dr.get("where"), dr.get("surface")))
                        _log("  причина: %s: %s" % (dr.get("exc_cls"), dr.get("exc_msg")))
                    except Exception: pass
                _log("===========================================================")
        except Exception as _edf:
            _log(f"boot dispatch-fail read err: {_edf}")
        try:
            cxa = _read_and_clear_cxa()
            if cxa:
                _log("===== C++ THROWS (host/plugin) IN PREVIOUS SESSION (%d) =====" % len(cxa))
                for cr in cxa:
                    kind = cr.get("kind")
                    owner = cr.get("owner")
                    who = ("plugin:%s" % owner) if (kind == "plugin" and owner) else kind
                    _log("ВИНОВНИК C++ THROW: %s type=%s module=%s" % (who, cr.get("type"), cr.get("module")))
                    fr = cr.get("frames") or []
                    if fr: _log("  кадр: %s" % fr[0])
                _log("===========================================================")
                try:
                    _cxa_ui = []
                    for _cr in cxa:
                        if _cr.get("kind") != "plugin" or not _cr.get("owner"):
                            continue
                        _r = dict(_cr)
                        _r["culprit"] = _cr.get("owner")
                        _r["confidence"] = _cr.get("conf")
                        _r["reason"] = "C++ исключение: %s" % (_cr.get("type") or "?")
                        _r["event_type"] = "cxx_exception"
                        _r["tombstone_norm_version"] = 1
                        _cxa_ui.append(_r)
                    if _cxa_ui:
                        _cxa_p = File(_DIR, "cxa_verdict.json").getAbsolutePath()
                        _cur_cxa = []
                        _rp_cxa = _rc_read_path(_cxa_p)
                        if _rp_cxa:
                            try:
                                with open(_rp_cxa, "r", encoding="utf-8") as _fcx: _cur_cxa = list(json.load(_fcx))
                            except Exception: pass
                        _cur_cxa.extend(_cxa_ui)
                        if len(_cur_cxa) > _CXA_UI_MAX: _cur_cxa = _cur_cxa[-_CXA_UI_MAX:]
                        _atomic_json_write(_cxa_p, _cur_cxa)
                except Exception: pass
        except Exception as _ecx:
            _log(f"boot cxa read err: {_ecx}")
        try:
            gref = _read_globalref_overflow()
            if gref:
                _log("===== JNI GLOBALREF-OVERFLOW В ПРОШЛОЙ СЕССИИ =====")
                _log("ВИНОВНИК: %s conf=%s метод=%s тип=%s share=%s%% max=%s" % (
                    gref.get("culprit"), gref.get("confidence"), gref.get("hot_method"),
                    gref.get("dominant_type"), int(round((gref.get("dominant_share") or 0)*100)), gref.get("max")))
                _log("==================================================")
        except Exception as _egr:
            _log(f"boot globalref read err: {_egr}")
        try:
            _b11_scan("boot")
        except Exception as _egs:
            _log(f"boot gate-scan err: {_egs}")
        try:
            ncrash = _read_native_crash()
            if ncrash:
                _log(f"Block#4C НАТИВНЫЙ КРАШ в прошлой сессии: signo={ncrash.get('signo')} cause={ncrash.get('cause')} type={ncrash.get('frame_type')} active_pid={ncrash.get('active_pid')} culprit_pid={ncrash.get('culprit_pid')} pid_src={ncrash.get('pid_src')} choice={ncrash.get('pid_choice_src')} resolve={ncrash.get('pid_resolve_src')} module={ncrash.get('foreign_so')!r} fso_src={ncrash.get('fso_src')!r} top_so={ncrash.get('top_so')!r} op_src={ncrash.get('op_stamp_src')!r} -> плагин={ncrash.get('pid')!r}; кадров={len(ncrash.get('frames') or [])}")
        except Exception as _enc:
            _log(f"native crash boot read err: {_enc}")
        try:
            verdict = _read_and_clear_crash_verdict()
        except Exception as e:
            _log(f"boot verdict read err: {e}"); return
        if verdict and verdict.get("had_crash"):
            try:
                _bc = []
                for _bk, _barr in (("pyerr", pyerrfails), ("bg", bfails),
                                   ("cb", cbfails), ("ui", ufails),
                                   ("fut", futfails), ("async", asyncfails)):
                    try:
                        for _br in (_barr or []):
                            _bc.append({"kind": _bk, "culprit": _br.get("culprit"),
                                        "confidence": _br.get("confidence"), "where": _br.get("where"),
                                        "exc_cls": _br.get("exc_cls"), "exc_msg": _br.get("exc_msg"),
                                        "py_file": _br.get("py_file"), "py_line": _br.get("py_line"),
                                        "ts": _br.get("ts")})
                    except Exception:
                        pass
                verdict = _b16_correlate_boot(verdict, _bc)
            except Exception as _ecb:
                _log("crash_verdict boot re-correlate err: %s" % _ecb)
            try:
                _cvdp = _crash_verdict_durable_path()
                if _cvdp:
                    try:
                        verdict["event_type"] = "app_crash"; verdict["dropbox_tag"] = "data_app_crash"; verdict["tombstone_norm_version"] = 1
                        verdict["persisted"] = True; verdict["persisted_src"] = "crash_verdict_persisted"
                    except Exception: pass
                    _atomic_json_write(_cvdp, verdict)
            except Exception as _ecvd:
                _log("crash_verdict durable mirror write err: %s" % _ecvd)
            cp = verdict.get("crashed_plugin_id", "unknown")
            conf = verdict.get("confidence", "?")
            tag = " [SELF-TEST]" if cp == "__selftest__" else ""
            if verdict.get("benign_restart"):
                _log("============= BENIGN RESTART (намеренный рестарт, не краш) =============")
                _log(f"ПРОШЛЫЙ ЗАПУСК: намеренный само-рестарт '{cp}'{tag} (benign, conf={conf}, источник={verdict.get('src')})")
            else:
                _log("================ CRASH VERDICT ================")
                _log(f"ПРОШЛЫЙ ЗАПУСК УПАЛ. ВИНОВНИК: {cp}{tag} (conf={conf}, источник={verdict.get('src')})")
            _log(f"  exc={verdict.get('exc_cls')}: {verdict.get('exc_msg')}")
            _corr = verdict.get("correlated")
            if _corr:
                _log(f"  KORRELJACIJA Block#16: podnjat do {_corr.get('culprit')} (conf={_corr.get('confidence')}, from={_corr.get('from')}, match={_corr.get('match')}, age={_corr.get('age_ms')}ms; nativ-istochnik byl {verdict.get('crashed_plugin_id_native')!r})")
            _log(f"  поток={verdict.get('thread')}")
            _log(f"  сигналы: tid={verdict.get('pid_tid')} (reg={verdict.get('reg_backend')}/idx={verdict.get('reg_idx')}) "
                 f"stack={verdict.get('pid_stack')} crumb={verdict.get('pid_crumb')} "
                 f"(fresh={verdict.get('crumb_fresh')}, age={verdict.get('crumb_age_ms')}ms)")
            cf = verdict.get("culprit_frame")
            if cf: _log(f"  stack-виновник: {cf}")
            nm = verdict.get("native_mem")
            if nm:
                _log(f"  native-память: топ={nm.get('top_pid')} ({nm.get('top_bytes')}B) total={nm.get('total')}B")
            if verdict.get("pid_4a"):
                _log(f"  Block#4A: владелец хука={verdict.get('pid_4a')} метод={verdict.get('hook4a_method')} match={verdict.get('hook4a_kind')}")
            _h4 = verdict.get("hook4a_meta") or {}
            if _h4:
                _log(f"  Block#4A карта: методов={_h4.get('n')} статус={_h4.get('status')}")
            if verdict.get("pid_4b"):
                _log(f"  Block#4B classloader: владелец={verdict.get('pid_4b')} кадр={verdict.get('cl4b_frame')}")
            _c4 = verdict.get("cl4b_meta") or {}
            if _c4:
                _log(f"  Block#4B classloader-карта: загрузчиков={_c4.get('n')} статус={_c4.get('status')}")
            if verdict.get("via_hook"):
                _log(f"  ⚠ крэш внутри Xposed/dex-хука; хукнутый метод: {verdict.get('hooked_method')}")
                if cp == "unknown":
                    _log("    имя обфусцировано — точная атрибуция dex-хуков = Block #4")
            for i, fr in enumerate((verdict.get("stack_top") or [])[:6]):
                _log(f"    #{i} {fr}")
            _log("===============================================")
            if _AUTO_DISABLE and conf == "high" and cp not in ("unknown", _SELF_ID, "__selftest__"):
                self._try_disable(cp)
        else:
            _log("прошлый запуск без крэша (crash-флаг чист)")

    def _coexist_selfcheck(self):
        try:
            prev_cls = "none"
            try:
                if _PREV_UEH is not None:
                    prev_cls = _PREV_UEH.getClass().getName()
            except Exception:
                prev_cls = "?"
            _log("Block#5 UEH-цепочка: prev=%s chained=%s" % (prev_cls, ("да" if _OUR_UEH is not None else "нет")))
            sdet = "n/a"
            try:
                _AppLoader = jclass("org.telegram.messenger.ApplicationLoader")
                _fdir = _AppLoader.getFilesDirFixed()
                _sf = File(_fdir, "plugin_crash_sentinel")
                sdet = "есть" if _sf.exists() else "нет"
            except Exception as _se:
                sdet = "err:%s" % _se
            _log("Block#5 движковый sentinel(plugin_crash_sentinel): %s — не трогаем" % sdet)
            _nat = "chained(g_prev)" if (_B4C_OK and _NLIB is not None) else "n/a"
            _log("Block#5 нативный sig-handler: %s; пишем только %s" % (_nat, _NATIVE_CRASH_NAME))
            _log("Block#5 режим ПАССИВНЫЙ: prefs движка не пишем (plugin_enabled_/crash_detected/crash_plugin_id), AUTO_DISABLE=%s" % _AUTO_DISABLE)
        except Exception as _e5:
            _log("Block#5 coexist-check err: %s" % _e5)

    def _install_crash_handler(self):
        global _PREV_UEH, _OUR_UEH
        if _JThread is None:
            _log("crash handler: java.lang.Thread недоступен — пропуск"); return
        if _HANDLER_CLASS is None:
            _log("crash handler: dynamic_proxy/iface недоступен — пропуск"); return
        if _OUR_UEH is not None:
            _log("crash handler: уже установлен"); return
        try:
            prev = _JThread.getDefaultUncaughtExceptionHandler()
            _PREV_UEH = prev; _OUR_UEH = _HANDLER_CLASS(prev)
            _JThread.setDefaultUncaughtExceptionHandler(_OUR_UEH)
            _log("crash handler installed (chained to default)")
        except Exception as e:
            _log(f"crash handler install err: {e}")

    def _try_disable(self, pid):
        try:
            from client_utils import run_on_queue
        except Exception:
            run_on_queue = None
        def _stop():
            try:
                PC = jclass("com.exteragram.messenger.plugins.PluginsController")
                controller = PC.getInstance()
                plugins = controller.getPlugins() if controller is not None else None
                plugin = plugins.get(pid) if plugins is not None else None
                if plugin is not None:
                    plugin.setEnabled(False); _log(f"AUTO-DISABLE: {pid} заглушен")
                else:
                    _log(f"AUTO-DISABLE: плагин {pid} не найден")
            except Exception as e:
                _log(f"AUTO-DISABLE err: {e}")
        try:
            if run_on_queue is not None: run_on_queue(_stop, delay=50)
            else: _stop()
        except Exception as e:
            _log(f"AUTO-DISABLE schedule err: {e}")

    def _install_direct_hook(self):
        self._direct_unhooks = getattr(self, "_direct_unhooks", [])
        live_ok = False
        try:
            live_ok = _direct_live_start()
        except Exception as e:
            _log(f"Block#3D: live-start err: {e}")
        hooked = 0; target = "none"
        try:
            cls = _java_lang_class("java.nio.DirectByteBuffer$MemoryRef")
            if cls is not None:
                for ctor in list(cls.getDeclaredConstructors()):
                    try:
                        ps = ctor.getParameterTypes()
                        if len(ps) == 1 and ps[0].getName() == "int":
                            try: ctor.setAccessible(True)
                            except Exception: pass
                            self._direct_unhooks.append(self.hook_method(ctor, _DirectAllocHook(), priority=_PRIO_MAX))
                            hooked += 1; target = "DirectByteBuffer$MemoryRef.<init>(int)"
                    except Exception: pass
        except Exception as e:
            _log(f"Block#3D: MemoryRef hook err: {e}")
        if hooked == 0:
            try:
                cls = _java_lang_class("java.nio.ByteBuffer")
                if cls is not None:
                    for m in list(cls.getDeclaredMethods()):
                        try:
                            if m.getName() != "allocateDirect": continue
                            ps = m.getParameterTypes()
                            if len(ps) == 1 and ps[0].getName() == "int":
                                try: m.setAccessible(True)
                                except Exception: pass
                                self._direct_unhooks.append(self.hook_method(m, _DirectAllocResultHook(), priority=_PRIO_MAX))
                                hooked += 1; target = "ByteBuffer.allocateDirect(int)"
                        except Exception: pass
            except Exception as e:
                _log(f"Block#3D: allocateDirect hook err: {e}")
        _log(f"Block#3D: DirectByteBuffer attribution hook: {hooked} (target={target}); live-учёт(reaper)={live_ok}")

    def _install_thread_start_hook(self):
        self._tstart_unhooks = getattr(self, "_tstart_unhooks", [])
        if not _D3_THREADSTART_ON:
            _log("Block#3E: Java Thread.start hook disabled (_D3_THREADSTART_ON=False)"); return
        hooked = 0
        try:
            cls = _java_lang_class("java.lang.Thread")
            if cls is not None:
                for m in list(cls.getDeclaredMethods()):
                    try:
                        if m.getName() != "start": continue
                        if len(m.getParameterTypes()) != 0: continue
                        try: m.setAccessible(True)
                        except Exception: pass
                        self._tstart_unhooks.append(self.hook_method(m, _ThreadStartHook(), priority=_PRIO_MAX))
                        hooked += 1
                    except Exception: pass
        except Exception as e:
            _log(f"Block#3E: Thread.start hook err: {e}")
        _log(f"Block#3E: Java Thread.start provenance hook: {hooked}")

    def _install_suicide_hook(self):
        self._suicide_unhooks = getattr(self, "_suicide_unhooks", [])
        targets = [
            ("android.os.Process", "killProcess", _HookKillProcess),
            ("java.lang.System",   "exit",        _HookSystemExit),
            ("java.lang.Runtime",  "halt",        _HookRuntimeHalt),
            ("java.lang.Runtime",  "exit",        _HookRuntimeExit),
        ]
        total = 0
        for cls_name, meth, hookcls in targets:
            try:
                cls = _java_lang_class(cls_name)
                if cls is None: continue
                for m in list(cls.getDeclaredMethods()):
                    try:
                        if m.getName() != meth: continue
                        ps = m.getParameterTypes()
                        if len(ps) != 1 or ps[0].getName() != "int": continue
                        try: m.setAccessible(True)
                        except Exception: pass
                        self._suicide_unhooks.append(self.hook_method(m, hookcls(), priority=_PRIO_MAX))
                        total += 1
                    except Exception: pass
            except Exception as e:
                _log("pre-mortem scan %s.%s err: %s" % (cls_name, meth, e))
        _rl_total = 0
        try:
            _pi = _java_lang_class("android.app.PendingIntent")
            if _pi is not None:
                for m in list(_pi.getDeclaredMethods()):
                    try:
                        if m.getName() not in ("getActivity", "getBroadcast", "getService", "getForegroundService"): continue
                        if not _method_hookable(m): continue
                        try: m.setAccessible(True)
                        except Exception: pass
                        self._suicide_unhooks.append(self.hook_method(m, _HookRelaunchSchedule(), priority=_PRIO_MAX))
                        _rl_total += 1
                    except Exception: pass
        except Exception as e:
            _log("H5.1 relaunch hook err: %s" % e)
        _log("Block#PM: pre-mortem хуки kill/halt/exit: %d + relaunch-schedule: %d" % (total, _rl_total))

    def _install_b24_dexhook(self):
        if not (_B4C_OK and _NLIB is not None): return
        try:
            self._loader_unhooks = getattr(self, "_loader_unhooks", [])
            seen = set(); hooked = 0
            for cname in ("dalvik.system.DexClassLoader",
                          "dalvik.system.PathClassLoader",
                          "dalvik.system.DelegateLastClassLoader",
                          "dalvik.system.InMemoryDexClassLoader"):
                cls = _java_lang_class(cname)
                if cls is None: continue
                try: ctors = list(cls.getDeclaredConstructors())
                except Exception: ctors = []
                for ctor in ctors:
                    try:
                        key = _safe_str(ctor)
                        if key in seen: continue
                        seen.add(key)
                        ctor.setAccessible(True)
                        self._loader_unhooks.append(self.hook_method(ctor, _LoaderHook(), priority=_PRIO_MAX))
                        hooked += 1
                    except Exception: pass
            _log("Block#24: concrete dex-loader ctor hooks: %d" % hooked)
        except Exception as e:
            _log("Block#24 install dexhook err: %s" % e)

    def _install_b27_view_hook(self):
        global _B27_REAPER, _B27_REAPER_STOP
        if not _BLOCK27_ON:
            _log("Block#27: отключён (_BLOCK27_ON=False)"); return
        try:
            self._b27_unhooks = getattr(self, "_b27_unhooks", [])
            cls = _java_lang_class("android.view.WindowManagerGlobal")
            if cls is None:
                _log("Block#27: WindowManagerGlobal не найден -- пропуск"); return
            try: methods = list(cls.getDeclaredMethods())
            except Exception: methods = []
            hooked = 0
            for m in methods:
                try:
                    nm = m.getName()
                    if nm == "addView": hk = _ViewAddHook()
                    elif nm in ("removeView", "removeViewImmediate"): hk = _ViewRemoveHook()
                    else: continue
                    try: m.setAccessible(True)
                    except Exception: pass
                    self._b27_unhooks.append(self.hook_method(m, hk, priority=_PRIO_MAX))
                    hooked += 1
                except Exception: pass
            if hooked <= 0:
                _log("Block#27: addView/removeView не найдены -- пропуск"); return
            _B27_REAPER_STOP = threading.Event()
            _B27_REAPER = threading.Thread(target=_b27_reaper, args=(_B27_REAPER_STOP,), name="culprit-view-reaper", daemon=True)
            _B27_REAPER.start()
            _log("Block#27: view-leak hooks (addView/removeView): %d; reaper sweep=%dms" % (hooked, _B27_SWEEP_MS))
            if _BLOCK27_VG_ON:
                try:
                    vgc = _java_lang_class("android.view.ViewGroup")
                    vg_hooked = 0
                    if vgc is None:
                        _log("Block#27B: ViewGroup не найден -- пропуск")
                    else:
                        try: vmethods = list(vgc.getDeclaredMethods())
                        except Exception: vmethods = []
                        for m in vmethods:
                            try:
                                nm = m.getName()
                                if nm == "addViewInner": hk = _ViewGroupAddHook()
                                elif nm in ("removeView", "removeViewInLayout"): hk = _ViewRemoveHook()
                                else: continue
                                try: m.setAccessible(True)
                                except Exception: pass
                                self._b27_unhooks.append(self.hook_method(m, hk, priority=_PRIO_MAX))
                                vg_hooked += 1
                            except Exception: pass
                        if vg_hooked == 0:
                            for m in vmethods:
                                try:
                                    nm = m.getName()
                                    if nm == "addView": hk = _ViewGroupAddHook()
                                    elif nm in ("removeView", "removeViewInLayout"): hk = _ViewRemoveHook()
                                    else: continue
                                    try: m.setAccessible(True)
                                    except Exception: pass
                                    self._b27_unhooks.append(self.hook_method(m, hk, priority=_PRIO_MAX))
                                    vg_hooked += 1
                                except Exception: pass
                        _log("Block#27B: ViewGroup view-leak hooks: %d (scope-gated, funnel=addViewInner)" % vg_hooked)
                except Exception as e:
                    _log("Block#27B install err: %s" % e)
        except Exception as e:
            _log("Block#27 install err: %s" % e)

    def _install_b28c_proxy_hook(self):
        global _B28C_ON
        if not _B28C_ON:
            _log("Block#28C: отключён (_B28C_ON=False)"); return
        if _GREF_NATIVE_OK and _NLIB is not None:
            try:
                rc = int(_NLIB.cd_gref_start())
                if rc >= 0 and int(_NLIB.cd_gref_running()):
                    _b28c_start_native_flush()
                    _log("Block#28C: NATIVE NewGlobalRef attribution ON (rc=%d) -- Java proxy tracer ne nuzhen" % rc)
                    return
                _log("Block#28C: native cd_gref_start rc=%d (ne aktiven) -- fallback na Java proxy tracer" % rc)
            except Exception as e:
                _log("Block#28C: native gref start err: %s -- fallback na Java proxy tracer" % e)
        try:
            self._b28c_unhooks = getattr(self, "_b28c_unhooks", [])
            cls = _java_lang_class("java.lang.reflect.Proxy")
            if cls is None:
                _log("Block#28C: java.lang.reflect.Proxy ne najden -- propusk"); return
            try: methods = list(cls.getDeclaredMethods())
            except Exception: methods = []
            hooked = 0
            for m in methods:
                try:
                    if m.getName() != "newProxyInstance": continue
                    try: m.setAccessible(True)
                    except Exception: pass
                    self._b28c_unhooks.append(self.hook_method(m, _ProxyCreateHook(), priority=_PRIO_MAX))
                    hooked += 1
                except Exception: pass
            _log("Block#28C: dynamic_proxy creation tracer hooks: %d (sample=1/%d)" % (hooked, _B28C_SAMPLE))
        except Exception as e:
