        except Exception: owner = None
        wfn = fn
        if owner is not None and callable(fn) and not getattr(fn, _B17_FLAG, False):
            try: wfn = _b17_wrap_fn(owner, fn)
            except Exception: wfn = fn
        fut = orig(self, wfn, *args, **kwargs)
        try: setattr(fut, _B17_FUT_TAG, True)
        except Exception: pass
        return fut
    try: setattr(_patched, _B17_FLAG, True)
    except Exception: pass
    return _patched

_B17_DELETE = object()

def _b17_make_map_patch(orig):
