    def _install_loader_hook(self):
        if not (_B4C_OK and _NLIB is not None):
            _log("Block#4C: натив без #4C-символов — хук загрузчика пропущен"); return
        try:
            self._loader_unhooks = getattr(self, "_loader_unhooks", [])
            cls = _java_lang_class("dalvik.system.BaseDexClassLoader")
            if cls is None:
                _log("Block#4C: BaseDexClassLoader не найден — пропуск"); return
            hooked = 0
            for ctor in list(cls.getDeclaredConstructors()):
                try:
                    ctor.setAccessible(True)
                    self._loader_unhooks.append(self.hook_method(ctor, _LoaderHook(), priority=_PRIO_MAX))
                    hooked += 1
                except Exception: pass
            _log(f"Block#4C: хук конструкторов BaseDexClassLoader: {hooked}")
        except Exception as e:
            _log(f"Block#4C install loader-hook err: {e}")

    def _install_appevent(self):
        try:
            self._appevent_unhooks = getattr(self, "_appevent_unhooks", [])
            engine = _java_lang_class("com.exteragram.messenger.plugins.PythonPluginsEngine") or find_class("com.exteragram.messenger.plugins.PythonPluginsEngine")
            if engine is None: _log("appevent: engine class not found"); return
            installed = 0
            for m in _get_declared_methods(engine, "PythonPluginsEngine"):
                try:
                    if m.getName() != "executeOnAppEvent": continue
                    try: m.setAccessible(True)
                    except Exception: pass
                    self._appevent_unhooks.append(self.hook_method(m, _AppEventHook(), priority=_PRIO_MAX))
                    installed += 1
                except Exception as e:
                    _log(f"scan executeOnAppEvent err: {e}")
            _log(f"Block#8: executeOnAppEvent hook installed: {installed}")
        except Exception as e:
            _log(f"install executeOnAppEvent err: {e}")

    def _install_execute(self):
        try:
            engine = _java_lang_class("com.exteragram.messenger.plugins.PythonPluginsEngine") or find_class("com.exteragram.messenger.plugins.PythonPluginsEngine")
            if engine is None: _log("engine class not found"); return
            installed = 0
            for m in _get_declared_methods(engine, "PythonPluginsEngine"):
                try:
                    if m.getName() != "executeHook": continue
                    ps = m.getParameterTypes()
                    if len(ps) != 6 or ps[0].getName() != "java.lang.String": continue
                    try: m.setAccessible(True)
                    except Exception: pass
                    self._exec_unhooks.append(self.hook_method(m, _ExecHook(), priority=_PRIO_MAX))
                    installed += 1
                except Exception as e:
                    _log(f"scan executeHook err: {e}")
            _log(f"executeHook(String) hook installed: {installed}")
        except Exception as e:
            _log(f"install executeHook err: {e}")

    def _install_exec_errcb(self):
        if not _BLOCK9_ON: return
        self._execcb_unhooks = getattr(self, "_execcb_unhooks", [])
        try:
            from java import dynamic_proxy
        except Exception as e:
            _log("Block#9: dynamic_proxy недоступен — пропуск: %s" % e); return
        try:
            from org.telegram.messenger import Utilities
        except Exception as e:
            _log("Block#9: Utilities недоступен — пропуск: %s" % e); return
        try:
            iface = Utilities.Callback
        except Exception as e:
            _log("Block#9: Utilities.Callback недоступен — пропуск: %s" % e); return
        try:
            class _ExecErrCb(dynamic_proxy(iface)):
                def __init__(self, orig, scoped):
                    super().__init__()
                    self._orig = orig
                    self._scoped = scoped
                def run(self, py_exception):
                    try: _record_hook_fail(py_exception, "executeHook", self._scoped)
                    except Exception: pass
                    try:
                        if self._orig is not None: self._orig.run(py_exception)
                    except Exception: pass
            def _factory(orig, scoped): return _ExecErrCb(orig, scoped)
        except Exception as e:
            _log("Block#9: proxy build err: %s" % e); return
        try:
            engine = _java_lang_class("com.exteragram.messenger.plugins.PythonPluginsEngine") or find_class("com.exteragram.messenger.plugins.PythonPluginsEngine")
            if engine is None: _log("Block#9: engine class not found"); return
            installed = 0
            for m in _get_declared_methods(engine, "PythonPluginsEngine"):
                try:
                    if m.getName() != "executeHook": continue
                    ps = m.getParameterTypes()
                    if len(ps) != 6: continue
                    if ps[0].getName() != "com.chaquo.python.PyObject": continue
                    try: m.setAccessible(True)
                    except Exception: pass
                    self._execcb_unhooks.append(self.hook_method(m, _ExecCbHook(_factory), priority=_PRIO_MAX))
                    installed += 1
                except Exception as e:
                    _log("Block#9: scan executeHook err: %s" % e)
            _log("Block#9: executeHook(PyObject) error-cb installed: %d" % installed)
        except Exception as e:
            _log("Block#9: install err: %s" % e)

    def _install_loadplugin(self):
        try:
            engine = _java_lang_class("com.exteragram.messenger.plugins.PythonPluginsEngine") or find_class("com.exteragram.messenger.plugins.PythonPluginsEngine")
            if engine is None: return
            hooked = 0
            for m in _get_declared_methods(engine, "PythonPluginsEngine"):
                try:
                    _mn = m.getName()
                    if _mn not in ("loadPlugin", "unloadPlugin"): continue
                    try: m.setAccessible(True)
                    except Exception: pass
                    _hk = _LoadHook() if _mn == "loadPlugin" else _UnloadHook()
                    self._load_unhooks.append(self.hook_method(m, _hk, priority=_PRIO_MAX))
                    hooked += 1
                except Exception as e:
                    _log(f"scan loadPlugin err: {e}")
            _log(f"loadPlugin hook installed on {hooked} overload(s)")
        except Exception as e:
            _log(f"install loadPlugin err: {e}")

