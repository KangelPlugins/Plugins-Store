            _MEDIACODEC_LAST.update(rec)
    except Exception as _egm:
        try: _log("Block#4C +CE(mediacodec): mediacodec_mark err: %s" % _egm)
        except Exception: pass

def _mediacodec_read_op():
    try:
        p = _mediacodec_op_path()
        if not p or not os.path.exists(p): return None
        with open(p, "r", encoding="utf-8") as f:
            d = json.load(f)
        if isinstance(d, dict) and d.get("owner"): return d
    except Exception:
        pass
    return None

def _frames_hit_mediacodec(frames):
    try:
        for fr in (frames or []):
            for h in _MEDIACODEC_FRAME_HINTS:
                if h in fr:
                    return h
    except Exception:
        pass
    return None

_GL_OP_FILE = "gl_op.json"
_GL_HOOK_INSTALLED = 0
_GL_LAST = {"owner": None, "ts": 0, "api": None}
_GL_LAST_WRITE_TS = 0
_GL_LAST_WRITE_OWNER = None
_GL_WRITE_N = 0
_GL_FRAME_HINTS = ("libGLESv2", "libGLESv1_CM", "libGLESv3", "libGLESv2.so", "libEGL", "libEGL.so",
                   "eglMakeCurrent", "eglCreateContext", "eglCreateWindowSurface", "eglSwapBuffers",
                   "android.opengl.GLSurfaceView", "android/opengl/GLSurfaceView", "GLSurfaceView$GLThread",
                   "GLSurfaceView", "GLThread", "android.opengl.GLES20", "android/opengl/GLES20",
                   "android.opengl.GLES30", "android.opengl.GLES31", "android.opengl.EGL14",
                   "android/opengl/EGL14", "android.opengl.GLUtils", "GLES20", "GLES30", "EGL14")

def _gl_op_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _GL_OP_FILE).getAbsolutePath()
    except Exception:
        try:
            return os.path.join(_DIR, _GL_OP_FILE)
        except Exception:
            return None

def _gl_mark(owner, api="gl"):
    if not owner or owner == _SELF_ID:
        return
    try:
        rec = {"owner": owner, "ts": int(time.time() * 1000), "api": api}
        _op_mark_native("gl", owner, api)
        with _GPU_LOCK:
            _GL_LAST.update(rec)
    except Exception as _egg:
        try: _log("Block#4C +CE(gl): gl_mark err: %s" % _egg)
        except Exception: pass

def _gl_read_op():
    try:
        p = _gl_op_path()
        if not p or not os.path.exists(p): return None
        with open(p, "r", encoding="utf-8") as f:
            d = json.load(f)
        if isinstance(d, dict) and d.get("owner"): return d
    except Exception:
        pass
    return None

def _frames_hit_gl(frames):
    try:
        for fr in (frames or []):
            for h in _GL_FRAME_HINTS:
                if h in fr:
                    return h
    except Exception:
        pass
    return None

_MVEL_CTX_CLASS_DENY = ("org.mvel2.", "java.", "javax.", "kotlin.", "sun.", "jdk.", "[")

def _mvel_ctx_learnable(cn):
    if not cn:
        return False
    for _p in _MVEL_CTX_CLASS_DENY:
        if cn.startswith(_p):
            return False
    return True

def _mvel_ctx_class(param):
    try:
        args = list(param.args) if getattr(param, "args", None) is not None else []
    except Exception:
        args = []
    for a in args:
        try:
            if a is None: continue
            nm = a.getClass().getName()
            if nm and _mvel_ctx_learnable(nm):
                return nm
        except Exception:
            continue
    return None

def _mvel_owner_now(param):
    ow = _gpu_owner_now()
    if ow:
        try:
            cn = _mvel_ctx_class(param)
            if cn: _MVEL_OWNER_BY_CLASS[cn] = ow
        except Exception:
            pass
        return ow
    try:
        cn = _mvel_ctx_class(param)
        if cn:
            return _MVEL_OWNER_BY_CLASS.get(cn)
    except Exception:
        pass
    return None

_MVEL_FIRE_SEEN = {}
_MVEL_FIRE_LOCK = threading.Lock()
_MVEL_FIRE_DEDUP_MS = 1000
_MVEL_FIRE_N = 0

def _mvel_fire_diag(param, ow):
    global _MVEL_FIRE_N
    try:
        cn = None
        try:
            cn = _mvel_ctx_class(param)
        except Exception:
            cn = None
        a0 = None
        try:
            args = list(param.args) if getattr(param, "args", None) is not None else []
            if args and args[0] is not None:
                a0 = args[0].getClass().getName()
        except Exception:
            a0 = None
        try:
            tname = threading.current_thread().name
        except Exception:
            tname = "?"
        key = (cn or "-", a0 or "-", repr(ow))
        now = int(time.time() * 1000)
        with _MVEL_FIRE_LOCK:
            if now - _MVEL_FIRE_SEEN.get(key, 0) < _MVEL_FIRE_DEDUP_MS:
                return
            _MVEL_FIRE_SEEN[key] = now
            _MVEL_FIRE_N += 1
            n = _MVEL_FIRE_N
        _log("Block#4C +BS(mvel-fire): #%d owner=%r ctx_class=%r arg0=%r thread=%s -- hook fired "
             "(this line proves the engine eval reached a +BN entrypoint regardless of owner)"
             % (n, ow, cn, a0, tname))
    except Exception:
        pass

def _classify_crash_frames(frames):
    try:
        if _gpu_frames_hit_rs(frames) or _frames_hit_gl(frames): return "gpu"
        if _frames_hit_anim(frames): return "anim"
        if _frames_hit_mvel(frames): return "mvel"
        if _frames_hit_camera(frames): return "camera"
        if _frames_hit_mediacodec(frames): return "mediacodec"
        if _frames_hit_binder(frames): return "binder"
    except Exception:
        pass
    return None

