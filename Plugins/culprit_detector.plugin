def _b25_native_notif_uninstall():
    global _NOTIF_NATIVE_ACTIVE
    if not _NOTIF_NATIVE_ACTIVE:
        return False
    try:
        if _NLIB is not None and _NOTIF_NATIVE_OK:
            _NLIB.cd_notif_unhook()
    except Exception as e:
        _log("Block#25NC: native notif unhook err: %s" % e)
