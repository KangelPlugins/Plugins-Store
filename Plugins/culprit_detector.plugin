def _b4c_decl(lib):
    c = ctypes
    lib.cd_lt_init.argtypes = [c.c_int32]; lib.cd_lt_init.restype = c.c_int
    lib.cd_register_loader.argtypes = [c.c_int64, c.c_int32]; lib.cd_register_loader.restype = c.c_int
    lib.cd_loader_pid.argtypes = [c.c_int64]; lib.cd_loader_pid.restype = c.c_int32
    lib.cd_lt_count.restype = c.c_int32
    lib.cd_lt_clear.restype = None
    lib.cd_set_active_plugin.argtypes = [c.c_int32]; lib.cd_set_active_plugin.restype = None
    lib.cd_clear_active_plugin.restype = None
    lib.cd_active_plugin.restype = c.c_int32
    try: lib.cd_reset_active_plugin.restype = None
    except Exception: pass
    lib.cd_install_crash_handler.argtypes = [c.c_char_p]; lib.cd_install_crash_handler.restype = c.c_int
    lib.cd_uninstall_crash_handler.restype = None
    if hasattr(lib, "cd_crash_handler_mask"):
        lib.cd_crash_handler_mask.restype = c.c_uint
    if hasattr(lib, "cd_set_host_lib_dir"):
        lib.cd_set_host_lib_dir.argtypes = [c.c_char_p]; lib.cd_set_host_lib_dir.restype = c.c_int
    if hasattr(lib, "cd_maps_refresh"):
        lib.cd_maps_refresh.restype = c.c_int
    if hasattr(lib, "cd_maps_count"):
        lib.cd_maps_count.restype = c.c_int
    if hasattr(lib, "cd_tomb_count"):
        lib.cd_tomb_count.restype = c.c_int64
    if hasattr(lib, "cd_compactions"):
        lib.cd_compactions.restype = c.c_int64
    if hasattr(lib, "cd_compact"):
        lib.cd_compact.restype = c.c_int64

def _native_crash_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _NATIVE_CRASH_NAME).getAbsolutePath()
    except Exception:
        return None

def _native_crash_verdict_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _NATIVE_CRASH_VERDICT_NAME).getAbsolutePath()
    except Exception:
        return None

def _crash_verdict_durable_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _CRASH_VERDICT_DURABLE_NAME).getAbsolutePath()
    except Exception:
        return None

def _host_lib_dir():
    try:
        ctx = _app_context()
        if ctx is None: return None
        ai = ctx.getApplicationInfo()
        d = getattr(ai, "nativeLibraryDir", None)
        return str(d) if d else None
    except Exception:
        return None

def _scope_decl(lib):
    c = ctypes
    if not all(hasattr(lib, n) for n in ("cd_scope_enter", "cd_scope_leave", "cd_scope_current")):
        return False
    lib.cd_scope_enter.argtypes = [c.c_int32]; lib.cd_scope_enter.restype = c.c_int
    lib.cd_scope_leave.argtypes = []; lib.cd_scope_leave.restype = c.c_int
    lib.cd_scope_current.argtypes = []; lib.cd_scope_current.restype = c.c_int32
    global _ARM_OK
    try:
        if all(hasattr(lib, n) for n in ("cd_scope_arm", "cd_scope_arm_clear")):
            lib.cd_scope_arm.argtypes = [c.c_int32]; lib.cd_scope_arm.restype = c.c_int
            lib.cd_scope_arm_clear.argtypes = []; lib.cd_scope_arm_clear.restype = c.c_int
            try:
                lib.cd_scope_arm_window_ns.argtypes = [c.c_int64]; lib.cd_scope_arm_window_ns.restype = c.c_int64
            except Exception: pass
            _ARM_OK = True
    except Exception:
        _ARM_OK = False
    global _PIDCOUNT_OK
    try:
        if hasattr(lib, "cd_reg_set_pid_count"):
            lib.cd_reg_set_pid_count.argtypes = [c.c_int32]; lib.cd_reg_set_pid_count.restype = c.c_int
            _PIDCOUNT_OK = True
            try: lib.cd_reg_set_pid_count(c.c_int32(len(_IDX_PID)))
            except Exception: pass
    except Exception:
        _PIDCOUNT_OK = False
    try:
        lib.cd_scope_depth.argtypes = []; lib.cd_scope_depth.restype = c.c_int32
    except Exception: pass
    try:
        lib.cd_thread_inherited.argtypes = []; lib.cd_thread_inherited.restype = c.c_int64
    except Exception: pass
    return True

def _b4c_init(lib):
    global _B4C_OK
    try:
        _b4c_decl(lib)
    except Exception as e:
        _B4C_OK = False
        _log(f"Block#4C: символы не найдены в .so (старый бинарь?) — #4C отключён: {e}")
        return
    try:
        rc = int(lib.cd_lt_init(int(_LT_SLOTS)))
        ncp = _native_crash_path()
        ncw = None
        try:
            ncw = _aw_mirror_path(ncp) if ncp else None
        except Exception:
            ncw = None
        ncp_install = ncw or ncp
        inst = -1
        if ncp_install:
            inst = int(lib.cd_install_crash_handler(ncp_install.encode("utf-8")))
            if hasattr(lib, "cd_maps_refresh"):
                try:
                    _mc = int(lib.cd_maps_refresh())
                    _log(f"Block#4C +CO maps snapshot: {_mc} modules")
                except Exception as _emr:
                    _log(f"Block#4C +CO cd_maps_refresh err: {_emr}")
        hld = None
        if hasattr(lib, "cd_set_host_lib_dir"):
            try:
                hld = _host_lib_dir()
                lib.cd_set_host_lib_dir((hld or "").encode("utf-8"))
            except Exception as _ehl:
                _log(f"Block#4C: cd_set_host_lib_dir err: {_ehl}"); hld = None
        if rc != 0:
            _B4C_OK = False
            _log(f"Block#4C: cd_lt_init FAIL rc={rc} — #4C отключён (native-crash attribution OFF)")
            return
        if ncp and inst != 0:
            _B4C_OK = False
            _log(f"Block#4C: cd_install_crash_handler FAIL rc={inst} — #4C отключён")
            return
        _B4C_OK = True
        _b4c_cov = ""
        if inst == 0 and hasattr(lib, "cd_crash_handler_mask"):
            try:
                _b4c_msk = int(lib.cd_crash_handler_mask()) & 0x1F
                _b4c_full = (_b4c_msk == 0x1F)
                _b4c_cov = f", coverage={'FULL' if _b4c_full else 'PARTIAL'} mask=0x{_b4c_msk:02x}"
                if not _b4c_full:
                    _log(f"Block#4C: native-crash coverage PARTIAL mask=0x{_b4c_msk:02x} (не все сигналы захвачены)")
            except Exception as _emsk:
                _log(f"Block#4C: cd_crash_handler_mask err: {_emsk}")
        _log(f"Block#4C: lt_init rc={rc} slots={_LT_SLOTS}, crash_handler={'OK' if inst==0 else 'rc=%d' % inst}{_b4c_cov} -> {ncp_install}")
        _log(f"Block#4C +CJ host-native: lib_dir={hld!r} -> {'ON' if hld else 'OFF (старый .so или нет контекста)'}")
        global _SCOPE_OK
        try:
            if _scope_decl(lib):
                lib.cd_scope_enter(-1); lib.cd_scope_leave()
                _SCOPE_OK = True
                _log("Block#10/C scope: cd_scope_enter/leave доступны — _scoped_set/clear через ОДИН нативный вызов")
                try:
                    if hasattr(lib, "cd_thread_inherited"):
                        _log("Block#10/C: cd_thread_inherited=%d (порождённые потоки унаследовали тег)" % int(lib.cd_thread_inherited()))
                except Exception: pass
            else:
                _SCOPE_OK = False
                _log("Block#10/C scope: cd_scope_* нет в .so (старый бинарь) — _scoped_set/clear через legacy (2 вызова)")
        except Exception as _esc:
            _SCOPE_OK = False
            _log("Block#10/C scope: декл/round-trip err: %s" % _esc)
    except Exception as e:
        _B4C_OK = False
        _log(f"Block#4C init err: {e}")

def _load_native():
    global _NLIB, _NATIVE_OK
    if not _CTYPES_OK or _REG_BUF is None:
        _log("Block#3: ctypes/shared-реестр недоступен — натив отключён (tid=Java id)")
        return
    if not _SO_ARM64:
        _log("Block#3: .so не вшит (_SO_ARM64 пуст) — запусти embed_so.py; натив отключён")
        return
    try:
        path = _b3_extract_so()
        if not path:
            return
        try:
            jclass("java.lang.System").load(path)
            _log("Block#3 System.load OK (namespace-load удался)")
        except Exception as e:
            _es = str(e)
            if ("getClassLoader" in _es) or ("null object reference" in _es):
                _log("Block#3 System.load: рефлексивный вызов без Java-caller — ожидаемо, .so грузится через ctypes.CDLL (не ошибка)")
            else:
                _log(f"Block#3 System.load warn: {_es}")
        lib = ctypes.CDLL(path)
        _b3_decl(lib)
        try:
            _abi = int(lib.cd_abi_version()) if hasattr(lib, "cd_abi_version") else None
        except Exception:
            _abi = None
        if _abi != _SO_ABI_EXPECT:
            globals()["_ABI_FAIL"] = True
            _log("Block#3 ABI MISMATCH .so=%s expected %d -- native disabled, plugin inert (+DT)" % (str(_abi), _SO_ABI_EXPECT))
            _NLIB = None; _NATIVE_OK = False
            return
        globals()["_SO_ABI_SEEN"] = int(_abi)
        try: _log("Block#3 +HS: native .so ABI=%d OK (expected %d) -- native active" % (int(_abi), _SO_ABI_EXPECT))
        except Exception: pass
        try: _log("Block#3 native build rev=%s" % (str(int(lib.cd_build_rev())) if hasattr(lib, "cd_build_rev") else "<absent: old .so>"))
        except Exception: pass
        info = registry_info()
        rc = int(lib.cd_init(ctypes.c_uint64(info["addr"]), int(info["slots"]), int(info["slot_bytes"])))
        if rc != 0:
            _log(f"Block#3 cd_init FAIL rc={rc} — натив отключён")
            return
        hooks = int(lib.cd_start())
        if hooks < 0:
            _log(f"Block#3 cd_start FAIL rc={hooks} — натив отключён")
            try: lib.cd_stop()
            except Exception: pass
            _NLIB = None; _NATIVE_OK = False
            return
        _NLIB = lib; _NATIVE_OK = True
        try:
            if _NA_NATIVE_OK and _NA_SAMPLE_ENABLE and hasattr(lib, "cd_na_enable"):
                lib.cd_na_enable(1, int(_NA_MIN_BYTES))
                _log("Block#3S native alloc-site capture: ON min=%d" % int(_NA_MIN_BYTES))
        except Exception as _ena:
            _log("Block#3S cd_na_enable err: %s" % _ena)
        _b4c_init(lib)
        try:
            _b19_init(lib)
        except Exception as _e19:
            _log(f"Block#19 init err: {_e19}")
        try:
            _b26_init(lib)
        except Exception as _e26:
            _log(f"Block#26 init err: {_e26}")
        try:
            _b30_init(lib)
        except Exception as _e30kg:
            _log(f"Block#30 init err: {_e30kg}")
        try:
            _b31_init(lib)
        except Exception as _e31fg:
            _log(f"Block#31 init err: {_e31fg}")
        _log(f"Block#3 натив загружен: {path}")
        _log(f"Block#3 cd_init OK (reg=0x{info['addr']:x} slots={info['slots']} slot={info['slot_bytes']}B), хуков malloc={hooks}")
        if hooks <= 0:
            _log("Block#3 ⚠ ноль хуков — sh не перехватил libc (проверь sh)")
    except Exception as e:
        _NLIB = None; _NATIVE_OK = False
        _log(f"Block#3 load err: {e}")

def _so_features_str():
    g = globals()
    flags = [("OOM", "_OOM_NATIVE_OK"), ("ANR", "_ANR_NATIVE_OK"),
             ("GREF", "_GREF_NATIVE_OK"), ("OP", "_OP_NATIVE_OK"),
             ("SCOPE", "_SCOPE_OK"), ("TRIM", "_TRIM_NATIVE_OK"),
             ("LOWMEM", "_LOWMEM_NATIVE_OK"), ("WD", "_WD_NATIVE_OK")]
    try:
        return "  ".join("%s:%s" % (lbl, "on" if g.get(v) else "off") for lbl, v in flags)
    except Exception:
        return ""

def _so_health():
    """Health of native libculprit.so for the 'Show culprits' header.
    state: 'ok' | 'not_loaded' | 'stale' | 'abi_mismatch'."""
    exp = _SO_ABI_EXPECT
    if not _NATIVE_OK or _NLIB is None:
        return {"ok": False, "state": "not_loaded", "abi": None, "expect": exp}
    abi = None
    try:
        if hasattr(_NLIB, "cd_abi_version"):
            abi = int(_NLIB.cd_abi_version())
    except Exception:
        abi = None
    if abi is None:
        return {"ok": False, "state": "stale", "abi": None, "expect": exp}
    if abi != exp:
        return {"ok": False, "state": "abi_mismatch", "abi": abi, "expect": exp}
    return {"ok": True, "state": "ok", "abi": abi, "expect": exp}


def native_mem_snapshot(top=5):
    d = _direct_snapshot()
    if not _NATIVE_OK or _NLIB is None:
        if not d["live_by_pid"] and d["total"] == 0:
            return None
        _pairs_src = dict(d["live_by_pid"])
        if int(d["live_untagged"]) > 0: _pairs_src["⟨untagged⟩"] = int(d["live_untagged"])
        pairs = sorted(_pairs_src.items(), key=lambda kv: kv[1], reverse=True)
        return {
            "total": 0, "untagged": 0, "dropped": 0, "dropped_bytes": -1, "live": 0,
            "direct_total": d["total"], "direct_untagged": d["untagged"],
            "direct_live_total": d["live_total"], "direct_live_untagged": d["live_untagged"],
            "top": pairs[:top],
        }
    try:
        n = len(_IDX_PID)
        arr = (ctypes.c_int64 * max(n, 1))()
        _NLIB.cd_snapshot(arr, n)
        combined = {}
        for i in range(n):
            pid = _resolve_idx(i) or f"idx{i}"
            combined[pid] = combined.get(pid, 0) + int(arr[i])
        for pid, b in d["live_by_pid"].items():
            combined[pid] = combined.get(pid, 0) + int(b)
        _unt = int(d["live_untagged"]) + int(_NLIB.cd_untagged())
        if _unt > 0: combined["⟨untagged⟩"] = combined.get("⟨untagged⟩", 0) + _unt
        pairs = sorted(combined.items(), key=lambda kv: kv[1], reverse=True)
        return {
            "total": int(_NLIB.cd_total()), "untagged": int(_NLIB.cd_untagged()),
            "dropped": int(_NLIB.cd_dropped()), "dropped_bytes": (int(_NLIB.cd_dropped_bytes()) if hasattr(_NLIB,'cd_dropped_bytes') else -1), "live": int(_NLIB.cd_live_count()),
            "direct_total": d["total"], "direct_untagged": d["untagged"],
            "direct_live_total": d["live_total"], "direct_live_untagged": d["live_untagged"],
            "top": pairs[:top],
        }
    except Exception:
        return None

class _CrumbFile:
    NAME = "last_breadcrumb.txt"
    def __init__(self):
        self.path = None; self._lock = threading.Lock()
        try:
            d = File(_DIR)
            if not d.exists(): d.mkdirs()
            self.path = File(d, self.NAME).getAbsolutePath()
        except Exception as e:
            _log(f"crumb init err: {e}")
    def read_prev(self):
        try:
            if self.path and os.path.exists(self.path):
                with open(self.path, "r", encoding="utf-8") as f:
                    return f.read().strip()
        except Exception: pass
        return None
    def write(self, pid, where):
        if not self.path: return
        with self._lock:
            try:
                with open(self.path, "w", encoding="utf-8") as f:
                    f.write(f"{pid}\t{where}\t{int(time.time()*1000)}"); f.flush()
            except Exception: pass
_CRUMB = None

def _known_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _KNOWN_FILE).getAbsolutePath()
    except Exception:
        return None
def _load_known():
    p = _known_path()
    try:
        if p and os.path.exists(p):
            with open(p, "r", encoding="utf-8") as f:
                return list(json.load(f))
    except Exception:
        pass
    return []
def _save_known(pid):
    try:
        cur = set(_load_known())
        if pid in cur: return
        cur.add(pid)
        p = _known_path()
        if not p: return
        _atomic_json_write(p, sorted(cur))
    except Exception:
        pass

def _known_union():
    out = set()
    try:
        out.update(_load_known() or [])
    except Exception:
        pass
    try:
        out.update([n for n in _IDX_PID if isinstance(n, str) and n])
    except Exception:
        pass
    try:
        p = _idxnames_path()
        if p and os.path.exists(p):
            with open(p, "r", encoding="utf-8") as f:
                m = json.load(f)
            if isinstance(m, dict):
                out.update([v for v in m.values() if isinstance(v, str) and v])
    except Exception:
        pass
    return list(out)


def _simple(class_str):
    s = class_str.replace("class ", "").strip()
    for sep in ("$", "."):
        if sep in s: s = s.split(sep)[-1]
    return s
def _tokens(s):
    return set(t for t in re.split(r"[^a-z0-9]+", (s or "").lower()) if len(t) >= 3)
def _is_hook_frame(f):
    if not f: return False
    for m in _HOOK_MARKERS:
        if m in f: return True
    return False
def _is_system_class(cls):
    if not cls: return True
    if "culprit" in cls.lower(): return True
    for p in _SYS_PREFIXES:
        if cls.startswith(p): return True
    return False
def _is_obfuscated(frame):
    parts = (frame or "").split(".")
    if len(parts) < 2: return True
    return all(len(p) <= 2 for p in parts[:-1])
def _short_method(frame):
    parts = (frame or "").split(".")
    return ".".join(parts[-2:]) if len(parts) >= 2 else frame
def _squash(s):
    return re.sub(r"[^a-z0-9]+", "", (s or "").lower())
def _py_module_of(frame):
    if not frame or not frame.startswith(_PY_PREFIX): return None
    rest = frame[len(_PY_PREFIX):]
    if not rest: return None
    return rest.split(".", 1)[0]
def _is_py_runtime_frame(fr):
    if not fr or not fr.startswith(_PY_PREFIX): return False
    low = fr[len(_PY_PREFIX):].lower()
    return any(low == s or low.startswith(s) for s in _PY_SYS_MODS)
def _stack_culprit(frames):
    for fr in frames:
        if _is_system_class(fr): continue
        if _is_hook_frame(fr): continue
        if _is_py_runtime_frame(fr): continue
        if _is_obfuscated(fr): continue
        return fr
    return None
def _pkg_of(frame):
    parts = (frame or "").split(".")
    return ".".join(parts[:3]) if len(parts) >= 3 else frame
def _map_stack_to_id(culprit_frame, known):
    if not culprit_frame or not known: return None
    mod = _py_module_of(culprit_frame)
    sq = _squash(mod) if mod else ""
    if sq:
        for pid in known:
            if _squash(pid) == sq: return pid
        for pid in known:
            ps = _squash(pid)
            if ps and len(ps) >= 4 and (ps in sq or sq in ps): return pid
    ct = _tokens(culprit_frame) - _GENERIC
    if not ct: return None
    best = None; best_score = 0; second = 0
    for pid in known:
        pt = _tokens(pid) - _GENERIC
        score = len(ct & pt)
        if score > best_score:
            second = best_score; best_score = score; best = pid
        elif score > second:
            second = score
    if best_score >= 1 and best_score > second:
        return best
    return None

_REENTRY = threading.local()
_FIRST_LOGGED = False
def _note_first(pid, where):
    global _FIRST_LOGGED
    if _FIRST_LOGGED: return
    _FIRST_LOGGED = True
    _log(f"first breadcrumb captured: pid={pid} where={where!r}")

def _crash_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _CRASH_FILE_NAME).getAbsolutePath()
    except Exception:
        return None
_APP_PRIV_DIR = None
_AW_LOG_SEEN = {}
def _aw_mirror_path(path):
    try:
        pd = _app_priv_dir()
        if not pd: return None
        return os.path.join(pd, os.path.basename(path))
    except Exception:
        return None
def _aw_mirror_list():
    out = []
    try:
        pd = _app_priv_dir()
        if not pd: return out
        names = File(pd).list()
        if names:
            for nm in names:
                try:
                    if nm.endswith(".stage"): continue
                    if not (nm.endswith(".json") or nm.endswith(".txt")): continue
                    out.append(File(pd, nm).getAbsolutePath())
                except Exception: pass
    except Exception: pass
    return out
def _aw_log_once(path, sig, msg):
    try:
        if _AW_LOG_SEEN.get(path) == sig:
            return
        _AW_LOG_SEEN[path] = sig
    except Exception:
        pass
    try: _log(msg)
    except Exception: pass
def _aw_log_clear(path):
    try:
        _AW_LOG_SEEN.pop(path, None)
    except Exception: pass
def _app_priv_dir():
    global _APP_PRIV_DIR
    try:
        if _APP_PRIV_DIR:
            return _APP_PRIV_DIR
    except Exception:
        pass
    d = None
    try:
        ctx = _app_context()
        if ctx is not None:
            base = None
            try: base = ctx.getCacheDir().getAbsolutePath()
            except Exception: base = None
            if not base:
                try: base = ctx.getFilesDir().getAbsolutePath()
                except Exception: base = None
            if base:
                jd = File(base, "culprit_tmp")
                try:
                    if not jd.exists(): jd.mkdirs()
                except Exception: pass
                if jd.exists() and jd.isDirectory():
                    d = jd.getAbsolutePath()
    except Exception:
        d = None
    if d:
        _APP_PRIV_DIR = d
    return d

_FALLBACK_IO_LOCK = threading.Lock()
def _atomic_same_dir_replace(path, text):
    sib = None
    try:
        d = os.path.dirname(path) or "."
        sib = os.path.join(d, os.path.basename(path) + ".fb." + str(os.getpid()) + "." + str(threading.get_ident()))
        with open(sib, "w", encoding="utf-8") as f:
            f.write(text); f.flush()
            try: os.fsync(f.fileno())
            except Exception: pass
        os.replace(sib, path)
        return True
    except Exception:
        if sib:
            try: os.remove(sib)
            except Exception: pass
        return False

def _aw_target_is_precious(path):
    try:
        return os.path.exists(path) and os.path.getsize(path) > 0
    except Exception:
        return False


def _atomic_write_fallback(path, text):
    last_exc = None
    try:
        if _atomic_same_dir_replace(path, text):
            return (True, "sdcard", None)
    except Exception as e:
        last_exc = e
    try:
        if not _aw_target_is_precious(path):
            with open(path, "w", encoding="utf-8") as f3:
                f3.write(text); f3.flush()
                try: os.fsync(f3.fileno())
                except Exception: pass
            return (True, "sdcard", None)
    except Exception as e:
        last_exc = e
    try:
        mp = _aw_mirror_path(path)
        if mp:
            if _atomic_same_dir_replace(mp, text):
                return (True, "app_priv", None)
            if not _aw_target_is_precious(mp):
                with open(mp, "w", encoding="utf-8") as f4:
                    f4.write(text); f4.flush()
                    try: os.fsync(f4.fileno())
                    except Exception: pass
                return (True, "app_priv", None)
    except Exception as e:
        last_exc = e
    return (False, None, last_exc)

def _atomic_json_write_impl(path, data, max_len=None, dedup=False):
    if not path: return False
    try:
        if max_len is not None and isinstance(data, (list, tuple)):
            try:
                if len(data) > max_len: data = data[-max_len:]
            except Exception: pass
    except Exception: pass
    try:
        _text = json.dumps(data, ensure_ascii=False)
    except Exception as e0:
        try: _log("atomic write enc err (%s): %s: %s" % (path, type(e0).__name__, e0))
        except Exception: pass
        return False
    if max_len is not None and not isinstance(data, (list, tuple)):
        try:
            if len(_text) > max_len:
                try: _log("atomic write oversize (%s): %d > %d bytes; skipped" % (path, len(_text), max_len))
                except Exception: pass
                return False
        except Exception: pass
    _vh = None
    if dedup:
        try:
            _vh = hash(_text)
            if _VERDICT_DEDUP.get(path) == _vh:
                return True
        except Exception:
            _vh = None
    try:
        if _VERDICT_NATIVE_OK and _NLIB is not None and _CTYPES_OK and hasattr(_NLIB, "cd_verdict_write"):
            _vb = _text.encode("utf-8")
            _ntmp = path + ".tmp." + str(os.getpid()) + "." + str(threading.get_ident())
            _vrc = int(_NLIB.cd_verdict_write(
                ctypes.c_char_p(_ntmp.encode("utf-8")),
                ctypes.c_char_p(path.encode("utf-8")),
                ctypes.c_char_p(_vb), ctypes.c_int32(len(_vb))))
            if _vrc == 0:
                _aw_log_clear(path)
                if _vh is not None:
                    try: _VERDICT_DEDUP[path] = _vh
                    except Exception: pass
                return True
    except Exception:
        pass
    try:
        tmp = path + ".tmp." + str(os.getpid()) + "." + str(threading.get_ident())
        with open(tmp, "w", encoding="utf-8") as f:
            f.write(_text); f.flush()
            try: os.fsync(f.fileno())
            except Exception: pass
        try:
            os.replace(tmp, path)
        except Exception:
            if _aw_target_is_precious(path):
                try: os.remove(tmp)
                except Exception: pass
                raise
            try:
                with _FALLBACK_IO_LOCK:
                    with open(path, "w", encoding="utf-8") as f2:
                        f2.write(_text); f2.flush()
                        try: os.fsync(f2.fileno())
                        except Exception: pass
            finally:
                try: os.remove(tmp)
                except Exception: pass
        _aw_log_clear(path)
        if _vh is not None:
            try: _VERDICT_DEDUP[path] = _vh
            except Exception: pass
        return True
    except Exception as e1:
        with _FALLBACK_IO_LOCK:
            ok, where, fe = _atomic_write_fallback(path, _text)
        if ok:
            if where == "app_priv":
                _aw_log_once(path, "app_priv", "atomic persist: %s -> app-private mirror (sdcard denied); included in share-logs" % path)
            else:
                _aw_log_clear(path)
            return True
        _aw_log_once(path, "fail", "atomic write err (%s): primary=%s fallback=%s: %s" % (path, type(e1).__name__, (type(fe).__name__ if fe is not None else "n/a"), fe))
        return False

_MOMENT_AUTOCAP_ON = True
_MOMENT_SEEN = {}
_MOMENT_INFLIGHT = set()
_MOMENT_LOCK = threading.Lock()
_MOMENT_SEEN_MAX = 512
_MOMENT_SESSION_MAX = 300
_MOMENT_SESSION_N = 0
_MOMENT_PRE_MS = 8000
_MOMENT_POST_MS = 8000
_MOMENT_MAX_LINES = 800
_MOMENT_MAX_CHARS = 60000
_MOMENT_FRESH_MS = 180000
_MOMENT_STALE_MS = 90000
_MOMENT_RATE_S = 45.0
_MOMENT_FAM_TS = {}
_MOMENT_SKIP = ("client_lowmem.json", "client_trim_unavailable.json", "client_lowmem_unavailable.json", "self_overhead.json")
_MOMENT_SRC_MAP = None

_MOMENT_INDEX_NAME = "culprit_moment_index.json"
_MOMENT_INDEX_MAX = 500
_MOMENT_FILES_MAX = 200
_MOMENT_FILES_BYTES = 25 * 1024 * 1024

def _moment_kind(base):
    try:
        b = base or ""
        if "*" in b:
            return b.split("*", 1)[0].rstrip("_")
        m = _moment_src_map()
        for k in m:
            if "*" in k:
                pre = k.split("*", 1)[0]
                if pre and b.startswith(pre):
                    return pre.rstrip("_")
        return b[:-5] if b.endswith(".json") else b
    except Exception:
        return base

def _moment_event_id(base, center_ms, culprit=None):
    try:
        _eid = "%s_%d" % (_moment_kind(base), int(center_ms))
        if culprit:
            try:
                _eid = "%s_%s" % (_eid, hashlib.sha1(str(culprit).encode("utf-8", "replace")).hexdigest()[:6])
            except Exception:
                pass
        return _eid
    except Exception:
        return "%s_%s" % (base, center_ms)

def _moment_event_prefix(base, center_ms):
    try:
        return "%s_%d" % (_moment_kind(base), int(center_ms))
    except Exception:
        return "%s_%s" % (base, center_ms)

def _moment_filename(base, center_ms, culprit=None):
    return "culprit_moment_%s.txt" % _moment_event_id(base, center_ms, culprit)

def _moment_index_path():
    try:
        return os.path.join(_DIR, _MOMENT_INDEX_NAME)
    except Exception:
        return None

def _moment_index_load():
    paths = []
    try: paths.append(_moment_index_path())
    except Exception: pass
    try: paths.append(_aw_mirror_path(_MOMENT_INDEX_NAME))
    except Exception: pass
    for p in paths:
        if not p:
            continue
        try:
            if os.path.exists(p):
                with open(p, "r", encoding="utf-8", errors="replace") as f:
                    d = json.load(f)
                if isinstance(d, dict):
                    return d
        except Exception:
            continue
    return {}

def _moment_index_upsert(event_id, entry):
    if not event_id:
        return
    try:
        with _MOMENT_LOCK:
            idx = _moment_index_load()
            e = dict(entry or {})
            e["event_id"] = event_id
            idx[event_id] = e
            if len(idx) > _MOMENT_INDEX_MAX:
                try:
                    keys = sorted(idx, key=lambda k: idx[k].get("created_ms", 0))
                    for k in keys[:len(idx) - _MOMENT_INDEX_MAX]:
                        idx.pop(k, None)
                except Exception:
                    pass
            p = _moment_index_path()
            if p:
                _atomic_json_write_impl(p, idx)
    except Exception:
        pass


def _moment_prune_files():
    try:
        import glob as _glob2
        dirs = []
        try: dirs.append(_DIR)
        except Exception: pass
        try:
            _md = _app_priv_dir()
            if _md: dirs.append(_md)
        except Exception: pass
        entries = []
        for d in dirs:
            if not d:
                continue
            try:
                for p in _glob2.glob(os.path.join(d, "culprit_moment_*.txt")):
                    try:
                        st = os.stat(p)
                        entries.append((st.st_mtime, st.st_size, p, os.path.basename(p)))
                    except Exception:
                        pass
            except Exception:
                pass
        if not entries:
            return
        entries.sort(key=lambda e: e[0])
        total = sum(e[1] for e in entries)
        n = len(entries)
        removed = set()
        i = 0
        while i < len(entries) and (n > _MOMENT_FILES_MAX or total > _MOMENT_FILES_BYTES):
            _mt, sz, p, bn = entries[i]
            try:
                os.remove(p)
                removed.add(bn)
                n -= 1
                total -= sz
            except Exception:
                pass
            i += 1
        if removed:
            try:
                with _MOMENT_LOCK:
                    idx = _moment_index_load()
                    ch = False
                    for k in list(idx.keys()):
                        try:
                            f = idx.get(k, {}).get("file")
                            if f and os.path.basename(f) in removed:
                                idx.pop(k, None); ch = True
                        except Exception:
                            pass
                    if ch:
                        _ip = _moment_index_path()
                        if _ip:
                            _atomic_json_write_impl(_ip, idx)
            except Exception:
                pass
    except Exception:
        pass

def _moment_find_existing_path(base, center_ms, culprit=None):

    cands = []
    prefix = None
    try:
        prefix = _moment_event_prefix(base, center_ms)
    except Exception:
        prefix = None
    if culprit:
        try:
            cands.append(_moment_filename(base, center_ms, culprit))
        except Exception:
            pass
    try:
        if prefix:
            idx = _moment_index_load()
            for k in sorted(idx, key=lambda x: idx.get(x, {}).get("created_ms", 0)):
                if k == prefix or k.startswith(prefix + "_"):
                    f = idx.get(k, {}).get("file")
                    if f:
                        cands.append(f)
    except Exception:
        pass
    try:
        if prefix:
            cands.append("culprit_moment_%s.txt" % prefix)
    except Exception:
        pass
    for fn in cands:
        if not fn:
            continue
        try:
            p1 = os.path.join(_DIR, fn)
            if os.path.exists(p1):
                return p1
        except Exception:
            pass
        try:
            mp = _aw_mirror_path(fn)
            if mp and os.path.exists(mp):
                return mp
        except Exception:
            pass
    return None


def _moment_src_map():
    global _MOMENT_SRC_MAP
    if _MOMENT_SRC_MAP is not None:
        return _MOMENT_SRC_MAP
    m = {}
    try:
        for src in _UI_VERDICT_SOURCES:
            try:
                fn, label, emoji, what, gate = src
                m[fn] = (label, emoji, what, gate)
            except Exception:
                pass
    except Exception:
        m = {}
    _MOMENT_SRC_MAP = m
    return m

def _moment_meta_for(base):
    m = _moment_src_map()
    if base in m:
        return m[base]
    for k, v in m.items():
        if "*" in k:
            pre = k.split("*", 1)[0]
            if pre and base.startswith(pre):
                return v
    return None

def _moment_center_ms(d):
    try:
        ts = d.get("ts")
        if isinstance(ts, (int, float)):
            return int(ts if ts > 1e11 else ts * 1000.0)
        if isinstance(ts, str) and ts:
            import time as _t2
            if "-" in ts and ":" in ts:
                return int(_t2.mktime(_t2.strptime(ts, "%Y-%m-%d %H:%M:%S")) * 1000.0)
            f = float(ts)
            return int(f if f > 1e11 else f * 1000.0)
    except Exception:
        return None
    return None

def _moment_culprit(d):
    try:
        c = (d.get("culprit") or d.get("crashed_plugin_id") or d.get("pid")
             or d.get("plugin") or d.get("py_module") or d.get("scoped_pid") or d.get("owner"))
        ck = d.get("culprit_kind")
        if not c and isinstance(ck, str):
            if ck.startswith("plugin:"):
                c = ck.split(":", 1)[1]
            elif ck == "host":
                c = d.get("host_so_owner") or "host"
        if not c:
            for _sub in ("verdict", "gref"):
                try:
                    _sv = d.get(_sub)
                    if isinstance(_sv, dict):
                        _cc = _sv.get("culprit") or _sv.get("owner")
                        if _cc:
                            c = _cc; break
                except Exception:
                    pass
        if not c:
            try:
                _ops = d.get("op_stamps")
                if isinstance(_ops, dict) and _ops:
                    _best = None
                    for _st in _ops.values():
                        if not isinstance(_st, dict): continue
                        _ow = _st.get("owner"); _ag = _st.get("age_ms")
                        if isinstance(_ow, str) and _ow.startswith("#") and _ow[1:].isdigit():
                            _nm = _resolve_idx(int(_ow[1:]))
                            if not (isinstance(_nm, str) and _nm):
                                _nm = _resolve_idx_durable(int(_ow[1:]))
                            _ow = _nm if (isinstance(_nm, str) and _nm) else ""
                        if not _ow or _ow == _SELF_ID or _ow == __id__: continue
                        if _ag is None or _ag < 0 or _ag > _GPU_OP_WINDOW_MS: continue
                        if _best is None or _ag < _best[0]: _best = (_ag, _ow)
                    if _best is not None: c = _best[1]
            except Exception:
                pass
        if not c:
            _ao = d.get("anr_owner")
            c = _ao if not isinstance(_ao, int) else (_ao if _ao >= 0 else None)
        if not c:
            try:
                _oi = int(d.get("owner_idx", -1))
                if _oi >= 0: c = _resolve_idx_durable(_oi)
            except Exception:
                pass
        try:
            if isinstance(c, bool):
                c = None
            elif isinstance(c, (int, float)) and int(c) < 0:
                c = None
            elif isinstance(c, str) and c.strip().lstrip("-").isdigit() and int(c.strip()) < 0:
                c = None
        except Exception:
            pass
        s = str(c).strip() if c else ""
        if "/" in s:
            s = s.rsplit("/", 1)[1]
        if s.endswith(".py"):
            s = s[:-3]
        if not s and d.get("hook_involved"):
            return "хук плагина (не определён)"
        return s or "не определён"
    except Exception:
        return "?"

def _moment_when(center_ms):
    try:
        return time.strftime("%d.%m %H:%M", time.localtime(center_ms / 1000.0))
    except Exception:
        return "-"

def _moment_is_tombstone_dump(lines, min_share=0.7):
    if not lines:
        return False
    _n = 0; _tot = 0
    for ln in lines:
        if not ln.strip():
            continue
        _tot += 1
        if (" F DEBUG " in ln) or (" F libc " in ln) or ("*** *** ***" in ln) or ("beginning of crash" in ln):
            _n += 1
    return _tot > 0 and (float(_n) / float(_tot)) >= min_share

def _moment_is_noise(ln):
    try:
        if "HWUI" in ln and "Image decoding logging dropped" in ln: return True
        if "Choreographer" in ln and "Skipped " in ln and "frames" in ln: return True
    except Exception:
        pass
    return False

def _moment_read_and_slice(center, pre_ms, post_ms, max_lines, max_chars):
    texts = []
    try:
        texts = _b28_read_logcat(prefilter=False)
    except Exception as e:
        try: _log("moment: logcat read err: %s" % e)
        except Exception: pass
    picked = []; total = 0; keep = False; _noise_supp = 0; matched_window = False
    _line_seen = 0; _ts_seen = 0; _newest_ts = None
    for blob in texts:
        for ln in blob.split("\n"):
            if ln.strip(): _line_seen += 1
            ets = _b28_logcat_event_ts(ln)
            if ets is not None:
                _ts_seen += 1
                if _newest_ts is None or ets > _newest_ts: _newest_ts = ets
                keep = (center is not None) and (-pre_ms <= (ets - center) <= post_ms)
            if keep:
                matched_window = True
                if _moment_is_noise(ln):
                    _noise_supp += 1; continue
                picked.append(ln); total += len(ln) + 1
                if len(picked) >= max_lines or total >= max_chars: break
        if len(picked) >= max_lines or total >= max_chars: break
    sealed = (_line_seen > 0 and _ts_seen == 0)
    stale = ((not picked) and _ts_seen > 0 and center is not None and _newest_ts is not None and (center - _newest_ts) > _MOMENT_STALE_MS)
    tail_mode = False
    _all_noise = False
    if not picked and matched_window:
        _all_noise = True
        picked = ["        … [+KP3] все строки окна были шумом HWUI/Choreographer: %d" % _noise_supp]
    if not picked:
        tail_mode = True
        allln = []
        for blob in texts:
            allln.extend(blob.split("\n"))
        picked = allln[-300:]
    if picked and not tail_mode and not _all_noise and _noise_supp > 0:
        picked.append("        … [+KP3] отфильтровано %d шумовых строк (HWUI/Choreographer) до лимита max_lines" % _noise_supp)
    return picked, tail_mode, sealed, stale

def _moment_write_text(target, body):
    try:
        with open(target, "w", encoding="utf-8", errors="replace") as f:
            f.write(body)
        return True
    except Exception:
        try:
            mp = _aw_mirror_path(target)
            if mp:
                with open(mp, "w", encoding="utf-8", errors="replace") as f:
                    f.write(body)
                return True
        except Exception:
            pass
    return False

def _breadcrumb_slice(center_ms, pre_ms, post_ms, max_lines=400):
    path = _LOG_PATH
    if not path:
        return []
    try:
        with open(path, "r", encoding="utf-8", errors="replace") as f:
            _lines = f.read().splitlines()
    except Exception:
        return []
    try:
        _lt = time.localtime(center_ms / 1000.0)
        _midnight = center_ms - ((_lt.tm_hour * 3600 + _lt.tm_min * 60 + _lt.tm_sec) * 1000) - (center_ms % 1000)
    except Exception:
        return []
    out = []
    for ln in _lines:
        if len(ln) < 10 or ln[0] != "[" or ln[3] != ":" or ln[6] != ":" or ln[9] != "]":
            continue
        try:
            _hh = int(ln[1:3]); _mm = int(ln[4:6]); _ss = int(ln[7:9])
        except Exception:
            continue
        ets = _midnight + (_hh * 3600 + _mm * 60 + _ss) * 1000
        d = ets - center_ms
        if d > post_ms + 43200000:
            ets -= 86400000; d = ets - center_ms
        elif d < -(pre_ms + 43200000):
            ets += 86400000; d = ets - center_ms
        if -pre_ms <= d <= post_ms:
            out.append(ln)
            if len(out) >= max_lines:
                break
    return out


_HZ_FB_KEYS = ("event_type", "reason", "where", "confidence", "src", "culprit_kind", "stalled_ms", "trim_level", "throws_per_min", "throws_in_window", "exc_cls", "exc_msg", "cause", "top_so", "signo", "py_file", "py_line", "symbol")


def _hz_moment_fallback(rec):
    out = [_cd_tr("(logcat пуст — снимок из вердикта)")]
    if not isinstance(rec, dict):
        return out
    for _k in _HZ_FB_KEYS:
        _v = rec.get(_k)
        if _v is not None and _v != "" and _v != -1:
            out.append("%s=%s" % (_k, _v))
    _vd = rec.get("verdict")
    if isinstance(_vd, dict):
        for _k in ("culprit", "top_named", "culprit_bytes", "top_named_bytes"):
            _vv = _vd.get(_k)
            if _vv is not None and _vv != "":
                out.append("verdict.%s=%s" % (_k, _vv))
    _mem = rec.get("mem")
    if isinstance(_mem, dict) and _mem.get("pct") is not None:
        out.append("mem.pct=%s used=%s limit=%s" % (_mem.get("pct"), _mem.get("used"), _mem.get("limit")))
    _top = rec.get("top")
    if isinstance(_top, list) and _top:
        out.append("top_alloc:")
        for _e in _top[:6]:
            try:
                out.append("  %s=%s" % (_e[0], _e[1]))
            except Exception:
                out.append("  %s" % (_e,))
    _st = rec.get("stack")
    if isinstance(_st, list) and _st:
        out.append("stack:")
        for _s in _st[:12]:
            out.append("  %s" % (_s,))
    _ct = rec.get("cpu_top")
    if isinstance(_ct, list) and _ct:
        out.append("cpu_top:")
        for _t in _ct[:8]:
            try:
                out.append("  %s %.1f%% owner=%s" % (_t.get("name"), float(_t.get("pct") or 0), _t.get("owner")))
            except Exception:
                out.append("  %s" % (_t,))
    return out


_MOMENT_DEDUP_MIN_RUN = 3

def _moment_logline_key(ln):
    try:
        parts = ln.split(None, 5)
        if (len(parts) >= 6 and len(parts[0]) == 5 and parts[0][2] == "-"
                and ":" in parts[1] and parts[2].isdigit() and parts[3].isdigit()
                and len(parts[4]) == 1):
            return parts[4] + " " + parts[5]
    except Exception:
        pass
    return ln.strip()

def _moment_dedup_lines(lines, min_run=None):
    if min_run is None:
        min_run = _MOMENT_DEDUP_MIN_RUN
    out = []; removed = 0
    i = 0; n = len(lines)
    while i < n:
        key = _moment_logline_key(lines[i])
        j = i + 1
        while j < n and _moment_logline_key(lines[j]) == key:
            j += 1
        run = j - i
        if run >= min_run:
            out.append(lines[i])
            out.append("        … ×%d (dedup: %s)" % (run, key[:80]))
            removed += run - 2
        else:
            out.extend(lines[i:j])
        i = j
    return out, removed


def _moment_capture_worker(key, base, label, emoji, culprit, center, rec=None):
    global _MOMENT_SESSION_N
    try:
        fn = _moment_filename(base, center, culprit)
        target = os.path.join(_DIR, fn)
        event_id = _moment_event_id(base, center, culprit)
        if os.path.exists(target):
            _moment_index_upsert(event_id, {"file": fn, "source": base, "culprit": culprit, "label": label, "center_ms": int(center), "created_ms": int(time.time() * 1000)})
            return
        picked, tail, _iw_sealed, _iy_stale = _moment_read_and_slice(center, _MOMENT_PRE_MS, _MOMENT_POST_MS,
                                              _MOMENT_MAX_LINES, _MOMENT_MAX_CHARS)
        head = ["Culprit Detector — %s" % _cd_tr("логи момента"),
                "%s %s" % (emoji or "", _cd_tr(label) or "-"),
                _cd_tr("Виноват: %s") % culprit,
                _cd_tr("Когда: %s") % _moment_when(center),
                "crash_ts=%d  window=-%dms/+%dms" % (center, _MOMENT_PRE_MS, _MOMENT_POST_MS),
                "event_id=%s  source=%s" % (event_id, base)]
        _hz_empty = not picked
        _iy_tomb = (tail and (not _hz_empty) and _moment_is_tombstone_dump(picked))
        _use_fb = _hz_empty or _iw_sealed or _iy_stale or _iy_tomb
        try:
            _MOMENT_FAM_TS[(base, culprit)] = (time.time(), bool(_use_fb))
        except Exception:
            pass
        if tail and not _use_fb:
            head.append(_cd_tr("(точное время не найдено — показан хвост logcat)"))
        head.append("[+HV auto-capture @ confirm]")
        if _hz_empty:
            head.append("[+HZ] logcat ring empty (lines=0) - verdict fallback")
        if _iw_sealed:
            head.append("[+IW] logcat sealed by host ((HKS)..(HKE), no threadtime) - verdict+breadcrumb fallback")
        if _iy_stale:
            head.append("[+IY] logcat stale (newest ts older than window) - verdict+breadcrumb fallback")
        if _iy_tomb:
            head.append("[+IY] logcat tail is tombstone/crash-buffer dump - verdict+breadcrumb fallback")
        _dd_lines = picked; _dd_removed = 0
        if picked and not _use_fb:
            try:
                _dd_lines, _dd_removed = _moment_dedup_lines(picked)
            except Exception:
                _dd_lines = picked; _dd_removed = 0
            if _dd_removed > 0:
                head.append("[+IX] dedup: свёрнуто %d повторяющихся строк (анти-спам)" % _dd_removed)
        head.append("=" * 60)
        _hz_body_lines = _hz_moment_fallback(rec) if _use_fb else _dd_lines
        if _use_fb:
            _iw_bc = _breadcrumb_slice(center, _MOMENT_PRE_MS, _MOMENT_POST_MS)
            if _iw_bc:
                _hz_body_lines = list(_hz_body_lines) + ["", "breadcrumb (+/-window):"] + _iw_bc
        if base in ("native_crash_verdict.json", "native_crash_history.json") and isinstance(rec, dict):
            _hz_body_lines = list(_hz_body_lines) + _native_crash_moment_evidence(rec)
        body = "\n".join(head) + "\n" + "\n".join(_hz_body_lines)
        if _moment_write_text(target, body):
            _moment_index_upsert(event_id, {"file": fn, "source": base, "culprit": culprit, "label": label, "center_ms": int(center), "created_ms": int(time.time() * 1000), "lines": len(picked), "tail": bool(tail), "empty": bool(_hz_empty), "fallback": bool(_use_fb), "sealed": bool(_iw_sealed)})
            try: _moment_prune_files()
            except Exception: pass
            try: _log("+HV: auto-moment -> %s (lines=%d%s)" % (fn, len(picked), ", tail" if tail else ""))
            except Exception: pass
    except Exception as e:
        try: _log("+HV moment worker err: %s" % e)
        except Exception: pass
    finally:
        with _MOMENT_LOCK:
            _MOMENT_INFLIGHT.discard(key)
            try:
                _MOMENT_SEEN[key] = time.time()
                if len(_MOMENT_SEEN) > _MOMENT_SEEN_MAX:
                    for _k in sorted(_MOMENT_SEEN, key=lambda x: _MOMENT_SEEN[x])[:len(_MOMENT_SEEN) - _MOMENT_SEEN_MAX]:
                        _MOMENT_SEEN.pop(_k, None)
            except Exception:
                pass

def _moment_autocap(path, data):
    global _MOMENT_SESSION_N
    if not _MOMENT_AUTOCAP_ON:
        return
    try:
        base = os.path.basename(path or "")
        if not base or not base.endswith(".json"):
            return
        if base in _MOMENT_SKIP:
            return
        meta = _moment_meta_for(base)
        if not meta:
            return
        label, emoji, _, gate = meta
        now_ms = time.time() * 1000.0
        items = data if isinstance(data, list) else [data]
        for it in items:
            try:
                if not isinstance(it, dict):
                    continue
                if bool(it.get("benign_restart")):
                    continue
                if gate and not any(bool(it.get(g)) for g in gate):
                    continue
                ck = it.get("culprit_kind")
                is_native = base in ("native_crash_verdict.json", "native_crash_history.json")
                if isinstance(ck, str) and ck == "system" and not is_native:
                    continue
                center = _moment_center_ms(it)
                if not center:
                    continue
                if center > now_ms + 5000.0 or (now_ms - center) > _MOMENT_FRESH_MS:
                    continue
                culprit = _moment_culprit(it)
                key = _moment_event_id(base, center, culprit)
                try:
                    _ft, _ffb = _MOMENT_FAM_TS.get((base, culprit), (0.0, False))
                    if _ffb and (time.time() - _ft) < _MOMENT_RATE_S and base not in ("native_crash_verdict.json", "native_crash_history.json"):
                        continue
                except Exception:
                    pass
                with _MOMENT_LOCK:
                    if key in _MOMENT_SEEN or key in _MOMENT_INFLIGHT:
                        continue
                    if _MOMENT_SESSION_N >= _MOMENT_SESSION_MAX:
                        continue
                    _MOMENT_INFLIGHT.add(key)
                    _MOMENT_SESSION_N += 1
                try:
                    threading.Thread(target=_moment_capture_worker,
                                     args=(key, base, label, emoji, culprit, center, it),
                                     name="culprit-moment", daemon=True).start()
                except Exception:
                    with _MOMENT_LOCK:
                        _MOMENT_INFLIGHT.discard(key)
            except Exception:
                continue
    except Exception:
        pass

def _extras_real_path(p):
    try:
        if os.path.exists(p):
            return p
    except Exception:
        pass
    try:
        mp = _aw_mirror_path(p)
        if mp and os.path.exists(mp):
            return mp
    except Exception:
        pass
    return None

def _send_logs_extras(names):

    out = []
    _errs = []
    try:
        texts = []
        try:
            texts = _b28_read_logcat(prefilter=False)
        except Exception as e:
            _errs.append("logcat_read: %s" % e)
        allln = []
        for blob in (texts or []):
            allln.extend(blob.split("\n"))
        tail = allln[-1200:]
        body = ("Culprit Detector send-logs current logcat\ncaptured=%s\nlines=%d\n%s\n" %
                (time.strftime("%Y-%m-%d %H:%M:%S", time.localtime()), len(tail), "=" * 60)) + "\n".join(tail)
        _p = os.path.join(_DIR, "send_logs_current_logcat.txt")
        if _moment_write_text(_p, body):
            _rp = _extras_real_path(_p)
            if _rp:
                out.append(_rp)
    except Exception as e:
        _errs.append("current_logcat: %s" % e)
    try:
        nm2 = list(names or [])
        nm2.append("send_logs_current_logcat.txt")
        nm2.append("archive_manifest.json")
        seen = set(); nmu = []
        for x in nm2:
            if x not in seen:
                seen.add(x); nmu.append(x)
        moment = [x for x in nmu if x.startswith("culprit_moment_") and x.endswith(".txt")]
        verdict = [x for x in nmu if x.endswith(".json")]
        native = {
            "abi_expect": _SO_ABI_EXPECT,
            "native_ok": bool(_NATIVE_OK),
            "oom": bool(_OOM_NATIVE_OK), "anr": bool(_ANR_NATIVE_OK),
            "gref": bool(_GREF_NATIVE_OK), "smaps": bool(_SMAPS_NATIVE_OK),
        }
        man = {
            "detector_version": __version__,
            "archived_at": time.strftime("%Y-%m-%d %H:%M:%S", time.localtime()),
            "archived_ms": int(time.time() * 1000),
            "file_count": len(nmu),
            "verdict_file_count": len(verdict),
            "moment_snapshot_count": len(moment),
            "files": sorted(nmu),
            "moment_snapshots": sorted(moment),
            "native_lib": native,
            "errors": _errs,
        }
        _pm = os.path.join(_DIR, "archive_manifest.json")
        if _moment_write_text(_pm, json.dumps(man, ensure_ascii=False, indent=2)):
            _rpm = _extras_real_path(_pm)
            if _rpm:
                out.append(_rpm)
    except Exception as e:
        try: _log("send_logs: manifest err: %s" % e)
        except Exception: pass
    return out

def _atomic_json_write(path, data, max_len=None, dedup=False):

    _ok = _atomic_json_write_impl(path, data, max_len, dedup)
    if _ok:
        try: _moment_autocap(path, data)
        except Exception: pass
    return _ok


_VW_Q = {}
_VW_LOCK = threading.Lock()
_VW_EVENT = threading.Event()
_VW_THREAD = None
_VW_STOP = None
_VW_FLUSH_S = 0.2
_VW_MAX_PATHS = 256

_VW_STATS = {"enqueued": 0, "coalesced": 0, "sync_fallback": 0, "written": 0, "drained": 0, "max_qlen": 0}

def _vw_stats_snapshot():
    try:
        with _VW_LOCK:
            s = dict(_VW_STATS)
            s["qlen"] = len(_VW_Q)
            s["alive"] = bool(_VW_THREAD is not None and _VW_THREAD.is_alive())
        return s
    except Exception:
        return None

def _enqueue_verdict_write(path, data, max_len=None, dedup=False):
    if not path:
        return False
    t = _VW_THREAD
    if t is None or not t.is_alive():
        with _VW_LOCK:
            _VW_STATS["sync_fallback"] += 1
        return _atomic_json_write(path, data, max_len, dedup)
    try:
        _sat = False
        with _VW_LOCK:
            if path not in _VW_Q and len(_VW_Q) >= _VW_MAX_PATHS:
                _VW_STATS["sync_fallback"] += 1
                _sat = True
            else:
                if path in _VW_Q:
                    _VW_STATS["coalesced"] += 1
                _VW_Q[path] = (data, max_len, dedup)
                _VW_STATS["enqueued"] += 1
                _ql = len(_VW_Q)
                if _ql > _VW_STATS["max_qlen"]:
                    _VW_STATS["max_qlen"] = _ql
        if _sat:
            return _atomic_json_write(path, data, max_len, dedup)
        _VW_EVENT.set()
        return True
    except Exception:
        with _VW_LOCK:
            _VW_STATS["sync_fallback"] += 1
        return _atomic_json_write(path, data, max_len, dedup)

def _vw_drain_once():
    with _VW_LOCK:
        if not _VW_Q:
            return
        batch = list(_VW_Q.items())
        _VW_Q.clear()
        _VW_STATS["drained"] += 1
        _VW_STATS["written"] += len(batch)
    for _p, _args in batch:
        try:
            _atomic_json_write(_p, _args[0], _args[1], _args[2])
        except Exception:
            pass

def _verdict_writer_loop(stop_evt):
    while not stop_evt.is_set():
        try:
            _VW_EVENT.wait(_VW_FLUSH_S)
            _VW_EVENT.clear()
            _vw_drain_once()
        except Exception:
            try: time.sleep(_VW_FLUSH_S)
            except Exception: pass
    _vw_drain_once()

def _vw_start():
    global _VW_THREAD, _VW_STOP
    try:
        if _VW_THREAD is not None and _VW_THREAD.is_alive():
            return
        _VW_STOP = threading.Event()
        _VW_THREAD = threading.Thread(target=_verdict_writer_loop, args=(_VW_STOP,), name="culprit-verdict-writer", daemon=True)
        _VW_THREAD.start()
        try:
            _log("+DJ verdict-writer запущен: thread=culprit-verdict-writer flush=%.1fs max_paths=%d (vw-телеметрия +DM)" % (_VW_FLUSH_S, _VW_MAX_PATHS))
        except Exception:
            pass
    except Exception as e:
        _VW_THREAD = None
        try: _log("verdict-writer start err: %r" % e)
        except Exception: pass

def _vw_stop():
    global _VW_THREAD
    try:
        if _VW_STOP is not None: _VW_STOP.set()
        _VW_EVENT.set()
        t = _VW_THREAD
        if t is not None:
            try: t.join(1.0)
            except Exception: pass
    except Exception:
        pass
    finally:
        try: _vw_drain_once()
        except Exception: pass
        _VW_THREAD = None

def _write_crash_verdict(rec):
    p = _crash_path()
    if not p: return
    try:
        rec.setdefault("event_type", "app_crash"); rec.setdefault("dropbox_tag", "data_app_crash")
        rec.setdefault("tombstone_norm_version", 1); rec.setdefault("persisted", False)
    except Exception: pass
    try:
        if _is_safemode_collateral(rec.get("exc_cls"), rec.get("exc_msg")):
            _victim = rec.get("crashed_plugin_id")
            rec["safe_mode_collateral"] = True
            rec["safemode_victim"] = _victim
            _corr = rec.get("correlated") or {}
            _root = _corr.get("culprit")
            if _root and _root != _victim and _corr.get("confidence") in ("high", "medium"):
                rec["crashed_plugin_id"] = _root
                rec["src"] = "safe-mode-collateral->corr-root"
                rec["confidence"] = _corr.get("confidence")
            else:
                rec["crashed_plugin_id"] = "safe-mode-collateral"
                rec["src"] = "safe-mode-collateral"
                rec["confidence"] = "none"
            rec["culprit_kind"] = "collateral"
            rec["reason"] = _SAFEMODE_COLLATERAL_REASON
    except Exception: pass
    try:
        _cx = rec.get("crashed_plugin_id") or rec.get("culprit")
        if _cx and _cx not in ("safe-mode-collateral", "unknown", "none"):
            _b10_passive_mark_recent_owner_force(_cx, rec.get("ts"), "native_crash_owner")
    except Exception: pass
    _atomic_json_write(p, rec)

_LOAD_FILE_NAME = "load_verdict.json"
_LOAD_FAILS_MAX = 20
_LOAD_DEDUP_MS = 4000
_LOAD_SEEN = {}; _LOAD_SEEN_LOCK = threading.Lock()
_PY_PREFIX = "<python>."
_PY_SYS_MODS = ("importlib", "java.chaquopy", "java.", "chaquopy_java",
                "_sdk_version", "encodings.", "<frozen", "base_plugin")

def _load_verdict_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _LOAD_FILE_NAME).getAbsolutePath()
    except Exception:
        return None

def _thr_chain(thr):
    out = []; n = 0; cur = thr
    while cur is not None and n < 12:
        n += 1
        try: cls = cur.getClass().getName()
        except Exception: cls = "?"
        try: msg = cur.getMessage()
        except Exception: msg = None
        out.append((cls, msg, cur))
        try: nxt = cur.getCause()
        except Exception: nxt = None
        if nxt is cur: break
        cur = nxt
    return out

def _py_module_from_throwable(chain):
    for (_c, _m, exc) in chain:
        try: st = exc.getStackTrace()
        except Exception: st = None
        if st is None: continue
        for el in st:
            try:
                cn = el.getClassName() or ""
                mn = el.getMethodName() or ""
                fn = el.getFileName() or ""
                ln = el.getLineNumber()
            except Exception:
                continue
            if not cn.startswith(_PY_PREFIX): continue
            if mn != "<module>": continue
            mod = cn[len(_PY_PREFIX):]
            low = mod.lower()
            if any(low == s or low.startswith(s) for s in _PY_SYS_MODS): continue
            return mod, (fn or (mod + ".py")), (int(ln) if ln is not None else -1)
    return None, None, -1

def _load_reason(chain):
    for (cls, msg, _e) in reversed(chain):
        if msg:
            scls = cls.rsplit(".", 1)[-1] if cls else "?"
            return ("%s: %s" % (scls, msg)) if (scls and scls not in (msg or "")) else msg
    for (cls, _m, _e) in reversed(chain):
        if cls and cls != "?":
            return cls.rsplit(".", 1)[-1]
    return "unknown"

_MEM_PRESSURE_REASON = "🧠 Python MemoryError — процесс исчерпал память (Python-куча); стек мог не сформироваться"
def _is_py_memoryerror(exc_cls, exc_msg):
    try:
        ec = str(exc_cls or ""); em = str(exc_msg or "")
        return ("MemoryError" in ec) or ("MemoryError" in em)
    except Exception:
        return False


_SAFEMODE_COLLATERAL_REASON = "safe-mode collateral — плагин заблокирован SafeModeImporter (жертва, не причина); корень — плагин, вызвавший safe-mode"
def _is_safemode_collateral(exc_cls, exc_msg):
    try:
        ec = str(exc_cls or ""); em = str(exc_msg or "")
        return ("Safe mode enabled" in em) or ("Safe mode enabled" in ec) or ("SafeModeImporter" in em)
    except Exception:
        return False


def _record_load_fail(scoped_pid, thr, where):
    try: chain = _thr_chain(thr)
    except Exception: chain = []
    py_mod, py_file, py_line = _py_module_from_throwable(chain)
    reason = _load_reason(chain)
    top_cls = chain[0][0] if chain else "?"
    top_msg = chain[0][1] if chain else None
    if where == "loadPlugin" and scoped_pid:
        culprit = scoped_pid; src = "scope/loadPlugin"; conf = "high" if py_mod else "medium"
    elif py_mod:
        culprit = py_mod; src = "py-frame"; conf = "high"
    elif scoped_pid:
        culprit = scoped_pid; src = "scope/" + where; conf = "medium"
    else:
        culprit = "unknown"; src = "none"; conf = "low"
    rec = {"had_load_fail": True, "event_type": "plugin_load_exception", "dropbox_tag": "plugin_load_blocked", "tombstone_norm_version": 1, "culprit": culprit, "src": src, "confidence": conf,
           "where": where, "scoped_pid": scoped_pid, "py_module": py_mod,
           "py_file": py_file, "py_line": py_line, "reason": reason,
           "exc_cls": top_cls, "exc_msg": top_msg, "ts": int(time.time() * 1000)}
    if _is_py_memoryerror(top_cls, top_msg) or ("MemoryError" in (reason or "")):
        rec["mem_pressure"] = True; rec["reason"] = _MEM_PRESSURE_REASON; reason = rec["reason"]
    key = "%s|%s|%s" % (culprit, reason, where); now = rec["ts"]
    with _LOAD_SEEN_LOCK:
        if now - _LOAD_SEEN.get(key, 0) < _LOAD_DEDUP_MS: return
        _LOAD_SEEN[key] = now
    try: _load_verdict_log(rec, "live")
    except Exception: pass
    try: _persist_load_fail(rec)
    except Exception: pass

_PERSIST_IO_LOCK = __import__("threading").Lock()


def _persist_load_fail(rec):
    p = _load_verdict_path()
    if not p: return
    _PERSIST_IO_LOCK.acquire()
    try:
        cur = []
        if os.path.exists(p):
            try:
                with open(p, "r", encoding="utf-8") as f: cur = list(json.load(f))
            except Exception: cur = []
        cur.append(rec)
        _atomic_json_write(p, cur, _LOAD_FAILS_MAX)
    except Exception: pass
    finally:
        try: _PERSIST_IO_LOCK.release()
        except Exception: pass

_RC_PROC_START = time.time()

def _rc_rearm_orphan(base):
    if not base: return
    proc = base + ".processing"
    try:
        if os.path.exists(base): return
        if not os.path.exists(proc): return
        if os.path.getmtime(proc) >= _RC_PROC_START: return
        os.rename(proc, base)
    except Exception:
        pass

def _rc_read_path(p):
    try:
        mp = _aw_mirror_path(p) if p else None
    except Exception:
        mp = None
    _rc_rearm_orphan(p)
    if mp: _rc_rearm_orphan(mp)
    try: pe = bool(p) and os.path.exists(p)
    except Exception: pe = False
    try: me = bool(mp) and os.path.exists(mp)
    except Exception: me = False
    if pe and me:
        try:
            if os.path.getmtime(mp) > os.path.getmtime(p): return mp
        except Exception: pass
        return p
    if pe: return p
    if me: return mp
    return None

def _rc_remove_both(p):
    if not p: return
    try: mp = _aw_mirror_path(p)
    except Exception: mp = None
    for _fp in (p, mp):
        try:
            if _fp and os.path.exists(_fp): os.remove(_fp)
        except Exception: pass

def _rc_take_path(p):
    if not p: return None
    _PERSIST_IO_LOCK.acquire()
    try:
        rp = _rc_read_path(p)
        if not rp: return None
        try: mp = _aw_mirror_path(p)
        except Exception: mp = None
        try: _claim_m = os.path.getmtime(rp)
        except Exception: _claim_m = None
        tmp = rp + ".processing"
        try:
            os.rename(rp, tmp); claimed = tmp
        except Exception:
            return None
        _other = p if rp != p else mp
        if _other and _other != rp:
            try:
                if os.path.exists(_other) and (_claim_m is None or os.path.getmtime(_other) <= _claim_m):
                    os.remove(_other)
            except Exception: pass
        return claimed
    finally:
        try: _PERSIST_IO_LOCK.release()
        except Exception: pass

def _read_and_clear_load_fails():
    p = _load_verdict_path()
    if not p: return []
    out = []
    _rp = _rc_take_path(p)
    try:
        if _rp:
            with open(_rp, "r", encoding="utf-8") as f: out = list(json.load(f))
    except Exception: out = []
    if _rp:
        try: os.remove(_rp)
        except Exception: pass
    return out

def _load_verdict_log(rec, when):
    try:
        _log("============= LOAD/IMPORT VERDICT (%s) =============" % when)
        cul = rec.get("culprit"); conf = rec.get("confidence")
        if cul and cul != "unknown":
            _log("ВИНОВНИК ЗАГРУЗКИ: %r conf=%s where=%s src=%s" % (cul, conf, rec.get("where"), rec.get("src")))
        else:
            _log("ВИНОВНИК ЗАГРУЗКИ: неизвестен (where=%s) — нет имени модуля в стеке" % rec.get("where"))
        _log("  причина: %s" % rec.get("reason"))
        pf = rec.get("py_file")
        if pf: _log("  модуль: %s:%s" % (pf, rec.get("py_line")))
        sp = rec.get("scoped_pid")
        if sp and sp != cul: _log("  scope-плагин(loadPlugin-арг): %s" % sp)
        _log("  исключение: %s: %s" % (rec.get("exc_cls"), rec.get("exc_msg")))
        _log("====================================================")
    except Exception: pass
_HOOK_FILE_NAME = "hook_verdict.json"
_HOOK_FAILS_MAX = 20
_HOOK_DEDUP_MS = 4000
_HOOK_SEEN = {}; _HOOK_SEEN_LOCK = threading.Lock()
_BLOCK9_ON = True

def _hook_verdict_path():
    try:
        d = File(_DIR)
        if not d.exists(): d.mkdirs()
        return File(d, _HOOK_FILE_NAME).getAbsolutePath()
    except Exception:
        return None

def _hook_scope_pid():
    try:
        c = get_culprit_for_tid(_cur_tid())
        if c and c != "unknown": return c
    except Exception: pass
    return None

def _record_hook_fail(thr, where="executeHook", scoped=None):
    if not _BLOCK9_ON: return
    try: chain = _thr_chain(thr)
    except Exception: chain = []
    if not chain: return
    py_mod, py_file, py_line = _py_module_from_throwable(chain)
    reason = _load_reason(chain)
    top_cls = chain[0][0] if chain else "?"
    top_msg = chain[0][1] if chain else None
    if scoped is None: scoped = _hook_scope_pid()
    if py_mod:
        culprit = py_mod; src = "py-frame"; conf = "high"
    elif scoped:
        culprit = scoped; src = "scope/" + where; conf = "medium"
    else:
        culprit = "unknown"; src = "none"; conf = "low"
    rec = {"had_hook_fail": True, "culprit": culprit, "src": src, "confidence": conf,
           "where": where, "scoped_pid": scoped, "py_module": py_mod,
           "py_file": py_file, "py_line": py_line, "reason": reason,
           "exc_cls": top_cls, "exc_msg": top_msg, "ts": int(time.time() * 1000)}
    key = "%s|%s|%s" % (culprit, reason, where); now = rec["ts"]
    with _HOOK_SEEN_LOCK:
        if now - _HOOK_SEEN.get(key, 0) < _HOOK_DEDUP_MS: return
        _HOOK_SEEN[key] = now
    try: _hook_verdict_log(rec, "live")
    except Exception: pass
    try: _persist_hook_fail(rec)
    except Exception: pass

def _persist_hook_fail(rec):
    p = _hook_verdict_path()
    if not p: return
    _PERSIST_IO_LOCK.acquire()
    try:
        cur = []
        if os.path.exists(p):
            try:
                with open(p, "r", encoding="utf-8") as f: cur = list(json.load(f))
            except Exception: cur = []
        try:
            rec.setdefault("event_type", "hook_exception"); rec.setdefault("dropbox_tag", "data_app_crash"); rec.setdefault("tombstone_norm_version", 1)
        except Exception: pass
        cur.append(rec)
        _atomic_json_write(p, cur, _HOOK_FAILS_MAX)
    except Exception: pass
    finally:
        try: _PERSIST_IO_LOCK.release()
        except Exception: pass

def _read_and_clear_hook_fails():
    p = _hook_verdict_path()
    if not p: return []
    out = []
    _rp = _rc_take_path(p)
    try:
        if _rp:
            with open(_rp, "r", encoding="utf-8") as f: out = list(json.load(f))
    except Exception: out = []
    if _rp:
        try: os.remove(_rp)
        except Exception: pass
    return out

def _hook_verdict_log(rec, when):
    try:
        _log("============= RUNTIME HOOK VERDICT (%s) =============" % when)
        cul = rec.get("culprit"); conf = rec.get("confidence")
        if cul and cul != "unknown":
