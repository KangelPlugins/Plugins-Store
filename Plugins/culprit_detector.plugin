                        if _tb.get("match_score") is not None:
                            rec["tombstone_match_score"] = int(_tb["match_score"])
                    except Exception:
                        pass
                    rec["tombstone_norm_version"] = 2
                    _log("Block#4C +MT: debuggerd tombstone symbolized (thread=%r top=%r frames=%d skew=%s subtype=%r)"
                         % (rec.get("crash_thread_name"), rec.get("tombstone_top_symbol"),
                            len(_mt_sym), rec.get("inproc_base_skew_hex"), rec.get("native_subtype")))
                elif rec.get("corroboration") is None:
                    rec["corroboration"] = "inprocess_only"
        except Exception as _emt:
            _log("Block#4C +MT tombstone-mine err: %s" % _emt)
        try:
            if rec.get("confidence") is None and rec.get("culprit_kind") == "system" and rec.get("pid") is None:
                _resolved_any = any(("+0x" in _fr) for _fr in (rec.get("frames") or []))
                if rec.get("symbolized_by") == "debuggerd":
                    _tsym = rec.get("tombstone_top_symbol") or "?"
                    _tthr = rec.get("crash_thread_name") or "?"
                    if rec.get("managed_interpreter_fault"):
                        _ureason = "managed-metadata corruption: fault in ART interpreter (%s) on thread %r -- corrupted class/field pointer (native/JNI/hook misuse), not plugin-attributable [debuggerd-symbolized]" % (_tsym, _tthr)
                    else:
