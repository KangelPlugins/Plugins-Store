__id__ = "reactions_below"
__name__ = "Reactions Below"
__description__ = """Перемещает панель реакций под меню сообщения.
Moves reactions bar below the message menu.
Thx inogram."""
__author__ = "@RnPlugins"
__version__ = "1.0.0"
__icon__ = "RnDev/15"
__app_version__ = ">=12.5.1"
__sdk_version__ = ">=1.4.3.3"

import base64
from base_plugin import BasePlugin
from java.nio import ByteBuffer
from dalvik.system import InMemoryDexClassLoader
from org.telegram.messenger import ApplicationLoader

DEX_B64 = """"""

class ReactionsBelowPlugin(BasePlugin):
    def on_plugin_load(self):
        try:
            self.log("Loading Java ReactionsBelow module...")
            dex_bytes = base64.b64decode(DEX_B64)
            buffer = ByteBuffer.wrap(dex_bytes)
            parent_cl = ApplicationLoader.applicationContext.getClassLoader()
            self.dex_loader = InMemoryDexClassLoader(buffer, parent_cl)
            self.dex_class = self.dex_loader.loadClass("dev.rooni.reactionsbelow.ReactionsBelow")
            
            start_method = self.dex_class.getMethod("start")
            start_method.invoke(None)
            self.log("Java ReactionsBelow module loaded and started successfully.")
        except Exception as e:
            self.log(f"Failed to load Java ReactionsBelow module: {e}")

    def on_plugin_unload(self):
        try:
            self.log("Unloading Java ReactionsBelow module...")
            if hasattr(self, "dex_class") and self.dex_class is not None:
                stop_method = self.dex_class.getMethod("stop")
                stop_method.invoke(None)
                self.log("Java ReactionsBelow module stopped successfully.")
            self.dex_class = None
            self.dex_loader = None
        except Exception as e:
            self.log(f"Failed to unload Java ReactionsBelow module: {e}")
