    def _add_switch_row(self, container: Any, context: Any, switch_view: Any, top_margin_dp: int):
        ViewGroupLayoutParams = jclass("android.view.ViewGroup$LayoutParams")
        LinearLayoutParams = jclass("android.widget.LinearLayout$LayoutParams")
        row_lp = LinearLayoutParams(ViewGroupLayoutParams.MATCH_PARENT, ViewGroupLayoutParams.WRAP_CONTENT)
        row_lp.setMargins(0, self._dp(top_margin_dp), 0, 0)

        if switch_view is not None and hasattr(switch_view, "setTextAndCheck"):
            self._set_view_background(switch_view, self._create_round_drawable("key_dialogBackgroundGray", "key_divider", 14, 1))
            try:
                switch_view.setDrawCheckRipple(True)
            except Exception:
                pass
            container.addView(switch_view, row_lp)
            return

        FrameLayout = jclass("android.widget.FrameLayout")
        FrameLayoutParams = jclass("android.widget.FrameLayout$LayoutParams")
        Gravity = jclass("android.view.Gravity")

        row = FrameLayout(context)
        row.setPadding(self._dp(12), self._dp(10), self._dp(12), self._dp(10))
        self._set_view_background(row, self._create_round_drawable("key_dialogBackgroundGray", "key_divider", 14, 1))
        container.addView(row, row_lp)
        row.addView(switch_view, FrameLayoutParams(ViewGroupLayoutParams.MATCH_PARENT, ViewGroupLayoutParams.WRAP_CONTENT, Gravity.CENTER_VERTICAL))

    def _create_telegram_toggle(self, context: Any, text: str, checked: bool):
        try:
            TextCheckCell = jclass("org.telegram.ui.Cells.TextCheckCell")
            cell = None
            try:
                cell = TextCheckCell(context, 16, True)
            except Exception:
                cell = TextCheckCell(context)
            cell.setTextAndCheck(str(text), bool(checked), False)
            return cell
        except Exception:
            SwitchCls = self._resolve_switch_class()
            switch_view = SwitchCls(context)
            switch_view.setText(str(text))
            switch_view.setChecked(bool(checked))
            self._apply_text_color(switch_view, "key_dialogTextBlack")
            return switch_view

    def _create_text_input(self, context: Any, hint: str, value: str, multiline: bool, numeric: bool):
        InputType = jclass("android.text.InputType")
        TypedValue = jclass("android.util.TypedValue")
        edit_text = None
        try:
            EditTextBoldCursor = jclass("org.telegram.ui.Components.EditTextBoldCursor")
            edit_text = EditTextBoldCursor(context)
            try:
                edit_text.setBackground(None)
            except Exception:
                pass
            try:
                edit_text.setLineColors(
                    self._theme_color("key_dialogInputField"),
                    self._theme_color("key_dialogInputFieldActivated"),
                    self._theme_color("key_text_RedBold"),
                )
            except Exception:
                pass
        except Exception:
            pass

        if edit_text is None:
            EditText = jclass("android.widget.EditText")
            edit_text = EditText(context)

        try:
            edit_text.setHint(str(hint))
        except Exception:
            pass
        try:
            edit_text.setText(str(value or ""))
        except Exception:
            pass
        try:
            self._apply_text_color(edit_text, "key_dialogTextBlack")
        except Exception:
            pass
        try:
            edit_text.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
        except Exception:
            pass
        try:
            edit_text.setPadding(0, 0, 0, 0)
        except Exception:
            pass
        try:
            hint_color = self._theme_color("key_dialogTextHint")
            if hint_color:
                edit_text.setHintTextColor(hint_color)
        except Exception:
            pass

        if numeric:
            try:
                edit_text.setInputType(int(InputType.TYPE_CLASS_NUMBER | InputType.TYPE_NUMBER_FLAG_SIGNED))
            except Exception:
                pass
            try:
                edit_text.setSingleLine(True)
            except Exception:
                pass
        elif multiline:
            try:
                edit_text.setInputType(int(InputType.TYPE_CLASS_TEXT | InputType.TYPE_TEXT_FLAG_MULTI_LINE))
            except Exception:
                pass
            try:
                edit_text.setSingleLine(False)
                edit_text.setMinLines(1)
                edit_text.setMaxLines(3)
            except Exception:
                pass
        else:
            try:
                edit_text.setInputType(int(InputType.TYPE_CLASS_TEXT))
            except Exception:
                pass
            try:
                edit_text.setSingleLine(True)
            except Exception:
                pass

        return edit_text

    def _open_message_emoji_picker(self, message_input: Any):
        if message_input is None:
            self._notify_error(self._t("message_emoji_open_error"))
            return

        activity, fragment = self._get_ui_context()
        if activity is None:
            self._notify_error(self._t("no_context"))
            return

        try:
            EmojiBottomSheet = jclass("org.telegram.ui.Stories.recorder.EmojiBottomSheet")
            Callback3Return = jclass("org.telegram.messenger.Utilities$Callback3Return")
        except Exception:
            self._notify_error(self._t("message_emoji_unavailable"))
            return

        self._dismiss_message_emoji_picker()
        resources_provider = None
        if fragment is not None:
            try:
                resources_provider = fragment.getResourceProvider()
            except Exception:
                resources_provider = None

        plugin = self

        class _DocumentSelected(dynamic_proxy(Callback3Return)):
            def run(self, _parent_object, document, is_gif):
                try:
                    inserted = plugin._insert_custom_emoji_into_input(message_input, document, bool(is_gif))
                    if not inserted:
                        plugin._notify_error(plugin._t("message_emoji_invalid"))
                    return bool(inserted)
                except Exception as e:
                    plugin.log(f"[HiddenGift] emoji picker callback error: {e}")
                    plugin._notify_error(plugin._t("message_emoji_insert_error"))
                    return False

        callback = _DocumentSelected()

        try:
            picker = EmojiBottomSheet(activity, False, resources_provider, False)
        except Exception:
            try:
                picker = EmojiBottomSheet(activity, False, resources_provider)
            except Exception as e:
                self.log(f"[HiddenGift] emoji picker init error: {e}")
                self._notify_error(self._t("message_emoji_open_error"))
                return

        try:
            picker.whenDocumentSelected(callback)
        except Exception as e:
            self.log(f"[HiddenGift] emoji picker setup error: {e}")
            self._notify_error(self._t("message_emoji_open_error"))
            return

        self._message_emoji_picker_dialog_ref = picker
        self._message_emoji_picker_delegate_ref = callback
        self._message_emoji_picker_dismiss_ref = None

        try:
            DismissListener = jclass("android.content.DialogInterface$OnDismissListener")

            class _Dismiss(dynamic_proxy(DismissListener)):
                def onDismiss(self, _dialog):
                    plugin._on_message_emoji_picker_dismiss()

            dismiss_listener = _Dismiss()
            picker.setOnDismissListener(dismiss_listener)
            self._message_emoji_picker_dismiss_ref = dismiss_listener
        except Exception:
            self._message_emoji_picker_dismiss_ref = None

        shown = False
        if fragment is not None and hasattr(fragment, "showDialog"):
            try:
                fragment.showDialog(picker)
                shown = True
            except Exception:
                shown = False

        if not shown:
            try:
                picker.show()
                shown = True
            except Exception as e:
                self.log(f"[HiddenGift] emoji picker show error: {e}")
                shown = False

        if not shown:
            self._on_message_emoji_picker_dismiss()
            self._notify_error(self._t("message_emoji_open_error"))

    def _on_message_emoji_picker_dismiss(self):
        self._message_emoji_picker_dialog_ref = None
        self._message_emoji_picker_delegate_ref = None
        self._message_emoji_picker_dismiss_ref = None

    def _dismiss_message_emoji_picker(self):
        dialog = self._message_emoji_picker_dialog_ref
        self._on_message_emoji_picker_dismiss()
        if dialog is None:
            return
        try:
            dialog.dismiss()
        except Exception:
            pass

    def _insert_custom_emoji_into_input(self, edit_text: Any, document: Any, is_gif: bool) -> bool:
        if edit_text is None or document is None or bool(is_gif):
            return False

        try:
            if bool(MessageObject.isGifDocument(document)):
                return False
        except Exception:
            pass

        doc_id = 0
        try:
            doc_id = int(getattr(document, "id", 0) or 0)
        except Exception:
            doc_id = 0
        if doc_id <= 0:
            return False

        try:
            if not bool(MessageObject.isAnimatedEmoji(document)):
                return False
        except Exception:
            pass

        symbol = self._extract_message_emoji_symbol(document)
        if not symbol:
            symbol = "🙂"

        editable = self._read_editable(edit_text)
        if editable is None:
            return False

        try:
            start = int(edit_text.getSelectionStart())
        except Exception:
            start = -1
        try:
            end = int(edit_text.getSelectionEnd())
        except Exception:
            end = start
        if start < 0:
            start = max(0, int(end))
        if end < 0:
            end = int(start)
        if start > end:
            start, end = end, start

        try:
            if start != end:
                editable.delete(start, end)
            insert_at = int(start)
        except Exception:
            insert_at = max(0, int(start))

        try:
            SpannableString = jclass("android.text.SpannableString")
            Spanned = jclass("android.text.Spanned")
            AnimatedEmojiSpan = jclass("org.telegram.ui.Components.AnimatedEmojiSpan")
        except Exception as e:
            self.log(f"[HiddenGift] emoji span classes unavailable: {e}")
            return False

        span_text = SpannableString(symbol)
        try:
            metrics = edit_text.getPaint().getFontMetricsInt()
        except Exception:
            metrics = None

        span = None
        try:
            if metrics is not None:
                span = AnimatedEmojiSpan(document, metrics)
            else:
                span = AnimatedEmojiSpan(document)
        except Exception:
            try:
                if metrics is not None:
                    span = AnimatedEmojiSpan(self._as_java_long(doc_id), metrics)
                else:
                    span = AnimatedEmojiSpan(self._as_java_long(doc_id))
            except Exception:
                span = None

        if span is None:
            return False

        try:
            span.fromEmojiKeyboard = True
        except Exception:
            pass
        try:
            AnimatedEmojiDrawable = jclass("org.telegram.ui.Components.AnimatedEmojiDrawable")
            cache_type = getattr(AnimatedEmojiDrawable, "CACHE_TYPE_ALERT_PREVIEW", None)
            if cache_type is not None:
                span.cacheType = int(cache_type)
        except Exception:
            pass

        try:
            flags = int(getattr(Spanned, "SPAN_EXCLUSIVE_EXCLUSIVE", 33))
            span_text.setSpan(span, 0, int(span_text.length()), flags)
        except Exception:
            return False

        try:
            editable.insert(int(insert_at), span_text)
            pos = int(insert_at) + int(span_text.length())
            edit_text.setSelection(pos, pos)
            return True
        except Exception as e:
            self.log(f"[HiddenGift] insert custom emoji error: {e}")
            return False

    def _extract_message_emoji_symbol(self, document: Any) -> str:
        alt = self._extract_document_alt_emoji(document)
        if alt:
            return alt

        emoji = ""
        try:
            emoji = str(MessageObject.findAnimatedEmojiEmoticon(document, "") or "").strip()
        except Exception:
            try:
                emoji = str(MessageObject.findAnimatedEmojiEmoticon(document) or "").strip()
            except Exception:
                emoji = ""
        if emoji and not emoji.startswith("animated_"):
            return emoji
        return ""

    def _extract_document_alt_emoji(self, document: Any) -> str:
        attrs = getattr(document, "attributes", None)
        if attrs is None:
            return ""

        for attr in self._iter_java_items(attrs):
            try:
                alt = str(getattr(attr, "alt", "") or "").strip()
                if alt:
                    return alt
            except Exception:
                continue
        return ""

    def _resolve_switch_class(self):
        try:
            return jclass("androidx.appcompat.widget.SwitchCompat")
        except Exception:
            return jclass("android.widget.Switch")

    def _apply_text_color(self, text_view: Any, theme_key_name: str):
        color = self._theme_color(theme_key_name)
        if color:
            text_view.setTextColor(color)

    def _theme_color(self, key_name: str) -> int:
        try:
            Theme = jclass("org.telegram.ui.ActionBar.Theme")
            key = getattr(Theme, key_name, None)
            if key is None:
                return 0
            return int(Theme.getColor(int(key)))
        except Exception:
            return 0

    def _dp(self, value: int) -> int:
        try:
            AndroidUtilities = jclass("org.telegram.messenger.AndroidUtilities")
            return int(AndroidUtilities.dp(float(value)))
        except Exception:
            return int(value)

    def _read_text(self, edit_text: Any) -> str:
        if edit_text is None:
            return ""
        try:
            return str(edit_text.getText().toString())
        except Exception:
            pass
        try:
            return str(edit_text.getText())
        except Exception:
            return ""

    def _read_checked(self, switch_view: Any, default: bool) -> bool:
        if switch_view is None:
            return bool(default)
        try:
            return bool(switch_view.isChecked())
        except Exception:
            return bool(default)

    def _to_int(self, value: Any) -> Optional[int]:
        try:
            text = str(value).strip()
            if text == "":
                return None
            return int(text)
        except Exception:
            return None

    def _as_java_long(self, value: Any):
        try:
            numeric = int(str(value).strip())
        except Exception:
            return 0
        try:
            Long = jclass("java.lang.Long")
            return Long.valueOf(str(numeric))
        except Exception as e:
            self.log(f"[HiddenGift] java long conversion failed for {numeric}: {e}")
            return 0

    def _set_optional_star_gift_field(self, gift: Any, field_name: str, value: Any) -> bool:
        try:
            setattr(gift, field_name, value)
            return True
        except Exception as e:
            if field_name not in self._missing_star_gift_fields:
                self._missing_star_gift_fields.add(field_name)
                self.log(f"[HiddenGift] TL_starGift field unavailable on this build: {field_name} ({e})")
            return False

    def _t(self, key: str, **kwargs) -> str:
        text = _TEXTS.get(key, key)
        try:
            return text.format(**kwargs) if kwargs else text
        except Exception:
            return text
