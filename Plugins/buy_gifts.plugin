@dataclass
class _SendSheetState:
    quantity: int = 1
    sending: bool = False
    sent: int = 0
    requested: int = 1
    detached: bool = False
    quantity_row: Any = None


class _SheetHook(MethodHook):
    def __init__(self, plugin: "HiddenStarGiftSenderPlugin"):
        self.plugin = plugin

    def after_hooked_method(self, param: Any) -> None:
        try:
            self.plugin._patch_sheet(
                getattr(param, "thisObject", None),
                getattr(param, "args", None),
            )
        except Exception as e:
            self.plugin.log(f"[HiddenGift] fillItems hook error: {e}")


class _SendSheetHook(MethodHook):
    def __init__(self, plugin: "HiddenStarGiftSenderPlugin"):
        self.plugin = plugin

    def before_hooked_method(self, param: Any) -> None:
        try:
            send_sheet = getattr(param, "thisObject", None)
            if self.plugin._maybe_open_custom_config(send_sheet):
                param.setResult(None)
        except Exception as e:
            self.plugin.log(f"[HiddenGift] send sheet hook error: {e}")


class _SendSheetItemsHook(MethodHook):
    def __init__(self, plugin: "HiddenStarGiftSenderPlugin"):
        self.plugin = plugin

    def after_hooked_method(self, param: Any) -> None:
        try:
            self.plugin._patch_send_sheet_items(
                getattr(param, "thisObject", None),
                getattr(param, "args", None),
            )
        except Exception as e:
            self.plugin.log(f"[HiddenGift] send sheet items hook error: {e}")


class _SendSheetButtonHook(MethodHook):
    def __init__(self, plugin: "HiddenStarGiftSenderPlugin"):
        self.plugin = plugin

    def after_hooked_method(self, param: Any) -> None:
        try:
            args = getattr(param, "args", None)
            animated = bool(args[0]) if args and len(args) > 0 else False
            self.plugin._apply_send_sheet_button_text(getattr(param, "thisObject", None), animated)
        except Exception as e:
            self.plugin.log(f"[HiddenGift] send sheet button hook error: {e}")


class _SendSheetBuyHook(MethodHook):
    def __init__(self, plugin: "HiddenStarGiftSenderPlugin"):
        self.plugin = plugin

    def before_hooked_method(self, param: Any) -> None:
        try:
            if self.plugin._intercept_send_sheet_bulk_buy(getattr(param, "thisObject", None)):
                param.setResult(None)
        except Exception as e:
            self.plugin.log(f"[HiddenGift] send sheet buy hook error: {e}")


class _SendSheetDetachHook(MethodHook):
    def __init__(self, plugin: "HiddenStarGiftSenderPlugin"):
        self.plugin = plugin

    def after_hooked_method(self, param: Any) -> None:
        try:
            self.plugin._clear_send_sheet_state(getattr(param, "thisObject", None))
        except Exception as e:
            self.plugin.log(f"[HiddenGift] send sheet detach hook error: {e}")


class _GiftCellHook(MethodHook):
    def __init__(self, plugin: "HiddenStarGiftSenderPlugin"):
        self.plugin = plugin

    def after_hooked_method(self, param: Any) -> None:
        try:
            args = getattr(param, "args", None)
            gift = args[0] if args and len(args) > 0 else None
            self.plugin._tune_config_cell(getattr(param, "thisObject", None), gift)
        except Exception as e:
            self.plugin.log(f"[HiddenGift] gift cell hook error: {e}")


class HiddenStarGiftSenderPlugin(BasePlugin):
    def __init__(self):
        super().__init__()
        self._menu_item_id = None
        self._hook_refs: List[Any] = []
        self._progress_dialog = None
        self._gift_catalog_cache: Dict[int, Any] = {}
        self._gift_catalog_loading = False
        self._gift_catalog_attempted = False
        self._hidden_gift_cache: Dict[int, Any] = {}
        self._pack_docs: Dict[str, List[Any]] = {}
        self._loading_packs = set()
        self._gift_sheet = None
        self._preview_session_seq = 0
        self._active_preview_session = 0
        self._message_emoji_picker_dialog_ref = None
        self._message_emoji_picker_delegate_ref = None
        self._message_emoji_picker_dismiss_ref = None
        self._custom_gift_picker_request = None
        self._missing_star_gift_fields = set()
        self._star_gift_factory_arity = None
        self._send_sheet_states: Dict[int, _SendSheetState] = {}

    def on_plugin_load(self):
        try:
            self._setup_hidden_hooks()
            self._load_pack(_BUILTIN_GIFT_PACK)
            self._load_pack(_CUSTOM_GIFT_PACK)
            self._load_pack(_CONFIG_GIFT_PACK)
            self._preload_custom_gift_packs()
            self._menu_item_id = self.add_menu_item(
                MenuItemData(
                    menu_type=MenuItemType.CHAT_ACTION_MENU,
                    item_id="hidden_star_gift_sender.menu",
                    text=self._t("menu_title"),
                    icon="menu_stars_gift",
                    on_click=self._on_chat_menu_click,
                )
            )
            self.log("[HiddenGift] plugin loaded")
        except Exception as e:
            self.log(f"[HiddenGift] on_plugin_load error: {e}")

    def on_plugin_unload(self):
        try:
            for ref in list(self._hook_refs):
                try:
                    self.unhook_method(ref)
                except Exception:
                    pass
            self._hook_refs.clear()
            self._gift_sheet = None
            self._send_sheet_states.clear()
            if self._menu_item_id is not None:
                self.remove_menu_item(self._menu_item_id)
                self._menu_item_id = None
        except Exception as e:
            self.log(f"[HiddenGift] remove menu item error: {e}")
        self._active_preview_session = -1
        self._custom_gift_picker_request = None
        self._dismiss_message_emoji_picker()
        self._dismiss_progress()
        self.log("[HiddenGift] plugin unloaded")

    def _setup_hidden_hooks(self):
        self._hook_sheet()
        self._hook_send_sheet()
        self._hook_gift_cell()

    def _preload_custom_gift_packs(self):
        seen = set()
        for spec in self._custom_gift_specs():
            pack_name = self._custom_pack_name(spec.get("pack", ""))
            if not pack_name or pack_name in seen:
                continue
            seen.add(pack_name)
            self._load_pack(pack_name)

    def _hook_sheet(self):
        try:
            cls = find_class("org.telegram.ui.Gifts.GiftSheet")
            if cls is None:
                self.log("[HiddenGift] GiftSheet class not found")
                return

            hooked = 0
            for method in self._iter_declared_methods(cls):
                try:
                    if method.getName() != "fillItems":
                        continue
                    params = method.getParameterTypes()
                    if len(params) != 2:
                        continue
                    if "java.util.ArrayList" not in str(params[0]):
                        continue
                    if "UniversalAdapter" not in str(params[1]):
                        continue
                    try:
                        method.setAccessible(True)
                    except Exception:
                        pass
                    ref = self.hook_method(method, _SheetHook(self), priority=2147483647)
                    if ref is not None:
                        self._hook_refs.append(ref)
                        hooked += 1
                except Exception:
                    pass

            if hooked == 0:
                self.log("[HiddenGift] GiftSheet.fillItems hook was not installed")
            else:
                self.log(f"[HiddenGift] hooked GiftSheet.fillItems ({hooked})")
        except Exception as e:
            self.log(f"[HiddenGift] _hook_sheet error: {e}")

    def _hook_send_sheet(self):
        try:
            cls = find_class("org.telegram.ui.Gifts.SendGiftSheet")
            if cls is None:
                self.log("[HiddenGift] SendGiftSheet class not found")
                return

            hooked = {
                "show": 0,
                "fillItems": 0,
                "setButtonText": 0,
                "buyStarGift": 0,
                "onDetachedFromWindow": 0,
            }
            for method in self._iter_declared_methods(cls):
                try:
                    name = str(method.getName())
                    params = method.getParameterTypes()
                    try:
                        method.setAccessible(True)
                    except Exception:
                        pass
                    hook_impl = None
                    if name == "show" and len(params) == 0:
                        hook_impl = _SendSheetHook(self)
                    elif name == "fillItems" and len(params) == 2 and "java.util.ArrayList" in str(params[0]) and "UniversalAdapter" in str(params[1]):
                        hook_impl = _SendSheetItemsHook(self)
                    elif name == "setButtonText" and len(params) == 1 and str(params[0]) == "boolean":
                        hook_impl = _SendSheetButtonHook(self)
                    elif name == "buyStarGift" and len(params) == 0:
                        hook_impl = _SendSheetBuyHook(self)
                    elif name == "onDetachedFromWindow" and len(params) == 0:
                        hook_impl = _SendSheetDetachHook(self)
                    if hook_impl is None:
                        continue
                    ref = self.hook_method(method, hook_impl, priority=2147483647)
                    if ref is not None:
                        self._hook_refs.append(ref)
                        hooked[name] += 1
                except Exception:
                    pass

            if sum(hooked.values()) == 0:
                self.log("[HiddenGift] SendGiftSheet.show hook was not installed")
            else:
                self.log(
                    "[HiddenGift] hooked SendGiftSheet "
                    f"(show={hooked['show']}, fillItems={hooked['fillItems']}, "
                    f"setButtonText={hooked['setButtonText']}, buyStarGift={hooked['buyStarGift']}, "
                    f"detach={hooked['onDetachedFromWindow']})"
                )
        except Exception as e:
            self.log(f"[HiddenGift] _hook_send_sheet error: {e}")

    def _hook_gift_cell(self):
        try:
            cls = find_class("org.telegram.ui.Gifts.GiftSheet$GiftCell")
            if cls is None:
                self.log("[HiddenGift] GiftCell class not found")
                return

            hooked = 0
            for method in self._iter_declared_methods(cls):
                try:
                    if method.getName() != "setStarsGift":
                        continue
                    params = method.getParameterTypes()
                    if len(params) < 1:
                        continue
                    first_param = str(params[0])
                    if ("TL_stars$SavedStarGift" in first_param) or ("SavedStarGift" in first_param):
                        continue
                    if ("TL_stars$StarGift" not in first_param) and ("StarGift" not in first_param):
                        continue
                    try:
                        method.setAccessible(True)
                    except Exception:
                        pass
                    ref = self.hook_method(method, _GiftCellHook(self), priority=2147483647)
                    if ref is not None:
                        self._hook_refs.append(ref)
                        hooked += 1
                except Exception:
                    pass

            if hooked == 0:
                self.log("[HiddenGift] GiftCell.setStarsGift hook was not installed")
            else:
                self.log(f"[HiddenGift] hooked GiftCell.setStarsGift ({hooked})")
        except Exception as e:
            self.log(f"[HiddenGift] _hook_gift_cell error: {e}")

    def _iter_declared_methods(self, cls_obj: Any) -> List[Any]:
        try:
            return list(cls_obj.getClass().getDeclaredMethods())
        except Exception:
            pass
        try:
            return list(cls_obj.getDeclaredMethods())
        except Exception:
            return []

    def _load_pack(self, pack_name: str):
        if not pack_name or pack_name in self._loading_packs or self._pack_docs.get(pack_name):
            return

        current_account = self._current_account()
        try:
            media = MediaDataController.getInstance(int(current_account))
            cached_set = media.getStickerSetByName(pack_name)
            docs = self._extract_pack_docs(cached_set)
            if docs:
                self._pack_docs[pack_name] = docs
                self._refresh_hidden_docs()
                return
        except Exception as e:
            self.log(f"[HiddenGift] sticker pack cache lookup error: {e}")

        self._request_pack(pack_name, int(current_account))

    def _request_pack(self, pack_name: str, current_account: int):
        if not pack_name or pack_name in self._loading_packs:
            return
        self._loading_packs.add(pack_name)

        try:
            req = TLRPC.TL_messages_getStickerSet()
            input_set = TLRPC.TL_inputStickerSetShortName()
            input_set.short_name = pack_name
            req.stickerset = input_set
            req.hash = self._as_java_long(0)
        except Exception as e:
            self._loading_packs.discard(pack_name)
            self.log(f"[HiddenGift] sticker pack request build error: {e}")
            return

        def on_result(response: Any, error: Any):
            self._loading_packs.discard(pack_name)
            if error is not None:
                try:
                    text = str(getattr(error, "text", "") or getattr(error, "error_message", "") or error)
                except Exception:
                    text = str(error)
                self.log(f"[HiddenGift] sticker pack fetch error: {text}")
                run_on_ui_thread(lambda: self._on_custom_gift_pack_failed(pack_name))
                return

            docs = self._extract_pack_docs(response)
            if not docs:
                self.log("[HiddenGift] sticker pack fetched but documents were not found")
                run_on_ui_thread(lambda: self._on_custom_gift_pack_failed(pack_name))
                return

            self._pack_docs[pack_name] = docs
            self._refresh_hidden_docs()
            run_on_ui_thread(lambda: self._after_custom_pack_loaded(pack_name))

        try:
            send_request(req, RequestCallback(on_result))
        except Exception as e:
            self._loading_packs.discard(pack_name)
            self.log(f"[HiddenGift] sticker pack request error: {e}")

    def _extract_pack_docs(self, response: Any) -> List[Any]:
        docs = getattr(response, "documents", None) if response is not None else None
        if docs is None:
            return []
        return self._iter_java_items(docs)

    def _pack_sticker(self, pack_name: str, sticker_number: Any):
        docs = self._pack_docs.get(pack_name) or []
        if not docs:
            return None
        try:
            index = int(sticker_number)
        except Exception:
            index = -1
        if 0 <= index < len(docs):
            return docs[index]
        return docs[0]

    def _refresh_hidden_docs(self):
        for gift_id, gift in list(self._hidden_gift_cache.items()):
            spec = self._gift_spec(gift_id)
            if spec is None or gift is None:
                continue
            try:
                sticker = self._pack_sticker(
                    str(spec.get("pack", _BUILTIN_GIFT_PACK) or _BUILTIN_GIFT_PACK),
                    self._sticker_index(spec),
                )
                if sticker is not None:
                    gift.sticker = sticker
            except Exception:
                pass

    def _patch_sheet(self, sheet: Any, args: Any):
        if sheet is None or args is None:
            return

        self._gift_sheet = sheet
        self._bind_sheet_long_press(sheet)
        items = self._get_at(args, 0)
        if items is None or not self._can_patch_sheet(sheet):
            return

        existing_ids, insert_index = self._scan_sheet(items)
        hidden_items = self._build_sheet_items(
            int(self._field(sheet, "TAB_ALL", -1) or -1),
            existing_ids,
        )
        if not hidden_items:
            return

        self._insert_items(items, insert_index, hidden_items)

    def _bind_sheet_long_press(self, sheet: Any):
        recycler = self._field(sheet, "recyclerListView", None)
        if recycler is None:
            return

        try:
            listener_iface = jclass("org.telegram.ui.Components.RecyclerListView$OnItemLongClickListener")
        except Exception:
            return

        plugin = self

        class _Listener(dynamic_proxy(listener_iface)):
            def onItemClick(self, view: Any, position: Any) -> bool:
                try:
                    return bool(plugin._on_sheet_long_press(sheet, int(position)))
                except Exception as e:
                    plugin.log(f"[HiddenGift] long press handler error: {e}")
                    return False

        try:
            recycler.setOnItemLongClickListener(_Listener())
        except Exception as e:
            self.log(f"[HiddenGift] bind long press error: {e}")

    def _on_sheet_long_press(self, sheet: Any, position: int) -> bool:
        adapter = self._field(sheet, "adapter", None)
        if adapter is None:
            return False

        try:
            item = adapter.getItem(int(position) - 1)
        except Exception:
            item = None
        if item is None:
            return False

        gift = getattr(item, "object", None)
        gift_id = self._gift_id(gift)
        if gift_id <= 0 or not self._is_custom_gift(gift_id):
            return False

        filtered = [spec for spec in self._custom_gift_specs() if int(spec["id"]) != gift_id]
        self._store_custom_gifts(filtered)
        self._notify_success(self._t("custom_gifts_removed"))
        return True

    def _maybe_open_custom_config(self, send_sheet: Any) -> bool:
        gift = self._field(send_sheet, "starGift", None)
        if self._gift_id(gift) != _CONFIG_GIFT_ID:
            return False

        context = self._send_sheet_context(send_sheet)
        if context is None:
            self._notify_error(self._t("no_context"))
            return True

        run_on_ui_thread(lambda: self._open_custom_gifts_dialog(context))
        return True

    def _patch_send_sheet_items(self, send_sheet: Any, args: Any):
        if send_sheet is None or args is None or not self._can_bulk_send_gifts(send_sheet):
            return

        items = self._get_at(args, 0)
        if items is None:
            return

        for existing_item in self._iter_java_items(items):
            if self._to_int(getattr(existing_item, "id", 0)) == _SEND_SHEET_QTY_ITEM_ID:
                return

        item = self._send_sheet_quantity_row_item(send_sheet)
        if item is None:
            return

        insert_index = self._send_sheet_quantity_insert_index(items)
        try:
            items.add(int(insert_index), item)
        except Exception:
            try:
                items.add(item)
            except Exception as e:
                self.log(f"[HiddenGift] SendGiftSheet quantity insert error: {e}")

    def _can_bulk_send_gifts(self, send_sheet: Any) -> bool:
        gift = self._field(send_sheet, "starGift", None)
        if gift is None:
            return False
        if self._gift_id(gift) == _CONFIG_GIFT_ID:
            return False
        if self._field(send_sheet, "premiumTier", None) is not None:
            return False
        if self._field(send_sheet, "auction", None) is not None:
            return False
        try:
            if bool(getattr(gift, "auction", False)):
                return False
        except Exception:
            pass
        return True

    def _send_sheet_quantity_insert_index(self, items: Any) -> int:
        shadow_index = None
        check_index = None
        for index, item in enumerate(self._iter_java_items(items)):
            item_id = self._to_int(getattr(item, "id", 0))
            if item_id == -6 and shadow_index is None:
                shadow_index = index
            elif item_id == 1 and check_index is None:
                check_index = index
        if shadow_index is not None:
            return int(shadow_index)
        if check_index is not None:
            return int(check_index)
        return 0

    def _send_sheet_quantity_row_item(self, send_sheet: Any):
        row = self._get_send_sheet_quantity_row(send_sheet)
        if row is None:
            return None
        self._update_send_sheet_quantity_row(send_sheet, row, False)
        try:
            UItem = jclass("org.telegram.ui.Components.UItem")
            return UItem.asCustom(_SEND_SHEET_QTY_ITEM_ID, row)
        except Exception as e:
            self.log(f"[HiddenGift] SendGiftSheet quantity row item error: {e}")
            return None

    def _get_send_sheet_quantity_row(self, send_sheet: Any):
        state = self._send_sheet_state(send_sheet)
        row = state.quantity_row
        if row is not None:
            return row

        context = self._send_sheet_context(send_sheet)
        if context is None:
            return None

        row = self._create_send_sheet_quantity_row(send_sheet, context)
        if row is not None:
            state.quantity_row = row
        return row

    def _create_send_sheet_quantity_row(self, send_sheet: Any, context: Any):
        try:
            TextCell = jclass("org.telegram.ui.Cells.TextCell")
            Theme = jclass("org.telegram.ui.ActionBar.Theme")
        except Exception as e:
            self.log(f"[HiddenGift] SendGiftSheet quantity row classes missing: {e}")
            return None

        try:
            row = TextCell(context, 23, True)
        except Exception:
            try:
                row = TextCell(context)
            except Exception as e:
                self.log(f"[HiddenGift] SendGiftSheet quantity row create error: {e}")
                return None

        try:
            self._set_view_background(row, Theme.getSelectorDrawable(False))
        except Exception:
            pass
        try:
            row.setOnClickListener(
                OnClickListener(lambda _v=None: self._on_send_sheet_quantity_row_click(send_sheet))
            )
        except Exception as e:
            self.log(f"[HiddenGift] SendGiftSheet quantity row click bind error: {e}")
        return row

    def _on_send_sheet_quantity_row_click(self, send_sheet: Any):
        if self._send_sheet_state(send_sheet).sending:
            return
        self._open_send_sheet_quantity_dialog(send_sheet)

    def _update_send_sheet_quantity_row(self, send_sheet: Any, row: Any = None, animated: bool = False):
        if row is None:
            row = self._get_send_sheet_quantity_row(send_sheet)
        if row is None:
            return
        label = self._t("send_quantity_label")
        value = self._format_send_sheet_quantity(send_sheet)
        try:
            row.setTextAndValue(label, value, bool(animated), False)
            return
        except Exception:
            pass
        try:
            row.setTextAndValue(label, value, False)
        except Exception as e:
            self.log(f"[HiddenGift] SendGiftSheet quantity row update error: {e}")

    def _open_send_sheet_quantity_dialog(self, send_sheet: Any):
        context = self._send_sheet_context(send_sheet)
        if context is None:
            self._notify_error(self._t("no_context"))
            return

        try:
            NumberPicker = jclass("org.telegram.ui.Components.NumberPicker")
            LinearLayout = jclass("android.widget.LinearLayout")
            TextView = jclass("android.widget.TextView")
            ViewGroupLayoutParams = jclass("android.view.ViewGroup$LayoutParams")
            LayoutParams = jclass("android.widget.LinearLayout$LayoutParams")
            Gravity = jclass("android.view.Gravity")
            TypedValue = jclass("android.util.TypedValue")
        except Exception as e:
            self.log(f"[HiddenGift] SendGiftSheet quantity dialog classes missing: {e}")
            self._notify_error(self._t("no_context"))
            return

        limit = self._send_sheet_quantity_limit(send_sheet)
        max_quantity = self._to_int(limit)
        if max_quantity is None or max_quantity <= 0:
            max_quantity = _SEND_SHEET_QTY_MAX
        max_quantity = max(1, int(max_quantity))
        current_quantity = max(1, min(self._send_sheet_quantity(send_sheet), max_quantity))

        try:
            container = LinearLayout(context)
            container.setOrientation(LinearLayout.VERTICAL)
            container.setPadding(self._dp(20), self._dp(10), self._dp(20), self._dp(4))

            info = TextView(context)
            info.setText(
                self._t(
                    "send_quantity_picker_info",
                    min="1",
                    max=self._format_number(max_quantity),
                )
            )
            try:
                info.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
            except Exception:
                info.setTextSize(14)
            try:
                info.setGravity(int(getattr(Gravity, "CENTER_HORIZONTAL", 1)))
            except Exception:
                pass
            self._apply_text_color(info, "key_dialogTextBlack")
            info_lp = LayoutParams(ViewGroupLayoutParams.MATCH_PARENT, ViewGroupLayoutParams.WRAP_CONTENT)
            info_lp.setMargins(0, 0, 0, self._dp(10))
            container.addView(
                info,
                info_lp,
            )

            picker = NumberPicker(context)
            try:
                picker.setItemCount(5)
            except Exception:
                pass
            picker.setMinValue(1)
            picker.setMaxValue(int(max_quantity))
            try:
                picker.setWrapSelectorWheel(int(max_quantity) > 1)
            except Exception:
                pass
            picker.setValue(int(current_quantity))
            container.addView(
                picker,
                LayoutParams(
                    ViewGroupLayoutParams.MATCH_PARENT,
                    self._dp(int(getattr(NumberPicker, "DEFAULT_SIZE_PER_COUNT", 42) or 42) * 5),
                ),
            )

            def on_apply(builder_obj: AlertDialogBuilder, _which: int):
                self._set_send_sheet_quantity(send_sheet, int(picker.getValue()), True)
                try:
                    builder_obj.dismiss()
                except Exception:
                    pass

            builder = AlertDialogBuilder(context, AlertDialogBuilder.ALERT_TYPE_MESSAGE)
            builder.set_title(self._t("send_quantity_title"))
            builder.set_view(container)
            builder.set_positive_button(self._t("send_quantity_apply"), on_apply)
            builder.set_negative_button(self._t("cancel_button"), lambda b, _w: b.dismiss())
            builder.show()
        except Exception as e:
            self.log(f"[HiddenGift] SendGiftSheet quantity dialog error: {e}")

    def _send_sheet_state(self, send_sheet: Any) -> _SendSheetState:
        key = self._send_sheet_key(send_sheet)
        state = self._send_sheet_states.get(key)
        if isinstance(state, _SendSheetState):
            return state
        state = _SendSheetState()
        self._send_sheet_states[key] = state
        return state

    def _send_sheet_key(self, obj: Any) -> int:
        if obj is None:
            return 0
        try:
            System = jclass("java.lang.System")
            return int(System.identityHashCode(obj))
        except Exception:
            pass
        try:
            return int(obj.hashCode())
        except Exception:
            return int(id(obj))

    def _clear_send_sheet_state(self, send_sheet: Any):
        key = self._send_sheet_key(send_sheet)
        state = self._send_sheet_states.get(key)
        if not isinstance(state, _SendSheetState):
            return
        if state.sending:
            state.detached = True
            return
        self._send_sheet_states.pop(key, None)

    def _send_sheet_quantity(self, send_sheet: Any) -> int:
        state = self._send_sheet_state(send_sheet)
        try:
            return max(1, int(state.quantity or 1))
        except Exception:
            return 1

    def _set_send_sheet_quantity(self, send_sheet: Any, quantity: Any, animated: bool) -> int:
        state = self._send_sheet_state(send_sheet)
        normalized = self._normalize_send_sheet_quantity(send_sheet, quantity, notify=True)
        state.quantity = normalized
        self._update_send_sheet_quantity_row(send_sheet, state.quantity_row, animated)
        adapter = self._field(send_sheet, "adapter", None)
        if adapter is not None:
            try:
                adapter.update(bool(animated))
            except Exception:
                pass
        self._apply_send_sheet_button_text(send_sheet, animated)
        return int(normalized)

    def _normalize_send_sheet_quantity(self, send_sheet: Any, quantity: Any, notify: bool) -> int:
        parsed = self._to_int(quantity)
        if parsed is None or parsed <= 0:
            return 1

        limit = self._send_sheet_quantity_limit(send_sheet)
        if limit not in (None, 0) and parsed > limit:
            parsed = int(limit)
            if notify:
                self._notify_error(self._t("send_quantity_limited", limit=str(limit)))
        return max(1, int(parsed))

    def _send_sheet_quantity_limit(self, send_sheet: Any) -> Optional[int]:
        gift = self._field(send_sheet, "starGift", None)
        if gift is None:
            return None

        limits = []
        try:
            if bool(getattr(gift, "limited_per_user", False)):
                remains = self._to_int(getattr(gift, "per_user_remains", 0))
                if remains is not None and remains > 0:
                    limits.append(int(remains))
        except Exception:
            pass
        try:
            if bool(getattr(gift, "limited", False)):
                remains = self._to_int(getattr(gift, "availability_remains", 0))
                if remains is not None and remains > 0:
                    limits.append(int(remains))
        except Exception:
            pass
        if not limits:
            return None
        return int(min(limits))

    def _format_send_sheet_quantity(self, send_sheet: Any) -> str:
        return self._format_number(self._send_sheet_quantity(send_sheet))

    def _format_number(self, value: Any) -> str:
        try:
            LocaleController = jclass("org.telegram.messenger.LocaleController")
            return str(LocaleController.formatNumber(int(value), ','))
        except Exception:
            try:
                return f"{int(value):,}".replace(",", " ")
            except Exception:
                return str(value)

    def _send_sheet_message(self, send_sheet: Any):
        paid_messages_stars = self._to_int(self._field(send_sheet, "send_paid_messages_stars", 0))
        if paid_messages_stars is not None and paid_messages_stars > 0:
            return None
        action = self._field(send_sheet, "action", None)
        if action is None:
            return None
        return getattr(action, "message", None)

    def _send_sheet_unit_price(self, send_sheet: Any) -> int:
        gift = self._field(send_sheet, "starGift", None)
        if gift is None:
            return 0

        total = self._to_int(getattr(gift, "stars", 0)) or 0
        if bool(self._field(send_sheet, "upgrade", False)):
            total += self._to_int(getattr(gift, "upgrade_stars", 0)) or 0

        paid_messages_stars = self._to_int(self._field(send_sheet, "send_paid_messages_stars", 0)) or 0
        if paid_messages_stars > 0:
            message_edit = self._field(send_sheet, "messageEdit", None)
            try:
                message_text = str(message_edit.getText() or "")
            except Exception:
                message = self._send_sheet_message(send_sheet)
                message_text = str(getattr(message, "text", "") or "")
            if message_text != "":
                total += paid_messages_stars
        return max(0, int(total))

    def _stars_controller_for_account(self, account: int):
        try:
            StarsController = jclass("org.telegram.ui.Stars.StarsController")
            return StarsController.getInstance(int(account))
        except Exception:
            return None

    def _make_callback2(self, callback):
        try:
            Callback2 = jclass("org.telegram.messenger.Utilities$Callback2")
        except Exception:
            return callback

        plugin = self

        class _Callback(dynamic_proxy(Callback2)):
            def run(self, arg, arg2):
                try:
                    callback(arg, arg2)
                except Exception as e:
                    plugin.log(f"[HiddenGift] callback2 proxy error: {e}")

        return _Callback()

    def _apply_send_sheet_button_text(self, send_sheet: Any, animated: bool):
        if send_sheet is None or not self._can_bulk_send_gifts(send_sheet):
            return

        button = self._field(send_sheet, "button", None)
        if button is None:
            return

        state = self._send_sheet_state(send_sheet)
        quantity = self._send_sheet_quantity(send_sheet)
        sent_count = int(state.sent or 0)
        requested_count = max(1, int(state.requested or quantity))
        total_quantity = requested_count if state.sending else quantity
        total_price = self._send_sheet_unit_price(send_sheet) * int(total_quantity)
        total_price = max(0, int(total_price))

        controller = self._stars_controller_for_account(self._send_sheet_account(send_sheet))

        balance_available = False
        balance = 0
        if controller is not None:
            try:
                balance_available = bool(controller.balanceAvailable())
            except Exception:
                balance_available = False
            try:
                balance = int(getattr(controller.getBalance(), "amount", 0) or 0)
            except Exception:
                balance = 0

        try:
            LocaleController = jclass("org.telegram.messenger.LocaleController")
            StarsIntroActivity = jclass("org.telegram.ui.Stars.StarsIntroActivity")
            total_price_display = min(int(total_price), _JAVA_INT_MAX)
            text_key = "Gift2SendSelf" if bool(self._field(send_sheet, "self", False)) else "Gift2Send"
            label = LocaleController.formatPluralStringComma(text_key, int(total_price_display))
            cached_star_span = self._field(send_sheet, "cachedStarSpan", None)
            try:
                button.setText(StarsIntroActivity.replaceStars(label, cached_star_span), bool(animated))
            except Exception:
                button.setText(str(label), bool(animated))
            if state.sending:
                button.setSubText(
                    self._t(
                        "send_quantity_progress",
                        current=str(min(sent_count, requested_count)),
                        total=str(requested_count),
                    ),
                    bool(animated),
                )
            elif balance_available and total_price > balance:
                balance_display = min(int(balance), _JAVA_INT_MAX)
                button.setSubText(
                    LocaleController.formatPluralStringComma("Gift2SendYourBalance", int(balance_display)),
                    bool(animated),
                )
            else:
                button.setSubText(None, bool(animated))
        except Exception as e:
            self.log(f"[HiddenGift] apply SendGiftSheet button text error: {e}")

    def _intercept_send_sheet_bulk_buy(self, send_sheet: Any) -> bool:
        if send_sheet is None or not self._can_bulk_send_gifts(send_sheet):
            return False

        state = self._send_sheet_state(send_sheet)
        if state.sending:
            return True

        selected_quantity = self._send_sheet_quantity(send_sheet)
        normalized_quantity = self._normalize_send_sheet_quantity(send_sheet, selected_quantity, notify=True)
        if normalized_quantity != selected_quantity:
            self._set_send_sheet_quantity(send_sheet, normalized_quantity, True)
        if normalized_quantity <= 1:
            return False

        gift = self._field(send_sheet, "starGift", None)
        if gift is None:
            return False

        current_account = self._send_sheet_account(send_sheet)
        dialog_id = int(self._field(send_sheet, "dialogId", 0) or 0)
        anonymous = bool(self._field(send_sheet, "anonymous", False))
        upgrade = bool(self._field(send_sheet, "upgrade", False))
        message = self._send_sheet_message(send_sheet)

        state.quantity = int(normalized_quantity)
        state.sending = True
        state.sent = 0
        state.requested = int(normalized_quantity)
        self._apply_send_sheet_button_text(send_sheet, True)
        self._send_sheet_bulk_step(
            send_sheet,
            gift,
            anonymous,
            upgrade,
            dialog_id,
            message,
            int(normalized_quantity),
            int(current_account),
            0,
        )
        return True

    def _send_sheet_bulk_step(
        self,
        send_sheet: Any,
        gift: Any,
        anonymous: bool,
        upgrade: bool,
        dialog_id: int,
        message: Any,
        total_quantity: int,
        current_account: int,
        completed: int,
    ):
        controller = self._stars_controller_for_account(current_account)
        if controller is None:
            self._finish_send_sheet_bulk(send_sheet, gift, current_account, completed, total_quantity, False, "StarsController missing")
            return

        def _on_done(status: bool, err: Any):
            if status:
                next_completed = int(completed) + 1
                state = self._send_sheet_state(send_sheet)
                state.sent = next_completed
                state.requested = int(total_quantity)
                if next_completed >= int(total_quantity):
                    self._finish_send_sheet_bulk(send_sheet, gift, current_account, next_completed, total_quantity, True, None)
                    return
                self._apply_send_sheet_button_text(send_sheet, True)
                self._send_sheet_bulk_step(
                    send_sheet,
                    gift,
                    anonymous,
                    upgrade,
                    dialog_id,
                    message,
                    total_quantity,
                    current_account,
                    next_completed,
                )
                return
            self._finish_send_sheet_bulk(send_sheet, gift, current_account, completed, total_quantity, False, err)

        try:
            controller.buyStarGift(gift, anonymous, upgrade, dialog_id, message, self._make_callback2(_on_done))
        except Exception as e:
            self._finish_send_sheet_bulk(send_sheet, gift, current_account, completed, total_quantity, False, str(e))

    def _finish_send_sheet_bulk(
        self,
        send_sheet: Any,
        gift: Any,
        current_account: int,
        completed: int,
        total_quantity: int,
        success: bool,
        err: Any,
    ):
        key = self._send_sheet_key(send_sheet)
        state = self._send_sheet_states.get(key)
        if not isinstance(state, _SendSheetState):
            state = self._send_sheet_state(send_sheet)
        state.sending = False
        state.sent = int(completed)
        state.requested = int(total_quantity)

        button = self._field(send_sheet, "button", None)
        if button is not None:
            try:
                button.setLoading(False)
            except Exception:
                pass

        if int(completed) > 0 and int(completed) < int(total_quantity):
            self._notify_success(self._t("send_quantity_partial", done=str(completed), total=str(total_quantity)))

        err_code = str(err or "")
        if success:
            close_parent_sheet = self._field(send_sheet, "closeParentSheet", None)
            try:
                if close_parent_sheet is not None:
                    close_parent_sheet.run()
            except Exception:
                pass
            self._hide_send_sheet_keyboard(send_sheet)
            self._dismiss_send_sheet(send_sheet)
            self._send_sheet_states.pop(key, None)
            return

        if err_code == "STARGIFT_USAGE_LIMITED":
            controller = self._stars_controller_for_account(current_account)
            if controller is not None and gift is not None:
                try:
                    controller.makeStarGiftSoldOut(gift)
                except Exception:
                    pass
            self._hide_send_sheet_keyboard(send_sheet)
            self._dismiss_send_sheet(send_sheet)
            self._send_sheet_states.pop(key, None)
            return

        if err_code == "STARGIFT_USER_USAGE_LIMITED":
            self._notify_error(self._t("error_usage_limited", code=err_code))
            self._hide_send_sheet_keyboard(send_sheet)
            self._dismiss_send_sheet(send_sheet)
            self._send_sheet_states.pop(key, None)
            return

        if int(completed) > 0 and int(completed) < int(total_quantity):
            state.quantity = max(1, int(total_quantity) - int(completed))
            adapter = self._field(send_sheet, "adapter", None)
            if adapter is not None:
                try:
                    adapter.update(True)
                except Exception:
                    pass

        if err_code != "":
            self._notify_error(self._t("error_with_code", code=err_code))
        if state.detached:
            self._send_sheet_states.pop(key, None)
            return
        self._apply_send_sheet_button_text(send_sheet, True)

    def _send_sheet_context(self, send_sheet: Any):
        context = None
        try:
            context = send_sheet.getContext()
        except Exception:
            context = None
        if context is not None:
            return context
        activity, _ = self._get_ui_context()
        return activity

    def _send_sheet_account(self, send_sheet: Any) -> int:
        account = self._to_int(self._field(send_sheet, "currentAccount", self._current_account()))
        if account is None:
            return self._current_account()
        return int(account)

    def _hide_send_sheet_keyboard(self, send_sheet: Any):
        try:
            AndroidUtilities = jclass("org.telegram.messenger.AndroidUtilities")
            message_edit = self._field(send_sheet, "messageEdit", None)
            if message_edit is not None:
                AndroidUtilities.hideKeyboard(message_edit)
        except Exception:
            pass

    def _dismiss_send_sheet(self, send_sheet: Any):
        try:
            send_sheet.dismiss()
        except Exception:
            pass

    def _can_patch_sheet(self, sheet: Any) -> bool:
        selected_tab = int(self._field(sheet, "selectedTab", -1) or -1)
        tab_all = int(self._field(sheet, "TAB_ALL", -1) or -1)
        if selected_tab != tab_all:
            return False

        if bool(self._field(sheet, "birthday", False)):
            return False

        user_settings = self._field(sheet, "userSettings", None)
        try:
            return not (user_settings is not None and bool(user_settings.disallow_unlimited_stargifts))
        except Exception:
            return True

    def _scan_sheet(self, items: Any):
        existing_ids = set()
        insert_index = -1
        size = int(items.size())

        for index in range(size):
            item = self._get_at(items, index)
            if item is None:
                continue
            obj = getattr(item, "object", None)
            gift_id = self._gift_id(obj)
            if gift_id <= 0:
                continue
            existing_ids.add(gift_id)
            if insert_index < 0 and self._is_gift(obj):
                insert_index = index

        if insert_index < 0:
            insert_index = size
        return existing_ids, insert_index

    def _build_sheet_items(self, tab_all: int, existing_ids: set) -> List[Any]:
        gift_factory = self._gift_item_factory()
        if gift_factory is None:
            return []

        hidden_items = []
        for spec in self._gift_specs():
            gift_id = int(spec["id"])
            if gift_id in existing_ids:
                continue

            gift = self._hidden_gift(gift_id)
            if gift is None:
                continue

            try:
                item = self._make_star_gift_item(gift_factory, tab_all, gift)
                if item is not None:
                    hidden_items.append(item)
            except Exception as e:
                self.log(f"[HiddenGift] asStarGift failed for {gift_id}: {e}")
        return hidden_items

    def _insert_items(self, items: Any, insert_index: int, new_items: List[Any]):
        for offset, item in enumerate(new_items):
            try:
                items.add(int(insert_index + offset), item)
            except Exception:
                try:
                    items.add(item)
                except Exception as e:
                    self.log(f"[HiddenGift] insert hidden gift item failed: {e}")
                    break

    def _gift_item_factory(self):
        try:
            return jclass("org.telegram.ui.Gifts.GiftSheet$GiftCell$Factory")
        except Exception:
            return None

    def _make_star_gift_item(self, gift_factory: Any, tab_all: int, gift: Any):
        arity = self._resolve_star_gift_factory_arity(gift_factory)
        try:
            if arity == 6:
                return gift_factory.asStarGift(tab_all, gift, False, False, False, False)
            if arity == 7 or arity is None:
                item = gift_factory.asStarGift(tab_all, gift, False, False, False, False, False)
                if arity is None:
                    self._star_gift_factory_arity = 7
                return item
        except Exception:
            pass

        for args in (
            (tab_all, gift, False, False, False, False),
            (tab_all, gift, False, False, False, False, False),
        ):
            try:
                item = gift_factory.asStarGift(*args)
                if self._star_gift_factory_arity is None:
                    self._star_gift_factory_arity = len(args)
                    self.log(f"[HiddenGift] GiftCell.Factory.asStarGift fallback arity: {len(args)}")
                return item
            except Exception:
                pass
        return None

    def _resolve_star_gift_factory_arity(self, gift_factory: Any) -> Optional[int]:
        cached = self._star_gift_factory_arity
        if cached is not None:
            return int(cached)

        try:
            for method in self._iter_declared_methods(gift_factory):
                try:
                    if method.getName() != "asStarGift":
                        continue
                    params = method.getParameterTypes()
                    if len(params) < 3:
                        continue
                    second_param = str(params[1])
                    if ("$SavedStarGift" in second_param) or ("SavedStarGift" in second_param):
                        continue
                    if ("$StarGift" not in second_param) and ("StarGift" not in second_param):
                        continue
                    self._star_gift_factory_arity = int(len(params))
                    self.log(f"[HiddenGift] GiftCell.Factory.asStarGift arity detected: {len(params)}")
                    return int(len(params))
                except Exception:
                    pass
        except Exception:
            pass
        return None

    def _gift_spec(self, gift_id: Any):
        try:
            gift_id = int(gift_id)
        except Exception:
            return None
        if gift_id == _CONFIG_GIFT_ID:
            return _CONFIG_GIFT_SPEC
        builtin = _BUILTIN_GIFT_SPECS_BY_ID.get(gift_id)
        if builtin is not None:
            return builtin
        for spec in self._custom_gift_specs():
            if int(spec["id"]) == gift_id:
                return spec
        return None

    def _gift_specs(self) -> List[Dict[str, Any]]:
        return [_CONFIG_GIFT_SPEC] + list(_BUILTIN_GIFT_SPECS) + self._custom_gift_specs()

    def _is_custom_gift(self, gift_id: int) -> bool:
        for spec in self._custom_gift_specs():
            if int(spec["id"]) == int(gift_id):
                return True
        return False

    def _custom_gift_specs(self) -> List[Dict[str, Any]]:
        raw = str(self.get_setting(_CUSTOM_GIFT_SETTING, "") or "")
        return self._parse_custom_gift_specs(raw)

    def _custom_pack_name(self, pack_name: Any) -> str:
        pack_name = str(pack_name or "").strip()
        return pack_name or _CUSTOM_GIFT_PACK

    def _normalize_custom_sticker_index(self, sticker_number: Any) -> int:
        parsed = self._to_int(sticker_number)
        if parsed is None or parsed < 0:
            return _CUSTOM_GIFT_STICKER
        return int(parsed)

    def _parse_custom_gift_specs(self, raw: str) -> List[Dict[str, Any]]:
        if raw.strip() == "":
            return []

        specs: List[Dict[str, Any]] = []
        seen = set()
        parts = re.split(r"[\n,;]+", raw)
        for part in parts:
            token = str(part).strip()
            if token == "":
                continue

            gift_text = token
            stars = _CUSTOM_GIFT_DEFAULT_STARS
            pack_name = _CUSTOM_GIFT_PACK
            sticker_number = _CUSTOM_GIFT_STICKER

            if "|" in token:
                chunks = [str(chunk).strip() for chunk in token.split("|")]
                if chunks:
                    gift_text = chunks[0]
                if len(chunks) > 1 and chunks[1] != "":
                    pack_name = self._custom_pack_name(chunks[1])
                if len(chunks) > 2:
                    sticker_number = self._normalize_custom_sticker_index(chunks[2])

            if ":" in gift_text:
                gift_text, stars_text = gift_text.split(":", 1)
                parsed_stars = self._to_int(stars_text)
                if parsed_stars is not None and parsed_stars > 0:
                    stars = parsed_stars

            gift_id = self._to_int(gift_text)
            if gift_id is None or gift_id <= 0:
                continue
            if gift_id in seen or gift_id in _BUILTIN_GIFT_SPECS_BY_ID or gift_id == _CONFIG_GIFT_ID:
                continue

            seen.add(gift_id)
            specs.append(
                {
                    "id": int(gift_id),
                    "stars": int(stars),
                    "sticker_number": int(sticker_number),
                    "pack": str(pack_name),
                }
            )
        return specs

    def _format_custom_gift_specs(self, specs: List[Dict[str, Any]]) -> str:
        lines = []
        for spec in specs:
            gift_id = int(spec["id"])
            stars = int(spec.get("stars", _CUSTOM_GIFT_DEFAULT_STARS) or _CUSTOM_GIFT_DEFAULT_STARS)
            pack_name = self._custom_pack_name(spec.get("pack", _CUSTOM_GIFT_PACK))
            sticker_number = self._normalize_custom_sticker_index(spec.get("sticker_number", _CUSTOM_GIFT_STICKER))

            if stars == _CUSTOM_GIFT_DEFAULT_STARS:
                line = str(gift_id)
            else:
                line = f"{gift_id}:{stars}"

            if pack_name != _CUSTOM_GIFT_PACK or sticker_number != _CUSTOM_GIFT_STICKER:
                line = f"{line}|{pack_name}|{sticker_number}"
            lines.append(line)
        return "\n".join(lines)

    def _gift_id(self, obj: Any) -> int:
        if obj is None:
            return 0
        try:
            return int(getattr(obj, "id", 0) or 0)
        except Exception:
            return 0

    def _is_gift(self, obj: Any) -> bool:
        if obj is None:
            return False
        try:
            return self._gift_id(obj) > 0 and hasattr(obj, "stars")
        except Exception:
            return False

    def _hidden_gift(self, gift_id: int):
        gift_id = int(gift_id)
        cached = self._hidden_gift_cache.get(gift_id)
        spec = self._gift_spec(gift_id)
        if spec is None:
            return None

        if cached is not None:
            self._fill_hidden_gift(cached, gift_id, spec)
            return cached

        gift_class = getattr(TL_stars, "TL_starGift", None)
        if gift_class is None:
            return None

        pack_name = str(spec.get("pack", _BUILTIN_GIFT_PACK) or _BUILTIN_GIFT_PACK)
        if not self._pack_docs.get(pack_name) and pack_name not in self._loading_packs:
            self._load_pack(pack_name)

        try:
            gift = gift_class()
            self._fill_hidden_gift(gift, gift_id, spec)
            self._hidden_gift_cache[gift_id] = gift
            return gift
        except Exception as e:
            self.log(f"[HiddenGift] hidden gift build error for {gift_id}: {e}")
            return None

    def _fill_hidden_gift(self, gift: Any, gift_id: int, spec: Dict[str, Any]):
        title = str(spec.get("title", "") or "")
        gift.id = self._as_java_long(gift_id)
        gift.title = title
        gift.flags = 32 if title else 0
        gift.stars = self._as_java_long(spec.get("stars", 50))
        self._set_optional_star_gift_field(gift, "convert_stars", self._as_java_long(0))

        for field_name in (
            "limited",
            "sold_out",
            "birthday",
            "require_premium",
            "resale_ton_only",
            "limited_per_user",
            "peer_color_available",
            "can_upgrade",
            "auction",
            "theme_available",
            "burned",
            "crafted",
        ):
            self._set_optional_star_gift_field(gift, field_name, False)

        for field_name in (
            "per_user_total",
            "per_user_remains",
            "locked_until_date",
            "availability_remains",
            "availability_total",
            "gifts_per_round",
            "offer_min_stars",
            "auction_start_date",
            "upgrade_variants",
            "craft_chance_permille",
            "num",
            "first_sale_date",
            "last_sale_date",
        ):
            self._set_optional_star_gift_field(gift, field_name, 0)

        for field_name in (
            "availability_resale",
            "upgrade_stars",
            "resell_min_stars",
            "value_amount",
            "value_usd_amount",
        ):
            self._set_optional_star_gift_field(gift, field_name, self._as_java_long(0))

        for field_name in (
            "slug",
            "auction_slug",
            "value_currency",
            "owner_name",
            "owner_address",
            "gift_address",
        ):
            self._set_optional_star_gift_field(gift, field_name, "")

        for field_name in (
            "background",
            "theme_peer",
            "peer_color",
            "host_id",
            "owner_id",
            "released_by",
            "resell_amount",
        ):
            self._set_optional_star_gift_field(gift, field_name, None)

        self._set_optional_star_gift_field(gift, "attributes", ArrayList())
        self._bind_hidden_sticker(gift, gift_id)

    def _bind_hidden_sticker(self, gift: Any, gift_id: int):
        spec = self._gift_spec(gift_id)
        if spec is None:
            return
        sticker = self._pack_sticker(
            str(spec.get("pack", _BUILTIN_GIFT_PACK) or _BUILTIN_GIFT_PACK),
            self._sticker_index(spec),
        )
        if sticker is not None:
            self._set_optional_star_gift_field(gift, "sticker", sticker)

    def _sticker_index(self, spec: Dict[str, Any]) -> int:
        pack_name = str(spec.get("pack", "") or "")
        if pack_name == _CONFIG_GIFT_PACK:
            docs = self._pack_docs.get(pack_name) or []
            if docs:
                upper = min(_CONFIG_GIFT_STICKER_MAX, len(docs) - 1)
                if upper >= _CONFIG_GIFT_STICKER_MIN:
                    return random.randint(_CONFIG_GIFT_STICKER_MIN, upper)
            return _CONFIG_GIFT_STICKER_MIN
        return int(spec.get("sticker_number", -1) or -1)

    def _get_at(self, values: Any, index: int):
        try:
            return values[index]
        except Exception:
            pass
        try:
            return values.get(index)
        except Exception:
            return None

    def _field(self, obj: Any, field_name: str, default: Any = None):
        if obj is None:
            return default
        try:
            return getattr(obj, field_name)
        except Exception:
            pass
        try:
            value = get_private_field(obj, field_name)
            return default if value is None else value
        except Exception:
            return default

    def _tune_config_cell(self, cell: Any, gift: Any):
        if self._gift_id(gift) != _CONFIG_GIFT_ID:
            return

        price_view = self._field(cell, "priceView", None)
        if price_view is None:
            return

        try:
            price_view.setText(self._t("config_chip"))
        except Exception:
            pass

    def _open_custom_gifts_dialog(self, context: Any):
        form = self._build_custom_gifts_form(context)
        if form is None:
            self._notify_error(self._t("no_context"))
            return

        try:
            builder = AlertDialogBuilder(context, AlertDialogBuilder.ALERT_TYPE_MESSAGE)
            builder.set_title(self._t("custom_gifts_title"))
            builder.set_view(form["root"])
            builder.set_positive_button(self._t("custom_gifts_add"), lambda b, _w: self._save_custom_gifts(b, form))
            builder.set_negative_button(self._t("cancel_button"), lambda b, _w: b.dismiss())
            try:
                builder.set_on_dismiss_listener(lambda _b: self._on_form_dismiss(form))
            except Exception:
                pass
            self._apply_dialog_style(builder, context)
            builder.show()
        except Exception as e:
            self.log(f"[HiddenGift] custom gifts dialog error: {e}")
            self._notify_error(self._t("no_context"))

    def _build_custom_gifts_form(self, context: Any) -> Optional[Dict[str, Any]]:
        try:
            LinearLayout = jclass("android.widget.LinearLayout")
            ScrollView = jclass("android.widget.ScrollView")
            TextView = jclass("android.widget.TextView")
            ViewGroupLayoutParams = jclass("android.view.ViewGroup$LayoutParams")
            LayoutParams = jclass("android.widget.LinearLayout$LayoutParams")

            scroll = ScrollView(context)
            container = LinearLayout(context)
            container.setOrientation(LinearLayout.VERTICAL)
            pad = self._dp(16)
            container.setPadding(pad, pad, pad, pad)
            scroll.addView(container)

            current_view = TextView(context)
            current_view.setText(self._custom_gifts_summary())
            current_view.setTextSize(13)
            self._apply_text_color(current_view, "key_dialogTextGray2")
            current_lp = LayoutParams(ViewGroupLayoutParams.MATCH_PARENT, ViewGroupLayoutParams.WRAP_CONTENT)
            current_lp.setMargins(0, self._dp(10), 0, self._dp(10))
            container.addView(current_view, current_lp)

            gift_input = self._create_text_input(
                context=context,
                hint=self._t("custom_gifts_hint"),
                value="",
                multiline=False,
                numeric=True,
            )
            self._add_field_card(container, context, self._t("custom_gifts_label"), gift_input)

            price_input = self._create_text_input(
                context=context,
                hint=self._t("custom_gifts_price_hint"),
                value=str(_CUSTOM_GIFT_DEFAULT_STARS),
                multiline=False,
                numeric=True,
            )
            self._add_field_card(container, context, self._t("custom_gifts_price_label"), price_input)

            pack_input = self._create_text_input(
                context=context,
                hint=self._t("custom_gifts_pack_hint"),
                value=_CUSTOM_GIFT_PACK,
                multiline=False,
                numeric=False,
            )
            self._add_field_card(container, context, self._t("custom_gifts_pack_label"), pack_input)

            sticker_input = self._create_text_input(
                context=context,
                hint=self._t("custom_gifts_index_hint"),
                value=str(_CUSTOM_GIFT_STICKER),
                multiline=False,
                numeric=True,
            )
            sticker_card = self._add_field_card(container, context, self._t("custom_gifts_index_label"), sticker_input)

            form: Dict[str, Any] = {
                "root": scroll,
                "context": context,
                "gift_input": gift_input,
                "price_input": price_input,
                "pack_input": pack_input,
                "sticker_input": sticker_input,
                "_cleanup": [],
                "_dismissed": False,
            }
            picker_button = self._add_card_button(
                sticker_card,
                context,
                self._t("custom_gifts_index_picker"),
                lambda: self._open_custom_gift_index_picker(form),
            )
            form["picker_button"] = picker_button
            self._attach_custom_gift_form_listeners(form)
            self._update_custom_gift_picker_button(picker_button, self._read_text(pack_input))

            return form
        except Exception as e:
            self.log(f"[HiddenGift] build custom gifts form error: {e}")
            return None

    def _attach_custom_gift_form_listeners(self, form: Dict[str, Any]):
        cleanup_list = form.get("_cleanup")
        if not isinstance(cleanup_list, list):
            cleanup_list = []
            form["_cleanup"] = cleanup_list

        def on_pack_change():
            button = form.get("picker_button")
            pack_name = self._read_text(form.get("pack_input"))
            self._update_custom_gift_picker_button(button, pack_name)
            pending = self._custom_gift_picker_request
            if isinstance(pending, dict) and pending.get("form") is form:
                pending_pack = self._custom_pack_name(pending.get("pack_name", ""))
                current_pack = self._custom_pack_name(pack_name)
                if pending_pack != current_pack:
                    self._custom_gift_picker_request = None

        cleanup = self._bind_text_watcher(form.get("pack_input"), on_pack_change)
        if cleanup is not None:
            cleanup_list.append(cleanup)

    def _save_custom_gifts(self, builder: AlertDialogBuilder, form: Dict[str, Any]):
        gift_id = self._to_int(self._read_text(form.get("gift_input")))
        if gift_id is None or gift_id <= 0:
            self._notify_error(self._t("custom_gifts_missing_id"))
            return

        specs = self._custom_gift_specs()
        filtered = [spec for spec in specs if int(spec["id"]) != int(gift_id)]

        price = self._to_int(self._read_text(form.get("price_input")))
        if price is None or price <= 0:
            price = _CUSTOM_GIFT_DEFAULT_STARS

        pack_name = self._custom_pack_name(self._read_text(form.get("pack_input")))
        sticker_number = self._normalize_custom_sticker_index(self._read_text(form.get("sticker_input")))
        docs = self._pack_docs.get(pack_name) or []
        if docs:
            sticker_number = max(0, min(int(sticker_number), len(docs) - 1))

        self._load_pack(pack_name)
        filtered.append(
            {
                "id": int(gift_id),
                "stars": int(price),
                "sticker_number": int(sticker_number),
                "pack": str(pack_name),
            }
        )
        self._store_custom_gifts(filtered)
        try:
            builder.dismiss()
        except Exception:
            pass
        self._notify_success(self._t("custom_gifts_saved"))

    def _store_custom_gifts(self, specs: List[Dict[str, Any]]):
        normalized = self._format_custom_gift_specs(specs)
        try:
            self.set_setting(_CUSTOM_GIFT_SETTING, normalized)
        except Exception as e:
            self.log(f"[HiddenGift] save custom gifts error: {e}")
            return
        self._refresh_gift_sheet()

    def _custom_gifts_summary(self) -> str:
        specs = self._custom_gift_specs()
        if not specs:
            return self._t("custom_gifts_current_empty")

        items = []
        for spec in specs:
            gift_id = int(spec["id"])
            stars = int(spec.get("stars", _CUSTOM_GIFT_DEFAULT_STARS) or _CUSTOM_GIFT_DEFAULT_STARS)
            pack_name = self._custom_pack_name(spec.get("pack", _CUSTOM_GIFT_PACK))
            sticker_number = self._normalize_custom_sticker_index(spec.get("sticker_number", _CUSTOM_GIFT_STICKER))
            item = str(gift_id) if stars == _CUSTOM_GIFT_DEFAULT_STARS else f"{gift_id}:{stars}"
            if pack_name != _CUSTOM_GIFT_PACK or sticker_number != _CUSTOM_GIFT_STICKER:
                item = f"{item} | {pack_name}#{sticker_number}"
            items.append(item)
        return self._t("custom_gifts_current", items=", ".join(items))

    def _update_custom_gift_picker_button(self, button: Any, pack_name: Any):
        if button is None:
            return
        pack_name = self._custom_pack_name(pack_name)
        docs = self._pack_docs.get(pack_name) or []
        if docs:
            text = self._t("custom_gifts_index_picker_ready", max_index=str(max(0, len(docs) - 1)))
        elif pack_name in self._loading_packs:
            text = self._t("custom_gifts_index_picker_loading_button")
        else:
            text = self._t("custom_gifts_index_picker")
        self._set_text(button, text)

    def _open_custom_gift_index_picker(self, form: Dict[str, Any]):
        context = form.get("context")
        if context is None:
            context, _ = self._get_ui_context()
        if context is None:
            self._notify_error(self._t("no_context"))
            return

        pack_raw = self._read_text(form.get("pack_input"))
        pack_name = self._custom_pack_name(pack_raw)
        if str(pack_raw).strip() == "":
            self._set_text(form.get("pack_input"), pack_name)

        docs = self._pack_docs.get(pack_name) or []
        if not docs:
            self._custom_gift_picker_request = {
                "form": form,
                "context": context,
                "pack_name": pack_name,
                "index_input": form.get("sticker_input"),
                "button": form.get("picker_button"),
            }
            self._load_pack(pack_name)
            self._update_custom_gift_picker_button(form.get("picker_button"), pack_name)
            self._notify_success(self._t("custom_gifts_pack_loading"))
            return

        self._show_custom_gift_index_picker(context, pack_name, form.get("sticker_input"), form.get("picker_button"))

    def _show_custom_gift_index_picker(self, context: Any, pack_name: str, index_input: Any, button: Any):
        docs = self._pack_docs.get(pack_name) or []
        if not docs:
            self._notify_error(self._t("custom_gifts_pack_error", pack=pack_name))
            return

        try:
            NumberPicker = jclass("org.telegram.ui.Components.NumberPicker")
            LinearLayout = jclass("android.widget.LinearLayout")
            TextView = jclass("android.widget.TextView")
            ViewGroupLayoutParams = jclass("android.view.ViewGroup$LayoutParams")
            LayoutParams = jclass("android.widget.LinearLayout$LayoutParams")
            Gravity = jclass("android.view.Gravity")
            TypedValue = jclass("android.util.TypedValue")
        except Exception as e:
            self.log(f"[HiddenGift] number picker classes missing: {e}")
            self._notify_error(self._t("custom_gifts_pack_error", pack=pack_name))
            return

        max_index = max(0, len(docs) - 1)
        current_index = self._normalize_custom_sticker_index(self._read_text(index_input))
        current_index = max(0, min(current_index, max_index))

        try:
            container = LinearLayout(context)
            container.setOrientation(LinearLayout.VERTICAL)
            container.setPadding(self._dp(20), self._dp(10), self._dp(20), self._dp(4))

            info = TextView(context)
            info.setText(self._t("custom_gifts_index_picker_info", pack=pack_name, max_index=str(max_index)))
            try:
                info.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
            except Exception:
                info.setTextSize(14)
            try:
                info.setGravity(int(getattr(Gravity, "CENTER_HORIZONTAL", 1)))
            except Exception:
                pass
            self._apply_text_color(info, "key_dialogTextBlack")
            info_lp = LayoutParams(ViewGroupLayoutParams.MATCH_PARENT, ViewGroupLayoutParams.WRAP_CONTENT)
            info_lp.setMargins(0, 0, 0, self._dp(10))
            container.addView(info, info_lp)

            picker = NumberPicker(context)
            try:
                picker.setItemCount(5)
            except Exception:
                pass
            picker.setMinValue(0)
            picker.setMaxValue(max_index)
            try:
                picker.setWrapSelectorWheel(max_index > 0)
            except Exception:
                pass
            picker.setValue(current_index)
            container.addView(
                picker,
                LayoutParams(
                    ViewGroupLayoutParams.MATCH_PARENT,
                    self._dp(int(getattr(NumberPicker, "DEFAULT_SIZE_PER_COUNT", 42) or 42) * 5),
                ),
            )

            def on_pick(builder_obj: AlertDialogBuilder, _which: int):
                self._set_text(index_input, str(int(picker.getValue())))
                self._update_custom_gift_picker_button(button, pack_name)
                try:
                    builder_obj.dismiss()
                except Exception:
                    pass

            builder = AlertDialogBuilder(context, AlertDialogBuilder.ALERT_TYPE_MESSAGE)
            builder.set_title(self._t("custom_gifts_index_picker_title"))
            builder.set_view(container)
            builder.set_positive_button(self._t("custom_gifts_index_picker_apply"), on_pick)
            builder.set_negative_button(self._t("cancel_button"), lambda b, _w: b.dismiss())
            builder.show()
        except Exception as e:
            self.log(f"[HiddenGift] custom gift index picker error: {e}")
            self._notify_error(self._t("custom_gifts_pack_error", pack=pack_name))

    def _after_custom_pack_loaded(self, pack_name: str):
        self._refresh_gift_sheet()
        pending = self._custom_gift_picker_request
        if not isinstance(pending, dict):
            return
        if self._custom_pack_name(pending.get("pack_name", "")) != self._custom_pack_name(pack_name):
            return

        self._custom_gift_picker_request = None
        form = pending.get("form")
        if isinstance(form, dict) and bool(form.get("_dismissed")):
            return

        button = pending.get("button")
        self._update_custom_gift_picker_button(button, pack_name)

        context = pending.get("context")
        if context is None:
            context, _ = self._get_ui_context()
        if context is None:
            return

        self._show_custom_gift_index_picker(context, pack_name, pending.get("index_input"), button)

    def _on_custom_gift_pack_failed(self, pack_name: str):
        pending = self._custom_gift_picker_request
        if not isinstance(pending, dict):
            return
        if self._custom_pack_name(pending.get("pack_name", "")) != self._custom_pack_name(pack_name):
            return
        self._custom_gift_picker_request = None
        self._update_custom_gift_picker_button(pending.get("button"), pack_name)
        self._notify_error(self._t("custom_gifts_pack_error", pack=pack_name))

    def _refresh_gift_sheet(self):
        sheet = self._gift_sheet
        if sheet is None:
            return

        adapter = self._field(sheet, "adapter", None)
        if adapter is None:
            return

        try:
            adapter.update(True)
            return
        except Exception:
            pass

        try:
            adapter.notifyDataSetChanged()
        except Exception:
            pass

    def _on_chat_menu_click(self, context: Any):
        dialog_id = self._resolve_context_dialog_id(context)
        run_on_ui_thread(lambda: self._open_picker_dialog(dialog_id, context))

    def _open_picker_dialog(self, context_dialog_id: int, context: Any = None):
        activity, _ = self._get_ui_context()
        if activity is None:
            self._notify_error(self._t("no_context"))
            return

        if self._open_picker_item_options(context_dialog_id, context):
            return

        items = [self._t("picker_manual")]

        def on_pick(_builder: AlertDialogBuilder, which: int):
            if int(which) == 0:
                self._open_send_dialog(context_dialog_id, "")

        try:
            builder = AlertDialogBuilder(activity, AlertDialogBuilder.ALERT_TYPE_MESSAGE)
            builder.set_title(self._t("picker_title"))
            builder.set_message(self._t("picker_text"))
            builder.set_items(items, on_pick)
            builder.set_negative_button(self._t("cancel_button"), lambda b, _w: b.dismiss())
            self._apply_dialog_style(builder, activity)
            builder.show()
        except Exception as e:
            self.log(f"[HiddenGift] picker dialog error: {e}")
            self._notify_error(self._t("no_context"))

    def _open_picker_item_options(self, context_dialog_id: int, context: Any) -> bool:
        activity, fragment = self._get_ui_context()
        if activity is None or fragment is None:
            return False

        try:
            ItemOptions = jclass("org.telegram.ui.Components.ItemOptions")
        except Exception:
            return False

        anchor = self._resolve_picker_anchor_view(activity, context)
        if anchor is None:
            return False

        manual_icon = 0
        try:
            TelegramR = jclass("org.telegram.messenger.R")
            manual_icon = int(getattr(getattr(TelegramR, "drawable", None), "menu_stars_gift", 0) or 0)
        except Exception:
            pass

        try:
            options = ItemOptions.makeOptions(fragment, anchor)
            try:
                options.setDrawScrim(False)
            except Exception:
                pass

            manual_action = R(lambda: self._open_send_dialog(context_dialog_id, ""))
            if manual_icon:
                options.add(manual_icon, self._t("picker_manual"), manual_action)
            else:
                options.add(self._t("picker_manual"), manual_action)

            options.show()
            return True
        except Exception as e:
            self.log(f"[HiddenGift] item options picker error: {e}")
            return False

    def _resolve_picker_anchor_view(self, activity: Any, context: Any):
        if context is not None and hasattr(context, "get"):
            for key in ("view", "menu_view", "anchor_view", "item_view", "clicked_view"):
                try:
                    view = context.get(key)
                    if view is not None:
                        return view
                except Exception:
                    pass

        try:
            fragment = get_last_fragment()
            if fragment is not None and hasattr(fragment, "getFragmentView"):
                view = fragment.getFragmentView()
                if view is not None:
                    return view
        except Exception:
            pass

        try:
            window = activity.getWindow() if activity is not None else None
            if window is None:
                return None
            decor = window.getDecorView()
            if decor is not None:
                return decor
        except Exception:
            pass
        return None

    def _open_send_dialog(self, context_dialog_id: int, preset_gift_id: str):
        activity, _ = self._get_ui_context()
        if activity is None:
            self._notify_error(self._t("no_context"))
            return

        form = self._build_send_form(activity, context_dialog_id, preset_gift_id)
        if form is None:
            self._notify_error(self._t("no_context"))
            return

        try:
            builder = AlertDialogBuilder(activity, AlertDialogBuilder.ALERT_TYPE_MESSAGE)
            builder.set_title(self._t("dialog_title"))
            builder.set_view(form["root"])
            builder.set_positive_button(
                self._t("send_button"),
                lambda b, _w: self._on_send_click(b, form, context_dialog_id),
            )
            builder.set_negative_button(self._t("cancel_button"), lambda b, _w: b.dismiss())
            try:
                builder.set_on_dismiss_listener(lambda _b: self._on_form_dismiss(form))
            except Exception:
                pass
            self._apply_dialog_style(builder, activity)
            builder.show()
            if "preview_title" in form:
                self._refresh_preview(form, allow_remote=True)
        except Exception as e:
            self.log(f"[HiddenGift] send dialog error: {e}")
            self._notify_error(self._t("no_context"))

    def _build_send_form(self, context: Any, context_dialog_id: int, preset_gift_id: str) -> Optional[Dict[str, Any]]:
        try:
            LinearLayout = jclass("android.widget.LinearLayout")
            ScrollView = jclass("android.widget.ScrollView")
            ViewGroupLayoutParams = jclass("android.view.ViewGroup$LayoutParams")
            LayoutParams = jclass("android.widget.LinearLayout$LayoutParams")

            scroll = ScrollView(context)
            container = LinearLayout(context)
            container.setOrientation(LinearLayout.VERTICAL)
            pad = self._dp(16)
            container.setPadding(pad, pad, pad, pad)
            scroll.addView(container)

            default_gift_id = str(preset_gift_id or "").strip()

            default_target = ""
            if not default_target and context_dialog_id:
                default_target = str(context_dialog_id)

            default_message = ""
            default_anonymous = True

            preview_session = self._next_preview_session()
            self._active_preview_session = preview_session

            preview = self._build_preview_card(context)
            if preview is not None:
                preview_lp = LayoutParams(ViewGroupLayoutParams.MATCH_PARENT, ViewGroupLayoutParams.WRAP_CONTENT)
                preview_lp.setMargins(0, self._dp(10), 0, self._dp(14))
                container.addView(preview["preview_root"], preview_lp)

            gift_input = self._create_text_input(
                context=context,
                hint=self._t("gift_hint"),
                value=default_gift_id,
                multiline=False,
                numeric=True,
            )
            self._add_field_card(container, context, self._t("gift_label"), gift_input)

            target_input = self._create_text_input(
                context=context,
                hint=self._t("target_hint"),
                value=default_target,
                multiline=False,
                numeric=True,
            )
            self._add_field_card(container, context, self._t("target_label"), target_input)

            message_input = self._create_text_input(
                context=context,
                hint=self._t("message_hint"),
                value=default_message,
                multiline=True,
                numeric=False,
            )
            message_card = self._add_field_card(container, context, self._t("message_label"), message_input)
            self._add_message_emoji_action(message_card, context, message_input)

            anonymous_switch = self._create_telegram_toggle(context, self._t("anonymous_label"), default_anonymous)
            self._add_switch_row(container, context, anonymous_switch, top_margin_dp=12)

            form: Dict[str, Any] = {
                "root": scroll,
                "gift_input": gift_input,
                "target_input": target_input,
                "message_input": message_input,
                "anonymous_switch": anonymous_switch,
                "context_dialog_id": int(context_dialog_id or 0),
                "preview_session": int(preview_session),
                "_cleanup": [],
            }
            if preview is not None:
                form.update(preview)
                self._attach_preview_listeners(form)
                self._refresh_preview(form, allow_remote=True)
            return form
        except Exception as e:
            self.log(f"[HiddenGift] build form error: {e}")
            return None

    def _on_send_click(self, builder: AlertDialogBuilder, form: Dict[str, Any], context_dialog_id: int):
        gift_raw = self._read_text(form.get("gift_input"))
        target_raw = self._read_text(form.get("target_input"))
        anonymous = self._read_checked(form.get("anonymous_switch"), True)

        gift_id = self._to_int(gift_raw)
        if gift_id is None:
            self._notify_error(self._t("invalid_gift_id"))
            return

        if target_raw == "":
            target_dialog_id = context_dialog_id
        else:
            parsed_target = self._to_int(target_raw)
            if parsed_target is None:
                self._notify_error(self._t("invalid_target_id"))
                return
            target_dialog_id = parsed_target

        if int(target_dialog_id or 0) == 0:
            try:
                user_config = get_user_config()
                target_dialog_id = int(user_config.getClientUserId())
            except Exception:
                target_dialog_id = 0
        if int(target_dialog_id or 0) == 0:
            self._notify_error(self._t("invalid_target_id"))
            return

        messages_controller = get_messages_controller()
        if messages_controller is None:
            self._notify_error(self._t("cannot_resolve_peer"))
            return

        try:
            input_peer = messages_controller.getInputPeer(self._as_java_long(target_dialog_id))
        except Exception:
            input_peer = None
        if input_peer is None:
            self._notify_error(self._t("cannot_resolve_peer"))
            return

        try:
            builder.dismiss()
        except Exception:
            pass

        self._send_hidden_gift(
            gift_id=gift_id,
            target_dialog_id=int(target_dialog_id),
            input_peer=input_peer,
            anonymous=bool(anonymous),
            message_source=form.get("message_input"),
        )

    def _send_hidden_gift(
        self,
        gift_id: int,
        target_dialog_id: int,
        input_peer: Any,
        anonymous: bool,
        message_source: Any,
    ):
        invoice_class = getattr(TLRPC, "TL_inputInvoiceStarGift", None)
        if invoice_class is None:
            self._notify_error(self._t("error_with_code", code="TL_inputInvoiceStarGift class missing"))
            return

        try:
            invoice = invoice_class()
            invoice.hide_name = bool(anonymous)
            invoice.peer = input_peer
            invoice.gift_id = self._as_java_long(gift_id)
            text_entities = self._build_text_with_entities(message_source)
            if text_entities is not None:
                invoice.flags |= 2
                invoice.message = text_entities
        except Exception as e:
            self._notify_error(self._t("error_with_code", code=str(e)))
            return

        try:
            req = TLRPC.TL_payments_getPaymentForm()
            req.invoice = invoice
            self._attach_theme_params(req)
        except Exception as e:
            self._notify_error(self._t("error_with_code", code=str(e)))
            return

        self._show_progress(self._t("progress_title"), self._t("progress_text"))

        form_class = getattr(TLRPC, "TL_payments_paymentFormStarGift", None)
        result_class = getattr(TLRPC, "TL_payments_paymentResult", None)

        def on_form(response: Any, error: Any):
            if not self._is_payment_form(response, form_class):
                self._dismiss_progress()
                err_text = self._extract_error_text(error, self._t("error_no_form"))
                self._notify_error(self._t("error_with_code", code=err_text))
                return

            form = response
            try:
                req2 = TL_stars.TL_payments_sendStarsForm()
                req2.form_id = self._as_java_long(getattr(form, "form_id", 0))
                req2.invoice = invoice
            except Exception as e:
                self._dismiss_progress()
                self._notify_error(self._t("error_with_code", code=str(e)))
                return

            def on_send(response2: Any, error2: Any):
                self._dismiss_progress()
                if self._is_payment_result(response2, result_class):
                    self._process_updates(response2)
                    spent_stars = self._sum_stars_from_form(form)
                    self._notify_success(
                        self._t(
                            "send_success",
                            gift_id=str(gift_id),
                            target_id=str(target_dialog_id),
                            stars=str(spent_stars),
                        )
                    )
                    return

                err_code = self._extract_error_text(error2, self._t("unknown_error"))
                if err_code == "BALANCE_TOO_LOW":
                    self._notify_error(self._t("error_balance_low"))
                elif err_code in ("STARGIFT_USAGE_LIMITED", "STARGIFT_USER_USAGE_LIMITED"):
                    self._notify_error(self._t("error_usage_limited", code=err_code))
                else:
                    self._notify_error(self._t("error_with_code", code=err_code))

            try:
                send_request(req2, RequestCallback(on_send))
            except Exception as e:
                self._dismiss_progress()
                self._notify_error(self._t("error_with_code", code=str(e)))

        try:
            send_request(req, RequestCallback(on_form))
        except Exception as e:
            self._dismiss_progress()
            self._notify_error(self._t("error_with_code", code=str(e)))

    def _process_updates(self, payment_result: Any):
        try:
            updates = getattr(payment_result, "updates", None)
            if updates is None:
                return
            messages_controller = get_messages_controller()
            if messages_controller is None:
                return
            run_on_queue(lambda: messages_controller.processUpdates(updates, False))
        except Exception as e:
            self.log(f"[HiddenGift] processUpdates failed: {e}")

    def _attach_theme_params(self, req: Any):
        try:
            fragment = get_last_fragment()
            resources_provider = None
            if fragment is not None and hasattr(fragment, "getResourceProvider"):
                resources_provider = fragment.getResourceProvider()

            BotWebViewSheet = jclass("org.telegram.ui.web.BotWebViewSheet")
            theme_json = BotWebViewSheet.makeThemeParams(resources_provider)
            if theme_json is None:
                return

            data_json = TLRPC.TL_dataJSON()
            data_json.data = theme_json.toString()
            req.theme_params = data_json
            req.flags |= 1
        except Exception:
            pass

    def _build_text_with_entities(self, source: Any):
        raw_text = self._read_text(source)
        if str(raw_text).strip() == "":
            return None

        editable = self._read_editable(source)
        custom_emoji_entities = self._collect_custom_emoji_entities(editable, raw_text)

        parsed = None
        try:
            parsed = parse_markdown(raw_text)
        except SyntaxError:
            parsed = None
        except Exception as e:
            self.log(f"[HiddenGift] parse_markdown failed: {e}")
            parsed = None

        use_markdown = parsed is not None
        if parsed is not None and custom_emoji_entities:
            parsed_text = str(getattr(parsed, "text", "") or "")
            if parsed_text != str(raw_text):
                use_markdown = False
                self.log("[HiddenGift] markdown disabled for message with custom emoji spans")

        text_with_entities = TLRPC.TL_textWithEntities()
        tl_entities: List[Any] = []

        if use_markdown and parsed is not None:
            text_with_entities.text = str(getattr(parsed, "text", raw_text) or "")
            for ent in self._iter_java_items(getattr(parsed, "entities", None)):
                try:
                    tl_entities.append(ent.to_tlrpc_object())
                except Exception:
                    pass
        else:
            text_with_entities.text = str(raw_text)

        custom_entity_class = getattr(TLRPC, "TL_messageEntityCustomEmoji", None)
        if custom_entity_class is not None:
            for offset, length, document_id in custom_emoji_entities:
                if int(length) <= 0 or int(document_id) <= 0:
                    continue
                try:
                    entity = custom_entity_class()
                    entity.offset = int(offset)
                    entity.length = int(length)
                    entity.document_id = self._as_java_long(document_id)
                    tl_entities.append(entity)
                except Exception as e:
                    self.log(f"[HiddenGift] custom emoji entity build failed: {e}")
        elif custom_emoji_entities:
            self.log("[HiddenGift] TL_messageEntityCustomEmoji unavailable in runtime")

        try:
            tl_entities.sort(key=lambda item: int(getattr(item, "offset", 0) or 0))
        except Exception:
            pass

        entities = ArrayList()
        for entity in tl_entities:
            try:
                entities.add(entity)
            except Exception:
                pass
        text_with_entities.entities = entities
        return text_with_entities

    def _read_editable(self, source: Any):
        if source is None:
            return None
        if hasattr(source, "getSpans") and hasattr(source, "getSpanStart"):
            return source
        try:
            if hasattr(source, "getText"):
                return source.getText()
        except Exception:
            return None
        return None

    def _collect_custom_emoji_entities(self, editable: Any, fallback_text: str) -> List[Tuple[int, int, int]]:
        if editable is None:
            return []

        try:
            text_len = int(editable.length())
        except Exception:
            text_len = len(str(fallback_text or ""))

        try:
            AnimatedEmojiSpan = jclass("org.telegram.ui.Components.AnimatedEmojiSpan")
            spans = editable.getSpans(0, int(text_len), AnimatedEmojiSpan)
        except Exception:
            return []

        result: List[Tuple[int, int, int]] = []
        seen = set()
        for span in self._iter_java_items(spans):
            try:
                start = int(editable.getSpanStart(span))
                end = int(editable.getSpanEnd(span))
            except Exception:
                continue
            if start < 0 or end <= start:
                continue
            document_id = 0
            try:
                document_id = int(span.getDocumentId() or 0)
            except Exception:
                try:
                    document_id = int(getattr(span, "documentId", 0) or 0)
                except Exception:
                    document_id = 0
            if document_id <= 0:
                continue
            length = int(end - start)
            key = (int(start), int(length), int(document_id))
            if key in seen:
                continue
            seen.add(key)
            result.append(key)

        result.sort(key=lambda item: (item[0], item[1], item[2]))
        return result

    def _iter_java_items(self, value: Any) -> List[Any]:
        if value is None:
            return []
        try:
            return [item for item in value]
        except Exception:
            pass

        items = []
        try:
            size = int(value.size())
            for i in range(size):
                items.append(value.get(i))
            return items
        except Exception:
            pass

        try:
            size = int(len(value))
            for i in range(size):
                items.append(value[i])
            return items
        except Exception:
            return items

    def _sum_stars_from_form(self, form: Any) -> int:
        total = 0
        try:
            invoice = getattr(form, "invoice", None)
            prices = getattr(invoice, "prices", None) if invoice is not None else None
            if prices is None:
                return 0

            try:
                size = int(prices.size())
                for i in range(size):
                    item = prices.get(i)
                    total += int(getattr(item, "amount", 0) or 0)
                return int(total)
            except Exception:
                pass

            for item in prices:
                total += int(getattr(item, "amount", 0) or 0)
        except Exception:
            return 0
        return int(total)

    def _resolve_context_dialog_id(self, context: Any) -> int:
        try:
            if context is not None:
                dialog_id = context.get("dialog_id")
                parsed = self._to_int(dialog_id)
                if parsed not in (None, 0):
                    return int(parsed)

                chat = context.get("chat")
                if chat is not None:
                    chat_id = self._to_int(getattr(chat, "id", 0))
                    if chat_id not in (None, 0):
                        return -int(chat_id)

                user = context.get("user")
                if user is not None:
                    user_id = self._to_int(getattr(user, "id", 0))
                    if user_id not in (None, 0):
                        return int(user_id)
        except Exception:
            pass
        try:
            fragment = get_last_fragment()
            if fragment is not None:
                if hasattr(fragment, "getDialogId"):
                    did = self._to_int(fragment.getDialogId())
                    if did not in (None, 0):
                        return int(did)
                did_attr = self._to_int(getattr(fragment, "dialog_id", 0))
                if did_attr not in (None, 0):
                    return int(did_attr)
        except Exception:
            pass
        return 0

    def _apply_dialog_style(self, builder: AlertDialogBuilder, activity: Any):
        try:
            top_bg = self._theme_color("key_dialogTopBackground")
            size = self._dp(104)
            builder.set_top_animation(R.raw.gift, size, True, top_bg)
        except Exception:
            try:
                top_bg = self._theme_color("key_dialogTopBackground")
                builder.set_top_image(R.drawable.menu_stars_gift, top_bg)
            except Exception:
                pass
        try:
            builder.set_blurred_background(True)
        except Exception:
            pass

    def _show_progress(self, title: str, text: str):
        def _ui():
            self._dismiss_progress_now()
            activity, _ = self._get_ui_context()
            if activity is None:
                return
            try:
                builder = AlertDialogBuilder(activity, AlertDialogBuilder.ALERT_TYPE_SPINNER)
                builder.set_title(title)
                builder.set_message(text)
                builder.show()
                try:
                    builder.set_cancelable(False)
                    builder.set_canceled_on_touch_outside(False)
                except Exception:
                    pass
                self._progress_dialog = builder
            except Exception as e:
                self.log(f"[HiddenGift] show progress error: {e}")

        run_on_ui_thread(_ui)

    def _dismiss_progress(self):
        run_on_ui_thread(self._dismiss_progress_now)

    def _dismiss_progress_now(self):
        if self._progress_dialog is None:
            return
        try:
            self._progress_dialog.dismiss()
        except Exception:
            pass
        self._progress_dialog = None

    def _notify_success(self, text: str):
        run_on_ui_thread(lambda: BulletinHelper.show_success(str(text)))

    def _notify_error(self, text: str):
        run_on_ui_thread(lambda: BulletinHelper.show_error(str(text)))

    def _is_payment_form(self, response: Any, form_class: Any) -> bool:
        if response is None:
            return False
        try:
            if form_class is not None and isinstance(response, form_class):
                return True
        except Exception:
            pass
        name = self._get_class_name(response)
        return ("paymentFormStarGift" in name) or ("paymentFormStars" in name)

    def _is_payment_result(self, response: Any, result_class: Any) -> bool:
        if response is None:
            return False
        try:
            if result_class is not None and isinstance(response, result_class):
                return True
        except Exception:
            pass
        return "paymentResult" in self._get_class_name(response)

    def _extract_error_text(self, error: Any, fallback: str) -> str:
        if error is None:
            return str(fallback)
        for key in ("text", "error_message", "message"):
            try:
                value = getattr(error, key, None)
                if value:
                    return str(value)
            except Exception:
                pass
        try:
            text = str(error)
            if text:
                return text
        except Exception:
            pass
        return str(fallback)

    def _get_class_name(self, obj: Any) -> str:
        if obj is None:
            return ""
        try:
            return str(obj.getClass().getName())
        except Exception:
            pass
        try:
            return str(obj.__class__.__name__)
        except Exception:
            return ""

    def _get_ui_context(self):
        fragment = None
        activity = None
        try:
            fragment = get_last_fragment()
            if fragment is not None:
                activity = fragment.getParentActivity()
        except Exception:
            activity = None
        return activity, fragment

    def _next_preview_session(self) -> int:
        self._preview_session_seq = int(self._preview_session_seq) + 1
        return int(self._preview_session_seq)

    def _on_form_dismiss(self, form: Dict[str, Any]):
        try:
            self._dismiss_message_emoji_picker()
            form["_dismissed"] = True
            pending = self._custom_gift_picker_request
            if isinstance(pending, dict) and pending.get("form") is form:
                self._custom_gift_picker_request = None
            session = int(form.get("preview_session", 0) or 0)
            if session == int(self._active_preview_session):
                self._active_preview_session = -1
            for cleanup in list(form.get("_cleanup", [])):
                try:
                    cleanup()
                except Exception:
                    pass
            form["_cleanup"] = []
        except Exception:
            pass

    def _build_preview_card(self, context: Any) -> Optional[Dict[str, Any]]:
        try:
            LinearLayout = jclass("android.widget.LinearLayout")
            TextView = jclass("android.widget.TextView")
            FrameLayout = jclass("android.widget.FrameLayout")
            ImageView = jclass("android.widget.ImageView")
            ViewGroupLayoutParams = jclass("android.view.ViewGroup$LayoutParams")
            LinearLayoutParams = jclass("android.widget.LinearLayout$LayoutParams")
            FrameLayoutParams = jclass("android.widget.FrameLayout$LayoutParams")
            Gravity = jclass("android.view.Gravity")

            root = LinearLayout(context)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(self._dp(14), self._dp(14), self._dp(14), self._dp(14))
            self._set_view_background(root, self._create_round_drawable("key_dialogBackground", "key_divider", 18, 1))

            section = TextView(context)
            section.setText(self._t("preview_section"))
            section.setTextSize(13)
            try:
                Typeface = jclass("android.graphics.Typeface")
                section.setTypeface(Typeface.DEFAULT_BOLD)
            except Exception:
                pass
            self._apply_text_color(section, "key_dialogTextBlack")
            root.addView(
                section,
                LinearLayoutParams(ViewGroupLayoutParams.MATCH_PARENT, ViewGroupLayoutParams.WRAP_CONTENT),
            )

            content = LinearLayout(context)
            content.setOrientation(LinearLayout.HORIZONTAL)
            try:
                content.setGravity(Gravity.CENTER_VERTICAL)
            except Exception:
                pass
            content_lp = LinearLayoutParams(ViewGroupLayoutParams.MATCH_PARENT, ViewGroupLayoutParams.WRAP_CONTENT)
            content_lp.setMargins(0, self._dp(8), 0, 0)
            root.addView(content, content_lp)

            icon_wrap = FrameLayout(context)
            self._set_view_background(icon_wrap, self._create_round_drawable("key_dialogBackgroundGray", "key_divider", 14, 1))
            icon_lp = LinearLayoutParams(self._dp(76), self._dp(76))
            icon_lp.rightMargin = self._dp(12)
            content.addView(icon_wrap, icon_lp)

            preview_anim = ImageView(context)
            gift_icon_res = 0
            try:
                TelegramR = jclass("org.telegram.messenger.R")
                gift_icon_res = int(getattr(getattr(TelegramR, "drawable", None), "menu_stars_gift", 0) or 0)
            except Exception:
                gift_icon_res = 0
            if gift_icon_res == 0:
                try:
                    gift_icon_res = int(getattr(getattr(R, "drawable", None), "menu_stars_gift", 0) or 0)
                except Exception:
                    gift_icon_res = 0
            try:
                if gift_icon_res:
                    preview_anim.setImageResource(gift_icon_res)
            except Exception:
                pass
            try:
                color = self._theme_color("key_windowBackgroundWhiteBlueText2")
                if color:
                    preview_anim.setColorFilter(int(color))
            except Exception:
                pass
            icon_wrap.addView(
                preview_anim,
                FrameLayoutParams(self._dp(54), self._dp(54), Gravity.CENTER),
            )

            preview_image = None
            try:
                BackupImageView = jclass("org.telegram.ui.Components.BackupImageView")
                preview_image = BackupImageView(context)
                try:
                    preview_image.setRoundRadius(self._dp(12))
                except Exception:
                    pass
                try:
                    if hasattr(preview_image, "setAspectFit"):
                        preview_image.setAspectFit(True)
                except Exception:
                    pass
                self._set_view_visible(preview_image, False)
                icon_wrap.addView(
                    preview_image,
                    FrameLayoutParams(ViewGroupLayoutParams.MATCH_PARENT, ViewGroupLayoutParams.MATCH_PARENT, Gravity.CENTER),
                )
            except Exception:
                preview_image = None

            text_wrap = LinearLayout(context)
            text_wrap.setOrientation(LinearLayout.VERTICAL)
            text_lp = LinearLayoutParams(0, ViewGroupLayoutParams.WRAP_CONTENT, 1.0)
            content.addView(text_wrap, text_lp)

            preview_title = TextView(context)
            preview_title.setTextSize(15)
            try:
                Typeface = jclass("android.graphics.Typeface")
                preview_title.setTypeface(Typeface.DEFAULT_BOLD)
            except Exception:
                pass
            self._apply_text_color(preview_title, "key_dialogTextBlack")
            text_wrap.addView(
                preview_title,
                LinearLayoutParams(ViewGroupLayoutParams.MATCH_PARENT, ViewGroupLayoutParams.WRAP_CONTENT),
            )

            preview_subtitle = TextView(context)
            preview_subtitle.setTextSize(12)
            self._apply_text_color(preview_subtitle, "key_windowBackgroundWhiteGrayText2")
            subtitle_lp = LinearLayoutParams(ViewGroupLayoutParams.MATCH_PARENT, ViewGroupLayoutParams.WRAP_CONTENT)
            subtitle_lp.setMargins(0, self._dp(2), 0, 0)
            text_wrap.addView(preview_subtitle, subtitle_lp)

            preview_target = TextView(context)
            preview_target.setTextSize(12)
            self._apply_text_color(preview_target, "key_windowBackgroundWhiteGrayText")
            target_lp = LinearLayoutParams(ViewGroupLayoutParams.MATCH_PARENT, ViewGroupLayoutParams.WRAP_CONTENT)
            target_lp.setMargins(0, self._dp(8), 0, 0)
            root.addView(preview_target, target_lp)

            preview_options = TextView(context)
            preview_options.setTextSize(12)
            self._apply_text_color(preview_options, "key_windowBackgroundWhiteBlueText2")
            options_lp = LinearLayoutParams(ViewGroupLayoutParams.MATCH_PARENT, ViewGroupLayoutParams.WRAP_CONTENT)
            options_lp.setMargins(0, self._dp(3), 0, 0)
            root.addView(preview_options, options_lp)

            preview_message = TextView(context)
            preview_message.setTextSize(12)
            self._apply_text_color(preview_message, "key_windowBackgroundWhiteGrayText")
            try:
                preview_message.setMaxLines(2)
            except Exception:
                pass
            try:
                TruncateAt = jclass("android.text.TextUtils$TruncateAt")
                preview_message.setEllipsize(TruncateAt.END)
            except Exception:
                pass
            message_lp = LinearLayoutParams(ViewGroupLayoutParams.MATCH_PARENT, ViewGroupLayoutParams.WRAP_CONTENT)
            message_lp.setMargins(0, self._dp(3), 0, 0)
            root.addView(preview_message, message_lp)

            return {
                "preview_root": root,
                "preview_anim": preview_anim,
                "preview_image": preview_image,
                "preview_title": preview_title,
                "preview_subtitle": preview_subtitle,
                "preview_target": preview_target,
                "preview_options": preview_options,
                "preview_message": preview_message,
            }
        except Exception as e:
            self.log(f"[HiddenGift] build preview card error: {e}")
            return None

    def _attach_preview_listeners(self, form: Dict[str, Any]):
        cleanup_list = form.get("_cleanup")
        if not isinstance(cleanup_list, list):
            cleanup_list = []
            form["_cleanup"] = cleanup_list

        def on_change():
            self._refresh_preview(form, allow_remote=True)

        for field_key in ("gift_input", "target_input", "message_input"):
            cleanup = self._bind_text_watcher(form.get(field_key), on_change)
            if cleanup is not None:
                cleanup_list.append(cleanup)

        for switch_key in ("anonymous_switch",):
            cleanup = self._bind_checked_listener(form.get(switch_key), on_change)
            if cleanup is not None:
                cleanup_list.append(cleanup)

    def _bind_text_watcher(self, edit_text: Any, on_change):
        if edit_text is None:
            return None
        try:
            TextWatcher = jclass("android.text.TextWatcher")
            plugin = self

            class _Watcher(dynamic_proxy(TextWatcher)):
                def beforeTextChanged(self, _s, _start, _count, _after):
                    pass

                def onTextChanged(self, _s, _start, _before, _count):
                    pass

                def afterTextChanged(self, _s):
                    try:
                        on_change()
                    except Exception as e:
                        plugin.log(f"[HiddenGift] preview text watcher error: {e}")

            watcher = _Watcher()
            edit_text.addTextChangedListener(watcher)

            def _cleanup():
                try:
                    edit_text.removeTextChangedListener(watcher)
                except Exception:
                    pass

            return _cleanup
        except Exception:
            return None

    def _bind_checked_listener(self, switch_view: Any, on_change):
        if switch_view is None:
            return None

        if hasattr(switch_view, "getCheckBox") and hasattr(switch_view, "isChecked") and hasattr(switch_view, "setChecked"):
            plugin = self
            check_box = None
            try:
                check_box = switch_view.getCheckBox()
            except Exception:
                check_box = None

            listener = None
            if check_box is not None:
                try:
                    ListenerCls = jclass("android.widget.CompoundButton$OnCheckedChangeListener")

                    class _CheckedListener(dynamic_proxy(ListenerCls)):
                        def onCheckedChanged(self, _button_view, _is_checked):
                            try:
                                on_change()
                            except Exception as e:
                                plugin.log(f"[HiddenGift] preview switch listener error: {e}")

                    listener = _CheckedListener()
                    check_box.setOnCheckedChangeListener(listener)
                except Exception:
                    listener = None

            def _on_row_click(_view=None):
                try:
                    switch_view.setChecked(not bool(switch_view.isChecked()))
                    on_change()
                except Exception:
                    try:
                        on_change()
                    except Exception as e:
                        plugin.log(f"[HiddenGift] preview switch listener error: {e}")

            try:
                switch_view.setOnClickListener(OnClickListener(_on_row_click))
            except Exception:
                pass

            def _cleanup():
                try:
                    switch_view.setOnClickListener(None)
                except Exception:
                    pass
                try:
                    if check_box is not None:
                        check_box.setOnCheckedChangeListener(None)
                except Exception:
                    pass

            return _cleanup

        try:
            ListenerCls = jclass("android.widget.CompoundButton$OnCheckedChangeListener")
            plugin = self

            class _CheckedListener(dynamic_proxy(ListenerCls)):
                def onCheckedChanged(self, _button_view, _is_checked):
                    try:
                        on_change()
                    except Exception as e:
                        plugin.log(f"[HiddenGift] preview switch listener error: {e}")

            listener = _CheckedListener()
            switch_view.setOnCheckedChangeListener(listener)

            def _cleanup():
                try:
                    switch_view.setOnCheckedChangeListener(None)
                except Exception:
                    pass

            return _cleanup
        except Exception:
            return None

    def _refresh_preview(self, form: Dict[str, Any], allow_remote: bool):
        try:
            session = int(form.get("preview_session", 0) or 0)
            if session != int(self._active_preview_session):
                return

            target_raw = self._read_text(form.get("target_input"))
            message_text = self._read_text(form.get("message_input"))
            anonymous = self._read_checked(form.get("anonymous_switch"), True)

            self._set_text(form.get("preview_target"), self._build_preview_target_text(target_raw, int(form.get("context_dialog_id", 0) or 0)))
            self._set_text(form.get("preview_options"), self._build_preview_options_text(anonymous))
            self._set_text(form.get("preview_message"), self._build_preview_message_text(message_text))

            gift_raw = self._read_text(form.get("gift_input"))
            gift_id = self._to_int(gift_raw)
            if gift_id is None:
                self._apply_preview_fallback(
                    form,
                    self._t("preview_invalid_title"),
                    self._t("preview_invalid_subtitle"),
                )
                return

            gift = self._gift_catalog_cache.get(int(gift_id))
            if gift is not None:
                self._apply_gift_preview(form, int(gift_id), gift)
                return

            lookup_state = self._ensure_gift_lookup(int(gift_id))
            if lookup_state == "resolved":
                gift2 = self._gift_catalog_cache.get(int(gift_id))
                if gift2 is not None:
                    self._apply_gift_preview(form, int(gift_id), gift2)
                    return

            if self._gift_catalog_loading:
                self._apply_preview_fallback(
                    form,
                    f"Подарок #{gift_id}",
                    self._t("preview_loading_subtitle"),
                )
                return

            if allow_remote and not self._gift_catalog_attempted:
                self._apply_preview_fallback(
                    form,
                    f"Подарок #{gift_id}",
                    self._t("preview_loading_subtitle"),
                )
                self._ensure_gift_catalog(form)
                return

            self._apply_preview_fallback(
                form,
                f"Подарок #{gift_id}",
                self._t("preview_fallback_subtitle"),
            )
        except Exception as e:
            self.log(f"[HiddenGift] refresh preview error: {e}")

    def _ensure_gift_lookup(self, gift_id: int) -> str:
        if int(gift_id) in self._gift_catalog_cache:
            return "resolved"

        controller = self._get_stars_controller()
        if controller is None:
            return "unavailable"

        try:
            gift_sync = controller.getStarGift(self._as_java_long(gift_id))
            if gift_sync is not None:
                self._gift_catalog_cache[int(gift_id)] = gift_sync
                return "resolved"
        except Exception:
            pass

        return "unavailable"

    def _get_stars_controller(self):
        try:
            StarsController = jclass("org.telegram.ui.Stars.StarsController")
        except Exception:
            return None
        account = self._current_account()
        try:
            return StarsController.getInstance(int(account))
        except Exception:
            return None

    def _current_account(self) -> int:
        try:
            UserConfig = jclass("org.telegram.messenger.UserConfig")
            selected = int(getattr(UserConfig, "selectedAccount", 0) or 0)
            if selected >= 0:
                return selected
        except Exception:
            pass
        try:
            cfg = get_user_config()
            if cfg is not None:
                current = int(getattr(cfg, "currentAccount", 0) or 0)
                if current >= 0:
                    return current
        except Exception:
            pass
        return 0

    def _ensure_gift_catalog(self, form: Dict[str, Any]):
        if self._gift_catalog_loading:
            return
        if self._gift_catalog_attempted:
            return
        req_class = getattr(TL_stars, "getStarGifts", None)
        if req_class is None:
            self._gift_catalog_attempted = True
            return

        try:
            req = req_class()
            req.hash = 0
        except Exception as e:
            self._gift_catalog_attempted = True
            self.log(f"[HiddenGift] build getStarGifts request error: {e}")
            return

        session = int(form.get("preview_session", 0) or 0)
        self._gift_catalog_loading = True
        self._gift_catalog_attempted = True

        def on_catalog(response: Any, _error: Any):
            parsed: Dict[int, Any] = {}
            try:
                for gift in self._extract_catalog_gifts(response):
                    gift_id = int(getattr(gift, "id", 0) or 0)
                    if gift_id:
                        parsed[gift_id] = gift
            except Exception as e:
                self.log(f"[HiddenGift] parse catalog error: {e}")

            def _ui():
                self._gift_catalog_loading = False
                if parsed:
                    self._gift_catalog_cache.update(parsed)
                self.log(f"[HiddenGift] star gifts catalog loaded: {len(parsed)}")
                if session != int(self._active_preview_session):
                    return
                self._refresh_preview(form, allow_remote=False)

            run_on_ui_thread(_ui)

        try:
            send_request(req, RequestCallback(on_catalog))
        except Exception as e:
            self._gift_catalog_loading = False
            self.log(f"[HiddenGift] getStarGifts request error: {e}")

    def _extract_catalog_gifts(self, response: Any):
        gifts = getattr(response, "gifts", None) if response is not None else None
        if gifts is None:
            return []

        result = []
        try:
            size = int(gifts.size())
            for i in range(size):
                result.append(gifts.get(i))
            return result
        except Exception:
            pass

        try:
            for item in gifts:
                result.append(item)
        except Exception:
            pass
        return result

    def _apply_gift_preview(self, form: Dict[str, Any], gift_id: int, gift: Any):
        title = str(getattr(gift, "title", "") or "").strip()
        if not title:
            title = f"Подарок #{gift_id}"

        stars = int(getattr(gift, "stars", 0) or 0)
        parts = []
        if stars > 0:
            parts.append(self._t("preview_price", stars=str(stars)))

        flags = self._extract_preview_flags(gift)
        if flags:
            parts.append(", ".join(flags))

        subtitle = " • ".join(parts) if parts else self._t("preview_fallback_subtitle")
        self._set_text(form.get("preview_title"), title)
        self._set_text(form.get("preview_subtitle"), subtitle)

        if not self._show_preview_gift_image(form, gift):
            self._set_text(form.get("preview_subtitle"), self._t("preview_fallback_subtitle"))

    def _extract_preview_flags(self, gift: Any):
        flags = []
        try:
            if bool(getattr(gift, "limited", False)):
                flags.append(self._t("preview_flag_limited"))
            if bool(getattr(gift, "sold_out", False)):
                flags.append(self._t("preview_flag_sold_out"))
            if bool(getattr(gift, "require_premium", False)):
                flags.append(self._t("preview_flag_premium"))
        except Exception:
            pass
        return flags

    def _show_preview_gift_image(self, form: Dict[str, Any], gift: Any) -> bool:
        image_view = form.get("preview_image")
        anim_view = form.get("preview_anim")
        if image_view is None:
            return False
        try:
            StarsIntroActivity = jclass("org.telegram.ui.Stars.StarsIntroActivity")
            StarsIntroActivity.setGiftImage(image_view.getImageReceiver(), gift, 160)
            self._set_view_visible(image_view, True)
            self._set_view_visible(anim_view, False)
            return True
        except Exception as e:
            self.log(f"[HiddenGift] set gift image error: {e}")
            self._set_view_visible(image_view, False)
            self._set_view_visible(anim_view, True)
            return False

    def _apply_preview_fallback(self, form: Dict[str, Any], title: str, subtitle: str):
        self._set_text(form.get("preview_title"), title)
        self._set_text(form.get("preview_subtitle"), subtitle)

        image_view = form.get("preview_image")
        anim_view = form.get("preview_anim")
        if image_view is not None:
            try:
                image_view.clearImage()
            except Exception:
                pass
        self._set_view_visible(image_view, False)
        self._set_view_visible(anim_view, True)
        try:
            if anim_view is not None and hasattr(anim_view, "playAnimation"):
                anim_view.playAnimation()
        except Exception:
            pass

    def _build_preview_target_text(self, target_raw: str, context_dialog_id: int) -> str:
        raw = str(target_raw or "").strip()
        if raw == "":
            if int(context_dialog_id or 0) == 0:
                target = self._t("preview_target_self")
            else:
                title = self._resolve_dialog_title(int(context_dialog_id))
                if title:
                    target = f"{title} ({context_dialog_id})"
                else:
                    target = self._t("preview_target_dialog", dialog_id=str(context_dialog_id))
        elif raw == "0":
            target = self._t("preview_target_self")
        else:
            parsed = self._to_int(raw)
            if parsed is None:
                target = self._t("target_unknown")
            else:
                title = self._resolve_dialog_title(int(parsed))
                if title:
                    target = f"{title} ({parsed})"
                else:
                    target = self._t("preview_target_dialog", dialog_id=str(parsed))
        return self._t("preview_target", target=target)

    def _resolve_dialog_title(self, dialog_id: int) -> str:
        did = int(dialog_id or 0)
        if did == 0:
            return ""
        mc = get_messages_controller()
        if mc is None:
            return ""
        try:
            if did > 0 and hasattr(mc, "getUser"):
                user = mc.getUser(int(did))
                if user is not None:
                    first = str(getattr(user, "first_name", "") or "").strip()
                    last = str(getattr(user, "last_name", "") or "").strip()
                    username = str(getattr(user, "username", "") or "").strip()
                    title = " ".join([x for x in (first, last) if x]).strip()
                    if title:
                        return title
                    if username:
                        return f"@{username}"
            if did < 0 and hasattr(mc, "getChat"):
                chat = mc.getChat(int(-did))
                if chat is None and did <= -1000000000000:
                    channel_chat_id = int(abs(did) - 1000000000000)
                    if channel_chat_id > 0:
                        chat = mc.getChat(channel_chat_id)
                if chat is not None:
                    return str(getattr(chat, "title", "") or "").strip()
        except Exception:
            return ""
        return ""

    def _build_preview_options_text(self, anonymous: bool) -> str:
        mode = self._t("preview_mode_anonymous") if anonymous else self._t("preview_mode_named")
        return self._t("preview_option_mode", mode=mode)

    def _build_preview_message_text(self, text: str) -> str:
        clean = str(text or "").strip()
        if not clean:
            return self._t("preview_message_empty")
        return self._t("preview_message_label", message=self._truncate_text(clean, 70))

    def _truncate_text(self, text: str, limit: int) -> str:
        value = str(text or "")
        if len(value) <= int(limit):
            return value
        return value[: max(1, int(limit) - 1)].rstrip() + "…"

    def _set_text(self, view: Any, text: str):
        if view is None:
            return
        try:
            view.setText(str(text))
        except Exception:
            pass

    def _set_view_visible(self, view: Any, visible: bool):
        if view is None:
            return
        try:
            view.setVisibility(0 if visible else 8)
        except Exception:
            pass

    def _create_round_drawable(self, fill_key: str, stroke_key: str, radius_dp: int, stroke_dp: int):
        try:
            GradientDrawable = jclass("android.graphics.drawable.GradientDrawable")
            bg = GradientDrawable()
            bg.setShape(GradientDrawable.RECTANGLE)
            bg.setCornerRadius(float(self._dp(radius_dp)))

            fill_color = self._theme_color(fill_key)
            if fill_color:
                bg.setColor(int(fill_color))

            if stroke_key and int(stroke_dp) > 0:
                stroke_color = self._theme_color(stroke_key)
                if stroke_color:
                    bg.setStroke(self._dp(stroke_dp), int(stroke_color))
            return bg
        except Exception:
            return None

