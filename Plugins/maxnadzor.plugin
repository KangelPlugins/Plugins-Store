# ══════════════════════════════════════════════════════════════════
#   УТИЛИТЫ
# ══════════════════════════════════════════════════════════════════

def _is_emoji_only(text: str) -> bool:
    """Проверяет, состоит ли сообщение только из эмодзи и пробелов."""
    import unicodedata
    for ch in text:
        if ch in (' ', '\n', '\r', '\t'):
            continue
        cat = unicodedata.category(ch)
        if cat not in ('So', 'Sm', 'Sk', 'Cs', 'Co'):
            # Проверяем расширенный диапазон эмодзи
            cp = ord(ch)
            is_emoji = (
                0x1F300 <= cp <= 0x1FAFF or
                0x2600 <= cp <= 0x27BF or
                0xFE00 <= cp <= 0xFE0F or
                0x1F1E0 <= cp <= 0x1F1FF
            )
            if not is_emoji:
                return False
    return len(text.strip()) > 0

# ══════════════════════════════════════════════════════════════════
#   ПЛАГИН
# ══════════════════════════════════════════════════════════════════

class MaxWatcherPlugin(BasePlugin):
    def __init__(self):
        super().__init__()
        self._troll_counter = 0

    def on_plugin_load(self):
        self.add_on_send_message_hook()
        log("МаксНадзор v3.0.0 активирован. Слежка начата.")

    def _show_bulletin(self, text: str):
        fragment = get_last_fragment()
        BulletinHelper.show_error(text, fragment)

    def _show_info_bulletin(self, text: str):
        fragment = get_last_fragment()
        BulletinHelper.show_info(text, fragment)

    def _fmt(self, text: str) -> str:
        now = time.localtime()
        return (text
            .replace("{time}", f"{now.tm_hour:02d}:{now.tm_min:02d}")
            .replace("{n}", str(random.randint(1000, 99999)))
            .replace("{w}", str(len(text.split())))
            .replace("{wpm}", str(random.randint(40, 180)))
        )

    def _get_time_reaction(self):
        hour = time.localtime().tm_hour
        if 0 <= hour < 6:
            return random.choice(NIGHT_MESSAGES)
        if 5 <= hour < 8:
            return random.choice(MORNING_MESSAGES)
        return None

    def on_send_message_hook(self, account: int, params: Any) -> HookResult:
        if not isinstance(params.message, str) or not params.message.strip():
            return HookResult()

        message = params.message.strip()
        msg_lower = message.lower()
        self._troll_counter += 1
        suffix_parts = []
        bulletin_text = None

        # ── 1. ЗАПРЕЩЁННЫЕ СЛОВА ──────────────────────────────────
        matched_violation = None
        for word, (law, text) in VIOLATIONS.items():
            if word in msg_lower:
                matched_violation = (law, text)
                break

        if matched_violation:
            law, vtext = matched_violation
            suffix_parts.append(
                f"─────────────────────────────\n"
                f"{vtext}\n"
                f"─────────────────────────────\n"
                f"🤖 МаксНадзор | {law} | ID: {abs(hash(message))}"
            )
            bulletin_text = f"⚠️ Нарушение {law}"

        # ── 2. ИМЯ МАКСА ──────────────────────────────────────────
        is_max = any(name in msg_lower for name in MAX_NAMES)
        if is_max and not matched_violation:
            troll = self._fmt(random.choice(MAX_PERSONAL_TROLLS))
            suffix_parts.append(
                f"━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n{troll}\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            )
            bulletin_text = "👮 Гражданин Макс замечен в сети"

        # ── 3. ТОЛЬКО ЭМОДЗИ ──────────────────────────────────────
        if _is_emoji_only(message) and not matched_violation:
            reaction = self._fmt(random.choice(EMOJI_ONLY_REACTIONS))
            suffix_parts.append(f"🖼️ {reaction}")
            bulletin_text = bulletin_text or "🖼️ Пиктографическое послание"

        # ── 4. ПРИВЕТСТВИЕ ────────────────────────────────────────
        elif any(w in msg_lower for w in GREETING_WORDS) and not matched_violation:
            reaction = random.choice(GREETING_REACTIONS)
            suffix_parts.append(f"👋 {reaction}")
            bulletin_text = bulletin_text or "👋 Личность установлена"

        # ── 5. ПРОЩАНИЕ ───────────────────────────────────────────
        elif any(w in msg_lower for w in FAREWELL_WORDS) and not matched_violation:
            reaction = random.choice(FAREWELL_REACTIONS)
            suffix_parts.append(f"🚪 {reaction}")
            bulletin_text = bulletin_text or "🚪 Попытка покинуть чат"

        # ── 6. ВОСКЛИЦАНИЯ / ЭМОЦИИ ───────────────────────────────
        if any(w in msg_lower for w in EXCLAMATION_WORDS) and not matched_violation:
            reaction = random.choice(EXCLAMATION_REACTIONS)
            suffix_parts.append(f"🧘 {reaction}")
            bulletin_text = bulletin_text or "🧘 Эмоциональный всплеск"

        # ── 7. ДЛИННОЕ СООБЩЕНИЕ (>200 символов) ─────────────────
        if len(message) > 200 and not matched_violation:
            reaction = random.choice(LONG_MESSAGE_REACTIONS)
            suffix_parts.append(f"📚 {reaction}")
            bulletin_text = bulletin_text or f"📝 Длинный текст ({len(message)} симв.) — на проверке"

        # ── 8. ВОПРОСИТЕЛЬНОЕ СООБЩЕНИЕ ───────────────────────────
        if "?" in message and not matched_violation and random.random() < 0.55:
            reaction = random.choice(QUESTION_REACTIONS)
            suffix_parts.append(f"❓ {reaction}")

        # ── 9. НОЧНОЙ / УТРЕННИЙ ПРОТОКОЛ ─────────────────────────
        if not matched_violation and random.random() < 0.35:
            t = self._get_time_reaction()
            if t:
                suffix_parts.append(t)
                bulletin_text = bulletin_text or "🌙 Временной протокол"

        # ── 10. СЛУЧАЙНЫЙ ФОНОВЫЙ ПОДКОЛ (~каждое 5-е сообщение) ─
        if not matched_violation and self._troll_counter % 5 == 0:
            troll = self._fmt(random.choice(RANDOM_TROLLS))
            suffix_parts.append(f"┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄\n{troll}")
            bulletin_text = bulletin_text or "📡 Система мониторинга активна"

        # ── СБОРКА ────────────────────────────────────────────────
        if suffix_parts:
            params.message = message + "\n\n" + "\n\n".join(suffix_parts)
            if bulletin_text:
                _bt = bulletin_text
                run_on_ui_thread(lambda: self._show_bulletin(_bt))
            return HookResult(strategy=HookStrategy.MODIFY, params=params)

        return HookResult()