_TGWS_NOTIFY_LOCK = threading.Lock()
_TGWS_NOTIFY_IN_FLIGHT = False
# [perf-01 redo] Reflection Field cache. Key f"{cls.getName()}::{name}" is stable
# across plugin reloads (unlike id(cls), which changes when the class is reloaded
# and can be recycled to alias a different class). Lazy-filled under a dedicated
# Lock; getDeclaredField + setAccessible runs once per (class, field).
_TGWS_FIELD_CACHE = {}
_FIELD_CACHE_LOCK = threading.Lock()
def _tgws_cached_field(cls, name):
    try:
        cls_name = str(cls.getName())
    except Exception:
        cls_name = str(cls)
    key = f"{cls_name}::{name}"
    with _FIELD_CACHE_LOCK:
        try:
            return _TGWS_FIELD_CACHE[key]
        except KeyError:
            f = cls.getDeclaredField(str(name))
            f.setAccessible(True)
            _TGWS_FIELD_CACHE[key] = f
            return f
