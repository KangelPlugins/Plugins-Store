def _is_ru_token(v):
    try:
        s = str(v or "").strip().lower()
    except Exception:
        return False
    if not s:
        return False
    if s.startswith("ru") or s.startswith("рус"):
        return True
    if " ru" in (" " + s) or "ru_" in s or "ru-" in s:
        return True
    if "рус" in s:
        return True
    return False
def _is_ru_language():
    try:
        lc = LocaleController.getInstance()
        if lc is not None:
            for method_name in ("getCurrentLocaleInfo", "getCurrentLocale", "getCurrentLangCode", "getCurrentLanguageName"):
                try:
                    member = getattr(lc, method_name, None)
                    val = member() if callable(member) else member
                    if _is_ru_token(val):
                        return True
                    for attr in ("shortName", "pluralLangCode", "langCode", "name", "nameEnglish"):
                        try:
                            if _is_ru_token(getattr(val, attr, None)):
                                return True
                        except Exception:
                            pass
                except Exception:
                    pass
            for attr in ("currentLocaleInfo", "currentLocale", "currentLangCode"):
                try:
                    val = getattr(lc, attr, None)
                    if _is_ru_token(val):
                        return True
                    for subattr in ("shortName", "pluralLangCode", "langCode", "name", "nameEnglish"):
                        try:
                            if _is_ru_token(getattr(val, subattr, None)):
                                return True
                        except Exception:
                            pass
                except Exception:
                    pass
    except Exception:
        pass
    try:
        if _is_ru_token(Locale.getDefault().getLanguage()):
            return True
        if _is_ru_token(Locale.getDefault().toString()):
            return True
    except Exception:
        pass
    return False
def Z(key):
    idx = 0 if _is_ru_language() else 1
    try: return str(TRANSLATIONS.get(key, (key, key))[idx])
    except Exception: return str(key)
def _log(message):
    try:
        log(str(message))
    except Exception:
        pass
def _apply_tg_proxy(port, enable, socks_user="", socks_pass="", secret=""):
    try:
        ProxyInfoClass = find_class("org.telegram.messenger.SharedConfig$ProxyInfo")
        try:
            SharedConfig.loadProxyList()
        except Exception:
            pass
        local_proxy = None
        try:
            # [lock-3 redo] Snapshot proxyList under _TGWS_PROXYLIST_LOCK, then scan
            # the copy OUTSIDE the lock (no concurrent-modification while iterating a
            # live Java list). deleteProxy mutations are re-taken under the lock.
            try:
                with _TGWS_PROXYLIST_LOCK:
                    pl = SharedConfig.proxyList if hasattr(SharedConfig, "proxyList") else None
                    proxy_snapshot = list(pl) if pl else []
            except Exception:
                proxy_snapshot = []
            duplicates = []
            for p in proxy_snapshot:
                try:
                    if str(p.address) == LOCAL_PROXY_HOST:
                        if local_proxy is None:
                            local_proxy = p
                        else:
                            duplicates.append(p)
                except Exception:
                    continue
            for p in duplicates:
                try:
                    with _TGWS_PROXYLIST_LOCK:
                        SharedConfig.deleteProxy(p)
                except Exception:
                    pass
        except Exception:
            pass
        ed = MessagesController.getGlobalMainSettings().edit()
        try:
            proxy_list = SharedConfig.proxyList
            if proxy_list:
                to_remove = []
                for i in range(proxy_list.size()):
                    p = proxy_list.get(i)
                    if str(p.address) == LOCAL_PROXY_HOST:
                        to_remove.append(p)
                for p in to_remove:
                    SharedConfig.deleteProxy(p)
        except Exception:
            pass
        try:
            curr = SharedConfig.currentProxy
            if curr and str(curr.address) == LOCAL_PROXY_HOST:
                SharedConfig.currentProxy = None
        except Exception:
            pass
        if enable:
            _secret = str(secret or "").strip()
            _su = "" if _secret else str(socks_user or "")
            _sp = "" if _secret else str(socks_pass or "")
            if local_proxy is not None:
                try:
                    local_proxy.port = int(port)
                    local_proxy.username = _su
                    local_proxy.password = _sp
                    local_proxy.secret = _secret
                except Exception:
                    pass
                proxy_obj = local_proxy
            else:
                proxy_obj = None
                try:
                    proxy_obj = SharedConfig.addProxy(LOCAL_PROXY_HOST, int(port), _su, _sp, _secret)
                except Exception:
                    proxy_obj = None
                if not proxy_obj:
                    try:
                        proxy_obj = ProxyInfoClass(LOCAL_PROXY_HOST, int(port), _su, _sp, _secret)
                        try:
                            SharedConfig.addProxy(proxy_obj)
                        except Exception:
                            pass
                    except Exception:
                        proxy_obj = None
            try:
                if proxy_obj:
                    SharedConfig.currentProxy = proxy_obj
                    try:
                        sc_cls = find_class("org.telegram.messenger.SharedConfig")
                        for _fname, _fval in (("currentProxyInfo", proxy_obj), ("currentProxy", proxy_obj), ("useProxySettings", True), ("proxyEnabled", True)):
                            try:
                                _f = _tgws_cached_field(sc_cls, str(_fname))
                                _f.set(None, _fval)
                            except Exception:
                                pass
                    except Exception:
                        pass
            except Exception:
                pass
            try:
                SharedConfig.proxyEnabled = True
            except Exception:
                pass
            ed.putString("proxy_ip", LOCAL_PROXY_HOST)
            ed.putInt("proxy_port", int(port))
            try:
                ed.putString("proxy_user", _su)
                ed.putString("proxy_pass", _sp)
            except Exception:
                pass
            ed.putString("proxy_secret", _secret)
            ed.putBoolean("proxy_enabled", True)
            _calls_enabled = False if _secret else True
            for key in ("proxy_enabled_calls", "proxy_calls_enabled", "calls_use_proxy"):
                try:
                    ed.putBoolean(key, bool(_calls_enabled))
                except Exception:
                    pass
            try:
                for attr in ("proxyEnabledCalls", "proxyCallsEnabled", "callsEnabled", "useProxyForCalls"):
                    try:
                        setattr(SharedConfig, attr, bool(_calls_enabled))
                    except Exception:
                        pass
            except Exception:
                pass
            if proxy_obj:
                try:
                    for attr in ("enabledForCalls", "useForCalls"):
                        try:
                            setattr(proxy_obj, attr, bool(_calls_enabled))
                        except Exception:
                            pass
                except Exception:
                    pass
            if _calls_enabled:
                try:
                    for ac in range(UserConfig.MAX_ACCOUNT_COUNT):
                        try:
                            prefs = MessagesController.getInstance(ac).getSharedPreferences("mainconfig", 0)
                            if prefs:
                                p2p_prev_key = "tgws_proxy_p2p_backup_" + str(ac)
                                current_p2p = prefs.getInt("calls_p2p", -1)
                                if current_p2p != 2:
                                    prefs.edit().putInt(p2p_prev_key, current_p2p).putInt("calls_p2p", 2).commit()
                        except Exception:
                            pass
                except Exception:
                    pass
        else:
            try:
                curr = SharedConfig.currentProxy
                if curr and str(curr.address) == LOCAL_PROXY_HOST:
                    SharedConfig.currentProxy = None
            except Exception:
                pass
            try:
                SharedConfig.proxyEnabled = False
            except Exception:
                pass
            try:
                sc_cls = find_class("org.telegram.messenger.SharedConfig")
                for _fname, _fval in (("useProxySettings", False), ("proxyEnabled", False)):
                    try:
                        _f = _tgws_cached_field(sc_cls, str(_fname))
                        _f.set(None, _fval)
                    except Exception:
                        pass
            except Exception:
                pass
            ed.putBoolean("proxy_enabled", False)
            try:
                for ac in range(UserConfig.MAX_ACCOUNT_COUNT):
                    try:
                        try:
                            _uc = UserConfig.getInstance(ac)
                            if _uc is None or not bool(_uc.isClientActivated()):
                                continue
                        except Exception:
                            pass
                        prefs = MessagesController.getInstance(ac).getSharedPreferences("mainconfig", 0)
                        if prefs:
                            p2p_prev_key = "tgws_proxy_p2p_backup_" + str(ac)
                            saved_p2p = prefs.getInt(p2p_prev_key, -1)
                            if saved_p2p >= 0:
                                prefs.edit().putInt("calls_p2p", saved_p2p).remove(p2p_prev_key).apply()
                    except Exception:
                        pass
            except Exception:
                pass
        try:
            ed.commit()
        except Exception:
            ed.apply()
        try:
            SharedConfig.saveProxyList()
        except Exception:
            pass
        try:
            SharedConfig.saveConfig()
        except Exception:
            pass
        _secret2 = str(secret or "").strip()
        _su2 = "" if _secret2 else str(socks_user or "")
        _sp2 = "" if _secret2 else str(socks_pass or "")
        for ac in range(UserConfig.MAX_ACCOUNT_COUNT):
            try:
                try:
                    _uc = UserConfig.getInstance(ac)
                    if _uc is None or not bool(_uc.isClientActivated()):
                        continue
                except Exception:
                    pass
                cm = ConnectionsManager.getInstance(ac)
                if cm:
                    if enable:
                        cm.setProxySettings(True, LOCAL_PROXY_HOST, int(port), _su2, _sp2, _secret2)
                    else:
                        cm.setProxySettings(False, "", 0, "", "", "")
            except Exception:
                pass
        try:
            if enable:
                ConnectionsManager.setProxySettings(True, LOCAL_PROXY_HOST, int(port), _su2, _sp2, _secret2)
            else:
                ConnectionsManager.setProxySettings(False, "", 0, "", "", "")
        except Exception:
            pass
        # [v2.1 coexist] re-entrance guard: если другой плагин (или мы сами) в
        # этот момент уже шлёт proxySettingsChanged, не плодим вторичный пост,
        # чтобы не было notification-каскада с th3_proxy_tools и его пирами.
        def _notify():
            global _TGWS_NOTIFY_IN_FLIGHT
            try:
                with _TGWS_NOTIFY_LOCK:
                    if _TGWS_NOTIFY_IN_FLIGHT:
                        return
                    _TGWS_NOTIFY_IN_FLIGHT = True
                try:
                    try:
                        from java import jarray
                        from java.lang import Object
                        NotificationCenter.getGlobalInstance().postNotificationName(
                            NotificationCenter.proxySettingsChanged, jarray(Object)(0)
                        )
                    except Exception:
                        NotificationCenter.getGlobalInstance().postNotificationName(
                            NotificationCenter.proxySettingsChanged
                        )
                finally:
                    with _TGWS_NOTIFY_LOCK:
                        _TGWS_NOTIFY_IN_FLIGHT = False
            except Exception:
                try:
                    with _TGWS_NOTIFY_LOCK:
                        _TGWS_NOTIFY_IN_FLIGHT = False
                except Exception:
                    pass
        try:
            run_on_ui_thread(_notify, 300)
        except Exception:
            pass
    except Exception as e:
        _log(f"apply_tg_proxy error: {e}")
def _get_free_port():
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        s.bind((LOCAL_PROXY_HOST, 0))
        return s.getsockname()[1]
def _tgws_xor_mask(data, mask):
    if not mask:
        return data
    buf = bytearray(data)
    for idx in range(len(buf)):
        buf[idx] ^= mask[idx & 3]
    return bytes(buf)
def _tgws_build_frame(opcode, payload, mask=True):
    try:
        body = bytes(payload or b"")
    except (TypeError, ValueError):
        body = b""
    out = bytearray()
    out.append(0x80 | (int(opcode) & 0x0F))
    length = len(body)
    mask_bit = 0x80 if mask else 0x00
    if length < 126:
        out.append(mask_bit | length)
    elif length <= 0xFFFF:
        out.append(mask_bit | 126)
        out.extend(struct.pack(">H", length))
    else:
        out.append(mask_bit | 127)
        out.extend(struct.pack(">Q", length))
    if mask:
        mask_key = os.urandom(4)
        out.extend(mask_key)
        body_off = len(out)
        out.extend(body)
        for idx in range(length):
            out[body_off + idx] ^= mask_key[idx & 3]
    else:
        out.extend(body)
    return bytes(out)
def _tgws_read_exact(reader, size):
    buf = b""
    need = int(size or 0)
    while len(buf) < need:
        chunk = reader.read(need - len(buf))
        if not chunk:
            raise EOFError("unexpected eof")
        buf += chunk
    return buf
def _tgws_recv_exact(conn, size):
    data = b""
    need = int(size or 0)
    while len(data) < need:
        chunk = conn.recv(need - len(data))
        if not chunk:
            raise EOFError("unexpected eof")
        data += chunk
    return data
_TGWS_DNS_CACHE = {}
_TGWS_DNS_CACHE_LOCK = threading.Lock()
_TGWS_DNS_TTL_SEC = 60.0
# Hard cap on distinct hostnames cached. Entries are never proactively
# deleted (expired ones are only overwritten on re-resolve), so without a
# cap the CF-proxy domain pool — refreshed from a remote list hourly —
# would grow this dict without bound over a multi-day session.
_TGWS_DNS_CACHE_MAX = 256
def _tgws_resolve_ipv4(hostname):
    try:
        hn = str(hostname or "").strip()
        if not hn:
            return None
        try:
            if ":" in hn:
                return None
            socket.inet_aton(hn)
            return hn
        except Exception:
            pass
        # Cache hit?
        try:
            with _TGWS_DNS_CACHE_LOCK:
                cached = _TGWS_DNS_CACHE.get(hn)
            if cached is not None:
                ip, ts = cached
                if (time.time() - float(ts)) < _TGWS_DNS_TTL_SEC:
                    return ip
        except Exception:
            pass
        for family, _, _, _, sockaddr in socket.getaddrinfo(hn, None, socket.AF_INET, socket.SOCK_STREAM):
            if family == socket.AF_INET:
                ip = str(sockaddr[0])
                try:
                    with _TGWS_DNS_CACHE_LOCK:
                        if hn not in _TGWS_DNS_CACHE and len(_TGWS_DNS_CACHE) >= _TGWS_DNS_CACHE_MAX:
                            _now = time.time()
                            # Drop expired entries first.
                            for _k in [
                                _hk for _hk, _hv in list(_TGWS_DNS_CACHE.items())
                                if (_now - float(_hv[1])) >= _TGWS_DNS_TTL_SEC
                            ]:
                                _TGWS_DNS_CACHE.pop(_k, None)
                            # Still full -> evict the single oldest entry.
                            if len(_TGWS_DNS_CACHE) >= _TGWS_DNS_CACHE_MAX:
                                _oldest = min(_TGWS_DNS_CACHE.items(), key=lambda kv: kv[1][1])[0]
                                _TGWS_DNS_CACHE.pop(_oldest, None)
                        _TGWS_DNS_CACHE[hn] = (ip, time.time())
                except Exception:
                    pass
                return ip
    except Exception:
        return None
    return None
TGWS_HANDSHAKE_LEN = 64
TGWS_SKIP_LEN = 8
TGWS_PREKEY_LEN = 32
TGWS_IV_LEN = 16
TGWS_PROTO_TAG_POS = 56
TGWS_DC_IDX_POS = 60
TGWS_ZERO_64 = b"\x00" * 64
TGWS_PROTO_TAG_ABRIDGED = b"\xef\xef\xef\xef"
TGWS_PROTO_TAG_INTERMEDIATE = b"\xee\xee\xee\xee"
TGWS_PROTO_TAG_SECURE = b"\xdd\xdd\xdd\xdd"
TGWS_RESERVED_FIRST_BYTES = {0xEF}
TGWS_RESERVED_STARTS = {
    b"HEAD", b"POST", b"GET ", b"\xee\xee\xee\xee", b"\xdd\xdd\xdd\xdd", b"\x16\x03\x01\x02"
}
TGWS_DIRECT_DC_IP = {
    1: "149.154.175.50",
    2: "149.154.167.51",
    3: "149.154.175.100",
    4: "149.154.167.91",
    5: "149.154.171.5",
    203: "91.105.192.100",
}
def _tgws_to_bytes(value):
    if value is None:
        return b""
    try:
        return bytes(value)
    except Exception:
        try:
            return bytes(bytearray(value))
        except Exception:
            return b""
def _tgws_cipher_new(key_bytes, iv_bytes):
    if JavaCipher is None or SecretKeySpec is None or IvParameterSpec is None:
        raise RuntimeError("Java crypto unavailable")
    cipher = JavaCipher.getInstance("AES/CTR/NoPadding")
    cipher.init(JavaCipher.ENCRYPT_MODE, SecretKeySpec(bytes(key_bytes), "AES"), IvParameterSpec(bytes(iv_bytes)))
    return cipher
def _tgws_cipher_update(cipher, data):
    try:
        out = cipher.update(bytes(data or b""))
        return _tgws_to_bytes(out)
    except Exception:
        return b""
def _tgws_try_mtproto_handshake(handshake, secret_bytes):
    try:
        raw = bytes(handshake or b"")
        secret = bytes(secret_bytes or b"")
        if len(raw) < TGWS_HANDSHAKE_LEN or len(secret) != 16:
            return None
        dec_prekey_iv = raw[TGWS_SKIP_LEN:TGWS_SKIP_LEN + TGWS_PREKEY_LEN + TGWS_IV_LEN]
        dec_prekey = dec_prekey_iv[:TGWS_PREKEY_LEN]
        dec_iv = dec_prekey_iv[TGWS_PREKEY_LEN:]
        dec_key = hashlib.sha256(dec_prekey + secret).digest()
        dec = _tgws_cipher_new(dec_key, dec_iv)
        decrypted = _tgws_cipher_update(dec, raw[:TGWS_HANDSHAKE_LEN])
        if len(decrypted) < TGWS_HANDSHAKE_LEN:
            return None
        proto_tag = decrypted[TGWS_PROTO_TAG_POS:TGWS_PROTO_TAG_POS + 4]
        if proto_tag not in (TGWS_PROTO_TAG_ABRIDGED, TGWS_PROTO_TAG_INTERMEDIATE, TGWS_PROTO_TAG_SECURE):
            return None
        dc_idx = struct.unpack("<h", decrypted[TGWS_DC_IDX_POS:TGWS_DC_IDX_POS + 2])[0]
        dc_id = abs(int(dc_idx))
        if dc_id <= 0 or dc_id > 1000:
            return None
        proto_int = struct.unpack("<I", proto_tag)[0]
        return dc_id, bool(dc_idx < 0), int(proto_int), bytes(proto_tag), bytes(dec_prekey_iv)
    except Exception:
        return None
def _tgws_generate_relay_init(proto_tag, dc_idx):
    try:
        proto = bytes(proto_tag or b"")[:4]
        if len(proto) != 4:
            proto = TGWS_PROTO_TAG_ABRIDGED
        while True:
            rnd = bytearray(os.urandom(TGWS_HANDSHAKE_LEN))
            if rnd[0] in TGWS_RESERVED_FIRST_BYTES:
                continue
            if bytes(rnd[:4]) in TGWS_RESERVED_STARTS:
                continue
            if rnd[4:8] == b"\x00\x00\x00\x00":
                continue
            break
        rnd_bytes = bytes(rnd)
        enc_key = rnd_bytes[TGWS_SKIP_LEN:TGWS_SKIP_LEN + TGWS_PREKEY_LEN]
        enc_iv = rnd_bytes[TGWS_SKIP_LEN + TGWS_PREKEY_LEN:TGWS_SKIP_LEN + TGWS_PREKEY_LEN + TGWS_IV_LEN]
        enc = _tgws_cipher_new(enc_key, enc_iv)
        encrypted_full = _tgws_cipher_update(enc, rnd_bytes)
        if len(encrypted_full) < TGWS_HANDSHAKE_LEN:
            return rnd_bytes
        keystream_tail = bytes(encrypted_full[i] ^ rnd_bytes[i] for i in range(56, 64))
        tail_plain = proto + struct.pack("<h", int(dc_idx)) + os.urandom(2)
        encrypted_tail = bytes(tail_plain[i] ^ keystream_tail[i] for i in range(8))
        result = bytearray(rnd_bytes)
        result[56:64] = encrypted_tail
        return bytes(result)
    except Exception:
        return os.urandom(TGWS_HANDSHAKE_LEN)
class _TgWsCryptoCtx:
    def __init__(self, clt_dec, clt_enc, tg_enc, tg_dec):
        self.clt_dec = clt_dec
        self.clt_enc = clt_enc
        self.tg_enc = tg_enc
        self.tg_dec = tg_dec
def _tgws_build_crypto_ctx(client_dec_prekey_iv, secret_bytes, relay_init):
    secret = bytes(secret_bytes or b"")
    client_iv = bytes(client_dec_prekey_iv or b"")
    relay = bytes(relay_init or b"")
    clt_dec_prekey = client_iv[:TGWS_PREKEY_LEN]
    clt_dec_iv = client_iv[TGWS_PREKEY_LEN:TGWS_PREKEY_LEN + TGWS_IV_LEN]
    clt_dec_key = hashlib.sha256(clt_dec_prekey + secret).digest()
    clt_dec = _tgws_cipher_new(clt_dec_key, clt_dec_iv)
    _tgws_cipher_update(clt_dec, TGWS_ZERO_64)
    clt_enc_prekey_iv = client_iv[::-1]
    clt_enc_key = hashlib.sha256(clt_enc_prekey_iv[:TGWS_PREKEY_LEN] + secret).digest()
    clt_enc_iv = clt_enc_prekey_iv[TGWS_PREKEY_LEN:TGWS_PREKEY_LEN + TGWS_IV_LEN]
    clt_enc = _tgws_cipher_new(clt_enc_key, clt_enc_iv)
    relay_enc_key = relay[TGWS_SKIP_LEN:TGWS_SKIP_LEN + TGWS_PREKEY_LEN]
    relay_enc_iv = relay[TGWS_SKIP_LEN + TGWS_PREKEY_LEN:TGWS_SKIP_LEN + TGWS_PREKEY_LEN + TGWS_IV_LEN]
    tg_enc = _tgws_cipher_new(relay_enc_key, relay_enc_iv)
    _tgws_cipher_update(tg_enc, TGWS_ZERO_64)
    relay_dec_prekey_iv = relay[TGWS_SKIP_LEN:TGWS_SKIP_LEN + TGWS_PREKEY_LEN + TGWS_IV_LEN][::-1]
    relay_dec_key = relay_dec_prekey_iv[:TGWS_PREKEY_LEN]
    relay_dec_iv = relay_dec_prekey_iv[TGWS_PREKEY_LEN:TGWS_PREKEY_LEN + TGWS_IV_LEN]
    tg_dec = _tgws_cipher_new(relay_dec_key, relay_dec_iv)
    return _TgWsCryptoCtx(clt_dec, clt_enc, tg_enc, tg_dec)
def _tgws_generate_secret_hex():
    try:
        return binascii.hexlify(os.urandom(16)).decode("ascii")
    except Exception:
        return "%032x" % random.getrandbits(128)
def _tgws_valid_secret_hex(value):
    try:
        s = str(value or "").strip().lower()
        if s.startswith("dd") or s.startswith("ee"):
            s = s[2:34]
        if len(s) != 32:
            return ""
        bytes.fromhex(s)
        return s
    except Exception:
        return ""
class _TgWsMsgSplitter:
    def __init__(self, init_data, proto_int=None):
        raw = bytes(init_data or b"")
        key = raw[8:40]
        iv = raw[40:56]
        if JavaCipher is None or SecretKeySpec is None or IvParameterSpec is None:
            raise RuntimeError("Java crypto unavailable")
        cipher = JavaCipher.getInstance("AES/CTR/NoPadding")
        cipher.init(JavaCipher.ENCRYPT_MODE, SecretKeySpec(bytes(key), "AES"), IvParameterSpec(bytes(iv)))
        try:
            cipher.update(b"\x00" * 64)
        except Exception:
            pass
        self._cipher = cipher
        try:
            self._proto = int(proto_int or 0)
        except Exception:
            self._proto = 0
        self._cipher_buf = bytearray()
        self._plain_buf = bytearray()
        self._disabled = False
        # Hard cap: a corrupted/foreign length prefix can declare a multi-GB
        # packet, making _next_packet_len() return None forever while the
        # buffers grow with every chunk. Past this size with no frame
        # boundary we give up splitting and pass through (see split()).
        self._max_buf = 16 * 1024 * 1024
    def split(self, chunk):
        if not chunk:
            return []
        if self._disabled:
            return [chunk]
        try:
            self._cipher_buf.extend(bytes(chunk))
            plain = self._cipher.update(bytes(chunk))
            try:
                self._plain_buf.extend(bytes(plain))
            except Exception:
                self._plain_buf.extend(bytes(bytearray(plain)))
        except Exception:
            return [chunk]
        parts = []
        while self._cipher_buf:
            packet_len = self._next_packet_len()
            if packet_len is None:
                if len(self._cipher_buf) > self._max_buf:
                    # No frame boundary within the cap -> stop splitting and
                    # flush what we have as one passthrough chunk so the
                    # buffers can never grow without bound on a broken stream.
                    parts.append(bytes(self._cipher_buf))
                    self._cipher_buf.clear()
                    self._plain_buf.clear()
                    self._disabled = True
                break
            if packet_len <= 0:
                parts.append(bytes(self._cipher_buf))
                self._cipher_buf.clear()
                self._plain_buf.clear()
                self._disabled = True
                break
            parts.append(bytes(self._cipher_buf[:packet_len]))
            del self._cipher_buf[:packet_len]
            del self._plain_buf[:packet_len]
        return parts
    def flush(self):
        if not self._cipher_buf:
            return []
        tail = bytes(self._cipher_buf)
        self._cipher_buf.clear()
        self._plain_buf.clear()
        return [tail]
    def _next_packet_len(self):
        try:
            proto = int(self._proto)
        except Exception:
            proto = 0
        if not self._plain_buf:
            return None
        if proto == 0xEFEFEFEF:
            return self._next_abridged_len()
        if proto in (0xEEEEEEEE, 0xDDDDDDDD):
            return self._next_intermediate_len()
        return 0
    def _next_abridged_len(self):
        first = self._plain_buf[0]
        if first in (0x7F, 0xFF):
            if len(self._plain_buf) < 4:
                return None
            payload_len = int.from_bytes(self._plain_buf[1:4], "little") * 4
            header_len = 4
        else:
            payload_len = (first & 0x7F) * 4
            header_len = 1
        if payload_len <= 0:
            return 0
        packet_len = header_len + payload_len
        if len(self._plain_buf) < packet_len:
            return None
        return packet_len
    def _next_intermediate_len(self):
        if len(self._plain_buf) < 4:
            return None
        payload_len = struct.unpack_from("<I", self._plain_buf, 0)[0] & 0x7FFFFFFF
        if payload_len <= 0:
            return 0
        packet_len = 4 + payload_len
        if len(self._plain_buf) < packet_len:
            return None
        return packet_len
def _tgws_ws_domains(dc, is_media):
    try:
        dc_num = int(dc or 0)
    except (TypeError, ValueError):
        dc_num = 0
    try:
        dc_num = int(TGWS_DC_OVERRIDES.get(int(dc_num), int(dc_num)))
    except Exception:
        pass
    bases = ["web.telegram.org"]
    out = []
    for base in bases:
        if is_media:
            out.append(f"kws{dc_num}-1.{base}")
            out.append(f"kws{dc_num}.{base}")
        else:
            out.append(f"kws{dc_num}.{base}")
            out.append(f"kws{dc_num}-1.{base}")
    seen = set()
    uniq = []
    for d in out:
        if d not in seen:
            seen.add(d)
            uniq.append(d)
    return uniq
class _TgWsRawWebSocket:
    def __init__(self, sock, reader):
        self.sock = sock
        self.reader = reader
        self._lock = threading.Lock()
        self._closed = False
        self._last_io_ts = time.time()
    def ping(self, payload=b""):
        """Send a WS ping frame. Returns True if sent OK, False if the socket is dead."""
        try:
            with self._lock:
                if self._closed:
                    return False
                self.sock.sendall(_tgws_build_frame(0x9, bytes(payload or b""), mask=True))
                self._last_io_ts = time.time()
            return True
        except Exception:
            try:
                self.close()
            except Exception:
                pass
            return False
    def last_io_age(self):
        try:
            return float(time.time() - float(self._last_io_ts or 0.0))
        except Exception:
            return 0.0
    @staticmethod
    def connect(connect_host, sni_host, timeout=TGWS_WS_CONNECT_TIMEOUT_SEC):
        sock = socket.create_connection((str(connect_host), 443), timeout=float(timeout))
        try:
            if TGWS_TCP_NODELAY:
                sock.setsockopt(socket.IPPROTO_TCP, socket.TCP_NODELAY, 1)
        except:
            pass
        try:
            sock.setsockopt(socket.SOL_SOCKET, socket.SO_RCVBUF, int(TGWS_SOCK_RCVBUF))
            sock.setsockopt(socket.SOL_SOCKET, socket.SO_SNDBUF, int(TGWS_SOCK_SNDBUF))
        except Exception:
            pass
        # RES-04: TCP keepalive ONLY on the upstream WS socket (never on the local
        # TG->127.0.0.1 client side). Conservative idle (5 min) so we don't keep the
        # mobile radio awake / drain battery, then 3 probes 60s apart to detect a
        # silently dropped link.
        try:
            sock.setsockopt(socket.SOL_SOCKET, socket.SO_KEEPALIVE, 1)
            if hasattr(socket, "TCP_KEEPIDLE"):
                sock.setsockopt(socket.IPPROTO_TCP, socket.TCP_KEEPIDLE, int(TGWS_TCP_KEEPIDLE_SEC))
            if hasattr(socket, "TCP_KEEPINTVL"):
                sock.setsockopt(socket.IPPROTO_TCP, socket.TCP_KEEPINTVL, int(TGWS_TCP_KEEPINTVL_SEC))
            if hasattr(socket, "TCP_KEEPCNT"):
                sock.setsockopt(socket.IPPROTO_TCP, socket.TCP_KEEPCNT, int(TGWS_TCP_KEEPCNT))
        except Exception:
            pass
        ctx = ssl.create_default_context()
        ctx.check_hostname = False
        ctx.verify_mode = ssl.CERT_NONE
        wrapped = ctx.wrap_socket(sock, server_hostname=str(sni_host or ""))
        wrapped.settimeout(float(timeout))
        key = base64.b64encode(os.urandom(16)).decode("ascii")
        req = "\r\n".join([
            "GET /apiws HTTP/1.1",
            "Host: " + str(sni_host or ""),
            "Upgrade: websocket",
            "Connection: Upgrade",
            "Sec-WebSocket-Key: " + key,
            "Sec-WebSocket-Version: 13",
            "Sec-WebSocket-Protocol: binary",
            "Origin: https://web.telegram.org",
            "User-Agent: Mozilla/5.0 (Linux; Android 13)",
            "",
            "",
        ])
        wrapped.sendall(req.encode("utf-8"))
        reader = wrapped.makefile("rb")
        status_line = reader.readline().decode("utf-8", errors="ignore").strip()
        headers = {}
        try:
            while True:
                line = reader.readline()
                if not line:
                    break
                if line in (b"\r\n", b"\n"):
                    break
                try:
                    s = line.decode("utf-8", errors="ignore").strip()
                except:
                    continue
                if ":" in s:
                    k, v = s.split(":", 1)
                    headers[str(k).strip().lower()] = str(v).strip()
        except:
            headers = headers or {}
        if " 101 " not in status_line:
            try:
                reader.close()
            except:
                pass
            try:
                wrapped.close()
            except:
                pass
            try:
                parts = str(status_line).split(" ", 2)
                code = int(parts[1]) if len(parts) >= 2 else 0
            except:
                code = 0
            try:
                loc = str(headers.get("location", "") or "").strip()
            except:
                loc = ""
            if code in (301, 302, 303, 307, 308) and loc:
                raise RuntimeError(f"{status_line} -> {loc}")
            raise RuntimeError(status_line or "bad websocket handshake")
        return _TgWsRawWebSocket(wrapped, reader)
    def send(self, payload):
        with self._lock:
            if self._closed:
                raise EOFError("websocket closed")
            self.sock.sendall(_tgws_build_frame(0x2, payload, mask=True))
    def send_batch(self, parts):
        with self._lock:
            if self._closed:
                raise EOFError("websocket closed")
            for payload in list(parts or []):
                self.sock.sendall(_tgws_build_frame(0x2, payload, mask=True))
    def _read_frame(self):
        header = _tgws_read_exact(self.reader, 2)
        opcode = header[0] & 0x0F
        masked = bool(header[1] & 0x80)
        length = header[1] & 0x7F
        if length == 126:
            length = struct.unpack(">H", _tgws_read_exact(self.reader, 2))[0]
        elif length == 127:
            length = struct.unpack(">Q", _tgws_read_exact(self.reader, 8))[0]
        mask_key = b""
        if masked:
            mask_key = _tgws_read_exact(self.reader, 4)
        payload = _tgws_read_exact(self.reader, length)
        if masked:
            payload = _tgws_xor_mask(payload, mask_key)
        return opcode, payload
    def recv(self):
        while True:
            opcode, payload = self._read_frame()
            if opcode == 0x8:
                self.close()
                return None
            if opcode == 0x9:
                self._write_control(0xA, payload)
                continue
            if opcode == 0xA:
                continue
            if opcode in (0x1, 0x2):
                return payload
    def _write_control(self, opcode, payload):
        with self._lock:
            if self._closed:
                return
            self.sock.sendall(_tgws_build_frame(opcode, payload, mask=True))
    def close(self):
        with self._lock:
            if self._closed:
                return
            self._closed = True
            try:
                self.sock.sendall(_tgws_build_frame(0x8, b"", mask=True))
            except:
                pass
            try:
                self.reader.close()
            except:
                pass
            try:
                self.sock.close()
            except:
                pass
    def is_closed(self):
        try:
            return bool(self._closed)
        except Exception:
            return True
class _TgWsWsPool:
    def __init__(self, max_age_sec=120.0, max_items_per_key=2):
        self._max_age = float(max_age_sec or 120.0)
        self._max_items = int(max_items_per_key or 2)
        self._lock = threading.Lock()
        self._idle = {}
    def get(self, key):
        now = time.time()
        with self._lock:
            q = self._idle.get(key)
            if not q:
                return None
            while q:
                ws, ts = q.pop(0)
                if ws is None:
                    continue
                try:
                    if ws.is_closed():
                        continue
                except Exception:
                    continue
                if self._max_age and (now - float(ts or 0.0)) > self._max_age:
                    try:
                        ws.close()
                    except Exception:
                        pass
                    continue
                return ws
            return None
    def put(self, key, ws):
        if ws is None:
            return
        try:
            if ws.is_closed():
                return
        except Exception:
            return
        with self._lock:
            q = self._idle.get(key)
            if not q:
                q = []
                self._idle[key] = q
            if len(q) >= self._max_items:
                try:
                    old, _ = q.pop(0)
                    if old is not None:
                        old.close()
                except Exception:
                    pass
            q.append((ws, time.time()))
    def clear(self):
        with self._lock:
            all_items = []
            for q in self._idle.values():
                all_items.extend(list(q))
            self._idle = {}
        for ws, _ in all_items:
            try:
                if ws is not None:
                    ws.close()
            except Exception:
                pass
class TgWsCore:
    def __init__(self):
        self.listener = None
        self.listener_thread = None
        self.stop_event = threading.Event()
        self.lock = threading.Lock()
        # RLock guards compound read-modify-write on fail_until/ws_blacklist/
        # ws_domain_pref/_cf_pref/_cf_domains. RLock so the same handler thread
        # can re-enter (e.g. _connect_ws_direct calling helpers that also lock).
        self._cfg_lock = threading.RLock()
        self.tracked = set()
        self.fail_until = {}
        self.fail_count = {}
        self.ws_blacklist = set()
        self.ws_blacklist_until = {}
        self.ws_domain_pref = {}
        self.port = 0
        self.dc_ip = dict(TGWS_DEFAULT_DC_IP)
        self.secret_hex = ""
        self.secret_bytes = b""
        self._ws_pool = _TgWsWsPool(max_age_sec=120.0, max_items_per_key=4)
        self._cf_domains = []
        self._cf_pref = {}
        try:
            _tgws_start_cfproxy_domain_refresh(self._set_cf_domains)
        except Exception:
            pass
    def _set_cf_domains(self, domains):
        try:
            d = list(domains or [])
        except Exception:
            d = []
        seen = set()
        out = []
        for x in d:
            try:
                s = str(x or "").strip().lower()
            except Exception:
                continue
            if not s or s in seen:
                continue
            seen.add(s)
            out.append(s)
        try:
            with self._cfg_lock:
                self._cf_domains = out
        except Exception:
            self._cf_domains = out
    def _cf_domains_for_dc(self, dc, is_media=False):
        try:
            dc_num = int(dc or 0)
        except Exception:
            dc_num = 0
        # Snapshot pool and pref together under lock so a refresh in-between
        # cannot produce mismatched (pool, pref) pair.
        try:
            with self._cfg_lock:
                pool = list(getattr(self, "_cf_domains", []) or [])
                _pref_map = dict(getattr(self, "_cf_pref", {}) or {})
        except Exception:
            pool = list(getattr(self, "_cf_domains", []) or [])
            _pref_map = dict(getattr(self, "_cf_pref", {}) or {})
        if not pool:
            return []
        try:
            pref = str(_pref_map.get(int(dc_num), "") or "").strip().lower()
        except Exception:
            pref = ""
        ordered = []
        if pref and pref in pool:
            ordered.append(pref)
        for base in pool:
            if base != pref:
                ordered.append(base)
        out = []
        for base in ordered:
            if is_media:
                out.append(f"kws{dc_num}-1.{base}")
            out.append(f"kws{dc_num}.{base}")
        seen = set()
        uniq = []
        for d in out:
            if d not in seen:
                seen.add(d)
                uniq.append(d)
        return uniq
    def _ws_pool_key(self, dc, is_media):
        try:
            return (int(dc or 0), bool(is_media))
        except Exception:
            return (0, bool(is_media))
    def _ws_pool_get(self, dc, is_media):
        return self._ws_pool.get(self._ws_pool_key(dc, is_media))
    def _ws_pool_put(self, dc, is_media, ws):
        try:
            self._ws_pool.put(self._ws_pool_key(dc, is_media), ws)
        except Exception:
            try:
                if ws is not None:
                    ws.close()
            except Exception:
                pass
    def _ws_pool_keeper_loop(self):
        # RES-02/03 keeper: periodically health-check IDLE pool entries — ping each
        # survivor, evict closed / expired / ping-failed sockets. The scan detaches
        # entries under the pool lock before pinging, so get() can never hand a
        # socket to a caller mid-scan; we therefore never ping or drop an in-use WS.
        try:
            interval = float(TGWS_WS_POOL_KEEPER_INTERVAL_SEC)
        except Exception:
            interval = 30.0
        if interval <= 0:
            return
        while not self.stop_event.is_set():
            try:
                if self.stop_event.wait(timeout=interval):
                    return
            except Exception:
                return
            try:
                self._ws_pool.health_scan()
            except Exception:
                pass
    def _ws_fail_timeout(self, dc_key):
        # RES-05b: read fail_until under _cfg_lock; use the short connect timeout
        # while a DC is still inside its backoff cooldown window.
        try:
            with self._cfg_lock:
                fail_until = float(self.fail_until.get(dc_key, 0.0) or 0.0)
        except Exception:
            fail_until = 0.0
        try:
            if time.time() < fail_until:
                return float(TGWS_WS_FAIL_TIMEOUT_SEC)
        except Exception:
            pass
        return float(TGWS_WS_CONNECT_TIMEOUT_SEC)
    def _ws_fail_record(self, dc_key):
        # RES-05b: read fail_count under _cfg_lock, compute exponential backoff
        # OUTSIDE the lock, then write fail_count + fail_until back under the lock as
        # one atomic transaction (no torn read-modify-write between handler threads).
        try:
            with self._cfg_lock:
                prev = int(self.fail_count.get(dc_key, 0) or 0)
        except Exception:
            prev = 0
        new_count = prev + 1
        try:
            base = float(TGWS_WS_FAIL_COOLDOWN_SEC)
            backoff = base * (2 ** min(max(new_count - 1, 0), 4))
            backoff = min(backoff, float(TGWS_WS_FAIL_COOLDOWN_MAX_SEC))
        except Exception:
            backoff = float(TGWS_WS_FAIL_COOLDOWN_SEC)
        deadline = time.time() + backoff
        try:
            with self._cfg_lock:
                self.fail_count[dc_key] = int(new_count)
                self.fail_until[dc_key] = float(deadline)
        except Exception:
            pass
    def _ws_fail_clear(self, dc_key):
        # RES-05b: clear backoff state on a successful connect (atomic under lock).
        try:
            with self._cfg_lock:
                self.fail_until.pop(dc_key, None)
                self.fail_count.pop(dc_key, None)
        except Exception:
            pass
    def _ws_is_blacklisted(self, dc_key):
        # RES-06/06b: TTL blacklist check under _cfg_lock (short critical section).
        # Lazily auto-clears an entry once its TTL has elapsed so the DC is retried.
        now = time.time()
        try:
            with self._cfg_lock:
                until = self.ws_blacklist_until.get(dc_key)
                if until is None:
                    return False
                if now >= float(until or 0.0):
                    self.ws_blacklist_until.pop(dc_key, None)
                    try:
                        self.ws_blacklist.discard(dc_key)
                    except Exception:
                        pass
                    return False
                return True
        except Exception:
            return False
    def _ws_blacklist_add(self, dc_key):
        # RES-06/06b: blacklist a DC for a bounded TTL (auto-expires) under _cfg_lock.
        try:
            with self._cfg_lock:
                self.ws_blacklist_until[dc_key] = time.time() + float(TGWS_WS_BLACKLIST_TTL_SEC)
                try:
                    self.ws_blacklist.add(dc_key)
                except Exception:
                    pass
        except Exception:
            pass
    def reset_resilience_state(self):
        # RES-06c: on app RESUME (network may have changed) reset blacklist + fail
        # backoff so DCs that failed pre-sleep are retried at once. Do NOT clear the
        # WS pool — the keeper-thread evicts stale sockets, and dropping live pooled
        # connections would add reconnect latency to the first post-resume request.
        try:
            with self._cfg_lock:
                self.ws_blacklist = set()
                self.ws_blacklist_until = {}
                self.fail_until = {}
                self.fail_count = {}
        except Exception:
            try:
                self.ws_blacklist = set()
                self.ws_blacklist_until = {}
                self.fail_until = {}
                self.fail_count = {}
            except Exception:
                pass
    def _warmup_ws_pool(self, delay_sec=0):
        try:
            d = float(delay_sec or 0)
        except Exception:
            d = 0.0
        # [F7/F8 redo] Top-level guard (correct 8-space indent) around the
        # deferred-start delay block — a clock/sleep error in this daemon thread
        # must not escape unhandled.
        try:
            if d > 0:
                end = time.time() + d
                while time.time() < end:
                    if self.stop_event.is_set():
                        return
                    time.sleep(min(0.2, max(0.0, end - time.time())))
        except Exception:
            pass
        try:
            items = []
            for k in list((self.dc_ip or {}).keys()):
                try:
                    dc = int(k)
                except Exception:
                    continue
                items.append((dc, False))
                items.append((dc, True))
            for dc, is_media in items:
                if self.stop_event.is_set():
                    return
                try:
                    target_ip = str((self.dc_ip or {}).get(str(dc), "") or "").strip()
                    if target_ip:
                        for domain in _tgws_ws_domains(dc, is_media):
                            if self.stop_event.is_set():
                                return
                            try:
                                ws = _TgWsRawWebSocket.connect(target_ip, domain, timeout=float(TGWS_WS_CONNECT_TIMEOUT_SEC))
                                self._ws_pool_put(dc, is_media, ws)
                                break
                            except Exception:
                                continue
                except Exception:
                    pass
                try:
                    time.sleep(max(0.0, float(TGWS_WARMUP_STAGGER_SEC)))
                except Exception:
                    pass
        except Exception:
            pass
    def is_available(self):
        return JavaCipher is not None
    def _track(self, closer):
        with self.lock:
            self.tracked.add(closer)
    def _untrack(self, closer):
        with self.lock:
            self.tracked.discard(closer)
    def _close_all_tracked(self):
        with self.lock:
            closers = list(self.tracked)
            self.tracked.clear()
        for closer in closers:
            try:
                closer.close()
            except Exception:
                pass
    def _parse_config(self, config_json):
        cfg = {"port": int(TGWS_LOCAL_PORT), "dc_ip": dict(TGWS_DEFAULT_DC_IP)}
        raw = str(config_json or "").strip()
        if raw:
            parsed = json.loads(raw)
            if isinstance(parsed, dict):
                if parsed.get("port"):
                    cfg["port"] = int(parsed.get("port") or TGWS_LOCAL_PORT)
                dc_ip = parsed.get("dc_ip")
                if isinstance(dc_ip, dict):
                    for key, value in dc_ip.items():
                        cfg["dc_ip"][str(key)] = str(value)
        if cfg["port"] <= 0 or cfg["port"] > 65535:
            cfg["port"] = int(TGWS_LOCAL_PORT)
        return cfg
    def start(self, config_json, socks_user="", socks_pass="", secret_hex=""):
        if not self.is_available():
            return Z("java_crypto_missing")
        try:
            cfg = self._parse_config(config_json)
            secret = _tgws_valid_secret_hex(secret_hex) or _tgws_generate_secret_hex()
            self.stop()
            self.secret_hex = secret
            self.secret_bytes = bytes.fromhex(secret)
            listener = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            listener.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
            try:
                if TGWS_TCP_NODELAY:
                    listener.setsockopt(socket.IPPROTO_TCP, socket.TCP_NODELAY, 1)
            except Exception:
                pass
            try:
                listener.setsockopt(socket.SOL_SOCKET, socket.SO_RCVBUF, int(TGWS_SOCK_RCVBUF))
                listener.setsockopt(socket.SOL_SOCKET, socket.SO_SNDBUF, int(TGWS_SOCK_SNDBUF))
            except Exception:
                pass
            listener.bind((LOCAL_PROXY_HOST, int(cfg["port"])))
            listener.listen(64)
            listener.settimeout(1.0)
            self.listener = listener
            self.port = int(cfg["port"])
            self.dc_ip = dict(cfg.get("dc_ip") or {})
            try:
                with self._cfg_lock:
                    self.fail_until = {}
                    self.fail_count = {}
                    self.ws_blacklist = set()
                    self.ws_blacklist_until = {}
            except Exception:
                self.fail_until = {}
                self.fail_count = {}
                self.ws_blacklist = set()
                self.ws_blacklist_until = {}
            self.stop_event.clear()
            self.listener_thread = threading.Thread(target=self._accept_loop, name="tgws-accept", daemon=True)
            self.listener_thread.start()
            if bool(TGWS_WARMUP_ON_START):
                threading.Thread(target=self._warmup_ws_pool, kwargs={"delay_sec": float(TGWS_WARMUP_DELAY_SEC)}, name="tgws-warmup", daemon=True).start()
            return ""
        except Exception as exc:
            try:
                if self.listener is not None:
                    self.listener.close()
            except Exception:
                pass
            self.listener = None
            return str(exc)
    def stop(self):
        self.stop_event.set()
        try:
            if self.listener is not None:
                self.listener.close()
        except Exception:
            pass
        self.listener = None
        try:
            self._ws_pool.clear()
        except Exception:
            pass
        self._close_all_tracked()
        thread = self.listener_thread
        self.listener_thread = None
        if thread is not None and thread.is_alive():
            try:
                thread.join(1.5)
            except Exception:
                pass
    def _accept_loop(self):
        while not self.stop_event.is_set():
            try:
                conn, _ = self.listener.accept()
                try:
                    if TGWS_TCP_NODELAY:
                        conn.setsockopt(socket.IPPROTO_TCP, socket.TCP_NODELAY, 1)
                except Exception:
                    pass
                try:
                    conn.setsockopt(socket.SOL_SOCKET, socket.SO_RCVBUF, int(TGWS_SOCK_RCVBUF))
                    conn.setsockopt(socket.SOL_SOCKET, socket.SO_SNDBUF, int(TGWS_SOCK_SNDBUF))
                except Exception:
                    pass
            except socket.timeout:
                continue
            except Exception:
                if self.stop_event.is_set():
                    break
                continue
            try:
                self._track(conn)
                threading.Thread(target=self._handle_client, args=(conn,), daemon=True).start()
            except Exception:
                try:
                    conn.close()
                except Exception:
                    pass
                try:
                    self._untrack(conn)
                except Exception:
                    pass
                if self.stop_event.is_set():
                    break
                continue
    def _close_write(self, conn):
        try:
            conn.shutdown(socket.SHUT_WR)
        except Exception:
            pass
    def _connect_ws_direct(self, dc, is_media, target_ip, timeout):
        dc_key = self._ws_pool_key(dc, is_media)
        try:
            ws = self._ws_pool_get(dc, is_media)
            if ws is not None:
                return ws
        except Exception:
            pass
        domains = _tgws_ws_domains(dc, is_media)
        try:
            with self._cfg_lock:
                pref = str(self.ws_domain_pref.get(dc_key) or "").strip()
        except Exception:
            pref = ""
        if pref:
            domains = [pref] + [d for d in domains if d != pref]
        last_exc = None
        redirects = 0
        for domain in domains:
            candidates = []
            for c in (domain, _tgws_resolve_ipv4(domain), str(target_ip or "").strip()):
                if c and c not in candidates:
                    candidates.append(c)
            for host in candidates:
                try:
                    ws = _TgWsRawWebSocket.connect(str(host), domain, timeout=timeout)
                    try:
                        with self._cfg_lock:
                            self.ws_domain_pref[dc_key] = str(domain)
                    except Exception:
                        pass
                    return ws
                except Exception as exc:
                    last_exc = exc
                    if " 30" in str(exc):
                        redirects += 1
                        continue
                    continue
        if redirects and redirects >= len(domains):
            # RES-06: blacklist with a bounded TTL (auto-expires) instead of a
            # permanent set entry, under _cfg_lock inside the helper.
            self._ws_blacklist_add(dc_key)
        if last_exc:
            raise last_exc
        raise RuntimeError("websocket unavailable")
    def _connect_ws_cf(self, dc, is_media, timeout):
        last_exc = None
        for domain in self._cf_domains_for_dc(dc, is_media):
            try:
                ws = _TgWsRawWebSocket.connect(domain, domain, timeout=timeout)
                try:
                    base = str(domain).split(".", 1)[1]
                    if base:
                        with self._cfg_lock:
                            self._cf_pref[int(dc)] = base
                except Exception:
                    pass
                return ws
            except Exception as exc:
                last_exc = exc
                continue
        if last_exc:
            raise last_exc
        raise RuntimeError("cf websocket unavailable")
    def _bridge_tcp_reencrypt(self, client, remote, ctx):
        done = threading.Event()
        def _client_to_remote():
            try:
                while not done.is_set():
                    chunk = client.recv(TGWS_RECV_CHUNK)
                    if not chunk:
                        break
                    plain = _tgws_cipher_update(ctx.clt_dec, chunk)
                    out = _tgws_cipher_update(ctx.tg_enc, plain)
                    if out:
                        remote.sendall(out)
            except Exception:
                pass
            try:
                done.set()
            except Exception:
                pass
            try:
                self._close_write(remote)
            except Exception:
                pass
        def _remote_to_client():
            try:
                while not done.is_set():
                    chunk = remote.recv(TGWS_RECV_CHUNK)
                    if not chunk:
                        break
                    plain = _tgws_cipher_update(ctx.tg_dec, chunk)
                    out = _tgws_cipher_update(ctx.clt_enc, plain)
                    if out:
                        client.sendall(out)
            except Exception:
                pass
            try:
                done.set()
            except Exception:
                pass
            try:
                self._close_write(client)
            except Exception:
                pass
        t1 = threading.Thread(target=_client_to_remote, daemon=True)
        t2 = threading.Thread(target=_remote_to_client, daemon=True)
        t1.start(); t2.start()
        try:
            while not done.is_set() and (t1.is_alive() or t2.is_alive()):
                done.wait(0.25)
        except Exception:
            pass
        done.set()
        for t in (t1, t2):
            try:
                if t.is_alive():
                    t.join(0.5)
            except Exception:
                pass
        for item in (client, remote):
            try:
                item.close()
            except Exception:
                pass
            try:
                self._untrack(item)
            except Exception:
                pass
    # NOTE: We intentionally do NOT proactively reconnect a broken WS.
    # The TG client owns the retry policy: when the local 127.0.0.1 socket
    # dies it will re-dial, which spawns a fresh _handle_client -> fresh
    # ws_pool.get() / dial. Adding a proactive reconnect here would race
    # with the client's own backoff and double-send queued messages.
    def _bridge_ws_reencrypt(self, client, ws, ctx, splitter):
        done = threading.Event()
        def _client_to_ws():
            try:
                while not done.is_set():
                    chunk = client.recv(TGWS_RECV_CHUNK)
                    if not chunk:
                        if splitter is not None:
                            try:
                                tail = splitter.flush() if hasattr(splitter, "flush") else []
                            except Exception:
                                tail = []
                            for p in list(tail or []):
                                try:
                                    ws.send(p)
                                except Exception:
                                    break
                        break
                    plain = _tgws_cipher_update(ctx.clt_dec, chunk)
                    data = _tgws_cipher_update(ctx.tg_enc, plain)
                    if not data:
                        continue
                    if splitter is not None:
                        parts = splitter.split(data)
                        if not parts:
                            continue
                        if len(parts) > 1:
                            try:
                                ws.send_batch(parts)
                            except Exception:
                                for p in parts:
                                    ws.send(p)
                        else:
                            ws.send(parts[0])
                    else:
                        ws.send(data)
            except Exception:
                pass
            try:
                done.set()
            except Exception:
                pass
        def _ws_to_client():
            try:
                while not done.is_set():
                    payload = ws.recv()
                    if not payload:
                        break
                    plain = _tgws_cipher_update(ctx.tg_dec, payload)
                    out = _tgws_cipher_update(ctx.clt_enc, plain)
                    if out:
                        client.sendall(out)
            except Exception:
                pass
            try:
                done.set()
            except Exception:
                pass
        t1 = threading.Thread(target=_client_to_ws, daemon=True)
        t2 = threading.Thread(target=_ws_to_client, daemon=True)
        t1.start(); t2.start()
        try:
            while not done.is_set() and (t1.is_alive() or t2.is_alive()):
                done.wait(0.25)
        except Exception:
            pass
        done.set()
        for t in (t1, t2):
            try:
                if t.is_alive():
                    t.join(0.5)
            except Exception:
                pass
        try:
            ws.close()
        except Exception:
            pass
        try:
            client.close()
        except Exception:
            pass
        try:
            self._untrack(ws)
        except Exception:
            pass
        try:
            self._untrack(client)
        except Exception:
            pass
    def _tcp_fallback_reencrypt(self, client, dc, relay_init, ctx):
        try:
            dc_eff = int(TGWS_DC_OVERRIDES.get(int(dc), int(dc)))
        except Exception:
            dc_eff = int(dc or 0)
        dst = str(TGWS_DIRECT_DC_IP.get(int(dc or 0), "") or TGWS_DIRECT_DC_IP.get(int(dc_eff), "") or "").strip()
        if not dst:
            dst = str((self.dc_ip or {}).get(str(dc), "") or (self.dc_ip or {}).get(str(dc_eff), "") or "").strip()
        if not dst:
            return False
        try:
            remote = socket.create_connection((dst, 443), 10.0)
            self._track(remote)
            remote.sendall(bytes(relay_init or b""))
            self._bridge_tcp_reencrypt(client, remote, ctx)
            return True
        except Exception:
            try:
                client.close()
            except Exception:
                pass
            return False
    def _handle_client(self, conn):
        try:
            conn.settimeout(10.0)
            init_packet = _tgws_recv_exact(conn, TGWS_HANDSHAKE_LEN)
            conn.settimeout(None)
            result = _tgws_try_mtproto_handshake(init_packet, self.secret_bytes)
            if result is None:
                return
            dc, is_media, proto_int, proto_tag, client_dec_prekey_iv = result
            relay_dc_idx = -int(dc) if bool(is_media) else int(dc)
            relay_init = _tgws_generate_relay_init(proto_tag, relay_dc_idx)
            ctx = _tgws_build_crypto_ctx(client_dec_prekey_iv, self.secret_bytes, relay_init)
            target_ip = str((self.dc_ip or {}).get(str(dc), "") or "").strip()
            dc_key = self._ws_pool_key(dc, is_media)
            ws = None
            try:
                ws = self._connect_ws_cf(dc, is_media, float(TGWS_WS_CONNECT_TIMEOUT_SEC))
            except Exception:
                ws = None
            if ws is None and target_ip and not self._ws_is_blacklisted(dc_key):
                # RES-05b: read backoff state (under _cfg_lock) to pick the timeout,
                # then record/clear backoff atomically via the helpers.
                timeout = self._ws_fail_timeout(dc_key)
                try:
                    ws = self._connect_ws_direct(dc, is_media, target_ip, timeout)
                except Exception:
                    self._ws_fail_record(dc_key)
                    ws = None
            if ws is None:
                self._tcp_fallback_reencrypt(conn, dc, relay_init, ctx)
                return
            self._ws_fail_clear(dc_key)
            self._track(ws)
            try:
                ws.send(relay_init)
                splitter = None
                try:
                    splitter = _TgWsMsgSplitter(relay_init, proto_int)
                except Exception:
                    splitter = None
                self._bridge_ws_reencrypt(conn, ws, ctx, splitter)
            except Exception:
                # send()/splitter/bridge raised before the bridge could untrack:
                # close + untrack the WS here so a LIVE socket never lingers in
                # self.tracked for the rest of the session.
                try:
                    ws.close()
                except Exception:
                    pass
                try:
                    self._untrack(ws)
                except Exception:
                    pass
            return
        except Exception:
            pass
        finally:
            try:
                conn.close()
            except Exception:
                pass
            # conn is _track()-ed in _accept_loop BEFORE this thread starts.
            # Early returns (bad handshake / exception / failed tcp-fallback)
            # close it but never untracked -> closed sockets pile up in
            # self.tracked. discard() is idempotent, so this is safe even when
            # a bridge already untracked conn on the happy path.
            try:
                self._untrack(conn)
            except Exception:
                pass
class TgWsProxyPlugin(BasePlugin):
    def _is_advanced_enabled(self) -> bool:
        try:
            return bool(self.get_setting("advanced_enabled", False))
        except Exception:
            return False
    def _normalize_local_host(self, raw_host) -> str:
        try:
            host = str(raw_host or "").strip()
        except Exception:
            host = ""
        if not host or host.lower() == "localhost":
            return "127.0.0.1"
        try:
            socket.inet_aton(host)
            return host
        except Exception:
            return "127.0.0.1"
    def _local_host(self) -> str:
        if not self._is_advanced_enabled():
            return "127.0.0.1"
        return self._normalize_local_host(self.get_setting("local_socks_host", "127.0.0.1"))
    def _apply_runtime_local_host(self) -> str:
        global LOCAL_PROXY_HOST
        host = self._normalize_local_host(self._local_host())
        with _TGWS_HOST_LOCK:
            LOCAL_PROXY_HOST = host
        return host
    def _normalize_local_port(self, raw_port) -> int:
        try:
            port = int(raw_port)
        except Exception:
            port = int(DEFAULT_LOCAL_PROXY_PORT)
        if port < 1024 or port > 65535:
            port = int(DEFAULT_LOCAL_PROXY_PORT)
        return int(port)
    def _is_local_port_free(self, port: int) -> bool:
        try:
            host = self._apply_runtime_local_host()
            with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
                s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
                s.bind((host, int(port)))
            return True
        except Exception:
            return False
    def _pick_random_local_port(self) -> int:
        self._apply_runtime_local_host()
        for _ in range(48):
            try:
                p = random.randint(20000, 55000)
            except Exception:
                p = 0
            if p > 0 and self._is_local_port_free(p):
                return int(p)
        try:
            p = int(_get_free_port())
            if 1024 <= p <= 65535 and self._is_local_port_free(p):
                return int(p)
        except Exception:
            pass
        return int(DEFAULT_LOCAL_PROXY_PORT)
    def _local_port(self) -> int:
        if self._is_advanced_enabled():
            return self._normalize_local_port(self.get_setting("local_socks_port", int(DEFAULT_LOCAL_PROXY_PORT)))
        try:
            cached = int(getattr(self, "_runtime_random_local_port", 0) or 0)
        except Exception:
            cached = 0
        if cached > 0 and self._is_local_port_free(cached):
            return int(cached)
        p = int(self._pick_random_local_port())
        self._runtime_random_local_port = int(p)
        return int(p)
    def _wait_local_port_free(self, port: int, timeout_sec: float = 1.8) -> bool:
        deadline = time.time() + float(max(0.2, timeout_sec))
        while time.time() < deadline:
            if self._is_local_port_free(int(port)):
                return True
            time.sleep(0.08)
        return self._is_local_port_free(int(port))
    def on_plugin_load(self):
        # RLock guards _tgws_running, _tgws_starting, _tgws_port, _tgws_start_token,
        # _tgws_start_seq, _tgws_proxy_managed, _tgws_proxy_snapshot,
        # _runtime_random_local_port and _reload_ui_pending. RLock so re-entrant
        # call chains (UI -> _start_tgws_runtime -> _tgws_connect_bg -> _tgws_connect)
        # that all touch flags from the same thread are safe.
        self._state_lock = threading.RLock()
        self._tgws_core = TgWsCore()
        self._tgws_port = 0
        self._tgws_running = False
        self._tgws_proxy_snapshot = None
        self._tgws_proxy_managed = False
        self._tgws_last_error = ""
        self._tgws_starting = False
        # Monotonic start sequence — replaces time.time() based token, which
        # could collide between two starts fired within sub-millisecond window.
        self._tgws_start_seq = 0
        self._tgws_start_token = 0
        self._runtime_random_local_port = 0
        self._reload_ui_pending = False
        self._chat_menu_item_id = "tgws_settings_chat"
        self._drawer_menu_item_id = "tgws_settings_drawer"
        try:
            _adv_raw = self.get_setting("advanced_enabled", False)
            _adv_norm = bool(_adv_raw)
            if _adv_raw is None or _adv_raw != _adv_norm:
                self.set_setting("advanced_enabled", _adv_norm, reload_settings=False)
            _host_norm = self._local_host()
            if str(self.get_setting("local_socks_host", "") or "") != str(_host_norm):
                self.set_setting("local_socks_host", _host_norm, reload_settings=False)
            if self._is_advanced_enabled():
                _port_raw = self.get_setting("local_socks_port", int(DEFAULT_LOCAL_PROXY_PORT))
                _port_norm = self._normalize_local_port(_port_raw)
                if _port_raw != _port_norm:
                    self.set_setting(
                        "local_socks_port",
                        _port_norm,
                        reload_settings=False,
                    )
        except Exception:
            pass
        try:
            self._apply_runtime_local_host()
        except Exception:
            pass
        self._add_menu_items()
        if bool(self.get_setting("tgws_enabled", False)):
            self._start_tgws_runtime(auto_start=True, delay_ms=int(TGWS_AUTOSTART_DELAY_MS))
    def on_plugin_unload(self):
        try:
            _tgws_cf_refresh_stop.set()
        except Exception:
            pass
        try:
            self._tgws_disconnect(silent=True)
        except Exception:
            pass
        try:
            self._remove_menu_items()
        except Exception:
            pass
    def on_app_event(self, event_type):
        try:
            AppEvent = find_class("com.exteragram.messenger.plugins.AppEvent")
            if not AppEvent:
                return
            if event_type in (AppEvent.START, AppEvent.RESUME):
                try:
                    with self._state_lock:
                        _busy = bool(getattr(self, "_tgws_running", False)) or bool(getattr(self, "_tgws_starting", False))
                except Exception:
                    _busy = bool(getattr(self, "_tgws_running", False)) or bool(getattr(self, "_tgws_starting", False))
                if bool(self.get_setting("tgws_enabled", False)) and not _busy:
                    self._start_tgws_runtime(auto_start=True, delay_ms=int(TGWS_RESUME_START_DELAY_MS))
        except Exception:
            pass
    def create_settings(self):
        def _t(ru, en):
            try:
                return ru if _is_ru_language() else en
            except Exception:
                return en
        try:
            running = bool(getattr(self, "_tgws_running", False))
            starting = bool(getattr(self, "_tgws_starting", False))
            if running:
                dot, state = "\U0001F7E2", Z("state_on")
            elif starting:
                dot, state = "\U0001F7E1", Z("state_starting")
            else:
                dot, state = "\U0001F534", Z("state_off")
            port = int(getattr(self, "_tgws_port", 0) or 0)
            status = f"{dot} {Z('tgws_status')} · {state}"
            if port > 0:
                status += f" · {LOCAL_PROXY_HOST}:{port}"
        except Exception:
            status = f"\U0001F534 {Z('tgws_status')} · {Z('state_off')}"
        items = [
            # --- Секция: Статус ---
            Header(text=_t("Статус", "Status")),
            Text(text=status, icon="msg_stats"),
            Divider(text=_t("Текущее состояние локального прокси.", "Current state of the local proxy.")),
            # --- Секция: Главное ---
            Header(text=_t("Главное", "General")),
            Switch(
                key="tgws_enabled",
                text=Z("enable_plugin"),
                default=False,
                icon="msg_permissions",
                on_change=self._on_enabled_changed,
            ),
            Text(text=Z("open_tg_settings"), icon="msg_settings", on_click=lambda v: self._open_tg_proxy_settings()),
            Divider(text=_t("Включение прокси и быстрый переход к настройкам прокси Telegram.", "Enable the proxy and jump to Telegram proxy settings.")),
            # --- Секция: Подключение ---
            Header(text=Z("connection_settings")),
            Switch(
                key="advanced_enabled",
                text=Z("advanced_settings"),
                default=False,
                icon="msg_settings",
                on_change=self._on_advanced_changed,
            ),
        ]
        if self._is_advanced_enabled():
            items += [
                Input(
                    key="local_socks_host",
                    text=Z("local_host"),
                    default=str(self._local_host()),
                    icon="msg_channel",
                    on_change=self._on_local_host_changed,
                ),
                Divider(text=_t("Адрес локального интерфейса. Обычно 127.0.0.1.", "Local interface address. Usually 127.0.0.1.")),
                Input(
                    key="local_socks_port",
                    text=Z("local_port"),
                    default=str(self._normalize_local_port(self.get_setting("local_socks_port", int(DEFAULT_LOCAL_PROXY_PORT)))),
                    icon="msg_settings_14",
                    on_change=self._on_local_port_changed,
                ),
                Divider(text=Z("local_port_desc")),
            ]
        else:
            items.append(Divider(text=_t("Включите, чтобы настроить хост и порт вручную.", "Enable to configure host and port manually.")))
        items += [
            # --- Секция: О плагине ---
            Header(text=_t("О плагине", "About")),
            Divider(text=Z("about")),
        ]
        return items
    def _start_tgws_runtime(self, auto_start=False, delay_ms=0):
        try:
            # Transactional check-and-set: only ONE caller can win the race to set
            # _tgws_starting=True and capture the new start sequence number.
            with self._state_lock:
                if bool(getattr(self, "_tgws_running", False)) or bool(getattr(self, "_tgws_starting", False)):
                    return
                if bool(auto_start) and not bool(self.get_setting("tgws_enabled", False)):
                    return
                self._tgws_starting = True
                self._tgws_start_seq = int(getattr(self, "_tgws_start_seq", 0) or 0) + 1
                self._tgws_start_token = int(self._tgws_start_seq)
                token = int(self._tgws_start_token)
        except Exception:
            token = -1
        def _run():
            try:
                # Recheck token under lock — if another disconnect/start fired after we
                # were scheduled, the counter advanced and we must abort.
                with self._state_lock:
                    if int(getattr(self, "_tgws_start_token", 0) or 0) != int(token):
                        return
                    if bool(auto_start) and not bool(self.get_setting("tgws_enabled", False)):
                        self._tgws_starting = False
                        return
                threading.Thread(target=self._tgws_connect_bg, kwargs={"auto_start": bool(auto_start)}, daemon=True).start()
            except Exception:
                try:
                    with self._state_lock:
                        self._tgws_starting = False
                except Exception:
                    pass
        try:
            d = int(delay_ms or 0)
        except Exception:
            d = 0
        if d > 0:
            try:
                run_on_ui_thread(_run, d)
                return
            except Exception:
                pass
        _run()
    def _tgws_connect_bg(self, auto_start=False):
        ok = False
        try:
            ok = bool(self._tgws_connect(auto_start=bool(auto_start)))
        except Exception as e:
            try:
                self._tgws_last_error = str(e)
            except Exception:
                pass
            ok = False
        if not ok:
            try:
                with self._state_lock:
                    self._tgws_starting = False
            except Exception:
                pass
            msg = Z("tgws_connect_failed")
            try:
                last = str(getattr(self, "_tgws_last_error", "") or "").strip()
                if last:
                    msg = f"{Z('tgws_connect_failed')}: {last}"
            except Exception:
                pass
            try:
                run_on_ui_thread(lambda: BulletinHelper.show_error(str(msg)))
            except Exception:
                pass
            if not bool(auto_start):
                try:
                    self.set_setting("tgws_enabled", False, reload_settings=True)
                except Exception:
                    pass
            try:
                run_on_ui_thread(self._reload_settings_ui)
            except Exception:
                pass
    def _tgws_get_static_field(self, cls, name, default=None):
        try:
            f = _tgws_cached_field(cls, str(name))
            return f.get(None)
        except Exception:
            return default
    def _tgws_set_static_field(self, cls, name, value):
        try:
            f = _tgws_cached_field(cls, str(name))
            f.set(None, value)
        except Exception:
            pass
    def _tgws_snapshot_current_proxy(self):
        if self._tgws_proxy_snapshot is not None:
            return
        try:
            shared_config_cls = find_class("org.telegram.messenger.SharedConfig")
            current = self._tgws_get_static_field(shared_config_cls, "currentProxyInfo", None)
            enabled = bool(self._tgws_get_static_field(shared_config_cls, "useProxySettings", False))
            snapshot = {"enabled": enabled, "host": "", "port": 0, "user": "", "password": "", "secret": ""}
            if current:
                snapshot["host"] = str(get_private_field(current, "address") or "")
                snapshot["port"] = int(get_private_field(current, "port") or 0)
                snapshot["user"] = str(get_private_field(current, "username") or "")
                snapshot["password"] = str(get_private_field(current, "password") or "")
                snapshot["secret"] = str(get_private_field(current, "secret") or "")
            self._tgws_proxy_snapshot = snapshot
        except Exception:
            pass
    def _tgws_restore_previous_proxy(self):
        if not bool(getattr(self, "_tgws_proxy_managed", False)):
            return
        snapshot = getattr(self, "_tgws_proxy_snapshot", None)
        try:
            if snapshot is None:
                return
            enabled = bool(snapshot.get("enabled", False))
            host = str(snapshot.get("host", "") or "")
            port = int(snapshot.get("port", 0) or 0)
            user = str(snapshot.get("user", "") or "")
            password = str(snapshot.get("password", "") or "")
            secret = str(snapshot.get("secret", "") or "")
            shared_config_cls = find_class("org.telegram.messenger.SharedConfig")
            try:
                self._tgws_set_static_field(shared_config_cls, "useProxySettings", bool(enabled))
            except Exception:
                pass
            try:
                if host and port > 0:
                    ProxyInfo = jclass("org.telegram.messenger.SharedConfig$ProxyInfo")
                    pinfo = ProxyInfo(host, int(port), user, password, secret)
                    try:
                        self._tgws_set_static_field(shared_config_cls, "currentProxyInfo", pinfo)
                    except Exception:
                        pass
                    try:
                        SharedConfig.addProxy(pinfo)
                    except Exception:
                        pass
                else:
                    self._tgws_set_static_field(shared_config_cls, "currentProxyInfo", None)
            except Exception:
                pass
            try:
                ConnectionsManager.setProxySettings(bool(enabled), host, int(port), user, password, secret)
            except Exception:
                try:
                    for ac in range(UserConfig.MAX_ACCOUNT_COUNT):
                        cm = ConnectionsManager.getInstance(ac)
                        if cm:
                            cm.setProxySettings(bool(enabled), host, int(port), user, password, secret)
                except Exception:
                    pass
        finally:
            try:
                self._tgws_proxy_managed = False
            except Exception:
                pass
            try:
                self._tgws_proxy_snapshot = None
            except Exception:
                pass
    def _tgws_get_or_create_secret(self):
        cached = getattr(self, "_tgws_secret_cache", "") or ""
        if cached:
            return cached
        try:
            current = _tgws_valid_secret_hex(self.get_setting("mtproto_secret", ""))
        except Exception:
            current = ""
        if current:
            try:
                self._tgws_secret_cache = current
            except Exception:
                pass
            return current
        current = _tgws_generate_secret_hex()
        try:
            self.set_setting("mtproto_secret", current, reload_settings=False)
        except Exception:
            pass
        try:
            self._tgws_secret_cache = current
        except Exception:
            pass
        return current
    def _tgws_connect(self, auto_start=False):
        try:
            self._apply_runtime_local_host()
            port = int(self._local_port())
            if not self._wait_local_port_free(port, timeout_sec=0.8):
                try:
                    self._tgws_last_error = f"{Z('local_port_busy')}: {port}"
                except Exception:
                    pass
                return False
            if int(port or 0) <= 0:
                try:
                    self._tgws_last_error = Z("tgws_no_port")
                except Exception:
                    pass
                self._tgws_running = False
                self._tgws_port = 0
                try:
                    self._tgws_starting = False
                except Exception:
                    pass
                return False
            self._tgws_port = int(port)
            secret_hex = self._tgws_get_or_create_secret()
            config_json = json.dumps({"port": int(port), "verbose": False})
            err = self._tgws_core.start(config_json, secret_hex=secret_hex)
            if err:
                try:
                    self._tgws_last_error = str(err)
                except Exception:
                    pass
                try:
                    run_on_ui_thread(lambda: BulletinHelper.show_error(str(err)))
                except Exception:
                    pass
                self._tgws_running = False
                self._tgws_port = 0
                try:
                    self._tgws_starting = False
                except Exception:
                    pass
                return False
            # start() уже сделал listener.bind() + listen(): порт открыт в момент
            # возврата, поэтому применяем прокси сразу, без watchdog-поллинга.
            _secret = str(secret_hex or "")
            try:
                self._tgws_snapshot_current_proxy()
            except Exception:
                pass
            try:
                self._tgws_proxy_managed = True
            except Exception:
                pass
            try:
                _apply_tg_proxy(int(port), True, secret=_secret)
            except Exception as _e:
                try:
                    self._tgws_last_error = str(_e)
                except Exception:
                    pass
            # [lock-7 redo] The JNI/proxy work (_apply_tg_proxy above) ran OUTSIDE
            # _state_lock to avoid a UI freeze. Only the Python flag transition is
            # made atomic here — a tiny lock-held critical section.
            try:
                with self._state_lock:
                    self._tgws_running = True
                    self._tgws_starting = False
            except Exception:
                self._tgws_running = True
                try:
                    self._tgws_starting = False
                except Exception:
                    pass
            try:
                self.set_setting("tgws_enabled", True, reload_settings=False)
            except Exception:
                pass
            try:
                if not bool(auto_start):
                    self._reload_settings_ui(delay_ms=400)
            except Exception:
                pass
            try:
                if bool(TGWS_SHOW_SUCCESS_BULLETIN) and not bool(auto_start):
                    BulletinHelper.show_success(Z("tgws_connected"))
            except Exception:
                pass
            # [v2.1 coexist] health-check: если другой плагин (или ручная чистка
            # из настроек прокси Telegram) удалит наш 127.0.0.1 entry из
            # SharedConfig.proxyList пока tgws активен — re-install через
            # _apply_tg_proxy. Это страховка против coexistence с
            # th3_proxy_tools.plugin и любыми будущими cleanup-инструментами.
            try:
                self._tgws_start_proxy_watchdog(int(port), str(_secret or ""))
            except Exception:
                pass
            return True
        except Exception as exc:
            self._tgws_running = False
            self._tgws_port = 0
            try:
                self._tgws_starting = False
            except Exception:
                pass
            try:
                self._tgws_last_error = str(exc)
            except Exception:
                pass
            try:
                self._tgws_core.stop()
            except Exception:
                pass
            return False

    # [v2.1 coexist] proxy-list watchdog: на каждом тике проверяет, что наш
    # 127.0.0.1 entry всё ещё в SharedConfig.proxyList. Если другой плагин
    # (или ручная чистка) его удалит, мы re-install'им через _apply_tg_proxy.
    # Тред умирает сам как только _tgws_running становится False.
    def _tgws_start_proxy_watchdog(self, port, secret):
        # Если уже крутится — не плодим второй.
        if bool(getattr(self, "_tgws_watchdog_running", False)):
            return
        self._tgws_watchdog_running = True
        host = LOCAL_PROXY_HOST
        port_i = int(port or 0)
        secret_s = str(secret or "")
        plugin = self

        def _loop():
            try:
                while bool(getattr(plugin, "_tgws_running", False)):
                    try:
                        time.sleep(30.0)
                    except Exception:
                        break
                    if not bool(getattr(plugin, "_tgws_running", False)):
                        break
                    try:
                        pl = getattr(SharedConfig, "proxyList", None)
                        found = False
                        if pl:
                            with _TGWS_PROXYLIST_LOCK:
                                snap = list(pl)
                            for p in snap:
                                try:
                                    if str(getattr(p, "address", "")) == host and int(getattr(p, "port", 0) or 0) == port_i:
                                        found = True
                                        break
                                except Exception:
                                    continue
                        if not found:
                            try:
                                _log("tgws watchdog: 127.0.0.1 entry vanished, re-installing")
                            except Exception:
                                pass
                            try:
                                _apply_tg_proxy(port_i, True, secret=secret_s)
                            except Exception:
                                pass
                    except Exception:
                        pass
            finally:
                try:
                    plugin._tgws_watchdog_running = False
                except Exception:
                    pass

        try:
            threading.Thread(target=_loop, name="tgws-watchdog", daemon=True).start()
        except Exception:
            try:
                self._tgws_watchdog_running = False
            except Exception:
                pass

    def _tgws_disconnect(self, silent=False):
        # core.stop() does I/O / thread join — keep OUTSIDE the state lock.
        try:
            self._tgws_core.stop()
        except Exception:
            pass
        # Atomic flag clear + token bump. Bumping _tgws_start_seq invalidates any
        # delayed _run() still pending in run_on_ui_thread.
        try:
            with self._state_lock:
                self._tgws_running = False
                self._tgws_port = 0
                self._tgws_starting = False
                self._tgws_start_seq = int(getattr(self, "_tgws_start_seq", 0) or 0) + 1
                self._tgws_start_token = int(self._tgws_start_seq)
        except Exception:
            pass
        try:
            self._tgws_restore_previous_proxy()
        except Exception:
            _apply_tg_proxy(0, False)
        if not silent:
            self._reload_settings_ui()
    def _on_enabled_changed(self, v):
        enabled = bool(v)
        if enabled:
            self._start_tgws_runtime(auto_start=False, delay_ms=TGWS_SOFT_RESTART_DELAY_MS)
        else:
            # [PATCH v2.0] Атомарно сбрасываем флаги ПЕРЕД disconnect, чтобы
            # быстрый OFF→ON не блокировался guard'ом в _start_tgws_runtime.
            try:
                with self._state_lock:
                    self._tgws_running = False
                    self._tgws_starting = False
            except Exception:
                pass
            self._tgws_disconnect()
    def _on_advanced_changed(self, v):
        try:
            enabled = bool(v)
            was_running = bool(getattr(self, "_tgws_running", False))
            if was_running:
                self._tgws_disconnect(silent=True)
            self.set_setting("advanced_enabled", enabled, reload_settings=False)
            if not enabled:
                self.set_setting("local_socks_host", "127.0.0.1", reload_settings=False)
                self._runtime_random_local_port = 0
            else:
                self.set_setting("local_socks_host", self._normalize_local_host(self.get_setting("local_socks_host", "127.0.0.1")), reload_settings=False)
                self.set_setting("local_socks_port", self._normalize_local_port(self.get_setting("local_socks_port", int(DEFAULT_LOCAL_PROXY_PORT))), reload_settings=False)
            self._apply_runtime_local_host()
            if was_running:
                self._start_tgws_runtime(auto_start=False, delay_ms=TGWS_SOFT_RESTART_DELAY_MS)
        except Exception:
            pass
        self._reload_settings_ui()
    def _on_local_host_changed(self, v):
        try:
            if not self._is_advanced_enabled():
                return
            host = self._normalize_local_host(v)
            prev = self._normalize_local_host(self.get_setting("local_socks_host", "127.0.0.1"))
            if host == prev:
                return
            was_running = bool(getattr(self, "_tgws_running", False))
            if was_running:
                self._tgws_disconnect(silent=True)
            self.set_setting("local_socks_host", host, reload_settings=False)
            self._apply_runtime_local_host()
            if was_running:
                self._start_tgws_runtime(auto_start=False, delay_ms=TGWS_SOFT_RESTART_DELAY_MS)
            self._reload_settings_ui()
        except Exception:
            pass
    def _on_local_port_changed(self, v):
        try:
            if not self._is_advanced_enabled():
                return
            raw = str(v or "").strip()
            if not raw:
                return
            port = self._normalize_local_port(raw)
            if str(port) != raw:
                try:
                    run_on_ui_thread(lambda: BulletinHelper.show_error(Z("local_port_invalid")))
                except Exception:
                    pass
            current = self._local_port()
            if int(port) == int(current):
                return
            was_running = bool(getattr(self, "_tgws_running", False))
            if was_running:
                self._tgws_disconnect(silent=True)
            self.set_setting("local_socks_port", int(port), reload_settings=False)
            self._runtime_random_local_port = int(port)
            if was_running:
                self._start_tgws_runtime(auto_start=False, delay_ms=TGWS_SOFT_RESTART_DELAY_MS)
            self._reload_settings_ui()
        except Exception:
            pass
    def _reload_settings_ui(self, delay_ms=100):
        try:
            if bool(getattr(self, "_reload_ui_pending", False)):
                return
            self._reload_ui_pending = True
        except Exception:
            pass
        def _do():
            try:
                self._reload_ui_pending = False
            except Exception:
                pass
            try:
                self.set_setting("__reload__", time.time(), reload_settings=True)
            except Exception:
                pass
        try:
            run_on_ui_thread(_do, int(delay_ms))
        except Exception:
            pass
    def _open_tg_proxy_settings(self):
        try:
            frag = get_last_fragment()
            if frag:
                from org.telegram.ui import ProxyListActivity
                frag.presentFragment(ProxyListActivity())
        except Exception:
            pass
    def _add_menu_items(self):
        def on_click(ctx):
            self._open_settings()
        try:
            self.remove_menu_item(self._chat_menu_item_id)
        except Exception:
            pass
        try:
            self.add_menu_item(MenuItemData(
                menu_type=MenuItemType.CHAT_ACTION_MENU,
                item_id=self._chat_menu_item_id,
                text=Z("menu_settings"),
                on_click=on_click,
                icon="msg_settings",
                priority=1,
            ))
        except Exception:
            pass
        try:
            self.remove_menu_item(self._drawer_menu_item_id)
        except Exception:
            pass
        try:
            self.add_menu_item(MenuItemData(
                menu_type=MenuItemType.DRAWER_MENU,
                item_id=self._drawer_menu_item_id,
                text=Z("menu_settings"),
                on_click=on_click,
                icon="msg_settings",
                priority=1,
            ))
        except Exception:
            pass
    def _remove_menu_items(self):
        try:
            self.remove_menu_item(self._chat_menu_item_id)
        except Exception:
            pass
        try:
            self.remove_menu_item(self._drawer_menu_item_id)
        except Exception:
            pass
    def _open_settings(self):
        try:
            PC = find_class("com.exteragram.messenger.plugins.PluginsController")
        except Exception:
            PC = None
        try:
            PSA = find_class("com.exteragram.messenger.plugins.ui.PluginSettingsActivity")
        except Exception:
            PSA = None
        try:
            if PC:
                inst = None
                try:
                    inst = PC.getInstance()
                except Exception:
                    inst = None
                if inst is not None and hasattr(inst, "plugins") and PSA:
                    plugin_obj = None
                    try:
                        plugin_obj = inst.plugins.get(self.id)
                    except Exception:
                        plugin_obj = None
                    if plugin_obj is not None:
                        frag = get_last_fragment()
                        if frag is not None:
                            frag.presentFragment(PSA(plugin_obj))
                            return
                try:
                    PC.openPluginSettings(self.id)
                    return
                except Exception:
                    pass
            frag = get_last_fragment()
            if frag and PC:
                PC.getInstance().openPluginSettings(self.id, frag)
        except Exception:
            pass
