# Guards LOCAL_PROXY_HOST mutations and SharedConfig.proxyList iteration/mutation.
# RLock so the same thread can re-enter (e.g. _apply_runtime_local_host -> _local_host).
_TGWS_HOST_LOCK = threading.RLock()
_TGWS_PROXYLIST_LOCK = threading.RLock()
# [v2.1 coexist] guard against re-entrant proxySettingsChanged posts when
