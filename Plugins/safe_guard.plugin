        ]
    def create_settings(self):
        Header, Switch, Input, Divider, Text, Selector = self.getUiParts()
        if Header is None:
            return []
        try:
            return [
                Header(text="SafeSend Guard"),
                Text(
                    text="Что проверять",
                    icon="msg_block",
                    create_sub_fragment=self.mkScan
                ),
                Text(
                    text="Маскирование и фото",
                    icon="msg_photo",
                    create_sub_fragment=self.mkPriv
                ),
                Text(
                    text="ГС и кружки",
                    icon="msg_calls",
                    create_sub_fragment=self.mkRec
                ),
                Text(
                    text="Белый список",
                    icon="msg_groups",
                    create_sub_fragment=self.mkWl
                )
            ]
        except Exception as e:
            self.log(f"SafeSend: error creating settings: {e}")
            return []
    def on_plugin_unload(self):
        try:
            self.remove_hook("on_send_message_hook")
        except Exception:
            pass
