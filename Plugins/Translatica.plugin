            # Salva como booleano (sempre visível > só estado muda)
            self.set_setting("logs_disabled", v_bool)
            self._set_log_muted(v_bool)
            run_on_ui_thread(lambda: BulletinHelper.show_info(self._t("logs_disable_label")))
        except Exception:
