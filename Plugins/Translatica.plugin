__id__          = "translatica"
__name__        = "Translatica"
__description__ = "A context based translation plugin that adapts messages to sound natural in the selected language, with full control over the target language\n\nРусский: Инструмент перевода с учетом контекста, который адаптирует сообщения, чтобы они звучали естественно на выбранном языке, с полным управлением целевым языком"
__author__      = "@AGeekApple"
__version__     = "1.0.0"
__min_version__ = "11.12.0"
__icon__        = "ApplePlugins/19"

class Translatica(BasePlugin):
    # Sistema de desativação de logs
    _TRANSLATICA_LOGS_MUTED = False

    def _set_log_muted(self, muted: bool):
        try:
            Translatica._TRANSLATICA_LOGS_MUTED = bool(muted)
        except Exception:
            pass

    def _log_wrapper(self, original_log):
        def wrapper(*args, **kwargs):
            try:
                if not Translatica._TRANSLATICA_LOGS_MUTED:
                    return original_log(*args, **kwargs)
            except Exception:
                return original_log(*args, **kwargs)
        return wrapper

    def _apply_log_wrapper(self):
        try:
            global log
            log = self._log_wrapper(log)
        except Exception:
            pass

    # Aplicar wrapper ao carregar classe
    _apply_log = True

