                icon="msg_secret_solar",
                on_change=on_change
            ),
        ]

        self._normalize_input_background_settings_texts(
            settings,
            is_ru,
            input_background_path,
            input_background_name,
        )

        if spoiler_enabled:
            settings.extend([
