                    default="50",
                    subtext="ะะฐัะฐะปัะฝะพะต ัะฐัััะพัะฝะธะต ัะฐััะธั (20-100)" if is_ru else "Initial particle distance (20-100)",
                    icon="msg_map_type_solar"
                )
             ])
        
        settings.extend([
            Divider(),
            Header(text="ะะปะฐะฒะฝัะน ะบัััะพั" if is_ru else "Smooth Cursor"),
            
            Switch(
                key="cursor_enabled",
                text="ะะปะฐะฒะฝัะน ะบัััะพั" if is_ru else "Smooth Cursor",
                default=True,
                subtext="ะะปะฐะฒะฝะพะต ะดะฒะธะถะตะฝะธะต ะบัััะพัะฐ" if is_ru else "Fluid cursor movement",
                icon="msg_channel_14_solar"
            ),
            
            Input(
                key="cursor_speed",
                text="ะกะบะพัะพััั (10-100)" if is_ru else "Speed (10-100)",
                default="25",
                subtext="ะกะบะพัะพััั ะฐะฝะธะผะฐัะธะธ ะบัััะพัะฐ" if is_ru else "Cursor animation speed",
                icon="msg_speed"
            ),
            
            Input(
                key="cursor_width",
                text="ะจะธัะธะฝะฐ ะบัััะพัะฐ" if is_ru else "Cursor Width",
                default="5",
                subtext="ะขะพะปัะธะฝะฐ ะบัััะพัะฐ ะฒ ะฟะธะบัะตะปัั" if is_ru else "Cursor thickness in pixels",
                icon="msg_edit"
            ),

            Switch(
                key="liquid_cursor_enabled",
                text="ะะธะดะบะธะน ะบัััะพั" if is_ru else "Liquid Cursor",
                default=False,
                subtext="ะะตัะพัะผะฐัะธั ะฟัะธ ะดะฒะธะถะตะฝะธะธ" if is_ru else "Deformation on movement",
                icon="msg_payment_delivery_solar"
            )
        ])

        liquid_enabled = self.get_setting("liquid_cursor_enabled", False)
        if liquid_enabled:
            settings.append(
                Input(
                    key="liquid_scale_factor",
                    text="ะกะธะปะฐ ัะฐัััะถะตะฝะธั" if is_ru else "Stretch Strength",
                    default="15",
                    subtext="ะะพัััะธัะธะตะฝั ัะฐัััะถะตะฝะธั (5-50)" if is_ru else "Stretch factor (5-50)",
                    icon="msg_noise_on_solar"
                )
            )
        
        settings.append(Divider())
        settings.append(
            Switch(
                key="debug_mode",
                text="ะ ะตะถะธะผ ะพัะปะฐะดะบะธ" if is_ru else "Debug Mode",
                default=False,
                subtext="ะะพะณะธัะพะฒะฐะฝะธะต ะพัะธะฑะพะบ (ะดะปั ัะฐะทัะฐะฑะพััะธะบะพะฒ)" if is_ru else "Error logging (for devs)",
                icon="msg_settings_solar"
            )
        )
        
        settings.extend([
            Divider(),
            Header(text="ะะพะดะตะปะธัััั ะฝะฐัััะพะนะบะฐะผะธ" if is_ru else "Share Settings"),
            
            Text(
                text="ะญะบัะฟะพััะธัะพะฒะฐัั ะฝะฐัััะพะนะบะธ" if is_ru else "Export Settings",
                icon="msg_share",
                accent=True,
                on_click=self._save_config_to_file
            ),
            
            Text(
                text="ะะผะฟะพััะธัะพะฒะฐัั ะฝะฐัััะพะนะบะธ" if is_ru else "Import Settings",
                icon="msg_download",
                accent=True,
                on_click=self._show_import_from_file_dialog
            ),
            
            Divider(
                text="ะญะบัะฟะพััะธััะนัะต ะฝะฐัััะพะนะบะธ ะฒ ัะฐะนะป .animtext ะธ ะฟะพะดะตะปะธัะตัั ะธะผ ั ะดััะทััะผะธ!" if is_ru else "Export settings to .animtext file and share with friends!"
            )
        ])
        
        return settings