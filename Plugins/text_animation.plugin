            header_layout.addView(icon_view, LayoutHelper.createLinear(48, 48, 0, 0, 14, 0))

            title_layout = LinearLayout(activity)
            title_layout.setOrientation(LinearLayout.VERTICAL)

            title_view = TextView(activity)
