            subtitle_view.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
            subtitle_view.setTextColor(Theme.getColor(Theme.key_dialogTextGray2))
            title_layout.addView(subtitle_view)

            header_layout.addView(title_layout, LayoutHelper.createLinear(0, -2, 1.0))
            container.addView(header_layout, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 0, 16))

            scroll = ScrollView(activity)
            scroll_height = min(360, max(180, len(configs) * 116))

            list_container = LinearLayout(activity)
            list_container.setOrientation(LinearLayout.VERTICAL)

            delete_state = {
                "path": None,
                "label": None,
                "background": None,
                "idle_color": None,
                "idle_text_color": None,
            }

            def reset_delete_state():
                label = delete_state.get("label")
                background = delete_state.get("background")
                idle_color = delete_state.get("idle_color")
                idle_text_color = delete_state.get("idle_text_color")

                if label is not None:
                    label.setText("Удалить" if is_ru else "Delete")
                    if idle_text_color is not None:
                        label.setTextColor(int(idle_text_color))
                if background is not None and idle_color is not None:
                    background.setColor(int(idle_color))

                delete_state["path"] = None
                delete_state["label"] = None
                delete_state["background"] = None
                delete_state["idle_color"] = None
                delete_state["idle_text_color"] = None

            for config_entry in configs:
                card = LinearLayout(activity)
                card.setOrientation(LinearLayout.VERTICAL)
                card.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(14), AndroidUtilities.dp(14), AndroidUtilities.dp(14))

                card_bg = GradientDrawable()
                card_bg.setCornerRadius(AndroidUtilities.dp(16))
                card_bg.setColor(Theme.getColor(Theme.key_listSelector))
                card.setBackground(card_bg)

                def on_preview(v, entry=config_entry):
                    reset_delete_state()
                    sheet.dismiss()
                    run_on_ui_thread(
                        lambda entry=entry: self._show_import_config_sheet(entry["config"], entry["filename"]),
                        delay=120
                    )

                card.setOnClickListener(OnClickListener(on_preview))

                top_row = LinearLayout(activity)
                top_row.setOrientation(LinearLayout.HORIZONTAL)
                top_row.setGravity(Gravity.CENTER_VERTICAL)

                row_icon_bg = GradientDrawable()
                row_icon_bg.setShape(GradientDrawable.OVAL)
                row_icon_bg.setColor(Theme.getColor(Theme.key_windowBackgroundWhite))

                row_icon = ImageView(activity)
                row_icon.setImageResource(R.drawable.files_storage)
                row_icon.setColorFilter(Theme.getColor(Theme.key_featuredStickers_addButton))
                row_icon.setBackground(row_icon_bg)
                row_icon.setPadding(AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8), AndroidUtilities.dp(8))
                top_row.addView(row_icon, LayoutHelper.createLinear(40, 40, 0, 0, 12, 0))

                text_layout = LinearLayout(activity)
                text_layout.setOrientation(LinearLayout.VERTICAL)

                name_view = TextView(activity)
                name_view.setText(config_entry["display_name"])
                name_view.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
                name_view.setTypeface(AndroidUtilities.bold())
                name_view.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
                text_layout.addView(name_view)

                meta_view = TextView(activity)
                meta_view.setText(self._get_config_meta_text(config_entry.get("config"), config_entry.get("filename")))
                meta_view.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
                meta_view.setTextColor(Theme.getColor(Theme.key_dialogTextGray2))
                text_layout.addView(meta_view)

                top_row.addView(text_layout, LayoutHelper.createLinear(0, -2, 1.0))
                card.addView(top_row, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 0, 14))

                actions_layout = LinearLayout(activity)
                actions_layout.setOrientation(LinearLayout.HORIZONTAL)

                def on_apply(v, entry=config_entry):
                    reset_delete_state()
                    sheet.dismiss()
                    self._apply_config_with_feedback(entry.get("config"), entry.get("display_name"))

                apply_button, _, _ = self._create_sheet_button(
                    activity,
                    "Применить" if is_ru else "Apply",
                    Theme.getColor(Theme.key_featuredStickers_addButton),
                    -1,
                    on_apply,
                    text_size_sp=14,
                )
                actions_layout.addView(apply_button, LayoutHelper.createLinear(0, 40, 1.2, 0, 0, 8, 0))

                def on_rename(v, entry=config_entry, reopen_mode=mode):
                    reset_delete_state()
                    sheet.dismiss()
                    run_on_ui_thread(
                        lambda entry=entry, reopen_mode=reopen_mode: self._show_rename_config_sheet(entry, reopen_mode),
                        delay=120
                    )

                rename_button, _, _ = self._create_sheet_button(
                    activity,
                    "Переименовать" if is_ru else "Rename",
                    Theme.getColor(Theme.key_windowBackgroundWhite),
                    Theme.getColor(Theme.key_featuredStickers_addButton),
                    on_rename,
                    text_size_sp=14,
                )
                actions_layout.addView(rename_button, LayoutHelper.createLinear(0, 40, 1.0, 8, 0, 8, 0))

                delete_idle_color = Theme.getColor(Theme.key_windowBackgroundWhite)
                delete_text_color = Theme.getColor(Theme.key_text_RedRegular)

                delete_button, delete_label, delete_bg = self._create_sheet_button(
                    activity,
                    "Удалить" if is_ru else "Delete",
                    delete_idle_color,
                    delete_text_color,
                    lambda v: None,
                    text_size_sp=14,
                )

                def on_delete(v, entry=config_entry, label=delete_label, background=delete_bg):
                    filepath = str(entry.get("filepath") or "")
                    if not filepath:
                        BulletinHelper.show_error("Файл конфига не найден" if is_ru else "Config file not found")
                        return

                    if delete_state.get("path") == filepath:
                        reset_delete_state()
                        sheet.dismiss()
                        if self._delete_saved_config_entry(entry):
                            self._reopen_saved_configs_sheet(mode)
                        return

                    reset_delete_state()
                    label.setText("Подтвердить" if is_ru else "Confirm")
                    label.setTextColor(-1)
                    background.setColor(Theme.getColor(Theme.key_text_RedRegular))

                    delete_state["path"] = filepath
                    delete_state["label"] = label
                    delete_state["background"] = background
                    delete_state["idle_color"] = delete_idle_color
                    delete_state["idle_text_color"] = delete_text_color

                    BulletinHelper.show_info(
                        "Нажмите ещё раз, чтобы удалить конфиг"
                        if is_ru else
                        "Tap again to delete the config"
                    )

                    def reset_later(path=filepath):
                        if delete_state.get("path") == path:
                            reset_delete_state()

                    run_on_ui_thread(reset_later, delay=2500)

                delete_button.setOnClickListener(OnClickListener(on_delete))
                actions_layout.addView(delete_button, LayoutHelper.createLinear(0, 40, 0.9, 8, 0, 0, 0))

                card.addView(actions_layout, LayoutHelper.createLinear(-1, -2))
                list_container.addView(card, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 0, 12))

            scroll.addView(list_container)
            container.addView(scroll, LayoutHelper.createLinear(-1, scroll_height, 0, 0, 0, 0, 16))

            close_button, _, _ = self._create_sheet_button(
                activity,
                "Закрыть" if is_ru else "Close",
                Theme.getColor(Theme.key_listSelector),
                Theme.getColor(Theme.key_featuredStickers_addButton),
                lambda v: (
                    reset_delete_state(),
                    sheet.dismiss()
                ),
            )
            container.addView(close_button, LayoutHelper.createLinear(-1, 48))

            sheet.setCustomView(container)
            sheet.show()
        except Exception as e:
            self.log(f"Saved configs sheet error: {e}")
            BulletinHelper.show_error(f"Ошибка: {e}" if is_ru else f"Error: {e}")

    def _show_rename_config_sheet(
        self,
        config_entry: dict[str, Any],
        reopen_mode: Optional[str] = None,
        parent_sheet=None,
    ) -> None:
        is_ru = self._is_russian()

        def on_submit(value: str) -> bool:
            if self._rename_saved_config_entry(config_entry, value):
                if parent_sheet is not None:
                    try:
                        parent_sheet.dismiss()
                    except Exception:
                        pass
                self._reopen_saved_configs_sheet(reopen_mode)
                return True
            return False

        self._show_config_name_sheet(
            "Переименовать конфиг" if is_ru else "Rename Config",
            "Имя конфига" if is_ru else "Config name",
            config_entry["display_name"],
            "Сохранить" if is_ru else "Save",
            on_submit,
        )

    def _show_text_input_dialog(
        self,
        title: str,
        hint: str,
        initial_value: str,
        positive_text: str,
        on_submit: Callable[[str], bool],
    ) -> None:
        self._show_config_name_sheet(title, hint, initial_value, positive_text, on_submit)

    def _show_manage_configs_dialog(self, view=None):
        configs = self._get_saved_configs()
        if not configs:
            BulletinHelper.show_info("Нет сохранённых конфигов" if self._is_russian() else "No saved configs")
            return
        self._show_manage_configs_popup_sheet(configs)

    def _show_rename_config_dialog(self, config_entry: dict[str, Any]) -> None:
        self._show_rename_config_sheet(config_entry)

    def _show_delete_config_confirmation(
        self,
        config_entry: dict[str, Any],
        reopen_mode: Optional[str] = None,
        parent_sheet=None,
    ) -> None:
        from ui.alert import AlertDialogBuilder

        is_ru = self._is_russian()

        try:
            activity = self._get_current_activity()
            if not activity:
                return

            builder = AlertDialogBuilder(activity)
            builder.set_title(
                f'Удалить конфиг "{config_entry["display_name"]}"?' if is_ru
                else f'Delete config "{config_entry["display_name"]}"?'
            )

            def on_delete(b, w):
                b.dismiss()
                if parent_sheet is not None:
                    try:
                        parent_sheet.dismiss()
                    except Exception:
                        pass
                self._delete_saved_config(config_entry, reopen_mode)

            builder.set_positive_button("Удалить" if is_ru else "Delete", on_delete)
            builder.set_negative_button("Отмена" if is_ru else "Cancel", lambda b, w: b.dismiss())
            builder.make_button_red(AlertDialogBuilder.BUTTON_POSITIVE)
            builder.show()
        except Exception as e:
            self.log(f"Delete config confirmation error: {e}")
            BulletinHelper.show_error(f"Ошибка: {e}" if is_ru else f"Error: {e}")

    def _delete_saved_config(
        self,
        config_entry: dict[str, Any],
        reopen_mode: Optional[str] = None,
    ) -> bool:
        deleted = self._delete_saved_config_entry(config_entry)
        if deleted:
            self._reopen_saved_configs_sheet(reopen_mode)
        return deleted
    
    def _handle_config_file_open(self, filepath: str):
        self.log(f"Handling config file: {filepath}")
        
        config = self._load_config_from_file(filepath)
        if config:
            filename = os.path.basename(filepath)
            run_on_ui_thread(lambda: self._show_import_config_sheet(config, filename))
        else:
            BulletinHelper.show_error("Не удалось прочитать файл конфигурации" if self._is_russian() else "Failed to read config file")
    
    def _export_config(self, config_name: Optional[str] = None) -> dict:
        config = {
            "version": CONFIG_VERSION,
            "plugin_version": __version__,
            "timestamp": int(time.time()),
            "name": self._sanitize_config_name(config_name),
            "settings": {}
        }
        for key in CONFIG_KEYS:
            default = CONFIG_DEFAULTS.get(key)
            config["settings"][key] = self.get_setting(key, default)
        return config
    
    def _import_config(self, config: dict) -> bool:
        try:
            if "settings" not in config:
                return False
            for key, value in config["settings"].items():
                if key in CONFIG_KEYS:
                    self.set_setting(key, value)
            
            if self.dex_loader:
                self.dex_loader.update_settings(config["settings"])
            return True
        except Exception as e:
            self.log(f"Import error: {e}")
            return False
    
    def _save_config_to_file(self, view=None):
        is_ru = self._is_russian()

        def on_submit(value: str) -> bool:
            config_name = self._sanitize_config_name(value)
            if not config_name:
                BulletinHelper.show_error("Введите имя конфига" if is_ru else "Enter config name")
                return False

            try:
                config_dir = self._get_config_dir()
                if not config_dir:
                    BulletinHelper.show_error("Не удалось сохранить" if is_ru else "Save failed")
                    return False

                filename, filepath = self._build_unique_config_filepath(config_dir, config_name)
                config = self._export_config(config_name)
                self._write_config_file(filepath, config)

                self.log(f"Config saved to: {filepath}")
                run_on_ui_thread(lambda filepath=filepath, filename=filename: self._show_share_dialog(filepath, filename), delay=50)
                return True
            except Exception as e:
                self.log(f"Save error: {e}")
                BulletinHelper.show_error(str(e))
                return False

        self._show_text_input_dialog(
            "Сохранить конфиг" if is_ru else "Save Config",
            "Имя конфига" if is_ru else "Config name",
            self._get_default_config_name(),
            "Сохранить" if is_ru else "Save",
            on_submit,
        )
    
