class DexDownloadDelegate(dynamic_proxy(NotificationCenter.NotificationCenterDelegate)):
    def __init__(self, plugin):
        super().__init__()
        self.plugin = plugin

    def didReceivedNotification(self, notification_id, account, *args):
        if self.plugin is not None:
            self.plugin._on_dex_download_notification(notification_id, account, *args)


class OpenDocumentHook(MethodHook):
    def __init__(self, plugin):
        super().__init__()
        self.plugin = plugin
    
    def before_hooked_method(self, param):
        try:
            if not param.args:
                return
            message = param.args[0]
            if not message:
                return
            
            file_name = self.plugin._get_message_file_name(message)
            if not file_name:
                return

            if self.plugin._is_config_file_name(file_name):
                m_name = param.method.getName()
                if "openForView" in m_name:
                    param.setResult(True)
                else:
                    param.setResult(None)
                
                path = self.plugin._resolve_message_file_path(message)
                
                if path and os.path.exists(str(path)):
                    run_on_ui_thread(lambda path=str(path): self.plugin._handle_config_file_open(path))
                else:
                    BulletinHelper.show_error("Файл ещё не загружен или не найден" if self.plugin._is_russian() else "File not downloaded or not found")
            elif self.plugin._is_dex_file_name(file_name):
                m_name = param.method.getName()
                if "openForView" in m_name:
                    param.setResult(True)
                else:
                    param.setResult(None)

                path = self.plugin._resolve_message_file_path(message)
                if path and os.path.exists(str(path)):
                    run_on_ui_thread(lambda path=str(path): self.plugin.install_dex_from_path(path, announce=True))
                else:
                    run_on_ui_thread(lambda: self.plugin.download_dex_from_message(message))
        except Exception as e:
            self.plugin.log(f"Document open hook error: {e}")


class DexLocalFileOpenHook(MethodHook):
    def __init__(self, plugin):
        super().__init__()
        self.plugin = plugin

    def before_hooked_method(self, param):
        try:
            if not param.args or len(param.args) < 2:
                return

            file_obj = param.args[0]
            file_name = str(param.args[1] or "")
            if not self.plugin._is_dex_file_name(file_name):
                return

            path = None
            try:
                if file_obj is not None and hasattr(file_obj, "getAbsolutePath"):
                    path = str(file_obj.getAbsolutePath())
            except Exception:
                path = None

            if not path or not os.path.exists(path):
                return

            param.setResult(True)
            run_on_ui_thread(lambda path=path: self.plugin.install_dex_from_path(path, announce=True))
        except Exception as e:
            self.plugin.log(f"Local DEX open hook error: {e}")


class LaunchActivityResultHook(MethodHook):
    def __init__(self, plugin):
        super().__init__()
        self.plugin = plugin

    def after_hooked_method(self, param):
        try:
            if not param.args or len(param.args) < 3:
                return
            self.plugin._on_launch_activity_result(
                param.thisObject,
                int(param.args[0]),
                int(param.args[1]),
                param.args[2]
            )
        except Exception as e:
            self.plugin.log(f"Launch activity result hook error: {e}")


class DexLoader:
    def __init__(self, plugin: BasePlugin):
        self.plugin = plugin
        self.dex_class = None
        self.dex_loader = None
        
        self.cache_dir = os.path.join(
            ApplicationLoader.applicationContext.getFilesDir().getAbsolutePath(),
            DEX_CACHE_DIR
        )
        self.cache_file = os.path.join(self.cache_dir, DEX_CACHE_FILE_NAME)
        
        if not os.path.exists(self.cache_dir):
            os.makedirs(self.cache_dir)

    def _plugin_dir(self) -> str:
        source = globals().get("__file__")
        if source:
            return os.path.dirname(os.path.abspath(str(source)))
        return os.getcwd()

    def find_local_dex_path(self) -> Optional[str]:
        current_dir = self._plugin_dir()
        checked = set()

        for _ in range(5):
            if not current_dir or current_dir in checked:
                break
            checked.add(current_dir)

            candidate = os.path.join(current_dir, DEX_LOCAL_FILE_NAME)
            if os.path.exists(candidate):
                return candidate

            parent_dir = os.path.dirname(current_dir)
            if parent_dir == current_dir:
                break
            current_dir = parent_dir

        return None

    def install_from_local(self) -> str:
        path = self.find_local_dex_path()
        if not path:
            raise FileNotFoundError(DEX_LOCAL_FILE_NAME)
        self.install_from_path(path)
        return path
    
    def load_from_cache(self) -> Optional[bytes]:
        try:
            if os.path.exists(self.cache_file):
                with open(self.cache_file, 'rb') as f:
                    return f.read()
            return None
        except Exception as e:
            self.plugin.log(f"Cache load error: {e}")
            return None

    def clear_cache(self):
        try:
            if os.path.exists(self.cache_file):
                os.remove(self.cache_file)
        except Exception as e:
            self.plugin.log(f"Cache clear error: {e}")
            raise

    def install_from_path(self, path: str):
        with open(path, 'rb') as f:
            self.install_from_bytes(f.read())

    def install_from_bytes(self, dex_bytes: bytes):
        self.unload()
        with open(self.cache_file, 'wb') as f:
            f.write(dex_bytes)

        try:
            self.start_from_bytes(dex_bytes)
        except Exception:
            try:
                self.clear_cache()
            except Exception:
                pass
            raise
    
    def start_from_bytes(self, dex_bytes: bytes):
        try:
            self.unload()
            buffer = ByteBuffer.wrap(dex_bytes)
            self.dex_loader = InMemoryDexClassLoader(
                buffer, 
                ApplicationLoader.applicationContext.getClassLoader()
            )
            
            self.dex_class = self.dex_loader.loadClass(DEX_CLASS_NAME)
            
            from java import jclass
            try:
                CoreClass = jclass(DEX_CLASS_NAME)
                CoreClass.getInstance().start()
                self.plugin.log(f"DEX loaded via jclass: {DEX_CLASS_NAME}")
            except Exception as e1:
                self.plugin.log(f"jclass failed: {e1}, trying reflection")
                instance_method = self.dex_class.getDeclaredMethod("getInstance", None)
                instance_method.setAccessible(True)
                
                start_method = self.dex_class.getDeclaredMethod("start", None)
                start_method.setAccessible(True)
                
                java_instance = instance_method.invoke(None, None)
                start_method.invoke(java_instance, None)
                self.plugin.log(f"DEX loaded via reflection: {DEX_CLASS_NAME}")
                
        except Exception as e:
            self.plugin.log(f"DEX start error: {e}")
            raise
    
    def load_and_start(self):
        cached_bytes = self.load_from_cache()
        if cached_bytes is None:
            raise RuntimeError("Manual DEX install required")
        self.start_from_bytes(cached_bytes)
        return
        try:
            cached_bytes = self.load_from_cache()
            
            if cached_bytes is not None:
                self.plugin.log("Loading DEX from cache...")
                self.start_from_bytes(cached_bytes)
                
                try:
                    if self.check_for_updates():
                        self.plugin.log("Downloading DEX update...")
                        self.download_dex()
                        
                        is_ru = self._is_russian()
                        msg = "Доступно обновление Text Animation! Перезапустите приложение." if is_ru else \
                              "Text Animation update available! Restart the app."
                        BulletinHelper.show_info(msg, get_last_fragment())
                except Exception as e:
                    self.plugin.log(f"Update check failed: {e}")
            else:
                self.plugin.log("No cache, downloading DEX...")
                
                try:
                    self.plugin.log(f"Fetching version from {VERSION_URL}")
                    r = requests.get(VERSION_URL, timeout=5)
                    r.raise_for_status()
                    lines = r.text.strip().split('\n')
                    self.plugin.log(f"Version response lines: {len(lines)}")
                    if len(lines) >= 2:
                        self.download_url = lines[1].strip()
                        self.plugin.log(f"Got URL from version.txt: {self.download_url}")
                    else:
                        self.download_url = DEFAULT_DEX_URL
                        self.plugin.log(f"Using default URL: {self.download_url}")
                except Exception as ve:
                    self.plugin.log(f"Version fetch error: {ve}")
                    self.download_url = DEFAULT_DEX_URL
                
                if not self.download_url:
                    self.download_url = DEFAULT_DEX_URL
                    self.plugin.log(f"URL was empty, using default: {self.download_url}")
                
                dex_bytes = self.download_dex()
                self.start_from_bytes(dex_bytes)
                
        except Exception as e:
            if "proxy" in str(e).lower():
                return
            self.plugin.log(f"Fatal DEX error: {e}")
            BulletinHelper.show_error(f"Text Animation load error: {e}", get_last_fragment())
    
    def _is_russian(self) -> bool:
        try:
            lang = LocaleController.getInstance().getCurrentLocale().getLanguage()
            return str(lang).startswith("ru")
        except:
            return False

    def update_settings(self, settings: dict):
        try:
            if self.dex_class:
                from java import jclass
                settings_json = json.dumps(settings)
                
                try:
                    CoreClass = jclass(DEX_CLASS_NAME)
                    CoreClass.getInstance().updateSettings(settings_json)
                except Exception as e1:
                    self.plugin.log(f"jclass settings failed: {e1}, trying reflection")
                    String = jclass("java.lang.String")
                    param_types = [String.getClass()]
                    
                    instance_method = self.dex_class.getDeclaredMethod("getInstance", None)
                    instance_method.setAccessible(True)
                    
                    method = self.dex_class.getDeclaredMethod("updateSettings", param_types)
                    method.setAccessible(True)
                    
                    method.invoke(instance_method.invoke(None, None), [settings_json])
        except Exception as e:
            self.plugin.log(f"Settings update error: {e}")
    
    def unload(self):
        try:
            if self.dex_class:
                from java import jclass
                try:
                    CoreClass = jclass(DEX_CLASS_NAME)
                    CoreClass.getInstance().onUnload()
                    self.plugin.log("DEX unloaded via jclass")
                except Exception as e1:
                    self.plugin.log(f"jclass unload failed: {e1}, trying reflection")
                    instance_method = self.dex_class.getDeclaredMethod("getInstance", None)
                    instance_method.setAccessible(True)
                    
                    method = self.dex_class.getDeclaredMethod("onUnload", None)
                    method.setAccessible(True)
                    
                    method.invoke(instance_method.invoke(None, None), None)
                    self.plugin.log("DEX unloaded via reflection")
        except Exception as e:
            self.plugin.log(f"Unload error: {e}")
        finally:
            self.dex_class = None
            self.dex_loader = None
    


class TextAnimationPlugin(BasePlugin):
    
    def __init__(self):
        super().__init__()
        self.dex_loader: Optional[DexLoader] = None
        self._hooks = []
        self._download_delegate = DexDownloadDelegate(self)
        self._observer_account: Optional[int] = None
        self._pending_dex_file_name: Optional[str] = None
        self._pending_dex_location: Optional[str] = None
        self._pending_install_after_download = False
    
    def _on_setting_change(self, new_value):
        self._sync_settings_to_dex()

    def _same_callback(self, left, right) -> bool:
        if left is None or right is None:
            return left is right
        return (
            getattr(left, "__func__", left) == getattr(right, "__func__", right)
            and getattr(left, "__self__", None) == getattr(right, "__self__", None)
        )

    def _normalize_input_background_settings_texts(
        self,
        settings: list[Any],
        is_ru: bool,
        input_background_path: str,
        input_background_name: str,
    ) -> None:
        header_text = "Фон поля ввода" if is_ru else "Input Field Background"
        enable_text = "Включить фон поля" if is_ru else "Enable Field Background"
        choose_text = (
            "Выбрать фото для фона"
            if is_ru else
            "Choose background photo"
        )
        replace_text = (
            "Сменить фоновое фото"
            if is_ru else
            "Replace background photo"
        )
        current_file_text = (
            f"Текущий файл: {input_background_name}"
            if input_background_name else
            ("Фото ещё не выбрано" if is_ru else "No photo selected yet")
        )
        clear_text = "Очистить фоновое фото" if is_ru else "Clear background photo"
        scale_text = "Масштаб" if is_ru else "Scale Mode"
        scale_items = ["Заполнить", "Вписать"] if is_ru else ["Fill", "Fit"]
        blur_text = "Размытие фона" if is_ru else "Background Blur"
        dim_text = "Затемнение" if is_ru else "Dimming"

        for index, item in enumerate(settings):
            key = getattr(item, "key", None)

            if isinstance(item, Header):
                next_key = getattr(settings[index + 1], "key", None) if index + 1 < len(settings) else None
                if next_key == "input_background_enabled":
                    item.text = header_text
                continue

            if key == "input_background_enabled":
                item.text = enable_text
                item.subtext = None
                continue

            if key == "input_background_scale_mode":
                item.text = scale_text
                item.items = scale_items
                continue

            if key == "input_background_blur":
                item.text = blur_text
                continue

            if key == "input_background_dim":
                item.text = dim_text
                continue

            if not isinstance(item, Text):
                continue

            if self._same_callback(item.on_click, self._open_input_background_picker):
                item.text = replace_text if input_background_path else choose_text
                continue

            if self._same_callback(item.on_click, self._clear_input_background):
                item.text = clear_text
                continue

            prev_item = settings[index - 1] if index > 0 else None
            if (
                item.icon == "msg_media"
                and prev_item is not None
                and isinstance(prev_item, Text)
                and self._same_callback(prev_item.on_click, self._open_input_background_picker)
            ):
                item.text = current_file_text

    def _get_input_background_storage_dir(self) -> str:
        storage_dir = os.path.join(
            ApplicationLoader.applicationContext.getFilesDir().getAbsolutePath(),
            INPUT_BACKGROUND_STORAGE_DIR
        )
        os.makedirs(storage_dir, exist_ok=True)
        return storage_dir

    def _get_input_background_picker_activity(self):
        try:
            fragment = get_last_fragment()
            if fragment is not None:
                activity = fragment.getParentActivity()
                if activity is not None:
                    return activity
        except Exception:
            pass

        try:
            LaunchActivity = jclass("org.telegram.ui.LaunchActivity")
            instance = getattr(LaunchActivity, "instance", None)
            if instance is not None:
                return instance
        except Exception:
            pass

        return None

    def _is_managed_input_background_path(self, path: Optional[str]) -> bool:
        if not path:
            return False
        try:
            storage_dir = os.path.abspath(self._get_input_background_storage_dir())
            candidate = os.path.abspath(str(path))
            return os.path.commonpath([storage_dir, candidate]) == storage_dir
        except Exception:
            return False

    def _delete_input_background_file(self, path: Optional[str]) -> None:
        if not self._is_managed_input_background_path(path):
            return
        try:
            if path and os.path.exists(path):
                os.remove(path)
        except Exception as e:
            self.log(f"Input background delete error: {e}")

    def _normalize_input_background_extension(self, display_name: Optional[str]) -> str:
        if not display_name:
            return ".img"
        _, ext = os.path.splitext(str(display_name))
        ext = ext.lower()
        if ext and 0 < len(ext) <= 10 and all(ch.isalnum() or ch == "." for ch in ext):
            return ext
        return ".img"

    def _get_uri_display_name(self, activity, uri) -> Optional[str]:
        cursor = None
        try:
            OpenableColumns = jclass("android.provider.OpenableColumns")
            cursor = activity.getContentResolver().query(uri, None, None, None, None)
            if cursor is None or not cursor.moveToFirst():
                return None
            column_index = cursor.getColumnIndex(OpenableColumns.DISPLAY_NAME)
            if column_index < 0:
                return None
            value = cursor.getString(column_index)
            return str(value) if value else None
        except Exception as e:
            self.log(f"Input background display name error: {e}")
            return None
        finally:
            try:
                if cursor is not None:
                    cursor.close()
            except Exception:
                pass

    def _copy_uri_to_file(self, activity, uri, output_path: str) -> bool:
        stream = None
        temp_path = f"{output_path}.tmp"
        try:
            stream = activity.getContentResolver().openInputStream(uri)
            if stream is None:
                return False

            with open(temp_path, "wb") as output:
                buffer = bytearray(64 * 1024)
                while True:
                    count = stream.read(buffer)
                    if count is None:
                        break
                    count = int(count)
                    if count <= 0:
                        break
                    output.write(buffer[:count])

            os.replace(temp_path, output_path)
            return True
        except Exception as e:
            self.log(f"Input background copy error: {e}")
            try:
                if os.path.exists(temp_path):
                    os.remove(temp_path)
            except Exception:
                pass
            return False
        finally:
            try:
                if stream is not None:
                    stream.close()
            except Exception:
                pass

    def _open_input_background_picker(self, view=None) -> None:
        try:
            activity = self._get_input_background_picker_activity()
            if activity is None:
                BulletinHelper.show_error(
                    "Сначала откройте Telegram на обычном экране." if self._is_russian()
                    else "Open Telegram on a regular screen first.",
                    get_last_fragment()
                )
                return

            Intent = jclass("android.content.Intent")
            intent = Intent(Intent.ACTION_OPEN_DOCUMENT)
            intent.addCategory(Intent.CATEGORY_OPENABLE)
            intent.setType("image/*")

            try:
                intent.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION | Intent.FLAG_GRANT_PERSISTABLE_URI_PERMISSION)
            except Exception:
                intent.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION)

            activity.startActivityForResult(intent, INPUT_BACKGROUND_REQUEST_CODE)
        except Exception as e:
            self.log(f"Input background picker open error: {e}")
            BulletinHelper.show_error(
                f"Не удалось открыть выбор фото: {e}" if self._is_russian()
                else f"Failed to open photo picker: {e}",
                get_last_fragment()
            )

    def _clear_input_background(self, view=None) -> None:
        try:
            current_path = self.get_setting("input_background_path", "") or ""
            if current_path:
                self._delete_input_background_file(current_path)

            self.set_setting("input_background_path", "", True)
            self.set_setting("input_background_name", "", True)
            self._sync_settings_to_dex()

            BulletinHelper.show_success(
                "Фон поля ввода очищен" if self._is_russian() else "Input field background cleared",
                get_last_fragment()
            )
        except Exception as e:
            self.log(f"Input background clear error: {e}")
            BulletinHelper.show_error(
                f"Не удалось очистить фон: {e}" if self._is_russian()
                else f"Failed to clear background: {e}",
                get_last_fragment()
            )

    def _on_launch_activity_result(self, activity, request_code: int, result_code: int, data) -> None:
        if int(request_code) != INPUT_BACKGROUND_REQUEST_CODE:
            return

        try:
            Activity = jclass("android.app.Activity")
            Intent = jclass("android.content.Intent")

            if int(result_code) != int(Activity.RESULT_OK) or data is None:
                return

            uri = None
            try:
                uri = data.getData()
            except Exception:
                uri = None
            if uri is None:
                BulletinHelper.show_error(
                    "Фото не выбрано" if self._is_russian() else "No photo selected",
                    get_last_fragment()
                )
                return

            try:
                flags = int(data.getFlags())
                activity.getContentResolver().takePersistableUriPermission(
                    uri,
                    flags & (
                        Intent.FLAG_GRANT_READ_URI_PERMISSION
                        | Intent.FLAG_GRANT_PERSISTABLE_URI_PERMISSION
                    )
                )
            except Exception:
                pass

            display_name = self._get_uri_display_name(activity, uri)
            if not display_name:
                try:
                    display_name = str(uri.getLastPathSegment() or "")
                except Exception:
                    display_name = "photo"

            ext = self._normalize_input_background_extension(display_name)
            target_path = os.path.join(
                self._get_input_background_storage_dir(),
                f"input_background_{int(time.time() * 1000)}{ext}"
            )

            previous_path = self.get_setting("input_background_path", "") or ""
            if self._copy_uri_to_file(activity, uri, target_path):
                if previous_path and previous_path != target_path:
                    self._delete_input_background_file(previous_path)

                self.set_setting("input_background_path", target_path, True)
                self.set_setting("input_background_name", str(display_name or ""), True)
                self._sync_settings_to_dex()

                BulletinHelper.show_success(
                    "Фото для фона поля ввода сохранено" if self._is_russian()
                    else "Input field background photo saved",
                    get_last_fragment()
                )
            else:
                BulletinHelper.show_error(
                    "Не удалось сохранить выбранное фото" if self._is_russian()
                    else "Failed to save selected photo",
                    get_last_fragment()
                )
        except Exception as e:
            self.log(f"Launch activity result error: {e}")
            BulletinHelper.show_error(
                f"Не удалось применить фото: {e}" if self._is_russian()
                else f"Failed to apply photo: {e}",
                get_last_fragment()
            )
    
    def _is_russian(self) -> bool:
        try:
            lang = LocaleController.getInstance().getCurrentLocale().getLanguage()
            return str(lang).startswith("ru")
        except:
            return False

    def _is_config_file_name(self, file_name: str) -> bool:
        return str(file_name or "").strip().lower().endswith(CONFIG_FILE_EXTENSION)

    def _is_dex_file_name(self, file_name: str) -> bool:
        return str(file_name or "").strip().lower() == DEX_LOCAL_FILE_NAME

    def _get_message_file_name(self, message) -> str:
        if message is None:
            return ""

        for getter_name in ("getDocumentName", "getFileName"):
            try:
                value = getattr(message, getter_name)()
                if value:
                    return str(value)
            except Exception:
                pass

        try:
            document = message.getDocument()
            if document is not None:
                for attr_name in ("file_name_fixed", "file_name"):
                    value = getattr(document, attr_name, None)
                    if value:
                        return str(value)
        except Exception:
            pass

        return ""

    def _resolve_message_file_path(self, message) -> Optional[str]:
        if message is None:
            return None

        try:
            attach_path = getattr(message.messageOwner, "attachPath", None)
            if attach_path:
                attach_path = str(attach_path)
                if attach_path and os.path.exists(attach_path):
                    return attach_path
        except Exception:
            pass

        try:
            from java import jclass
            FileLoader = jclass("org.telegram.messenger.FileLoader")
            file_obj = FileLoader.getInstance(message.currentAccount).getPathToMessage(message.messageOwner)
            if file_obj is not None:
                path = str(file_obj.getAbsolutePath())
                if os.path.exists(path):
                    return path
        except Exception as e:
            self.log(f"Resolve DEX path error: {e}")

        return None

    def _reset_pending_dex_download(self):
        self._pending_dex_file_name = None
        self._pending_dex_location = None
        self._pending_install_after_download = False

    def _attach_dex_download_observer(self, account: int):
        if self._observer_account == account:
            return

        self._detach_dex_download_observer()
        notification_center = NotificationCenter.getInstance(account)
        notification_center.addObserver(self._download_delegate, NotificationCenter.fileLoaded)
        notification_center.addObserver(self._download_delegate, NotificationCenter.fileLoadFailed)
        self._observer_account = account

    def _detach_dex_download_observer(self):
        if self._observer_account is None:
            return

        try:
            notification_center = NotificationCenter.getInstance(self._observer_account)
            notification_center.removeObserver(self._download_delegate, NotificationCenter.fileLoaded)
            notification_center.removeObserver(self._download_delegate, NotificationCenter.fileLoadFailed)
        except Exception:
            pass
        finally:
            self._observer_account = None

    def _matches_pending_dex_file(self, location) -> bool:
        if location is None:
            return False

        location = str(location).lower()
        pending_file_name = str(self._pending_dex_file_name or "").lower()
        pending_location = str(self._pending_dex_location or "").lower()

        return bool(location and (location == pending_file_name or location == pending_location))

    def install_dex_from_path(self, path: str, announce: bool = True):
        try:
            if not self.dex_loader:
                self.dex_loader = DexLoader(self)
            self.dex_loader.install_from_path(path)
            self._sync_settings_to_dex()
            self.log(f"DEX installed from file: {path}")
            if announce:
                BulletinHelper.show_success(
                    "Text Animation загружен из DEX." if self._is_russian() else "Text Animation loaded from DEX.",
                    get_last_fragment()
                )
        except Exception as e:
            self.log(f"DEX install error: {e}")
            BulletinHelper.show_error(
                f"Не удалось загрузить DEX: {e}" if self._is_russian() else f"Failed to load DEX: {e}",
                get_last_fragment()
            )

    def download_dex_from_message(self, message):
        try:
            document = message.getDocument()
            if document is None:
                BulletinHelper.show_error(
                    "В этом сообщении нет DEX-файла." if self._is_russian() else "This message does not contain a DEX file.",
                    get_last_fragment()
                )
                return

            file_name = self._get_message_file_name(message)
            if not file_name:
                BulletinHelper.show_error(
                    "Не удалось определить имя DEX-файла." if self._is_russian() else "Failed to resolve DEX file name.",
                    get_last_fragment()
                )
                return

            account = int(message.currentAccount)
            pending_location = ""

            try:
                from java import jclass
                FileLoader = jclass("org.telegram.messenger.FileLoader")
                pending_location = str(FileLoader.getAttachFileName(document) or "")
            except Exception as e:
                self.log(f"Resolve pending DEX location error: {e}")

            def start_download():
                from java import jclass
                FileLoader = jclass("org.telegram.messenger.FileLoader")
                self._attach_dex_download_observer(account)
                self._pending_dex_file_name = file_name
                self._pending_dex_location = pending_location
                self._pending_install_after_download = True
                FileLoader.getInstance(account).loadFile(document, message, FileLoader.PRIORITY_HIGH, 1)

            run_on_ui_thread(start_download)
            BulletinHelper.show_info(
                f"Загрузка {file_name}..." if self._is_russian() else f"Downloading {file_name}...",
                get_last_fragment()
            )
        except Exception as e:
            self._reset_pending_dex_download()
            self._detach_dex_download_observer()
            self.log(f"DEX download start error: {e}")
            BulletinHelper.show_error(
                f"Не удалось начать загрузку DEX: {e}" if self._is_russian() else f"Failed to start DEX download: {e}",
                get_last_fragment()
            )

    def _on_dex_download_notification(self, notification_id, account, *args):
        try:
            if self._observer_account is None or int(account) != int(self._observer_account):
                return

            if notification_id == NotificationCenter.fileLoaded:
                location = args[0] if len(args) > 0 else None
                final_file = args[1] if len(args) > 1 else None
                if not self._matches_pending_dex_file(location):
                    return

                path = None
                if final_file is not None and hasattr(final_file, "getAbsolutePath"):
                    path = str(final_file.getAbsolutePath())

                install_after_download = self._pending_install_after_download
                self._reset_pending_dex_download()
                self._detach_dex_download_observer()

                if path and os.path.exists(path) and install_after_download:
                    run_on_ui_thread(lambda path=path: self.install_dex_from_path(path, announce=True))
                else:
                    run_on_ui_thread(
                        lambda: BulletinHelper.show_error(
                            "DEX загружен, но локальный файл не найден." if self._is_russian() else "DEX downloaded, but local file was not found.",
                            get_last_fragment()
                        )
                    )

            elif notification_id == NotificationCenter.fileLoadFailed:
                location = args[0] if len(args) > 0 else None
                if not self._matches_pending_dex_file(location):
                    return

                failed_name = self._pending_dex_file_name or DEX_CACHE_FILE_NAME
                self._reset_pending_dex_download()
                self._detach_dex_download_observer()
                run_on_ui_thread(
                    lambda failed_name=failed_name: BulletinHelper.show_error(
                        f"Не удалось загрузить {failed_name}" if self._is_russian() else f"Failed to download {failed_name}",
                        get_last_fragment()
                    )
                )
        except Exception as e:
            self.log(f"DEX download notification error: {e}")
    
    def _get_config_dir(self) -> Optional[str]:
        try:
            from java import jclass
            Environment = jclass("android.os.Environment")
            downloads = Environment.getExternalStoragePublicDirectory(
                Environment.DIRECTORY_DOWNLOADS
            ).getAbsolutePath()
            config_dir = os.path.join(downloads, "TextAnimation")
            if not os.path.exists(config_dir):
                os.makedirs(config_dir)
            return config_dir
        except Exception as e:
            self.log(f"Config dir error: {e}")
            return None

    def _same_path(self, left: Optional[str], right: Optional[str]) -> bool:
        if not left or not right:
            return left == right
        return os.path.normcase(os.path.abspath(str(left))) == os.path.normcase(os.path.abspath(str(right)))

    def _get_default_config_name(self) -> str:
        prefix = "Конфиг Text Animation" if self._is_russian() else "Text Animation Config"
        return f"{prefix} {time.strftime('%Y-%m-%d %H-%M')}"

    def _sanitize_config_name(self, raw_name: Optional[str]) -> str:
        if raw_name is None:
            return ""

        cleaned = str(raw_name).replace("\r", " ").replace("\n", " ").replace("\t", " ")
        cleaned = " ".join(cleaned.split())
        cleaned = "".join(ch for ch in cleaned if ch.isprintable())
        return cleaned.strip(" .")[:64]

    def _build_config_file_stem(self, config_name: Optional[str]) -> str:
        stem = self._sanitize_config_name(config_name)
        if not stem:
            stem = self._sanitize_config_name(self._get_default_config_name())

        invalid_chars = '<>:"/\\|?*'
        stem = "".join("_" if ch in invalid_chars else ch for ch in stem)
        stem = stem.strip(" .")
        return stem or "text_animation_config"

    def _build_unique_config_filepath(
        self,
        config_dir: str,
        config_name: Optional[str],
        current_path: Optional[str] = None,
    ) -> tuple[str, str]:
        stem = self._build_config_file_stem(config_name)
        suffix = 1

        while True:
            filename_suffix = "" if suffix == 1 else f" ({suffix})"
            filename = f"{stem}{filename_suffix}{CONFIG_FILE_EXTENSION}"
            filepath = os.path.join(config_dir, filename)
            if not os.path.exists(filepath) or self._same_path(filepath, current_path):
                return filename, filepath
            suffix += 1

    def _get_config_display_name(self, config_data: Optional[dict], filename: Optional[str]) -> str:
        if isinstance(config_data, dict):
            display_name = self._sanitize_config_name(config_data.get("name"))
            if display_name:
                return display_name

        fallback = self._sanitize_config_name(os.path.splitext(str(filename or ""))[0])
        if fallback:
            return fallback

        return "Без названия" if self._is_russian() else "Untitled"

    def _write_config_file(self, filepath: str, config_data: dict) -> None:
        timestamp = int(config_data.get("timestamp") or time.time())
        display_name = self._get_config_display_name(config_data, os.path.basename(filepath))
        config_json = json.dumps(config_data, indent=2, ensure_ascii=False)
        config_b64 = base64.b64encode(config_json.encode("utf-8")).decode("utf-8")
        temp_path = f"{filepath}.tmp"

        with open(temp_path, "w", encoding="utf-8") as f:
            f.write(f"# Text Animation Config v{__version__}\n")
            f.write(f"# {display_name}\n")
            f.write(f"# {time.strftime('%Y-%m-%d %H:%M:%S', time.localtime(timestamp))}\n\n")
            f.write(config_b64)

        os.replace(temp_path, filepath)

    def _get_saved_configs(self) -> list[dict[str, Any]]:
        config_dir = self._get_config_dir()
        if not config_dir or not os.path.exists(config_dir):
            return []

        configs = []
        for filename in os.listdir(config_dir):
            if not self._is_config_file_name(filename):
                continue

            filepath = os.path.join(config_dir, filename)
            if not os.path.isfile(filepath):
                continue

            config_data = self._load_config_from_file(filepath)
            if not isinstance(config_data, dict):
                continue

            display_name = self._get_config_display_name(config_data, filename)
            filename_stem = self._sanitize_config_name(os.path.splitext(filename)[0])
            list_title = display_name if display_name == filename_stem else f"{display_name} ({filename})"

            try:
                sort_ts = int(config_data.get("timestamp") or 0)
            except Exception:
                sort_ts = 0

            if sort_ts <= 0:
                try:
                    sort_ts = int(os.path.getmtime(filepath))
                except Exception:
                    sort_ts = 0

            configs.append({
                "config": config_data,
                "display_name": display_name,
                "filename": filename,
                "filepath": filepath,
                "list_title": list_title,
                "sort_ts": sort_ts,
            })

        configs.sort(key=lambda item: (item["sort_ts"], item["filename"].lower()), reverse=True)
        return configs

    def _get_current_activity(self):
        fragment = get_last_fragment()
        if not fragment:
            return None

        try:
            return fragment.getParentActivity()
        except Exception:
            return None

    def _format_config_timestamp(self, timestamp_value: Any) -> str:
        try:
            timestamp = int(timestamp_value or 0)
        except Exception:
            timestamp = 0

        if timestamp <= 0:
            return "Неизвестно" if self._is_russian() else "Unknown"

        return time.strftime("%d.%m.%Y", time.localtime(timestamp))

    def _get_config_meta_text(self, config_data: Optional[dict], filename: Optional[str]) -> str:
        config = config_data if isinstance(config_data, dict) else {}
        plugin_ver = str(config.get("plugin_version") or ("Неизвестно" if self._is_russian() else "Unknown"))

        parts = []
        file_part = str(filename or "").strip()
        if file_part:
            parts.append(file_part)
        parts.append(f"v{plugin_ver}")
        parts.append(self._format_config_timestamp(config.get("timestamp")))
        return " • ".join(parts)

    def _get_manage_config_meta_text(self, config_entry: dict[str, Any]) -> str:
        filename = str(config_entry.get("filename") or "").strip()
        date_text = self._format_config_timestamp(config_entry.get("sort_ts"))
        return " • ".join([part for part in (filename, date_text) if part])

    def _create_sheet_button(
        self,
        activity,
        text: str,
        background_color: int,
        text_color: int,
        on_click: Callable,
        text_size_sp: int = 15,
    ):
        from android_utils import OnClickListener
        from java import jclass

        FrameLayout = jclass("android.widget.FrameLayout")
        TextView = jclass("android.widget.TextView")
        TypedValue = jclass("android.util.TypedValue")
        Gravity = jclass("android.view.Gravity")
        GradientDrawable = jclass("android.graphics.drawable.GradientDrawable")
        AndroidUtilities = jclass("org.telegram.messenger.AndroidUtilities")
        LayoutHelper = jclass("org.telegram.ui.Components.LayoutHelper")

        frame = FrameLayout(activity)
        background = GradientDrawable()
        background.setCornerRadius(AndroidUtilities.dp(10))
        background.setColor(background_color)
        frame.setBackground(background)

        label = TextView(activity)
        label.setText(text)
        label.setTextSize(TypedValue.COMPLEX_UNIT_DIP, text_size_sp)
        label.setTypeface(AndroidUtilities.bold())
        label.setTextColor(text_color)
        label.setGravity(Gravity.CENTER)

        frame.addView(label, LayoutHelper.createFrame(-1, -1))
        frame.setOnClickListener(OnClickListener(on_click))
        return frame, label, background

    def _apply_config_with_feedback(
        self,
        config_data: Optional[dict],
        display_name: Optional[str] = None,
    ) -> bool:
        is_ru = self._is_russian()

        if not isinstance(config_data, dict):
            BulletinHelper.show_error("Не удалось прочитать конфиг" if is_ru else "Failed to read config")
            return False

        if self._import_config(config_data):
            if self.dex_loader:
                self._sync_settings_to_dex()

            if display_name:
                BulletinHelper.show_success(
                    f'Применён "{display_name}"' if is_ru else f'Applied "{display_name}"'
                )
            else:
                BulletinHelper.show_success("Настройки применены" if is_ru else "Settings applied")
            return True

        BulletinHelper.show_error("Ошибка применения" if is_ru else "Error applying")
        return False

    def _rename_saved_config_entry(self, config_entry: dict[str, Any], raw_name: str) -> bool:
        is_ru = self._is_russian()
        config_name = self._sanitize_config_name(raw_name)
        if not config_name:
            BulletinHelper.show_error("Введите имя конфига" if is_ru else "Enter config name")
            return False

        filepath = str(config_entry.get("filepath") or "")
        if not filepath or not os.path.exists(filepath):
            BulletinHelper.show_error("Файл конфига не найден" if is_ru else "Config file not found")
            return False

        config_data = self._load_config_from_file(filepath)
        if not isinstance(config_data, dict):
            BulletinHelper.show_error("Не удалось прочитать конфиг" if is_ru else "Failed to read config")
            return False

        try:
            config_data["name"] = config_name
            filename, target_path = self._build_unique_config_filepath(os.path.dirname(filepath), config_name, filepath)
            self._write_config_file(filepath, config_data)
            if not self._same_path(target_path, filepath):
                os.replace(filepath, target_path)

            BulletinHelper.show_success(
                f"Конфиг переименован: {filename}" if is_ru else f"Config renamed: {filename}"
            )
            return True
        except Exception as e:
            self.log(f"Rename config error: {e}")
            BulletinHelper.show_error(
                f"Не удалось переименовать конфиг: {e}" if is_ru else f"Failed to rename config: {e}"
            )
            return False

    def _delete_saved_config_entry(self, config_entry: dict[str, Any]) -> bool:
        is_ru = self._is_russian()
        filepath = str(config_entry.get("filepath") or "")

        try:
            if not filepath or not os.path.exists(filepath):
                BulletinHelper.show_error("Файл конфига не найден" if is_ru else "Config file not found")
                return False

            os.remove(filepath)
            BulletinHelper.show_success("Конфиг удалён" if is_ru else "Config deleted")
            return True
        except Exception as e:
            self.log(f"Delete config error: {e}")
            BulletinHelper.show_error(
                f"Не удалось удалить конфиг: {e}" if is_ru else f"Failed to delete config: {e}"
            )
            return False

    def _reopen_saved_configs_sheet(self, mode: Optional[str], delay: int = 120) -> None:
        if not mode or not self._get_saved_configs():
            return

        def reopen(current_mode=mode):
            configs = self._get_saved_configs()
            if not configs:
                return
            if current_mode == "manage":
                self._show_manage_configs_popup_sheet(configs)
            else:
                self._show_saved_configs_sheet(current_mode)

        run_on_ui_thread(reopen, delay=delay)

    def _show_saved_config_actions_popup(self, anchor_view, config_entry: dict[str, Any], parent_sheet=None) -> None:
        from android_utils import OnClickListener
        from java import jclass

        is_ru = self._is_russian()

        try:
            if anchor_view is None:
                return

            context = anchor_view.getContext()
            if context is None:
                return

            ActionBarPopupWindow = jclass("org.telegram.ui.ActionBar.ActionBarPopupWindow")
            ActionBarPopupLayout = jclass("org.telegram.ui.ActionBar.ActionBarPopupWindow$ActionBarPopupWindowLayout")
            Theme = jclass("org.telegram.ui.ActionBar.Theme")
            LayoutHelper = jclass("org.telegram.ui.Components.LayoutHelper")
            AndroidUtilities = jclass("org.telegram.messenger.AndroidUtilities")
            TelegramR = jclass("org.telegram.messenger.R")
            View = jclass("android.view.View")
            Gravity = jclass("android.view.Gravity")
            FrameLayout = jclass("android.widget.FrameLayout")
            LinearLayout = jclass("android.widget.LinearLayout")
            TextView = jclass("android.widget.TextView")
            ImageView = jclass("android.widget.ImageView")
            TypedValue = jclass("android.util.TypedValue")
            PorterDuff = jclass("android.graphics.PorterDuff")
            ContextCompat = jclass("androidx.core.content.ContextCompat")

            popup_layout = ActionBarPopupLayout(context)
            popup_layout.setBackgroundColor(Theme.getColor(Theme.key_actionBarDefaultSubmenuBackground))
            try:
                popup_layout.setFitItems(True)
            except Exception:
                pass

            popup_ref = {"window": None}

            def close_popup():
                popup = popup_ref.get("window")
                if popup is not None:
                    try:
                        popup.dismiss()
                    except Exception:
                        pass

            def open_rename():
                run_on_ui_thread(
                    lambda entry=config_entry, current_sheet=parent_sheet: self._show_rename_config_sheet(entry, "manage", current_sheet),
                    delay=120
                )

            def open_delete():
                run_on_ui_thread(
                    lambda entry=config_entry, current_sheet=parent_sheet: self._show_delete_config_confirmation(entry, "manage", current_sheet),
                    delay=120
                )

            def add_menu_item(icon_res: int, text: str, callback: Callable[[], None], destructive: bool = False):
                item_frame = FrameLayout(context)
                item_frame.setMinimumWidth(AndroidUtilities.dp(196))
                item_frame.setClickable(True)
                item_frame.setFocusable(True)
                item_frame.setBackground(
                    Theme.createSelectorDrawable(Theme.getColor(Theme.key_listSelector), 2)
                )

                content = LinearLayout(context)
                content.setOrientation(LinearLayout.HORIZONTAL)
                content.setGravity(Gravity.CENTER_VERTICAL)
                content.setPadding(
                    AndroidUtilities.dp(16),
                    AndroidUtilities.dp(12),
                    AndroidUtilities.dp(16),
                    AndroidUtilities.dp(12)
                )

                text_color = Theme.getColor(
                    Theme.key_text_RedRegular if destructive else Theme.key_actionBarDefaultSubmenuItem
                )

                icon_view = ImageView(context)
                icon_view.setScaleType(ImageView.ScaleType.CENTER)
                try:
                    icon_drawable = ContextCompat.getDrawable(context, icon_res)
                    icon_drawable.setColorFilter(text_color, PorterDuff.Mode.SRC_IN)
                    icon_view.setImageDrawable(icon_drawable)
                except Exception:
                    icon_view.setImageResource(icon_res)
                content.addView(icon_view, LayoutHelper.createLinear(24, 24, Gravity.CENTER_VERTICAL, 0, 0, 12, 0))

                title_view = TextView(context)
                title_view.setText(text)
                title_view.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
                title_view.setTextColor(text_color)
                content.addView(title_view, LayoutHelper.createLinear(-1, -2, 1.0, Gravity.CENTER_VERTICAL))

                item_frame.addView(content)

                def on_click(_v):
                    close_popup()
                    callback()

                item_frame.setOnClickListener(OnClickListener(on_click))
                popup_layout.addView(item_frame, LayoutHelper.createLinear(-1, -2))

            add_menu_item(TelegramR.drawable.msg_edit, "Переименовать" if is_ru else "Rename", open_rename)
            add_menu_item(TelegramR.drawable.msg_delete, "Удалить" if is_ru else "Delete", open_delete, True)

            popup_window = ActionBarPopupWindow(popup_layout, -2, -2)
            popup_ref["window"] = popup_window

            popup_window.setOutsideTouchable(True)
            popup_window.setClippingEnabled(True)
            popup_window.setFocusable(True)
            try:
                popup_window.setAnimationStyle(TelegramR.style.PopupContextAnimation)
            except Exception:
                pass

            popup_layout.measure(
                View.MeasureSpec.makeMeasureSpec(AndroidUtilities.dp(1000), View.MeasureSpec.AT_MOST),
                View.MeasureSpec.makeMeasureSpec(AndroidUtilities.dp(1000), View.MeasureSpec.AT_MOST)
            )

            location = [0, 0]
            anchor_view.getLocationInWindow(location)

            popup_x = location[0] + anchor_view.getWidth() - popup_layout.getMeasuredWidth()
            popup_y = location[1] - popup_layout.getMeasuredHeight()
            if popup_y < 0:
                popup_y = location[1] + anchor_view.getHeight()

            popup_window.showAtLocation(
                anchor_view,
                Gravity.TOP | Gravity.LEFT,
                max(0, popup_x),
                max(0, popup_y)
            )
        except Exception as e:
            self.log(f"Config actions popup error: {e}")
            BulletinHelper.show_error(f"Ошибка: {e}" if is_ru else f"Error: {e}")

    def _show_manage_configs_popup_sheet(self, configs: list[dict[str, Any]]) -> None:
        from android_utils import OnClickListener
        from java import jclass

        is_ru = self._is_russian()

        try:
            activity = self._get_current_activity()
            if not activity:
                return

            BottomSheet = jclass("org.telegram.ui.ActionBar.BottomSheet")
            LinearLayout = jclass("android.widget.LinearLayout")
            TextView = jclass("android.widget.TextView")
            ImageView = jclass("android.widget.ImageView")
            FrameLayout = jclass("android.widget.FrameLayout")
            ScrollView = jclass("android.widget.ScrollView")
            TypedValue = jclass("android.util.TypedValue")
            Gravity = jclass("android.view.Gravity")
            Theme = jclass("org.telegram.ui.ActionBar.Theme")
            AndroidUtilities = jclass("org.telegram.messenger.AndroidUtilities")
            GradientDrawable = jclass("android.graphics.drawable.GradientDrawable")
            LayoutHelper = jclass("org.telegram.ui.Components.LayoutHelper")
            R = jclass("org.telegram.messenger.R")

            sheet = BottomSheet(activity, False)
            try:
                sheet.fixNavigationBar(Theme.getColor(Theme.key_dialogBackground))
            except Exception:
                pass

            container = LinearLayout(activity)
            container.setOrientation(LinearLayout.VERTICAL)
            container.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(20), AndroidUtilities.dp(16), AndroidUtilities.dp(16))

            header_layout = LinearLayout(activity)
            header_layout.setOrientation(LinearLayout.HORIZONTAL)
            header_layout.setGravity(Gravity.CENTER_VERTICAL)

            icon_bg = GradientDrawable()
            icon_bg.setShape(GradientDrawable.OVAL)
            icon_bg.setColor(Theme.getColor(Theme.key_featuredStickers_addButton) & 0x15FFFFFF | 0x10000000)

            icon_view = ImageView(activity)
            icon_view.setImageResource(R.drawable.files_folder)
            icon_view.setColorFilter(Theme.getColor(Theme.key_featuredStickers_addButton))
            icon_view.setBackground(icon_bg)
            icon_view.setPadding(AndroidUtilities.dp(10), AndroidUtilities.dp(10), AndroidUtilities.dp(10), AndroidUtilities.dp(10))
            header_layout.addView(icon_view, LayoutHelper.createLinear(48, 48, 0, 0, 14, 0))

            title_layout = LinearLayout(activity)
            title_layout.setOrientation(LinearLayout.VERTICAL)

            title_view = TextView(activity)
            title_view.setText("Сохранённые конфиги" if is_ru else "Saved Configs")
            title_view.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 20)
            title_view.setTypeface(AndroidUtilities.bold())
            title_view.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
            title_layout.addView(title_view)

            subtitle_view = TextView(activity)
            subtitle_view.setText(
                "Нажмите на конфиг, чтобы открыть действия"
                if is_ru else
                "Tap a config to open its actions"
            )
            subtitle_view.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
            subtitle_view.setTextColor(Theme.getColor(Theme.key_dialogTextGray2))
            title_layout.addView(subtitle_view)

            header_layout.addView(title_layout, LayoutHelper.createLinear(0, -2, 1.0))
            container.addView(header_layout, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 0, 16))

            scroll = ScrollView(activity)
            scroll_height = min(360, max(176, len(configs) * 74))

            list_container = LinearLayout(activity)
            list_container.setOrientation(LinearLayout.VERTICAL)

            list_bg = GradientDrawable()
            list_bg.setCornerRadius(AndroidUtilities.dp(16))
            list_bg.setColor(Theme.getColor(Theme.key_windowBackgroundWhite))
            try:
                list_bg.setStroke(AndroidUtilities.dp(1), Theme.getColor(Theme.key_divider))
            except Exception:
                pass
            list_container.setBackground(list_bg)

            divider_color = Theme.getColor(Theme.key_divider)

            for index, config_entry in enumerate(configs):
                row = FrameLayout(activity)
                row.setClickable(True)
                row.setFocusable(True)
                try:
                    row.setBackground(Theme.createSelectorDrawable(Theme.getColor(Theme.key_listSelector), 6))
                except Exception:
                    pass

                row_layout = LinearLayout(activity)
                row_layout.setOrientation(LinearLayout.HORIZONTAL)
                row_layout.setGravity(Gravity.CENTER_VERTICAL)
                row_layout.setPadding(
                    AndroidUtilities.dp(16),
                    AndroidUtilities.dp(14),
                    AndroidUtilities.dp(16),
                    AndroidUtilities.dp(14)
                )

                text_layout = LinearLayout(activity)
                text_layout.setOrientation(LinearLayout.VERTICAL)

                name_view = TextView(activity)
                name_view.setText(config_entry["display_name"])
                name_view.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
                name_view.setTypeface(AndroidUtilities.bold())
                name_view.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
                text_layout.addView(name_view)

                meta_view = TextView(activity)
                meta_view.setText(self._get_manage_config_meta_text(config_entry))
                meta_view.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
                meta_view.setTextColor(Theme.getColor(Theme.key_dialogTextGray2))
                text_layout.addView(meta_view, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 0, 2))

                row_layout.addView(text_layout, LayoutHelper.createLinear(0, -2, 1.0))

                action_view = ImageView(activity)
                action_view.setImageResource(R.drawable.msg_actions)
                action_view.setColorFilter(Theme.getColor(Theme.key_dialogTextGray2))
                row_layout.addView(action_view, LayoutHelper.createLinear(22, 22, 0, 12, 0, 0, 0))

                row.addView(row_layout, LayoutHelper.createFrame(-1, -2))

                def on_row_click(_v, anchor=row, entry=config_entry, current_sheet=sheet):
                    self._show_saved_config_actions_popup(anchor, entry, current_sheet)

                row.setOnClickListener(OnClickListener(on_row_click))
                action_view.setOnClickListener(OnClickListener(on_row_click))
                list_container.addView(row, LayoutHelper.createLinear(-1, -2))

                if index < len(configs) - 1:
                    divider = FrameLayout(activity)
                    divider.setBackgroundColor(divider_color)
                    list_container.addView(divider, LayoutHelper.createLinear(-1, 1, 0, 16, 0, 16, 0))

            scroll.addView(list_container)
            container.addView(scroll, LayoutHelper.createLinear(-1, scroll_height, 0, 0, 0, 0, 16))

            close_button, _, _ = self._create_sheet_button(
                activity,
                "Закрыть" if is_ru else "Close",
                Theme.getColor(Theme.key_listSelector),
                Theme.getColor(Theme.key_featuredStickers_addButton),
                lambda v: sheet.dismiss(),
            )
            container.addView(close_button, LayoutHelper.createLinear(-1, 48))

            sheet.setCustomView(container)
            sheet.show()
        except Exception as e:
            self.log(f"Manage configs popup sheet error: {e}")
            BulletinHelper.show_error(f"Ошибка: {e}" if is_ru else f"Error: {e}")

    def _show_config_name_sheet(
        self,
        title: str,
        hint: str,
        initial_value: str,
        positive_text: str,
        on_submit: Callable[[str], bool],
    ) -> None:
        from java import jclass

        try:
            activity = self._get_current_activity()
            if not activity:
                return

            is_ru = self._is_russian()

            BottomSheet = jclass("org.telegram.ui.ActionBar.BottomSheet")
            LinearLayout = jclass("android.widget.LinearLayout")
            TextView = jclass("android.widget.TextView")
            FrameLayout = jclass("android.widget.FrameLayout")
            TypedValue = jclass("android.util.TypedValue")
            Gravity = jclass("android.view.Gravity")
            Theme = jclass("org.telegram.ui.ActionBar.Theme")
            AndroidUtilities = jclass("org.telegram.messenger.AndroidUtilities")
            GradientDrawable = jclass("android.graphics.drawable.GradientDrawable")
            LayoutHelper = jclass("org.telegram.ui.Components.LayoutHelper")
            EditTextBoldCursor = jclass("org.telegram.ui.Components.EditTextBoldCursor")
            ColorDrawable = jclass("android.graphics.drawable.ColorDrawable")
            ColorStateList = jclass("android.content.res.ColorStateList")
            Color = jclass("android.graphics.Color")
            InputType = jclass("android.text.InputType")

            sheet = BottomSheet(activity, True)
            try:
                sheet.fixNavigationBar(Theme.getColor(Theme.key_dialogBackground))
            except Exception:
                pass

            container = LinearLayout(activity)
            container.setOrientation(LinearLayout.VERTICAL)
            container.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(20), AndroidUtilities.dp(16), AndroidUtilities.dp(16))

            title_view = TextView(activity)
            title_view.setText(title)
            title_view.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 20)
            title_view.setTypeface(AndroidUtilities.bold())
            title_view.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
            container.addView(title_view, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 0, 6))

            subtitle_view = TextView(activity)
            subtitle_view.setText(
                "Имя будет показано в списке и сохранено в .animtext"
                if is_ru else
                "The name is shown in the list and stored in the .animtext file"
            )
            subtitle_view.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
            subtitle_view.setTextColor(Theme.getColor(Theme.key_dialogTextGray2))
            container.addView(subtitle_view, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 0, 16))

            input_frame = FrameLayout(activity)
            input_bg = GradientDrawable()
            input_bg.setCornerRadius(AndroidUtilities.dp(14))
            input_bg.setColor(Theme.getColor(Theme.key_listSelector))
            input_frame.setBackground(input_bg)

            edit_text = EditTextBoldCursor(activity)
            edit_text.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 17)
            edit_text.setTextColor(Theme.getColor(Theme.key_dialogTextBlack))
            edit_text.setHintTextColor(Theme.getColor(Theme.key_dialogTextHint))
            edit_text.setPadding(
                AndroidUtilities.dp(16),
                AndroidUtilities.dp(14),
                AndroidUtilities.dp(16),
                AndroidUtilities.dp(14)
            )
            edit_text.setGravity(Gravity.CENTER_VERTICAL)
            edit_text.setInputType(int(InputType.TYPE_CLASS_TEXT | InputType.TYPE_TEXT_FLAG_CAP_SENTENCES))
            edit_text.setSingleLine(True)
            edit_text.setMaxLines(1)
            edit_text.setHint(hint)
            try:
                edit_text.setLineColors(
                    Theme.getColor(Theme.key_dialogInputField),
                    Theme.getColor(Theme.key_dialogInputFieldActivated),
                    Theme.getColor(Theme.key_text_RedBold),
                )
            except Exception:
                pass
            try:
                edit_text.setBackground(ColorDrawable(0))
            except Exception:
                pass
            try:
                edit_text.setBackgroundTintList(ColorStateList.valueOf(Color.TRANSPARENT))
            except Exception:
                pass
            try:
                if hasattr(edit_text, "setCursorColor"):
                    edit_text.setCursorColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
            except Exception:
                pass
            try:
                edit_text.setBackgroundDrawable(None)
            except Exception:
                pass

            initial_text = str(initial_value or "")
            if initial_text:
                edit_text.setText(initial_text)
                try:
                    edit_text.setSelection(len(initial_text))
                except Exception:
                    pass

            input_frame.addView(edit_text, LayoutHelper.createFrame(-1, -2))
            container.addView(input_frame, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 0, 20))

            buttons_layout = LinearLayout(activity)
            buttons_layout.setOrientation(LinearLayout.HORIZONTAL)

            cancel_button, _, _ = self._create_sheet_button(
                activity,
                "Отмена" if is_ru else "Cancel",
                Theme.getColor(Theme.key_listSelector),
                Theme.getColor(Theme.key_featuredStickers_addButton),
                lambda v: sheet.dismiss(),
            )
            buttons_layout.addView(cancel_button, LayoutHelper.createLinear(0, 48, 1.0, 0, 0, 8, 0))

            def on_save(v):
                try:
                    value = str(edit_text.getText().toString())
                except Exception:
                    value = str(edit_text.getText() or "")

                if on_submit(value):
                    sheet.dismiss()

            save_button, _, _ = self._create_sheet_button(
                activity,
                positive_text,
                Theme.getColor(Theme.key_featuredStickers_addButton),
                -1,
                on_save,
            )
            buttons_layout.addView(save_button, LayoutHelper.createLinear(0, 48, 1.0, 8, 0, 0, 0))

            container.addView(buttons_layout, LayoutHelper.createLinear(-1, -2))

            sheet.setCustomView(container)
            sheet.show()

            def setup_focus():
                try:
                    edit_text.requestFocus()
                    if initial_text:
                        edit_text.setSelection(len(initial_text))
                except Exception:
                    pass

            run_on_ui_thread(setup_focus, delay=180)
        except Exception as e:
            self.log(f"Config name sheet error: {e}")
            BulletinHelper.show_error(f"Ошибка: {e}" if self._is_russian() else f"Error: {e}")

    def _show_saved_configs_sheet(self, mode: str = "manage") -> None:
        from android_utils import OnClickListener
        from java import jclass

        is_ru = self._is_russian()

        try:
