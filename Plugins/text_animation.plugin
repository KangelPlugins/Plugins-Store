CONFIG_KEYS = list(CONFIG_DEFAULTS.keys())

_Integer = None


def java_integer():
    global _Integer
    if _Integer is None:
        _Integer = jclass("java.lang.Integer")
    return _Integer


def as_java_color(color: int) -> int:
    color = int(color) & 0xFFFFFFFF
    if color >= 0x80000000:
        color -= 0x100000000
    return int(color)


def call_int(target, method_name: str, value: int):
    try:
        method = target.getClass().getMethod(method_name, java_integer().TYPE)
        return method.invoke(target, java_integer()(int(value)))
    except Exception:
        return getattr(target, method_name)(int(value))


def call_int_color(target, method_name: str, color: int):
    return call_int(target, method_name, as_java_color(color))


def set_drawable_color(drawable, color: int):
    try:
        return call_int_color(drawable, "setColor", color)
    except Exception:
        try:
            ColorStateList = jclass("android.content.res.ColorStateList")
            return drawable.setColor(ColorStateList.valueOf(java_integer()(as_java_color(color))))
        except Exception:
            return drawable.setColor(as_java_color(color))


def set_paint_color(paint, color: int):
    color = int(color) & 0xFFFFFFFF
    paint.setARGB(
        int((color >> 24) & 0xFF),
        int((color >> 16) & 0xFF),
        int((color >> 8) & 0xFF),
        int(color & 0xFF),
    )


class DexDownloadDelegate(dynamic_proxy(NotificationCenter.NotificationCenterDelegate)):
    def __init__(self, plugin):
        super().__init__()
        self._plugin_ref = weakref.ref(plugin)

    def didReceivedNotification(self, notification_id, account, *args):
        plugin = self._plugin_ref()
        if plugin is not None:
            plugin._on_download_notification(notification_id, account, *args)


class DexOpenHook(MethodHook):
    def __init__(self, plugin):
        super().__init__()
        self._plugin_ref = weakref.ref(plugin)

    def before_hooked_method(self, param):
        plugin = self._plugin_ref()
        if plugin is None:
            return

        try:
            if not param.args:
                return

            message = param.args[0]
            if not plugin._is_supported_dex_message(message):
                return

            if "openForView" in param.method.getName():
                param.setResult(True)
            else:
                param.setResult(None)

            path = plugin._resolve_message_file_path(message)
            file_name = plugin._get_message_file_name(message) or DEX_INSTALL_FILE_NAME
            if path and os.path.exists(path):
                run_on_ui_thread(lambda path=path, file_name=file_name: plugin.install_dex_from_path(path, file_name))
            else:
                run_on_ui_thread(lambda message=message, file_name=file_name: plugin.download_dex_from_message(message, file_name))
        except Exception as error:
            plugin._log(f"Ошибка перехвата DEX: {error}")


class DexLocalFileOpenHook(MethodHook):
    def __init__(self, plugin):
        super().__init__()
        self._plugin_ref = weakref.ref(plugin)

    def before_hooked_method(self, param):
        plugin = self._plugin_ref()
        if plugin is None:
            return

        try:
            if not param.args or len(param.args) < 2:
                return

            file_obj = param.args[0]
            file_name = str(param.args[1] or "")
            if not file_name and file_obj is not None and hasattr(file_obj, "getName"):
                try:
                    file_name = str(file_obj.getName())
                except Exception:
                    file_name = ""
            if not plugin._is_dex_file_name(file_name):
                return

            path = None
            try:
                if file_obj is not None and hasattr(file_obj, "getAbsolutePath"):
                    path = str(file_obj.getAbsolutePath())
            except Exception:
                path = None

            if not path or not os.path.exists(path):
                return

            param.setResult(True)
            run_on_ui_thread(lambda path=path, file_name=file_name: plugin.install_dex_from_path(path, file_name))
        except Exception as error:
            plugin._log(f"Local DEX open hook error: {error}")


class DexLoader:
    def __init__(self, plugin: BasePlugin):
        self.plugin = plugin
        self.dex_class = None
        self.dex_loader = None
        self._lock = threading.RLock()
        self.cache_dir = os.path.join(
            ApplicationLoader.applicationContext.getFilesDir().getAbsolutePath(),
            DEX_CACHE_DIR,
        )
        self.cache_file = os.path.join(self.cache_dir, DEX_CACHE_FILE_NAME)
        os.makedirs(self.cache_dir, exist_ok=True)

    def is_loaded(self) -> bool:
        return self.dex_class is not None

    def has_cache(self) -> bool:
        try:
            return os.path.exists(self.cache_file)
        except Exception:
            return False

    def load_from_cache(self) -> Optional[bytes]:
        try:
            if os.path.exists(self.cache_file):
                with open(self.cache_file, "rb") as file_obj:
                    return file_obj.read()
        except Exception as error:
            self.plugin._log(f"Ошибка чтения DEX cache: {error}")
        return None

    def install_from_path(self, path: str) -> None:
        with open(path, "rb") as file_obj:
            self.install_from_bytes(file_obj.read())

    def install_from_bytes(self, dex_bytes: bytes) -> None:
        with self._lock:
            self.unload()
            with open(self.cache_file, "wb") as file_obj:
                file_obj.write(dex_bytes)
            try:
                self._start_from_bytes_locked(dex_bytes)
            except Exception:
                try:
                    if os.path.exists(self.cache_file):
                        os.remove(self.cache_file)
                except Exception:
                    pass
                raise

    def start_from_bytes(self, dex_bytes: bytes) -> None:
        with self._lock:
            self.unload()
            self._start_from_bytes_locked(dex_bytes)

    def _start_from_bytes_locked(self, dex_bytes: bytes) -> None:
        self.dex_loader = InMemoryDexClassLoader(
            ByteBuffer.wrap(dex_bytes),
            ApplicationLoader.applicationContext.getClassLoader(),
        )
        self.dex_class = self.dex_loader.loadClass(DEX_CLASS_NAME)
        self._invoke_void("start")

    def _invoke(self, method_name: str, *args):
        if self.dex_class is None:
            raise RuntimeError("DEX не загружен")
        if args:
            if len(args) != 1 or not isinstance(args[0], str):
                raise TypeError(f"Неподдерживаемые аргументы bridge-метода {method_name}")
            method = self.dex_class.getMethod(method_name, jclass("java.lang.String"))
            return method.invoke(None, args[0])
        method = self.dex_class.getMethod(method_name)
        return method.invoke(None)

    def _invoke_void(self, method_name: str, *args) -> None:
        self._invoke(method_name, *args)

    def update_settings(self, settings: dict[str, Any]) -> None:
        with self._lock:
            if self.dex_class is None:
                return
            self._invoke_void("updateSettings", json.dumps(settings, ensure_ascii=False))

    def unload(self) -> None:
        with self._lock:
            if self.dex_class is None:
                return
            try:
                self._invoke_void("unload")
            finally:
                self.dex_class = None
                self.dex_loader = None

    def delete_cache(self) -> bool:
        with self._lock:
            self.unload()
            if not self.has_cache():
                return False
            os.remove(self.cache_file)
            return True


class DexInstallerSheet:
    def __init__(self, plugin, file_name: str):
        self.plugin = plugin
        self.file_name = file_name or DEX_INSTALL_FILE_NAME
        self.sheet = None
        self.progress = None
        self.title = None
        self.subtitle = None
        self.icon = None
        self.icon_wrap = None
        self.icon_bg = None
        self.button = None
        self.status_left = None
        self.status_right = None
        self._button_click_delegate = None

        self.context = plugin._get_active_context()
        if self.context is None:
            return

        self.resources_provider = plugin._get_resources_provider()
        self._build()

    def _color(self, key, fallback: int = 0xFFFFFFFF) -> int:
        try:
            Theme = jclass("org.telegram.ui.ActionBar.Theme")
            if self.resources_provider is not None:
                return as_java_color(Theme.getColor(key, self.resources_provider))
            return as_java_color(Theme.getColor(key))
        except Exception:
            return as_java_color(fallback)

    def _build(self):
        BottomSheet = jclass("org.telegram.ui.ActionBar.BottomSheet")
        Theme = jclass("org.telegram.ui.ActionBar.Theme")
        AndroidUtilities = jclass("org.telegram.messenger.AndroidUtilities")
        LayoutHelper = jclass("org.telegram.ui.Components.LayoutHelper")
        LineProgressView = jclass("org.telegram.ui.Components.LineProgressView")
        ButtonWithCounterView = jclass("org.telegram.ui.Stories.recorder.ButtonWithCounterView")
        R = jclass("org.telegram.messenger.R")
        LinearLayout = jclass("android.widget.LinearLayout")
        FrameLayout = jclass("android.widget.FrameLayout")
        TextView = jclass("android.widget.TextView")
        ImageView = jclass("android.widget.ImageView")
        GradientDrawable = jclass("android.graphics.drawable.GradientDrawable")
        TypedValue = jclass("android.util.TypedValue")
        Gravity = jclass("android.view.Gravity")

        try:
            self.sheet = BottomSheet(self.context, False, self.resources_provider)
        except Exception:
            self.sheet = BottomSheet(self.context, False)

        bg_color = self._color(Theme.key_dialogBackground, 0xFFFFFFFF)
        call_int_color(self.sheet, "fixNavigationBar", bg_color)

        root = LinearLayout(self.context)
        root.setOrientation(LinearLayout.VERTICAL)
        root.setPadding(AndroidUtilities.dp(22), AndroidUtilities.dp(9), AndroidUtilities.dp(22), AndroidUtilities.dp(18))

        handle = FrameLayout(self.context)
        handle_bg = GradientDrawable()
        handle_bg.setCornerRadius(float(AndroidUtilities.dp(2)))
        set_drawable_color(handle_bg, self.plugin._alpha(self._color(Theme.key_dialogTextGray3, 0xFF777777), 0.24))
        handle.setBackground(handle_bg)
        root.addView(handle, LayoutHelper.createLinear(36, 4, Gravity.CENTER_HORIZONTAL, 0, 0, 0, 18))

        hero = LinearLayout(self.context)
        hero.setOrientation(LinearLayout.HORIZONTAL)
        hero.setGravity(Gravity.CENTER_VERTICAL)

        self.icon_wrap = FrameLayout(self.context)
        self.icon_bg = GradientDrawable()
        self.icon_bg.setShape(GradientDrawable.OVAL)
        set_drawable_color(self.icon_bg, self.plugin._alpha(self._color(Theme.key_featuredStickers_addButton), 0.14))
        self.icon_wrap.setBackground(self.icon_bg)

        self.icon = ImageView(self.context)
        self.icon.setImageResource(R.drawable.msg_download)
        call_int_color(self.icon, "setColorFilter", self._color(Theme.key_featuredStickers_addButton))
        self.icon_wrap.addView(self.icon, FrameLayout.LayoutParams(AndroidUtilities.dp(24), AndroidUtilities.dp(24), Gravity.CENTER))
        hero.addView(self.icon_wrap, LayoutHelper.createLinear(54, 54))

        text_col = LinearLayout(self.context)
        text_col.setOrientation(LinearLayout.VERTICAL)

        self.title = TextView(self.context)
        self.title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 20)
        self.title.setTypeface(AndroidUtilities.bold())
        call_int_color(self.title, "setTextColor", self._color(Theme.key_dialogTextBlack, 0xFF000000))
        text_col.addView(self.title)

        self.subtitle = TextView(self.context)
        self.subtitle.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
        self.subtitle.setLineSpacing(AndroidUtilities.dp(2), 1.0)
        call_int_color(self.subtitle, "setTextColor", self._color(Theme.key_dialogTextGray3, 0xFF777777))
        text_col.addView(self.subtitle, LayoutHelper.createLinear(-1, -2, 0, 0, 0, 0, 2))

        hero.addView(text_col, LayoutHelper.createLinear(0, -2, 1.0, 15, 0, 0, 0))
        root.addView(hero)

        self.progress = LineProgressView(self.context)
        call_int_color(self.progress, "setProgressColor", self._color(Theme.key_featuredStickers_addButton))
        try:
            call_int_color(self.progress, "setBackColor", self._color(Theme.key_dialogLineProgressBackground, 0xFFE0E0E0))
        except Exception:
            pass
        root.addView(self.progress, LayoutHelper.createLinear(-1, 4, 0, 0, 22, 0, 0))

        status_row = LinearLayout(self.context)
        status_row.setOrientation(LinearLayout.HORIZONTAL)
        status_row.setGravity(Gravity.CENTER_VERTICAL)

        self.status_left = TextView(self.context)
        self.status_left.setSingleLine(True)
        self.status_left.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
        call_int_color(self.status_left, "setTextColor", self._color(Theme.key_dialogTextGray3, 0xFF777777))
        status_row.addView(self.status_left, LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0))

        self.status_right = TextView(self.context)
        self.status_right.setSingleLine(True)
        self.status_right.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
        self.status_right.setGravity(Gravity.RIGHT)
        call_int_color(self.status_right, "setTextColor", self._color(Theme.key_dialogTextGray3, 0xFF777777))
        status_row.addView(self.status_right, LayoutHelper.createLinear(-2, -2))
        root.addView(status_row, LayoutHelper.createLinear(-1, -2, 0, 8, 0, 0))

        self.button = ButtonWithCounterView(self.context, True, self.resources_provider)
        try:
            self.button.setRound()
        except Exception:
            pass

        click_cls = jclass("android.view.View$OnClickListener")

        class _CloseClick(dynamic_proxy(click_cls)):
            def onClick(_self, _view):
                if self.sheet is not None:
                    self.sheet.dismiss()

        self._button_click_delegate = _CloseClick()
        self.button.setOnClickListener(self._button_click_delegate)
        root.addView(self.button, LayoutHelper.createLinear(-1, 48, 0, 18, 0, 0))

        self.sheet.setCustomView(root)
        try:
            self.sheet.setCanDismissWithSwipe(False)
            self.sheet.setCancelable(False)
        except Exception:
            pass
        self.set_state("prepare")

    def show(self):
        if self.sheet is not None:
            self.sheet.show()

    def _icon_resource(self, R, name: str, fallback):
        try:
            return getattr(R.drawable, name)
        except Exception:
            return fallback

    def set_state(self, state: str, detail: str = ""):
        if self.title is None or self.subtitle is None:
            return

        tr = self.plugin._tr
        labels = {
            "prepare": (tr("Установка DEX", "Installing DEX"), tr("Подготовка файла...", "Preparing file..."), 0.12, tr("Подготовка", "Preparing")),
            "download": (tr("Загрузка DEX", "Downloading DEX"), tr("Telegram скачивает файл...", "Telegram is downloading the file..."), 0.35, tr("Загрузка", "Downloading")),
            "install": (tr("Установка DEX", "Installing DEX"), tr("Подключаю ядро анимации текста...", "Connecting the text animation core..."), 0.72, tr("Установка", "Installing")),
            "done": (tr("DEX установлен", "DEX installed"), tr("Готово. Настройки уже синхронизированы.", "Done. Settings are already synced."), 1.0, tr("Готово", "Done")),
            "error": (tr("Не удалось установить DEX", "Couldn't install DEX"), detail or tr("Проверьте файл и попробуйте ещё раз.", "Check the file and try again."), 1.0, tr("Ошибка", "Error")),
        }
        title, subtitle, progress, stage = labels.get(state, labels["prepare"])
        if detail and state not in ("error",):
            subtitle = detail
        self.title.setText(title)
        self.subtitle.setText(subtitle)
        if self.progress is not None:
            self.progress.setProgress(float(progress), True)
        if self.status_left is not None:
            self.status_left.setText(self.file_name)
        if self.status_right is not None:
            self.status_right.setText(f"{stage} · {int(float(progress) * 100)}%")

        if self.button is not None:
            if state == "done":
                self.button.setText(tr("Готово", "Done"), True)
                self.button.setSubText(None, True)
                self.button.setLoading(False)
                self.button.setEnabled(True)
            elif state == "error":
                self.button.setText(tr("Закрыть", "Close"), True)
                self.button.setSubText(None, True)
                self.button.setLoading(False)
                self.button.setEnabled(True)
            else:
                self.button.setText(tr("Устанавливаю...", "Installing..."), True)
                self.button.setSubText(stage, True)
                self.button.setLoading(True)
                self.button.setEnabled(False)

        if self.icon is not None:
            Theme = jclass("org.telegram.ui.ActionBar.Theme")
            R = jclass("org.telegram.messenger.R")
            accent = self._color(Theme.key_featuredStickers_addButton)
            icon_name = {
                "prepare": "msg_download",
                "download": "msg_download",
                "install": "msg_retry",
                "done": "msg_check",
                "error": "msg_clear",
            }.get(state, "msg_download")
            color = accent
            if state == "error":
                try:
                    color = self._color(Theme.key_text_RedRegular, accent)
                except Exception:
                    color = accent
            resource = self._icon_resource(R, icon_name, R.drawable.msg_download)
            self.icon.setImageResource(resource)
            call_int_color(self.icon, "setColorFilter", color)
            if self.icon_bg is not None:
                set_drawable_color(self.icon_bg, self.plugin._alpha(color, 0.14))


class TextAnimationPlugin(BasePlugin):
    def __init__(self):
        super().__init__()
        self.dex_loader: Optional[DexLoader] = None
        self._hooks = []
        self._observer_account: Optional[int] = None
        self._download_delegate: Optional[DexDownloadDelegate] = None
        self._pending_file_name: Optional[str] = None
        self._pending_install_sheet: Optional[DexInstallerSheet] = None
        self._settings_factories = []
        self._settings_preview_delegates = []
        self._settings_preview_views = []

    def _log(self, message: str) -> None:
        self.log(f"[TextAnimation] {message}")

    def _is_russian(self) -> bool:
        try:
            lang = LocaleController.getInstance().getCurrentLocale().getLanguage()
            return str(lang).startswith("ru")
        except Exception:
            return True

    def _tr(self, ru: str, en: str) -> str:
        return ru if self._is_russian() else en

    def _alpha(self, color: int, alpha: float) -> int:
        alpha_value = max(0, min(255, int(float(alpha) * 255)))
        return as_java_color((alpha_value << 24) | (int(color) & 0x00FFFFFF))

    def _get_active_context(self):
        fragment = get_last_fragment()
        if fragment is None:
            return None
        try:
            return fragment.getParentActivity()
        except Exception:
            return None

    def _get_resources_provider(self):
        fragment = get_last_fragment()
        if fragment is None:
            return None
        try:
            if hasattr(fragment, "getResourceProvider"):
                return fragment.getResourceProvider()
        except Exception:
            pass
        try:
            return getattr(fragment, "resourcesProvider", None)
        except Exception:
            return None

    def _collect_settings(self) -> dict[str, Any]:
        return {key: self.get_setting(key, default) for key, default in CONFIG_DEFAULTS.items()}

    def _on_setting_change(self, _new_value=None):
        self._sync_settings_to_dex()
        self._invalidate_settings_preview()

    def _sync_settings_to_dex(self) -> None:
        if self.dex_loader is None:
            return
        try:
            self.dex_loader.update_settings(self._collect_settings())
        except Exception as error:
            self._log(f"Ошибка синхронизации настроек: {error}")

    def _is_dex_file_name(self, file_name: str) -> bool:
        normalized = os.path.basename(str(file_name or "").strip()).lower()
        return normalized == DEX_INSTALL_FILE_NAME

    def _is_supported_dex_message(self, message) -> bool:
        return any(self._is_dex_file_name(name) for name in self._get_message_file_name_candidates(message))

    def _get_message_file_name(self, message) -> str:
        candidates = self._get_message_file_name_candidates(message)
        for name in candidates:
            if self._is_dex_file_name(name):
                return name
        return candidates[0] if candidates else ""

    def _get_message_file_name_candidates(self, message) -> list[str]:
        candidates: list[str] = []

        def add_candidate(value) -> None:
            if not value:
                return
            value = str(value).strip()
            if value and value not in candidates:
                candidates.append(value)

        if message is None:
            return candidates

        for getter_name in ("getDocumentName",):
            try:
                add_candidate(getattr(message, getter_name)())
            except Exception:
                pass

        try:
            document = message.getDocument()
            if document is not None:
                try:
                    FileLoader = jclass("org.telegram.messenger.FileLoader")
                    add_candidate(FileLoader.getDocumentFileName(document))
                except Exception:
                    pass
                for attr_name in ("file_name_fixed", "file_name"):
                    add_candidate(getattr(document, attr_name, None))
        except Exception:
            pass

        for getter_name in ("getFileName",):
            try:
                add_candidate(getattr(message, getter_name)())
            except Exception:
                pass

        return candidates

    def _resolve_message_file_path(self, message) -> Optional[str]:
        if message is None:
            return None
        try:
            attach_path = getattr(message.messageOwner, "attachPath", None)
            if attach_path:
                attach_path = str(attach_path)
                if os.path.exists(attach_path):
                    return attach_path
        except Exception:
            pass
        try:
            FileLoader = jclass("org.telegram.messenger.FileLoader")
            file_obj = FileLoader.getInstance(message.currentAccount).getPathToMessage(message.messageOwner)
            if file_obj is not None:
                path = str(file_obj.getAbsolutePath())
                if os.path.exists(path):
                    return path
        except Exception as error:
            self._log(f"Не удалось определить путь DEX: {error}")
        return None

    def _run_on_ui_thread_sync(self, fn, timeout_ms: int = 3000) -> None:
        try:
            Looper = jclass("android.os.Looper")
            if Looper.getMainLooper().isCurrentThread():
                fn()
                return
        except Exception:
            pass

        finished = threading.Event()
        error_holder = {}

        def wrapped():
            try:
                fn()
            except Exception as error:
                error_holder["error"] = error
            finally:
                finished.set()

        run_on_ui_thread(wrapped)
        finished.wait(timeout_ms / 1000.0)
        if "error" in error_holder:
            raise error_holder["error"]

    def _ensure_download_delegate(self):
        if self._download_delegate is None:
            self._download_delegate = DexDownloadDelegate(self)

    def _attach_download_observer(self, account: int) -> None:
        def attach():
            if self._observer_account == account:
                return
            self._ensure_download_delegate()
            self._detach_download_observer_locked()
            nc = NotificationCenter.getInstance(account)
            nc.addObserver(self._download_delegate, NotificationCenter.fileLoaded)
            nc.addObserver(self._download_delegate, NotificationCenter.fileLoadFailed)
            self._observer_account = account

        self._run_on_ui_thread_sync(attach)

    def _detach_download_observer(self) -> None:
        self._run_on_ui_thread_sync(self._detach_download_observer_locked)

    def _detach_download_observer_locked(self) -> None:
        if self._observer_account is None or self._download_delegate is None:
            self._observer_account = None
            return
        try:
            nc = NotificationCenter.getInstance(self._observer_account)
            nc.removeObserver(self._download_delegate, NotificationCenter.fileLoaded)
            nc.removeObserver(self._download_delegate, NotificationCenter.fileLoadFailed)
        except Exception:
            pass
        finally:
            self._observer_account = None

    def _reset_pending_download(self):
        self._pending_file_name = None
        self._pending_install_sheet = None

    def _matches_pending_file(self, location) -> bool:
        if not self._pending_file_name or location is None:
            return False
        return str(location).strip().lower() == self._pending_file_name.strip().lower()

    def install_dex_from_path(self, path: str, file_name: str = DEX_INSTALL_FILE_NAME) -> None:
        sheet = DexInstallerSheet(self, file_name)
        if sheet.sheet is not None:
            sheet.show()
            sheet.set_state("install")
        try:
            if self.dex_loader is None:
                self.dex_loader = DexLoader(self)
            self.dex_loader.install_from_path(path)
            self._sync_settings_to_dex()
            self._log(f"DEX установлен из {path}")
            if sheet.sheet is not None:
                sheet.set_state("done")
        except Exception as error:
            self._log(f"Ошибка установки DEX: {error}")
            if sheet.sheet is not None:
                sheet.set_state("error", str(error))

    def download_dex_from_message(self, message, file_name: str = DEX_INSTALL_FILE_NAME) -> None:
        try:
            document = message.getDocument()
            if document is None:
                self._log("В сообщении нет DEX-файла")
                return
            account = int(message.currentAccount)
            self._attach_download_observer(account)
            self._pending_file_name = file_name
            self._pending_install_sheet = DexInstallerSheet(self, file_name)
            if self._pending_install_sheet.sheet is not None:
                self._pending_install_sheet.show()
                self._pending_install_sheet.set_state("download")

            FileLoader = jclass("org.telegram.messenger.FileLoader")
            FileLoader.getInstance(account).loadFile(document, message, FileLoader.PRIORITY_HIGH, 1)
        except Exception as error:
            self._reset_pending_download()
            self._detach_download_observer()
            self._log(f"Ошибка запуска загрузки DEX: {error}")

    def _on_download_notification(self, notification_id, account, *args) -> None:
        try:
            if self._observer_account is None or int(account) != int(self._observer_account):
                return

            if notification_id == NotificationCenter.fileLoaded:
                location = args[0] if len(args) > 0 else None
                final_file = args[1] if len(args) > 1 else None
                if not self._matches_pending_file(location):
                    return

                path = None
                if final_file is not None and hasattr(final_file, "getAbsolutePath"):
                    path = str(final_file.getAbsolutePath())

                sheet = self._pending_install_sheet
                file_name = self._pending_file_name or DEX_INSTALL_FILE_NAME
                self._reset_pending_download()
                self._detach_download_observer()

                if sheet is not None:
                    sheet.set_state("install")
                if path and os.path.exists(path):
                    if sheet is not None:
                        self._install_downloaded_dex(path, file_name, sheet)
                    else:
                        run_on_ui_thread(lambda path=path, file_name=file_name: self.install_dex_from_path(path, file_name))
                else:
                    if sheet is not None:
                        sheet.set_state("error", "Файл скачан, но путь не найден")
                    self._log("DEX скачан, но файл не найден")

            elif notification_id == NotificationCenter.fileLoadFailed:
                location = args[0] if len(args) > 0 else None
                if not self._matches_pending_file(location):
                    return
                sheet = self._pending_install_sheet
                failed_name = self._pending_file_name or DEX_INSTALL_FILE_NAME
                self._reset_pending_download()
                self._detach_download_observer()
                if sheet is not None:
                    sheet.set_state("error", f"Не удалось скачать {failed_name}")
                self._log(f"Не удалось скачать {failed_name}")
        except Exception as error:
            self._log(f"Ошибка уведомления загрузки DEX: {error}")

    def _install_downloaded_dex(self, path: str, file_name: str, sheet: DexInstallerSheet) -> None:
        try:
            if self.dex_loader is None:
                self.dex_loader = DexLoader(self)
            self.dex_loader.install_from_path(path)
            self._sync_settings_to_dex()
            sheet.set_state("done")
        except Exception as error:
            self._log(f"Ошибка установки скачанного DEX: {error}")
            sheet.set_state("error", str(error))

    def _hook_android_utilities(self) -> None:
        try:
            AndroidUtilities = JClass.forName("org.telegram.messenger.AndroidUtilities")
            message_hook = DexOpenHook(self)
            local_file_hook = DexLocalFileOpenHook(self)
            for method in AndroidUtilities.getDeclaredMethods():
                name = method.getName()
                params = method.getParameterTypes()
                if name == "openDocument" and len(params) == 3 and "MessageObject" in params[0].getName():
                    method.setAccessible(True)
                    self._hooks.append(self.hook_method(method, message_hook))
                elif name == "openForView" and len(params) == 4 and "MessageObject" in params[0].getName():
                    method.setAccessible(True)
                    self._hooks.append(self.hook_method(method, message_hook))
                elif name == "openForView" and len(params) == 6:
                    first_type = params[0].getName()
                    second_type = params[1].getName()
                    if first_type == "java.io.File" and second_type == "java.lang.String":
                        method.setAccessible(True)
                        self._hooks.append(self.hook_method(method, local_file_hook))
        except Exception as error:
            self._log(f"Не удалось поставить хуки AndroidUtilities: {error}")

    def _load_cached_dex(self) -> None:
        try:
            self.dex_loader = DexLoader(self)
            cached = self.dex_loader.load_from_cache()
            if not cached:
                self._log("Cached DEX не найден. Установите text_animation.dex тапом из чата.")
                return
            self.dex_loader.start_from_bytes(cached)
            run_on_ui_thread(self._sync_settings_to_dex, delay=100)
            self._log("Cached DEX загружен")
        except Exception as error:
            self._log(f"Ошибка загрузки cached DEX: {error}")

    def _has_cached_dex(self) -> bool:
        try:
            if self.dex_loader is not None:
                return self.dex_loader.has_cache()
            return DexLoader(self).has_cache()
        except Exception as error:
            self._log(f"DEX cache check error: {error}")
            return False

    def _has_installed_dex(self) -> bool:
        try:
            return bool((self.dex_loader is not None and self.dex_loader.is_loaded()) or self._has_cached_dex())
        except Exception:
            return False

    def _show_dex_bulletin(self, kind: str, text: str) -> None:
        try:
            method = getattr(BulletinHelper, f"show_{kind}", BulletinHelper.show_info)
            try:
                method(text, get_last_fragment())
            except Exception:
                method(text)
        except Exception as error:
            self._log(f"Bulletin error: {error}")

    def _delete_cached_dex(self) -> None:
        try:
            self._reset_pending_download()
            self._detach_download_observer()

            loader = self.dex_loader
            if loader is None:
                loader = DexLoader(self)

            was_loaded = loader.is_loaded()
            was_cached = loader.has_cache()
            deleted = loader.delete_cache()
            self.dex_loader = None
            self._invalidate_settings_preview()

            if deleted:
                self._log("Cached DEX deleted")
                self._show_dex_bulletin("success", self._tr("DEX удалён", "DEX deleted"))
            elif was_loaded:
                self._log("DEX unloaded; cache file was not found")
                self._show_dex_bulletin("success", self._tr("DEX выгружен", "DEX unloaded"))
            elif was_cached:
                self._show_dex_bulletin("success", self._tr("DEX удалён", "DEX deleted"))
            else:
                self._show_dex_bulletin("info", self._tr("DEX уже не установлен", "DEX is already not installed"))
        except Exception as error:
            self._log(f"DEX delete error: {error}")
            self._show_dex_bulletin("error", f"{self._tr('Не удалось удалить DEX', 'Could not delete DEX')}: {error}")

    def _confirm_delete_dex(self) -> None:
        context = self._get_active_context()
        if context is None:
            self._delete_cached_dex()
            return

        try:
            from ui.alert import AlertDialogBuilder

            resources_provider = self._get_resources_provider()
            try:
                builder = AlertDialogBuilder(context, AlertDialogBuilder.ALERT_TYPE_MESSAGE, resources_provider)
            except Exception:
                builder = AlertDialogBuilder(context, AlertDialogBuilder.ALERT_TYPE_MESSAGE)

            def on_delete(dialog, _which):
                try:
                    dialog.dismiss()
                except Exception:
                    pass
                self._delete_cached_dex()

            builder.set_title(self._tr("Удалить DEX?", "Delete DEX?"))
            builder.set_message(self._tr(
                "Кэшированное ядро animation_core.dex будет выгружено и удалено. Исходный text_animation.dex в папке плагина не трогаем.",
                "The cached animation_core.dex will be unloaded and deleted. The source text_animation.dex in the plugin folder will not be touched.",
            ))
            builder.set_positive_button(self._tr("Удалить", "Delete"), on_delete)
            builder.make_button_red(AlertDialogBuilder.BUTTON_POSITIVE)
            builder.set_negative_button(self._tr("Отмена", "Cancel"), lambda dialog, _which: dialog.dismiss())
            builder.show()
        except Exception as error:
            self._log(f"DEX delete dialog error: {error}")
            self._show_dex_bulletin("error", f"{self._tr('Не удалось открыть подтверждение', 'Could not open confirmation')}: {error}")

    def on_plugin_load(self) -> None:
        self._log(f"Loading v{__version__}")
        self._hooks = []
        self._hook_android_utilities()
        self._load_cached_dex()

    def on_plugin_unload(self) -> None:
        for hook in self._hooks:
            try:
                self.unhook_method(hook)
            except Exception:
                pass
        self._hooks.clear()
        self._reset_pending_download()
        self._detach_download_observer()
        if self.dex_loader is not None:
            self.dex_loader.unload()
            self.dex_loader = None
        self._settings_preview_delegates = []
        self._settings_preview_views = []
        self._log("Plugin unloaded")

    def _keep_settings_factory(self, factory):
        self._settings_factories.append(factory)
        return factory.instance.java

    def _setting_float_clamped(self, key: str, default: float, min_value: float, max_value: float) -> float:
        try:
            value = float(self.get_setting(key, default))
        except Exception:
            value = float(default)
        return max(float(min_value), min(float(max_value), value))

    def _setting_int_clamped(self, key: str, default: int, min_value: int, max_value: int) -> int:
        return int(round(self._setting_float_clamped(key, default, min_value, max_value)))

    def _settings_theme_color(self, key, resources_provider=None, fallback: int = 0xFF000000) -> int:
        try:
            Theme = jclass("org.telegram.ui.ActionBar.Theme")
            if resources_provider is not None:
                return as_java_color(Theme.getColor(key, resources_provider))
        except Exception:
            pass
        try:
            Theme = jclass("org.telegram.ui.ActionBar.Theme")
            return as_java_color(Theme.getColor(key))
        except Exception:
            return as_java_color(fallback)

    def _settings_text(self, context, text: str, size_dp: int, color: int, bold: bool = False):
        TextView = jclass("android.widget.TextView")
        TypedValue = jclass("android.util.TypedValue")
        AndroidUtilities = jclass("org.telegram.messenger.AndroidUtilities")

        view = TextView(context)
        view.setText(str(text))
        view.setTextSize(TypedValue.COMPLEX_UNIT_DIP, int(size_dp))
        call_int_color(view, "setTextColor", color)
        if bold:
            try:
                view.setTypeface(AndroidUtilities.bold())
            except Exception:
                pass
        return view

    def _invalidate_settings_preview(self):
        try:
            views = list(self._settings_preview_views or [])
        except Exception:
            views = []
        for view in views:
            try:
                view.invalidate()
            except Exception:
                pass

    def _start_live_settings_preview(self, host, edit):
        sample = self._tr("Печатаю красиво", "Typing smoothly")
        second_line = self._tr("И вторую строку", "And a second line")
        delete_to = sample.rfind(" ")
        if delete_to < 0:
            delete_to = max(0, len(sample) - 4)
        pause_steps = 3
        state = {"step": 0, "misses": 0}

        def apply_preview_text(text: str, selection_start=None, selection_end=None):
            text = str(text or "")
            edit.setText(text)
            try:
                text_len = len(text)
                if selection_start is None:
                    edit.setSelection(text_len)
                elif selection_end is None:
                    edit.setSelection(max(0, min(text_len, int(selection_start))))
                else:
                    start = max(0, min(text_len, int(selection_start)))
                    end = max(0, min(text_len, int(selection_end)))
                    edit.setSelection(min(start, end), max(start, end))
            except Exception:
                pass

        def tick():
            try:
                if host is None or edit is None:
                    return
                try:
                    attached = host.getWindowToken() is not None
                except Exception:
                    attached = True
                if not attached:
                    state["misses"] += 1
                    if state["misses"] > 30:
                        return
                    run_on_ui_thread(tick, delay=300)
                    return
                state["misses"] = 0

                step = int(state.get("step", 0))
                text_len = len(sample)
                delete_steps = text_len - delete_to
                type_end = text_len
                pause_end = type_end + pause_steps
                delete_end = pause_end + delete_steps
                newline_end = delete_end + 2
                second_end = newline_end + len(second_line)
                select_end = second_end + 5
                reset_end = select_end + 2

                if step <= type_end:
                    text = sample[:step]
                    delay = 190
                    apply_preview_text(text)
                elif step <= pause_end:
                    text = sample
                    delay = 360
                    apply_preview_text(text)
                elif step <= delete_end:
                    removed = step - pause_end
                    text = sample[:max(delete_to, text_len - removed)]
                    delay = 210
                    apply_preview_text(text)
                elif step <= newline_end:
                    text = sample[:delete_to] + "\n"
                    delay = 360
                    apply_preview_text(text)
                elif step <= second_end:
                    added = step - newline_end
                    text = sample[:delete_to] + "\n" + second_line[:added]
                    delay = 170
                    apply_preview_text(text)
                elif step <= select_end:
                    text = sample[:delete_to] + "\n" + second_line
                    delay = 420
                    start = len(sample[:delete_to]) + 1
                    end = len(text)
                    apply_preview_text(text, start, end)
                else:
                    text = ""
                    delay = 480
                    apply_preview_text(text)
                try:
                    edit.requestFocus()
                except Exception:
                    pass
                try:
                    edit.invalidate()
                    host.invalidate()
                except Exception:
                    pass

                state["step"] = (step + 1) % (reset_end + 1)
                run_on_ui_thread(tick, delay=delay)
            except Exception as error:
                self._log(f"Live preview tick error: {error}")

        run_on_ui_thread(tick, delay=350)

    def _live_preview_factory(self):
        from ui.settings import SimpleSettingFactory

        plugin = self

        def create_view(context, list_view, current_account, class_guid, resources_provider):
            Gravity = jclass("android.view.Gravity")
            View = jclass("android.view.View")
            ViewGroupLayoutParams = jclass("android.view.ViewGroup$LayoutParams")
            LinearLayout = jclass("android.widget.LinearLayout")
            TypedValue = jclass("android.util.TypedValue")
            AndroidUtilities = jclass("org.telegram.messenger.AndroidUtilities")
            LayoutHelper = jclass("org.telegram.ui.Components.LayoutHelper")
            Theme = jclass("org.telegram.ui.ActionBar.Theme")

            root = LinearLayout(context)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(21), AndroidUtilities.dp(10), AndroidUtilities.dp(21), AndroidUtilities.dp(12))
            try:
                root.setLayoutParams(ViewGroupLayoutParams(ViewGroupLayoutParams.MATCH_PARENT, ViewGroupLayoutParams.WRAP_CONTENT))
            except Exception:
                pass

            title = plugin._settings_text(
                context,
                plugin._tr("Предпросмотр", "Preview"),
                16,
                plugin._settings_theme_color(Theme.key_windowBackgroundWhiteBlackText, resources_provider, 0xFF111111),
                True,
            )
            root.addView(title, LayoutHelper.createLinear(-1, -2))

            try:
                EditTextCaption = jclass("org.telegram.ui.Components.EditTextCaption")
            except Exception:
                try:
                    UniversalView = jclass("com.exteragram.messenger.plugins.ui.components.templates.UniversalView")
                    Delegate = jclass("com.exteragram.messenger.plugins.ui.components.templates.UniversalView$UniversalViewDelegate")
                    preview_ref = [None]

                    class _FallbackPreviewDelegate(dynamic_proxy(Delegate)):
                        def __init__(self):
                            super().__init__()

                        def onDraw(self, canvas, callback):
                            try:
                                callback.run(canvas)
                            except Exception:
                                pass
                            plugin._draw_settings_preview(canvas, resources_provider)
                            try:
                                view = preview_ref[0]
                                if view is not None:
                                    run_on_ui_thread(lambda view=view: view.invalidate(), delay=80)
                            except Exception:
                                pass

                        def onMeasure(self, width_spec, height_spec, callback):
                            try:
                                callback.run(java_integer()(int(width_spec)), java_integer()(int(height_spec)))
                            except Exception:
                                pass

                        def onAttachedToWindow(self):
                            return None

                        def onDetachedFromWindow(self):
                            return None

                        def onTouchEvent(self, motion_event, callback):
                            try:
                                return bool(callback.run(motion_event))
                            except Exception:
                                return False

                        def onInitializeAccessibilityNodeInfo(self, info, callback):
                            try:
                                callback.run(info)
                            except Exception:
                                pass

                    delegate = _FallbackPreviewDelegate()
                    preview = UniversalView(context, delegate)
                    preview_ref[0] = preview
                    try:
                        preview.setWillNotDraw(False)
                    except Exception:
                        pass
                    try:
                        preview.setImportantForAccessibility(View.IMPORTANT_FOR_ACCESSIBILITY_NO)
                    except Exception:
                        pass
                    plugin._settings_preview_delegates.append(delegate)
                    plugin._settings_preview_views.append(preview)
                    root.addView(preview, LayoutHelper.createLinear(-1, 188, 0, 8, 0, 0, 0))
                    return root
                except Exception:
                    pass
                unavailable = plugin._settings_text(
                    context,
                    plugin._tr("Предпросмотр недоступен в этой сборке", "Preview is not available in this build"),
                    13,
                    plugin._settings_theme_color(Theme.key_windowBackgroundWhiteGrayText2, resources_provider, 0xFF7D7D7D),
                )
                root.addView(unavailable, LayoutHelper.createLinear(-1, -2, 0, 8, 0, 0, 0))
                return root

            edit = EditTextCaption(context, resources_provider)
            try:
                edit.setImportantForAccessibility(View.IMPORTANT_FOR_ACCESSIBILITY_NO)
                edit.setShowSoftInputOnFocus(False)
            except Exception:
                pass
            edit.setSingleLine(False)
            edit.setMaxLines(2)
            edit.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 18)
            edit.setGravity(Gravity.LEFT | Gravity.CENTER_VERTICAL)
            edit.setPadding(0, 0, 0, 0)
            try:
                edit.setIncludeFontPadding(False)
            except Exception:
                pass
            try:
                edit.setBackgroundDrawable(None)
            except Exception:
                try:
                    edit.setBackground(None)
                except Exception:
                    pass
            call_int_color(edit, "setTextColor", plugin._settings_theme_color(Theme.key_chat_messagePanelText, resources_provider, 0xFF222222))
            call_int_color(edit, "setHintTextColor", plugin._settings_theme_color(Theme.key_chat_messagePanelHint, resources_provider, 0xFF8A8A8A))
            try:
                call_int_color(edit, "setHintColor", plugin._settings_theme_color(Theme.key_chat_messagePanelHint, resources_provider, 0xFF8A8A8A))
            except Exception:
                pass
            try:
                edit.setHintText(plugin._tr("Сообщение", "Message"))
            except Exception:
                edit.setHint(plugin._tr("Сообщение", "Message"))
            try:
                call_int_color(edit, "setCursorColor", plugin._settings_theme_color(Theme.key_chat_messagePanelCursor, resources_provider, 0xFF3390EC))
                edit.setCursorWidth(1.5)
                edit.setCursorSize(AndroidUtilities.dp(24))
            except Exception:
                pass
            root.addView(edit, LayoutHelper.createLinear(-1, 64, 0, 8, 0, 0, 0))

            def stabilize_preview_width():
                try:
                    list_width = 0
                    try:
                        if list_view is not None:
                            list_width = int(list_view.getMeasuredWidth() or list_view.getWidth() or 0)
                    except Exception:
                        list_width = 0
                    if list_width <= 0:
                        list_width = int(AndroidUtilities.displaySize.x)

                    root_width = max(AndroidUtilities.dp(240), list_width)
                    edit_width = max(1, root_width - AndroidUtilities.dp(42))

                    root.setMinimumWidth(root_width)
                    edit.setMinWidth(edit_width)
                    root.requestLayout()
                    edit.requestLayout()
                except Exception:
                    pass

            stabilize_preview_width()
            run_on_ui_thread(stabilize_preview_width, delay=80)

            plugin._settings_preview_views.append(edit)
            root.setGravity(Gravity.CENTER_VERTICAL)
            plugin._start_live_settings_preview(edit, edit)
            return root

        def bind_view(view, item, divider, adapter, list_view):
            try:
                view.getChildAt(1).invalidate()
            except Exception:
                pass

        return SimpleSettingFactory(create_view, bind_view, is_clickable=False, is_shadow=False)

    def _preview_factory(self):
        from ui.settings import SimpleSettingFactory

        plugin = self

        def create_view(context, list_view, current_account, class_guid, resources_provider):
            Gravity = jclass("android.view.Gravity")
            View = jclass("android.view.View")
            LinearLayout = jclass("android.widget.LinearLayout")
            AndroidUtilities = jclass("org.telegram.messenger.AndroidUtilities")
            LayoutHelper = jclass("org.telegram.ui.Components.LayoutHelper")

            root = LinearLayout(context)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(21), AndroidUtilities.dp(10), AndroidUtilities.dp(21), AndroidUtilities.dp(12))

            title = plugin._settings_text(
                context,
                plugin._tr("Предпросмотр", "Preview"),
                16,
                plugin._settings_theme_color(jclass("org.telegram.ui.ActionBar.Theme").key_windowBackgroundWhiteBlackText, resources_provider, 0xFF111111),
                True,
            )
            root.addView(title, LayoutHelper.createLinear(-1, -2))

            try:
                UniversalView = jclass("com.exteragram.messenger.plugins.ui.components.templates.UniversalView")
                Delegate = jclass("com.exteragram.messenger.plugins.ui.components.templates.UniversalView$UniversalViewDelegate")
            except Exception:
                unavailable = plugin._settings_text(
                    context,
                    plugin._tr("Предпросмотр недоступен в этой сборке", "Preview is not available in this build"),
                    13,
                    plugin._settings_theme_color(jclass("org.telegram.ui.ActionBar.Theme").key_windowBackgroundWhiteGrayText2, resources_provider, 0xFF7D7D7D),
                )
                root.addView(unavailable, LayoutHelper.createLinear(-1, -2, 0, 8, 0, 0, 0))
                return root

            preview_ref = [None]

            class _PreviewDelegate(dynamic_proxy(Delegate)):
                def __init__(self):
                    super().__init__()

                def onDraw(self, canvas, callback):
                    try:
                        callback.run(canvas)
                    except Exception:
                        pass
                    plugin._draw_settings_preview(canvas, resources_provider)
                    try:
                        view = preview_ref[0]
                        if view is not None:
                            run_on_ui_thread(lambda view=view: view.invalidate(), delay=80)
                    except Exception:
                        pass

                def onMeasure(self, width_spec, height_spec, callback):
                    try:
                        callback.run(java_integer()(int(width_spec)), java_integer()(int(height_spec)))
                    except Exception:
                        pass

                def onAttachedToWindow(self):
                    return None

                def onDetachedFromWindow(self):
                    return None

                def onTouchEvent(self, motion_event, callback):
                    try:
                        return bool(callback.run(motion_event))
                    except Exception:
                        return False

                def onInitializeAccessibilityNodeInfo(self, info, callback):
                    try:
                        callback.run(info)
                    except Exception:
                        pass

            delegate = _PreviewDelegate()
            preview = UniversalView(context, delegate)
            preview_ref[0] = preview
            try:
                preview.setWillNotDraw(False)
            except Exception:
                pass
            try:
                preview.setImportantForAccessibility(View.IMPORTANT_FOR_ACCESSIBILITY_NO)
            except Exception:
                pass

            self._settings_preview_delegates.append(delegate)
            self._settings_preview_views.append(preview)
            root.addView(preview, LayoutHelper.createLinear(-1, 188, 0, 8, 0, 0, 0))
            root.setGravity(Gravity.CENTER_VERTICAL)
            return root

        def bind_view(view, item, divider, adapter, list_view):
            try:
                view.getChildAt(1).invalidate()
            except Exception:
                pass

        return SimpleSettingFactory(create_view, bind_view, is_clickable=False, is_shadow=False)

    def _draw_round_rect(self, canvas, paint, rect, radius: int, color: int):
        set_paint_color(paint, color)
        canvas.drawRoundRect(rect, float(radius), float(radius), paint)

    def _argb_with_opacity(self, color: int, opacity: int) -> int:
        opacity = max(0, min(100, int(opacity)))
        alpha = int(opacity * 255 / 100)
        return as_java_color((alpha << 24) | (int(color) & 0x00FFFFFF))

    def _ellipsize_preview_text(self, text: str, paint, max_width: int) -> str:
        text = str(text or "")
        max_width = max(0, int(max_width))
        if not text or max_width <= 0:
            return ""
        try:
            if float(paint.measureText(text)) <= float(max_width):
                return text
            ellipsis = "..."
            if float(paint.measureText(ellipsis)) > float(max_width):
                return ""
            candidate = text
            while candidate:
                shortened = candidate.rstrip() + ellipsis
                if float(paint.measureText(shortened)) <= float(max_width):
                    return shortened
                candidate = candidate[:-1]
            return ellipsis
        except Exception:
            return text

    def _draw_settings_preview(self, canvas, resources_provider=None):
        try:
            Paint = jclass("android.graphics.Paint")
            RectF = jclass("android.graphics.RectF")
            AndroidUtilities = jclass("org.telegram.messenger.AndroidUtilities")
            Theme = jclass("org.telegram.ui.ActionBar.Theme")
            System = jclass("java.lang.System")

            width = int(canvas.getWidth())
            height = int(canvas.getHeight())
            if width <= 0 or height <= 0:
                return

            now = int(System.currentTimeMillis())
            phase = (now % 1400) / 1400.0
            blink = ((now // 450) % 2) == 0

            paint = Paint(Paint.ANTI_ALIAS_FLAG)
            pad = AndroidUtilities.dp(8)
            surface = RectF(float(pad), 0.0, float(width - pad), float(height))
            surface_color = self._settings_theme_color(Theme.key_windowBackgroundWhite, resources_provider, 0xFFF4F7FB)
            self._draw_round_rect(canvas, paint, surface, AndroidUtilities.dp(14), surface_color)

            inset = AndroidUtilities.dp(8)
            chat = RectF(float(pad + inset), float(inset), float(width - pad - inset), float(height - inset))
            chat_bg = self._settings_theme_color(getattr(Theme, "key_chat_wallpaper", Theme.key_windowBackgroundWhite), resources_provider, 0xFFE7EEF6)
            self._draw_round_rect(canvas, paint, chat, AndroidUtilities.dp(12), chat_bg)

            in_bubble = self._settings_theme_color(getattr(Theme, "key_chat_inBubble", Theme.key_windowBackgroundWhite), resources_provider, 0xFFFFFFFF)
            out_bubble = self._settings_theme_color(getattr(Theme, "key_chat_outBubble", Theme.key_windowBackgroundWhite), resources_provider, 0xFFDDF7C8)
            text_color = self._settings_theme_color(getattr(Theme, "key_chat_messageTextIn", Theme.key_windowBackgroundWhiteBlackText), resources_provider, 0xFF222222)
            accent = self._settings_theme_color(Theme.key_windowBackgroundWhiteBlueText, resources_provider, 0xFF3390EC)
            muted = self._settings_theme_color(Theme.key_windowBackgroundWhiteGrayText2, resources_provider, 0xFF7D7D7D)

            bubble_left = int(chat.left) + AndroidUtilities.dp(18)
            bubble_top = int(chat.top) + AndroidUtilities.dp(18)
            bubble_w = min(AndroidUtilities.dp(238), max(AndroidUtilities.dp(150), width - AndroidUtilities.dp(92)))
            bubble_h = AndroidUtilities.dp(64)
            bubble = RectF(float(bubble_left), float(bubble_top), float(bubble_left + bubble_w), float(bubble_top + bubble_h))
            self._draw_round_rect(canvas, paint, bubble, AndroidUtilities.dp(15), in_bubble)

            sample = self._tr("Печатаю красиво", "Typing smoothly")
            visible_count = max(1, min(len(sample), int(len(sample) * max(0.08, phase))))
            shown = sample[:visible_count]
            text_paint = Paint(Paint.ANTI_ALIAS_FLAG)
            text_paint.setTextSize(float(AndroidUtilities.dp(16)))
            set_paint_color(text_paint, text_color)
            shown = self._ellipsize_preview_text(shown, text_paint, bubble_w - AndroidUtilities.dp(84))

            baseline = bubble_top + AndroidUtilities.dp(37)
            text_x = bubble_left + AndroidUtilities.dp(14)
            text_y = float(baseline)
            if bool(self.get_setting("blur_enabled", True)):
                ghost_color = self._argb_with_opacity(accent, max(8, min(32, self._setting_int_clamped("blur_radius", 10, 0, 30) + 8)))
                set_paint_color(text_paint, ghost_color)
                canvas.drawText(shown, float(text_x + AndroidUtilities.dp(1)), text_y - AndroidUtilities.dp(1), text_paint)
                set_paint_color(text_paint, text_color)

            if bool(self.get_setting("slide_enabled", True)):
                slide = self._setting_int_clamped("slide_dist", 20, 0, 60)
                text_y -= float(AndroidUtilities.dp(int(slide * max(0.0, 0.28 - phase))))

            if bool(self.get_setting("scale_enabled", False)):
                text_paint.setTextSize(float(AndroidUtilities.dp(15 + int(phase * 2))))

            canvas.drawText(shown, float(text_x), text_y, text_paint)

            cursor_x = min(
                text_x + int(text_paint.measureText(shown)) + AndroidUtilities.dp(3),
                bubble_left + bubble_w - AndroidUtilities.dp(52),
            )
            if bool(self.get_setting("cursor_enabled", True)) and blink:
                cursor_w = AndroidUtilities.dp(max(1, min(12, self._setting_int_clamped("cursor_width", 5, 1, 12))))
                cursor_h = AndroidUtilities.dp(21)
                stretch = AndroidUtilities.dp(self._setting_int_clamped("liquid_scale_factor", 15, 0, 40) // 6) if bool(self.get_setting("liquid_cursor_enabled", False)) else 0
                cursor = RectF(
                    float(cursor_x),
                    float(baseline - cursor_h + AndroidUtilities.dp(3) - stretch),
                    float(cursor_x + cursor_w),
                    float(baseline + AndroidUtilities.dp(3) + stretch),
                )
                self._draw_round_rect(canvas, paint, cursor, AndroidUtilities.dp(2), accent)

            time_paint = Paint(Paint.ANTI_ALIAS_FLAG)
            time_paint.setTextSize(float(AndroidUtilities.dp(11)))
            set_paint_color(time_paint, muted)
            canvas.drawText("12:48", float(bubble_left + bubble_w - AndroidUtilities.dp(42)), float(bubble_top + bubble_h - AndroidUtilities.dp(10)), time_paint)

            out_w = min(AndroidUtilities.dp(198), max(AndroidUtilities.dp(142), width - AndroidUtilities.dp(118)))
            out_left = int(chat.right) - AndroidUtilities.dp(18) - out_w
            out_top = bubble_top + AndroidUtilities.dp(76)
            out_rect = RectF(float(out_left), float(out_top), float(out_left + out_w), float(out_top + AndroidUtilities.dp(44)))
            self._draw_round_rect(canvas, paint, out_rect, AndroidUtilities.dp(15), out_bubble)

            reply_text = self._tr("В настройках сразу видно эффект", "Settings show the effect")
            text_paint.setTextSize(float(AndroidUtilities.dp(13)))
            set_paint_color(text_paint, text_color)
            reply_text = self._ellipsize_preview_text(reply_text, text_paint, out_w - AndroidUtilities.dp(24))
            canvas.drawText(reply_text, float(out_left + AndroidUtilities.dp(12)), float(out_top + AndroidUtilities.dp(27)), text_paint)

            if bool(self.get_setting("delete_anim_enabled", True)):
                particle_count = min(12, self._setting_int_clamped("particle_count", 5, 0, 12))
                speed = self._setting_int_clamped("particle_speed", 50, 0, 120)
                spread = self._setting_int_clamped("particle_spread", 50, 0, 120)
                size = max(2, self._setting_int_clamped("particle_size", 50, 10, 120) // 18)
                style = self._setting_int_clamped("particle_style", 0, 0, 4)
                particle_color = self._argb_with_opacity(accent, 58)
                set_paint_color(paint, particle_color)
                try:
                    paint.setStrokeCap(Paint.Cap.ROUND)
                except Exception:
                    pass
                origin_x = bubble_left + AndroidUtilities.dp(42)
                origin_y = bubble_top + AndroidUtilities.dp(50)
                for index in range(particle_count):
                    angle = (index + 1) * 2.399
                    distance = AndroidUtilities.dp(5 + int(speed * phase * (0.45 + spread / 90.0) / 7))
                    if style == 2:
                        px = origin_x + int(distance * 0.55 * math.cos(angle) + AndroidUtilities.dp(10 * phase))
                        py = origin_y + int(distance * 0.35 * math.sin(angle) + AndroidUtilities.dp(12 * phase))
                    elif style == 3:
                        px = origin_x + int(distance * (0.35 + spread / 120.0) * math.cos(angle) + AndroidUtilities.dp(14 * phase))
                        py = origin_y + int(distance * 0.28 * math.sin(angle) + AndroidUtilities.dp(8 * phase))
                    else:
                        px = origin_x + int(distance * math.cos(angle))
                        py = origin_y + int(distance * math.sin(angle))
                    psize = float(AndroidUtilities.dp(size))
                    if style == 1:
                        paint.setStyle(Paint.Style.STROKE)
                        paint.setStrokeWidth(max(1.0, psize * 0.28))
                        dx = math.cos(angle) * psize * 1.8
                        dy = math.sin(angle) * psize * 1.8
                        canvas.drawLine(float(px - dx), float(py - dy), float(px + dx), float(py + dy), paint)
                        paint.setStyle(Paint.Style.FILL)
                    elif style == 2:
                        paint.setStyle(Paint.Style.STROKE)
                        paint.setStrokeWidth(max(1.0, psize * 0.12))
                        canvas.save()
                        canvas.rotate(float((index * 31 + phase * 90) % 360), float(px), float(py))
                        radius = psize * 0.85
                        for spoke in range(3):
                            canvas.rotate(60.0, float(px), float(py))
                            canvas.drawLine(float(px - radius), float(py), float(px + radius), float(py), paint)
                        canvas.restore()
                        paint.setStyle(Paint.Style.FILL)
                    elif style == 3:
                        glow_color = self._argb_with_opacity(0xFFFF9DC8, 22)
                        set_paint_color(paint, glow_color)
                        canvas.save()
                        canvas.rotate(float((index * 43 + phase * 140) % 360), float(px), float(py))
                        glow_rect = RectF(float(px - psize * 0.72), float(py - psize * 1.16), float(px + psize * 0.72), float(py + psize * 1.16))
                        canvas.drawOval(glow_rect, paint)
                        set_paint_color(paint, self._argb_with_opacity(0xFFFF7FAF, 72))
                        rect = RectF(float(px - psize * 0.46), float(py - psize * 0.94), float(px + psize * 0.46), float(py + psize * 0.94))
                        canvas.drawOval(rect, paint)
                        set_paint_color(paint, self._argb_with_opacity(0xFFFFD2E3, 58))
                        paint.setStrokeWidth(max(1.0, psize * 0.08))
                        canvas.drawLine(float(px), float(py - psize * 0.54), float(px), float(py + psize * 0.56), paint)
                        canvas.restore()
                        set_paint_color(paint, particle_color)
                    elif style == 4:
                        paint.setTextSize(float(AndroidUtilities.dp(max(9, size + 6))))
                        canvas.save()
                        canvas.rotate(float((index * 17 + phase * 80) % 360), float(px), float(py))
                        canvas.drawText("A", float(px), float(py), paint)
                        canvas.restore()
                    else:
                        canvas.drawCircle(float(px), float(py), psize, paint)

            chip_paint = Paint(Paint.ANTI_ALIAS_FLAG)
            chip_text = Paint(Paint.ANTI_ALIAS_FLAG)
            chip_text.setTextSize(float(AndroidUtilities.dp(11)))
            set_paint_color(chip_text, accent)
            chip_y = int(chat.bottom) - AndroidUtilities.dp(24)
            chip_x = int(chat.left) + AndroidUtilities.dp(16)
            chips = []
            if bool(self.get_setting("blur_enabled", True)):
                chips.append(self._tr("размытие", "blur"))
            if bool(self.get_setting("slide_enabled", True)):
                chips.append(self._tr("движение", "motion"))
            if bool(self.get_setting("liquid_cursor_enabled", False)):
                chips.append(self._tr("жидкий курсор", "liquid cursor"))
            chip_row_right = int(chat.right) - AndroidUtilities.dp(16)
            for chip in chips[:3]:
                available_w = chip_row_right - chip_x
                if available_w < AndroidUtilities.dp(42):
                    break
                chip = self._ellipsize_preview_text(chip, chip_text, available_w - AndroidUtilities.dp(18))
                if not chip:
                    break
                chip_w = min(int(chip_text.measureText(chip)) + AndroidUtilities.dp(18), available_w)
                rect = RectF(float(chip_x), float(chip_y - AndroidUtilities.dp(16)), float(chip_x + chip_w), float(chip_y + AndroidUtilities.dp(5)))
                self._draw_round_rect(canvas, chip_paint, rect, AndroidUtilities.dp(10), self._argb_with_opacity(accent, 10))
                canvas.drawText(chip, float(chip_x + AndroidUtilities.dp(9)), float(chip_y), chip_text)
                chip_x += chip_w + AndroidUtilities.dp(6)
        except Exception as error:
            self._log(f"Settings preview draw error: {error}")

    def _slider_factory(
        self,
        key: str,
        title: str,
        default,
        min_value,
        max_value,
        suffix: str = "",
        decimals: int = 0,
    ):
        from ui.settings import SimpleSettingFactory

        plugin = self
        refs = []
        min_float = float(min_value)
        max_float = float(max_value)

        def current_value():
            if decimals <= 0:
                return plugin._setting_int_clamped(key, int(default), int(min_value), int(max_value))
            return plugin._setting_float_clamped(key, float(default), min_float, max_float)

        def normalize(value):
            if decimals <= 0:
                return str(int(round(float(value))))
            return f"{float(value):.{decimals}f}"

        def format_value(value):
            text = normalize(value)
            return f"{text} {suffix}" if suffix else text

        def progress_to_value(progress):
            raw = min_float + (max_float - min_float) * float(progress)
            if decimals <= 0:
                return int(round(raw))
            step = 10 ** decimals
            return round(raw * step) / step

        def create_view(context, list_view, current_account, class_guid, resources_provider):
            Gravity = jclass("android.view.Gravity")
            LinearLayout = jclass("android.widget.LinearLayout")
            AndroidUtilities = jclass("org.telegram.messenger.AndroidUtilities")
            LayoutHelper = jclass("org.telegram.ui.Components.LayoutHelper")
            SeekBarView = jclass("org.telegram.ui.Components.SeekBarView")
            Theme = jclass("org.telegram.ui.ActionBar.Theme")

            root = LinearLayout(context)
            root.setOrientation(LinearLayout.VERTICAL)
            root.setPadding(AndroidUtilities.dp(21), AndroidUtilities.dp(10), AndroidUtilities.dp(21), AndroidUtilities.dp(12))

            row = LinearLayout(context)
            row.setOrientation(LinearLayout.HORIZONTAL)
            row.setGravity(Gravity.CENTER_VERTICAL)

            title_view = plugin._settings_text(
                context,
                title,
                16,
                plugin._settings_theme_color(Theme.key_windowBackgroundWhiteBlackText, resources_provider, 0xFF111111),
            )
            row.addView(title_view, LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0))

            value_view = plugin._settings_text(
                context,
                format_value(current_value()),
                14,
                plugin._settings_theme_color(Theme.key_windowBackgroundWhiteBlueText, resources_provider, 0xFF3390EC),
                True,
            )
            row.addView(value_view, LayoutHelper.createLinear(-2, -2))
            root.addView(row, LayoutHelper.createLinear(-1, -2))

            seek = SeekBarView(context, resources_provider)
            seek.setReportChanges(True)
            try:
                seek.setColors(
                    plugin._settings_theme_color(Theme.key_switchTrack, resources_provider, 0x33000000),
                    plugin._settings_theme_color(Theme.key_windowBackgroundWhiteBlueText, resources_provider, 0xFF3390EC),
                )
            except Exception:
                pass
            root.addView(seek, LayoutHelper.createLinear(-1, 38, 0, 2, 0, 0, 0))

            delegate_cls = jclass("org.telegram.ui.Components.SeekBarView$SeekBarViewDelegate")

            class _SliderDelegate(dynamic_proxy(delegate_cls)):
                def onSeekBarDrag(self, stop, progress):
                    value = progress_to_value(progress)
                    value = max(min_float, min(max_float, float(value)))
                    setting_value = normalize(value)
                    try:
                        value_view.setText(format_value(value))
                    except Exception:
                        pass
                    plugin.set_setting(key, setting_value)
                    plugin._sync_settings_to_dex()
                    plugin._invalidate_settings_preview()

                def onSeekBarPressed(self, pressed):
                    return None

                def getContentDescription(self):
                    return f"{title}: {format_value(current_value())}"

                def getStepsCount(self):
                    if decimals <= 0:
                        return int(max_float - min_float)
                    return int((max_float - min_float) * (10 ** decimals))

                def needVisuallyDivideSteps(self):
                    return False

            delegate = _SliderDelegate()
            refs.append(delegate)
            seek.setDelegate(delegate)
            return root

        def bind_view(view, item, divider, adapter, list_view):
            value = current_value()
            progress = 0.0 if max_float == min_float else float(float(value) - min_float) / float(max_float - min_float)
            try:
                view.getChildAt(0).getChildAt(1).setText(format_value(value))
                view.getChildAt(1).setProgress(progress)
            except Exception:
                pass

        return SimpleSettingFactory(create_view, bind_view, is_clickable=False, is_shadow=False)

    def _dex_delete_factory(self):
        from ui.settings import SimpleSettingFactory

        plugin = self

        def create_view(context, list_view, current_account, class_guid, resources_provider):
            Gravity = jclass("android.view.Gravity")
            LinearLayout = jclass("android.widget.LinearLayout")
            ImageView = jclass("android.widget.ImageView")
            AndroidUtilities = jclass("org.telegram.messenger.AndroidUtilities")
            LayoutHelper = jclass("org.telegram.ui.Components.LayoutHelper")
            Theme = jclass("org.telegram.ui.ActionBar.Theme")
            R = jclass("org.telegram.messenger.R")

            root = LinearLayout(context)
            root.setOrientation(LinearLayout.HORIZONTAL)
            root.setGravity(Gravity.CENTER_VERTICAL)
            root.setPadding(AndroidUtilities.dp(21), AndroidUtilities.dp(11), AndroidUtilities.dp(21), AndroidUtilities.dp(11))

            icon = ImageView(context)
            try:
                icon.setImageResource(R.drawable.msg_clear)
            except Exception:
                pass
            call_int_color(
                icon,
                "setColorFilter",
                plugin._settings_theme_color(Theme.key_text_RedRegular, resources_provider, 0xFFE53935),
            )
            root.addView(icon, LayoutHelper.createLinear(24, 24, 0, 0, 0, 18, 0))

            text_col = LinearLayout(context)
            text_col.setOrientation(LinearLayout.VERTICAL)

            title = plugin._settings_text(
                context,
                plugin._tr("Удалить DEX", "Delete DEX"),
                16,
                plugin._settings_theme_color(Theme.key_text_RedRegular, resources_provider, 0xFFE53935),
                True,
            )
            text_col.addView(title, LayoutHelper.createLinear(-1, -2))

            subtitle = plugin._settings_text(
                context,
                plugin._tr("Выгрузить ядро и удалить animation_core.dex", "Unload the core and delete animation_core.dex"),
                13,
                plugin._settings_theme_color(Theme.key_dialogTextGray3, resources_provider, 0xFF777777),
            )
            subtitle.setSingleLine(False)
            text_col.addView(subtitle, LayoutHelper.createLinear(-1, -2, 0, 2, 0, 0, 0))
            root.addView(text_col, LayoutHelper.createLinear(0, -2, 1.0))
            return root

        def bind_view(view, item, divider, adapter, list_view):
            try:
                text_col = view.getChildAt(1)
                text_col.getChildAt(0).setText(plugin._tr("Удалить DEX", "Delete DEX"))
                text_col.getChildAt(1).setText(plugin._tr(
                    "Выгрузить ядро и удалить animation_core.dex",
                    "Unload the core and delete animation_core.dex",
                ))
            except Exception:
                pass

        def on_click(_plugin, item, view):
            plugin._confirm_delete_dex()

        return SimpleSettingFactory(create_view, bind_view, is_clickable=True, is_shadow=False, on_click=on_click)

    def create_settings(self) -> list[Any]:
        on_change = self._on_setting_change
        self._settings_factories = []
        self._settings_preview_delegates = []
        self._settings_preview_views = []
        is_loaded = self.dex_loader is not None and self.dex_loader.is_loaded()
        dex_status = self._tr(
            "Ядро анимаций подключено" if is_loaded else "Ядро не подключено",
            "Animation core is connected" if is_loaded else "Core is not connected",
        )
        dex_controls = []
        if self._has_installed_dex():
            dex_controls.append(Custom(factory=self._keep_settings_factory(self._dex_delete_factory())))

        def slider(key, title_ru, title_en, default, min_value, max_value, suffix="", decimals=0):
            return Custom(factory=self._keep_settings_factory(self._slider_factory(
                key,
                self._tr(title_ru, title_en),
                default,
                min_value,
                max_value,
                suffix,
                decimals,
            )))

        return [
            Header(self._tr("Состояние", "Status")),
            Switch(
                key="enabled",
                text=self._tr("Включить анимации ввода", "Enable typing animations"),
                default=True,
                icon="msg_photo_curve",
                on_change=on_change,
            ),
            Text(text=dex_status, icon="msg_download"),
            *dex_controls,
            Divider(self._tr(
                "DEX ставится один раз: найдите text_animation.dex нажмите на файл",
                "Install the DEX once: find text_animation.dex tap the file",
            )),
            Custom(factory=self._keep_settings_factory(self._live_preview_factory())),

            Header(self._tr("Поведение текста", "Text behavior")),
            Switch(
                key="animate_all_lines",
                text=self._tr("Анимировать каждую строку", "Animate every line"),
                default=True,
                icon="msg_list",
                on_change=on_change,
            ),
            Switch(
                key="ignore_spaces",
                text=self._tr("Игнорировать пробелы", "Ignore spaces"),
                default=True,
                icon="msg_message",
                on_change=on_change,
            ),
            slider("duration", "Темп появления", "Appearance tempo", 300, 80, 900, self._tr("мс", "ms")),

            Header(self._tr("Мягкое появление", "Soft appearance")),
            Switch(
                key="blur_enabled",
                text=self._tr("Появляться из размытия", "Fade in from blur"),
                default=True,
                icon="msg_photo_blur",
                on_change=on_change,
            ),
            slider("blur_duration", "Длительность размытия", "Blur duration", 300, 80, 900, self._tr("мс", "ms")),
