# Файл сгенерирован catalib (https://github.com/cataIystdev/catalib) из модульного дерева исходников.
# Редактировать вручную не следует: правьте исходники и пересоберите.
__id__ = 'read_notification'
__name__ = 'Read Receipt Notify'
__version__ = '1.0.0'
__description__ = 'Уведомления о прочтении ваших сообщений в личных чатах exteraGram: системное в шторку, пуш-уведомление или всплывашка в стиле темы Telegram. По тапу — открывает чат.'
__author__ = '@catalystdevplugins'
__icon__ = 'project_mugen/2'
__app_version__ = '>=12.5.1'

"""Встраиваемый загрузчик модульного плагина.

Исходник этого модуля целиком встраивается в собранный ``<plugin_id>.py``.
Он не зависит ни от чего, кроме стандартной библиотеки, и не порождает
процессы (подпроцессы в Chaquopy недоступны).

Идея: собранный файл импортируется exteraGram как модуль ``<plugin_id>``.
Этот модуль объявляется пакетом, а все исходные модули плагина
регистрируются как его подмодули ``<plugin_id>.<имя>`` через собственный
finder в ``sys.meta_path``. Имена уникальны, так как ``<plugin_id>``
уникален в exteraGram. Каждый модуль компилируется с собственным origin и
регистрируется в ``linecache`` — трейсбеки указывают на исходные файлы.
"""

import importlib
import importlib.util
import linecache
import sys

#: Ключ в ``sources``: значение — кортеж ``(исходник, признак_пакета, origin)``.
#: Ключи — полные рантайм-имена модулей (``<plugin_id>`` и ``<plugin_id>.*``).


class _CatalibLoader:
    """Загрузчик одного встроенного модуля из строки-исходника."""

    def __init__(self, plugin_id, source, origin, is_package):
        self._catalib_plugin = plugin_id
        self._source = source
        self._origin = origin
        self._is_package = is_package

    def create_module(self, spec):
        """Использовать стандартное создание модуля."""
        return None

    def exec_module(self, module):
        """Зарегистрировать исходник в linecache и исполнить модуль."""
        linecache.cache[self._origin] = (
            len(self._source),
            None,
            self._source.splitlines(keepends=True),
            self._origin,
        )
        # Пометка: модуль создан встроенным загрузчиком из этого плагина.
        # По ней при следующей загрузке вычищается устаревшая вендоренная
        # копия (общее имя catalib.* в sys.modules между деплоями).
        module.__catalib_vendored__ = self._catalib_plugin
        code = compile(self._source, self._origin, "exec")
        exec(code, module.__dict__)


class _CatalibFinder:
    """Finder в ``sys.meta_path``, отдающий подмодули конкретного плагина."""

    def __init__(self, plugin_id, sources):
        self._catalib_plugin = plugin_id
        self._sources = sources

    def find_spec(self, fullname, path=None, target=None):
        """Вернуть spec для встроенного подмодуля плагина либо ``None``."""
        entry = self._sources.get(fullname)
        if entry is None or fullname == self._catalib_plugin:
            return None
        source, is_package, origin = entry
        loader = _CatalibLoader(self._catalib_plugin, source, origin, is_package)
        return importlib.util.spec_from_loader(
            fullname, loader, origin=origin, is_package=is_package
        )


def _find_plugin_class(namespace, entry_module_name):
    """Найти класс плагина, определённый в модуле точки входа.

    Учитываются только классы, объявленные именно в модуле ``entry_module_name``
    (импортированные ``CatalibPlugin``/``BasePlugin`` и т. п. исключаются по
    ``__module__``). Принадлежность к плагину определяется строгой проверкой
    через ``base_plugin.BasePlugin``, а при отсутствии SDK — по именам базовых
    классов в MRO.
    """
    base_cls = None
    try:
        import base_plugin

        base_cls = base_plugin.BasePlugin
    except Exception:
        base_cls = None

    candidates = []
    for value in namespace.values():
        if not isinstance(value, type):
            continue
        if getattr(value, "__module__", None) != entry_module_name:
            continue
        if base_cls is not None:
            if issubclass(value, base_cls) and value is not base_cls:
                candidates.append(value)
        else:
            base_names = {klass.__name__ for klass in value.__mro__[1:]}
            if base_names & {"BasePlugin", "CatalibPlugin"}:
                candidates.append(value)
    for value in candidates:
        if getattr(value, "__catalib_plugin__", False):
            return value
    return candidates[0] if candidates else None


def catalib_install(module_name, module_globals, sources, entry_fullname):
    """Активировать встроенный загрузчик плагина.

    :param module_name: имя верхнего модуля (``<plugin_id>``).
    :param module_globals: ``globals()`` собранного модуля.
    :param sources: отображение «полное имя -> (исходник, пакет?, origin)».
    :param entry_fullname: полное имя модуля точки входа.
    """
    # Снять прежние finder'ы и подмодули этого плагина (безопасный reload).
    sys.meta_path[:] = [
        f for f in sys.meta_path if getattr(f, "_catalib_plugin", None) != module_name
    ]
    prefix = module_name + "."
    for name in [n for n in sys.modules if n.startswith(prefix)]:
        del sys.modules[name]

    # Вычистить устаревшие вендоренные модули (catalib.support и т. п.):
    # имя catalib.* общее между плагинами, и в общем sys.modules могла
    # остаться копия из прошлого деплоя/другого плагина (в т. ч. собранная
    # старым загрузчиком без пометки). Признак вендоренного модуля —
    # пометка __catalib_vendored__ ИЛИ синтетический origin вида
    # "<...>" (его ставит встроенный загрузчик). Настоящий host-catalib
    # (тесты) имеет origin-путь файла и не трогается.
    def _is_vendored(mod):
        if getattr(mod, "__catalib_vendored__", None) is not None:
            return True
        spec = getattr(mod, "__spec__", None)
        origin = getattr(spec, "origin", None) if spec is not None else None
        return isinstance(origin, str) and origin.startswith("<")

    for name in [
        n
        for n, mod in list(sys.modules.items())
        if (n == "catalib" or n.startswith("catalib.")) and _is_vendored(mod)
    ]:
        del sys.modules[name]

    sys.meta_path.insert(0, _CatalibFinder(module_name, sources))

    # Метаданные плагина задаются литералом ``__name__ = "<display>"``, что
    # перетирает реальное имя модуля и ломает относительные импорты.
    # Восстанавливаем идентичность модуля и делаем его пакетом.
    module_globals["__name__"] = module_name
    module_globals["__package__"] = module_name
    module_globals.setdefault("__path__", [])
    # Согласовать __spec__ с тем, что модуль теперь пакет, иначе Python
    # предупреждает о расхождении __package__ и __spec__.parent.
    spec = module_globals.get("__spec__")
    if spec is not None and getattr(spec, "submodule_search_locations", None) is None:
        spec.submodule_search_locations = []

    # Тело корневого модуля (src/__init__.py) исполнить в этом же модуле.
    root = sources.get(module_name)
    if root is not None:
        source, _is_package, origin = root
        linecache.cache[origin] = (
            len(source),
            None,
            source.splitlines(keepends=True),
            origin,
        )
        exec(compile(source, origin, "exec"), module_globals)

    # Импортировать точку входа и поднять класс плагина на верхний уровень.
    if entry_fullname != module_name:
        entry_module = importlib.import_module(entry_fullname)
        plugin_class = _find_plugin_class(vars(entry_module), entry_fullname)
        if plugin_class is not None and plugin_class.__name__ not in module_globals:
            module_globals[plugin_class.__name__] = plugin_class

_CATALIB_SOURCES = {
    'read_notification': ('"""Пакет плагина Read Receipt Notify.\n\nСодержит чистые доменные слои (``core``, ``util``), оркестрацию\n(``services``), декларативную схему настроек (``ui``), обёртки над SDK\nexteraGram и Android API (``infra``) и точку входа (``plugin``).\n\nТочка входа задаётся в ``catalib.toml`` параметром ``entry = "plugin"``.\ncatalib собирает этот пакет в один файл ``read_notification.py`` и\nвстраивает рантайм-загрузчик, который поднимает относительные импорты.\n"""\n', True, '<read_notification>/__init__.py'),
    'read_notification.config': ('"""Константы плагина Read Receipt Notify.\n\nСюда вынесены значения, разделяемые между слоями, чтобы избежать\nмагических строк и обеспечить единственный источник истины.\n"""\n\nfrom __future__ import annotations\n\nfrom typing import Final\n\n# Префикс логов — общий для всех слоёв плагина.\nLOG_PREFIX: Final[str] = "[read_notification]"\n\n# Идентификатор и заголовки канала Android-уведомлений.\n#\n# Имеется два канала с разной ``importance``: «обычный» (без heads-up,\n# только в шторку) и «пуш» (heads-up — всплывает поверх экрана). Канал\n# выбирается в зависимости от пользовательской настройки режима.\nNOTIFICATION_CHANNEL_ID: Final[str] = "read_notification_channel"\nNOTIFICATION_CHANNEL_NAME: Final[str] = "Прочтение сообщений"\nNOTIFICATION_CHANNEL_DESCRIPTION: Final[str] = (\n    "Тихое уведомление в шторке: собеседник в личном чате прочитал ваши сообщения."\n)\n\nNOTIFICATION_CHANNEL_ID_PUSH: Final[str] = "read_notification_channel_push"\nNOTIFICATION_CHANNEL_NAME_PUSH: Final[str] = "Прочтение сообщений (пуш)"\nNOTIFICATION_CHANNEL_DESCRIPTION_PUSH: Final[str] = (\n    "Всплывающее уведомление-пуш: собеседник прочитал ваши сообщения."\n)\n\n# Действие Intent для открытия чата. Уникализируется случайной частью при\n# сборке PendingIntent — это согласовано с реализацией\n# org.telegram.messenger.NotificationsController в exteraGram.\nINTENT_OPEN_CHAT_ACTION_PREFIX: Final[str] = "com.tmessages.openchat"\n\n# Ключи настроек плагина (значения хранятся штатным механизмом SDK).\nSETTING_ENABLED: Final[str] = "enabled"\nSETTING_HIDE_WHEN_CHAT_OPEN: Final[str] = "hide_when_chat_open"\nSETTING_RECENT_ONLY_IDX: Final[str] = "recent_only_idx"\nSETTING_EXCLUDED_USER_IDS: Final[str] = "excluded_user_ids"\nSETTING_NOTIFICATION_MODE_IDX: Final[str] = "notification_mode_idx"\n\n# Режимы доставки уведомления о прочтении.\n#\n# 0 — «обычное»: системное уведомление в шторку, без heads-up.\n# 1 — «уведомление + пуш»: системное уведомление + всплывает поверх\n#     экрана (Android heads-up на канале с IMPORTANCE_HIGH).\n# 2 — «только всплывашка»: системного уведомления нет, рисуем\n#     собственный баннер в стиле темы Telegram поверх UI.\nNOTIFICATION_MODE_SYSTEM: Final[int] = 0\nNOTIFICATION_MODE_PUSH: Final[int] = 1\nNOTIFICATION_MODE_OVERLAY: Final[int] = 2\n\n#: Пользовательские подписи режимов для селектора настроек.\nNOTIFICATION_MODE_ITEMS: Final[tuple[str, ...]] = (\n    "Обычное уведомление",\n    "Уведомление + пуш",\n    "Только всплывашка",\n)\n\n# Параметры всплывашки — настройки видны только при выбранном режиме\n# «Только всплывашка». Каждый параметр — селектор с дискретными\n# значениями, потому что в ``ui.settings`` exteraGram нет ползунка.\nSETTING_OVERLAY_DURATION_IDX: Final[str] = "overlay_duration_idx"\nSETTING_OVERLAY_ALPHA_IDX: Final[str] = "overlay_alpha_idx"\nSETTING_OVERLAY_SIDE_MARGIN_IDX: Final[str] = "overlay_side_margin_idx"\n\n#: Подписи и значения длительности показа всплывашки.\nOVERLAY_DURATION_ITEMS: Final[tuple[str, ...]] = (\n    "2 секунды",\n    "4 секунды",\n    "6 секунд",\n    "8 секунд",\n    "12 секунд",\n    "Не закрывать автоматически",\n)\nOVERLAY_DURATION_MS_BY_IDX: Final[tuple[int, ...]] = (\n    2_000,\n    4_000,\n    6_000,\n    8_000,\n    12_000,\n    0,\n)\n\n#: Подписи и значения прозрачности (умножитель альфы).\nOVERLAY_ALPHA_ITEMS: Final[tuple[str, ...]] = (\n    "25%",\n    "50%",\n    "75%",\n    "90%",\n    "100%",\n)\nOVERLAY_ALPHA_BY_IDX: Final[tuple[float, ...]] = (\n    0.25,\n    0.50,\n    0.75,\n    0.90,\n    1.00,\n)\n\n#: Подписи и значения боковых отступов (dp).\nOVERLAY_SIDE_MARGIN_ITEMS: Final[tuple[str, ...]] = (\n    "0 (на всю ширину)",\n    "8 dp",\n    "16 dp",\n    "24 dp",\n    "32 dp",\n    "48 dp",\n)\nOVERLAY_SIDE_MARGIN_DP_BY_IDX: Final[tuple[int, ...]] = (0, 8, 16, 24, 32, 48)\n\nDEFAULT_OVERLAY_DURATION_IDX: Final[int] = 1\nDEFAULT_OVERLAY_ALPHA_IDX: Final[int] = 4\nDEFAULT_OVERLAY_SIDE_MARGIN_IDX: Final[int] = 2\n\n# Значения настроек по умолчанию.\nDEFAULT_ENABLED: Final[bool] = True\nDEFAULT_HIDE_WHEN_CHAT_OPEN: Final[bool] = True\nDEFAULT_RECENT_ONLY_IDX: Final[int] = 0\nDEFAULT_EXCLUDED_USER_IDS: Final[str] = ""\nDEFAULT_NOTIFICATION_MODE_IDX: Final[int] = NOTIFICATION_MODE_PUSH\n\n# Варианты селектора «свежести». Индекс хранится в настройках,\n# значение в секундах — в `RECENT_ONLY_SECONDS_BY_IDX`. Нулевое\n# значение означает «без ограничения».\nRECENT_ONLY_ITEMS: Final[tuple[str, ...]] = (\n    "всегда",\n    "не старше 5 минут",\n    "не старше 15 минут",\n    "не старше 1 часа",\n    "не старше 3 часов",\n    "не старше 12 часов",\n)\nRECENT_ONLY_SECONDS_BY_IDX: Final[tuple[int, ...]] = (\n    0,\n    5 * 60,\n    15 * 60,\n    60 * 60,\n    3 * 60 * 60,\n    12 * 60 * 60,\n)\n\n# Имя FQN класса LaunchActivity для построения Intent.\nLAUNCH_ACTIVITY_FQN: Final[str] = "org.telegram.ui.LaunchActivity"\n\n# Имя класса фрагмента чата, используется для проверки переднего плана.\nCHAT_ACTIVITY_FQN: Final[str] = "org.telegram.ui.ChatActivity"\n', False, '<read_notification>/config.py'),
    'read_notification.core': ('"""Доменный слой плагина.\n\nСодержит чистую логику без зависимостей от Android и SDK exteraGram:\n\n- :mod:`.dialog` — утилиты для идентификации личных диалогов.\n- :mod:`.read_event` — иммутабельная модель события прочтения.\n- :mod:`.outbox_tracker` — потокобезопасный in-memory трекер\n  отправленных, но ещё не прочитанных сообщений.\n\nВсе модули этого слоя должны быть импортируемы и тестируемы без\nexteraGram и Java-зависимостей.\n"""\n', True, '<read_notification>/core/__init__.py'),
    'read_notification.core.dialog': ('"""Утилиты идентификации диалогов и пиров TLRPC.\n\nПлагин работает только с личными чатами. Здесь сосредоточена логика,\nкоторая защитно извлекает ``user_id`` собеседника из объекта пира\nTLRPC и отвергает чаты, каналы и любые непригодные значения.\n\nИдентификация устроена ступенчато:\n\n1. Если у объекта есть атрибут ``chat_id`` или ``channel_id`` —\n   это не личный чат. Возвращается ``None``.\n2. Иначе считывается ``user_id``; при положительном целом — возвращается.\n3. Иначе — ``None``.\n\nТакой подход не зависит ни от точного имени класса\n(``TL_peerUser`` / ``TLRPC$TL_peerUser`` / Python-обёртки Chaquopy могут\nдавать разные ``__name__``), ни от наличия рефлексии SDK.\n"""\n\nfrom __future__ import annotations\n\nfrom typing import Any\n\n\ndef extract_private_user_id(peer: Any) -> int | None:\n    """Вернуть ``user_id`` собеседника, если пир — личный чат.\n\n    :param peer: объект ``TLRPC.Peer`` (например, ``TL_peerUser``);\n        допустимо передать ``None``.\n    :returns: положительное целое — id пользователя — или ``None``,\n        если ``peer`` не соответствует личному чату или содержит\n        неподходящее значение.\n    """\n    if peer is None:\n        return None\n    # Чат или канал — заведомо не личный диалог.\n    if _has_positive_attr(peer, "chat_id"):\n        return None\n    if _has_positive_attr(peer, "channel_id"):\n        return None\n    user_id = getattr(peer, "user_id", None)\n    if not isinstance(user_id, int):\n        return None\n    if user_id <= 0:\n        return None\n    return user_id\n\n\ndef is_private_peer(peer: Any) -> bool:\n    """Удобный логический алиас над :func:`extract_private_user_id`.\n\n    :param peer: объект пира.\n    :returns: ``True``, если ``peer`` представляет личный чат.\n    """\n    return extract_private_user_id(peer) is not None\n\n\ndef _has_positive_attr(obj: Any, name: str) -> bool:\n    """Есть ли у объекта целочисленный атрибут с положительным значением.\n\n    Java-классы TLRPC в Chaquopy всегда имеют объявленные поля как\n    атрибуты Python-обёртки (даже если значение ``0`` / ``null``).\n    Поэтому одного ``hasattr`` мало — проверяем именно «значение есть и\n    оно положительное».\n    """\n    value = getattr(obj, name, None)\n    return isinstance(value, int) and value > 0\n', False, '<read_notification>/core/dialog.py'),
    'read_notification.core.outbox_tracker': ('"""In-memory трекер отправленных, но ещё не прочитанных сообщений.\n\nХранит для каждой пары ``(account, user_id)`` упорядоченный по\n``msg_id`` список записей ``OutgoingEntry``. Доступ потокобезопасен:\nобновления приходят из обработчиков TL-апдейтов, которые в Chaquopy\nвполне могут пересечься между разными аккаунтами.\n\nТрекер сознательно in-memory и без персистентности: данные имеют смысл\nтолько в рамках живого процесса exteraGram. После рестарта приложение\nгарантированно получает свежий поток обновлений, а собирать\n«исторические» прочтения мы не обещаем (см. Implementation Plan).\n"""\n\nfrom __future__ import annotations\n\nimport bisect\nimport threading\nfrom dataclasses import dataclass\n\n\n@dataclass(frozen=True, slots=True)\nclass OutgoingEntry:\n    """Одно отправленное сообщение, ожидающее прочтения.\n\n    :param msg_id: серверный id сообщения (TL ``message.id``).\n    :param date_epoch: дата отправки в Unix epoch секундах.\n    """\n\n    msg_id: int\n    date_epoch: int\n\n\n@dataclass(frozen=True, slots=True)\nclass ConsumeResult:\n    """Результат снятия записей с трекера до указанного ``max_id``.\n\n    :param count: количество удалённых записей.\n    :param last_msg_id: ``msg_id`` самой свежей удалённой записи; ``None``\n        если ничего не удалено.\n    :param last_date_epoch: дата самой свежей удалённой записи; ``None``\n        если ничего не удалено.\n    """\n\n    count: int\n    last_msg_id: int | None\n    last_date_epoch: int | None\n\n\nclass OutgoingTracker:\n    """Потокобезопасный трекер отправленных сообщений.\n\n    Все операции работают за O(log n) на диалог: список записей всегда\n    хранится отсортированным по ``msg_id``, вставка и снятие выполняются\n    через ``bisect``.\n    """\n\n    def __init__(self) -> None:\n        self._by_dialog: dict[tuple[int, int], list[OutgoingEntry]] = {}\n        self._lock = threading.Lock()\n\n    def register(self, account: int, user_id: int, msg_id: int, date_epoch: int) -> bool:\n        """Запомнить отправленное сообщение в диалоге.\n\n        Идемпотентно по ``msg_id``: повторная регистрация того же id\n        ничего не делает. Защищает от двойных событий ``updateNewMessage``,\n        которые иногда приходят в обновлениях-контейнерах.\n\n        :param account: номер аккаунта.\n        :param user_id: id собеседника (положительный).\n        :param msg_id: id сообщения (положительный).\n        :param date_epoch: дата отправки в Unix epoch секундах.\n        :returns: ``True`` — сообщение добавлено впервые; ``False`` —\n            запись уже была или вход некорректный (полезно для\n            диагностики, чтобы не логировать дубликаты).\n        """\n        if account < 0 or user_id <= 0 or msg_id <= 0:\n            return False\n        key = (account, user_id)\n        with self._lock:\n            entries = self._by_dialog.setdefault(key, [])\n            idx = bisect.bisect_left(entries, msg_id, key=lambda e: e.msg_id)\n            if idx < len(entries) and entries[idx].msg_id == msg_id:\n                return False\n            entries.insert(idx, OutgoingEntry(msg_id, int(date_epoch)))\n            return True\n\n    def consume_up_to(self, account: int, user_id: int, max_id: int) -> ConsumeResult:\n        """Снять с трекера все записи с ``msg_id ≤ max_id``.\n\n        :param account: номер аккаунта.\n        :param user_id: id собеседника.\n        :param max_id: верхняя граница (включительно).\n        :returns: :class:`ConsumeResult` с количеством удалённых записей\n            и метаданными последней удалённой.\n        """\n        if account < 0 or user_id <= 0 or max_id <= 0:\n            return ConsumeResult(0, None, None)\n        key = (account, user_id)\n        with self._lock:\n            entries = self._by_dialog.get(key)\n            if not entries:\n                return ConsumeResult(0, None, None)\n            split = bisect.bisect_right(entries, max_id, key=lambda e: e.msg_id)\n            if split == 0:\n                return ConsumeResult(0, None, None)\n            consumed = entries[:split]\n            remaining = entries[split:]\n            if remaining:\n                self._by_dialog[key] = remaining\n            else:\n                self._by_dialog.pop(key, None)\n        last = consumed[-1]\n        return ConsumeResult(len(consumed), last.msg_id, last.date_epoch)\n\n    def forget_dialog(self, account: int, user_id: int) -> None:\n        """Сбросить все записи диалога.\n\n        :param account: номер аккаунта.\n        :param user_id: id собеседника.\n        """\n        with self._lock:\n            self._by_dialog.pop((account, user_id), None)\n\n    def len_for(self, account: int, user_id: int) -> int:\n        """Размер очереди диалога.\n\n        :param account: номер аккаунта.\n        :param user_id: id собеседника.\n        :returns: количество записей; ``0`` если диалог не отслеживается.\n        """\n        with self._lock:\n            return len(self._by_dialog.get((account, user_id), ()))\n\n    def clear(self) -> None:\n        """Очистить весь трекер; вызывается при выгрузке плагина."""\n        with self._lock:\n            self._by_dialog.clear()\n', False, '<read_notification>/core/outbox_tracker.py'),
    'read_notification.core.read_event': ('"""Доменная модель события «собеседник прочитал ваши сообщения».\n\nОбъект ``ReadEvent`` — единственный канал передачи фактов прочтения\nнаружу из доменного слоя. Иммутабельный, поэтому может свободно\nпрокидываться между потоками и логироваться без копирования.\n"""\n\nfrom __future__ import annotations\n\nfrom dataclasses import dataclass\n\n\n@dataclass(frozen=True, slots=True)\nclass ReadEvent:\n    """Факт того, что собеседник прочитал отправленные вами сообщения.\n\n    :param account: номер аккаунта exteraGram, в рамках которого\n        произошло событие (обычно 0; поддерживается мульти-аккаунт).\n    :param user_id: положительный id собеседника (всегда соответствует\n        ``TL_peerUser.user_id``).\n    :param count: количество сообщений, ставших прочитанными за это\n        событие (≥ 1).\n    :param last_msg_id: ``message.id`` самого «свежего» прочитанного\n        сообщения (наибольший id среди ставших прочитанными).\n    :param last_date_epoch: дата отправки сообщения с ``last_msg_id``\n        в Unix epoch секундах.\n    :param now_epoch: время обработки события в Unix epoch секундах;\n        используется для фильтра «свежести» прочтения.\n    """\n\n    account: int\n    user_id: int\n    count: int\n    last_msg_id: int\n    last_date_epoch: int\n    now_epoch: int\n\n    def age_seconds(self) -> int:\n        """Сколько секунд прошло между отправкой сообщения и прочтением.\n\n        :returns: разница ``now_epoch - last_date_epoch``, но не меньше нуля.\n            Часы устройства иногда уходят вперёд — в этом случае\n            возвращается ноль, чтобы фильтры по «свежести» не отбрасывали\n            заведомо новые сообщения.\n        """\n        diff = self.now_epoch - self.last_date_epoch\n        return diff if diff >= 0 else 0\n', False, '<read_notification>/core/read_event.py'),
    'read_notification.infra': ('"""Инфраструктурный слой плагина.\n\nСодержит обёртки над SDK exteraGram и Android-framework:\n\n- :mod:`.time_provider` — инжектируемый источник времени.\n- :mod:`.user_resolver` — имя собеседника через ``MessagesController``.\n- :mod:`.foreground_state` — определение, открыт ли сейчас данный чат.\n- :mod:`.intent_factory` — построение ``PendingIntent`` на ``LaunchActivity``.\n- :mod:`.android_notification` — публикация/обновление/сброс\n  нативного Android-уведомления.\n\nНа устройстве модули обращаются к реальному SDK; в офлайн-окружении\nметоды безопасно возвращают «пустые» значения (``None``, ``""``,\n``False``) и не падают на отсутствии Java-классов.\n"""\n', True, '<read_notification>/infra/__init__.py'),
    'read_notification.infra.android_notification': ('"""Публикация и сброс нативных Android-уведомлений.\n\nОдин канал ``read_notification_channel``, идентификатор уведомления —\nстабильная 31-битная свёртка от пары ``(account, user_id)``. Благодаря\nэтому повторные публикации обновляют **тот же** баннер в шторке.\n\nИспользуется системный ``android.app.NotificationManager``: он есть на\nвсех версиях Android, не требует наличия androidx.core и стабильно\nработает в окружении Chaquopy.\n\nОфлайн (без SDK) все методы — безопасные no-op.\n"""\n\nfrom __future__ import annotations\n\nfrom collections.abc import Callable\nfrom typing import Any, Protocol\n\nfrom catalib.support import find_class\n\nfrom ..config import (\n    NOTIFICATION_CHANNEL_DESCRIPTION,\n    NOTIFICATION_CHANNEL_DESCRIPTION_PUSH,\n    NOTIFICATION_CHANNEL_ID,\n    NOTIFICATION_CHANNEL_ID_PUSH,\n    NOTIFICATION_CHANNEL_NAME,\n    NOTIFICATION_CHANNEL_NAME_PUSH,\n)\nfrom ..core.read_event import ReadEvent\nfrom ..util.formatting import format_notification_body, format_notification_title\nfrom .diag import Diag\nfrom .intent_factory import ChatIntentFactory\n\n\nclass Notifier(Protocol):\n    """Контракт компонента, публикующего уведомление о прочтении."""\n\n    def show(self, event: ReadEvent, user_name: str) -> None:  # pragma: no cover - протокол\n        """Опубликовать или обновить уведомление по событию прочтения."""\n\n    def cancel(self, account: int, user_id: int) -> None:  # pragma: no cover - протокол\n        """Снять уведомление, ранее опубликованное для этой пары."""\n\n\ndef stable_notification_id(account: int, user_id: int) -> int:\n    """Стабильный 31-битный id уведомления для пары ``(account, user_id)``.\n\n    Android требует ``int``. Простая биективная свёртка обеспечивает\n    устойчивое обновление одного и того же уведомления.\n\n    :param account: номер аккаунта.\n    :param user_id: id собеседника.\n    :returns: положительное 31-битное целое.\n    """\n    mixed = (int(account) * 0x9E3779B1) ^ (int(user_id) * 0x85EBCA77)\n    return mixed & 0x7FFFFFFF\n\n\nclass AndroidNotifier:\n    """Реализация :class:`Notifier` через системный ``NotificationManager``.\n\n    :param context_provider: callable, возвращающий ``Context`` приложения.\n    :param intent_factory: :class:`ChatIntentFactory` для PendingIntent.\n    :param diag: журнал диагностики.\n    :param channel_id: id канала уведомлений.\n    :param channel_name: видимое имя канала в системных настройках.\n    :param channel_description: описание канала.\n    """\n\n    def __init__(\n        self,\n        context_provider: Callable[[], Any],\n        intent_factory: ChatIntentFactory,\n        diag: Diag,\n    ) -> None:\n        self._context_provider = context_provider\n        self._intent_factory = intent_factory\n        self._diag = diag\n        # Создаём ОБА канала: «тихий» (DEFAULT) для режима обычного\n        # уведомления и «пуш» (HIGH) для режима с heads-up.\n        self._channels_ready = False\n\n    def ensure_channel(self) -> bool:\n        """Создать оба канала уведомлений: тихий и пуш.\n\n        :returns: ``True`` — оба канала созданы (или Android < 8, где\n            каналы не нужны).\n        """\n        if self._channels_ready:\n            return True\n        try:\n            context = self._context_provider()\n        except Exception as exc:\n            self._diag.write("ensure_channel: context error", error=repr(exc))\n            return False\n        if context is None:\n            self._diag.write("ensure_channel: no context")\n            return False\n        try:\n            from android.app import NotificationChannel, NotificationManager\n            from android.os import Build\n\n            sdk_int = int(Build.VERSION.SDK_INT)\n            if sdk_int < 26:\n                self._channels_ready = True\n                self._diag.write("ensure_channel: pre-O, no channel needed", sdk_int=sdk_int)\n                return True\n            manager = context.getSystemService(NotificationManager)\n            if manager is None:\n                self._diag.write("ensure_channel: NotificationManager is None")\n                return False\n            quiet = NotificationChannel(\n                NOTIFICATION_CHANNEL_ID,\n                NOTIFICATION_CHANNEL_NAME,\n                NotificationManager.IMPORTANCE_DEFAULT,\n            )\n            quiet.setDescription(NOTIFICATION_CHANNEL_DESCRIPTION)\n            manager.createNotificationChannel(quiet)\n            push = NotificationChannel(\n                NOTIFICATION_CHANNEL_ID_PUSH,\n                NOTIFICATION_CHANNEL_NAME_PUSH,\n                NotificationManager.IMPORTANCE_HIGH,\n            )\n            push.setDescription(NOTIFICATION_CHANNEL_DESCRIPTION_PUSH)\n            manager.createNotificationChannel(push)\n            self._channels_ready = True\n            self._diag.write(\n                "ensure_channel: created",\n                channel_quiet=NOTIFICATION_CHANNEL_ID,\n                channel_push=NOTIFICATION_CHANNEL_ID_PUSH,\n                sdk_int=sdk_int,\n            )\n            return True\n        except Exception as exc:\n            self._diag.write("ensure_channel: failed", error=repr(exc))\n            return False\n\n    def show(self, event: ReadEvent, user_name: str, *, heads_up: bool = False) -> None:\n        """Опубликовать или обновить уведомление.\n\n        :param event: доменное событие прочтения.\n        :param user_name: имя собеседника (может быть пустым).\n        :param heads_up: ``True`` — публикуем в «пуш»-канал\n            (``IMPORTANCE_HIGH``) с priority high, чтобы Android показал\n            heads-up баннер. ``False`` — тихий канал ``IMPORTANCE_DEFAULT``.\n        """\n        self._diag.write(\n            "show: enter",\n            account=event.account,\n            user_id=event.user_id,\n            count=event.count,\n            heads_up=heads_up,\n        )\n        try:\n            context = self._context_provider()\n        except Exception as exc:\n            self._diag.write("show: context error", error=repr(exc))\n            return\n        if context is None:\n            self._diag.write("show: no context")\n            return\n        if not self.ensure_channel():\n            self._diag.write("show: channel not ready, aborting")\n            return\n        try:\n            from android.app import Notification, NotificationManager\n            from android.os import Build\n\n            small_icon = _small_icon_resource()\n            pending = self._intent_factory.build(event.account, event.user_id)\n            title = format_notification_title(user_name)\n            body = format_notification_body(event.count)\n            channel_id = (\n                NOTIFICATION_CHANNEL_ID_PUSH if heads_up else NOTIFICATION_CHANNEL_ID\n            )\n\n            sdk_int = int(Build.VERSION.SDK_INT)\n            builder = self._make_builder(context, sdk_int, channel_id)\n            builder.setSmallIcon(small_icon)\n            builder.setContentTitle(title)\n            builder.setContentText(body)\n            builder.setAutoCancel(True)\n            builder.setCategory("msg")\n            builder.setWhen(int(event.now_epoch) * 1000)\n            builder.setShowWhen(True)\n            if heads_up:\n                # На API < 26 priority определяет heads-up; на ≥ 26 решает\n                # importance канала. Ставим оба для совместимости.\n                try:\n                    builder.setPriority(Notification.PRIORITY_HIGH)\n                    builder.setDefaults(Notification.DEFAULT_ALL)\n                except Exception:\n                    pass\n            if pending is not None:\n                builder.setContentIntent(pending)\n            if event.count > 1:\n                builder.setNumber(int(event.count))\n\n            notification = builder.build()\n            manager = context.getSystemService(NotificationManager)\n            if manager is None:\n                self._diag.write("show: NotificationManager is None")\n                return\n            notif_id = stable_notification_id(event.account, event.user_id)\n            manager.notify(notif_id, notification)\n            self._diag.write(\n                "show: notified",\n                notif_id=notif_id,\n                small_icon=small_icon,\n                has_pending=pending is not None,\n            )\n        except Exception as exc:\n            self._diag.write("show: failed", error=repr(exc))\n\n    def cancel(self, account: int, user_id: int) -> None:\n        """Снять уведомление, ранее опубликованное для этой пары.\n\n        :param account: номер аккаунта.\n        :param user_id: id собеседника.\n        """\n        try:\n            context = self._context_provider()\n        except Exception as exc:\n            self._diag.write("cancel: context error", error=repr(exc))\n            return\n        if context is None:\n            return\n        try:\n            from android.app import NotificationManager\n\n            manager = context.getSystemService(NotificationManager)\n            if manager is None:\n                return\n            manager.cancel(stable_notification_id(account, user_id))\n        except Exception as exc:\n            self._diag.write("cancel: failed", error=repr(exc))\n\n    def _make_builder(self, context: Any, sdk_int: int, channel_id: str) -> Any:\n        """Построить ``Notification.Builder`` совместимо с версией Android.\n\n        :param context: ``Context`` приложения.\n        :param sdk_int: ``Build.VERSION.SDK_INT``.\n        :param channel_id: id канала, на котором публикуем (используется\n            только на API ≥ 26).\n        """\n        from android.app import Notification\n\n        if sdk_int >= 26:\n            return Notification.Builder(context, channel_id)\n        return Notification.Builder(context)\n\n\ndef _small_icon_resource() -> int:\n    """Идентификатор drawable-ресурса для маленькой иконки уведомления.\n\n    Сначала пытаемся взять ``org.telegram.messenger.R.drawable.notification``\n    (родной приватный ресурс exteraGram), при недоступности — системную\n    ``android.R.drawable.stat_notify_chat``.\n\n    :returns: int — идентификатор ресурса.\n    """\n    for fqn, attr in (\n        ("org.telegram.messenger.R$drawable", "notification"),\n        ("android.R$drawable", "stat_notify_chat"),\n    ):\n        try:\n            cls = find_class(fqn)\n            if cls is None:\n                continue\n            value = getattr(cls, attr, None)\n            if isinstance(value, int) and value != 0:\n                return value\n        except Exception:\n            continue\n    return 0\n', False, '<read_notification>/infra/android_notification.py'),
    'read_notification.infra.diag': ('"""Файловый диагностический лог.\n\nЧасть сборок exteraGram **не пробрасывает** `log()` плагина в `adb logcat`\n(см. подводные камни catalib). Чтобы можно было диагностировать поведение\nплагина на устройстве, мы пишем подробный журнал в файл, лежащий в\n**внешнем** каталоге приложения — ``Context.getExternalFilesDir(None)``.\nЭтот путь читается через ``adb shell``/``adb pull`` без root-прав.\n\nДиагностика безопасна для прод-сборок: один файл с авто-усечением до\n``64 KiB``, без блокирующих операций на UI-потоке, без исключений\nнаружу — любая ошибка записи проглатывается.\n\nОфлайн (без SDK) диагностика становится no-op, что удобно для тестов.\n"""\n\nfrom __future__ import annotations\n\nimport os\nimport threading\nimport time\nfrom collections.abc import Callable\nfrom typing import Any\n\n#: Имя файла журнала.\nDIAG_FILENAME = "read_notification_diag.log"\n\n#: Максимальный размер файла, после которого он усечётся до половины.\n_MAX_BYTES = 64 * 1024\n_TRIM_TO = 32 * 1024\n\n\nclass Diag:\n    """Минимальный thread-safe файловый журнал.\n\n    :param context_provider: callable, возвращающий ``Context`` приложения\n        (``ApplicationLoader.applicationContext``) или ``None`` офлайн.\n    :param tag: префикс строк (по умолчанию ``"diag"``).\n    """\n\n    def __init__(self, context_provider: Callable[[], Any], *, tag: str = "diag") -> None:\n        self._context_provider = context_provider\n        self._tag = tag\n        self._lock = threading.Lock()\n        self._path: str | None = None\n        self._resolved = False\n\n    def write(self, message: str, **fields: Any) -> None:\n        """Записать строку в журнал.\n\n        :param message: основное сообщение (одна строка).\n        :param fields: произвольные именованные значения; будут\n            сериализованы как ``key=value`` через пробел.\n        """\n        try:\n            path = self._resolve_path()\n            if path is None:\n                return\n            payload = self._format(message, fields)\n            with self._lock:\n                self._rotate_if_needed(path)\n                with open(path, "a", encoding="utf-8") as fh:\n                    fh.write(payload)\n        except Exception:  # pragma: no cover - защитный no-op\n            pass\n\n    def path(self) -> str | None:\n        """Полный путь к файлу журнала или ``None``, если SDK недоступен."""\n        return self._resolve_path()\n\n    def _resolve_path(self) -> str | None:\n        if self._resolved:\n            return self._path\n        try:\n            context = self._context_provider()\n            if context is None:\n                self._resolved = True\n                return None\n            ext_dir = context.getExternalFilesDir(None)\n            if ext_dir is None:\n                self._resolved = True\n                return None\n            base = str(ext_dir.getAbsolutePath())\n            os.makedirs(base, exist_ok=True)\n            self._path = os.path.join(base, DIAG_FILENAME)\n        except Exception:\n            self._path = None\n        self._resolved = True\n        return self._path\n\n    def _format(self, message: str, fields: dict[str, Any]) -> str:\n        ts = time.strftime("%Y-%m-%d %H:%M:%S", time.localtime())\n        extras = " ".join(f"{k}={_repr(v)}" for k, v in fields.items())\n        line = f"{ts} [{self._tag}] {message}"\n        if extras:\n            line = f"{line} {extras}"\n        return line + "\\n"\n\n    def _rotate_if_needed(self, path: str) -> None:\n        try:\n            size = os.path.getsize(path)\n        except OSError:\n            return\n        if size <= _MAX_BYTES:\n            return\n        try:\n            with open(path, "rb") as fh:\n                fh.seek(-_TRIM_TO, os.SEEK_END)\n                tail = fh.read()\n            with open(path, "wb") as fh:\n                fh.write(b"# trimmed\\n")\n                fh.write(tail)\n        except OSError:\n            return\n\n\ndef _repr(value: Any) -> str:\n    """Безопасное короткое представление произвольного значения для журнала."""\n    try:\n        text = repr(value)\n    except Exception:\n        text = "<unrepr>"\n    if len(text) > 200:\n        text = text[:200] + "..."\n    return text\n', False, '<read_notification>/infra/diag.py'),
    'read_notification.infra.foreground_state': ('"""Определение «открыт ли сейчас данный личный чат».\n\nПроверяется состояние верхнего фрагмента UI: если это ``ChatActivity``\nи его ``Bundle``-аргументы содержат ``user_id == <ожидаемый>``, чат\nсчитается открытым.\n\nНа устройстве это нужно, чтобы по настройке ``hide_when_chat_open``\nне дёргать уведомления о прочтении сообщений в чате, на котором вы\nсейчас смотрите. В офлайн-окружении (тесты) обёртка безопасно\nвозвращает ``False``.\n"""\n\nfrom __future__ import annotations\n\nfrom collections.abc import Callable\nfrom typing import Any\n\n\nclass CurrentFragmentForegroundState:\n    """Реализация :class:`src.services.gate.ForegroundState` через SDK.\n\n    :param last_fragment_provider: callable, возвращающий текущий\n        фрагмент (``client_utils.get_last_fragment()``) или ``None``.\n    """\n\n    #: Имя класса ChatActivity для сравнения через ``type(...).__name__``.\n    _CHAT_ACTIVITY_CLASSNAME = "ChatActivity"\n\n    def __init__(self, last_fragment_provider: Callable[[], Any]) -> None:\n        self._provider = last_fragment_provider\n\n    def is_chat_open(self, account: int, user_id: int) -> bool:\n        """Открыт ли личный чат с указанным пользователем.\n\n        :param account: номер аккаунта (для согласованности интерфейса;\n            многосессионная проверка опускается, см. Implementation Plan).\n        :param user_id: id собеседника.\n        :returns: ``True``, если открытый фрагмент — ``ChatActivity``\n            с тем же ``user_id``.\n        """\n        if not isinstance(user_id, int) or user_id <= 0:\n            return False\n        del account  # пока неиспользуем — оставлено в сигнатуре намеренно\n        try:\n            fragment = self._provider()\n            if fragment is None:\n                return False\n            if type(fragment).__name__ != self._CHAT_ACTIVITY_CLASSNAME:\n                return False\n            args = fragment.getArguments()\n            if args is None:\n                return False\n            bundle_user_id = int(args.getLong("user_id", 0))\n            return bundle_user_id == int(user_id)\n        except Exception:\n            return False\n', False, '<read_notification>/infra/foreground_state.py'),
    'read_notification.infra.intent_factory': ('"""Сборка ``PendingIntent``, открывающего личный чат.\n\nКонтракт extras согласован с собственным\n``org.telegram.messenger.NotificationsController`` exteraGram:\n\n- ``Intent(applicationContext, LaunchActivity.class)``;\n- ``setAction("com.tmessages.openchat" + <unique>)`` — уникальное\n  действие, чтобы Android не сливал PendingIntent разных чатов в один;\n- ``putExtra("userId", user_id_long)``;\n- ``putExtra("currentAccount", account_int)``;\n- ``FLAG_ACTIVITY_NEW_TASK | FLAG_ACTIVITY_CLEAR_TOP``.\n\nPendingIntent создаётся с ``FLAG_IMMUTABLE`` — обязательно для\nAndroid 12+.\n"""\n\nfrom __future__ import annotations\n\nimport secrets\nfrom collections.abc import Callable\nfrom typing import Any\n\nfrom catalib.support import find_class\n\nfrom ..config import INTENT_OPEN_CHAT_ACTION_PREFIX, LAUNCH_ACTIVITY_FQN\n\n\nclass ChatIntentFactory:\n    """Фабрика ``PendingIntent`` для тапа по уведомлению.\n\n    :param context_provider: callable, возвращающий ``Context``\n        приложения (``ApplicationLoader.applicationContext``).\n    :param action_prefix: префикс действия Intent.\n    """\n\n    def __init__(\n        self,\n        context_provider: Callable[[], Any],\n        *,\n        action_prefix: str = INTENT_OPEN_CHAT_ACTION_PREFIX,\n    ) -> None:\n        self._context_provider = context_provider\n        self._action_prefix = action_prefix\n\n    def build(self, account: int, user_id: int) -> Any:\n        """Собрать ``PendingIntent``, открывающий чат с пользователем.\n\n        :param account: номер аккаунта exteraGram.\n        :param user_id: id собеседника (положительный).\n        :returns: объект ``android.app.PendingIntent`` (на устройстве)\n            либо ``None``, если SDK недоступен или возникла ошибка.\n        """\n        if not isinstance(user_id, int) or user_id <= 0:\n            return None\n        try:\n            context = self._context_provider()\n            if context is None:\n                return None\n            launch_activity_cls = find_class(LAUNCH_ACTIVITY_FQN)\n            if launch_activity_cls is None:\n                return None\n            # Импорт классов Android делаем лениво: офлайн их попросту нет.\n            from android.app import PendingIntent\n            from android.content import Intent\n            from android.os import Bundle\n\n            intent = Intent(context, launch_activity_cls)\n            # Уникальный action гарантирует, что Android не считает\n            # PendingIntent\'ы для разных чатов «эквивалентными».\n            unique_suffix = secrets.token_hex(8)\n            intent.setAction(f"{self._action_prefix}.{account}.{user_id}.{unique_suffix}")\n            # Bundle обходит неоднозначность перегрузок ``Intent.putExtra``:\n            # LaunchActivity читает экстры через ``getLongExtra``/\n            # ``getIntExtra``, и Bundle.putLong/putInt пишут именно те\n            # примитивы, что ожидает читатель.\n            extras = Bundle()\n            extras.putLong("userId", int(user_id))\n            extras.putInt("currentAccount", int(account))\n            intent.putExtras(extras)\n            intent.setFlags(Intent.FLAG_ACTIVITY_NEW_TASK | Intent.FLAG_ACTIVITY_CLEAR_TOP)\n\n            flags = PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE\n            request_code = _stable_request_code(account, user_id)\n            return PendingIntent.getActivity(context, request_code, intent, flags)\n        except Exception:\n            return None\n\n\ndef _stable_request_code(account: int, user_id: int) -> int:\n    """Положительный 31-битный request code, устойчиво производный от пары.\n\n    PendingIntent в Android идентифицируется кортежем (requestCode, action,\n    data, type, component, categories). Стабильный requestCode на пару\n    ``(account, user_id)`` даёт корректное обновление одного PendingIntent\n    при повторных публикациях.\n\n    :param account: номер аккаунта.\n    :param user_id: id собеседника.\n    :returns: 31-битное неотрицательное целое.\n    """\n    mixed = (int(account) * 0x9E3779B1) ^ (int(user_id) * 0x85EBCA77)\n    return mixed & 0x7FFFFFFF\n', False, '<read_notification>/infra/intent_factory.py'),
    'read_notification.infra.nc_listener': ('"""Наблюдение за событиями ``NotificationCenter`` Telegram-Android.\n\nЭмпирически зафиксировано:\n\n- ``add_hook("update*")`` в SDK не дисптчит TL-апдейты в плагин.\n- ``Chaquopy.dynamic_proxy(<интерфейс>)`` создаёт инстанс, но реальных\n  Java→Python вызовов не маршрутизирует (``addObserver`` принимает\n  делегата, но ``didReceivedNotification`` не зовётся).\n- ``extera_utils.classes.java_subclass(<интерфейс>)`` для одного-лишь\n  интерфейса возвращает Python-класс, чей инстанс Java конвертировать\n  в ``NotificationCenterDelegate`` отказывается.\n\nЕдинственный путь, который **гарантированно** работает — это Xposed-хук\nсамого Java-метода ``NotificationCenter.postNotificationNameInternal``:\nон вызывается на каждом ``postNotificationName``-е, регистрация — через\ncatalib `@xposed`. Этот файл предоставляет :class:`NotificationObserver`,\nкоординирующий резолвинг id и форвардинг событий обработчику.\n\nОфлайн все методы — no-op.\n"""\n\nfrom __future__ import annotations\n\nfrom collections.abc import Callable\nfrom typing import Any\n\nfrom .diag import Diag\n\n\nclass NotificationObserver:\n    """Координатор приёма событий ``NotificationCenter``.\n\n    Сам класс **не** регистрирует Xposed-хук — это делает плагин через\n    декоратор ``@xposed`` на собственном методе. Здесь только хранятся\n    словарь интересующих ``event_id`` и обработчик, чтобы остальной\n    код плагина не зависел от особенностей платформы.\n\n    :param diag: журнал диагностики.\n    :param handler: функция ``(event_id, event_name, account, args) -> None``,\n        вызываемая для каждого интересующего события.\n    :param events: словарь ``{константное_имя: event_id}`` —\n        интересующие события ``NotificationCenter``.\n    """\n\n    def __init__(\n        self,\n        diag: Diag,\n        handler: Callable[[int, str, int, Any], None],\n        events: dict[str, int],\n    ) -> None:\n        self._diag = diag\n        self._handler = handler\n        self._events = dict(events)\n        self._allowed_ids: set[int] = {\n            int(eid) for eid in self._events.values() if isinstance(eid, int)\n        }\n        self._name_by_id: dict[int, str] = {\n            int(eid): name for name, eid in self._events.items() if isinstance(eid, int)\n        }\n\n    def dispatch(self, notification_id: Any, account: Any, args: Any) -> None:\n        """Передать пришедшее событие в обработчик.\n\n        Безопасен в любых ошибочных ситуациях: исключения подавляются\n        и пишутся в журнал — нельзя ломать чужой Java-код.\n\n        :param notification_id: int или Integer.\n        :param account: int или Integer.\n        :param args: ``Object[]`` Java или ``None``.\n        """\n        try:\n            event_id = int(notification_id)\n        except Exception:\n            return\n        if event_id not in self._allowed_ids:\n            return\n        try:\n            account_int = int(account) if account is not None else 0\n        except Exception:\n            account_int = 0\n        name = self._name_by_id.get(event_id, str(event_id))\n        try:\n            self._handler(event_id, name, account_int, args)\n        except Exception as exc:\n            self._diag.write(\n                "nc.dispatch: handler failed",\n                id=event_id,\n                name=name,\n                error=repr(exc),\n            )\n\n\ndef resolve_event_ids(diag: Diag, names: list[str]) -> dict[str, int]:\n    """Сопоставить имена констант ``NotificationCenter.<имя>`` их значениям.\n\n    :param diag: журнал диагностики; в него попадают только неразрешённые.\n    :param names: список имён публичных констант.\n    :returns: словарь ``{имя: int_value}``; неразрешённые — отсутствуют.\n    """\n    try:\n        from catalib.support import find_class\n\n        nc_class = find_class("org.telegram.messenger.NotificationCenter")\n    except Exception:\n        diag.write("nc.resolve: find_class failed")\n        return {}\n    if nc_class is None:\n        diag.write("nc.resolve: no NotificationCenter class")\n        return {}\n    out: dict[str, int] = {}\n    missing: list[str] = []\n    for name in names:\n        try:\n            value = getattr(nc_class, name, None)\n            if isinstance(value, int):\n                out[name] = int(value)\n            else:\n                missing.append(name)\n        except Exception:\n            missing.append(name)\n    if missing:\n        diag.write("nc.resolve: missing", names=missing)\n    return out\n', False, '<read_notification>/infra/nc_listener.py'),
    'read_notification.infra.overlay_banner': ('"""In-app/system всплывашка о прочтении.\n\nАльтернатива системному уведомлению: рисует прямоугольник сверху\nэкрана с именем собеседника и текстом, поверх любого приложения\n(``TYPE_APPLICATION_OVERLAY``) — нужно разрешение «Поверх других\nприложений». При отсутствии разрешения и активном приложении баннер\nдобавляется в ``decorView`` верхней Activity (работает только пока\nexteraGram на переднем плане).\n\nЦвета берутся из текущей темы Telegram (см. :mod:`src.infra.theme`)\nс осмысленным fallback. По тапу — открывается чат через переданный\n``ChatIntentFactory``. По свайпу — баннер плавно уходит. Появляется и\nисчезает с анимацией. Учитывает высоту строки состояния.\n\nОфлайн (без SDK) все методы — безопасные no-op.\n"""\n\nfrom __future__ import annotations\n\nimport threading\nfrom collections.abc import Callable\nfrom typing import Any\n\nfrom .diag import Diag\nfrom .intent_factory import ChatIntentFactory\nfrom .theme import first_available_color\n\n\n#: Продолжительность показа баннера по умолчанию, миллисекунды\n#: (значение перекрывается параметром ``duration_ms`` в ``show``).\nDEFAULT_DURATION_MS = 4000\n\n#: Длительность анимации появления/ухода, миллисекунды.\n_ANIM_IN_MS = 220\n_ANIM_OUT_MS = 180\n\n#: Радиус скругления углов баннера, dp.\n_RADIUS_DP = 14\n\n#: Внутренние отступы баннера, dp.\n_PADDING_HORIZONTAL_DP = 16\n_PADDING_VERTICAL_DP = 12\n\n#: Верхний внешний отступ (под строкой состояния), dp.\n_MARGIN_TOP_DP = 6\n\n#: Боковые отступы по умолчанию, dp (перекрываются параметром\n#: ``side_margin_dp`` в ``show``).\nDEFAULT_SIDE_MARGIN_DP = 8\n\n#: Целевая альфа баннера по умолчанию (полная непрозрачность);\n#: перекрывается параметром ``alpha`` в ``show``.\nDEFAULT_ALPHA = 1.0\n\n#: Эвристический fallback для строки состояния, если ресурс не нашёлся, dp.\n_FALLBACK_STATUS_BAR_DP = 24\n\n#: Ключи темы для фона/текста — приоритетный список, первый\n#: разрешившийся побеждает.\n_BACKGROUND_KEYS = (\n    "key_undo_background",\n    "key_dialogBackground",\n    "key_chats_actionBackground",\n)\n_TITLE_KEYS = (\n    "key_undo_infoColor",\n    "key_dialogTextBlack",\n    "key_windowBackgroundWhiteBlackText",\n)\n_SUBTITLE_KEYS = (\n    "key_undo_infoColor",\n    "key_dialogTextGray3",\n    "key_windowBackgroundWhiteGrayText",\n)\n\n#: Fallback ARGB-значения, когда тема недоступна.\n_FALLBACK_BG = 0xFFEC5B5B\n_FALLBACK_TITLE = 0xFFFFFFFF\n_FALLBACK_SUBTITLE = 0xCCFFFFFF\n\n\nclass OverlayBanner:\n    """Показывает всплывашку поверх любого приложения / поверх decor-view.\n\n    :param context_provider: callable, возвращающий ``Context`` приложения.\n    :param last_fragment_provider: callable, возвращающий текущий\n        фрагмент UI (нужен для in-app fallback, когда разрешение\n        ``SYSTEM_ALERT_WINDOW`` ещё не дано).\n    :param intent_factory: фабрика ``PendingIntent`` для тапа.\n    :param diag: журнал диагностики.\n    :param duration_ms: длительность показа.\n    """\n\n    def __init__(\n        self,\n        context_provider: Callable[[], Any],\n        last_fragment_provider: Callable[[], Any],\n        intent_factory: ChatIntentFactory,\n        diag: Diag,\n    ) -> None:\n        self._context_provider = context_provider\n        self._last_fragment_provider = last_fragment_provider\n        self._intent_factory = intent_factory\n        self._diag = diag\n        # Активные баннеры (account, user_id) → handle.\n        self._active: dict[tuple[int, int], Any] = {}\n        self._lock = threading.Lock()\n\n    def can_show_globally(self) -> bool:\n        """Можно ли показать всплывашку поверх любого приложения.\n\n        :returns: ``True`` — у exteraGram есть разрешение\n            ``SYSTEM_ALERT_WINDOW`` и баннер увидно за пределами\n            приложения. ``False`` — баннер появится только пока\n            приложение на переднем плане.\n        """\n        try:\n            context = self._context_provider()\n            if context is None:\n                return False\n            from android.provider import Settings as AndroidSettings\n\n            return bool(AndroidSettings.canDrawOverlays(context))\n        except Exception:\n            return False\n\n    def show(\n        self,\n        account: int,\n        user_id: int,\n        title: str,\n        body: str,\n        *,\n        duration_ms: int = DEFAULT_DURATION_MS,\n        alpha: float = DEFAULT_ALPHA,\n        side_margin_dp: int = DEFAULT_SIDE_MARGIN_DP,\n    ) -> bool:\n        """Показать или обновить всплывашку.\n\n        :param duration_ms: длительность показа в миллисекундах. ``0`` —\n            не закрывать автоматически (пользователь снимает свайпом\n            или тапом).\n        :param alpha: целевая непрозрачность баннера, ``0.0`` — полностью\n            прозрачно (бесполезно), ``1.0`` — без полупрозрачности.\n        :param side_margin_dp: отступ от левого и правого краёв экрана\n            в dp. ``0`` — растянуть на всю ширину.\n        :returns: ``True`` если баннер удалось показать.\n\n        Вызов **синхронный**: ``postNotificationNameInternal`` Telegram\n        всегда исполняется на UI-потоке, и поэтому хук-обработчик\n        плагина тоже на UI — оборачивать публикацию в\n        ``run_on_ui_thread`` (это асинхронный ``Handler.post``) опасно,\n        потому что вызывающий код узнаёт результат до фактической\n        публикации и срабатывает ложный fallback. Если по какой-то\n        причине вызов всё же из не-UI потока, ``WindowManager.addView``\n        бросит исключение и мы вернём ``False``.\n        """\n        return self._publish_on_ui(\n            account,\n            user_id,\n            title,\n            body,\n            duration_ms=int(duration_ms),\n            alpha=float(alpha),\n            side_margin_dp=int(side_margin_dp),\n        )\n\n    def dismiss(self, account: int, user_id: int) -> None:\n        """Скрыть конкретную всплывашку, если она ещё показана."""\n        self._dismiss_animated((int(account), int(user_id)))\n\n    def dismiss_all(self) -> None:\n        """Скрыть все активные всплывашки (на выгрузке плагина)."""\n        with self._lock:\n            keys = list(self._active.keys())\n        for key in keys:\n            self._dismiss_animated(key)\n\n    def _publish_on_ui(\n        self,\n        account: int,\n        user_id: int,\n        title: str,\n        body: str,\n        *,\n        duration_ms: int,\n        alpha: float,\n        side_margin_dp: int,\n    ) -> bool:\n        try:\n            context = self._context_provider()\n            if context is None:\n                self._diag.write("overlay.show: no context")\n                return False\n            target_alpha = max(0.05, min(1.0, float(alpha)))\n            view = self._build_view(\n                context,\n                account,\n                user_id,\n                title,\n                body,\n                side_margin_dp=int(side_margin_dp),\n            )\n            if view is None:\n                self._diag.write("overlay.view: container is None")\n                return False\n            key = (int(account), int(user_id))\n            # Сразу гасим предыдущий баннер для этого диалога.\n            self._dismiss_immediate(key)\n            top_offset = self._top_inset_px(context)\n            host, source = self._attach(context, view, top_offset)\n            if host is None:\n                self._diag.write(\n                    "overlay.show: cannot attach",\n                    can_overlay=self.can_show_globally(),\n                )\n                return False\n            handle = (source, host, view)\n            with self._lock:\n                self._active[key] = handle\n            self._animate_in(view, target_alpha)\n            if duration_ms > 0:\n                self._schedule_auto_dismiss(key, duration_ms)\n            self._diag.write(\n                "overlay.show: shown",\n                source=source,\n                account=account,\n                user_id=user_id,\n                duration_ms=duration_ms,\n                alpha=target_alpha,\n                side_margin_dp=side_margin_dp,\n            )\n            return True\n        except Exception as exc:\n            self._diag.write("overlay.show: failed", error=repr(exc))\n            return False\n\n    def _attach(self, context: Any, view: Any, top_offset_px: int) -> tuple[Any, str]:\n        """Прикрепить ``view`` либо как окно overlay, либо в decor.\n\n        :returns: ``(host, source)``: ``host`` — ``WindowManager`` или\n            ``ViewGroup`` (decor); ``source`` — ``"system"`` или\n            ``"in_app"``; ``host=None`` если ничего не получилось.\n        """\n        if self.can_show_globally():\n            host = self._attach_system_overlay(context, view, top_offset_px)\n            if host is not None:\n                return host, "system"\n        host = self._attach_in_app(view, top_offset_px)\n        if host is not None:\n            return host, "in_app"\n        return None, ""\n\n    def _attach_system_overlay(\n        self, context: Any, view: Any, top_offset_px: int\n    ) -> Any:\n        """Опубликовать баннер как окно ``TYPE_APPLICATION_OVERLAY``.\n\n        :returns: ``WindowManager`` или ``None``.\n        """\n        try:\n            from android.view import Gravity, WindowManager\n            from android.os import Build\n        except Exception:\n            return None\n        try:\n            sdk_int = int(Build.VERSION.SDK_INT)\n            type_overlay = (\n                WindowManager.LayoutParams.TYPE_APPLICATION_OVERLAY\n                if sdk_int >= 26\n                else WindowManager.LayoutParams.TYPE_PHONE\n            )\n            flags = (\n                WindowManager.LayoutParams.FLAG_NOT_FOCUSABLE\n                | WindowManager.LayoutParams.FLAG_LAYOUT_IN_SCREEN\n                | WindowManager.LayoutParams.FLAG_LAYOUT_NO_LIMITS\n            )\n            params = WindowManager.LayoutParams(\n                WindowManager.LayoutParams.MATCH_PARENT,\n                WindowManager.LayoutParams.WRAP_CONTENT,\n                type_overlay,\n                flags,\n                # PixelFormat.TRANSLUCENT = -3\n                -3,\n            )\n            params.gravity = Gravity.TOP\n            params.x = 0\n            params.y = int(top_offset_px)\n            wm = context.getSystemService(context.WINDOW_SERVICE)\n            if wm is None:\n                return None\n            wm.addView(view, params)\n            return wm\n        except Exception as exc:\n            self._diag.write("overlay.system: addView failed", error=repr(exc))\n            return None\n\n    def _attach_in_app(self, view: Any, top_offset_px: int) -> Any:\n        """Добавить ``view`` в decor верхнего фрагмента (fallback без разрешения)."""\n        fragment = self._safe_last_fragment()\n        if fragment is None:\n            return None\n        try:\n            activity = fragment.getParentActivity()\n        except Exception:\n            activity = None\n        if activity is None:\n            return None\n        try:\n            window = activity.getWindow()\n            decor = window.getDecorView()\n        except Exception:\n            return None\n        try:\n            from android.view import Gravity, ViewGroup\n            from android.widget import FrameLayout\n\n            params = FrameLayout.LayoutParams(\n                ViewGroup.LayoutParams.MATCH_PARENT,\n                ViewGroup.LayoutParams.WRAP_CONTENT,\n            )\n            params.gravity = Gravity.TOP\n            params.topMargin = int(top_offset_px)\n            decor.addView(view, params)\n            return decor\n        except Exception as exc:\n            self._diag.write("overlay.in_app: addView failed", error=repr(exc))\n            return None\n\n    def _build_view(\n        self,\n        context: Any,\n        account: int,\n        user_id: int,\n        title: str,\n        body: str,\n        *,\n        side_margin_dp: int,\n    ) -> Any:\n        """Построить дерево ``View`` для баннера и его сенсоры жестов.\n\n        Структура:\n\n        - Внешний ``FrameLayout``-обёртка с ``setPadding`` по бокам —\n          его паддинг даёт визуальный отступ и не теряется при\n          ``WindowManager.addView``/``decor.addView`` (там назначаются\n          собственные ``LayoutParams``, поэтому ``setMargins`` на\n          самом баннере не работает).\n        - Внутренний ``FrameLayout``-подкласс через ``java_subclass``\n          с переопределением ``onTouchEvent`` для тапа и свайпа.\n          Java-методы (``setBackground``, ``addView``, …) зовём через\n          ``.this``: Python-peer их не проксирует.\n        """\n        try:\n            from android.graphics.drawable import GradientDrawable\n            from android.widget import LinearLayout, TextView\n        except Exception as exc:\n            self._diag.write("overlay.view: import failed", error=repr(exc))\n            return None\n\n        bg_color = first_available_color(_BACKGROUND_KEYS, _FALLBACK_BG)\n        title_color = first_available_color(_TITLE_KEYS, _FALLBACK_TITLE)\n        body_color = first_available_color(_SUBTITLE_KEYS, _FALLBACK_SUBTITLE)\n\n        density = _density(context)\n        radius_px = float(_RADIUS_DP * density)\n        margin_side_px = max(0, int(int(side_margin_dp) * density))\n        pad_h = int(_PADDING_HORIZONTAL_DP * density)\n        pad_v = int(_PADDING_VERTICAL_DP * density)\n        try:\n            from android.widget import FrameLayout\n        except Exception as exc:\n            self._diag.write("overlay.view: FrameLayout import failed", error=repr(exc))\n            return None\n\n        background = GradientDrawable()\n        background.setColor(bg_color)\n        background.setCornerRadius(radius_px)\n\n        title_view = TextView(context)\n        title_view.setText(title or "")\n        title_view.setTextColor(title_color)\n        title_view.setTextSize(15.0)\n        try:\n            from android.graphics import Typeface\n\n            title_view.setTypeface(Typeface.DEFAULT_BOLD)\n        except Exception:\n            pass\n\n        body_view = TextView(context)\n        body_view.setText(body or "")\n        body_view.setTextColor(body_color)\n        body_view.setTextSize(13.0)\n\n        column = LinearLayout(context)\n        column.setOrientation(LinearLayout.VERTICAL)\n        column.addView(title_view)\n        column.addView(body_view)\n\n        key = (int(account), int(user_id))\n        inner_view = self._build_touchable_container(context, key, account, user_id)\n        if inner_view is None:\n            self._diag.write("overlay.view: container is None")\n            return None\n        try:\n            inner_view.setBackground(background)\n            inner_view.setPadding(pad_h, pad_v, pad_h, pad_v)\n        except Exception as exc:\n            self._diag.write("overlay.view: background failed", error=repr(exc))\n            return None\n        try:\n            inner_view.addView(column)\n        except Exception as exc:\n            self._diag.write("overlay.view: addView failed", error=repr(exc))\n            return None\n        try:\n            inner_view.setClickable(True)\n        except Exception:\n            pass\n\n        # Внешняя обёртка задаёт боковые отступы через padding — потому\n        # что собственные LayoutParams на ``addView`` в WindowManager /\n        # decorView перетираются.\n        try:\n            outer = FrameLayout(context)\n            outer.setPadding(margin_side_px, 0, margin_side_px, 0)\n            from android.view import ViewGroup\n\n            inner_params = FrameLayout.LayoutParams(\n                ViewGroup.LayoutParams.MATCH_PARENT,\n                ViewGroup.LayoutParams.WRAP_CONTENT,\n            )\n            outer.addView(inner_view, inner_params)\n        except Exception as exc:\n            self._diag.write("overlay.view: outer wrap failed", error=repr(exc))\n            return None\n        # Запоминаем inner на outer, чтобы анимация и свайп работали\n        # именно с видимым баннером, а не с прозрачной обёрткой.\n        try:\n            outer.setTag(inner_view)\n        except Exception:\n            pass\n        return outer\n\n    def _build_touchable_container(\n        self,\n        context: Any,\n        key: tuple[int, int],\n        account: int,\n        user_id: int,\n    ) -> Any:\n        """Построить ``FrameLayout``-подкласс с собственной обработкой касаний.\n\n        Возвращает **Java-объект** (``.this``) контейнера, а не\n        Python-peer — иначе вызовы ``setBackground``, ``addView`` и т. п.\n        падают с ``AttributeError``: peer не пробрасывает методы View.\n\n        План Б — если DSL ``java_subclass`` или его экземпляр не\n        получился — возвращается обычный ``FrameLayout`` с\n        :class:`catalib.support.android.OnClickListener` для тапа\n        (свайпа в этом fallback не будет).\n        """\n        outer = self\n        try:\n            from catalib.support import Base, java_subclass, jfield, joverride\n            from android.view import MotionEvent\n\n            action_down = int(MotionEvent.ACTION_DOWN)\n            action_move = int(MotionEvent.ACTION_MOVE)\n            action_up = int(MotionEvent.ACTION_UP)\n            action_cancel = int(MotionEvent.ACTION_CANCEL)\n            slop = float(_touch_slop(context))\n            dismiss_threshold = float(_dismiss_threshold_px(context))\n\n            @java_subclass("android.widget.FrameLayout")\n            class _BannerContainer(Base):\n                """Контейнер баннера: тап открывает чат, свайп — гасит."""\n\n                _tracking = jfield("boolean", default=False)\n                _down_x = jfield("float", default=0.0)\n                _down_y = jfield("float", default=0.0)\n                _cur_dx = jfield("float", default=0.0)\n                _cur_dy = jfield("float", default=0.0)\n\n                @joverride("onTouchEvent")\n                def _on_touch_event(self, event: Any) -> bool:\n                    action = int(event.getAction())\n                    java_self = self.this\n                    if action == action_down:\n                        self._tracking = True\n                        self._down_x = float(event.getRawX())\n                        self._down_y = float(event.getRawY())\n                        self._cur_dx = 0.0\n                        self._cur_dy = 0.0\n                        return True\n                    if not self._tracking:\n                        return False\n                    if action == action_move:\n                        self._cur_dx = float(event.getRawX()) - self._down_x\n                        self._cur_dy = float(event.getRawY()) - self._down_y\n                        try:\n                            java_self.setTranslationX(float(self._cur_dx))\n                            java_self.setTranslationY(min(0.0, float(self._cur_dy)))\n                        except Exception:\n                            pass\n                        return True\n                    if action in (action_up, action_cancel):\n                        was_tracking = self._tracking\n                        self._tracking = False\n                        if action == action_cancel or not was_tracking:\n                            outer._spring_back(java_self)\n                            return True\n                        abs_dx = abs(float(self._cur_dx))\n                        abs_dy = abs(float(self._cur_dy))\n                        if abs_dx < slop and abs_dy < slop:\n                            outer._open_chat(account, user_id)\n                            outer._dismiss_animated(key)\n                            return True\n                        if abs_dx >= dismiss_threshold or abs_dy >= dismiss_threshold:\n                            outer._fling_away(\n                                java_self,\n                                float(self._cur_dx),\n                                float(self._cur_dy),\n                                key,\n                            )\n                            return True\n                        outer._spring_back(java_self)\n                        return True\n                    return False\n\n            try:\n                peer = _BannerContainer.new_instance(context)\n            except Exception as exc:\n                self._diag.write(\n                    "overlay.touch: new_instance failed", error=repr(exc)\n                )\n                return self._build_plain_container(\n                    context, key, account, user_id\n                )\n            java_view = _unwrap_java(peer)\n            if java_view is None:\n                self._diag.write(\n                    "overlay.touch: cannot unwrap java view",\n                    peer_cls=type(peer).__name__,\n                )\n                return self._build_plain_container(\n                    context, key, account, user_id\n                )\n            return java_view\n        except Exception as exc:\n            self._diag.write("overlay.touch: subclass failed", error=repr(exc))\n            return self._build_plain_container(context, key, account, user_id)\n\n    def _build_plain_container(\n        self,\n        context: Any,\n        key: tuple[int, int],\n        account: int,\n        user_id: int,\n    ) -> Any:\n        """Fallback-контейнер без свайпа: только тап через OnClickListener."""\n        try:\n            from android.widget import FrameLayout\n            from catalib.support.android import OnClickListener\n        except Exception as exc:\n            self._diag.write("overlay.plain: import failed", error=repr(exc))\n            return None\n        outer = self\n        try:\n            container = FrameLayout(context)\n        except Exception as exc:\n            self._diag.write("overlay.plain: ctor failed", error=repr(exc))\n            return None\n\n        def _on_tap(_view: Any) -> None:\n            outer._open_chat(account, user_id)\n            outer._dismiss_animated(key)\n\n        try:\n            container.setOnClickListener(OnClickListener(_on_tap))\n        except Exception as exc:\n            self._diag.write(\n                "overlay.plain: click listener failed", error=repr(exc)\n            )\n        return container\n\n    def _spring_back(self, view: Any) -> None:\n        """Анимация «возврата на место» после короткого свайпа."""\n        try:\n            view.animate().translationX(0.0).translationY(0.0).setDuration(150).start()\n        except Exception:\n            pass\n\n    def _fling_away(\n        self, view: Any, dx: float, dy: float, key: tuple[int, int]\n    ) -> None:\n        """Анимация «улетания» по направлению свайпа и удаление баннера."""\n        try:\n            distance = float((dx * dx + dy * dy) ** 0.5) or 1.0\n            try:\n                target_x = float(view.getWidth() or 800)\n            except Exception:\n                target_x = 800.0\n            try:\n                target_y = float(view.getHeight() or 200)\n            except Exception:\n                target_y = 200.0\n            end_x = float(dx) / distance * target_x * 1.4\n            end_y = float(dy) / distance * target_y * 1.4\n            with self._lock:\n                handle = self._active.pop(key, None)\n            view.animate().translationX(end_x).translationY(end_y).alpha(0.0).setDuration(\n                _ANIM_OUT_MS\n            ).withEndAction(\n                _runnable(lambda: self._remove_handle(handle) if handle else None)\n            ).start()\n        except Exception:\n            self._dismiss_animated(key)\n\n    def _open_chat(self, account: int, user_id: int) -> None:\n        try:\n            context = self._context_provider()\n            if context is None:\n                return\n            pending = self._intent_factory.build(account, user_id)\n            if pending is None:\n                return\n            pending.send()\n        except Exception as exc:\n            self._diag.write("overlay.tap: send failed", error=repr(exc))\n\n    def _animate_in(self, view: Any, target_alpha: float) -> None:\n        """Анимация появления: плавный slide-down + fade-in до ``target_alpha``."""\n        try:\n            view.setAlpha(0.0)\n            view.setTranslationY(float(-self._estimate_height(view)))\n            view.animate().alpha(float(target_alpha)).translationY(0.0).setDuration(\n                _ANIM_IN_MS\n            ).start()\n        except Exception:\n            pass\n\n    def _animate_out(self, view: Any, after: Callable[[], None]) -> None:\n        """Анимация ухода: slide-up + fade-out, по окончании — ``after``."""\n        try:\n            height = float(self._estimate_height(view))\n            view.animate().alpha(0.0).translationY(-height).setDuration(\n                _ANIM_OUT_MS\n            ).withEndAction(_runnable(after)).start()\n        except Exception:\n            after()\n\n    def _estimate_height(self, view: Any) -> int:\n        try:\n            measured = int(view.getHeight() or 0)\n            if measured > 0:\n                return measured\n            measured = int(view.getMeasuredHeight() or 0)\n            if measured > 0:\n                return measured\n        except Exception:\n            pass\n        # Эвристика: высота двух строк + отступы. Достаточно, чтобы\n        # анимация смотрелась адекватно даже до первой отрисовки.\n        return 160\n\n    def _schedule_auto_dismiss(self, key: tuple[int, int], duration_ms: int) -> None:\n        try:\n            from catalib.support import run_on_ui_thread\n\n            run_on_ui_thread(\n                lambda: self._dismiss_animated(key), delay=int(duration_ms)\n            )\n        except Exception:\n            pass\n\n    def _dismiss_animated(self, key: tuple[int, int]) -> None:\n        with self._lock:\n            handle = self._active.pop(key, None)\n        if handle is None:\n            return\n        try:\n            _source, _host, view = handle\n        except Exception:\n            return\n        self._animate_out(view, lambda: self._remove_handle(handle))\n\n    def _dismiss_immediate(self, key: tuple[int, int]) -> None:\n        with self._lock:\n            handle = self._active.pop(key, None)\n        if handle is None:\n            return\n        self._remove_handle(handle)\n\n    def _remove_handle(self, handle: Any) -> None:\n        try:\n            kind, host, view = handle\n        except Exception:\n            return\n        try:\n            if kind in ("system", "in_app"):\n                host.removeView(view)\n        except Exception as exc:\n            self._diag.write(\n                "overlay.dismiss: removeView failed", kind=kind, error=repr(exc)\n            )\n\n    def _safe_last_fragment(self) -> Any:\n        try:\n            return self._last_fragment_provider()\n        except Exception:\n            return None\n\n    def _top_inset_px(self, context: Any) -> int:\n        """Высота строки состояния + базовый отступ в пикселях."""\n        status_h = 0\n        try:\n            res = context.getResources()\n            res_id = res.getIdentifier("status_bar_height", "dimen", "android")\n            if res_id and res_id > 0:\n                status_h = int(res.getDimensionPixelSize(res_id))\n        except Exception:\n            status_h = 0\n        if status_h <= 0:\n            status_h = int(_FALLBACK_STATUS_BAR_DP * _density(context))\n        return status_h + int(_MARGIN_TOP_DP * _density(context))\n\n\ndef _unwrap_java(peer: Any) -> Any:\n    """Достать Java-объект из Python-peer\'а ``java_subclass``.\n\n    Документация catalib называет два кандидата: ``peer.this`` и\n    ``peer.java`` — на разных сборках доступен какой-то один (а где-то\n    и оба отсутствуют). Пробуем по очереди; если ни один не\n    подходит — возвращаем ``None``, чтобы вызывающий перешёл на\n    fallback (обычный ``FrameLayout`` без свайпа).\n    """\n    for attr in ("this", "java"):\n        candidate = getattr(peer, attr, None)\n        if candidate is not None:\n            return candidate\n    return None\n\n\ndef _density(context: Any) -> float:\n    """Плотность пикселей текущего экрана; ``1.0`` при ошибке."""\n    try:\n        return float(context.getResources().getDisplayMetrics().density)\n    except Exception:\n        return 1.0\n\n\ndef _touch_slop(context: Any) -> float:\n    """Минимальное движение пальца до начала жеста, пикселей."""\n    try:\n        from android.view import ViewConfiguration\n\n        return float(ViewConfiguration.get(context).getScaledTouchSlop())\n    except Exception:\n        return 16.0 * _density(context)\n\n\ndef _dismiss_threshold_px(context: Any) -> float:\n    """Порог смещения, после которого свайп считается «улетающим», пикселей."""\n    return 80.0 * _density(context)\n\n\ndef _runnable(action: Callable[[], None]) -> Any:\n    """Обернуть Python-callable в ``java.lang.Runnable``.\n\n    Используется как ``withEndAction`` у ``ViewPropertyAnimator``: API\n    принимает только Java-``Runnable``, и Chaquopy без обёртки не\n    пропустит Python-функцию.\n    """\n    try:\n        from catalib.support import android as android_helpers\n\n        return android_helpers.R(action)\n    except Exception:\n        # Если SDK недоступен (тесты) — возвращаем сам callable; вызывающий\n        # код всё равно его выполнит через try/except.\n        return action\n', False, '<read_notification>/infra/overlay_banner.py'),
    'read_notification.infra.theme': ('"""Доступ к цветам текущей темы Telegram-Android.\n\nВ Telegram-Android палитра темы вычитывается через\n``org.telegram.ui.ActionBar.Theme.getColor(int key)``, где ``key`` — это\nконстанта из множества полей ``Theme.key_*``. Имя ключа подбираем\nсемантически, а значение разрешается на устройстве\nчерез рефлексию: ``getattr(Theme, key_name)``.\n\nОфлайн (без SDK) функции возвращают заданный fallback — это позволяет\nписать тесты без устройства.\n"""\n\nfrom __future__ import annotations\n\n#: Альфа-составляющая, добавляемая к fallback-цветам, если её нет.\n_OPAQUE = 0xFF000000\n\n\ndef theme_color(key_name: str, fallback: int) -> int:\n    """Получить ARGB-цвет темы по имени ключа.\n\n    :param key_name: имя поля ``Theme.key_<...>``, например\n        ``"key_undo_background"``.\n    :param fallback: значение, возвращаемое при отсутствии SDK или\n        неудаче рефлексии; принимается без альфы (тогда выставляется\n        непрозрачная) или с альфой.\n    :returns: ARGB-цвет.\n    """\n    try:\n        from org.telegram.ui.ActionBar import Theme\n    except Exception:\n        return _force_alpha(fallback)\n    try:\n        key_id = getattr(Theme, key_name, None)\n        if key_id is None:\n            return _force_alpha(fallback)\n        return int(Theme.getColor(key_id))\n    except Exception:\n        return _force_alpha(fallback)\n\n\ndef first_available_color(keys: tuple[str, ...], fallback: int) -> int:\n    """Вернуть первый разрешившийся цвет из списка ключей.\n\n    Помогает справиться с тем, что отдельные ключи переименовывают и\n    переставляют между версиями Telegram-Android: задаём приоритетный\n    список и берём первый, который сработал.\n\n    :param keys: упорядоченный кортеж имён ``Theme.key_*``.\n    :param fallback: значение, если ни один ключ не разрешился.\n    :returns: ARGB-цвет.\n    """\n    for key_name in keys:\n        value = theme_color(key_name, _SENTINEL)\n        if value != _SENTINEL:\n            return value\n    return _force_alpha(fallback)\n\n\ndef _force_alpha(color: int) -> int:\n    """Гарантировать, что у цвета есть непрозрачная альфа-составляющая."""\n    return int(color) | _OPAQUE if (int(color) & _OPAQUE) == 0 else int(color)\n\n\n#: Sentinel-цвет, заведомо не возникающий в палитре (используется\n#: для отличия «не разрешился» от обычного ``0`` (полностью прозрачный\n#: чёрный).\n_SENTINEL = -1\n', False, '<read_notification>/infra/theme.py'),
    'read_notification.infra.time_provider': ('"""Инжектируемый источник «текущего времени».\n\nСуществует только для тестируемости: бизнес-правила, опирающиеся на\n«сейчас», не должны напрямую обращаться к :func:`time.time`. Это бы\nделало тесты зависимыми от системных часов и непредсказуемыми.\n"""\n\nfrom __future__ import annotations\n\nimport time\nfrom collections.abc import Callable\n\n\nclass TimeProvider:\n    """Простая обёртка над функцией-часами.\n\n    :param clock: callable, возвращающий текущее время в секундах\n        Unix-эпохи (по умолчанию :func:`time.time`).\n    """\n\n    def __init__(self, clock: Callable[[], float] = time.time) -> None:\n        self._clock = clock\n\n    def now_epoch(self) -> int:\n        """Текущее время в Unix epoch секундах (целое).\n\n        :returns: целое число секунд от эпохи.\n        """\n        return int(self._clock())\n', False, '<read_notification>/infra/time_provider.py'),
    'read_notification.infra.user_resolver': ('"""Разрешение имени собеседника по ``user_id``.\n\nИспользует ``MessagesController.getUser(long)``: если объект найден,\nвозвращает первое+последнее имя, иначе пробует ``@username``. Все\nобращения к SDK обёрнуты в try/except: при отсутствии SDK (тесты) или\nпри ошибке рефлексии возвращается пустая строка — вызывающий слой\nсам подберёт fallback (``"Собеседник"``).\n"""\n\nfrom __future__ import annotations\n\nfrom collections.abc import Callable\nfrom typing import Any\n\n\nclass UserResolver:\n    """Обёртка над ``client_utils.get_messages_controller``.\n\n    :param messages_controller_provider: callable, возвращающий объект\n        ``MessagesController`` (на устройстве) или ``None`` (офлайн/тест).\n    """\n\n    def __init__(self, messages_controller_provider: Callable[[], Any]) -> None:\n        self._provider = messages_controller_provider\n\n    def display_name(self, user_id: int) -> str:\n        """Получить отображаемое имя собеседника.\n\n        :param user_id: id пользователя (положительный).\n        :returns: непустая строка с именем или пустая строка, если\n            пользователь не найден / SDK недоступен / возникла ошибка.\n        """\n        if not isinstance(user_id, int) or user_id <= 0:\n            return ""\n        try:\n            controller = self._provider()\n            if controller is None:\n                return ""\n            user = controller.getUser(user_id)\n            if user is None:\n                return ""\n            first = (getattr(user, "first_name", "") or "").strip()\n            last = (getattr(user, "last_name", "") or "").strip()\n            full = f"{first} {last}".strip()\n            if full:\n                return full\n            username = (getattr(user, "username", "") or "").strip()\n            return f"@{username}" if username else ""\n        except Exception:\n            # Любая ошибка рефлексии (отсутствие метода, обновление SDK,\n            # сломанный объект) не должна валить публикацию уведомления.\n            return ""\n', False, '<read_notification>/infra/user_resolver.py'),
    'read_notification.plugin': ('"""Точка входа плагина Read Receipt Notify.\n\nСвязывает слои в единый граф зависимостей в ``on_load`` и\nподписывается на события ``NotificationCenter`` Telegram-Android.\n\nПочему ``NotificationCenter``, а не ``@hook.on_update``:\nэмпирически зафиксировано через файловую диагностику — в собранном\nexteraGram (12.5.x) механизм ``add_hook("update*")`` не дисптчит\nвызовы плагина. ``NotificationCenter`` — официальный, стабильный\nканал, и SDK явно его экспортирует через ``NotificationCenterDelegate``.\n\nСигналы:\n\n- ``didReceiveNewMessages`` — поступают новые ``MessageObject``-ы\n  (входящие и наши исходящие, включая локальные «псевдо-сообщения»).\n- ``messageReceivedByServer`` — наше исходящее сообщение получило\n  серверный id. Регистрируем его в трекере.\n- ``messagesRead`` — обновился ``read_outbox_max_id`` для одного или\n  нескольких диалогов. Снимаем с трекера все наши сообщения с id\n  ≤ ``max_id``, формируем ``ReadEvent`` и публикуем уведомление.\n"""\n\nfrom __future__ import annotations\n\nfrom typing import Any\n\nfrom catalib.support import (\n    CatalibPlugin,\n    client,\n    find_class,\n    log,\n)\n\nfrom .config import (\n    DEFAULT_ENABLED,\n    DEFAULT_EXCLUDED_USER_IDS,\n    DEFAULT_HIDE_WHEN_CHAT_OPEN,\n    DEFAULT_NOTIFICATION_MODE_IDX,\n    DEFAULT_OVERLAY_ALPHA_IDX,\n    DEFAULT_OVERLAY_DURATION_IDX,\n    DEFAULT_OVERLAY_SIDE_MARGIN_IDX,\n    DEFAULT_RECENT_ONLY_IDX,\n    LOG_PREFIX,\n    NOTIFICATION_CHANNEL_ID,\n    NOTIFICATION_CHANNEL_ID_PUSH,\n    NOTIFICATION_MODE_ITEMS,\n    NOTIFICATION_MODE_OVERLAY,\n    NOTIFICATION_MODE_PUSH,\n    NOTIFICATION_MODE_SYSTEM,\n    OVERLAY_ALPHA_BY_IDX,\n    OVERLAY_DURATION_MS_BY_IDX,\n    OVERLAY_SIDE_MARGIN_DP_BY_IDX,\n    RECENT_ONLY_SECONDS_BY_IDX,\n    SETTING_ENABLED,\n    SETTING_EXCLUDED_USER_IDS,\n    SETTING_HIDE_WHEN_CHAT_OPEN,\n    SETTING_NOTIFICATION_MODE_IDX,\n    SETTING_OVERLAY_ALPHA_IDX,\n    SETTING_OVERLAY_DURATION_IDX,\n    SETTING_OVERLAY_SIDE_MARGIN_IDX,\n    SETTING_RECENT_ONLY_IDX,\n)\nfrom .core.outbox_tracker import OutgoingTracker\nfrom .core.read_event import ReadEvent\nfrom .infra.android_notification import AndroidNotifier\nfrom .infra.diag import Diag\nfrom .infra.foreground_state import CurrentFragmentForegroundState\nfrom .infra.intent_factory import ChatIntentFactory\nfrom .infra.nc_listener import NotificationObserver, resolve_event_ids\nfrom .infra.overlay_banner import OverlayBanner\nfrom .infra.time_provider import TimeProvider\nfrom .infra.user_resolver import UserResolver\nfrom .util.formatting import (\n    format_notification_body,\n    format_notification_title,\n)\nfrom .services.gate import GateSettings, NotificationGate\nfrom .services.read_service import ReadService\nfrom .ui.settings_schema import build_settings\nfrom .util.formatting import parse_user_id_list\n\n\n#: Имена констант ``NotificationCenter``, на которые подписываемся.\n_NC_EVENTS = (\n    "didReceiveNewMessages",\n    "messageReceivedByServer",\n    "messageReceivedByServer2",\n    "messagesRead",\n)\n\n\ndef _application_context() -> Any:\n    """Получить Android-``Context`` приложения через ``ApplicationLoader``.\n\n    :returns: статическое поле ``applicationContext`` или ``None``, если\n        SDK недоступен (офлайн-тесты).\n    """\n    application_loader = find_class("org.telegram.messenger.ApplicationLoader")\n    if application_loader is None:\n        return None\n    return getattr(application_loader, "applicationContext", None)\n\n\ndef _coerce_recent_idx(value: Any) -> int:\n    """Привести значение настройки селектора «свежести» к корректному индексу."""\n    last_idx = len(RECENT_ONLY_SECONDS_BY_IDX) - 1\n    try:\n        idx = int(value)\n    except (TypeError, ValueError):\n        return DEFAULT_RECENT_ONLY_IDX\n    if idx < 0:\n        return 0\n    if idx > last_idx:\n        return last_idx\n    return idx\n\n\ndef _coerce_mode_idx(value: Any) -> int:\n    """Привести значение селектора режима к корректному индексу."""\n    last_idx = len(NOTIFICATION_MODE_ITEMS) - 1\n    try:\n        idx = int(value)\n    except (TypeError, ValueError):\n        return DEFAULT_NOTIFICATION_MODE_IDX\n    if idx < 0:\n        return 0\n    if idx > last_idx:\n        return last_idx\n    return idx\n\n\ndef _clamp_idx(value: Any, default_idx: int, last_idx: int) -> int:\n    """Универсальный clamp индекса селектора к ``[0, last_idx]``."""\n    try:\n        idx = int(value)\n    except (TypeError, ValueError):\n        return default_idx\n    if idx < 0:\n        return 0\n    if idx > last_idx:\n        return last_idx\n    return idx\n\n\nclass ReadNotificationPlugin(CatalibPlugin):\n    """Плагин Read Receipt Notify.\n\n    При прочтении собеседником ваших сообщений в личном чате\n    публикует нативное Android-уведомление с именем и числом\n    прочитанных сообщений; тап открывает чат через ``LaunchActivity``.\n    """\n\n    def on_load(self) -> None:\n        """Собрать граф зависимостей, создать канал, подписаться на NC."""\n        log(f"{LOG_PREFIX} loaded")\n        self._diag = Diag(_application_context, tag="plugin")\n        self._diag.write("on_load: start", path=self._diag.path())\n\n        self._tracker = OutgoingTracker()\n        self._time = TimeProvider()\n        self._user_resolver = UserResolver(client.get_messages_controller)\n        self._foreground = CurrentFragmentForegroundState(client.get_last_fragment)\n        self._intent_factory = ChatIntentFactory(_application_context)\n        self._notifier = AndroidNotifier(\n            _application_context, self._intent_factory, self._diag\n        )\n        self._overlay = OverlayBanner(\n            _application_context,\n            client.get_last_fragment,\n            self._intent_factory,\n            self._diag,\n        )\n        # Принудительно создаём оба канала в момент загрузки: тихий\n        # (DEFAULT) и пуш (HIGH). Без этого кнопка «Канал уведомлений в\n        # системе» открывает несуществующий канал и Android закрывает\n        # экран.\n        channel_ok = self._notifier.ensure_channel()\n        self._read_service = ReadService(self._tracker)\n        self._gate = NotificationGate(self._foreground)\n\n        # Какие пары (account, user_id) мы успели уведомить — чтобы\n        # корректно их погасить при выгрузке плагина.\n        self._tracked_dialogs: set[tuple[int, int]] = set()\n        # Уже залогированные структуры аргументов NC (один раз на event_id).\n        self._args_dumped: set[int] = set()\n\n        # Распознаём id констант NotificationCenter — обработчик ниже\n        # фильтрует входящие события по этому набору.\n        self._nc_event_ids = resolve_event_ids(self._diag, list(_NC_EVENTS))\n        self._diag.write("on_load: nc events resolved", **self._nc_event_ids)\n        self._nc_observer = NotificationObserver(\n            self._diag, self._on_nc_event, self._nc_event_ids\n        )\n\n        # Ручной Xposed-хук на NotificationCenter.postNotificationNameInternal.\n        # catalib `@xposed` без ``arg_types`` зовёт ``getDeclaredMethod(name)``\n        # без типов — для перегруженного/varargs-метода это\n        # ``NoSuchMethodException``. Поэтому перебираем\n        # ``getDeclaredMethods()`` и ловим по имени.\n        self._nc_hook_handle = self._install_nc_hook()\n\n        self._diag.write(\n            "on_load: ready",\n            channel_ok=channel_ok,\n            has_context=_application_context() is not None,\n            nc_hook_installed=self._nc_hook_handle is not None,\n        )\n\n    def on_unload(self) -> None:\n        """Снять ручной Xposed-хук, погасить опубликованные уведомления."""\n        log(f"{LOG_PREFIX} unloaded")\n        diag = getattr(self, "_diag", None)\n        if diag is not None:\n            diag.write("on_unload: start", tracked=len(self._tracked_dialogs))\n        handle = getattr(self, "_nc_hook_handle", None)\n        if handle is not None:\n            try:\n                self.unhook_method(handle)\n            except Exception as exc:\n                if diag is not None:\n                    diag.write("nc.hook: unhook failed", error=repr(exc))\n            self._nc_hook_handle = None\n        overlay = getattr(self, "_overlay", None)\n        if overlay is not None:\n            overlay.dismiss_all()\n        for account, user_id in tuple(self._tracked_dialogs):\n            self._notifier.cancel(account, user_id)\n        self._tracked_dialogs.clear()\n        self._tracker.clear()\n\n    def settings(self) -> list[Any]:\n        """Вернуть декларативный список элементов экрана настроек.\n\n        Параметры всплывашки (длительность, прозрачность, отступы)\n        включаются в схему **только** когда выбран режим «Только\n        всплывашка». Схема собирается при каждом открытии экрана, так\n        что после смены режима достаточно вернуться и снова войти.\n        """\n        mode = _coerce_mode_idx(\n            self.get_setting(SETTING_NOTIFICATION_MODE_IDX, DEFAULT_NOTIFICATION_MODE_IDX)\n        )\n        return build_settings(\n            open_channel_settings=self._open_channel_settings,\n            publish_test_notification=self._publish_test_notification,\n            open_overlay_permission=self._open_overlay_permission,\n            include_overlay_tuning=(mode == NOTIFICATION_MODE_OVERLAY),\n        )\n\n    def _install_nc_hook(self) -> Any:\n        """Подвесить ручной Xposed-хук на ``postNotificationNameInternal``.\n\n        :returns: дескриптор, который понимает ``unhook_method``, либо\n            ``None`` при неуспехе (всё логируется в diag).\n\n        Особенности Chaquopy:\n\n        - Прокси ``find_class(...)`` экспонирует только часть методов\n          ``java.lang.Class`` (например, ``getDeclaredMethod`` работает,\n          ``getDeclaredMethods`` — ``AttributeError``).\n        - Для полного доступа к рефлексии берём настоящий ``Class<?>``\n          через ``java.lang.Class.forName(...)``.\n        """\n        try:\n            from java.lang import Class as JClass\n\n            java_class = JClass.forName("org.telegram.messenger.NotificationCenter")\n        except Exception as exc:\n            self._diag.write("nc.hook: Class.forName failed", error=repr(exc))\n            return None\n        method = None\n        try:\n            for candidate in java_class.getDeclaredMethods():\n                if candidate.getName() == "postNotificationNameInternal":\n                    method = candidate\n                    break\n        except Exception as exc:\n            self._diag.write("nc.hook: getDeclaredMethods failed", error=repr(exc))\n            return None\n        if method is None:\n            self._diag.write("nc.hook: method not found")\n            return None\n        try:\n            from catalib.support import MethodHook\n\n            outer_self = self\n\n            class _Bridge(MethodHook):\n                """Мост Xposed→Python: перенаправляет before-фазу в плагин."""\n\n                def before_hooked_method(self, param: Any) -> None:\n                    outer_self._on_post_notification(param)\n\n            handle = self.hook_method(method, _Bridge(), priority=10)\n            self._diag.write("nc.hook: registered")\n            return handle\n        except Exception as exc:\n            self._diag.write("nc.hook: hook_method failed", error=repr(exc))\n            return None\n\n    def _on_post_notification(self, param: Any) -> None:\n        """Обработчик ручного Xposed-хука ``postNotificationNameInternal``.\n\n        Сигнатура Java: ``(int id, boolean z, Object... objArr)``.\n        ``thisObject`` — экземпляр ``NotificationCenter`` (имеет\n        ``currentAccount``). Все ошибки подавляются: Java-родитель\n        обязан продолжить штатное исполнение.\n        """\n        try:\n            args = param.args\n            notification_id = args[0]\n            obj_args = args[2] if len(args) > 2 else None\n            this_obj = getattr(param, "thisObject", None)\n            account = getattr(this_obj, "currentAccount", 0) if this_obj else 0\n            self._nc_observer.dispatch(notification_id, account, obj_args)\n        except Exception as exc:\n            self._diag.write("nc.hook: dispatch failed", error=repr(exc))\n\n    def _on_nc_event(self, event_id: int, event_name: str, account: int, args: Any) -> None:\n        """Точка входа всех событий ``NotificationCenter``."""\n        if event_id not in self._args_dumped:\n            self._args_dumped.add(event_id)\n            self._diag.write(\n                "nc.dump",\n                event=event_name,\n                id=event_id,\n                account=account,\n                shape=_describe_args(args),\n            )\n        if event_name == "didReceiveNewMessages":\n            self._on_new_messages(account, args)\n        elif event_name in ("messageReceivedByServer", "messageReceivedByServer2"):\n            self._on_message_received_by_server(account, args)\n        elif event_name == "messagesRead":\n            self._on_messages_read(account, args)\n\n    def _on_new_messages(self, account: int, args: Any) -> None:\n        """Зарегистрировать наши исходящие сообщения, попавшие в чаты."""\n        messages = _extract_message_objects(args)\n        if not messages:\n            return\n        new_count = 0\n        for message_object in messages:\n            owner = _message_owner(message_object)\n            if owner is None:\n                continue\n            if not bool(getattr(owner, "out", False)):\n                continue\n            msg_id = int(getattr(owner, "id", 0) or 0)\n            if msg_id <= 0:\n                # Локальное сообщение с временным id — серверный id придёт\n                # отдельным NC ``messageReceivedByServer``.\n                continue\n            peer = getattr(owner, "peer_id", None)\n            user_id = _peer_user_id(peer)\n            if user_id is None:\n                continue\n            date = int(getattr(owner, "date", 0) or 0)\n            if self._tracker.register(account, user_id, msg_id, date):\n                new_count += 1\n        if new_count:\n            self._diag.write(\n                "nc.new_messages: registered", account=account, count=new_count\n            )\n\n    def _on_message_received_by_server(self, account: int, args: Any) -> None:\n        """Когда серверный id присвоен — поднимаем запись в трекере."""\n        if not isinstance(args, (list, tuple)) and not _is_indexable(args):\n            return\n        # Args исторически: ``(oldId, newId, message?, dialogId?, ...)``.\n        new_id = _coerce_int(_get_arg(args, 1))\n        if new_id is None or new_id <= 0:\n            return\n        message = _find_in_args(args, lambda v: _looks_like_tl_message(v))\n        if message is None:\n            self._diag.write(\n                "nc.msg_received: no tl message in args",\n                shape=_describe_args(args),\n            )\n            return\n        if not bool(getattr(message, "out", False)):\n            return\n        peer = getattr(message, "peer_id", None)\n        user_id = _peer_user_id(peer)\n        if user_id is None:\n            return\n        date = int(getattr(message, "date", 0) or 0)\n        # Один и тот же messageReceivedByServer может прилететь несколько\n        # раз (per-account NC + другие хуки). Логируем только при реальной\n        # вставке, чтобы не спамить диагностику.\n        if self._tracker.register(account, user_id, new_id, date):\n            self._diag.write(\n                "nc.msg_received: registered",\n                account=account,\n                user_id=user_id,\n                msg_id=new_id,\n            )\n\n    def _on_messages_read(self, account: int, args: Any) -> None:\n        """Обработать обновление ``read_outbox_max_id``.\n\n        ``args`` ожидаются как ``(inbox, outbox)`` — два\n        ``LongSparseIntArray dialogId -> maxId``. На разных сборках\n        Telegram-Android встречаются ``SparseLongArray`` /\n        ``LongSparseLongArray``. Поэтому работаем с тем, что есть,\n        через duck-typed обращения ``size()``, ``keyAt()``, ``valueAt()``.\n        """\n        outbox = _get_arg(args, 1)\n        if outbox is None:\n            # Telegram-Android посылает ``messagesRead(inbox, outbox)``,\n            # причём аут-бокс часто ``null`` (когда пришёл только инбокс-\n            # рид). Это штатное событие, не пишем в диагностику.\n            return\n        try:\n            size = int(outbox.size())\n        except Exception as exc:\n            self._diag.write("nc.messages_read: bad outbox", error=repr(exc))\n            return\n        if size == 0:\n            return\n        now = self._time.now_epoch()\n        for i in range(size):\n            try:\n                dialog_id = int(outbox.keyAt(i))\n                max_id = int(outbox.valueAt(i))\n            except Exception as exc:\n                self._diag.write(\n                    "nc.messages_read: kv read failed",\n                    error=repr(exc),\n                    index=i,\n                )\n                continue\n            if dialog_id <= 0:\n                # < 0 — групп/каналы; они вне области плагина.\n                continue\n            user_id = dialog_id\n            event = self._read_service.handle_outbox_read(\n                account, _SyntheticPeer(user_id), max_id, now\n            )\n            self._diag.write(\n                "nc.messages_read: outbox entry",\n                account=account,\n                user_id=user_id,\n                max_id=max_id,\n                consumed=0 if event is None else event.count,\n            )\n            if event is None:\n                continue\n            gate_settings = self._current_gate_settings()\n            allow = self._gate.should_notify(event, gate_settings)\n            self._diag.write(\n                "nc.messages_read: gate",\n                allow=allow,\n                user_id=event.user_id,\n                count=event.count,\n                age=event.age_seconds(),\n                enabled=gate_settings.enabled,\n                hide_when_chat_open=gate_settings.hide_when_chat_open,\n                recent_only=gate_settings.recent_only_seconds,\n                excluded=len(gate_settings.excluded_user_ids),\n            )\n            if not allow:\n                continue\n            user_name = self._user_resolver.display_name(event.user_id)\n            self._publish_read_notification(event, user_name)\n            self._tracked_dialogs.add((event.account, event.user_id))\n\n    def _publish_read_notification(self, event: ReadEvent, user_name: str) -> None:\n        """Опубликовать уведомление о прочтении согласно выбранному режиму.\n\n        Маршрутизирует событие по одной из трёх веток:\n\n        - :data:`NOTIFICATION_MODE_SYSTEM` — обычное системное\n          уведомление (тихий канал).\n        - :data:`NOTIFICATION_MODE_PUSH` — системное уведомление в\n          пуш-канале (Android покажет heads-up поверх экрана).\n        - :data:`NOTIFICATION_MODE_OVERLAY` — собственный баннер\n          плагина в стиле темы Telegram, без системного уведомления.\n        """\n        mode = _coerce_mode_idx(\n            self.get_setting(SETTING_NOTIFICATION_MODE_IDX, DEFAULT_NOTIFICATION_MODE_IDX)\n        )\n        self._diag.write("publish: mode", mode=mode)\n        if mode == NOTIFICATION_MODE_SYSTEM:\n            self._notifier.show(event, user_name, heads_up=False)\n            return\n        if mode == NOTIFICATION_MODE_PUSH:\n            self._notifier.show(event, user_name, heads_up=True)\n            return\n        # Режим «только всплывашка»: рисуем свой баннер. Если он не\n        # смог отобразиться (нет разрешения и нет фрагмента-хоста, т.е.\n        # exteraGram свернут), используем push-уведомление как самое\n        # близкое визуальное представление — пользователь хотя бы\n        # увидит событие, и в настройках сможет дать разрешение\n        # «Поверх других приложений».\n        title = format_notification_title(user_name)\n        body = format_notification_body(event.count)\n        duration_ms, alpha, side_margin_dp = self._current_overlay_look()\n        if self._overlay.show(\n            event.account,\n            event.user_id,\n            title,\n            body,\n            duration_ms=duration_ms,\n            alpha=alpha,\n            side_margin_dp=side_margin_dp,\n        ):\n            return\n        self._diag.write("publish: overlay unavailable, fallback to push")\n        self._notifier.show(event, user_name, heads_up=True)\n\n    def _current_overlay_look(self) -> tuple[int, float, int]:\n        """Считать пользовательские параметры всплывашки.\n\n        :returns: ``(duration_ms, alpha, side_margin_dp)``.\n        """\n        duration_idx = _clamp_idx(\n            self.get_setting(\n                SETTING_OVERLAY_DURATION_IDX, DEFAULT_OVERLAY_DURATION_IDX\n            ),\n            DEFAULT_OVERLAY_DURATION_IDX,\n            len(OVERLAY_DURATION_MS_BY_IDX) - 1,\n        )\n        alpha_idx = _clamp_idx(\n            self.get_setting(SETTING_OVERLAY_ALPHA_IDX, DEFAULT_OVERLAY_ALPHA_IDX),\n            DEFAULT_OVERLAY_ALPHA_IDX,\n            len(OVERLAY_ALPHA_BY_IDX) - 1,\n        )\n        margin_idx = _clamp_idx(\n            self.get_setting(\n                SETTING_OVERLAY_SIDE_MARGIN_IDX, DEFAULT_OVERLAY_SIDE_MARGIN_IDX\n            ),\n            DEFAULT_OVERLAY_SIDE_MARGIN_IDX,\n            len(OVERLAY_SIDE_MARGIN_DP_BY_IDX) - 1,\n        )\n        return (\n            OVERLAY_DURATION_MS_BY_IDX[duration_idx],\n            OVERLAY_ALPHA_BY_IDX[alpha_idx],\n            OVERLAY_SIDE_MARGIN_DP_BY_IDX[margin_idx],\n        )\n\n    def _current_gate_settings(self) -> GateSettings:\n        """Считать актуальный снимок настроек, релевантных для ``NotificationGate``."""\n        enabled = bool(self.get_setting(SETTING_ENABLED, DEFAULT_ENABLED))\n        hide = bool(self.get_setting(SETTING_HIDE_WHEN_CHAT_OPEN, DEFAULT_HIDE_WHEN_CHAT_OPEN))\n        idx = _coerce_recent_idx(self.get_setting(SETTING_RECENT_ONLY_IDX, DEFAULT_RECENT_ONLY_IDX))\n        raw_excluded = self.get_setting(SETTING_EXCLUDED_USER_IDS, DEFAULT_EXCLUDED_USER_IDS)\n        excluded = parse_user_id_list(raw_excluded if isinstance(raw_excluded, str) else "")\n        return GateSettings(\n            enabled=enabled,\n            hide_when_chat_open=hide,\n            recent_only_seconds=RECENT_ONLY_SECONDS_BY_IDX[idx],\n            excluded_user_ids=excluded,\n        )\n\n    def _open_channel_settings(self, *_args: Any, **_kwargs: Any) -> None:\n        """Открыть системные настройки канала уведомлений Android.\n\n        Открывается канал, соответствующий текущему режиму\n        (тихий — для «обычного», пуш — для «уведомление + пуш»).\n        Если канал не успел создаться, открываем общий экран настроек\n        уведомлений приложения как разумный fallback.\n        """\n        self._diag.write("open_channel_settings: clicked")\n        try:\n            context = _application_context()\n            if context is None:\n                self._diag.write("open_channel_settings: no context")\n                return\n            self._notifier.ensure_channel()\n            from android.content import Intent\n            from android.provider import Settings\n\n            mode = _coerce_mode_idx(\n                self.get_setting(SETTING_NOTIFICATION_MODE_IDX, DEFAULT_NOTIFICATION_MODE_IDX)\n            )\n            target_channel = (\n                NOTIFICATION_CHANNEL_ID_PUSH\n                if mode == NOTIFICATION_MODE_PUSH\n                else NOTIFICATION_CHANNEL_ID\n            )\n            channel_intent = Intent(Settings.ACTION_CHANNEL_NOTIFICATION_SETTINGS)\n            channel_intent.putExtra(Settings.EXTRA_APP_PACKAGE, context.getPackageName())\n            channel_intent.putExtra(Settings.EXTRA_CHANNEL_ID, target_channel)\n            channel_intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)\n            if channel_intent.resolveActivity(context.getPackageManager()) is not None:\n                context.startActivity(channel_intent)\n                self._diag.write(\n                    "open_channel_settings: opened channel",\n                    channel=target_channel,\n                )\n                return\n            self._diag.write("open_channel_settings: channel intent unresolved, fallback")\n            app_intent = Intent(Settings.ACTION_APP_NOTIFICATION_SETTINGS)\n            app_intent.putExtra(Settings.EXTRA_APP_PACKAGE, context.getPackageName())\n            app_intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)\n            context.startActivity(app_intent)\n        except Exception as exc:\n            self._diag.write("open_channel_settings: failed", error=repr(exc))\n\n    def _open_overlay_permission(self, *_args: Any, **_kwargs: Any) -> None:\n        """Открыть системный экран «Поверх других приложений».\n\n        Нужно для режима «Только всплывашка»: без разрешения наш баннер\n        умеет показываться лишь поверх ``LaunchActivity`` exteraGram\n        (когда приложение на переднем плане). С разрешением — поверх\n        любого приложения.\n        """\n        self._diag.write("open_overlay_permission: clicked")\n        try:\n            context = _application_context()\n            if context is None:\n                self._diag.write("open_overlay_permission: no context")\n                return\n            from android.content import Intent\n            from android.net import Uri\n            from android.provider import Settings\n\n            intent = Intent(Settings.ACTION_MANAGE_OVERLAY_PERMISSION)\n            intent.setData(Uri.parse(f"package:{context.getPackageName()}"))\n            intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)\n            if intent.resolveActivity(context.getPackageManager()) is not None:\n                context.startActivity(intent)\n                self._diag.write("open_overlay_permission: opened")\n                return\n            # Запасной экран, если ACTION_MANAGE_OVERLAY_PERMISSION\n            # запрещён на устройстве: общий экран разрешений приложения.\n            fallback = Intent(Settings.ACTION_APPLICATION_DETAILS_SETTINGS)\n            fallback.setData(Uri.parse(f"package:{context.getPackageName()}"))\n            fallback.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)\n            context.startActivity(fallback)\n            self._diag.write("open_overlay_permission: opened fallback")\n        except Exception as exc:\n            self._diag.write("open_overlay_permission: failed", error=repr(exc))\n\n    def _publish_test_notification(self, *_args: Any, **_kwargs: Any) -> None:\n        """Опубликовать тестовое уведомление вручную, минуя поток прочтений.\n\n        Использует текущий выбранный режим, чтобы пользователь мог\n        сразу увидеть, как именно будет выглядеть уведомление.\n        """\n        self._diag.write("test_notification: clicked")\n        try:\n            now = self._time.now_epoch()\n            event = ReadEvent(\n                account=0,\n                user_id=0,\n                count=1,\n                last_msg_id=0,\n                last_date_epoch=now,\n                now_epoch=now,\n            )\n            self._publish_read_notification(event, "Тест уведомления")\n        except Exception as exc:\n            self._diag.write("test_notification: failed", error=repr(exc))\n\n\nclass _SyntheticPeer:\n    """Псевдо-пир с только ``user_id``, для совместимости с ``ReadService``.\n\n    NC даёт нам уже готовый ``dialog_id``; превращать его в полноценный\n    ``TL_peerUser`` нет смысла — достаточно объекта-обёртки с одним полем.\n    """\n\n    __slots__ = ("user_id",)\n\n    def __init__(self, user_id: int) -> None:\n        self.user_id = int(user_id)\n\n\ndef _describe_args(args: Any) -> str:\n    """Краткое описание структуры ``args`` для диагностики."""\n    try:\n        if args is None:\n            return "None"\n        if hasattr(args, "__len__"):\n            try:\n                size = len(args)\n            except Exception:\n                size = -1\n            if isinstance(size, int) and 0 <= size <= 16:\n                parts: list[str] = []\n                for i in range(size):\n                    try:\n                        item = args[i]\n                    except Exception:\n                        parts.append("<no-idx>")\n                        continue\n                    parts.append(type(item).__name__)\n                return f"len={size}[{\', \'.join(parts)}]"\n            return f"len={size}"\n        return type(args).__name__\n    except Exception:\n        return "<undescr>"\n\n\ndef _extract_message_objects(args: Any) -> list[Any]:\n    """Найти ``ArrayList<MessageObject>`` в ``args`` события NC."""\n    if args is None:\n        return []\n    # Перебираем элементы и берём первый «итерируемый» список.\n    found: list[Any] = []\n    for value in _iter_args(args):\n        if value is None:\n            continue\n        if isinstance(value, (str, bytes, int, float, bool)):\n            continue\n        try:\n            iterable = iter(value)\n        except Exception:\n            continue\n        items = list(iterable)\n        if not items:\n            continue\n        # Проверка: первый элемент должен иметь ``messageOwner`` (MessageObject)\n        # либо сам быть похож на TLRPC.Message.\n        sample = items[0]\n        if hasattr(sample, "messageOwner") or _looks_like_tl_message(sample):\n            for item in items:\n                found.append(item)\n            break\n    return found\n\n\ndef _message_owner(message_object: Any) -> Any:\n    """Достать ``TLRPC.Message`` из ``MessageObject`` или вернуть сам объект."""\n    if message_object is None:\n        return None\n    owner = getattr(message_object, "messageOwner", None)\n    if owner is not None:\n        return owner\n    return message_object\n\n\ndef _looks_like_tl_message(value: Any) -> bool:\n    """Грубая проверка: похоже ли значение на ``TLRPC.Message``."""\n    if value is None:\n        return False\n    return (\n        hasattr(value, "peer_id")\n        and hasattr(value, "out")\n        and hasattr(value, "id")\n        and hasattr(value, "date")\n    )\n\n\ndef _peer_user_id(peer: Any) -> int | None:\n    """user_id у TL-пира, если это личный диалог."""\n    if peer is None:\n        return None\n    if _has_positive_int(peer, "chat_id"):\n        return None\n    if _has_positive_int(peer, "channel_id"):\n        return None\n    value = getattr(peer, "user_id", None)\n    if not isinstance(value, int) or value <= 0:\n        return None\n    return value\n\n\ndef _has_positive_int(obj: Any, attr: str) -> bool:\n    value = getattr(obj, attr, None)\n    return isinstance(value, int) and value > 0\n\n\ndef _coerce_int(value: Any) -> int | None:\n    """Преобразовать ``Long``/``Integer``/Python-int в Python-int."""\n    if value is None:\n        return None\n    try:\n        return int(value)\n    except Exception:\n        return None\n\n\ndef _get_arg(args: Any, index: int) -> Any:\n    """Безопасно достать ``args[index]``."""\n    try:\n        return args[index]\n    except Exception:\n        return None\n\n\ndef _is_indexable(args: Any) -> bool:\n    """Допускает ли значение ``args[0]``."""\n    try:\n        _ = args[0]\n        return True\n    except Exception:\n        return False\n\n\ndef _iter_args(args: Any) -> list[Any]:\n    """Безопасно вернуть содержимое ``Object[]`` или ``list``."""\n    out: list[Any] = []\n    if hasattr(args, "__len__"):\n        try:\n            size = len(args)\n        except Exception:\n            return out\n        for i in range(size):\n            try:\n                out.append(args[i])\n            except Exception:\n                out.append(None)\n        return out\n    if isinstance(args, (list, tuple)):\n        return list(args)\n    return out\n\n\ndef _find_in_args(args: Any, predicate: Any) -> Any:\n    """Найти в ``args`` первое значение, удовлетворяющее предикату."""\n    for value in _iter_args(args):\n        try:\n            if predicate(value):\n                return value\n        except Exception:\n            continue\n    return None\n', False, '<read_notification>/plugin.py'),
    'read_notification.services': ('"""Сервисный слой плагина.\n\nСодержит оркестрацию доменного слоя:\n\n- :mod:`.read_service` — приём TL-обновлений и превращение их в\n  доменные события :class:`~src.core.read_event.ReadEvent`.\n- :mod:`.gate` — правила, по которым событие либо приводит к\n  публикации Android-уведомления, либо подавляется.\n\nСлой не зависит от Android; для подключения к инфраструктуре\n``services`` принимает интерфейсы (foreground state, источник\nнастроек) через параметры конструктора.\n"""\n', True, '<read_notification>/services/__init__.py'),
    'read_notification.services.gate': ('"""Правила публикации уведомлений.\n\n«Ворота» решают, нужно ли превращать доменное событие в видимое\nсистемное уведомление. Слой принимает зависимости (источник настроек,\nсостояние переднего плана) через параметры, чтобы оставаться\nтестируемым без Android.\n"""\n\nfrom __future__ import annotations\n\nfrom dataclasses import dataclass\nfrom typing import Protocol\n\nfrom ..core.read_event import ReadEvent\n\n\n@dataclass(frozen=True, slots=True)\nclass GateSettings:\n    """Снимок настроек, релевантных для решения о публикации.\n\n    :param enabled: главный выключатель уведомлений.\n    :param hide_when_chat_open: подавлять уведомление, если этот чат\n        открыт сейчас.\n    :param recent_only_seconds: ``0`` — без ограничения по времени;\n        иначе — игнорировать события, где возраст сообщения больше\n        указанного в секундах.\n    :param excluded_user_ids: множество id собеседников, для которых\n        уведомления подавлены.\n    """\n\n    enabled: bool\n    hide_when_chat_open: bool\n    recent_only_seconds: int\n    excluded_user_ids: frozenset[int]\n\n\nclass ForegroundState(Protocol):\n    """Интерфейс источника знаний о текущем открытом чате."""\n\n    def is_chat_open(self, account: int, user_id: int) -> bool:  # pragma: no cover - протокол\n        """Возвращает ``True``, если указанный личный чат открыт сейчас."""\n\n\nclass NotificationGate:\n    """Применяет правила к :class:`ReadEvent` и возвращает решение.\n\n    :param foreground: объект, реализующий :class:`ForegroundState`.\n    """\n\n    def __init__(self, foreground: ForegroundState) -> None:\n        self._foreground = foreground\n\n    def should_notify(self, event: ReadEvent, settings: GateSettings) -> bool:\n        """Решить, публиковать ли уведомление по событию.\n\n        :param event: доменное событие прочтения.\n        :param settings: текущий снимок настроек.\n        :returns: ``True`` — уведомление публиковать; ``False`` — нет.\n        """\n        if not settings.enabled:\n            return False\n        if event.user_id in settings.excluded_user_ids:\n            return False\n        if (\n            settings.recent_only_seconds > 0\n            and event.age_seconds() > settings.recent_only_seconds\n        ):\n            return False\n        return not (\n            settings.hide_when_chat_open\n            and self._foreground.is_chat_open(event.account, event.user_id)\n        )\n', False, '<read_notification>/services/gate.py'),
    'read_notification.services.read_service': ('"""Доменный сервис: TL-обновления → ``ReadEvent``.\n\nСвязывает поток обновлений, идущий из catalib-хуков, и трекер\nотправленных сообщений. Изолирован от Android и логирования.\n"""\n\nfrom __future__ import annotations\n\nfrom collections.abc import Callable\nfrom typing import Any\n\nfrom ..core.dialog import extract_private_user_id\nfrom ..core.outbox_tracker import OutgoingTracker\nfrom ..core.read_event import ReadEvent\n\n\nclass ReadService:\n    """Сервис, обслуживающий поток обновлений отправки и прочтения.\n\n    :param tracker: in-memory трекер отправленных сообщений.\n    :param peer_extractor: функция, по объекту пира возвращающая\n        ``user_id`` собеседника или ``None``. По умолчанию —\n        :func:`src.core.dialog.extract_private_user_id`. Параметр\n        нужен для тестов: подмена функции позволяет проверить ветки\n        без TLRPC.\n    """\n\n    def __init__(\n        self,\n        tracker: OutgoingTracker,\n        *,\n        peer_extractor: Callable[[Any], int | None] = extract_private_user_id,\n    ) -> None:\n        self._tracker = tracker\n        self._peer_extractor = peer_extractor\n\n    def register_outgoing(self, account: int, message: Any) -> bool:\n        """Зарегистрировать отправленное сообщение из ``updateNewMessage``.\n\n        :param account: номер аккаунта.\n        :param message: объект TLRPC.Message; допустим ``None``.\n        :returns: ``True``, если сообщение принято к учёту;\n            ``False`` — если оно проигнорировано (не своё, не личный\n            чат, без id и т. п.).\n        """\n        if message is None:\n            return False\n        if not bool(getattr(message, "out", False)):\n            return False\n        peer = getattr(message, "peer_id", None)\n        user_id = self._peer_extractor(peer)\n        if user_id is None:\n            return False\n        msg_id = getattr(message, "id", None)\n        if not isinstance(msg_id, int) or msg_id <= 0:\n            return False\n        date_raw = getattr(message, "date", 0)\n        date_epoch = int(date_raw) if isinstance(date_raw, int) else 0\n        self._tracker.register(account, user_id, msg_id, date_epoch)\n        return True\n\n    def handle_outbox_read(\n        self,\n        account: int,\n        peer: Any,\n        max_id: Any,\n        now_epoch: int,\n    ) -> ReadEvent | None:\n        """Обработать ``updateReadHistoryOutbox`` и собрать ``ReadEvent``.\n\n        :param account: номер аккаунта.\n        :param peer: объект пира TLRPC.\n        :param max_id: верхняя граница прочитанных сообщений (TL ``max_id``).\n        :param now_epoch: текущее время в Unix epoch секундах.\n        :returns: :class:`ReadEvent`, если в трекере нашлись\n            соответствующие отправленные сообщения; иначе ``None``.\n        """\n        user_id = self._peer_extractor(peer)\n        if user_id is None:\n            return None\n        if not isinstance(max_id, int) or max_id <= 0:\n            return None\n        result = self._tracker.consume_up_to(account, user_id, max_id)\n        if result.count == 0:\n            return None\n        assert result.last_msg_id is not None  # гарантирует count > 0\n        assert result.last_date_epoch is not None\n        return ReadEvent(\n            account=account,\n            user_id=user_id,\n            count=result.count,\n            last_msg_id=result.last_msg_id,\n            last_date_epoch=result.last_date_epoch,\n            now_epoch=int(now_epoch),\n        )\n\n    def forget_dialog(self, account: int, user_id: int) -> None:\n        """Пробросить запрос на сброс диалога в трекер.\n\n        :param account: номер аккаунта.\n        :param user_id: id собеседника.\n        """\n        self._tracker.forget_dialog(account, user_id)\n', False, '<read_notification>/services/read_service.py'),
    'read_notification.ui': ('"""UI-слой плагина: декларативная схема экрана настроек.\n\nСодержит единственный модуль :mod:`.settings_schema`, который собирает\nсписок элементов catalib (``SettingItem``) для отображения в стандартном\nэкране настроек плагина exteraGram.\n\nСлой не зависит от ``infra``: внешние действия (например, открытие\nсистемных настроек канала уведомлений) передаются через коллбэк,\nкоторый связывается с инфраструктурой на уровне ``plugin.py``.\n"""\n', True, '<read_notification>/ui/__init__.py'),
    'read_notification.ui.settings_schema': ('"""Декларативная схема экрана настроек плагина.\n\nИспользует API catalib (``catalib.support.settings``): на устройстве\nэлементы рендерятся в нативный экран ``ui.settings`` exteraGram, в\nофлайн-тестах остаются ``SettingItem``-объектами с теми же полями.\n\nСигнатура :func:`build_settings` принимает внешние коллбэки —\n``open_channel_settings``, ``publish_test_notification`` и\n``open_overlay_permission``. Это сохраняет UI-слой чистым: он не знает,\nкак открывать системные настройки и публиковать уведомления, и не\nзависит от ``infra``.\n"""\n\nfrom __future__ import annotations\n\nfrom collections.abc import Callable\nfrom typing import Any\n\nfrom catalib.support import settings\n\nfrom ..config import (\n    DEFAULT_ENABLED,\n    DEFAULT_EXCLUDED_USER_IDS,\n    DEFAULT_HIDE_WHEN_CHAT_OPEN,\n    DEFAULT_NOTIFICATION_MODE_IDX,\n    DEFAULT_OVERLAY_ALPHA_IDX,\n    DEFAULT_OVERLAY_DURATION_IDX,\n    DEFAULT_OVERLAY_SIDE_MARGIN_IDX,\n    DEFAULT_RECENT_ONLY_IDX,\n    NOTIFICATION_MODE_ITEMS,\n    OVERLAY_ALPHA_ITEMS,\n    OVERLAY_DURATION_ITEMS,\n    OVERLAY_SIDE_MARGIN_ITEMS,\n    RECENT_ONLY_ITEMS,\n    SETTING_ENABLED,\n    SETTING_EXCLUDED_USER_IDS,\n    SETTING_HIDE_WHEN_CHAT_OPEN,\n    SETTING_NOTIFICATION_MODE_IDX,\n    SETTING_OVERLAY_ALPHA_IDX,\n    SETTING_OVERLAY_DURATION_IDX,\n    SETTING_OVERLAY_SIDE_MARGIN_IDX,\n    SETTING_RECENT_ONLY_IDX,\n)\n\n\ndef build_settings(\n    open_channel_settings: Callable[..., Any],\n    publish_test_notification: Callable[..., Any],\n    open_overlay_permission: Callable[..., Any],\n    include_overlay_tuning: bool = False,\n) -> list[Any]:\n    """Собрать список настроек для экрана плагина.\n\n    :param open_channel_settings: callable, открывающий системные\n        настройки канала Android.\n    :param publish_test_notification: callable, публикующий тестовое\n        уведомление сразу же.\n    :param open_overlay_permission: callable, открывающий системный\n        экран разрешения «Поверх других приложений».\n    :param include_overlay_tuning: добавить секцию параметров\n        всплывашки (длительность, прозрачность, боковые отступы).\n        Используется только при выбранном режиме «Только всплывашка».\n    :returns: список ``SettingItem``, готовый к возврату из метода\n        ``settings()`` плагина.\n    """\n    items: list[Any] = [\n        settings.header("Уведомления о прочтении"),\n        settings.switch(\n            SETTING_ENABLED,\n            "Включить уведомления",\n            DEFAULT_ENABLED,\n            "Показывать нативное Android-уведомление, когда собеседник прочитал ваши сообщения",\n        ),\n        settings.selector(\n            SETTING_NOTIFICATION_MODE_IDX,\n            "Тип уведомления",\n            DEFAULT_NOTIFICATION_MODE_IDX,\n            list(NOTIFICATION_MODE_ITEMS),\n        ),\n        settings.switch(\n            SETTING_HIDE_WHEN_CHAT_OPEN,\n            "Скрывать при открытом чате",\n            DEFAULT_HIDE_WHEN_CHAT_OPEN,\n            "Не уведомлять, если вы сейчас в этом чате",\n        ),\n        settings.selector(\n            SETTING_RECENT_ONLY_IDX,\n            "Свежесть прочтения",\n            DEFAULT_RECENT_ONLY_IDX,\n            list(RECENT_ONLY_ITEMS),\n        ),\n        settings.header("Исключения"),\n        settings.text_input(\n            SETTING_EXCLUDED_USER_IDS,\n            "ID собеседников",\n            DEFAULT_EXCLUDED_USER_IDS,\n            "Через запятую или пробел. Невалидные значения игнорируются.",\n        ),\n    ]\n    if include_overlay_tuning:\n        items.extend(_overlay_tuning_items())\n    items.extend(\n        [\n            settings.header("Диагностика"),\n            settings.text(\n                "Опубликовать тестовое уведомление",\n                subtext="Использует выбранный тип уведомления. Проверит права и канал.",\n                on_click=publish_test_notification,\n            ),\n            settings.text(\n                "Канал уведомлений в системе",\n                subtext="Откроет настройки канала Android (звук, вибрация, важность)",\n                on_click=open_channel_settings,\n            ),\n            settings.text(\n                "Разрешить наложение поверх приложений",\n                subtext="Нужно для режима «Только всплывашка», чтобы баннер видно за пределами exteraGram",\n                on_click=open_overlay_permission,\n            ),\n        ]\n    )\n    return items\n\n\ndef _overlay_tuning_items() -> list[Any]:\n    """Секция параметров всплывашки.\n\n    Показывается только когда выбран режим «Только всплывашка» —\n    остальные режимы её параметры не используют, поэтому секция была\n    бы шумом.\n    """\n    return [\n        settings.header("Параметры всплывашки"),\n        settings.selector(\n            SETTING_OVERLAY_DURATION_IDX,\n            "Длительность показа",\n            DEFAULT_OVERLAY_DURATION_IDX,\n            list(OVERLAY_DURATION_ITEMS),\n        ),\n        settings.selector(\n            SETTING_OVERLAY_ALPHA_IDX,\n            "Прозрачность",\n            DEFAULT_OVERLAY_ALPHA_IDX,\n            list(OVERLAY_ALPHA_ITEMS),\n        ),\n        settings.selector(\n            SETTING_OVERLAY_SIDE_MARGIN_IDX,\n            "Отступы по краям",\n            DEFAULT_OVERLAY_SIDE_MARGIN_IDX,\n            list(OVERLAY_SIDE_MARGIN_ITEMS),\n        ),\n    ]\n', False, '<read_notification>/ui/settings_schema.py'),
    'read_notification.util': ('"""Чистые утилиты плагина (без SDK exteraGram и Android).\n\nСодержит модули, переиспользуемые между слоями: форматирование строк\nуведомления, нормализация пользовательских списков и т. п.\n"""\n', True, '<read_notification>/util/__init__.py'),
    'read_notification.util.formatting': ('"""Форматирование строк уведомления и разбор пользовательских вводов.\n\nМодуль чистый: без обращений к SDK exteraGram и Android. Тесты на эти\nфункции — самые надёжные «гарантии корректности» представления.\n"""\n\nfrom __future__ import annotations\n\nimport re\nfrom typing import Final\n\n#: Разделители в списке id, который пользователь вводит в настройках.\n_USER_LIST_SEPARATORS = re.compile(r"[\\s,;]+")\n\n#: Шаблоны русских числительных «сообщение/сообщения/сообщений».\n_FORM_ONE: Final[str] = "сообщение"\n_FORM_FEW: Final[str] = "сообщения"\n_FORM_MANY: Final[str] = "сообщений"\n\n\ndef russian_plural_form(count: int) -> str:\n    """Выбрать русскую форму слова «сообщение» по числу.\n\n    :param count: число элементов; обрабатывается по модулю.\n    :returns: одна из строк «сообщение», «сообщения», «сообщений».\n    """\n    n = abs(int(count))\n    mod10 = n % 10\n    mod100 = n % 100\n    if mod10 == 1 and mod100 != 11:\n        return _FORM_ONE\n    if 2 <= mod10 <= 4 and not 12 <= mod100 <= 14:\n        return _FORM_FEW\n    return _FORM_MANY\n\n\ndef format_count_phrase(count: int) -> str:\n    """Сформатировать фразу «N сообщение/сообщения/сообщений».\n\n    :param count: количество (≥ 0).\n    :returns: строка вида ``"3 сообщения"``.\n    """\n    return f"{int(count)} {russian_plural_form(count)}"\n\n\ndef format_notification_title(user_name: str) -> str:\n    """Заголовок уведомления — имя собеседника, защищённое от пустоты.\n\n    :param user_name: имя; может быть пустым или ``None`` — в этом случае\n        подставляется нейтральное «Собеседник».\n    :returns: непустая строка заголовка.\n    """\n    if not isinstance(user_name, str):\n        return "Собеседник"\n    cleaned = user_name.strip()\n    return cleaned if cleaned else "Собеседник"\n\n\ndef format_notification_body(count: int) -> str:\n    """Строка тела уведомления: «прочитал(а) ваши N сообщений».\n\n    :param count: число прочитанных сообщений; ожидается положительным.\n    :returns: строка для ``setContentText``.\n    """\n    n = max(1, int(count))\n    if n == 1:\n        return "прочитал(а) ваше сообщение"\n    return f"прочитал(а) ваши {format_count_phrase(n)}"\n\n\ndef parse_user_id_list(raw: str) -> frozenset[int]:\n    """Разобрать строку из настроек в множество положительных id.\n\n    Допустимые разделители: пробел, запятая, точка с запятой. Все элементы,\n    которые не парсятся как положительное целое, тихо игнорируются —\n    это пользовательский ввод, мы не падаем из-за опечатки.\n\n    :param raw: строка из настроек.\n    :returns: иммутабельное множество положительных int.\n    """\n    if not isinstance(raw, str) or not raw.strip():\n        return frozenset()\n    out: set[int] = set()\n    for token in _USER_LIST_SEPARATORS.split(raw.strip()):\n        if not token:\n            continue\n        try:\n            value = int(token)\n        except ValueError:\n            continue\n        if value > 0:\n            out.add(value)\n    return frozenset(out)\n', False, '<read_notification>/util/formatting.py'),
    'catalib': ('"""catalib — инструмент сборки модульных плагинов exteraGram в один файл.\n\nПакет содержит две среды исполнения с жёсткой границей между ними:\n\n- Среда инструмента (подпакеты ``cli``, ``manifest``, ``bundler``, ``deploy``,\n  ``scaffold``) — исполняется на машине разработчика.\n- Встраиваемая среда (подпакеты ``runtime``, ``support``) — её исходники\n  попадают внутрь собранного плагина и исполняются под Chaquopy на устройстве,\n  поэтому зависят только от стандартной библиотеки и SDK exteraGram.\n\nЗдесь же объявлена :func:`check_for_updates` — безопасная проверка наличия\nболее новой версии catalib на PyPI. Все её зависимости (``urllib``,\n``json`` и т. п.) импортируются **лениво внутри функции**: при обычном\n``import catalib`` (в т. ч. в вендоренном виде внутри плагина на\nустройстве) никаких сетевых запросов и тяжёлых импортов не происходит.\nВызывается из CLI; никогда не роняет команду.\n"""\n\nfrom __future__ import annotations\n\n__all__ = ["__version__", "check_for_updates"]\n\n#: Версия пакета. Единый источник истины — синхронизирована с ``pyproject.toml``.\n__version__ = "0.3.3"\n\n#: Имя пакета на PyPI и переменная окружения для отключения проверки.\n_PYPI_JSON_URL = "https://pypi.org/pypi/catalib/json"\n_OPT_OUT_ENV = "CATALIB_NO_UPDATE_CHECK"\n#: Срок жизни кеша последней проверки, секунд (сутки).\n_CACHE_TTL_SECONDS = 24 * 60 * 60\n\n\ndef _parse_version(value: str) -> tuple[int, ...]:\n    """Разобрать строку версии ``X.Y.Z`` в кортеж чисел для сравнения.\n\n    Нечисловые/пред-релизные части отбрасываются с первого нечислового\n    сегмента (грубое, но безопасное сравнение SemVer без внешних\n    зависимостей: ложного «доступно обновление» не даёт).\n    """\n    parts: list[int] = []\n    for chunk in value.strip().split("."):\n        if chunk.isdigit():\n            parts.append(int(chunk))\n        else:\n            break\n    return tuple(parts)\n\n\ndef _is_newer(latest: str, current: str) -> bool:\n    """``True``, если ``latest`` строго новее ``current``."""\n    lp, cp = _parse_version(latest), _parse_version(current)\n    if not lp or not cp:\n        return False\n    return lp > cp\n\n\ndef _cache_path() -> str:\n    """Путь к файлу кеша проверки обновлений (в каталоге кеша пользователя)."""\n    import os\n\n    base = os.environ.get("XDG_CACHE_HOME") or os.path.join(\n        os.path.expanduser("~"), ".cache"\n    )\n    return os.path.join(base, "catalib", "update-check.json")\n\n\ndef _read_cache(now: float) -> str | None:\n    """Вернуть закешированную последнюю версию, если кеш свежий, иначе ``None``."""\n    import json\n\n    try:\n        with open(_cache_path(), encoding="utf-8") as handle:\n            data = json.load(handle)\n        if now - float(data["ts"]) < _CACHE_TTL_SECONDS:\n            latest = data.get("latest")\n            return latest if isinstance(latest, str) else None\n    except Exception:\n        return None\n    return None\n\n\ndef _write_cache(now: float, latest: str) -> None:\n    """Сохранить результат проверки (без падения при ошибке ФС)."""\n    import json\n    import os\n\n    try:\n        path = _cache_path()\n        os.makedirs(os.path.dirname(path), exist_ok=True)\n        with open(path, "w", encoding="utf-8") as handle:\n            json.dump({"ts": now, "latest": latest}, handle)\n    except Exception:\n        pass\n\n\ndef _fetch_latest_version(timeout: float) -> str | None:\n    """Запросить последнюю версию catalib с PyPI (или ``None`` при ошибке)."""\n    import json\n    import urllib.request\n\n    try:\n        with urllib.request.urlopen(_PYPI_JSON_URL, timeout=timeout) as response:\n            payload = json.loads(response.read().decode("utf-8"))\n        version = payload["info"]["version"]\n        return version if isinstance(version, str) else None\n    except Exception:\n        return None\n\n\ndef check_for_updates(timeout: float = 2.5) -> str | None:\n    """Проверить, есть ли на PyPI более новая версия catalib.\n\n    Полностью безопасна: при отключении, любой ошибке сети, таймауте или\n    проблеме с кешем возвращает ``None`` и ничего не печатает. Сетевой\n    запрос делается не чаще раза в сутки (кеш\n    ``~/.cache/catalib/update-check.json``). Отключается переменной\n    окружения ``CATALIB_NO_UPDATE_CHECK=1``. Не вызывается при импорте\n    пакета — только из CLI.\n\n    :param timeout: таймаут HTTP-запроса к PyPI в секундах.\n    :returns: строка более новой версии (например ``"0.4.0"``) либо\n        ``None``, если обновления нет или проверку выполнить не удалось.\n    """\n    import os\n    import time\n\n    if os.environ.get(_OPT_OUT_ENV, "").strip() not in ("", "0", "false", "False"):\n        return None\n\n    now = time.time()\n    latest = _read_cache(now)\n    if latest is None:\n        latest = _fetch_latest_version(timeout)\n        if latest is None:\n            return None\n        _write_cache(now, latest)\n\n    return latest if _is_newer(latest, __version__) else None\n', True, '<catalib-vendor>/catalib/__init__.py'),
    'catalib.support': ('"""Урезанный фасад catalib.support (сгенерирован catalib).\n\nИмпортирует только то, что использует плагин, чтобы фасад не\nтянул отсечённые подмодули."""\n\nfrom __future__ import annotations\n\nfrom catalib.support import android\nfrom catalib.support import client\nfrom catalib.support import settings\nfrom catalib.support.plugin import CatalibPlugin\nfrom catalib.support.proxy import Base, java_subclass, jfield, joverride\nfrom catalib.support.sdk import MethodHook, find_class, log, run_on_ui_thread\n\n__all__ = [\'Base\', \'CatalibPlugin\', \'MethodHook\', \'android\', \'client\', \'find_class\', \'java_subclass\', \'jfield\', \'joverride\', \'log\', \'run_on_ui_thread\', \'settings\']\n', True, '<catalib-vendor>/catalib/support/__init__.py'),
    'catalib.support.android': ('"""Обёртки модуля SDK ``android_utils``.\n\nНа устройстве используются настоящие интерфейс-обёртки exteraGram\n(``R``, ``OnClickListener``, ``OnLongClickListener``, ``copy_to_clipboard``);\nвне приложения — функциональные офлайн-заглушки, которые действительно\nвызывают переданный callable (это полноценный офлайн-контракт для тестов,\nа не пустышка; на устройстве всегда работает настоящий SDK).\n\n``log`` и ``run_on_ui_thread`` ре-экспортируются из :mod:`catalib.support.sdk`\n(единая точка адаптации, ADR-0003): там уже реализованы безопасный импорт и\nfallback по аргументу задержки. Зависит только от стандартной библиотеки,\nSDK exteraGram и встраиваемого периметра catalib.\n"""\n\nfrom __future__ import annotations\n\nfrom collections.abc import Callable\nfrom typing import Any\n\nfrom catalib.support.sdk import log, run_on_ui_thread\n\n#: Записанные офлайн вызовы ``copy_to_clipboard`` (для проверок в тестах).\n_clipboard_history: list[str] = []\n\n\ntry:  # pragma: no cover - ветка выполняется только на устройстве\n    from android_utils import R\nexcept Exception:  # pragma: no cover - ветка для обычного Python\n\n    class R:\n        """Офлайн-заглушка ``java.lang.Runnable`` из Python-callable.\n\n        Хранит callable и вызывает его при ``run()`` либо при вызове\n        экземпляра — этого достаточно для офлайн-тестов логики.\n        """\n\n        def __init__(self, fn: Callable[[], Any]) -> None:\n            self.fn = fn\n\n        def run(self) -> Any:\n            """Выполнить обёрнутый callable."""\n            return self.fn()\n\n        def __call__(self) -> Any:\n            return self.fn()\n\n\ntry:  # pragma: no cover - ветка выполняется только на устройстве\n    from android_utils import OnClickListener\nexcept Exception:  # pragma: no cover - ветка для обычного Python\n\n    class OnClickListener:\n        """Офлайн-заглушка ``View.OnClickListener``.\n\n        Callable получает кликнутый ``View`` единственным аргументом.\n        """\n\n        def __init__(self, fn: Callable[[Any], Any]) -> None:\n            self.fn = fn\n\n        def onClick(self, view: Any = None) -> Any:\n            """Сымитировать клик по ``view``."""\n            return self.fn(view)\n\n        def __call__(self, view: Any = None) -> Any:\n            return self.fn(view)\n\n\ntry:  # pragma: no cover - ветка выполняется только на устройстве\n    from android_utils import OnLongClickListener\nexcept Exception:  # pragma: no cover - ветка для обычного Python\n\n    class OnLongClickListener:\n        """Офлайн-заглушка ``View.OnLongClickListener``.\n\n        Callable получает ``View`` и возвращает ``bool``: ``True`` —\n        событие поглощено, ``False`` — обработка продолжается.\n        """\n\n        def __init__(self, fn: Callable[[Any], bool]) -> None:\n            self.fn = fn\n\n        def onLongClick(self, view: Any = None) -> bool:\n            """Сымитировать долгий клик по ``view``."""\n            return bool(self.fn(view))\n\n        def __call__(self, view: Any = None) -> bool:\n            return bool(self.fn(view))\n\n\ndef copy_to_clipboard(text: str) -> None:\n    """Скопировать строку в системный буфер обмена.\n\n    На устройстве вызывает ``android_utils.copy_to_clipboard`` (та же\n    стандартная всплывашка «скопировано»). Офлайн — записывает значение в\n    :data:`_clipboard_history` и ничего не делает (для проверок в тестах).\n\n    :param text: строка для копирования.\n    """\n    try:  # pragma: no cover - на устройстве\n        from android_utils import copy_to_clipboard as _copy\n\n        _copy(text)\n    except Exception:\n        _clipboard_history.append(text)\n\n\n__all__ = [\n    "OnClickListener",\n    "OnLongClickListener",\n    "R",\n    "copy_to_clipboard",\n    "log",\n    "run_on_ui_thread",\n]\n', False, '<catalib-vendor>/catalib/support/android.py'),
    'catalib.support.client': ('"""Обёртки модуля SDK ``client_utils``.\n\nОчереди, сетевые запросы, отправка и редактирование сообщений, геттеры\nконтроллеров Telegram, подписка на уведомления. На устройстве вызывается\nнастоящий ``client_utils``; вне приложения — функциональные офлайн-заглушки\nс честным контрактом: ``run_on_queue`` офлайн выполняет callable немедленно\n(чтобы логика плагина прогонялась в тестах), отправки фиксируются в\n:data:`_sent`, геттеры контроллеров возвращают ``None``. На устройстве\nвсегда работает настоящий SDK. Зависит только от стандартной библиотеки и\nSDK.\n"""\n\nfrom __future__ import annotations\n\nfrom collections.abc import Callable\nfrom typing import Any\n\n# Константы очередей (значения совпадают с client_utils).\nSTAGE_QUEUE = "stageQueue"\nGLOBAL_QUEUE = "globalQueue"\nCACHE_CLEAR_QUEUE = "cacheClearQueue"\nSEARCH_QUEUE = "searchQueue"\nPHONE_BOOK_QUEUE = "phoneBookQueue"\nTHEME_QUEUE = "themeQueue"\nEXTERNAL_NETWORK_QUEUE = "externalNetworkQueue"\nPLUGINS_QUEUE = "pluginsQueue"\n\n#: Допустимые режимы разметки текста.\n_PARSE_MODES = (None, "HTML", "Markdown")\n\n#: Офлайн-журнал отправок/запросов (для проверок в тестах).\n_sent: list[tuple[Any, ...]] = []\n#: Офлайн-журнал постановок в очередь.\n_queue_runs: list[tuple[str, int]] = []\n_request_seq = 0\n\n\ndef _client_attr(name: str) -> Any:\n    """Вернуть атрибут настоящего ``client_utils`` либо ``None`` офлайн."""\n    try:  # pragma: no cover - на устройстве\n        import client_utils\n\n        return getattr(client_utils, name, None)\n    except Exception:\n        return None\n\n\ndef _check_parse_mode(parse_mode: str | None) -> None:\n    """Проверить режим разметки; бросить ``ValueError`` при неизвестном."""\n    if parse_mode not in _PARSE_MODES:\n        raise ValueError(f"неподдерживаемый parse_mode: {parse_mode!r}")\n\n\ndef run_on_queue(\n    func: Callable[[], Any], queue_name: str = PLUGINS_QUEUE, delay_ms: int = 0\n) -> Any:\n    """Выполнить работу вне UI-потока.\n\n    :param func: вызываемый объект без аргументов.\n    :param queue_name: имя очереди (по умолчанию :data:`PLUGINS_QUEUE`).\n    :param delay_ms: задержка в миллисекундах (офлайн игнорируется).\n    :returns: на устройстве — результат SDK; офлайн — результат ``func()``\n        (вызов выполняется немедленно, чтобы логика тестировалась).\n    """\n    real = _client_attr("run_on_queue")\n    if real is not None:  # pragma: no cover - на устройстве\n        return real(func, queue_name, delay_ms)\n    _queue_runs.append((queue_name, delay_ms))\n    return func()\n\n\ndef get_queue_by_name(queue_name: str) -> Any:\n    """Вернуть ``DispatchQueue`` по имени (офлайн — ``None``)."""\n    real = _client_attr("get_queue_by_name")\n    return real(queue_name) if real is not None else None\n\n\ndef send_request(request: Any, callback: Callable[[Any, Any], None] | None = None) -> Any:\n    """Отправить сырой запрос Telegram API.\n\n    :param request: TL-объект запроса.\n    :param callback: ``callback(response, error)``.\n    :returns: идентификатор запроса (офлайн — синтетический ``int``).\n    """\n    real = _client_attr("send_request")\n    if real is not None:  # pragma: no cover - на устройстве\n        return real(request, callback)\n    global _request_seq\n    _request_seq += 1\n    _sent.append(("request", request))\n    return _request_seq\n\n\ndef _send(real_name: str, kind: str, *args: Any) -> Any:\n    """Делегировать отправку на устройство либо зафиксировать офлайн."""\n    real = _client_attr(real_name)\n    if real is not None:  # pragma: no cover - на устройстве\n        return real(*args)\n    _sent.append((kind, *args))\n    return None\n\n\ndef send_text(\n    peer_id: Any, message: str, replyToMsg: Any = None, parse_mode: str | None = None\n) -> Any:\n    """Отправить текстовое сообщение."""\n    return _send("send_text", "text", peer_id, message, replyToMsg, parse_mode)\n\n\ndef send_photo(\n    peer_id: Any,\n    photo_path: str,\n    caption: str | None = None,\n    high_quality: bool = False,\n    parse_mode: str | None = None,\n) -> Any:\n    """Отправить фото с необязательной подписью."""\n    return _send(\n        "send_photo", "photo", peer_id, photo_path, caption, high_quality, parse_mode\n    )\n\n\ndef send_document(\n    peer_id: Any, file_path: str, caption: str | None = None, parse_mode: str | None = None\n) -> Any:\n    """Отправить файл-документ."""\n    return _send("send_document", "document", peer_id, file_path, caption, parse_mode)\n\n\ndef send_video(\n    peer_id: Any, video_path: str, caption: str | None = None, parse_mode: str | None = None\n) -> Any:\n    """Отправить видео (метаданные SDK заполняет сам)."""\n    return _send("send_video", "video", peer_id, video_path, caption, parse_mode)\n\n\ndef send_audio(\n    peer_id: Any, audio_path: str, caption: str | None = None, parse_mode: str | None = None\n) -> Any:\n    """Отправить аудио (метаданные SDK заполняет сам)."""\n    return _send("send_audio", "audio", peer_id, audio_path, caption, parse_mode)\n\n\ndef send_message(params: dict[str, Any], parse_mode: str | None = None) -> Any:\n    """Низкоуровневая отправка по словарю ``SendMessageParams``."""\n    return _send("send_message", "message", params, parse_mode)\n\n\ndef edit_message(\n    message_obj: Any,\n    text: str | None = None,\n    file_path: str | None = None,\n    with_spoiler: bool = False,\n    parse_mode: str | None = None,\n) -> Any:\n    """Отредактировать существующий ``MessageObject``.\n\n    :raises ValueError: при неподдерживаемом ``parse_mode`` (как в SDK).\n    """\n    _check_parse_mode(parse_mode)\n    real = _client_attr("edit_message")\n    if real is not None:  # pragma: no cover - на устройстве\n        return real(message_obj, text, file_path, with_spoiler, parse_mode)\n    _sent.append(("edit", message_obj, text, file_path, with_spoiler, parse_mode))\n    return None\n\n\ndef _controller(name: str) -> Any:\n    """Вернуть контроллер с текущего аккаунта (офлайн — ``None``)."""\n    real = _client_attr(name)\n    return real() if real is not None else None\n\n\ndef get_last_fragment() -> Any:\n    """Текущий фрагмент UI (офлайн — ``None``)."""\n    return _controller("get_last_fragment")\n\n\ndef get_account_instance() -> Any:\n    """Экземпляр текущего аккаунта (офлайн — ``None``)."""\n    return _controller("get_account_instance")\n\n\ndef get_messages_controller() -> Any:\n    """``MessagesController`` — состояние и запросы (офлайн — ``None``)."""\n    return _controller("get_messages_controller")\n\n\ndef get_contacts_controller() -> Any:\n    """``ContactsController`` (офлайн — ``None``)."""\n    return _controller("get_contacts_controller")\n\n\ndef get_media_data_controller() -> Any:\n    """``MediaDataController`` (офлайн — ``None``)."""\n    return _controller("get_media_data_controller")\n\n\ndef get_connections_manager() -> Any:\n    """``ConnectionsManager`` (офлайн — ``None``)."""\n    return _controller("get_connections_manager")\n\n\ndef get_location_controller() -> Any:\n    """``LocationController`` (офлайн — ``None``)."""\n    return _controller("get_location_controller")\n\n\ndef get_notifications_controller() -> Any:\n    """``NotificationsController`` (офлайн — ``None``)."""\n    return _controller("get_notifications_controller")\n\n\ndef get_messages_storage() -> Any:\n    """``MessagesStorage`` (поле ``.database``) (офлайн — ``None``)."""\n    return _controller("get_messages_storage")\n\n\ndef get_send_messages_helper() -> Any:\n    """``SendMessagesHelper`` (офлайн — ``None``)."""\n    return _controller("get_send_messages_helper")\n\n\ndef get_file_loader() -> Any:\n    """``FileLoader`` (офлайн — ``None``)."""\n    return _controller("get_file_loader")\n\n\ndef get_secret_chat_helper() -> Any:\n    """``SecretChatHelper`` (офлайн — ``None``)."""\n    return _controller("get_secret_chat_helper")\n\n\ndef get_download_controller() -> Any:\n    """``DownloadController`` (офлайн — ``None``)."""\n    return _controller("get_download_controller")\n\n\ndef get_notifications_settings() -> Any:\n    """``NotificationsSettings`` (офлайн — ``None``)."""\n    return _controller("get_notifications_settings")\n\n\ndef get_notification_center() -> Any:\n    """``NotificationCenter`` — подписки (офлайн — ``None``)."""\n    return _controller("get_notification_center")\n\n\ndef get_media_controller() -> Any:\n    """``MediaController`` (офлайн — ``None``)."""\n    return _controller("get_media_controller")\n\n\ndef get_user_config() -> Any:\n    """``UserConfig`` (офлайн — ``None``)."""\n    return _controller("get_user_config")\n\n\ntry:  # pragma: no cover - ветка выполняется только на устройстве\n    from client_utils import NotificationCenterDelegate\nexcept Exception:  # pragma: no cover - ветка для обычного Python\n\n    class NotificationCenterDelegate:\n        """Офлайн-база делегата ``NotificationCenter``.\n\n        Подкласс переопределяет ``didReceivedNotification(id, account,\n        args)``. Офлайн базовая реализация — no-op.\n        """\n\n        def didReceivedNotification(\n            self, id: int, account: int, args: Any\n        ) -> None:\n            """Получено уведомление (офлайн — ничего не делает)."""\n\n\n__all__ = [\n    "CACHE_CLEAR_QUEUE",\n    "EXTERNAL_NETWORK_QUEUE",\n    "GLOBAL_QUEUE",\n    "PHONE_BOOK_QUEUE",\n    "PLUGINS_QUEUE",\n    "SEARCH_QUEUE",\n    "STAGE_QUEUE",\n    "THEME_QUEUE",\n    "NotificationCenterDelegate",\n    "edit_message",\n    "get_account_instance",\n    "get_connections_manager",\n    "get_contacts_controller",\n    "get_download_controller",\n    "get_file_loader",\n    "get_last_fragment",\n    "get_location_controller",\n    "get_media_controller",\n    "get_media_data_controller",\n    "get_messages_controller",\n    "get_messages_storage",\n    "get_notification_center",\n    "get_notifications_controller",\n    "get_notifications_settings",\n    "get_queue_by_name",\n    "get_secret_chat_helper",\n    "get_send_messages_helper",\n    "get_user_config",\n    "run_on_queue",\n    "send_audio",\n    "send_document",\n    "send_message",\n    "send_photo",\n    "send_request",\n    "send_text",\n    "send_video",\n]\n', False, '<catalib-vendor>/catalib/support/client.py'),
    'catalib.support.hooks': ('"""Декларативная разметка хуков плагина.\n\nДокументированная типичная ошибка: реализовать ``on_send_message_hook`` и\nзабыть вызвать ``add_on_send_message_hook`` в ``on_plugin_load``. Здесь метод\nпомечается декоратором, а :class:`~catalib.support.plugin.CatalibPlugin`\nрегистрирует его автоматически — забыть регистрацию невозможно.\n"""\n\nfrom __future__ import annotations\n\nfrom collections.abc import Callable\nfrom dataclasses import dataclass\nfrom typing import Any\n\n#: Имя атрибута-маркера на функции с описанием хука.\nHOOK_ATTR = "__catalib_hook__"\n\n#: Имя атрибута-маркера на методе-обработчике события приложения.\nAPP_EVENT_ATTR = "__catalib_app_event__"\n\n\n#: Виды хуков, привязанных к фиксированным методам SDK по имени\n#: запроса/апдейта (диспетчеризуются :class:`CatalibPlugin`).\nREQUEST_HOOK_KINDS = ("pre_request", "post_request", "on_update", "on_updates")\n\n\n@dataclass(frozen=True, slots=True)\nclass HookSpec:\n    """Описание хука, привязанного к методу плагина.\n\n    :param kind: ``"send_message"`` — хук исходящих сообщений;\n        ``"request"`` — общая регистрация по имени запроса (как раньше);\n        ``"pre_request"``/``"post_request"``/``"on_update"``/\n        ``"on_updates"`` — конкретные хук-методы SDK с диспетчеризацией.\n    :param name: имя запроса/апдейта (для ``send_message`` — пусто).\n    :param priority: приоритет регистрации хука.\n    :param match_substring: матчить ``name`` как подстроку (как в\n        ``add_hook(match_substring=True)``); по умолчанию ``False``.\n    """\n\n    kind: str\n    name: str\n    priority: int\n    match_substring: bool = False\n\n\n@dataclass(frozen=True, slots=True)\nclass AppEventSpec:\n    """Описание подписки метода на события жизненного цикла приложения.\n\n    :param events: кортеж событий (значения ``AppEvent``); пустой кортеж —\n        обработчик вызывается на всех событиях.\n    """\n\n    events: tuple[Any, ...]\n\n\ndef _mark(func: Callable, spec: HookSpec) -> Callable:\n    setattr(func, HOOK_ATTR, spec)\n    return func\n\n\ndef _mark_app_event(func: Callable, events: tuple[Any, ...]) -> Callable:\n    setattr(func, APP_EVENT_ATTR, AppEventSpec(events=events))\n    return func\n\n\nclass _Hook:\n    """Фабрика декораторов хуков (экземпляр доступен как ``hook``)."""\n\n    def send_message(self, func: Callable | None = None, *, priority: int = 0) -> Callable:\n        """Пометить метод как хук исходящих сообщений.\n\n        Применяется и как ``@hook.send_message``, и как\n        ``@hook.send_message(priority=5)``.\n        """\n\n        def decorator(target: Callable) -> Callable:\n            return _mark(target, HookSpec(kind="send_message", name="", priority=priority))\n\n        return decorator(func) if func is not None else decorator\n\n    def request(self, name: str, *, priority: int = 0) -> Callable[[Callable], Callable]:\n        """Пометить метод как хук сетевого запроса ``name``."""\n        if not isinstance(name, str) or not name:\n            raise ValueError("имя запроса для hook.request должно быть непустой строкой")\n\n        def decorator(target: Callable) -> Callable:\n            return _mark(target, HookSpec(kind="request", name=name, priority=priority))\n\n        return decorator\n\n    def _request_kind(\n        self, kind: str, name: str, priority: int, match_substring: bool\n    ) -> Callable[[Callable], Callable]:\n        """Общий конструктор декораторов хук-методов запроса/апдейта."""\n        if not isinstance(name, str) or not name:\n            raise ValueError(f"имя для hook.{kind} должно быть непустой строкой")\n\n        def decorator(target: Callable) -> Callable:\n            return _mark(\n                target,\n                HookSpec(\n                    kind=kind,\n                    name=name,\n                    priority=priority,\n                    match_substring=match_substring,\n                ),\n            )\n\n        return decorator\n\n    def pre_request(\n        self, name: str, *, priority: int = 0, match_substring: bool = False\n    ) -> Callable[[Callable], Callable]:\n        """Пометить метод как хук ``pre_request_hook`` запроса ``name``.\n\n        Обработчик: ``handler(request_name, account, request) ->\n        HookResult | None``. catalib регистрирует ``add_hook(name)`` и\n        диспетчеризует вызов ``pre_request_hook`` в помеченный метод.\n        """\n        return self._request_kind("pre_request", name, priority, match_substring)\n\n    def post_request(\n        self, name: str, *, priority: int = 0, match_substring: bool = False\n    ) -> Callable[[Callable], Callable]:\n        """Пометить метод как хук ``post_request_hook`` запроса ``name``.\n\n        Обработчик: ``handler(request_name, account, response, error) ->\n        HookResult | None``.\n        """\n        return self._request_kind("post_request", name, priority, match_substring)\n\n    def on_update(\n        self, name: str, *, priority: int = 0, match_substring: bool = False\n    ) -> Callable[[Callable], Callable]:\n        """Пометить метод как хук ``on_update_hook`` апдейта ``name``.\n\n        Обработчик: ``handler(update_name, account, update) ->\n        HookResult | None``.\n        """\n        return self._request_kind("on_update", name, priority, match_substring)\n\n    def on_updates(\n        self, name: str, *, priority: int = 0, match_substring: bool = False\n    ) -> Callable[[Callable], Callable]:\n        """Пометить метод как хук ``on_updates_hook`` контейнера ``name``.\n\n        Обработчик: ``handler(container_name, account, updates) ->\n        HookResult | None``.\n        """\n        return self._request_kind("on_updates", name, priority, match_substring)\n\n    def app_event(self, *events: Any) -> Callable:\n        """Пометить метод как обработчик событий жизненного цикла приложения.\n\n        exteraGram вызывает ``plugin.on_app_event(event_type)`` при смене\n        состояния приложения. :class:`~catalib.support.plugin.CatalibPlugin`\n        реализует диспетчер ``on_app_event``, который вызывает помеченные\n        методы; ручная проверка ``event_type`` в одном большом методе не\n        нужна. Сам обработчик получает ``event_type``.\n\n        Формы применения:\n\n        - ``@hook.app_event`` или ``@hook.app_event()`` — все события;\n        - ``@hook.app_event(AppEvent.START)`` — только указанные события;\n        - ``@hook.app_event(AppEvent.PAUSE, AppEvent.RESUME)`` — несколько.\n\n        :param events: значения ``AppEvent``; без аргументов — все события.\n            Перечень событий не валидируется: будущая сборка SDK может\n            добавить новые, и catalib не должен их отвергать.\n        """\n        # Бар-форма: @hook.app_event — единственный аргумент это сам метод\n        # (он callable; значения AppEvent — не callable).\n        if len(events) == 1 and callable(events[0]):\n            return _mark_app_event(events[0], ())\n\n        def decorator(target: Callable) -> Callable:\n            return _mark_app_event(target, tuple(events))\n\n        return decorator\n\n\n#: Единственный публичный экземпляр фабрики декораторов хуков.\nhook = _Hook()\n', False, '<catalib-vendor>/catalib/support/hooks.py'),
    'catalib.support.plugin': ('"""Базовый класс плагина с автоматической регистрацией хуков и меню.\n\n``CatalibPlugin`` устраняет шаблон и класс ошибок «хук определён, но не\nзарегистрирован»: помеченные :mod:`~catalib.support.hooks` методы и\nобъявленные пункты меню регистрируются автоматически в ``on_plugin_load``.\nПрямой доступ к API SDK не ограничивается — слой только убирает шаблон.\n"""\n\nfrom __future__ import annotations\n\nfrom collections.abc import Callable\nfrom dataclasses import dataclass\nfrom typing import Any\n\nfrom catalib.support.hooks import (\n    APP_EVENT_ATTR,\n    HOOK_ATTR,\n    REQUEST_HOOK_KINDS,\n    AppEventSpec,\n    HookSpec,\n)\nfrom catalib.support.sdk import BasePlugin\nfrom catalib.support.settings import SettingItem\nfrom catalib.support.xposed import (\n    XPOSED_ATTR,\n    XposedSpec,\n    register_xposed,\n    unregister_xposed,\n)\n\n#: Атрибут-маркер метода-обработчика пункта меню.\nMENU_ATTR = "__catalib_menu__"\n\n\n#: Допустимые типы меню exteraGram (значения MenuItemType).\nMENU_TYPES = (\n    "DRAWER_MENU",\n    "MESSAGE_CONTEXT_MENU",\n    "CHAT_ACTION_MENU",\n    "PROFILE_ACTION_MENU",\n)\n\n\n@dataclass(frozen=True, slots=True)\nclass MenuSpec:\n    """Описание пункта меню, привязанного к методу-обработчику.\n\n    Метод-обработчик получает один аргумент ``context: dict`` (см. SDK).\n\n    :param item_id: необязательный стабильный идентификатор пункта.\n    :param condition: необязательный предикат показа пункта (как в SDK).\n    :param priority: необязательный приоритет пункта (по умолчанию 0 —\n        в ``MenuItemData`` не передаётся, действует значение SDK).\n    """\n\n    text: str\n    menu_type: str\n    icon: str = ""\n    subtext: str = ""\n    item_id: str = ""\n    condition: Any = None\n    priority: int = 0\n\n\ndef menu_item(\n    text: str,\n    menu_type: str = "DRAWER_MENU",\n    icon: str = "",\n    subtext: str = "",\n    *,\n    item_id: str = "",\n    condition: Any = None,\n    priority: int = 0,\n) -> Callable[[Callable], Callable]:\n    """Пометить метод как обработчик пункта меню.\n\n    :param text: подпись пункта меню.\n    :param menu_type: тип меню — одно из значений :data:`MENU_TYPES`\n        (``DRAWER_MENU``, ``MESSAGE_CONTEXT_MENU``, ``CHAT_ACTION_MENU``,\n        ``PROFILE_ACTION_MENU``).\n    :param icon: необязательное имя иконки (drawable).\n    :param subtext: необязательная подпись под текстом.\n    :param item_id: необязательный стабильный идентификатор пункта.\n    :param condition: необязательный предикат показа пункта.\n    :param priority: необязательный приоритет (0 — не передаётся в SDK).\n\n    Декорируемый метод обязан принимать аргумент ``context: dict``.\n    Новые параметры — keyword-only; прежние позиционные вызовы и\n    формируемый ``MenuItemData`` не меняются.\n    """\n    if not isinstance(text, str) or not text:\n        raise ValueError("текст пункта меню должен быть непустой строкой")\n    if menu_type not in MENU_TYPES:\n        raise ValueError(f"menu_type должен быть одним из {MENU_TYPES}")\n\n    def decorator(func: Callable) -> Callable:\n        setattr(\n            func,\n            MENU_ATTR,\n            MenuSpec(\n                text=text,\n                menu_type=menu_type,\n                icon=icon,\n                subtext=subtext,\n                item_id=item_id,\n                condition=condition,\n                priority=priority,\n            ),\n        )\n        return func\n\n    return decorator\n\n\nclass CatalibPlugin(BasePlugin):\n    """Базовый класс плагина catalib с автоматической регистрацией.\n\n    Подклассы реализуют помеченные хуки/меню и при необходимости методы\n    ``settings`` (вернуть список :class:`SettingItem`) и ``on_load``\n    (пользовательская инициализация). Регистрация хуков и меню происходит\n    автоматически — повторять её вручную не нужно.\n    """\n\n    #: Распознаётся загрузчиком как класс плагина (см. bootstrap).\n    __catalib_plugin__ = True\n\n    #: Собранные при создании класса хуки: list[(имя_метода, HookSpec)].\n    _catalib_hooks: tuple[tuple[str, HookSpec], ...] = ()\n    #: Собранные пункты меню: list[(имя_метода, MenuSpec)].\n    _catalib_menu: tuple[tuple[str, MenuSpec], ...] = ()\n    #: Собранные обработчики событий приложения: list[(имя_метода, AppEventSpec)].\n    _catalib_app_events: tuple[tuple[str, AppEventSpec], ...] = ()\n    #: Собранные Xposed-хуки: list[(имя_метода, XposedSpec)].\n    _catalib_xposed: tuple[tuple[str, XposedSpec], ...] = ()\n\n    def __init_subclass__(cls, **kwargs: object) -> None:\n        super().__init_subclass__(**kwargs)\n        hooks: list[tuple[str, HookSpec]] = []\n        menu: list[tuple[str, MenuSpec]] = []\n        app_events: list[tuple[str, AppEventSpec]] = []\n        xposed: list[tuple[str, XposedSpec]] = []\n        for attr_name in dir(cls):\n            member = getattr(cls, attr_name, None)\n            if not callable(member):\n                continue\n            hook_spec = getattr(member, HOOK_ATTR, None)\n            if isinstance(hook_spec, HookSpec):\n                hooks.append((attr_name, hook_spec))\n            menu_spec = getattr(member, MENU_ATTR, None)\n            if isinstance(menu_spec, MenuSpec):\n                menu.append((attr_name, menu_spec))\n            app_event_spec = getattr(member, APP_EVENT_ATTR, None)\n            if isinstance(app_event_spec, AppEventSpec):\n                app_events.append((attr_name, app_event_spec))\n            xposed_spec = getattr(member, XPOSED_ATTR, None)\n            if isinstance(xposed_spec, XposedSpec):\n                xposed.append((attr_name, xposed_spec))\n        cls._catalib_hooks = tuple(sorted(hooks))\n        cls._catalib_menu = tuple(sorted(menu))\n        cls._catalib_app_events = tuple(sorted(app_events, key=lambda pair: pair[0]))\n        cls._catalib_xposed = tuple(sorted(xposed, key=lambda pair: pair[0]))\n\n    #: Дескрипторы зарегистрированных Xposed-хуков (для on_plugin_unload).\n    #: Класс-умолчание — безопасный неизменяемый ``()``; экземпляр получает\n    #: новый список в ``on_plugin_load`` (нет общего мутабельного состояния).\n    _catalib_xposed_handles: tuple[Any, ...] | list[Any] = ()\n\n    def on_plugin_load(self) -> None:\n        """Зарегистрировать хуки, меню и Xposed-хуки, затем вызвать on_load."""\n        for _attr_name, spec in self._catalib_hooks:\n            if spec.kind == "send_message":\n                self._register_send_message_hook(spec.priority)\n            elif spec.kind == "request":\n                self.add_hook(spec.name)\n            elif spec.kind in REQUEST_HOOK_KINDS:\n                self._register_request_hook(spec)\n        for attr_name, menu_spec in self._catalib_menu:\n            self._register_menu_item(attr_name, menu_spec)\n        handles: list[Any] = []\n        for attr_name, xposed_spec in self._catalib_xposed:\n            handle = register_xposed(self, attr_name, xposed_spec)\n            if handle is not None:\n                handles.append(handle)\n        self._catalib_xposed_handles = handles\n        self.on_load()\n\n    def on_plugin_unload(self) -> None:\n        """Снять зарегистрированные Xposed-хуки и вызвать on_unload.\n\n        Прежнее поведение сохранено: без Xposed-хуков и без переопределения\n        ``on_unload`` метод фактически ничего не делает (как до 0.2.0, когда\n        ``on_plugin_unload`` не определялся вовсе). Подкласс, переопределивший\n        ``on_plugin_unload`` напрямую, продолжает работать как раньше.\n        """\n        for handle in getattr(self, "_catalib_xposed_handles", ()):\n            unregister_xposed(self, handle)\n        self._catalib_xposed_handles = []\n        self.on_unload()\n\n    def on_app_event(self, event_type: Any) -> None:\n        """Диспетчер событий жизненного цикла приложения.\n\n        exteraGram вызывает этот метод при смене состояния приложения.\n        Вызывает все методы, помеченные ``@hook.app_event``, у которых\n        событие подходит (без указанных событий — на любое). Обработчику\n        передаётся ``event_type``.\n\n        Прямое переопределение ``on_app_event`` в подклассе по-прежнему\n        работает (поведение SDK не ограничивается). Если декораторы не\n        использовались, метод ничего не делает — это эквивалентно\n        отсутствию обработчика, как было до 0.2.0.\n        """\n        for attr_name, spec in self._catalib_app_events:\n            if not spec.events or event_type in spec.events:\n                getattr(self, attr_name)(event_type)\n\n    def _register_request_hook(self, spec: HookSpec) -> None:\n        """Зарегистрировать имя запроса/апдейта через ``add_hook``.\n\n        SDK по этому имени будет вызывать фиксированные методы\n        ``pre_request_hook``/``post_request_hook``/``on_update_hook``/\n        ``on_updates_hook``; их реализуют диспетчеры ниже. Сигнатура\n        ``add_hook`` на старых сборках без ``match_substring``/``priority``\n        — graceful fallback.\n        """\n        try:\n            self.add_hook(\n                spec.name,\n                match_substring=spec.match_substring,\n                priority=spec.priority,\n            )\n        except TypeError:\n            self.add_hook(spec.name)\n\n    def _dispatch_request_hook(self, kind: str, name: str, *args: Any) -> Any:\n        """Вызвать помеченные ``@hook.<kind>`` обработчики по имени.\n\n        Совпадение по равенству имени либо по подстроке (если у спецификации\n        ``match_substring``). Возвращается первый не-``None`` результат\n        обработчика, иначе ``HookResult()`` (стратегия DEFAULT — поведение\n        не меняется, если обработчиков нет: эквивалентно их отсутствию до\n        0.3.0). Прямое переопределение метода-хука в подклассе по-прежнему\n        перекрывает диспетчер (MRO).\n        """\n        from catalib.support.sdk import HookResult\n\n        for attr_name, spec in self._catalib_hooks:\n            if spec.kind != kind:\n                continue\n            matched = (\n                spec.name in name if spec.match_substring else spec.name == name\n            )\n            if not matched:\n                continue\n            result = getattr(self, attr_name)(name, *args)\n            if result is not None:\n                return result\n        return HookResult()\n\n    def pre_request_hook(self, request_name: str, account: int, request: Any) -> Any:\n        """Диспетчер ``@hook.pre_request`` (см. :meth:`_dispatch_request_hook`)."""\n        return self._dispatch_request_hook(\n            "pre_request", request_name, account, request\n        )\n\n    def post_request_hook(\n        self, request_name: str, account: int, response: Any, error: Any\n    ) -> Any:\n        """Диспетчер ``@hook.post_request``."""\n        return self._dispatch_request_hook(\n            "post_request", request_name, account, response, error\n        )\n\n    def on_update_hook(self, update_name: str, account: int, update: Any) -> Any:\n        """Диспетчер ``@hook.on_update``."""\n        return self._dispatch_request_hook(\n            "on_update", update_name, account, update\n        )\n\n    def on_updates_hook(\n        self, container_name: str, account: int, updates: Any\n    ) -> Any:\n        """Диспетчер ``@hook.on_updates``."""\n        return self._dispatch_request_hook(\n            "on_updates", container_name, account, updates\n        )\n\n    def _register_send_message_hook(self, priority: int) -> None:\n        """Зарегистрировать хук исходящих сообщений с приоритетом, если он поддержан."""\n        try:\n            self.add_on_send_message_hook(priority)\n        except TypeError:\n            # Старые сборки SDK: метод без аргумента приоритета.\n            self.add_on_send_message_hook()\n\n    def _register_menu_item(self, attr_name: str, menu_spec: MenuSpec) -> None:\n        """Построить и зарегистрировать пункт меню для метода-обработчика.\n\n        Использует реальный API SDK: ``MenuItemData(menu_type=MenuItemType.X,\n        text=..., on_click=...)``. Обработчик получает ``context: dict``.\n        """\n        from catalib.support.sdk import MenuItemData, MenuItemType\n\n        handler = getattr(self, attr_name)\n        kwargs = {\n            "menu_type": getattr(MenuItemType, menu_spec.menu_type),\n            "text": menu_spec.text,\n            "on_click": handler,\n        }\n        if menu_spec.icon:\n            kwargs["icon"] = menu_spec.icon\n        if menu_spec.subtext:\n            kwargs["subtext"] = menu_spec.subtext\n        # Необязательные поля пробрасываются только когда заданы: прежний\n        # вызов (без них) формирует тот же MenuItemData, что и раньше.\n        if menu_spec.item_id:\n            kwargs["item_id"] = menu_spec.item_id\n        if menu_spec.condition is not None:\n            kwargs["condition"] = menu_spec.condition\n        if menu_spec.priority:\n            kwargs["priority"] = menu_spec.priority\n        self.add_menu_item(MenuItemData(**kwargs))\n\n    def settings(self) -> list[SettingItem]:\n        """Переопределяемый метод: вернуть список элементов настроек."""\n        return []\n\n    def create_settings(self) -> list[object]:\n        """Построить элементы настроек для exteraGram из объявленных."""\n        return [item.build() for item in self.settings()]\n\n    def on_load(self) -> None:\n        """Переопределяемый хук пользовательской инициализации плагина."""\n\n    def on_unload(self) -> None:\n        """Переопределяемый хук пользовательской очистки плагина.\n\n        Вызывается из ``on_plugin_unload`` после автоснятия Xposed-хуков.\n        По умолчанию ничего не делает.\n        """\n', False, '<catalib-vendor>/catalib/support/plugin.py'),
    'catalib.support.proxy': ('"""Обёртки SDK ``extera_utils.classes`` — управляемый class proxy.\n\nНа устройстве **полностью** ре-экспортируется настоящий DSL exteraGram\n(подклассы Java, переопределения, перегрузки, поля, конструкторы, MVEL,\n``J``/``PyObj``) — он работает в полном объёме. Вне приложения —\nфункциональные офлайн-заглушки: декларации классов-проксей импортируются и\nинстанцируются, ``jfield`` ведёт себя как атрибут со значением по\nумолчанию, отрабатывают ``@jpreconstructor``/``__init__``/``@jconstructor``,\n``J``/``PyObj`` проксируют Python-объект. Это честная граница офлайн-режима\n(Java-родитель недоступен без устройства); на устройстве всегда\nработает настоящий SDK.\n\nИмпорт делается одним блоком: ``extera_utils.classes`` — цельный API,\nприсутствует на устройстве полностью либо отсутствует офлайн целиком.\nЗависит только от стандартной библиотеки и SDK.\n"""\n\nfrom __future__ import annotations\n\nfrom typing import Any\n\ntry:  # pragma: no cover - ветка выполняется только на устройстве\n    from extera_utils.classes import (\n        Base,\n        ClassHelper,\n        J,\n        JavaHelper,\n        PyObj,\n        java_subclass,\n        jclassbuilder,\n        jconstructor,\n        jfield,\n        jgetmethod,\n        jmethod,\n        jMVELmethod,\n        jMVELoverride,\n        joverload,\n        joverride,\n        jpreconstructor,\n        jsetmethod,\n    )\nexcept Exception:  # pragma: no cover - ветка для обычного Python\n    _JCTOR = "__catalib_jconstructor__"\n    _JPRECTOR = "__catalib_jpreconstructor__"\n\n    def _mark(attr: str, value: Any = True):\n        """Вернуть декоратор, помечающий функцию атрибутом ``attr``."""\n\n        def decorator(func: Any) -> Any:\n            setattr(func, attr, value)\n            return func\n\n        return decorator\n\n    def java_subclass(*bases: Any, **kwargs: Any):\n        """Офлайн: фиксирует базовый Java-класс/интерфейсы, класс не меняет."""\n\n        def decorator(cls: type) -> type:\n            cls.__catalib_java_bases__ = bases\n            cls.__catalib_java_kwargs__ = kwargs\n            return cls\n\n        return decorator\n\n    def joverride(java_method_name: str | None = None):\n        """Офлайн: пометить метод как переопределение Java-метода."""\n        return _mark("__catalib_joverride__", java_method_name or True)\n\n    def joverload(java_method_name: str, arg_types: list[Any]):\n        """Офлайн: пометить метод как конкретную перегрузку."""\n        return _mark("__catalib_joverload__", (java_method_name, tuple(arg_types)))\n\n    def jmethod(\n        java_method_name: str | None = None,\n        return_type: str | None = None,\n        arg_types: list[Any] | None = None,\n    ):\n        """Офлайн: пометить добавляемый в Java-класс метод."""\n        return _mark(\n            "__catalib_jmethod__",\n            (java_method_name, return_type, tuple(arg_types or ())),\n        )\n\n    def jconstructor(arg_types: list[Any]):\n        """Офлайн: пометить метод как пост-конструктор."""\n        return _mark(_JCTOR, tuple(arg_types))\n\n    def jpreconstructor(arg_types: list[Any]):\n        """Офлайн: пометить classmethod как пред-конструктор."""\n        return _mark(_JPRECTOR, tuple(arg_types))\n\n    def jclassbuilder(*args: Any, **kwargs: Any):\n        """Офлайн: декоратор кастомизации класса, функцию не меняет."""\n\n        def decorator(func: Any) -> Any:\n            func.__catalib_jclassbuilder__ = True\n            return func\n\n        return decorator\n\n    class _MVELCallable:\n        """Офлайн-плейсхолдер MVEL-метода/переопределения.\n\n        Как атрибут класса доступен и вызываем; офлайн возвращает ``None``\n        (тело на MVEL исполняется только на устройстве).\n        """\n\n        def __init__(self, kind: str, spec: dict[str, Any]) -> None:\n            self.kind = kind\n            self.spec = spec\n\n        def __get__(self, obj: Any, owner: Any = None) -> Any:\n            return self\n\n        def __call__(self, *args: Any, **kwargs: Any) -> Any:\n            return None\n\n    def jMVELmethod(\n        return_type: str | None = None,\n        arguments: list[tuple[str, str]] | None = None,\n        code: str = "",\n    ) -> _MVELCallable:\n        """Офлайн-плейсхолдер добавляемого MVEL-метода."""\n        return _MVELCallable(\n            "method",\n            {"return_type": return_type, "arguments": arguments or [], "code": code},\n        )\n\n    def jMVELoverride(\n        arguments: list[tuple[str, str]] | None = None, code: str = ""\n    ) -> _MVELCallable:\n        """Офлайн-плейсхолдер MVEL-переопределения."""\n        return _MVELCallable("override", {"arguments": arguments or [], "code": code})\n\n    class _JFieldMethod:\n        """Маркер getter/setter, передаваемый в ``jfield(methods=[...])``."""\n\n        def __init__(self, kind: str, java_name: str) -> None:\n            self.kind = kind\n            self.java_name = java_name\n\n    def jgetmethod(java_method_name: str) -> _JFieldMethod:\n        """Офлайн-маркер Java-getter\'а поля."""\n        return _JFieldMethod("get", java_method_name)\n\n    def jsetmethod(java_method_name: str) -> _JFieldMethod:\n        """Офлайн-маркер Java-setter\'а поля."""\n        return _JFieldMethod("set", java_method_name)\n\n    class jfield:\n        """Офлайн-дескриптор Java-поля: атрибут со значением по умолчанию.\n\n        Хранит значение по экземпляру; читается/пишется как обычный\n        атрибут (``self.counter += 1``). ``methods`` (getter/setter)\n        офлайн принимается, но не нужен (Java-аксессоры — device-side).\n        """\n\n        def __init__(\n            self,\n            java_type: str,\n            default: Any = None,\n            methods: list[_JFieldMethod] | None = None,\n        ) -> None:\n            self.java_type = java_type\n            self.default = default\n            self.methods = methods or []\n            self._name = "_catalib_jfield"\n\n        def __set_name__(self, owner: type, name: str) -> None:\n            self._name = f"_catalib_jfield_{name}"\n\n        def __get__(self, obj: Any, owner: type | None = None) -> Any:\n            if obj is None:\n                return self\n            return getattr(obj, self._name, self.default)\n\n        def __set__(self, obj: Any, value: Any) -> None:\n            object.__setattr__(obj, self._name, value)\n\n    class Base:\n        """Офлайн-база управляемого Java-подкласса.\n\n        Поддерживает порядок инициализации без устройства:\n        ``@jpreconstructor`` → ``__init__`` → ``@jconstructor`` →\n        ``on_post_init``. Атрибуты ``java``/``this`` офлайн — ``None``.\n        """\n\n        java: Any = None\n        this: Any = None\n\n        @classmethod\n        def bind(cls, *bases: Any) -> type:\n            """Офлайн: фиксирует Java-базу/интерфейсы, возвращает класс."""\n            cls.__catalib_java_bases__ = bases\n            return cls\n\n        @classmethod\n        def java_class(cls) -> Any:\n            """Сгенерированный Java-класс (офлайн — ``None``)."""\n            return None\n\n        @classmethod\n        def _find_marked(cls, attr: str) -> Any:\n            for name in dir(cls):\n                member = getattr(cls, name, None)\n                if callable(member) and hasattr(member, attr):\n                    return name\n            return None\n\n        @classmethod\n        def new_instance(cls, *args: Any, init_args: list[Any] | None = None) -> Base:\n            """Создать Python-peer (офлайн, без Java).\n\n            Повторяет порядок SDK: ``@jpreconstructor`` (может заменить\n            аргументы) → ``__init__`` → ``@jconstructor`` →\n            ``on_post_init``.\n            """\n            ctor_args = list(args)\n            pre_name = cls._find_marked(_JPRECTOR)\n            if pre_name is not None:\n                # Сигнатура pre-конструктора — (cls, ...): офлайн декоратор\n                # не оборачивает в classmethod, поэтому cls передаём явно.\n                replaced = getattr(cls, pre_name)(cls, *ctor_args)\n                if isinstance(replaced, list | tuple):\n                    ctor_args = list(replaced)\n                elif replaced is not None:\n                    ctor_args = [replaced]\n            instance = object.__new__(cls)\n            instance.java = None\n            instance.this = None\n            init_with = init_args if init_args is not None else ctor_args\n            # Если подкласс не определил собственный __init__, не передаём\n            # аргументы в object.__init__ (иначе TypeError) — частый случай\n            # из документации (subclass без __init__).\n            if cls.__init__ is object.__init__:\n                instance.__init__()\n            else:\n                instance.__init__(*init_with)\n            ctor_name = cls._find_marked(_JCTOR)\n            if ctor_name is not None:\n                getattr(instance, ctor_name)(*ctor_args)\n            post = getattr(instance, "on_post_init", None)\n            if callable(post):\n                post()\n            return instance\n\n        @classmethod\n        def new_java_instance(cls, *args: Any) -> Any:\n            """Сырой Java-объект (офлайн — ``None``)."""\n            return None\n\n        @classmethod\n        def from_java(cls, java_instance: Any) -> Base:\n            """Восстановить Python-peer из Java-объекта (офлайн — пустой)."""\n            instance = object.__new__(cls)\n            instance.java = java_instance\n            instance.this = java_instance\n            return instance\n\n    class _JWrapper:\n        """Офлайн-обёртка ``J``/``JavaHelper``/``ClassHelper``.\n\n        Прозрачно проксирует чтение/запись атрибутов и вызовы методов на\n        обёрнутый объект. Переключатели режимов (``JAccessAll`` и пр.) —\n        неизменяемые: возвращают обёртку того же объекта.\n        """\n\n        def __init__(self, target: Any) -> None:\n            object.__setattr__(self, "_target", target)\n\n        def _same(self) -> _JWrapper:\n            return self\n\n        # Переключатели режимов (поведение SDK офлайн не меняет).\n        JAccessAll = property(_same)\n        JNotAccessAll = property(_same)\n        JUseGetterAndSetter = property(_same)\n        JNotUseGetterAndSetter = property(_same)\n        JIgnoreResult = property(_same)\n        JNotIgnoreResult = property(_same)\n\n        def __getattr__(self, name: str) -> Any:\n            return getattr(object.__getattribute__(self, "_target"), name)\n\n        def __setattr__(self, name: str, value: Any) -> None:\n            setattr(object.__getattribute__(self, "_target"), name, value)\n\n        def __call__(self, *args: Any, **kwargs: Any) -> Any:\n            return object.__getattribute__(self, "_target")(*args, **kwargs)\n\n    def J(java_object: Any) -> _JWrapper:\n        """Офлайн-обёртка над Python-объектом (passthrough)."""\n        return _JWrapper(java_object)\n\n    JavaHelper = J\n    ClassHelper = J\n\n    class PyObj:\n        """Офлайн ``PyObj``: переносит Python-объект через Java-границу."""\n\n        def __init__(self, value: Any) -> None:\n            self.value = value\n\n        @staticmethod\n        def create(python_object: Any) -> PyObj:\n            """Обернуть произвольный Python-объект."""\n            return PyObj(python_object)\n\n        def get(self) -> Any:\n            """Вернуть исходный Python-объект."""\n            return self.value\n\n\n__all__ = [\n    "Base",\n    "ClassHelper",\n    "J",\n    "JavaHelper",\n    "PyObj",\n    "jMVELmethod",\n    "jMVELoverride",\n    "java_subclass",\n    "jclassbuilder",\n    "jconstructor",\n    "jfield",\n    "jgetmethod",\n    "jmethod",\n    "joverload",\n    "joverride",\n    "jpreconstructor",\n    "jsetmethod",\n]\n', False, '<catalib-vendor>/catalib/support/proxy.py'),
    'catalib.support.sdk': ('"""Безопасные импорты SDK exteraGram с заглушками для офлайн-тестов.\n\nЕдинственная точка адаптации к SDK: если плагин исполняется в exteraGram —\nиспользуются настоящие классы и функции; вне приложения (юнит-тесты на\nобычном Python) подключаются минимальные заглушки с тем же интерфейсом.\nЭто устраняет россыпь ``try/except`` по плагину и даёт офлайн-тестируемость\nдоменной логики. Код только стандартной библиотеки и SDK.\n"""\n\nfrom __future__ import annotations\n\nimport tempfile\nfrom typing import Any\n\n#: Истинно, если плагин исполняется внутри exteraGram (SDK доступен).\nSDK_AVAILABLE: bool\n\ntry:  # pragma: no cover - ветка выполняется только на устройстве\n    from base_plugin import (\n        BasePlugin,\n        HookResult,\n        HookStrategy,\n        MenuItemData,\n        MenuItemType,\n    )\n\n    SDK_AVAILABLE = True\nexcept Exception:  # pragma: no cover - ветка для обычного Python\n    SDK_AVAILABLE = False\n\n    class HookStrategy:\n        """Заглушка стратегий хука, повторяющая значения SDK."""\n\n        DEFAULT = "DEFAULT"\n        CANCEL = "CANCEL"\n        MODIFY = "MODIFY"\n        MODIFY_FINAL = "MODIFY_FINAL"\n\n    class HookResult:\n        """Заглушка результата хука со всеми полями SDK.\n\n        Поля соответствуют документации plugin-class: ``strategy``,\n        ``request``, ``response``, ``update``, ``updates``, ``params``.\n        ``strategy``/``params`` остаются первыми позиционными (обратная\n        совместимость), остальные — необязательные.\n        """\n\n        def __init__(\n            self,\n            strategy: str | None = None,\n            params: Any = None,\n            request: Any = None,\n            response: Any = None,\n            update: Any = None,\n            updates: Any = None,\n        ) -> None:\n            self.strategy = strategy or HookStrategy.DEFAULT\n            self.params = params\n            self.request = request\n            self.response = response\n            self.update = update\n            self.updates = updates\n\n    class MenuItemType:\n        """Заглушка типов пунктов меню (значения как в SDK exteraGram)."""\n\n        DRAWER_MENU = "DRAWER_MENU"\n        MESSAGE_CONTEXT_MENU = "MESSAGE_CONTEXT_MENU"\n        CHAT_ACTION_MENU = "CHAT_ACTION_MENU"\n        PROFILE_ACTION_MENU = "PROFILE_ACTION_MENU"\n\n    class MenuItemData:\n        """Заглушка описания пункта меню."""\n\n        def __init__(self, **kwargs: Any) -> None:\n            self.__dict__.update(kwargs)\n\n    class BasePlugin:\n        """Заглушка базового класса плагина для офлайн-тестов.\n\n        Повторяет минимальный публичный интерфейс SDK, фиксируя вызовы\n        регистрации, чтобы их можно было проверить в тестах.\n        """\n\n        def __init__(self) -> None:\n            self._settings: dict[str, Any] = {}\n            self.registered_hooks: list[Any] = []\n            self.registered_menu_items: list[Any] = []\n            self.removed_menu_items: list[Any] = []\n            self.registered_xposed: list[Any] = []\n            self.registered_hook_all: list[Any] = []\n            self.hook_method_calls: list[dict[str, Any]] = []\n            self.unhooked: list[Any] = []\n            self.logged: list[str] = []\n            self._menu_seq = 0\n            self._menu_by_id: dict[Any, Any] = {}\n\n        def add_on_send_message_hook(self, priority: int = 0) -> None:\n            self.registered_hooks.append(("send_message", priority))\n\n        def add_hook(\n            self, name: str, match_substring: bool = False, priority: int = 0\n        ) -> None:\n            # Кортеж (name, priority) сохранён прежним для обратной\n            # совместимости; match_substring фиксируется отдельно.\n            self.registered_hooks.append((name, priority))\n            if match_substring:\n                self.registered_hooks.append((name, "substring"))\n\n        def hook_method(\n            self,\n            member: Any,\n            handler: Any = None,\n            priority: int = 10,\n            before_filters: Any = (),\n            after_filters: Any = (),\n            before: Any = None,\n            after: Any = None,\n        ) -> Any:\n            """Зафиксировать Xposed-хук; вернуть дескриптор для unhook.\n\n            Дескриптор — прежний 4-кортеж (обратная совместимость); полный\n            набор аргументов фиксируется в ``hook_method_calls``.\n            """\n            handle = ("xposed", member, handler, priority)\n            self.registered_xposed.append(handle)\n            self.hook_method_calls.append(\n                {\n                    "member": member,\n                    "handler": handler,\n                    "priority": priority,\n                    "before_filters": tuple(before_filters),\n                    "after_filters": tuple(after_filters),\n                    "before": before,\n                    "after": after,\n                }\n            )\n            return handle\n\n        def hook_all_methods(\n            self, clazz: Any, method_name: str, handler: Any\n        ) -> list[Any]:\n            """Зафиксировать хук всех перегрузок метода; вернуть список."""\n            handle = ("xposed_all_methods", clazz, method_name, handler)\n            self.registered_hook_all.append(handle)\n            return [handle]\n\n        def hook_all_constructors(self, clazz: Any, handler: Any) -> list[Any]:\n            """Зафиксировать хук всех конструкторов; вернуть список."""\n            handle = ("xposed_all_constructors", clazz, handler)\n            self.registered_hook_all.append(handle)\n            return [handle]\n\n        def unhook_method(self, handle: Any) -> None:\n            """Зафиксировать снятие Xposed-хука."""\n            self.unhooked.append(handle)\n\n        def add_menu_item(self, data: Any) -> Any:\n            """Зафиксировать пункт меню; вернуть его идентификатор."""\n            self._menu_seq += 1\n            item_id = getattr(data, "item_id", None) or self._menu_seq\n            self.registered_menu_items.append(data)\n            self._menu_by_id[item_id] = data\n            return item_id\n\n        def remove_menu_item(self, item_id: Any) -> None:\n            """Зафиксировать удаление пункта меню по идентификатору."""\n            self.removed_menu_items.append(item_id)\n            data = self._menu_by_id.pop(item_id, None)\n            if data is not None and data in self.registered_menu_items:\n                self.registered_menu_items.remove(data)\n\n        def get_setting(self, key: str, default: Any = None) -> Any:\n            return self._settings.get(key, default)\n\n        def set_setting(\n            self, key: str, value: Any, reload_settings: bool = False\n        ) -> None:\n            self._settings[key] = value\n\n        def export_settings(self) -> dict[str, Any]:\n            """Вернуть копию всех настроек плагина."""\n            return dict(self._settings)\n\n        def import_settings(\n            self, settings: dict[str, Any], reload_settings: bool = True\n        ) -> None:\n            """Заменить/дополнить настройки плагина переданными."""\n            self._settings.update(settings)\n\n        def log(self, message: str) -> None:\n            self.logged.append(message)\n\n\n# --------------------------------------------------------------------------\n# Расширенный SDK (события приложения и Xposed-хуки).\n#\n# Импортируется НЕЗАВИСИМЫМИ ``try/except``, отдельно от ядра выше: на\n# старой сборке SDK какого-то из этих имён может не быть, и это не должно\n# сбрасывать ``SDK_AVAILABLE`` и подменять ядро (``BasePlugin`` и пр.)\n# заглушками. Каждое имя при отсутствии получает собственную офлайн-заглушку\n# с тем же интерфейсом — для офлайн-тестов.\n# --------------------------------------------------------------------------\n\ntry:  # pragma: no cover - ветка выполняется только на устройстве\n    from base_plugin import AppEvent\nexcept Exception:  # pragma: no cover - ветка для обычного Python\n\n    class AppEvent:\n        """Заглушка событий жизненного цикла приложения (значения как в SDK)."""\n\n        START = "START"\n        STOP = "STOP"\n        PAUSE = "PAUSE"\n        RESUME = "RESUME"\n\n\ntry:  # pragma: no cover - ветка выполняется только на устройстве\n    from base_plugin import BaseHook\nexcept Exception:  # pragma: no cover - ветка для обычного Python\n\n    class BaseHook:\n        """Заглушка базового класса Xposed-хука."""\n\n\ntry:  # pragma: no cover - ветка выполняется только на устройстве\n    from base_plugin import MethodHook\nexcept Exception:  # pragma: no cover - ветка для обычного Python\n\n    class MethodHook(BaseHook):\n        """Заглушка хука метода: переопределяемые before/after — no-op офлайн."""\n\n        def before_hooked_method(self, param: Any) -> None:\n            """Вызывается до оригинального метода (офлайн — ничего не делает)."""\n\n        def after_hooked_method(self, param: Any) -> None:\n            """Вызывается после оригинального метода (офлайн — ничего не делает)."""\n\n\ntry:  # pragma: no cover - ветка выполняется только на устройстве\n    from base_plugin import MethodReplacement\nexcept Exception:  # pragma: no cover - ветка для обычного Python\n\n    class MethodReplacement(BaseHook):\n        """Заглушка полной замены метода (офлайн — возвращает ``None``)."""\n\n        def replace_hooked_method(self, param: Any) -> Any:\n            """Замещает оригинальный метод (офлайн — ничего не делает)."""\n            return None\n\n\ntry:  # pragma: no cover - ветка выполняется только на устройстве\n    from base_plugin import HookFilter\nexcept Exception:  # pragma: no cover - ветка для обычного Python\n\n    class HookFilter:\n        """Заглушка фильтров Xposed-хуков.\n\n        Константы — строки, параметрические фильтры возвращают кортеж-маркер\n        ``(имя, *аргументы)``. Этого достаточно офлайн-тестам, чтобы\n        проверить, что фильтр дошёл до регистрации без изменений.\n        """\n\n        RESULT_IS_NULL = "RESULT_IS_NULL"\n        RESULT_IS_TRUE = "RESULT_IS_TRUE"\n        RESULT_IS_FALSE = "RESULT_IS_FALSE"\n        RESULT_NOT_NULL = "RESULT_NOT_NULL"\n\n        @staticmethod\n        def ResultIsInstanceOf(clazz: Any) -> tuple:\n            """Результат является экземпляром ``clazz``."""\n            return ("ResultIsInstanceOf", clazz)\n\n        @staticmethod\n        def ResultEqual(value: Any) -> tuple:\n            """Результат равен ``value``."""\n            return ("ResultEqual", value)\n\n        @staticmethod\n        def ResultNotEqual(value: Any) -> tuple:\n            """Результат не равен ``value``."""\n            return ("ResultNotEqual", value)\n\n        @staticmethod\n        def ArgumentIsNull(index: int) -> tuple:\n            """Аргумент ``index`` равен ``null``."""\n            return ("ArgumentIsNull", index)\n\n        @staticmethod\n        def ArgumentNotNull(index: int) -> tuple:\n            """Аргумент ``index`` не ``null``."""\n            return ("ArgumentNotNull", index)\n\n        @staticmethod\n        def ArgumentIsFalse(index: int) -> tuple:\n            """Аргумент ``index`` равен ``false``."""\n            return ("ArgumentIsFalse", index)\n\n        @staticmethod\n        def ArgumentIsTrue(index: int) -> tuple:\n            """Аргумент ``index`` равен ``true``."""\n            return ("ArgumentIsTrue", index)\n\n        @staticmethod\n        def ArgumentIsInstanceOf(index: int, clazz: Any) -> tuple:\n            """Аргумент ``index`` является экземпляром ``clazz``."""\n            return ("ArgumentIsInstanceOf", index, clazz)\n\n        @staticmethod\n        def ArgumentEqual(index: int, value: Any) -> tuple:\n            """Аргумент ``index`` равен ``value``."""\n            return ("ArgumentEqual", index, value)\n\n        @staticmethod\n        def ArgumentNotEqual(index: int, value: Any) -> tuple:\n            """Аргумент ``index`` не равен ``value``."""\n            return ("ArgumentNotEqual", index, value)\n\n        @staticmethod\n        def Condition(mvel_expr: str, obj: Any = None) -> tuple:\n            """MVEL-выражение истинно."""\n            return ("Condition", mvel_expr, obj)\n\n        @staticmethod\n        def Or(*filters: Any) -> tuple:\n            """Хотя бы один из вложенных фильтров истинен."""\n            return ("Or", *filters)\n\n\ntry:  # pragma: no cover - ветка выполняется только на устройстве\n    from base_plugin import hook_filters\nexcept Exception:  # pragma: no cover - ветка для обычного Python\n\n    def hook_filters(*filters: Any) -> Any:\n        """Заглушка декоратора фильтров Xposed-хука.\n\n        Офлайн сохраняет фильтры в атрибуте функции (``__catalib_filters__``),\n        чтобы тест мог проверить, что фильтры применены, и возвращает функцию\n        без изменений.\n        """\n\n        def decorator(func: Any) -> Any:\n            existing = getattr(func, "__catalib_filters__", ())\n            func.__catalib_filters__ = tuple(existing) + tuple(filters)\n            return func\n\n        return decorator\n\n\ntry:  # pragma: no cover - ветка выполняется только на устройстве\n    from hook_utils import find_class\nexcept Exception:  # pragma: no cover - ветка для обычного Python\n\n    def find_class(name: str) -> Any:\n        """Заглушка поиска Java-класса: вне exteraGram класса нет."""\n        return None\n\n\ndef log(message: str) -> None:\n    """Записать строку в лог приложения (или в no-op вне exteraGram)."""\n    try:  # pragma: no cover - на устройстве\n        from android_utils import log as _log\n\n        _log(message)\n    except Exception:\n        pass\n\n\ndef run_on_ui_thread(callback: Any, delay: int = 0) -> None:\n    """Выполнить callback в UI-потоке (на устройстве) или сразу (офлайн).\n\n    :param callback: вызываемый объект без аргументов.\n    :param delay: задержка в миллисекундах (на устройстве; офлайн\n        игнорируется — вызов выполняется немедленно).\n    """\n    try:  # pragma: no cover - на устройстве\n        from android_utils import run_on_ui_thread as _ui\n\n        try:\n            _ui(callback, delay)\n        except TypeError:\n            # Старые сборки SDK: run_on_ui_thread без аргумента задержки.\n            _ui(callback)\n        return\n    except Exception:\n        callback()\n\n\ndef get_plugins_dir() -> str:\n    """Каталог плагинов на устройстве; во офлайн-режиме — временный каталог."""\n    try:  # pragma: no cover - на устройстве\n        from file_utils import get_plugins_dir as _dir\n\n        return _dir()\n    except Exception:\n        return tempfile.gettempdir()\n\n\n__all__ = [\n    "SDK_AVAILABLE",\n    "AppEvent",\n    "BaseHook",\n    "BasePlugin",\n    "HookFilter",\n    "HookResult",\n    "HookStrategy",\n    "MenuItemData",\n    "MenuItemType",\n    "MethodHook",\n    "MethodReplacement",\n    "find_class",\n    "get_plugins_dir",\n    "hook_filters",\n    "log",\n    "run_on_ui_thread",\n]\n', False, '<catalib-vendor>/catalib/support/sdk.py'),
    'catalib.support.settings': ('"""Типизированные декларативные настройки плагина.\n\nОписание настроек не зависит от наличия SDK: на устройстве элементы\nконвертируются в классы ``ui.settings`` exteraGram, в офлайн-тестах остаются\nсамодостаточными объектами с теми же полями.\n\nПолный паритет с публичным SDK ``ui.settings`` (ADR-0006): компоненты\n``header``, ``divider``, ``switch``, ``selector``, ``text_input`` (Input),\n``edit_text`` (EditText), ``text`` (кликабельный Text), ``custom`` со всеми\nпараметрами SDK (``on_click``, ``on_change``, ``icon``, ``accent``, ``red``,\n``link_alias``, ``create_sub_fragment``, ``multiline``, ``max_length``,\n``mask``).\n\nРасширения строго аддитивны: прежние позиционные сигнатуры ``header``,\n``switch``, ``text_input``, ``text`` сохранены, а новые параметры — только\nkeyword-only и со «незаданным» значением по умолчанию, поэтому для прежнего\nкода итоговый ``params`` (и вызов ``ui.settings``) не меняется.\n"""\n\nfrom __future__ import annotations\n\nfrom collections.abc import Callable\nfrom dataclasses import dataclass, field\nfrom typing import Any\n\n#: Поддерживаемые типы элементов настроек и соответствующие классы ui.settings.\n_SDK_CLASS_BY_KIND = {\n    "header": "Header",\n    "divider": "Divider",\n    "switch": "Switch",\n    "selector": "Selector",\n    "input": "Input",\n    "edittext": "EditText",\n    "text": "Text",\n    "custom": "Custom",\n}\n\n\n@dataclass(frozen=True, slots=True)\nclass SettingItem:\n    """Один элемент настроек плагина.\n\n    :param kind: тип элемента — ключ из :data:`_SDK_CLASS_BY_KIND`\n        (``header`` | ``divider`` | ``switch`` | ``selector`` | ``input`` |\n        ``edittext`` | ``text`` | ``custom``).\n    :param params: именованные параметры, передаваемые классу ``ui.settings``.\n    """\n\n    kind: str\n    params: dict[str, Any] = field(default_factory=dict)\n\n    def build(self) -> Any:\n        """Построить объект ``ui.settings`` (на устройстве) либо вернуть себя.\n\n        В офлайн-окружении SDK недоступен — возвращается сам элемент, что\n        удобно для модульных тестов.\n        """\n        try:  # pragma: no cover - выполняется только на устройстве\n            from ui import settings as sdk_settings\n\n            sdk_class = getattr(sdk_settings, _SDK_CLASS_BY_KIND[self.kind])\n            return sdk_class(**self.params)\n        except Exception:\n            return self\n\n\ndef header(text: str) -> SettingItem:\n    """Заголовок секции настроек.\n\n    :param text: текст заголовка.\n    """\n    return SettingItem("header", {"text": text})\n\n\ndef divider(text: str = "") -> SettingItem:\n    """Разделитель с необязательной подписью.\n\n    :param text: необязательная подпись разделителя; если пусто — без неё.\n    """\n    params: dict[str, Any] = {}\n    if text:\n        params["text"] = text\n    return SettingItem("divider", params)\n\n\ndef switch(\n    key: str,\n    text: str,\n    default: bool = False,\n    subtext: str = "",\n    *,\n    icon: str = "",\n    on_change: Callable[..., Any] | None = None,\n    on_long_click: Callable[..., Any] | None = None,\n    link_alias: str = "",\n) -> SettingItem:\n    """Переключатель булевой настройки.\n\n    :param key: ключ настройки (``get_setting``/``set_setting``).\n    :param text: подпись переключателя.\n    :param default: значение по умолчанию.\n    :param subtext: необязательная подпись под текстом.\n    :param icon: необязательная иконка (drawable).\n    :param on_change: необязательный обработчик изменения значения.\n    :param on_long_click: необязательный обработчик долгого нажатия.\n    :param link_alias: необязательный алиас для ссылки на настройку.\n    """\n    params: dict[str, Any] = {"key": key, "text": text, "default": default}\n    if subtext:\n        params["subtext"] = subtext\n    if icon:\n        params["icon"] = icon\n    if on_change is not None:\n        params["on_change"] = on_change\n    if on_long_click is not None:\n        params["on_long_click"] = on_long_click\n    if link_alias:\n        params["link_alias"] = link_alias\n    return SettingItem("switch", params)\n\n\ndef selector(\n    key: str,\n    text: str,\n    default: int,\n    items: list[str],\n    *,\n    icon: str = "",\n    on_change: Callable[..., Any] | None = None,\n    on_long_click: Callable[..., Any] | None = None,\n    link_alias: str = "",\n) -> SettingItem:\n    """Выпадающий список (выбор одного значения из набора).\n\n    :param key: ключ настройки; хранит индекс выбранного пункта.\n    :param text: подпись селектора.\n    :param default: индекс выбранного по умолчанию пункта.\n    :param items: непустой список подписей пунктов.\n    :param icon: необязательная иконка (drawable).\n    :param on_change: необязательный обработчик изменения значения.\n    :param on_long_click: необязательный обработчик долгого нажатия.\n    :param link_alias: необязательный алиас для ссылки на настройку.\n    :raises ValueError: если ``items`` не является непустым списком строк.\n    """\n    if not isinstance(items, list) or not items:\n        raise ValueError("items селектора должен быть непустым списком")\n    if not all(isinstance(it, str) for it in items):\n        raise ValueError("items селектора должен содержать только строки")\n    params: dict[str, Any] = {\n        "key": key,\n        "text": text,\n        "default": default,\n        "items": items,\n    }\n    if icon:\n        params["icon"] = icon\n    if on_change is not None:\n        params["on_change"] = on_change\n    if on_long_click is not None:\n        params["on_long_click"] = on_long_click\n    if link_alias:\n        params["link_alias"] = link_alias\n    return SettingItem("selector", params)\n\n\ndef text_input(\n    key: str,\n    text: str,\n    default: str = "",\n    subtext: str = "",\n    icon: str = "",\n    *,\n    on_change: Callable[..., Any] | None = None,\n    on_long_click: Callable[..., Any] | None = None,\n    link_alias: str = "",\n) -> SettingItem:\n    """Однострочное текстовое поле ввода (``ui.settings.Input``).\n\n    :param key: ключ настройки.\n    :param text: подпись поля.\n    :param default: значение по умолчанию.\n    :param subtext: необязательная подпись под текстом.\n    :param icon: необязательная иконка (drawable).\n    :param on_change: необязательный обработчик изменения значения.\n    :param on_long_click: необязательный обработчик долгого нажатия.\n    :param link_alias: необязательный алиас для ссылки на настройку.\n    """\n    params: dict[str, Any] = {"key": key, "text": text, "default": default}\n    if subtext:\n        params["subtext"] = subtext\n    if icon:\n        params["icon"] = icon\n    if on_change is not None:\n        params["on_change"] = on_change\n    if on_long_click is not None:\n        params["on_long_click"] = on_long_click\n    if link_alias:\n        params["link_alias"] = link_alias\n    return SettingItem("input", params)\n\n\ndef edit_text(\n    key: str,\n    hint: str,\n    default: str = "",\n    *,\n    multiline: bool = False,\n    max_length: int = 0,\n    mask: str = "",\n    on_change: Callable[..., Any] | None = None,\n) -> SettingItem:\n    """Многострочное текстовое поле (``ui.settings.EditText``).\n\n    :param key: ключ настройки.\n    :param hint: текст-подсказка (placeholder).\n    :param default: значение по умолчанию; добавляется при непустом значении.\n    :param multiline: разрешить многострочный ввод.\n    :param max_length: ограничение длины (>0 — добавляется в параметры).\n    :param mask: необязательная маска ввода.\n    :param on_change: необязательный обработчик изменения значения.\n    """\n    params: dict[str, Any] = {"key": key, "hint": hint}\n    if default:\n        params["default"] = default\n    if multiline:\n        params["multiline"] = True\n    if max_length:\n        params["max_length"] = max_length\n    if mask:\n        params["mask"] = mask\n    if on_change is not None:\n        params["on_change"] = on_change\n    return SettingItem("edittext", params)\n\n\ndef text(\n    text: str,\n    subtext: str = "",\n    icon: str = "",\n    *,\n    accent: bool = False,\n    red: bool = False,\n    on_click: Callable[..., Any] | None = None,\n    on_long_click: Callable[..., Any] | None = None,\n    create_sub_fragment: Callable[..., Any] | None = None,\n    link_alias: str = "",\n) -> SettingItem:\n    """Информационная или кликабельная строка (``ui.settings.Text``).\n\n    Первоклассный способ сделать строку настроек кликабельной — передать\n    ``on_click``; ручной перебор API клика в плагине больше не нужен.\n\n    :param text: основной текст строки.\n    :param subtext: необязательная подпись под текстом.\n    :param icon: необязательная иконка (drawable).\n    :param accent: выделить акцентным цветом.\n    :param red: выделить красным (деструктивное действие).\n    :param on_click: обработчик клика по строке.\n    :param on_long_click: необязательный обработчик долгого нажатия.\n    :param create_sub_fragment: фабрика вложенного экрана настроек.\n    :param link_alias: необязательный алиас для ссылки на настройку.\n    """\n    params: dict[str, Any] = {"text": text}\n    if subtext:\n        params["subtext"] = subtext\n    if icon:\n        params["icon"] = icon\n    if accent:\n        params["accent"] = True\n    if red:\n        params["red"] = True\n    if on_click is not None:\n        params["on_click"] = on_click\n    if on_long_click is not None:\n        params["on_long_click"] = on_long_click\n    if create_sub_fragment is not None:\n        params["create_sub_fragment"] = create_sub_fragment\n    if link_alias:\n        params["link_alias"] = link_alias\n    return SettingItem("text", params)\n\n\ndef custom(\n    *,\n    item: Any = None,\n    view: Any = None,\n    factory: Callable[..., Any] | None = None,\n    factory_args: Any = None,\n    on_click: Callable[..., Any] | None = None,\n    on_long_click: Callable[..., Any] | None = None,\n    create_sub_fragment: Callable[..., Any] | None = None,\n    link_alias: str = "",\n) -> SettingItem:\n    """Кастомная строка настроек (``ui.settings.Custom``).\n\n    Источник содержимого задаётся одним из ``item`` / ``view`` / ``factory``.\n\n    :param item: готовый элемент строки.\n    :param view: готовое Android-``View``.\n    :param factory: фабрика, создающая ``View`` (см. :func:`simple_setting_factory`).\n    :param factory_args: аргументы фабрики.\n    :param on_click: необязательный обработчик клика.\n    :param on_long_click: необязательный обработчик долгого нажатия.\n    :param create_sub_fragment: фабрика вложенного экрана настроек.\n    :param link_alias: необязательный алиас для ссылки на настройку.\n    :raises ValueError: если не задан ни ``item``, ни ``view``, ни ``factory``.\n    """\n    if item is None and view is None and factory is None:\n        raise ValueError("custom требует один из аргументов: item, view или factory")\n    params: dict[str, Any] = {}\n    if item is not None:\n        params["item"] = item\n    if view is not None:\n        params["view"] = view\n    if factory is not None:\n        params["factory"] = factory\n    if factory_args is not None:\n        params["factory_args"] = factory_args\n    if on_click is not None:\n        params["on_click"] = on_click\n    if on_long_click is not None:\n        params["on_long_click"] = on_long_click\n    if create_sub_fragment is not None:\n        params["create_sub_fragment"] = create_sub_fragment\n    if link_alias:\n        params["link_alias"] = link_alias\n    return SettingItem("custom", params)\n\n\ndef simple_setting_factory(\n    create_view: Callable[..., Any],\n    bind_view: Callable[..., Any],\n    *,\n    is_clickable: bool = False,\n    is_shadow: bool = False,\n    create_item: Callable[..., Any] | None = None,\n    on_click: Callable[..., Any] | None = None,\n    on_long_click: Callable[..., Any] | None = None,\n    attached_view: Callable[..., Any] | None = None,\n    equals: Callable[..., Any] | None = None,\n    content_equals: Callable[..., Any] | None = None,\n) -> Any:\n    """Построить ``ui.settings.SimpleSettingFactory`` для строки ``custom``.\n\n    На устройстве возвращается настоящий ``SimpleSettingFactory``; офлайн —\n    самодостаточный объект с теми же полями и вызываемый\n    (``factory(link_alias=..., *args)``), что удобно для модульных тестов.\n\n    :param create_view: ``create_view(context, list_view, current_account,\n        class_guid, resources_provider) -> View``.\n    :param bind_view: ``bind_view(view, item, divider, adapter, list_view)``.\n    :param is_clickable: строка кликабельна.\n    :param is_shadow: строка-тень (разделитель).\n    :param create_item: фабрика элемента строки.\n    :param on_click: ``on_click(plugin, item, view)``.\n    :param on_long_click: ``on_long_click(plugin, item, view) -> bool``.\n    :param attached_view: фабрика прикреплённого ``View``.\n    :param equals: сравнение элементов.\n    :param content_equals: сравнение содержимого элементов.\n    """\n    kwargs: dict[str, Any] = {\n        "create_view": create_view,\n        "bind_view": bind_view,\n        "is_clickable": is_clickable,\n        "is_shadow": is_shadow,\n    }\n    for name, value in (\n        ("create_item", create_item),\n        ("on_click", on_click),\n        ("on_long_click", on_long_click),\n        ("attached_view", attached_view),\n        ("equals", equals),\n        ("content_equals", content_equals),\n    ):\n        if value is not None:\n            kwargs[name] = value\n    try:  # pragma: no cover - выполняется только на устройстве\n        from ui.settings import SimpleSettingFactory as _SSF\n\n        return _SSF(**kwargs)\n    except Exception:\n        return _OfflineSettingFactory(kwargs)\n\n\nclass _OfflineSettingFactory:\n    """Офлайн-двойник ``SimpleSettingFactory``: хранит поля и вызываем."""\n\n    def __init__(self, kwargs: dict[str, Any]) -> None:\n        self.kwargs = kwargs\n\n    def __call__(self, *args: Any, link_alias: str = "", **extra: Any) -> _OfflineSettingFactory:\n        self.link_alias = link_alias\n        self.call_args = args\n        return self\n', False, '<catalib-vendor>/catalib/support/settings.py'),
    'catalib.support.xposed': ('"""Декларативные Xposed-хуки методов Java.\n\nДокументированный паттерн exteraGram (см. шаблон ``xposed_demo``):\n``find_class`` → ``getDeclaredMethod``/``getDeclaredConstructor`` →\n``self.hook_method(method, MethodHook(), priority=...)`` → в\n``on_plugin_unload`` ``self.unhook_method(handle)``. Это много шаблона и\nтиповая ошибка — забыть ``unhook``.\n\nЗдесь хук объявляется одним декоратором :func:`xposed` на методе плагина;\n:class:`~catalib.support.plugin.CatalibPlugin` регистрирует его в\n``on_plugin_load`` и снимает в ``on_plugin_unload`` автоматически. Все\nошибки рефлексии перехватываются и логируются (рефлексия хрупка при\nобновлении приложения — pitfall #7), кадр загрузки не падает.\n\nСлой не скрывает SDK: те же ``MethodHook``/``MethodReplacement``/\n``HookFilter``/``find_class`` доступны напрямую через\n:mod:`catalib.support.sdk`. Зависит только от стандартной библиотеки и SDK.\n"""\n\nfrom __future__ import annotations\n\nfrom collections.abc import Callable\nfrom dataclasses import dataclass, field\nfrom typing import Any\n\nimport catalib.support.sdk as sdk\n\n#: Имя атрибута-маркера на методе-обработчике Xposed-хука.\nXPOSED_ATTR = "__catalib_xposed__"\n\n#: Допустимые фазы хука.\n_PHASES = ("before", "after", "replace")\n\n\n@dataclass(frozen=True, slots=True)\nclass XposedSpec:\n    """Описание декларативного Xposed-хука, привязанного к методу плагина.\n\n    :param class_fqn: полное имя Java-класса (``org.telegram.ui.ChatActivity``).\n    :param method_name: имя метода; для конструктора игнорируется.\n    :param phase: ``before`` | ``after`` | ``replace``.\n    :param priority: приоритет хука (по умолчанию 10, как в SDK).\n    :param is_constructor: хукать конструктор, а не метод.\n    :param arg_types: типы аргументов для разрешения перегрузки —\n        кортеж FQN-строк (резолвятся ``find_class``) либо уже готовых\n        Java-``Class``; ``None`` — без уточнения (метод без перегрузок).\n    :param filters: кортеж фильтров ``HookFilter`` (применяются через\n        ``hook_filters`` к методу моста).\n    """\n\n    class_fqn: str\n    method_name: str\n    phase: str\n    priority: int = 10\n    is_constructor: bool = False\n    arg_types: tuple[Any, ...] | None = None\n    filters: tuple[Any, ...] = field(default_factory=tuple)\n\n\ndef xposed(\n    class_fqn: str,\n    method_name: str = "",\n    *,\n    phase: str = "after",\n    priority: int = 10,\n    is_constructor: bool = False,\n    arg_types: tuple[Any, ...] | list[Any] | None = None,\n    filters: tuple[Any, ...] | list[Any] = (),\n) -> Callable[[Callable], Callable]:\n    """Пометить метод плагина как обработчик Xposed-хука.\n\n    Обработчик получает один аргумент ``param`` (``MethodHookParam`` SDK):\n    ``param.thisObject``, ``param.args``, ``param.getResult()``,\n    ``param.setResult(v)`` и т. д. Для ``phase="replace"`` возвращаемое\n    значение обработчика становится результатом метода.\n\n    :param class_fqn: полное имя Java-класса (непустая строка).\n    :param method_name: имя метода; для конструктора можно опустить.\n    :param phase: ``before`` (до оригинала), ``after`` (после) или\n        ``replace`` (полная замена).\n    :param priority: приоритет хука.\n    :param is_constructor: хукать конструктор.\n    :param arg_types: типы аргументов для разрешения перегрузки.\n    :param filters: фильтры ``HookFilter`` (см. :mod:`catalib.support.sdk`).\n    :raises ValueError: при пустом ``class_fqn``, неизвестной ``phase`` или\n        пустом ``method_name`` для не-конструктора.\n    """\n    if not isinstance(class_fqn, str) or not class_fqn:\n        raise ValueError("class_fqn должен быть непустой строкой")\n    if phase not in _PHASES:\n        raise ValueError(f"phase должен быть одним из {_PHASES}")\n    if not is_constructor and (not isinstance(method_name, str) or not method_name):\n        raise ValueError("method_name обязателен для хука метода (не конструктора)")\n\n    spec = XposedSpec(\n        class_fqn=class_fqn,\n        method_name=method_name,\n        phase=phase,\n        priority=priority,\n        is_constructor=is_constructor,\n        arg_types=tuple(arg_types) if arg_types is not None else None,\n        filters=tuple(filters),\n    )\n\n    def decorator(func: Callable) -> Callable:\n        setattr(func, XPOSED_ATTR, spec)\n        return func\n\n    return decorator\n\n\ndef _make_bridge(handler: Callable[[Any], Any], phase: str, filters: tuple[Any, ...]) -> Any:\n    """Построить объект-мост SDK, делегирующий в связанный метод плагина.\n\n    Методы ``MethodHook``/``MethodReplacement`` получают ``self`` моста; сам\n    обработчик плагина уже связан (``self`` плагина захвачен). Фильтры\n    применяются к методу фазы через ``hook_filters`` ровно как в\n    документации SDK (``@hook_filters(...) def before_hooked_method``).\n    """\n\n    def phase_call(_self: Any, param: Any) -> Any:\n        return handler(param)\n\n    if filters:\n        phase_call = sdk.hook_filters(*filters)(phase_call)\n\n    if phase == "replace":\n        return type(\n            "_CatalibReplaceHook",\n            (sdk.MethodReplacement,),\n            {"replace_hooked_method": phase_call},\n        )()\n    method_name = "before_hooked_method" if phase == "before" else "after_hooked_method"\n    return type("_CatalibMethodHook", (sdk.MethodHook,), {method_name: phase_call})()\n\n\ndef _log(plugin: Any, message: str) -> None:\n    """Записать диагностику Xposed-слоя.\n\n    Предпочтительно через логгер плагина (есть и в SDK, и в офлайн-заглушке —\n    диагностику видно в тестах); при его отсутствии — через модульный\n    ``sdk.log`` (на устройстве уходит в ``android_utils.log``).\n    """\n    try:\n        plugin.log(message)\n    except Exception:\n        sdk.log(message)\n\n\ndef _resolve_member(spec: XposedSpec) -> Any:\n    """Найти Java-класс и нужный метод/конструктор по спецификации.\n\n    :returns: объект метода/конструктора либо ``None``, если класс или тип\n        аргумента не найдены (вне exteraGram ``find_class`` всегда ``None``).\n    """\n    cls_obj = sdk.find_class(spec.class_fqn)\n    if cls_obj is None:\n        return None\n    resolved: list[Any] = []\n    for arg in spec.arg_types or ():\n        if isinstance(arg, str):\n            arg_cls = sdk.find_class(arg)\n            if arg_cls is None:\n                return None\n            resolved.append(arg_cls)\n        else:\n            resolved.append(arg)\n    if spec.is_constructor:\n        return cls_obj.getDeclaredConstructor(*resolved)\n    return cls_obj.getDeclaredMethod(spec.method_name, *resolved)\n\n\ndef register_xposed(plugin: Any, attr_name: str, spec: XposedSpec) -> Any:\n    """Зарегистрировать один декларативный Xposed-хук на устройстве.\n\n    Безопасно: любая ошибка рефлексии логируется и не роняет загрузку\n    плагина (рефлексия хрупка при обновлении приложения — pitfall #7).\n\n    :param plugin: экземпляр плагина (источник ``hook_method`` и обработчика).\n    :param attr_name: имя метода-обработчика на плагине.\n    :param spec: спецификация хука.\n    :returns: дескриптор для ``unhook_method`` либо ``None`` при неуспехе.\n    """\n    try:\n        member = _resolve_member(spec)\n        if member is None:\n            _log(\n                plugin,\n                f"[catalib] Xposed: класс/метод не найден "\n                f"({spec.class_fqn}.{spec.method_name or \'<init>\'}) — хук пропущен",\n            )\n            return None\n        handler = getattr(plugin, attr_name)\n        bridge = _make_bridge(handler, spec.phase, spec.filters)\n        return plugin.hook_method(member, bridge, priority=spec.priority)\n    except Exception as exc:  # рефлексия/SDK хрупки — не валим on_plugin_load\n        _log(plugin, f"[catalib] Xposed: ошибка регистрации {spec.class_fqn}: {exc}")\n        return None\n\n\ndef unregister_xposed(plugin: Any, handle: Any) -> None:\n    """Снять один Xposed-хук, не роняя выгрузку при ошибке."""\n    try:\n        plugin.unhook_method(handle)\n    except Exception as exc:\n        _log(plugin, f"[catalib] Xposed: ошибка снятия хука: {exc}")\n', False, '<catalib-vendor>/catalib/support/xposed.py'),
}
_CATALIB_ENTRY = 'read_notification.plugin'

catalib_install('read_notification', globals(), _CATALIB_SOURCES, _CATALIB_ENTRY)
