            LinearLayout.LayoutParams.MATCH_PARENT,
            LinearLayout.LayoutParams.WRAP_CONTENT,
        )
        button_row.addView(close_btn, button_params)

        button_container.addView(button_row)

        container.addView(content)
        container.addView(button_container)

        self.bottom_sheet.setCustomView(container)

    def show(self):
        try:
            self.bottom_sheet.show()
        except Exception as e:
            self.log(f"WSP: error showing evolution: {e}")

    def dismiss(self):
        try:
            self.bottom_sheet.dismiss()
        except Exception as e:
            self.log(f"WSP: error dismissing evolution: {e}")
        finally:
            self.plugin = None
            self.context = None
            self.chat_id = None
            self.bottom_sheet = None


class PetStatsBottomSheet:
    def __init__(self, context, plugin, chat_id):
        self.context = context
        self.plugin = plugin
        self.chat_id = chat_id
        self.log = plugin.log if plugin else log

        if plugin:
            self.log(
                f"WSP: PetStatsBottomSheet.__init__ called with plugin={type(plugin).__name__}, chat_id={chat_id}"
            )
        else:
            self.log(
                f"WSP ERROR: PetStatsBottomSheet.__init__ called with plugin=None, chat_id={chat_id}"
            )

        self.bottom_sheet = BottomSheet(context, False)

        if not plugin:
            self.log("WSP ERROR: plugin is None in PetStatsBottomSheet.__init__")
            error_tv = TextView(context)
            error_tv.setText("Ошибка: плагин не инициализирован")
            error_tv.setTextSize(1, 16)
            error_tv.setTextColor(get_error())
            error_tv.setGravity(Gravity.CENTER)
            error_tv.setPadding(
                AndroidUtilities.dp(32),
                AndroidUtilities.dp(32),
                AndroidUtilities.dp(32),
                AndroidUtilities.dp(32),
            )
            self.bottom_sheet.setCustomView(error_tv)
            return

        pet = plugin.pets.get(chat_id)
        streak = plugin._get_or_create_streak(chat_id)
        is_active = chat_id in plugin.pet_enabled_chats

        if not pet and not is_active:
            self._build_invite_screen()
            return

        if not is_active:
            self._build_activation_screen(pet)
            return

        container = LinearLayout(context)
        container.setOrientation(LinearLayout.VERTICAL)
        container.setBackgroundColor(get_surface())
        apply_elevation(container, ELEVATION_SHEET)

        scroll_view = ScrollView(context)
        scroll_view.setFillViewport(True)

        content = LinearLayout(context)
        content.setOrientation(LinearLayout.VERTICAL)
        content.setBackgroundColor(get_surface())

        self._build_header(content, pet, is_active)
        self._build_stats(content, pet, streak)
        self._build_progress(content, pet)
        self._build_info(content, is_active)

        scroll_view.addView(content)

        scroll_params = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT, 0, 1.0
        )
        container.addView(scroll_view, scroll_params)

        button_container = self._create_buttons(is_active)
        button_params = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT,
            LinearLayout.LayoutParams.WRAP_CONTENT,
        )
        container.addView(button_container, button_params)

        self.bottom_sheet.setCustomView(container)

    def _build_invite_screen(self):
        container = LinearLayout(self.context)
        container.setOrientation(LinearLayout.VERTICAL)
        container.setGravity(Gravity.CENTER)
        container.setPadding(
            AndroidUtilities.dp(32),
            AndroidUtilities.dp(48),
            AndroidUtilities.dp(32),
            AndroidUtilities.dp(32),
        )
        container.setBackgroundColor(Theme.getColor(Theme.key_windowBackgroundWhite))

        emoji_tv = TextView(self.context)
        emoji_tv.setText("🥚")
        emoji_tv.setTextSize(1, 96)
        emoji_tv.setGravity(Gravity.CENTER)
        container.addView(emoji_tv)

        title_tv = TextView(self.context)
        title_tv.setText("Заведи питомца!")
        title_tv.setTextSize(1, 24)
        title_tv.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
        title_tv.setTypeface(None, Typeface.BOLD)
        title_tv.setGravity(Gravity.CENTER)
        title_params = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.WRAP_CONTENT,
            LinearLayout.LayoutParams.WRAP_CONTENT,
        )
        title_params.setMargins(0, AndroidUtilities.dp(24), 0, AndroidUtilities.dp(12))
        container.addView(title_tv, title_params)

        desc_tv = TextView(self.context)
        desc_tv.setText(
            "Начни получать опыт за сообщения\nи вырасти своего виртуального питомца!"
        )
        desc_tv.setTextSize(1, 15)
        desc_tv.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
        desc_tv.setGravity(Gravity.CENTER)
        container.addView(desc_tv)

        start_btn = self._create_action_button(
            "Завести питомца", Theme.getColor(Theme.key_chat_messagePanelSend)
        )
        start_btn.setOnClickListener(
            OnClickListener(lambda *args: self._on_start_pet())
        )
        btn_params = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT,
            LinearLayout.LayoutParams.WRAP_CONTENT,
        )
        btn_params.setMargins(0, AndroidUtilities.dp(32), 0, AndroidUtilities.dp(8))
        container.addView(start_btn, btn_params)

        close_btn = self._create_action_button(
            "Закрыть", Theme.getColor(Theme.key_windowBackgroundWhiteGrayText)
        )
        close_btn.setOnClickListener(OnClickListener(lambda *args: self.dismiss()))
        close_params = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT,
            LinearLayout.LayoutParams.WRAP_CONTENT,
        )
        container.addView(close_btn, close_params)

        self.bottom_sheet.setCustomView(container)

    def _build_activation_screen(self, pet):
        container = LinearLayout(self.context)
        container.setOrientation(LinearLayout.VERTICAL)
        container.setGravity(Gravity.CENTER)
        container.setPadding(
            AndroidUtilities.dp(32),
            AndroidUtilities.dp(48),
            AndroidUtilities.dp(32),
            AndroidUtilities.dp(32),
        )
        container.setBackgroundColor(Theme.getColor(Theme.key_windowBackgroundWhite))

        emoji = pet.get_emoji() if pet else "🥚"
        emoji_tv = TextView(self.context)
        emoji_tv.setText(emoji)
        emoji_tv.setTextSize(1, 96)
        emoji_tv.setGravity(Gravity.CENTER)
        container.addView(emoji_tv)

        title_tv = TextView(self.context)
        title_tv.setText("Питомец неактивен")
        title_tv.setTextSize(1, 24)
        title_tv.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
        title_tv.setTypeface(None, Typeface.BOLD)
        title_tv.setGravity(Gravity.CENTER)
        title_params = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.WRAP_CONTENT,
            LinearLayout.LayoutParams.WRAP_CONTENT,
        )
        title_params.setMargins(0, AndroidUtilities.dp(24), 0, AndroidUtilities.dp(12))
        container.addView(title_tv, title_params)

        desc_tv = TextView(self.context)
        desc_tv.setText("Активируй питомца чтобы получать XP\nза сообщения в этом чате")
        desc_tv.setTextSize(1, 15)
        desc_tv.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
        desc_tv.setGravity(Gravity.CENTER)
        container.addView(desc_tv)

        start_btn = self._create_action_button(
            "Активировать", Theme.getColor(Theme.key_chat_messagePanelSend)
        )
        start_btn.setOnClickListener(
            OnClickListener(lambda *args: self._on_start_pet())
        )
        btn_params = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT,
            LinearLayout.LayoutParams.WRAP_CONTENT,
        )
        btn_params.setMargins(0, AndroidUtilities.dp(32), 0, AndroidUtilities.dp(8))
        container.addView(start_btn, btn_params)

        close_btn = self._create_action_button(
            "Закрыть", Theme.getColor(Theme.key_windowBackgroundWhiteGrayText)
        )
        close_btn.setOnClickListener(OnClickListener(lambda *args: self.dismiss()))
        close_params = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT,
            LinearLayout.LayoutParams.WRAP_CONTENT,
        )
        container.addView(close_btn, close_params)

        self.bottom_sheet.setCustomView(container)

    def _build_header(self, container, pet, is_active):
        header = LinearLayout(self.context)
        header.setOrientation(LinearLayout.VERTICAL)
        header.setGravity(Gravity.CENTER)
        header.setPadding(
            AndroidUtilities.dp(24),
            AndroidUtilities.dp(32),
            AndroidUtilities.dp(24),
            AndroidUtilities.dp(24),
        )

        bg = GradientDrawable()
        bg.setCornerRadius(0)
        try:
            bg.setGradientType(GradientDrawable.LINEAR_GRADIENT)
            color1 = Theme.getColor(Theme.key_chat_inBubble)
            color2 = Theme.getColor(Theme.key_chat_outBubble)
            bg.setColors([_jint32(color1), _jint32(color2)])
            bg.setOrientation(GradientDrawable.Orientation.TOP_BOTTOM)
        except Exception:
            bg.setColor(Theme.getColor(Theme.key_windowBackgroundWhite))
        header.setBackground(bg)

        emoji = pet.get_emoji()
        emoji_tv = TextView(self.context)
        emoji_tv.setText(emoji)
        emoji_tv.setTextSize(1, 72)
        emoji_tv.setGravity(Gravity.CENTER)
        header.addView(emoji_tv)

        name = pet.name
        name_tv = TextView(self.context)
        name_tv.setText(name)
        name_tv.setTextSize(1, 24)
        name_tv.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
        name_tv.setTypeface(None, Typeface.BOLD)
        name_tv.setGravity(Gravity.CENTER)
        name_params = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.WRAP_CONTENT,
            LinearLayout.LayoutParams.WRAP_CONTENT,
        )
        name_params.setMargins(0, AndroidUtilities.dp(12), 0, 0)
        header.addView(name_tv, name_params)

        stage_name_name = pet.get_stage_name()
        stage_tv = TextView(self.context)
        stage_tv.setText(stage_name_name)
        stage_tv.setTextSize(1, 16)
        stage_tv.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
        stage_tv.setGravity(Gravity.CENTER)
        stage_params = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.WRAP_CONTENT,
            LinearLayout.LayoutParams.WRAP_CONTENT,
        )
        stage_params.setMargins(0, AndroidUtilities.dp(4), 0, 0)
        header.addView(stage_tv, stage_params)

        if is_active:
            status_badge = TextView(self.context)
            status_badge.setText("✅ Активен")
            status_badge.setTextSize(1, 13)
            status_badge.setTextColor(Theme.getColor(Theme.key_chat_messagePanelSend))
            status_badge.setTypeface(None, Typeface.BOLD)
            status_badge.setGravity(Gravity.CENTER)
            status_badge.setPadding(
                AndroidUtilities.dp(12),
                AndroidUtilities.dp(6),
                AndroidUtilities.dp(12),
                AndroidUtilities.dp(6),
            )
            badge_bg = create_filled_bg(CORNER_MEDIUM, get_surface_variant())
            status_badge.setBackground(badge_bg)
            status_params = LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.WRAP_CONTENT,
                LinearLayout.LayoutParams.WRAP_CONTENT,
            )
            status_params.setMargins(0, AndroidUtilities.dp(12), 0, 0)
            header.addView(status_badge, status_params)

        container.addView(header)

    def _build_stats(self, container, pet, streak):
        pet.update_state()

        stats = LinearLayout(self.context)
        stats.setOrientation(LinearLayout.VERTICAL)
        stats.setPadding(
            AndroidUtilities.dp(16),
            AndroidUtilities.dp(16),
            AndroidUtilities.dp(16),
            AndroidUtilities.dp(8),
        )

        self._add_stat_card(
            stats,
            "⚡ Опыт",
            f"{pet.xp} XP (Ур.{pet.level})",
            Theme.getColor(Theme.key_chat_inBubble),
        )

        mood_color = (
            Theme.getColor(Theme.key_chat_outBubble)
            if pet.mood >= MOOD_MEDIUM_THRESHOLD
            else Theme.getColor(Theme.key_text_RedRegular)
        )
        self._add_stat_card(
            stats,
            "❤️ Настроение",
            f"{int(pet.mood)}%",
            mood_color,
        )

        hunger_color = (
            Theme.getColor(Theme.key_chat_inBubble)
            if pet.hunger >= HUNGER_MEDIUM_THRESHOLD
            else Theme.getColor(Theme.key_text_RedRegular)
        )
        self._add_stat_card(
            stats,
            "🍖 Голод",
            f"{int(pet.hunger)}%",
            hunger_color,
        )

        if streak:
            flame = streak.get_flame_emoji()
            self._add_stat_card(
                stats,
                f"{flame} Streak",
                f"{streak.count} дней",
                Theme.getColor(Theme.key_chat_inBubble),
            )

        container.addView(stats)

    def _add_stat_card(self, container, label, value, accent_color):
        card = LinearLayout(self.context)
        card.setOrientation(LinearLayout.HORIZONTAL)
        card.setPadding(
            AndroidUtilities.dp(16),
            AndroidUtilities.dp(14),
            AndroidUtilities.dp(16),
            AndroidUtilities.dp(14),
        )

        bg = create_filled_bg(CORNER_MEDIUM, get_surface_variant())
        try:
            bg.setStroke(AndroidUtilities.dp(2), accent_color)
        except Exception:
            pass

        card.setBackground(bg)
        apply_elevation(card, ELEVATION_CARD)

        label_tv = TextView(self.context)
        label_tv.setText(label)
        label_tv.setTextSize(1, 15)
        label_tv.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
        label_tv.setTypeface(None, Typeface.BOLD)
        label_params = LinearLayout.LayoutParams(
            0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0
        )
        card.addView(label_tv, label_params)

        value_tv = TextView(self.context)
        value_tv.setText(value)
        value_tv.setTextSize(1, 15)
        value_tv.setTextColor(accent_color)
        value_tv.setTypeface(None, Typeface.BOLD)
        value_tv.setGravity(Gravity.END)
        card.addView(value_tv)

        card_params = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT,
            LinearLayout.LayoutParams.WRAP_CONTENT,
        )
        card_params.setMargins(0, 0, 0, AndroidUtilities.dp(8))
        container.addView(card, card_params)

    def _build_progress(self, container, pet):
        progress_container = LinearLayout(self.context)
        progress_container.setOrientation(LinearLayout.VERTICAL)
        progress_container.setPadding(
            AndroidUtilities.dp(16),
            AndroidUtilities.dp(8),
            AndroidUtilities.dp(16),
            AndroidUtilities.dp(16),
        )

        divider = View(self.context)
        divider.setBackgroundColor(Theme.getColor(Theme.key_divider))
        divider_params = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT, 1
        )
        divider_params.setMargins(0, 0, 0, AndroidUtilities.dp(16))
        progress_container.addView(divider, divider_params)

        title_tv = TextView(self.context)
        title_tv.setText("Прогресс эволюции")
        title_tv.setTextSize(1, 16)
        title_tv.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
        title_tv.setTypeface(None, Typeface.BOLD)
        title_params = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.WRAP_CONTENT,
            LinearLayout.LayoutParams.WRAP_CONTENT,
        )
        title_params.setMargins(0, 0, 0, AndroidUtilities.dp(12))
        progress_container.addView(title_tv, title_params)

        xp_to_next = pet.xp_to_next_stage()

        if xp_to_next > 0:
            progress_bar = self._create_progress_bar(pet)
            progress_container.addView(progress_bar)

            subtitle_tv = TextView(self.context)
            subtitle_tv.setText(f"До следующей стадии: {xp_to_next} XP")
            subtitle_tv.setTextSize(1, 14)
            subtitle_tv.setTextColor(
                Theme.getColor(Theme.key_windowBackgroundWhiteGrayText)
            )
            subtitle_tv.setGravity(Gravity.CENTER)
            subtitle_params = LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.WRAP_CONTENT,
                LinearLayout.LayoutParams.WRAP_CONTENT,
            )
            subtitle_params.setMargins(0, AndroidUtilities.dp(8), 0, 0)
            progress_container.addView(subtitle_tv, subtitle_params)
        else:
            max_tv = TextView(self.context)
            max_tv.setText("✨ Максимальная стадия достигнута!")
            max_tv.setTextSize(1, 14)
            max_tv.setTextColor(Theme.getColor(Theme.key_chat_inBubble))
            max_tv.setGravity(Gravity.CENTER)
            max_tv.setTypeface(None, Typeface.BOLD)
            progress_container.addView(max_tv)

        container.addView(progress_container)

    def _create_progress_bar(self, pet):
        bar_container = FrameLayout(self.context)
        bar_container.setLayoutParams(
            FrameLayout.LayoutParams(
                FrameLayout.LayoutParams.MATCH_PARENT, AndroidUtilities.dp(24)
            )
        )

        bg_bar = View(self.context)
        bg_drawable = create_filled_bg(CORNER_MEDIUM, get_surface_variant())
        bg_bar.setBackground(bg_drawable)
        bg_bar.setLayoutParams(
            FrameLayout.LayoutParams(
                FrameLayout.LayoutParams.MATCH_PARENT, AndroidUtilities.dp(24)
            )
        )
        bar_container.addView(bg_bar)

        current_stage_xp = PET_STAGES[pet.stage]["xp"]

        if pet.stage >= len(PET_STAGES) - 1:
            progress_percent = 1.0
        else:
            next_stage_xp = PET_STAGES[pet.stage + 1]["xp"]
            xp_in_stage = pet.xp - current_stage_xp
            total_xp_needed = next_stage_xp - current_stage_xp

            if total_xp_needed > 0:
                progress_percent = float(xp_in_stage) / float(total_xp_needed)
            else:
                progress_percent = 1.0

        progress_percent = max(0.0, min(1.0, progress_percent))

        progress_bar = View(self.context)
        progress_drawable = create_filled_bg(CORNER_MEDIUM, get_primary())
        progress_bar.setBackground(progress_drawable)
        progress_params = FrameLayout.LayoutParams(
            int(FrameLayout.LayoutParams.MATCH_PARENT * progress_percent),
            AndroidUtilities.dp(24),
        )
        progress_bar.setLayoutParams(progress_params)
        bar_container.addView(progress_bar)

        return bar_container

    def _create_action_button(self, text, color):
        btn = TextView(self.context)
        btn.setText(text)
        btn.setTextSize(1, 17)
        btn.setTextColor(get_on_primary())
        btn.setGravity(Gravity.CENTER)
        btn.setPadding(
            AndroidUtilities.dp(24),
            AndroidUtilities.dp(16),
            AndroidUtilities.dp(24),
            AndroidUtilities.dp(16),
        )
        btn.setTypeface(None, Typeface.BOLD)

        bg = create_ripple_bg(CORNER_SMALL, color, get_on_primary())
        btn.setBackground(bg)
        apply_elevation(btn, ELEVATION_BUTTON)

        return btn

    def _build_info(self, container, is_active):
        info = LinearLayout(self.context)
        info.setOrientation(LinearLayout.VERTICAL)
        info.setPadding(
            AndroidUtilities.dp(16),
            AndroidUtilities.dp(0),
            AndroidUtilities.dp(16),
            AndroidUtilities.dp(16),
        )

        divider = View(self.context)
        divider.setBackgroundColor(Theme.getColor(Theme.key_divider))
        divider_params = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT, 1
        )
        divider_params.setMargins(0, 0, 0, AndroidUtilities.dp(16))
        info.addView(divider, divider_params)

        sync_manager = self.plugin._get_sync_manager()
        sync_mode_text = {
            StreakSyncManager.MODE_P2P: "📡 P2P (локальная)",
            StreakSyncManager.MODE_SERVER: "☁️ Сервер (облачная)",
            StreakSyncManager.MODE_AUTO: "🔄 Авто (гибрид)",
        }.get(sync_manager.mode, "❓ Неизвестно")

        info_text = f"Синхронизация: {sync_mode_text}\n"

        if is_active:
            info_text += "\n💡 Питомец получает XP за каждое сообщение\n"
            info_text += "🍖 Кормите питомца чтобы поднять настроение"
        else:
            info_text += "\n⚠️ Питомец неактивен - XP не начисляется"

        hint_tv = TextView(self.context)
        hint_tv.setText(info_text)
        hint_tv.setTextSize(1, 13)
        hint_tv.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
        hint_tv.setGravity(Gravity.CENTER)
        info.addView(hint_tv)

        container.addView(info)

    def _create_buttons(self, is_active):
        container = LinearLayout(self.context)
        container.setOrientation(LinearLayout.VERTICAL)
        container.setBackgroundColor(get_surface())

        divider = View(self.context)
        divider.setBackgroundColor(Theme.getColor(Theme.key_divider))
        divider_params = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT, 1
        )
        container.addView(divider, divider_params)

        button_row = LinearLayout(self.context)
        button_row.setOrientation(LinearLayout.HORIZONTAL)
        button_row.setPadding(
            AndroidUtilities.dp(12),
            AndroidUtilities.dp(12),
            AndroidUtilities.dp(12),
            AndroidUtilities.dp(12),
        )

        button_params = LinearLayout.LayoutParams(
            0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0
        )
        button_params.setMargins(AndroidUtilities.dp(4), 0, AndroidUtilities.dp(4), 0)

        if is_active:
            feed_btn = self._create_button("Покормить")
            feed_btn.setOnClickListener(
                OnClickListener(lambda *args: self._on_feed_click())
            )
            button_row.addView(feed_btn, button_params)

            play_btn = self._create_button("Поиграть")
            play_btn.setOnClickListener(
                OnClickListener(lambda *args: self._on_play_click())
            )
            button_row.addView(play_btn, button_params)

            rename_btn = self._create_button("Переименовать")
            rename_btn.setOnClickListener(
                OnClickListener(lambda *args: self._on_rename_click())
            )
            button_row.addView(rename_btn, button_params)

            sync_manager = self.plugin._get_sync_manager()
            if sync_manager.mode in [
                StreakSyncManager.MODE_SERVER,
                StreakSyncManager.MODE_AUTO,
            ]:
                sync_btn = self._create_button("Синхронизация")
                sync_btn.setOnClickListener(
                    OnClickListener(lambda *args: self._on_sync_click())
                )
                button_row.addView(sync_btn, button_params)

            container.addView(button_row)

            button_row2 = LinearLayout(self.context)
            button_row2.setOrientation(LinearLayout.HORIZONTAL)
            button_row2.setPadding(
                AndroidUtilities.dp(12),
                0,
                AndroidUtilities.dp(12),
                AndroidUtilities.dp(12),
            )

            show_widget = self.plugin.get_setting("show_widget", True)
            widget_text = "Скрыть виджет" if show_widget else "Показать виджет"
            widget_btn = self._create_button(widget_text)
            widget_btn.setOnClickListener(
                OnClickListener(lambda *args: self._on_toggle_widget())
            )
            button_row2.addView(widget_btn, button_params)

            kick_btn = self._create_button("Выгнать питомца")
            kick_btn.setOnClickListener(
                OnClickListener(lambda *args: self._on_kick_pet_click())
            )
            button_row2.addView(kick_btn, button_params)

            close_btn = self._create_button("Закрыть")
            close_btn.setOnClickListener(OnClickListener(lambda *args: self.dismiss()))
            button_row2.addView(close_btn, button_params)

            container.addView(button_row2)
        else:
            close_btn = self._create_button("Закрыть")
            close_btn.setOnClickListener(OnClickListener(lambda *args: self.dismiss()))
            button_row.addView(close_btn, button_params)

            container.addView(button_row)

        return container

    def _create_button(self, text):
        btn = TextView(self.context)
        btn.setText(text)
        btn.setTextSize(1, 15)
        btn.setGravity(Gravity.CENTER)
        btn.setSingleLine(True)
        btn.setPadding(
            AndroidUtilities.dp(12),
            AndroidUtilities.dp(16),
            AndroidUtilities.dp(12),
            AndroidUtilities.dp(16),
        )

        bg = create_outlined_bg(CORNER_SMALL, get_outline())
        btn.setBackground(bg)
        btn.setTextColor(get_on_surface())

        return btn

    def _on_feed_click(self):
        plugin = self.plugin
        chat_id = self.chat_id
        self.dismiss()
        plugin.feed_pet({"chat_id": chat_id})

    def _on_play_click(self):
        plugin = self.plugin
        chat_id = self.chat_id
        self.dismiss()
        plugin.play_with_pet({"chat_id": chat_id})

    def _on_start_pet(self):
        self.log(
            f"WSP: _on_start_pet called, self.plugin={self.plugin}, self.chat_id={self.chat_id}"
        )
        plugin = self.plugin
        chat_id = self.chat_id
        self.dismiss()
        if plugin:
            self.log(f"WSP: calling plugin._start_pet({chat_id})")
            plugin._start_pet(chat_id)
        else:
            self.log(
                f"WSP ERROR: plugin is None in _on_start_pet, type(plugin)={type(plugin)}"
            )
            BulletinHelper.show_error("Ошибка: плагин не инициализирован")

    def _on_sync_click(self):
        plugin = self.plugin
        chat_id = self.chat_id
        self.dismiss()
        plugin._force_sync_now(chat_id)

    def _on_stop_click(self):
        plugin = self.plugin
        chat_id = self.chat_id
        self.dismiss()
        plugin._stop_pet(chat_id)

    def _on_toggle_widget(self):
        current_state = self.plugin.get_setting("show_widget", True)
        new_state = not current_state
        self.plugin.set_setting("show_widget", new_state)

        if new_state:
            BulletinHelper.show_success("Виджет питомца показан")
        else:
            BulletinHelper.show_success("Виджет питомца скрыт")
            with self.plugin.data_lock:
                if self.chat_id in self.plugin.active_widgets:
                    try:
                        widget = self.plugin.active_widgets[self.chat_id]
                        if hasattr(widget, "cleanup"):
                            widget.cleanup()
                    except Exception as e:
                        self.log(f"WSP: error hiding widget: {e}")

        self.dismiss()

        def show_updated_menu():
            new_sheet = PetStatsBottomSheet(self.context, self.plugin, self.chat_id)
            new_sheet.show()

        run_on_ui_thread(show_updated_menu)

    def _on_rename_click(self):
        try:
            from android.text import InputType
            from android.widget import EditText
            from org.telegram.ui.ActionBar import AlertDialog

            pet = self.plugin.pets.get(self.chat_id)
            if not pet:
                BulletinHelper.show_error("Питомец не найден")
                return

            edit_text = EditText(self.context)
            edit_text.setText(pet.name)
            edit_text.setHint("Введите новое имя")
            edit_text.setInputType(
                InputType.TYPE_CLASS_TEXT | InputType.TYPE_TEXT_FLAG_CAP_WORDS
            )
            edit_text.setSingleLine(True)
            edit_text.setPadding(
                AndroidUtilities.dp(20),
                AndroidUtilities.dp(12),
                AndroidUtilities.dp(20),
                AndroidUtilities.dp(12),
            )

            builder = AlertDialog.Builder(self.context)
            builder.setTitle("Переименовать питомца")
            builder.setView(edit_text)

            def on_positive(dialog, which):
                new_name = str(edit_text.getText()).strip()
                if new_name and len(new_name) <= 100:
                    self.plugin._rename_pet(self.chat_id, new_name)
                    self.dismiss()

                    def show_updated_menu():
                        new_sheet = PetStatsBottomSheet(
                            self.context, self.plugin, self.chat_id
                        )
                        new_sheet.show()

                    run_on_ui_thread(show_updated_menu)
                elif len(new_name) > 100:
                    BulletinHelper.show_error(
                        "Имя слишком длинное (макс. 100 символов)"
                    )
                else:
                    BulletinHelper.show_error("Имя не может быть пустым")

            from java import dynamic_proxy

            ButtonClickListener = dynamic_proxy(AlertDialog.OnButtonClickListener)

            class PositiveListener(ButtonClickListener):
                def onClick(self, dialog, which):
                    on_positive(dialog, which)

            builder.setPositiveButton("Сохранить", PositiveListener())
            builder.setNegativeButton("Отмена", None)

            builder.show()

        except Exception as e:
            self.log(f"WSP: error showing rename dialog: {e}")
            BulletinHelper.show_error(f"Ошибка: {e}")

    def _on_kick_pet_click(self):
        try:
            from org.telegram.ui.ActionBar import AlertDialog

            builder = AlertDialog.Builder(self.context)
            builder.setTitle("Выгнать питомца?")
            builder.setMessage(
                "Вы уверены что хотите выгнать питомца? Это действие нельзя отменить! Все прогресс будет потерян."
            )

            def on_confirm(dialog, which):
                self.dismiss()
                self.plugin._kick_pet(self.chat_id)

            from java import dynamic_proxy

            ButtonClickListener = dynamic_proxy(AlertDialog.OnButtonClickListener)

            class ConfirmListener(ButtonClickListener):
                def onClick(self, dialog, which):
                    on_confirm(dialog, which)

            builder.setPositiveButton("Выгнать", ConfirmListener())
            builder.setNegativeButton("Отмена", None)

            builder.show()

        except Exception as e:
            self.log(f"WSP: error showing kick pet dialog: {e}")
            BulletinHelper.show_error(f"Ошибка: {e}")

    def show(self):
        try:
            self.bottom_sheet.show()
        except Exception as e:
            self.log(f"WSP: error showing pet stats: {e}")

    def dismiss(self):
        try:
            self.bottom_sheet.dismiss()
        except Exception as e:
            self.log(f"WSP: error dismissing pet stats: {e}")
        finally:
            self.plugin = None
            self.context = None
            self.chat_id = None
            self.bottom_sheet = None


class StreakMenuBottomSheet:
    def __init__(self, context, plugin, chat_id):
        self.context = context
        self.plugin = plugin
        self.chat_id = chat_id
        self.log = plugin.log if plugin else log

        self.bottom_sheet = BottomSheet(context, False)

        streak = plugin._get_or_create_streak(chat_id)
        is_active = chat_id in plugin.streak_enabled_chats

        container = LinearLayout(context)
        container.setOrientation(LinearLayout.VERTICAL)
        container.setBackgroundColor(get_surface())
        apply_elevation(container, ELEVATION_SHEET)

        scroll_view = ScrollView(context)
        scroll_view.setFillViewport(True)

        content = LinearLayout(context)
        content.setOrientation(LinearLayout.VERTICAL)
        content.setBackgroundColor(get_surface())

        if is_active and streak:
            self._build_active_streak_ui(content, streak)
        else:
            self._build_inactive_streak_ui(content)

        scroll_view.addView(content)

        scroll_params = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT, 0, 1.0
        )
        container.addView(scroll_view, scroll_params)

        button_container = self._create_buttons(is_active)
        button_params = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT,
            LinearLayout.LayoutParams.WRAP_CONTENT,
        )
        container.addView(button_container, button_params)

        self.bottom_sheet.setCustomView(container)

    def _build_active_streak_ui(self, container, streak):
        header_container = LinearLayout(self.context)
        header_container.setOrientation(LinearLayout.VERTICAL)
        header_container.setGravity(Gravity.CENTER)
        header_container.setPadding(
            AndroidUtilities.dp(24),
            AndroidUtilities.dp(32),
            AndroidUtilities.dp(24),
            AndroidUtilities.dp(24),
        )

        bg = GradientDrawable()
        bg.setCornerRadius(0)
        try:
            bg.setGradientType(GradientDrawable.LINEAR_GRADIENT)
            color1 = Theme.getColor(Theme.key_chat_inBubble)
            color2 = Theme.getColor(Theme.key_chat_outBubble)
            bg.setColors([_jint32(color1), _jint32(color2)])
            bg.setOrientation(GradientDrawable.Orientation.TOP_BOTTOM)
        except Exception:
            bg.setColor(Theme.getColor(Theme.key_windowBackgroundWhite))
        header_container.setBackground(bg)

        flame = streak.get_flame_emoji()
        emoji_text = TextView(self.context)
        emoji_text.setText(flame)
        emoji_text.setTextSize(1, 72)
        emoji_text.setGravity(Gravity.CENTER)
        header_container.addView(emoji_text)

        streak_count = TextView(self.context)
        streak_count.setText(f"{streak.count} дней")
        streak_count.setTextSize(1, 32)
        streak_count.setTextColor(
            Theme.getColor(Theme.key_windowBackgroundWhiteBlackText)
        )
        streak_count.setTypeface(None, Typeface.BOLD)
        streak_count.setGravity(Gravity.CENTER)
        count_params = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.WRAP_CONTENT,
            LinearLayout.LayoutParams.WRAP_CONTENT,
        )
        count_params.setMargins(0, AndroidUtilities.dp(12), 0, 0)
        header_container.addView(streak_count, count_params)

        subtitle = TextView(self.context)
        subtitle.setText("Streak")
        subtitle.setTextSize(1, 16)
        subtitle.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
        subtitle.setGravity(Gravity.CENTER)
        subtitle_params = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.WRAP_CONTENT,
            LinearLayout.LayoutParams.WRAP_CONTENT,
        )
        subtitle_params.setMargins(0, AndroidUtilities.dp(4), 0, 0)
        header_container.addView(subtitle, subtitle_params)

        status_badge = TextView(self.context)
        status_badge.setText("✅ Активен")
        status_badge.setTextSize(1, 13)
        status_badge.setTextColor(Theme.getColor(Theme.key_chat_messagePanelSend))
        status_badge.setTypeface(None, Typeface.BOLD)
        status_badge.setGravity(Gravity.CENTER)
        status_badge.setPadding(
            AndroidUtilities.dp(12),
            AndroidUtilities.dp(6),
            AndroidUtilities.dp(12),
            AndroidUtilities.dp(6),
        )
        badge_bg = create_filled_bg(CORNER_MEDIUM, get_surface_variant())
        status_badge.setBackground(badge_bg)
        status_params = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.WRAP_CONTENT,
            LinearLayout.LayoutParams.WRAP_CONTENT,
        )
        status_params.setMargins(0, AndroidUtilities.dp(12), 0, 0)
        header_container.addView(status_badge, status_params)

        container.addView(header_container)

        divider = View(self.context)
        divider.setBackgroundColor(Theme.getColor(Theme.key_divider))
        divider_params = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT, 1
        )
        container.addView(divider, divider_params)

        stats_container = LinearLayout(self.context)
        stats_container.setOrientation(LinearLayout.VERTICAL)
        stats_container.setPadding(
            AndroidUtilities.dp(16),
            AndroidUtilities.dp(16),
            AndroidUtilities.dp(16),
            AndroidUtilities.dp(16),
        )

        self._add_info_row(
            stats_container,
            "📅 Последнее сообщение",
            str(streak.last_date) if streak.last_date else "Не установлено",
            Theme.getColor(Theme.key_chat_inBubble),
        )
        self._add_info_row(
            stats_container,
            "🎯 Начало серии",
            str(streak.first_date) if streak.first_date else "Не установлено",
            Theme.getColor(Theme.key_chat_outBubble),
        )

        sync_mode = self.plugin.sync_manager.mode if self.plugin.sync_manager else "p2p"
        sync_text = {
            "p2p": "P2P (локальный)",
            "server": "Server (облачный)",
            "auto": "Auto (гибрид)",
        }.get(sync_mode, sync_mode)
        self._add_info_row(
            stats_container,
            "🔄 Синхронизация",
            sync_text,
            Theme.getColor(Theme.key_chat_messagePanelSend),
        )

        container.addView(stats_container)

    def _build_inactive_streak_ui(self, container):
        header_container = LinearLayout(self.context)
        header_container.setOrientation(LinearLayout.VERTICAL)
        header_container.setGravity(Gravity.CENTER)
        header_container.setPadding(
            AndroidUtilities.dp(24),
            AndroidUtilities.dp(32),
            AndroidUtilities.dp(24),
            AndroidUtilities.dp(24),
        )

        emoji_text = TextView(self.context)
        emoji_text.setText("🔥")
        emoji_text.setTextSize(1, 64)
        emoji_text.setGravity(Gravity.CENTER)
        header_container.addView(emoji_text)

        title = TextView(self.context)
        title.setText("Начать Streak?")
        title.setTextSize(1, 24)
        title.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
        title.setTypeface(None, Typeface.BOLD)
        title.setGravity(Gravity.CENTER)
        title_params = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.WRAP_CONTENT,
            LinearLayout.LayoutParams.WRAP_CONTENT,
        )
        title_params.setMargins(0, AndroidUtilities.dp(16), 0, 0)
        header_container.addView(title, title_params)

        description = TextView(self.context)
        description.setText(
            "Streak - это серия дней подряд общения.\nОбщайтесь каждый день чтобы поддерживать серию!"
        )
        description.setTextSize(1, 14)
        description.setTextColor(
            Theme.getColor(Theme.key_windowBackgroundWhiteGrayText)
        )
        description.setGravity(Gravity.CENTER)
        description_params = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.WRAP_CONTENT,
            LinearLayout.LayoutParams.WRAP_CONTENT,
        )
        description_params.setMargins(
            AndroidUtilities.dp(16), AndroidUtilities.dp(8), AndroidUtilities.dp(16), 0
        )
        header_container.addView(description, description_params)

        container.addView(header_container)

    def _add_info_row(self, container, label, value, accent_color=None):
        row = LinearLayout(self.context)
        row.setOrientation(LinearLayout.HORIZONTAL)
        row.setPadding(
            AndroidUtilities.dp(16),
            AndroidUtilities.dp(14),
            AndroidUtilities.dp(16),
            AndroidUtilities.dp(14),
        )

        if accent_color is None:
            accent_color = get_primary()

        bg = create_filled_bg(CORNER_MEDIUM, get_surface_variant())
        try:
            bg.setStroke(AndroidUtilities.dp(2), accent_color)
        except Exception:
            pass

        row.setBackground(bg)
        row.setElevation(AndroidUtilities.dp(2))

        label_tv = TextView(self.context)
        label_tv.setText(label)
        label_tv.setTextSize(1, 15)
        label_tv.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
        label_tv.setTypeface(None, Typeface.BOLD)
        label_params = LinearLayout.LayoutParams(
            0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0
        )
        row.addView(label_tv, label_params)

        value_tv = TextView(self.context)
        value_tv.setText(value)
        value_tv.setTextSize(1, 15)
        value_tv.setTextColor(accent_color)
        value_tv.setTypeface(None, Typeface.BOLD)
        value_tv.setGravity(Gravity.END)
        row.addView(value_tv)

        row_params = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT,
            LinearLayout.LayoutParams.WRAP_CONTENT,
        )
        row_params.setMargins(0, 0, 0, AndroidUtilities.dp(8))
        container.addView(row, row_params)

    def _create_buttons(self, is_active):
        container = LinearLayout(self.context)
        container.setOrientation(LinearLayout.VERTICAL)
        container.setBackgroundColor(get_surface())

        divider = View(self.context)
        divider.setBackgroundColor(Theme.getColor(Theme.key_divider))
        divider_params = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT, 1
        )
        container.addView(divider, divider_params)

        button_row = LinearLayout(self.context)
        button_row.setOrientation(LinearLayout.HORIZONTAL)
        button_row.setPadding(
            AndroidUtilities.dp(12),
            AndroidUtilities.dp(12),
            AndroidUtilities.dp(12),
            AndroidUtilities.dp(12),
        )

        button_params = LinearLayout.LayoutParams(
            0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0
        )
        button_params.setMargins(AndroidUtilities.dp(4), 0, AndroidUtilities.dp(4), 0)

        if is_active:
            sync_manager = self.plugin._get_sync_manager()
            if sync_manager.mode in [
                StreakSyncManager.MODE_SERVER,
                StreakSyncManager.MODE_AUTO,
            ]:
                sync_btn = self._create_button("Синхронизация", False)
                sync_btn.setOnClickListener(
                    OnClickListener(lambda *args: self._on_sync_click())
                )
                button_row.addView(sync_btn, button_params)

            stop_btn = self._create_button("Остановить", False)
            stop_btn.setOnClickListener(
                OnClickListener(lambda *args: self._on_stop_click())
            )
            button_row.addView(stop_btn, button_params)

            close_btn = self._create_button("Закрыть", False)
            close_btn.setOnClickListener(OnClickListener(lambda *args: self.dismiss()))
            button_row.addView(close_btn, button_params)
        else:
            cancel_btn = self._create_button("Отмена", False)
            cancel_btn.setOnClickListener(OnClickListener(lambda *args: self.dismiss()))
            button_row.addView(cancel_btn, button_params)

            start_btn = self._create_button("Начать Streak", True)
            start_btn.setOnClickListener(
                OnClickListener(lambda *args: self._on_start_click())
            )
            button_row.addView(start_btn, button_params)

        container.addView(button_row)
        return container

    def _create_button(self, text, is_primary):
        button = TextView(self.context)
        button.setText(text)
        button.setTextSize(1, 15)
        button.setGravity(Gravity.CENTER)
        button.setSingleLine(True)
        button.setPadding(
            AndroidUtilities.dp(12),
            AndroidUtilities.dp(16),
            AndroidUtilities.dp(12),
            AndroidUtilities.dp(16),
        )

        if is_primary:
            bg = create_ripple_bg(CORNER_SMALL, get_primary(), get_on_primary())
            button.setBackground(bg)
            button.setTextColor(get_on_primary())
            button.setTypeface(None, Typeface.BOLD)
            apply_elevation(button, ELEVATION_BUTTON)
        else:
            bg = create_outlined_bg(CORNER_SMALL, get_outline())
            button.setBackground(bg)
            button.setTextColor(get_on_surface())

        return button

    def _on_start_click(self):
        self.plugin._start_streak(self.chat_id)
        self.dismiss()

    def _on_stop_click(self):
        self.plugin._stop_streak(self.chat_id)
        self.dismiss()

    def _on_sync_click(self):
        plugin = self.plugin
        chat_id = self.chat_id
        self.dismiss()
        plugin._force_sync_now(chat_id)

    def show(self):
        self.bottom_sheet.show()

    def dismiss(self):
        try:
            self.bottom_sheet.dismiss()
        except Exception as e:
            self.log(f"WSP: error dismissing streak menu: {e}")
        finally:
            self.plugin = None
            self.context = None
            self.chat_id = None
            self.bottom_sheet = None


class WatamoteStreakPetPlugin(BasePlugin):
    def __init__(self):
        super().__init__()

        import threading

        self.data_lock = threading.RLock()
        self.sync_threads = []
        self.shutdown_event = threading.Event()
        self.pets = {}
        self.streaks = {}
        self.streak_enabled_chats = set()
        self.pet_enabled_chats = set()
        self.last_messages = {}
        self.header_hook = None
        self.cleanup_hook = None
        self.active_widgets = {}
        self.widget_manager = None
        self.sync_manager = None
        self.last_auto_sync = {}
        self.last_server_check = {}
        self.last_global_server_check = 0
        self.background_sync_thread = None
        self.sync_backoff_seconds = 1
        self.sync_backoff_max = SYNC_BACKOFF_MAX_SECONDS
        self.sync_consecutive_errors = 0
        self.last_xp_time = {}
        self.xp_history = {}
        self.recent_messages = {}
        self.widget_positions = {}

    def log(self, message):
        if self.get_setting("debug_mode", False):
            from android_utils import log as android_log

            android_log(f"[WatamoteStreakPet] {message}")

    def _is_private_chat(self, chat_id):
        try:
            chat_id_int = int(chat_id)
            return chat_id_int > 0
        except Exception:
            return False

    def _is_chat_allowed(self, chat_id):
        try:
            chat_id_int = int(chat_id)
            if chat_id_int <= 0:
                self.log(f"WSP: chat {chat_id} rejected - group/channel (chat_id <= 0)")
                return False

            my_user_id = self._get_my_user_id()

            if chat_id_int == my_user_id:
                self.log(
                    f"WSP: chat {chat_id} rejected - Saved Messages (chat with self)"
                )
                return False

            try:
                MessagesController = find_class(
                    "org.telegram.messenger.MessagesController"
                )
                if MessagesController:
                    controller = MessagesController.getInstance(0)
                    user = controller.getUser(chat_id_int)
                    if user:
                        is_bot = getattr(user, "bot", False)
                        if is_bot:
                            self.log(f"WSP: chat {chat_id} rejected - bot user")
                            return False
            except Exception as e:
                self.log(f"WSP: error checking if user is bot: {e}")
            return True
        except Exception as e:
            self.log(f"WSP: _is_chat_allowed exception for {chat_id}: {e}")
            return False

    def _get_my_user_id(self):
        try:
            UserConfig = find_class("org.telegram.messenger.UserConfig")
            if UserConfig:
                user_config = UserConfig.getInstance(0)
                return user_config.getClientUserId()
            else:
                self.log("WSP: UserConfig class not found")
        except Exception as e:
            self.log(f"WSP: failed to get my_user_id: {e}")
        return 0

    def _get_streak_key(self, chat_id):
        my_id = str(self._get_my_user_id())
        other_id = str(chat_id)

        user_ids = sorted([my_id, other_id])
        streak_key = f"{user_ids[0]}:{user_ids[1]}"
        return streak_key

    def _get_sorted_user_ids(self, chat_id):
        my_id = self._get_my_user_id()
        other_id = int(chat_id)

        ids = sorted([int(my_id), other_id])

        return ids[0], ids[1]

    def _get_streak(self, chat_id):
        if not self._is_private_chat(chat_id):
            return None

        streak_key = self._get_streak_key(chat_id)
        return self.streaks.get(streak_key)

    def _should_run_sync(self):
        if not self.get_setting("background_sync", True):
            return False

        sync_manager = self._get_sync_manager()
        if sync_manager.mode not in [
            StreakSyncManager.MODE_SERVER,
            StreakSyncManager.MODE_AUTO,
        ]:
            return False

        my_user_id = self._get_my_user_id()
        return my_user_id and my_user_id > 0

    def _get_sync_interval(self):
        sync_interval_index = self.get_setting("auto_sync_interval", 1)
        return (
            SYNC_INTERVAL_OPTIONS[sync_interval_index]
            if sync_interval_index < len(SYNC_INTERVAL_OPTIONS)
            else SYNC_INTERVAL_OPTIONS[SYNC_INTERVAL_DEFAULT_INDEX]
        )

    def _check_expired_streaks(self):
        with self.data_lock:
            for chat_id, streak in list(self.streaks.items()):
                if streak and not streak.deleted:
                    try:
                        if streak.check_and_reset_if_expired():
                            self.log(f"WSP: streak expired and reset for {chat_id}")
                            self._send_sync_message(chat_id, streak)
                    except Exception as e:
                        self.log(
                            f"WSP: error checking streak expiration for {chat_id}: {e}"
                        )

    def _collect_chats_for_sync(self):
        with self.data_lock:
            chats_with_streaks = list(self.streak_enabled_chats.copy())
            chats_with_pets = list(self.pet_enabled_chats.copy())
            chats_to_sync = list(set(chats_with_streaks + chats_with_pets))

        self.log(
            f"WSP: background sync starting for {len(chats_to_sync)} chats "
            f"(streaks: {len(chats_with_streaks)}, pets: {len(chats_with_pets)})"
        )

        return chats_with_streaks, chats_with_pets

    def _collect_sync_data(self, chats_with_streaks, chats_with_pets):
        streak_data_list = []
        pet_data_list = []

        with self.data_lock:
            for chat_id in chats_with_streaks:
                streak_key = self._get_streak_key(chat_id)
                streak = self.streaks.get(streak_key)
                if streak and not streak.deleted:
                    streak_data_list.append((chat_id, streak.get_sync_data()))

            for chat_id in chats_with_pets:
                pet = self.pets.get(chat_id)
                if pet and not pet.deleted:
                    pet_data_list.append((chat_id, pet.get_sync_data()))

        return streak_data_list, pet_data_list

    def _apply_sync_results(self, results):
        if not results:
            return

        with self.data_lock:
            for streak_result in results.get("streaks", []):
                server_data = streak_result.get("data")
                action = streak_result.get("action")

                if server_data and action != "kept_local":
                    chat_key = streak_result.get("chat_key")
                    if chat_key in self.streaks:
                        self.streaks[chat_key].apply_sync_data(server_data)
                        self.log(
                            f"WSP: batch-sync merged streak {chat_key}, action={action}"
                        )

            for pet_result in results.get("pets", []):
                server_data = pet_result.get("data")
                action = pet_result.get("action")

                if server_data and action != "kept_local":
                    chat_key = pet_result.get("chat_key")
                    for chat_id, pet in self.pets.items():
                        if self._get_streak_key(chat_id) == chat_key:
                            pet.apply_sync_data(server_data)
                            self.log(
                                f"WSP: batch-sync merged pet for {chat_id}, action={action}"
                            )
                            break

            self._save_data_unsafe()

    def _reset_sync_backoff(self):
        self.sync_consecutive_errors = 0
        self.sync_backoff_seconds = 1

    def _handle_sync_error(self, error):
        import traceback

        self.log(f"WSP: background sync loop error: {error}")
        self.log(f"WSP: bg-sync traceback: {traceback.format_exc()}")

        self.sync_consecutive_errors += 1
        self.sync_backoff_seconds = min(
            self.sync_backoff_seconds * 2, self.sync_backoff_max
        )
        self.log(
            f"WSP: backoff increased to {self.sync_backoff_seconds}s "
            f"(errors: {self.sync_consecutive_errors})"
        )

    def _background_sync_loop(self):
        self.log("WSP: background sync thread started")

        while not self.shutdown_event.is_set():
            try:
                if not self._should_run_sync():
                    self.shutdown_event.wait(SYNC_DEFAULT_WAIT_SECONDS)
                    continue

                sync_interval = self._get_sync_interval()
                if sync_interval >= SYNC_INTERVAL_DISABLED:
                    self.shutdown_event.wait(SYNC_DEFAULT_WAIT_SECONDS)
                    continue

                self._check_expired_streaks()
                chats_with_streaks, chats_with_pets = self._collect_chats_for_sync()
                streak_data_list, pet_data_list = self._collect_sync_data(
                    chats_with_streaks, chats_with_pets
                )

                if not streak_data_list and not pet_data_list:
                    self.log("WSP: no data to sync, skipping")
                else:
                    sync_manager = self._get_sync_manager()
                    my_user_id = self._get_my_user_id()
                    results = sync_manager.batch_sync(
                        my_user_id, streak_data_list, pet_data_list
                    )
                    self._apply_sync_results(results)

                self.log("WSP: background sync cycle completed")
                self._reset_sync_backoff()
                self.shutdown_event.wait(sync_interval)

            except Exception as e:
                self._handle_sync_error(e)
                self.shutdown_event.wait(self.sync_backoff_seconds)

        self.log("WSP: background sync thread stopped")

    def _setup_hooks(self):
        self.add_on_send_message_hook()
        self.log("WSP: send hook added")

        self.add_hook("UpdateNewMessage", match_substring=True)
        self.log("WSP: update hook added")

    def _load_saved_data(self):
        self._load_data()
        self.log(f"WSP: loaded {len(self.pets)} pets")

    def _initialize_sync_manager(self):
        sync_mode_index = self.get_setting("streak_sync_mode", 2)
        mode_map = {0: "p2p", 1: "server", 2: "auto"}
        sync_mode = mode_map.get(sync_mode_index, "auto")

        custom_url = self.get_setting("custom_server_url", "")
        server_url = custom_url if custom_url else None

        self.sync_manager = StreakSyncManager(
            mode=sync_mode, server_url=server_url, enable_fallback=True
        )
        self.log(
            f"WSP: sync_manager initialized in {sync_mode} mode, server={server_url or 'default'}"
        )

    def _start_background_sync(self):
        if self.get_setting("background_sync", True):
            import threading

            self.background_sync_thread = threading.Thread(
                target=self._background_sync_loop, daemon=False
            )
            self.background_sync_thread.start()
            self.log("WSP: background sync thread started")

    def _initialize_widget_manager(self):
        self.widget_manager = WidgetManager(self)
        self.log("WSP: widget manager initialized")

    def _setup_chat_activity_hooks(self):
        import traceback

        try:
            self.log("WSP: trying to hook ChatActivity.onResume")
            ChatActivity = find_class("org.telegram.ui.ChatActivity")
            self.log(f"WSP: ChatActivity class = {ChatActivity}")
            if ChatActivity:
                method_onresume = ChatActivity.getClass().getDeclaredMethod("onResume")
                self.log(f"WSP: got onResume method = {method_onresume}")
                method_onresume.setAccessible(True)
                hook_instance = ChatActivityHook(self)
                self.log(f"WSP: created hook instance = {hook_instance}")
                self.header_hook = self.hook_method(method_onresume, hook_instance)
                self.log(f"WSP: hook_method returned = {self.header_hook}")
                self.log("WSP: header hook OK!")
            else:
                self.log("WSP: ChatActivity class is None!")
        except Exception as e:
            self.log(f"WSP: header hook fail {e}")
            self.log(f"WSP: hook traceback: {traceback.format_exc()}")

        try:
            self.log("WSP: trying to hook ChatActivity.onPause")
            ChatActivity = find_class("org.telegram.ui.ChatActivity")
            if ChatActivity:
                method_onpause = ChatActivity.getClass().getDeclaredMethod("onPause")
                self.log(f"WSP: got onPause method = {method_onpause}")
                method_onpause.setAccessible(True)
                cleanup_hook_instance = WidgetCleanupHook(self)
                self.log(
                    f"WSP: created cleanup hook instance = {cleanup_hook_instance}"
                )
                self.cleanup_hook = self.hook_method(
                    method_onpause, cleanup_hook_instance
                )
                self.log(f"WSP: cleanup hook_method returned = {self.cleanup_hook}")
                self.log("WSP: cleanup hook OK!")
            else:
                self.log("WSP: ChatActivity class is None!")
        except Exception as e:
            self.log(f"WSP: cleanup hook fail {e}")
            self.log(f"WSP: cleanup hook traceback: {traceback.format_exc()}")

    def _register_menu_items(self):
        self.add_menu_item(
            MenuItemData(
                menu_type=MenuItemType.CHAT_ACTION_MENU,
                item_id="telepet_stats",
                text="Питомец",
                icon="msg_fave",
                on_click=self.show_pet_stats,
            )
        )

        self.add_menu_item(
            MenuItemData(
                menu_type=MenuItemType.CHAT_ACTION_MENU,
                item_id="telepet_streak",
                text="Streak",
                icon="msg_fire",
                on_click=self._show_streak_menu,
            )
        )

    def on_plugin_load(self):
        self.log("WSP: starting load")
        self.log(f"WSP: _SETTINGS_AVAILABLE = {_SETTINGS_AVAILABLE}")

        self._setup_hooks()
        self._load_saved_data()
        self._initialize_sync_manager()
        self._start_background_sync()
        self._initialize_widget_manager()
        self._setup_chat_activity_hooks()
        self._register_menu_items()

        self.log("WSP: plugin loaded!")

    def on_plugin_unload(self):
        self.log("WSP: starting graceful shutdown...")

        self.shutdown_event.set()

        if self.background_sync_thread and self.background_sync_thread.is_alive():
            self.log("WSP: waiting for background sync thread...")
            self.background_sync_thread.join(timeout=10.0)
            if self.background_sync_thread.is_alive():
                self.log("WSP: background sync thread did not finish in time")

        self.log(f"WSP: waiting for {len(self.sync_threads)} sync threads to finish...")
        for thread in list(self.sync_threads):
            if thread.is_alive():
                thread.join(timeout=5.0)
                if thread.is_alive():
                    self.log(f"WSP: thread {thread.name} did not finish in time")
        self.sync_threads.clear()

        with self.data_lock:
            for widget in list(self.active_widgets.values()):
                try:
                    if hasattr(widget, "cleanup"):
                        widget.cleanup()
                except Exception as e:
                    self.log(f"WSP: error cleaning up widget: {e}")
            self.active_widgets.clear()

        if self.header_hook:
            self.unhook_method(self.header_hook)
        if self.cleanup_hook:
            self.unhook_method(self.cleanup_hook)

        with self.data_lock:
            for pet in list(self.pets.values()):
                try:
                    if hasattr(pet, "cleanup"):
                        pet.cleanup()
                except Exception as e:
                    self.log(f"WSP: error cleaning up pet: {e}")

        sync_manager = self._get_sync_manager()
        if sync_manager and hasattr(sync_manager, "cache"):
            sync_manager.cache.clear()

        self.last_auto_sync.clear()
        self.last_messages.clear()

        self._save_data()
        self.log("WSP: plugin unloaded successfully")

    def create_settings(self):
        self.log(
            f"WSP: create_settings called, _SETTINGS_AVAILABLE={_SETTINGS_AVAILABLE}"
        )

        if not _SETTINGS_AVAILABLE:
            self.log("WSP: settings UI not available, returning empty list")
            return []

        try:
            self.log("WSP: building settings list...")
            settings_list = [
                Header(text="Внешний вид"),
                Switch(
                    key="show_widget",
                    text="Плавающий питомец",
                    default=DEFAULTS["show_widget"],
