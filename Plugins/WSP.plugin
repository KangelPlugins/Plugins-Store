                Selector(
                    key="pet_emoji_style",
                    text="Стиль питомца",
                    default=0,
                    items=[
                        "🦅 Птица (яйцо → птенец → цыпа → петух → орёл)",
                        "👾 Монстр (яйцо → слизень → гоблин → демон → дракон)",
                        "🌱 Растение (росток → побег → клевер → дерево → сакура)",
                        "⭐ Космос (звезда → искра → блеск → комета → галактика)",
