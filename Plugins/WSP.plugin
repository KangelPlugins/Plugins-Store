    def on_send_message_hook(self, account, params):
        try:
            chat_id = str(params.peer)
            message = params.message

            self.log(f"WSP: msg from chat {chat_id}")

            if not isinstance(message, str):
                return HookResult()

            streak = None
            updated = False
            if self._is_chat_allowed(chat_id):
                if chat_id in self.streak_enabled_chats:
                    streak = self._get_or_create_streak(chat_id)
                    if streak:
                        updated = streak.update_streak()
                        if updated:
                            self.log(f"WSP: streak updated for {chat_id}, sending sync")
                            self._send_sync_message(chat_id, streak)
                        else:
                            self.log(
                                f"WSP: streak not updated (same day or earlier) for {chat_id}"
                            )
                else:
                    self.log(
                        f"WSP: streak NOT enabled for chat {chat_id}. Use menu to enable."
                    )

            if self._is_chat_allowed(chat_id) and chat_id in self.pet_enabled_chats:
                pet = self._get_or_create_pet(chat_id)

                streak_count = streak.count if streak else 0
                self.log(f"WSP: pet {pet.get_emoji()} streak {streak_count}")

                xp_for_msg = self._calculate_xp(chat_id, message)

                evolution = pet.add_xp(xp_for_msg)

                if evolution:
                    show_notification = self.get_setting("show_notifications", True)
                    if show_notification:
                        run_on_ui_thread(lambda: self._show_evolution(pet))
                    else:
                        run_on_ui_thread(
                            lambda: BulletinHelper.show_success(
                                f"🎉 {pet.get_emoji()} Эволюция!"
                            )
                        )

                if streak and updated:
                    bonus_xp = 0
                    bonus_msg = ""
                    if streak.count % 30 == 0 and streak.count > 0:
                        bonus_xp = XP_REWARDS["streak_30_days"]
                        bonus_msg = f"{streak.get_flame_emoji()} {streak.count} дней! +{bonus_xp} XP! 🎊"
                    elif streak.count % 14 == 0 and streak.count > 0:
                        bonus_xp = XP_REWARDS["streak_14_days"]
                        bonus_msg = f"{streak.get_flame_emoji()} {streak.count} дней! +{bonus_xp} XP! 🎉"
                    elif streak.count % 7 == 0 and streak.count > 0:
                        bonus_xp = XP_REWARDS["streak_7_days"]
                        bonus_msg = f"{streak.get_flame_emoji()} {streak.count} дней! +{bonus_xp} XP бонус!"
                    elif streak.count % 3 == 0 and streak.count > 0:
                        bonus_xp = XP_REWARDS["streak_3_days"]
                        bonus_msg = f"{streak.get_flame_emoji()} {streak.count} дней! +{bonus_xp} XP! 🔥"

                    if bonus_xp > 0:
                        pet.add_xp(bonus_xp)
                        run_on_ui_thread(
                            lambda msg=bonus_msg: BulletinHelper.show_success(msg)
                        )

                self.last_messages[chat_id] = time.time()
                self._save_data()

                self._send_pet_sync(chat_id, pet)

                if (
                    self.get_setting("show_widget", True)
                    and chat_id in self.active_widgets
                ):
                    run_on_ui_thread(
                        lambda: self._create_flame_particle(chat_id, xp_for_msg)
                    )
            else:
                self.log(
                    f"WSP: pet NOT enabled for chat {chat_id}. Use menu to enable."
                )
                self._save_data()

        except Exception as err:
            self.log(f"WSP send hook error: {err}")

        return HookResult()

    def on_update_hook(self, update_name, account, update):
        try:
            if "UpdateNewMessage" not in update_name:
                return HookResult()

            message = getattr(update, "message", None)
            if not message:
                return HookResult()

            message_text = getattr(message, "message", None)
            if not message_text or not isinstance(message_text, str):
                return HookResult()

            peer = getattr(message, "peerId", None) or getattr(message, "peer_id", None)
            if not peer:
                return HookResult()

            from_id = getattr(peer, "userId", None) or getattr(peer, "user_id", None)
            if not from_id:
                return HookResult()

            chat_id = str(from_id)

            if not self._is_private_chat(chat_id):
                return HookResult()

            sync_data = StreakSyncManager.parse_sync_message(message_text)
            if not sync_data:
                self._check_server_for_new_data(chat_id)
                return HookResult()

            sync_manager = self._get_sync_manager()
            if sync_manager.mode == StreakSyncManager.MODE_SERVER:
                self.log(f"WSP: ignoring P2P message in SERVER mode for chat {chat_id}")
                self._delete_message(message)
                return HookResult(strategy=HookStrategy.CANCEL)

            if "streak" in sync_data:
                is_deleted = sync_data["streak"].get("deleted", False)

                if is_deleted:
                    self.log(
                        f"WSP: P2P sync received deleted=True for streak {chat_id}, resetting streak"
                    )
                    with self.data_lock:
                        self.streak_enabled_chats.discard(chat_id)
                        streak_key = self._get_streak_key(chat_id)
                        if streak_key in self.streaks:
                            self.streaks[streak_key].count = 0
                            self.streaks[streak_key].last_date = None
                            self.streaks[streak_key].first_date = None
                            self.streaks[streak_key].deleted = True
                            self.streaks[streak_key].last_sync_timestamp = time.time()
                    self.log(f"WSP: streak deactivated from P2P sync for {chat_id}")
                else:
                    if chat_id not in self.streak_enabled_chats:
                        self.log(
                            f"WSP: auto-enabling streak for chat {chat_id} from P2P sync"
                        )
                        with self.data_lock:
                            self.streak_enabled_chats.add(chat_id)

                    with self.data_lock:
                        streak_key = self._get_streak_key(chat_id)
                        streak = self.streaks.get(streak_key)
                        if not streak:
                            streak = self._get_or_create_streak(chat_id)

                        if streak:
                            local_data = streak.get_sync_data()
                            if StreakSyncManager.should_accept_sync(
                                local_data, sync_data["streak"]
                            ):
                                streak.apply_sync_data(sync_data["streak"])
                                self.log(
                                    f"WSP: P2P streak synced for chat {chat_id}, count={sync_data['streak'].get('count', 0)}"
                                )

            if "pet" in sync_data:
                is_deleted = sync_data["pet"].get("deleted", False)

                if is_deleted:
                    self.log(f"WSP: P2P sync received deleted=True for pet {chat_id}")
                    with self.data_lock:
                        self.pet_enabled_chats.discard(chat_id)
                        if chat_id in self.pets:
                            self.pets[chat_id].deleted = True
                            self.pets[chat_id].last_sync_timestamp = time.time()
                    self.log(f"WSP: pet deactivated from P2P sync for {chat_id}")
                else:
                    if chat_id not in self.pet_enabled_chats:
                        self.log(
                            f"WSP: auto-enabling pet for chat {chat_id} from P2P sync"
                        )
                        with self.data_lock:
                            self.pet_enabled_chats.add(chat_id)

                    with self.data_lock:
                        pet = self.pets.get(chat_id)
                        if not pet:
                            pet = self._get_or_create_pet(chat_id)

                        if pet:
                            local_pet_data = pet.get_sync_data()
                            if StreakSyncManager.should_accept_sync(
                                local_pet_data, sync_data["pet"]
                            ):
                                pet.apply_sync_data(sync_data["pet"])
                                self.log(
                                    f"WSP: P2P pet synced for chat {chat_id}, xp={sync_data['pet'].get('xp', 0)}, stage={sync_data['pet'].get('stage', 0)}, name={sync_data['pet'].get('name', 'unknown')}"
                                )

            if "streak" in sync_data or "pet" in sync_data:
                self._save_data()

            self._delete_message(message)

            return HookResult(strategy=HookStrategy.CANCEL)

        except Exception as e:
            self.log(f"WSP update hook error: {e}")

        return HookResult()

    def _has_repeated_chars(self, text, threshold=None):
        if threshold is None:
            threshold = SPAM_REPEATED_CHARS_THRESHOLD

        if len(text) < 10:
            return False

        from collections import Counter

        char_counts = Counter(text.replace(" ", ""))
        if not char_counts:
            return False

        most_common_char, count = char_counts.most_common(1)[0]
        ratio = count / len(text.replace(" ", ""))

        return ratio > threshold

    def _calculate_similarity(self, text1, text2):
        words1 = set(text1.lower().split())
        words2 = set(text2.lower().split())

        if not words1 or not words2:
            return 0.0

        intersection = len(words1 & words2)
        union = len(words1 | words2)

        return intersection / union if union > 0 else 0.0

    def _is_spam_message(self, chat_id, message):
        recent = self.recent_messages.get(chat_id, [])

        if len(recent) >= SPAM_IDENTICAL_THRESHOLD:
            last_messages = recent[-SPAM_IDENTICAL_THRESHOLD:]
            if len(set(last_messages)) == 1:
                return True

        if len(recent) >= 2:
            similarity = self._calculate_similarity(message, recent[-1])
            if similarity > SPAM_SIMILARITY_THRESHOLD:
                self.log(
                    f"WSP: similar messages detected for {chat_id} (similarity: {similarity:.2f})"
                )
                return True

        return False

    def _calculate_xp(self, chat_id, message):
        current_time = time.time()

        last_xp = self.last_xp_time.get(chat_id, 0)
        if current_time - last_xp < XP_COOLDOWN_SECONDS:
            self.log(
                f"WSP: XP cooldown active for {chat_id} ({current_time - last_xp:.1f}s < {XP_COOLDOWN_SECONDS}s)"
            )
            return 0

        hour_ago = current_time - SECONDS_PER_HOUR
        if chat_id not in self.xp_history:
            self.xp_history[chat_id] = []
        self.xp_history[chat_id] = [t for t in self.xp_history[chat_id] if t > hour_ago]
        if len(self.xp_history[chat_id]) >= XP_MAX_PER_HOUR // XP_REWARDS["msg"]:
            self.log(
                f"WSP: XP rate limit reached for {chat_id} ({len(self.xp_history[chat_id])} msgs in last hour)"
            )
            return 0

        if len(message.strip()) < SPAM_MIN_MESSAGE_LENGTH:
            self.log(
                f"WSP: message too short for {chat_id} (len={len(message.strip())})"
            )
            return 0

        if self._has_repeated_chars(message):
            self.log(f"WSP: repeated chars spam detected for {chat_id}")
            return 0

        if chat_id not in self.recent_messages:
            self.recent_messages[chat_id] = []
        self.recent_messages[chat_id].append(message)
        self.recent_messages[chat_id] = self.recent_messages[chat_id][
            -SPAM_CHECK_WINDOW_MESSAGES:
        ]

        if self._is_spam_message(chat_id, message):
            self.log(f"WSP: spam detected for {chat_id}")
            return 0

        xp = XP_REWARDS["msg"]
        last_message_date = self.last_messages.get(chat_id)
        today_msk = get_msk_date()
        now_msk = get_msk_now()

        try:
            if (
                last_message_date is None
                or datetime.fromtimestamp(last_message_date, MSK_TZ).date() < today_msk
            ):
                xp += XP_REWARDS["first_of_day"]
        except (ValueError, OSError):
            xp += XP_REWARDS["first_of_day"]

        current_hour_msk = now_msk.hour
        if NIGHT_HOURS_START <= current_hour_msk < NIGHT_HOURS_END:
            xp += XP_REWARDS["night"]

        current_weekday_msk = now_msk.weekday()
        if current_weekday_msk >= 5:
            xp += XP_REWARDS["weekend"]

        self.last_xp_time[chat_id] = current_time
        self.xp_history[chat_id].append(current_time)

        return xp

    def _get_or_create_pet(self, chat_id):
        with self.data_lock:
            if chat_id not in self.pets:
                self.pets[chat_id] = Pet(chat_id, plugin_ref=self)
                self.log(
                    f"WSP: created NEW pet for chat {chat_id}, total pets: {len(self.pets)}"
                )
            else:
                pet = self.pets[chat_id]
                if not hasattr(pet, "plugin_ref") or pet.plugin_ref is None:
                    pet.plugin_ref = self
                self.log(
                    f"WSP: using EXISTING pet for chat {chat_id}, stage={pet.stage}, xp={pet.xp}"
                )
            return self.pets[chat_id]

    def _get_or_create_streak(self, chat_id):
        if not self._is_private_chat(chat_id):
            return None

        with self.data_lock:
            if chat_id not in self.streak_enabled_chats:
                return None

            streak_key = self._get_streak_key(chat_id)

            if streak_key not in self.streaks:
                self.streaks[streak_key] = Streak(chat_id)
            return self.streaks[streak_key]

    def _get_sync_manager(self):
        current_time = time.time()
        if not hasattr(self, "_sync_manager_cache_time"):
            self._sync_manager_cache_time = 0

        if current_time - self._sync_manager_cache_time > 5:
            sync_mode_index = self.get_setting("streak_sync_mode", 2)
            mode_map = {0: "p2p", 1: "server", 2: "auto"}
            sync_mode = mode_map.get(sync_mode_index, "auto")

            custom_url = self.get_setting("custom_server_url", "")
            server_url = custom_url if custom_url else StreakSyncManager.SERVER_URL

            self.sync_manager.mode = sync_mode
            self.sync_manager.server_url = server_url
            self._sync_manager_cache_time = current_time

        return self.sync_manager

    def _send_sync_message(self, chat_id, streak):
        try:
            sync_manager = self._get_sync_manager()
            mode = sync_manager.mode
            use_p2p_fallback = False
            server_success = False

            if mode in [StreakSyncManager.MODE_SERVER, StreakSyncManager.MODE_AUTO]:
                my_user_id = self._get_my_user_id()

                if my_user_id and my_user_id > 0:
                    try:
                        with self.data_lock:
                            streak_sync_data = streak.get_sync_data()
                            pet_sync_data = None
                            if chat_id in self.pets:
                                pet_sync_data = self.pets[chat_id].get_sync_data()

                        server_success = sync_manager.save_streak_to_server(
                            my_user_id, chat_id, streak_sync_data
                        )

                        if pet_sync_data:
                            user1_id, user2_id = self._get_sorted_user_ids(chat_id)
                            pet_success = sync_manager.save_pet_to_server(
                                user1_id, user2_id, pet_sync_data
                            )
                            server_success = server_success and pet_success

                        if (
                            not server_success
                            and mode == StreakSyncManager.MODE_AUTO
                            and sync_manager.enable_fallback
                        ):
                            use_p2p_fallback = True
                    except Exception as e:
                        self.log(f"WSP: server sync error: {e}")
                        if (
                            mode == StreakSyncManager.MODE_AUTO
                            and sync_manager.enable_fallback
                        ):
                            use_p2p_fallback = True
                else:
                    if (
                        mode == StreakSyncManager.MODE_AUTO
                        and sync_manager.enable_fallback
                    ):
                        use_p2p_fallback = True

            if mode == StreakSyncManager.MODE_P2P or use_p2p_fallback:
                with self.data_lock:
                    streak_sync_data = streak.get_sync_data()
                    pet_sync_data = None
                    if chat_id in self.pets:
                        pet_sync_data = self.pets[chat_id].get_sync_data()

                sync_message = StreakSyncManager.create_sync_message(
                    streak_data=streak_sync_data, pet_data=pet_sync_data
                )
                send_text(int(chat_id), sync_message, silent=True)

        except Exception as e:
            import traceback

            self.log(f"WSP: sync send error: {e}")
            self.log(f"WSP: sync send traceback: {traceback.format_exc()}")

    def _send_pet_sync(self, chat_id, pet):
        try:
            sync_manager = self._get_sync_manager()
            mode = sync_manager.mode
            use_p2p_fallback = False
            server_success = False

            if mode in [StreakSyncManager.MODE_SERVER, StreakSyncManager.MODE_AUTO]:
                my_user_id = self._get_my_user_id()
                self.log(f"WSP pet sync: got my_user_id={my_user_id}")

                if my_user_id and my_user_id > 0:
                    try:
                        self.log(
                            f"WSP: attempting pet sync to server for chat {chat_id}"
                        )
                        user1_id, user2_id = self._get_sorted_user_ids(chat_id)

                        with self.data_lock:
                            pet_sync_data = pet.get_sync_data()

                        server_success = sync_manager.save_pet_to_server(
                            user1_id, user2_id, pet_sync_data
                        )

                        if server_success:
                            self.log(
                                f"WSP: pet saved to server for {chat_id}, xp={pet.xp}, stage={pet.stage}"
                            )
                        else:
                            self.log(f"WSP: failed to save pet to server for {chat_id}")
                            if (
                                mode == StreakSyncManager.MODE_AUTO
                                and sync_manager.enable_fallback
                            ):
                                use_p2p_fallback = True
                                self.log(
                                    f"WSP: falling back to P2P sync for pet due to server failure"
                                )
                    except Exception as e:
                        self.log(f"WSP: pet save error: {e}")
                        if (
                            mode == StreakSyncManager.MODE_AUTO
                            and sync_manager.enable_fallback
                        ):
                            use_p2p_fallback = True
                            self.log(
                                f"WSP: falling back to P2P sync for pet due to exception: {e}"
                            )
                else:
                    self.log(
                        f"WSP: my_user_id is invalid ({my_user_id}), cannot sync pet"
                    )
                    if (
                        mode == StreakSyncManager.MODE_AUTO
                        and sync_manager.enable_fallback
                    ):
                        use_p2p_fallback = True
                        self.log(
                            f"WSP: falling back to P2P sync for pet due to invalid user_id"
                        )

            if mode == StreakSyncManager.MODE_P2P or use_p2p_fallback:
                with self.data_lock:
                    pet_sync_data = pet.get_sync_data()

                sync_message = StreakSyncManager.create_sync_message(
                    pet_data=pet_sync_data
                )
                send_text(int(chat_id), sync_message, silent=True)
                self.log(f"WSP: pet sync message sent via P2P to {chat_id}")

        except Exception as e:
            import traceback

            self.log(f"WSP: pet sync error: {e}")
            self.log(f"WSP: pet sync traceback: {traceback.format_exc()}")

    def _delete_message(self, message):
        try:
            MessagesController = find_class("org.telegram.messenger.MessagesController")
            if not MessagesController:
                self.log(f"WSP: MessagesController not found, cannot delete message")
                return

            message_id = getattr(message, "id", None)
            if not message_id:
                self.log(f"WSP: message has no id, cannot delete")
                return

            peer = getattr(message, "peerId", None) or getattr(message, "peer_id", None)
            if not peer:
                self.log(f"WSP: message has no peer, cannot delete")
                return

            dialog_id = (
                getattr(peer, "userId", None)
                or getattr(peer, "user_id", None)
                or getattr(peer, "channelId", None)
                or getattr(peer, "channel_id", None)
                or getattr(peer, "chatId", None)
                or getattr(peer, "chat_id", None)
            )
            if not dialog_id:
                self.log(f"WSP: cannot determine dialog_id, cannot delete")
                return

            if not self._is_private_chat(str(dialog_id)):
                self.log(f"WSP: not a private chat, skipping message deletion")
                return

            controller = MessagesController.getInstance(0)
            if controller:
                from java.util import ArrayList

                ids = ArrayList()
                ids.add(int(message_id))

                run_on_ui_thread(
                    lambda: controller.deleteMessages(
                        ids, None, None, int(dialog_id), True, False
                    )
                )
                self.log(
                    f"WSP: P2P sync message deleted (id={message_id}, dialog={dialog_id})"
                )
            else:
                self.log(f"WSP: MessagesController instance not available")
        except Exception as e:
            self.log(f"WSP: delete message error (non-critical): {e}")

    def show_pet_stats(self, data):
        self.log(f"WSP: show_pet_stats called with {data}")
        chat_id = data.get("chat_id")
        if not chat_id:
            chat_id = data.get("dialog_id")
        chat_id = str(chat_id) if chat_id else ""

        if not chat_id:
            BulletinHelper.show_error("Не удалось определить чат!")
            return

        if not self._is_chat_allowed(chat_id):
            BulletinHelper.show_error("Питомцы недоступны в этом чате!")
            return

        with self.data_lock:
            streak_key = self._get_streak_key(chat_id)
            streak = self.streaks.get(streak_key)
            if streak and not streak.deleted:
                try:
                    if streak.check_and_reset_if_expired():
                        self.log(f"WSP: streak expired when opening menu for {chat_id}")
                        BulletinHelper.show_error(
                            "Стрик сброшен! Прошло более 24 часов без сообщений."
                        )
                        self._send_sync_message(chat_id, streak)
                except Exception as e:
                    self.log(f"WSP: error checking streak expiration: {e}")

        sync_manager = self._get_sync_manager()
        if sync_manager:
            my_user_id = self._get_my_user_id()

            pet_cache_key = "pet_" + sync_manager.get_cache_key(my_user_id, chat_id)
            if pet_cache_key in sync_manager.cache:
                sync_manager.cache.pop(pet_cache_key)
                self.log(f"WSP: cleared pet cache for {chat_id}")

            streak_cache_key = sync_manager.get_cache_key(my_user_id, chat_id)
            if streak_cache_key in sync_manager.cache:
                sync_manager.cache.pop(streak_cache_key)
                self.log(f"WSP: cleared streak cache for {chat_id}")

        self._sync_from_server_if_needed(chat_id)

        context = get_last_fragment()
        if not context:
            return

        activity = context.getParentActivity()
        if not activity:
            return

        try:
            sheet = PetStatsBottomSheet(activity, self, chat_id)
            sheet.show()
        except Exception as e:
            self.log(f"WSP: show_pet_stats error: {e}")
            import traceback

            self.log(f"WSP: traceback: {traceback.format_exc()}")

    def feed_pet(self, data):
        self.log(f"WSP: feed_pet called with {data}")
        chat_id = data.get("chat_id")
        if not chat_id:
            chat_id = data.get("dialog_id")
        chat_id = str(chat_id) if chat_id else ""

        if not self._is_chat_allowed(chat_id):
            BulletinHelper.show_error("Питомцы недоступны в этом чате!")
            return

        with self.data_lock:
            if chat_id not in self.pet_enabled_chats:
                BulletinHelper.show_info("Питомец не активен в этом чате!")
                return

            if not chat_id or chat_id not in self.pets:
                BulletinHelper.show_info("Сначала заведи питомца!")
                return

            pet = self.pets[chat_id]

            current_time = time.time()
            time_diff = current_time - pet.last_feed_time

            if time_diff < FEED_COOLDOWN_SECONDS:
                remaining_minutes = int(
                    (FEED_COOLDOWN_SECONDS - time_diff) / SECONDS_PER_MINUTE
                )
                BulletinHelper.show_info(
                    f"Питомец сыт! Приходи через {remaining_minutes} мин"
                )
                return

            xp_reward = pet.feed()
            evolved = pet.add_xp(xp_reward)
            emoji = pet.get_emoji()

        if evolved:
            BulletinHelper.show_success(
                f"🍖 Покормил! {emoji} ЭВОЛЮЦИЯ! +{xp_reward} XP"
            )
        else:
            hunger_emoji = "🍖" if pet.hunger >= 80 else "🥗"
            BulletinHelper.show_success(
                f"{hunger_emoji} Покормил! {emoji} +{xp_reward} XP | Голод: {int(pet.hunger)}%"
            )

        self._save_data()
        self._send_pet_sync(chat_id, pet)

    def play_with_pet(self, data):
        self.log(f"WSP: poigrat called with {data}")
        chat_id = data.get("chat_id")
        if not chat_id:
            chat_id = data.get("dialog_id")
        chat_id = str(chat_id) if chat_id else ""

        if not self._is_chat_allowed(chat_id):
            BulletinHelper.show_error("Питомцы недоступны в этом чате!")
            return

        with self.data_lock:
            if chat_id not in self.pet_enabled_chats:
                BulletinHelper.show_info("Питомец не активен в этом чате!")
                return

            if not chat_id or chat_id not in self.pets:
                BulletinHelper.show_info("Сначала заведи питомца!")
                return

            pet = self.pets[chat_id]

            if pet.hunger < HUNGER_CONFIG["critical_level"]:
                BulletinHelper.show_error(
                    f"💀 Питомец слишком голодный! Покорми его сначала (голод: {int(pet.hunger)}%)"
                )
                return

            xp_reward = pet.play()

            if xp_reward > 0:
                evolved = pet.add_xp(xp_reward)
                emoji = pet.get_emoji()

                if evolved:
                    BulletinHelper.show_success(
                        f"🎮 Поиграл! {emoji} ЭВОЛЮЦИЯ! +{xp_reward} XP"
                    )
                else:
                    mood_emoji = "😊" if pet.mood >= MOOD_HIGH_THRESHOLD else "🙂"
                    BulletinHelper.show_success(
                        f"{mood_emoji} Поиграл! {emoji} +{xp_reward} XP | Настроение: {int(pet.mood)}%"
                    )

                self._save_data()
                self._send_pet_sync(chat_id, pet)
            else:
                BulletinHelper.show_error("Питомец не хочет играть!")

    def _start_streak(self, chat_id):
        if not self._is_chat_allowed(chat_id):
            BulletinHelper.show_error("Streak недоступен в этом чате!")
            return

        if chat_id in self.streak_enabled_chats:
            BulletinHelper.show_info("Streak уже активен в этом чате!")
            return

        sync_manager = self._get_sync_manager()

        if sync_manager.mode in [
            StreakSyncManager.MODE_SERVER,
            StreakSyncManager.MODE_AUTO,
        ]:
            my_user_id = self._get_my_user_id()

            if my_user_id and my_user_id > 0:
                try:
                    server_data = sync_manager.get_streak_from_server(
                        my_user_id, chat_id
                    )

                    if (
                        server_data
                        and not server_data.get("deleted", False)
                        and server_data.get("count", 0) > 0
                    ):
                        self.log(
                            f"WSP: found existing streak on server for {chat_id}, loading..."
                        )

                        with self.data_lock:
                            self.streak_enabled_chats.add(chat_id)

                        streak = self._get_or_create_streak(chat_id)
                        if streak:
                            streak.apply_sync_data(server_data)
                            self._save_data()

                            BulletinHelper.show_success(
                                f"🔥 Streak загружен с сервера: {server_data.get('count', 0)} дней!"
                            )
                            self.log(
                                f"WSP: streak loaded from server for {chat_id}, count={server_data.get('count')}"
                            )
                        return

                except Exception as e:
                    self.log(f"WSP: failed to check server for streak: {e}")

        self.log(f"WSP: creating new streak for {chat_id}")

        with self.data_lock:
            self.streak_enabled_chats.add(chat_id)

        streak = self._get_or_create_streak(chat_id)
        self._save_data()
        self.log(f"WSP: streak created and enabled for chat {chat_id}")

        BulletinHelper.show_success(
            f"🔥 Streak активирован! Пиши каждый день чтобы продолжать серию"
        )

        if streak:
            self._send_sync_message(chat_id, streak)
            self.log(f"WSP: new streak synced to server for {chat_id}")

    def _stop_streak(self, chat_id):
        if chat_id not in self.streak_enabled_chats:
            BulletinHelper.show_info("Streak не активен в этом чате")
            return

        streak_key = self._get_streak_key(chat_id)
        streak = self.streaks.get(streak_key)

        with self.data_lock:
            self.streak_enabled_chats.discard(chat_id)
            if streak:
                streak.count = 0
                streak.last_date = None
                streak.first_date = None
                streak.deleted = True
                streak.last_sync_timestamp = time.time()
        self._save_data()

        if streak:
            self._send_sync_message(chat_id, streak)

        BulletinHelper.show_success("Streak остановлен и сброшен")

    def _start_pet(self, chat_id):
        if not self._is_chat_allowed(chat_id):
            BulletinHelper.show_error("Питомцы недоступны в этом чате!")
            return

        if chat_id in self.pet_enabled_chats:
            BulletinHelper.show_info("Питомец уже активен в этом чате!")
            return

        sync_manager = self._get_sync_manager()

        if sync_manager.mode in [
            StreakSyncManager.MODE_SERVER,
            StreakSyncManager.MODE_AUTO,
        ]:
            my_user_id = self._get_my_user_id()

            if my_user_id and my_user_id > 0:
                try:
                    user1_id, user2_id = self._get_sorted_user_ids(chat_id)
                    server_data = sync_manager.get_pet_from_server(user1_id, user2_id)

                    if server_data and not server_data.get("deleted", False):
                        self.log(
                            f"WSP: found existing pet on server for {chat_id}, loading..."
                        )

                        with self.data_lock:
                            self.pet_enabled_chats.add(chat_id)

                        pet = self._get_or_create_pet(chat_id)
                        pet.apply_sync_data(server_data)
                        self._save_data()

                        stage_emoji = [
                            "🥚",
                            "🐣",
                            "🐥",
                            "🦆",
                            "🦅",
                            "🦉",
                            "🦚",
                            "🐉",
                            "🌟",
                            "👑",
                        ][server_data.get("stage", 1) - 1]
                        BulletinHelper.show_success(
                            f"🐾 Питомец загружен с сервера: {stage_emoji} ур.{server_data.get('stage')} (XP: {server_data.get('xp')})"
                        )
                        self.log(
                            f"WSP: pet loaded from server for {chat_id}, xp={server_data.get('xp')}, stage={server_data.get('stage')}"
                        )
                        return

                except Exception as e:
                    self.log(f"WSP: failed to check server for pet: {e}")

        self.log(f"WSP: creating new pet for {chat_id}")

        with self.data_lock:
            self.pet_enabled_chats.add(chat_id)
            if chat_id in self.pets:
                old_pet = self.pets[chat_id]
                if hasattr(old_pet, "cleanup"):
                    try:
                        old_pet.cleanup()
                    except Exception:
                        pass
                del self.pets[chat_id]

        pet = self._get_or_create_pet(chat_id)
        self._save_data()
        self.log(f"WSP: pet created and enabled for chat {chat_id}")

        BulletinHelper.show_success(
            f"🐾 Питомец заведен! Отправь сообщение чтобы он начал расти"
        )

        self._send_pet_sync(chat_id, pet)
        self.log(f"WSP: new pet synced to server for {chat_id}")

    def _stop_pet(self, chat_id):
        if chat_id not in self.pet_enabled_chats:
            BulletinHelper.show_info("Питомец не активен в этом чате")
            return

        with self.data_lock:
            self.pet_enabled_chats.discard(chat_id)
            if chat_id in self.pets:
                old_pet = self.pets[chat_id]
                if hasattr(old_pet, "cleanup"):
                    try:
                        old_pet.cleanup()
                    except Exception:
                        pass
                del self.pets[chat_id]
        self._save_data()

        BulletinHelper.show_success("Питомец остановлен")

    def _rename_pet(self, chat_id, new_name):
        with self.data_lock:
            pet = self.pets.get(chat_id)
            if not pet:
                BulletinHelper.show_error("Питомец не найден")
                return

            old_name = pet.name
            pet.name = new_name
            pet.last_sync_timestamp = time.time()

        self._save_data()

        BulletinHelper.show_success(f"Питомец переименован: {old_name} → {new_name}")

        self._send_pet_sync(chat_id, pet)

    def _kick_pet(self, chat_id):
        with self.data_lock:
            pet = self.pets.get(chat_id)
            self.pet_enabled_chats.discard(chat_id)
            if pet:
                pet.deleted = True
                pet.last_sync_timestamp = time.time()
        self._save_data()

        if pet:
            self._send_pet_sync(chat_id, pet)

        BulletinHelper.show_success("Питомец выгнан")

    def _check_server_status(self, view=None):
        import threading
        import time

        from client_utils import get_last_fragment
        from ui.alert import AlertDialogBuilder

        def check_in_thread():
            try:
                sync_manager = self._get_sync_manager()
                server_url = sync_manager.server_url
                mode_names = {
                    StreakSyncManager.MODE_P2P: "P2P (локальный)",
                    StreakSyncManager.MODE_SERVER: "Server (облачный)",
                    StreakSyncManager.MODE_AUTO: "Auto (гибрид)",
                }
                current_mode = mode_names.get(sync_manager.mode, str(sync_manager.mode))
                start_time = time.time()
                is_healthy = sync_manager.check_server_health()
                response_time = int((time.time() - start_time) * 1000)
                total_streaks = "N/A"
                total_pets = "N/A"
                try:
                    stats_url = f"{server_url}/api/v1/stats"
                    stats_result, stats_error = sync_manager._make_http_request(
                        stats_url, method="GET", retries=1
                    )
                    if stats_result:
                        total_streaks = stats_result.get("total_streaks", "N/A")
                        total_pets = stats_result.get("total_pets", "N/A")
                except:
                    pass

                def show_result():
                    try:
                        fragment = get_last_fragment()
                        if not fragment:
                            BulletinHelper.show_error("Не удалось открыть диалог")
                            return

                        activity = fragment.getParentActivity()
                        if not activity:
                            BulletinHelper.show_error("Не удалось открыть диалог")
                            return

                        builder = AlertDialogBuilder(activity)

                        if is_healthy:
                            builder.set_title("Сервер работает")
                            message = (
                                f"Подключение к серверу успешно!\n\n"
                                f"Режим: {current_mode}\n"
                                f"URL: {server_url}\n"
                                f"Отклик: {response_time}ms\n\n"
                                f"Статистика сервера:\n"
                                f"Всего стриков: {total_streaks}\n"
                                f"Всего питомцев: {total_pets}\n\n"
                                f"Кэш: {len(sync_manager.cache)} записей"
                            )
                        else:
                            builder.set_title("Сервер недоступен")
                            message = (
                                f"Не удалось подключиться к серверу!\n\n"
                                f"Режим: {current_mode}\n"
                                f"URL: {server_url}\n"
                                f"Отклик: {response_time}ms\n\n"
                                f"Проверьте интернет соединение или измените сервер в настройках."
                            )

                        builder.set_message(message)
                        builder.set_positive_button("OK", lambda b, w: b.dismiss())
                        builder.show()
                    except Exception as e:
                        self.log(f"WSP: error showing server status: {e}")
                        BulletinHelper.show_error("Ошибка при отображении результата")

                run_on_ui_thread(show_result)

            except Exception as e:
                self.log(f"WSP: error checking server: {e}")
                run_on_ui_thread(
                    lambda: BulletinHelper.show_error(f"Ошибка проверки: {e}")
                )

        BulletinHelper.show_info("Проверка сервера...")
        thread = threading.Thread(target=check_in_thread, daemon=True)
        thread.start()

    def _show_reset_confirmation(self):
        from client_utils import get_last_fragment
        from ui.alert import AlertDialogBuilder

        try:
            fragment = get_last_fragment()
            if not fragment:
                BulletinHelper.show_error("Не удалось открыть диалог")
                return

            activity = fragment.getParentActivity()
            if not activity:
                BulletinHelper.show_error("Не удалось открыть диалог")
                return

            builder = AlertDialogBuilder(activity)
            builder.set_title("Сброс всех данных")
            builder.set_message(
                "Вы уверены, что хотите удалить ВСЕ данные?\n\n"
                "• Все питомцы будут удалены\n"
                "• Все стрики будут сброшены\n"
                "• Данные удалятся локально и на сервере\n\n"
                "Это действие НЕЛЬЗЯ отменить!"
            )
            builder.set_positive_button("Удалить", lambda b, w: self._execute_reset(b))
            builder.set_negative_button("Отмена", lambda b, w: b.dismiss())
            builder.show()
        except Exception as e:
            self.log(f"WSP: error showing reset confirmation: {e}")
            BulletinHelper.show_error("Ошибка при открытии диалога")

    def _execute_reset(self, builder):
        try:
            builder.dismiss()
        except Exception as e:
            self.log(f"WSP: builder dismiss error: {e}")

        self._reset_all_data_internal()

    def _reset_all_data(self, view=None):
        self._show_reset_confirmation()

    def _reset_all_data_internal(self):
        try:
            self.log("WSP: _reset_all_data_internal called!")
            BulletinHelper.show_info("Начинается сброс данных...")

            sync_manager = self._get_sync_manager()
            my_user_id = self._get_my_user_id()

            with self.data_lock:
                pet_count = len(self.pets)
                streak_count = len(self.streaks)

                if sync_manager.mode in [
                    StreakSyncManager.MODE_SERVER,
                    StreakSyncManager.MODE_AUTO,
                ]:
                    if my_user_id and my_user_id > 0:
                        for chat_id, pet in self.pets.items():
                            try:
                                pet.deleted = True
                                pet.last_sync_timestamp = time.time()
                                self._send_pet_sync(chat_id, pet)
                            except Exception as e:
                                self.log(
                                    f"WSP: failed to delete pet {chat_id} on server: {e}"
                                )

                        for chat_id, streak in self.streaks.items():
                            try:
                                streak.count = 0
                                streak.last_date = None
                                streak.first_date = None
                                streak.deleted = True
                                streak.last_sync_timestamp = time.time()
                                self._send_sync_message(chat_id, streak)
                            except Exception as e:
                                self.log(
                                    f"WSP: failed to delete streak {chat_id} on server: {e}"
                                )

                        self.log(
                            "WSP: sent delete sync to server for all pets and streaks"
                        )

                for pet in self.pets.values():
                    if hasattr(pet, "cleanup"):
                        try:
                            pet.cleanup()
                        except Exception:
                            pass
                self.pets.clear()
                self.streaks.clear()
                self.last_messages.clear()
                self.streak_enabled_chats.clear()
                self.pet_enabled_chats.clear()

            self._save_data()

            self.log(
                f"WSP: reset completed - removed {pet_count} pets, {streak_count} streaks"
            )
            BulletinHelper.show_success(
                f"✅ Все данные удалены: {pet_count} питомцев, {streak_count} стриков"
            )

        except Exception as e:
            self.log(f"WSP: error resetting data: {e}")
            BulletinHelper.show_error(f"Ошибка сброса данных: {e}")

    def _show_streak_menu(self, data):
        try:
            self.log(f"WSP: _show_streak_menu called with data={data}")
            chat_id = data.get("chat_id")
            if not chat_id:
                chat_id = data.get("dialog_id")
            chat_id = str(chat_id) if chat_id else ""
            self.log(f"WSP: chat_id={chat_id}")

            if not self._is_private_chat(chat_id):
                self.log("WSP: not a private chat")
                BulletinHelper.show_error("Streak работает только в личных чатах!")
                return

            context = get_last_fragment()
            self.log(f"WSP: context={context}")
            if not context:
                self.log("WSP: context is None!")
                return

            activity = context.getParentActivity()
            self.log(f"WSP: activity={activity}")
            if not activity:
                self.log("WSP: activity is None!")
                return

            self.log("WSP: creating StreakMenuBottomSheet")
            sheet = StreakMenuBottomSheet(activity, self, chat_id)
            self.log("WSP: showing sheet")
            sheet.show()
            self.log("WSP: sheet shown")
        except Exception as e:
            self.log(f"WSP: _show_streak_menu ERROR: {e}")
            import traceback

            self.log(f"WSP: traceback: {traceback.format_exc()}")

    def _show_streak_info(self, chat_id):
        self._show_streak_menu({"chat_id": chat_id})

    def _show_evolution(self, pet):
        try:
            context = get_last_fragment()
            if not context:
                emoji = pet.get_emoji()
                stage_name = pet.get_stage_name()
                BulletinHelper.show_success(
                    f"🎉 {emoji} ЭВОЛЮЦИЯ! {pet.name} стал {stage_name} (ур. {pet.stage})"
                )
                return

            activity = context.getParentActivity()
            if not activity:
                emoji = pet.get_emoji()
                stage_name = pet.get_stage_name()
                BulletinHelper.show_success(
                    f"🎉 {emoji} ЭВОЛЮЦИЯ! {pet.name} стал {stage_name} (ур. {pet.stage})"
                )
                return

            sheet = EvolutionBottomSheet(activity, pet)
            sheet.show()
        except Exception as e:
            self.log(f"WSP: _show_evolution error: {e}")
            emoji = pet.get_emoji()
            stage_name = pet.get_stage_name()
            BulletinHelper.show_success(
                f"🎉 {emoji} ЭВОЛЮЦИЯ! {pet.name} стал {stage_name} (ур. {pet.stage})"
            )

    def _sync_from_server_if_needed(self, chat_id, skip_throttling=True):
        self._check_server_for_new_data(chat_id, skip_throttling=skip_throttling)

    def _check_server_for_new_data(self, chat_id, skip_throttling=False):
        import time

        try:
            if not skip_throttling:
                now = time.time()

                if now - self.last_global_server_check < 2:
                    return

                last_check = self.last_server_check.get(chat_id, 0)
                if now - last_check < SYNC_SERVER_CHECK_COOLDOWN:
                    return

                self.last_server_check[chat_id] = now
                self.last_global_server_check = now

            sync_manager = self._get_sync_manager()

            if sync_manager.mode not in [
                StreakSyncManager.MODE_SERVER,
                StreakSyncManager.MODE_AUTO,
            ]:
                return

            my_user_id = self._get_my_user_id()
            if not my_user_id or my_user_id <= 0:
                return

            try:
                user1_id, user2_id = self._get_sorted_user_ids(chat_id)
                server_pet = sync_manager.get_pet_from_server(user1_id, user2_id)

                if server_pet and not server_pet.get("deleted", False):
                    if chat_id not in self.pet_enabled_chats:
                        self.log(
                            f"WSP: found pet on server for inactive chat {chat_id}, auto-enabling"
                        )
                        with self.data_lock:
                            self.pet_enabled_chats.add(chat_id)
                            pet = self._get_or_create_pet(chat_id)
                            pet.apply_sync_data(server_pet)
                            self._save_data_unsafe()
                            self.log(
                                f"WSP: pet auto-enabled from server for {chat_id}, xp={server_pet.get('xp')}, stage={server_pet.get('stage')}, name={server_pet.get('name', 'unknown')}"
                            )
                    else:
                        with self.data_lock:
                            pet = self.pets.get(chat_id)
                            if not pet:
                                pet = self._get_or_create_pet(chat_id)

                            local_data = pet.get_sync_data()
                            if StreakSyncManager.should_accept_sync(
                                local_data, server_pet
                            ):
                                pet.apply_sync_data(server_pet)
                                self._save_data_unsafe()
                                self.log(
                                    f"WSP: synced pet from server for {chat_id}, xp={server_pet.get('xp')}, stage={server_pet.get('stage')}, name={server_pet.get('name', 'unknown')}"
                                )
                elif server_pet and server_pet.get("deleted", False):
                    self.log(
                        f"WSP: server pet has deleted=True for chat {chat_id}, deactivating"
                    )
                    with self.data_lock:
                        self.pet_enabled_chats.discard(chat_id)
                        if chat_id in self.pets:
                            self.pets[chat_id].deleted = True
                            self.pets[chat_id].last_sync_timestamp = time.time()
                            self._save_data_unsafe()
            except Exception as e:
                self.log(f"WSP: error checking pet on server: {e}")

            try:
                server_streak = sync_manager.get_streak_from_server(my_user_id, chat_id)

                if (
                    server_streak
                    and server_streak.get("count", 0) > 0
                    and not server_streak.get("deleted", False)
                ):
                    if chat_id not in self.streak_enabled_chats:
                        self.log(
                            f"WSP: found streak on server for inactive chat {chat_id}, auto-enabling"
                        )
                        with self.data_lock:
                            self.streak_enabled_chats.add(chat_id)

                    with self.data_lock:
                        streak_key = self._get_streak_key(chat_id)
                        streak = self.streaks.get(streak_key)
                        if not streak:
                            streak = self._get_or_create_streak(chat_id)

                        if streak:
                            local_data = streak.get_sync_data()
                            if StreakSyncManager.should_accept_sync(
                                local_data, server_streak
                            ):
                                streak.apply_sync_data(server_streak)
                                self._save_data_unsafe()
                                self.log(
                                    f"WSP: synced streak from server for {chat_id}, count={server_streak.get('count')}"
                                )
                elif server_streak and server_streak.get("deleted", False):
                    self.log(
                        f"WSP: server streak has deleted=True for chat {chat_id}, resetting streak to 0"
                    )
                    with self.data_lock:
                        self.streak_enabled_chats.discard(chat_id)
                        streak_key = self._get_streak_key(chat_id)
                        if streak_key in self.streaks:
                            streak = self.streaks[streak_key]
                            streak.count = 0
                            streak.last_date = None
                            streak.first_date = None
                            streak.deleted = True
                            streak.last_sync_timestamp = time.time()
                            self._save_data_unsafe()
            except Exception as e:
                self.log(f"WSP: error checking streak on server: {e}")
        except Exception as e:
            self.log(f"WSP: _check_server_for_new_data error: {e}")

    def _check_sync_status(self, chat_id):
        try:
            sync_manager = self._get_sync_manager()
            my_user_id = self._get_my_user_id()

            lines = []
            lines.append("🔍 Статус синхронизации:")
            lines.append("")

            mode_names = {
                "p2p": "P2P (локальный)",
                "server": "Server (облачный)",
                "auto": "Auto (гибрид)",
            }
            mode_name = mode_names.get(sync_manager.mode, sync_manager.mode)
            lines.append(f"📡 Режим: {mode_name}")

            if my_user_id and my_user_id > 0:
                lines.append(f"✅ User ID: {my_user_id}")
            else:
                lines.append(f"❌ User ID: не получен ({my_user_id})")
                BulletinHelper.show_error("\n".join(lines))
                return

            if sync_manager.mode in [
                StreakSyncManager.MODE_SERVER,
                StreakSyncManager.MODE_AUTO,
            ]:
                lines.append("")
                lines.append(f"🌐 Сервер: {sync_manager.server_url}")

                is_healthy = sync_manager.check_server_health()
                if is_healthy:
                    lines.append("✅ Сервер доступен")
                else:
                    lines.append("❌ Сервер недоступен!")

                lines.append("")
                server_streak = sync_manager.get_streak_from_server(my_user_id, chat_id)
                if server_streak:
                    count = server_streak.get("count", 0)
                    lines.append(f"🔥 Стрик на сервере: {count} дней")
                else:
                    lines.append("🔥 Стрик на сервере: не найден")

                user1_id, user2_id = self._get_sorted_user_ids(chat_id)
                server_pet = sync_manager.get_pet_from_server(user1_id, user2_id)
                if server_pet:
                    xp = server_pet.get("xp", 0)
                    stage = server_pet.get("stage", 1)
                    lines.append(f"🐾 Питомец на сервере: stage {stage}, XP {xp}")
                else:
                    lines.append("🐾 Питомец на сервере: не найден")

            lines.append("")
            lines.append("💾 Локально:")

            if chat_id in self.streak_enabled_chats:
                streak = self.streaks.get(chat_id)
                if streak:
                    lines.append(f"🔥 Стрик: {streak.count} дней")
                else:
                    lines.append("🔥 Стрик: включен, но данные не найдены")
            else:
                lines.append("🔥 Стрик: не включен")

            if chat_id in self.pets:
                pet = self.pets[chat_id]
                lines.append(f"🐾 Питомец: stage {pet.stage}, XP {pet.xp}")
            else:
                lines.append("🐾 Питомец: не создан")

            BulletinHelper.show_info("\n".join(lines))

        except Exception as e:
            self.log(f"WSP: _check_sync_status error: {e}")
            import traceback

            self.log(f"WSP: check_sync_status traceback: {traceback.format_exc()}")
            BulletinHelper.show_error(f"Ошибка проверки: {e}")

    def _force_sync_now(self, chat_id):
        try:
            sync_manager = self._get_sync_manager()

            if sync_manager.mode == StreakSyncManager.MODE_P2P:
                BulletinHelper.show_info(
                    "P2P режим не поддерживает принудительную синхронизацию"
                )
                return

            my_user_id = self._get_my_user_id()
            if not my_user_id or my_user_id <= 0:
                BulletinHelper.show_error(f"Не удалось получить User ID: {my_user_id}")
                return

            if not sync_manager.check_server_health():
                BulletinHelper.show_error("Сервер недоступен!")
                return

            BulletinHelper.show_info("⏳ Синхронизация...")

            def do_sync():
                try:
                    synced_items = []

                    server_streak = sync_manager.get_streak_from_server(
                        my_user_id, chat_id
                    )
                    if server_streak and server_streak.get("count", 0) > 0:
                        with self.data_lock:
                            if chat_id not in self.streak_enabled_chats:
                                self.streak_enabled_chats.add(chat_id)

                        streak = self._get_or_create_streak(chat_id)
                        if streak:
                            local_data = streak.get_sync_data()
                            if StreakSyncManager.should_accept_sync(
                                local_data, server_streak
                            ):
                                streak.apply_sync_data(server_streak)
                                synced_items.append(
                                    f"🔥 Стрик: {server_streak.get('count')} дней"
                                )
                            else:
                                success = sync_manager.save_streak_to_server(
                                    my_user_id, chat_id, local_data
                                )
                                if success:
                                    synced_items.append(
                                        f"🔥 Стрик отправлен на сервер: {local_data.get('count')} дней"
                                    )
                    else:
                        if chat_id in self.streak_enabled_chats:
                            streak = self.streaks.get(chat_id)
                            if streak:
                                success = sync_manager.save_streak_to_server(
                                    my_user_id, chat_id, streak.get_sync_data()
                                )
                                if success:
                                    synced_items.append(
                                        f"🔥 Стрик отправлен: {streak.count} дней"
                                    )

                    user1_id, user2_id = self._get_sorted_user_ids(chat_id)
                    server_pet = sync_manager.get_pet_from_server(user1_id, user2_id)
                    pet = self._get_or_create_pet(chat_id)

                    if server_pet:
                        local_pet_data = pet.get_sync_data()
                        if StreakSyncManager.should_accept_sync(
                            local_pet_data, server_pet
                        ):
                            pet.apply_sync_data(server_pet)
                            synced_items.append(
                                f"🐾 Питомец загружен: stage {server_pet.get('stage')}, XP {server_pet.get('xp')}"
                            )
                        else:
                            success = sync_manager.save_pet_to_server(
                                user1_id, user2_id, local_pet_data
                            )
                            if success:
                                synced_items.append(
                                    f"🐾 Питомец отправлен: stage {local_pet_data.get('stage')}, XP {local_pet_data.get('xp')}"
                                )
                    else:
                        success = sync_manager.save_pet_to_server(
                            user1_id, user2_id, pet.get_sync_data()
                        )
                        if success:
                            synced_items.append(
                                f"🐾 Питомец отправлен: stage {pet.stage}, XP {pet.xp}"
                            )

                    self._save_data()

                    if synced_items:
                        run_on_ui_thread(
                            lambda: BulletinHelper.show_success(
                                "✅ Синхронизация завершена!\n"
                                + "\n".join(synced_items)
                            )
                        )
                    else:
                        run_on_ui_thread(
                            lambda: BulletinHelper.show_info(
                                "ℹ️ Нет данных для синхронизации"
                            )
                        )

                except Exception as e:
                    self.log(f"WSP: force_sync error: {e}")
                    import traceback

                    self.log(f"WSP: force_sync traceback: {traceback.format_exc()}")
                    error_msg = str(e)
                    run_on_ui_thread(
                        lambda: BulletinHelper.show_error(
                            f"Ошибка синхронизации: {error_msg}"
                        )
                    )

            import threading

            self._cleanup_finished_threads()
            thread = threading.Thread(target=do_sync)
            thread.daemon = False
            self.sync_threads.append(thread)
            thread.start()

        except Exception as e:
            self.log(f"WSP: _force_sync_now error: {e}")
            import traceback

            self.log(f"WSP: force_sync_now traceback: {traceback.format_exc()}")
            BulletinHelper.show_error(f"Ошибка: {e}")

    def _check_server_health(self):
        try:
            sync_manager = self._get_sync_manager()

            BulletinHelper.show_info("Проверка сервера...")

            def do_check():
                try:
                    import threading

                    start_time = time.time()
                    mode_names = {
                        StreakSyncManager.MODE_P2P: "P2P (локальный)",
                        StreakSyncManager.MODE_SERVER: "Server (облачный)",
                        StreakSyncManager.MODE_AUTO: "Auto (гибрид)",
                    }
                    current_mode = mode_names.get(sync_manager.mode, sync_manager.mode)
                    server_url = sync_manager.server_url
                    is_healthy = sync_manager.check_server_health()
                    response_time = time.time() - start_time

                    try:
                        stats_url = f"{server_url}/api/v1/stats"
                        stats_result, stats_error = sync_manager._make_http_request(
                            stats_url, method="GET", retries=1
                        )

                        if stats_result:
                            total_streaks = stats_result.get("total_streaks", "N/A")
                            total_pets = stats_result.get("total_pets", "N/A")
                            has_stats = True
                        else:
                            total_streaks = "N/A"
                            total_pets = "N/A"
                            has_stats = False
                    except:
                        total_streaks = "N/A"
                        total_pets = "N/A"
                        has_stats = False

                    if is_healthy:
                        status_text = "Онлайн"
                    else:
                        status_text = "Недоступен"

                    message = f"""Статус сервера: {status_text}

Режим: {current_mode}
URL: {server_url}
Отклик: {int(response_time * 1000)}ms

Кэш: {len(sync_manager.cache)} записей
Последняя проверка: сейчас"""

                    run_on_ui_thread(
                        lambda: BulletinHelper.show_success(message)
                        if is_healthy
                        else BulletinHelper.show_error(message)
                    )

                except Exception as e:
                    self.log(f"WSP: server health check error: {e}")
                    import traceback

                    self.log(f"WSP: health check traceback: {traceback.format_exc()}")
                    run_on_ui_thread(
                        lambda: BulletinHelper.show_error(
                            f"Ошибка проверки сервера:\n{str(e)}"
                        )
                    )

            thread = threading.Thread(target=do_check)
            thread.daemon = False
            thread.start()

        except Exception as e:
            self.log(f"WSP: _check_server_health error: {e}")
            import traceback

            self.log(f"WSP: check_server_health traceback: {traceback.format_exc()}")
            BulletinHelper.show_error(f"Ошибка: {e}")

    def _save_data_unsafe(self):
        pets_data = {cid: pet.to_dict() for cid, pet in self.pets.items()}
        streaks_data = {cid: ser.to_dict() for cid, ser in self.streaks.items()}

        errors = []

        try:
            self.set_setting("pets", pets_data)
        except Exception as e:
            import traceback

            errors.append(f"pets: {e}")
            self.log(f"WSP: ERROR saving pets: {e}")
            self.log(f"WSP: save pets traceback: {traceback.format_exc()}")

        try:
            self.set_setting("streaks", streaks_data)
        except Exception as e:
            import traceback

            errors.append(f"streaks: {e}")
            self.log(f"WSP: ERROR saving streaks: {e}")
            self.log(f"WSP: save streaks traceback: {traceback.format_exc()}")

        try:
            self.set_setting("last_msgs", self.last_messages)
        except Exception as e:
            errors.append(f"last_msgs: {e}")
            self.log(f"WSP: ERROR saving last_msgs: {e}")

        try:
            self.set_setting("streak_enabled", list(self.streak_enabled_chats))
        except Exception as e:
            errors.append(f"streak_enabled: {e}")
            self.log(f"WSP: ERROR saving streak_enabled: {e}")

        try:
            self.set_setting("pet_enabled", list(self.pet_enabled_chats))
        except Exception as e:
            errors.append(f"pet_enabled: {e}")
            self.log(f"WSP: ERROR saving pet_enabled: {e}")

        positions_to_remove = []
        for chat_id in self.widget_positions.keys():
            if chat_id not in self.pets and chat_id not in self.streaks:
                positions_to_remove.append(chat_id)

        for chat_id in positions_to_remove:
            del self.widget_positions[chat_id]
            self.log(f"WSP: removed widget position for inactive chat {chat_id}")

        try:
            self.set_setting("widget_positions", self.widget_positions)
        except Exception as e:
            errors.append(f"widget_positions: {e}")
            self.log(f"WSP: ERROR saving widget_positions: {e}")

        if errors:
            self.log(f"WSP: data save FAILED with {len(errors)} errors: {errors}")
            return False
        else:
            return True

    def _save_data(self):
        with self.data_lock:
            self._save_data_unsafe()

    def _cleanup_finished_threads(self):
        if not hasattr(self, "sync_threads"):
            return

        alive_threads = [t for t in self.sync_threads if t.is_alive()]
        removed_count = len(self.sync_threads) - len(alive_threads)

        if removed_count > 0:
            self.log(
                f"WSP: cleaned up {removed_count} finished threads, {len(alive_threads)} still running"
            )

        self.sync_threads = alive_threads

    def _create_flame_particle(self, chat_id, xp_amount):
        try:
            with self.data_lock:
                if chat_id not in self.active_widgets:
                    return
                widget = self.active_widgets[chat_id]

            widget_view = widget.get_view()

            parent = widget_view.getParent()
            if not parent:
                return

            widget_x = widget_view.getX() + widget_view.getWidth() / 2
            widget_y = widget_view.getY() + widget_view.getHeight() / 2

            start_x = AndroidUtilities.dp(20)
            start_y = parent.getHeight() - AndroidUtilities.dp(100)

            flame = FlyingXPParticle(
                widget_view.getContext(),
                start_x,
                start_y,
                widget_x,
                widget_y,
                xp_amount,
                lambda: self._remove_flame_particle(parent, flame),
            )

            flame_view = flame.get_view()
            parent.addView(flame_view)

            pulse = ObjectAnimator.ofFloat(widget.container, "scaleX", 1.0, 1.3, 1.0)
            pulse.setDuration(300)
            pulse.setStartDelay(800)
            pulse.start()
            pulse2 = ObjectAnimator.ofFloat(widget.container, "scaleY", 1.0, 1.3, 1.0)
            pulse2.setDuration(300)
            pulse2.setStartDelay(800)
            pulse2.start()

            widget._update_visual()

        except Exception as e:
            self.log(f"WSP flame error: {e}")

    def _remove_flame_particle(self, parent, flame):
        try:
            if hasattr(flame, "cleanup"):
                flame.cleanup()
            parent.removeView(flame.get_view())
        except Exception:
            pass

    def _load_data(self):
        self.log("WSP: loading data from settings...")
        pets_data = self.get_setting("pets", {})
        streaks_data = self.get_setting("streaks", {})
        self.last_messages = self.get_setting("last_msgs", {})
        streak_enabled_list = self.get_setting("streak_enabled", [])
        self.streak_enabled_chats = set(streak_enabled_list)
        pet_enabled_list = self.get_setting("pet_enabled", [])
        self.pet_enabled_chats = set(pet_enabled_list)

        self.log(
            f"WSP: loaded {len(pets_data)} pets, {len(streaks_data)} streaks from settings"
        )
        self.log(f"WSP: streak_enabled_chats: {self.streak_enabled_chats}")
        self.log(f"WSP: pet_enabled_chats: {self.pet_enabled_chats}")

        for chat_id, data in pets_data.items():
            try:
                if data.get("deleted", False):
                    self.log(f"WSP: skipping deleted pet for chat {chat_id}")
                    continue

                self.pets[chat_id] = Pet.from_dict(data, plugin_ref=self)
                self.log(
                    f"WSP: loaded pet for chat {chat_id}: xp={data.get('xp', 0)}, stage={data.get('stage', 0)}"
                )
            except Exception as e:
                self.log(f"WSP: ERROR loading pet for chat {chat_id}: {e}")

        for chat_id, data in streaks_data.items():
            try:
                if data.get("deleted", False):
                    self.log(f"WSP: skipping deleted streak for chat {chat_id}")
                    continue

                self.streaks[chat_id] = Streak.from_dict(data)
                self.log(
                    f"WSP: loaded streak for chat {chat_id}: count={data.get('count', 0)}"
                )
            except Exception as e:
                self.log(f"WSP: ERROR loading streak for chat {chat_id}: {e}")

        self.widget_positions = self.get_setting("widget_positions", {})
        self.log(f"WSP: loaded {len(self.widget_positions)} widget positions")

        self.log(
            f"WSP: data loading completed. Total pets: {len(self.pets)}, total streaks: {len(self.streaks)}"
        )
