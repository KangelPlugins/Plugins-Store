class GetDialogsArrayHook(MethodHook):
    def __init__(self, plugin):
        super().__init__()
        self.plugin = plugin
    def get_list_fingerprint(self, original_list):
        size = original_list.size()
        if size == 0:
            return (0,)
        sample_size = min(10, size)
        fingerprint = [size]
        for i in range(sample_size):
            dialog = original_list.get(i)
            fingerprint.append(dialog.id)
            fingerprint.append(dialog.last_message_date)
        return tuple(fingerprint)

    def after_hooked_method(self, param):
        try:
            original_list = param.getResult()
            if not original_list or original_list.size() <= 0:
                return

            if not self.plugin.loader or not self.plugin.loader.lib:
                return

            args = param.args
            currentAccount = args[0]
            dialogsType = args[1]
            folderId = args[2]
            frozen = args[3] if len(args) > 3 else False

            # If the dialogs list is currently frozen for animation/transition, do not modify it
            if frozen:
                return

            # Check rate limit before spawning thread to avoid UI thread lag from excessive thread creation
            now = time.time()
            last_sync = self.plugin.last_sync_time.get(currentAccount, 0)
            if now - last_sync >= 10.0:
                self.plugin.last_sync_time[currentAccount] = now
                threading.Thread(target=lambda: self.plugin.sync_folders_db(currentAccount)).start()

            # Cache messagesController instances to avoid lookup overhead in hot path
            messagesController = self.plugin.messages_controllers.get(currentAccount)
            if messagesController is None:
                messagesController = find_class("org.telegram.messenger.MessagesController").getInstance(currentAccount)
                self.plugin.messages_controllers[currentAccount] = messagesController

            if dialogsType in (7, 8):
                filter_idx = 0 if dialogsType == 7 else 1
                dialogFilter = messagesController.selectedDialogFilter[filter_idx]
                if dialogFilter:
                    current_folder_id = dialogFilter.id
                else:
                    current_folder_id = 0
            else:
                current_folder_id = folderId

            target_folder_id = current_folder_id

            config = self.plugin.get_folder_config(currentAccount, target_folder_id)

            # Prevent infinite loadDialogs loops when all filters are disabled
            if config["filter_mask"] == 0:
                self.plugin.update_dialog_flags(currentAccount, target_folder_id, True)

            is_default = (config["sort_type"] == "time_desc" and 
                          config["filter_mask"] == 15 and 
                          config["only_unmuted"] == 0 and 
                          config["exclude_other_folders"] == 0)

            if is_default:
                return

            # --- AUTO-LOAD ALL DIALOGS FROM CACHE ---
            # If the folder has custom sorting/filtering, load all dialogs from local cache in the background
            if not messagesController.isDialogsEndReached(target_folder_id) and not messagesController.isLoadingDialogs(target_folder_id):
                offset = original_list.size()
                messagesController.loadDialogs(target_folder_id, offset, 200, True)

            cache_key = (currentAccount, target_folder_id)
            cached_result = self.plugin.sorted_list_cache.get(cache_key)

            list_fingerprint = self.get_list_fingerprint(original_list)
            config_fingerprint = (
                config["sort_type"],
                config["filter_mask"],
                config["only_unmuted"],
                config["exclude_other_folders"]
            )
            current_fingerprint = (list_fingerprint, config_fingerprint)

            # Check if we have a valid cache matching the current fingerprint
            if cached_result is not None:
                cached_list, cache_time, cached_fingerprint = cached_result
                if current_fingerprint == cached_fingerprint:
                    self.plugin.log(f"[SmartFolder] Cache hit for folder {target_folder_id} (size: {cached_list.size()})")
                    param.setResult(cached_list)
                    return
                else:
                    # Stale cache: return immediately to prevent screen freeze, sort in background
                    self.plugin.log(f"[SmartFolder] Stale cache for folder {target_folder_id}, returning cached copy temporarily and scheduling background sort")
                    param.setResult(cached_list)
            else:
                # No cache: return original list immediately, sort in background
                self.plugin.log(f"[SmartFolder] No cache for folder {target_folder_id}, returning original list and scheduling background sort")
                param.setResult(original_list)

            # Spawn background sort if not already running for this folder
            if cache_key not in self.plugin.pending_sorts:
                self.plugin.pending_sorts.add(cache_key)
                
                # Clone original list on UI thread to prevent concurrent modification issues
                ArrayList = find_class("java.util.ArrayList")
                original_list_copy = ArrayList(original_list)
                
                self.plugin.log(f"[SmartFolder] Scheduling background sort thread for folder {target_folder_id}")
                threading.Thread(
                    target=self.background_sort_worker,
                    args=(currentAccount, target_folder_id, original_list_copy, config, current_fingerprint)
                ).start()

        except Exception as e:
            self.plugin.log(f"[SmartFolder] Error in getDialogsArray hook: {e}\n{traceback.format_exc()}")

    def background_sort_worker(self, currentAccount, target_folder_id, original_list_copy, config, current_fingerprint):
        cache_key = (currentAccount, target_folder_id)
        start_time = time.time()
        try:
            messagesController = find_class("org.telegram.messenger.MessagesController").getInstance(currentAccount)
            
            other_folder_dialog_ids = set()
            if config["exclude_other_folders"]:
                for i in range(messagesController.dialogFilters.size()):
                    f = messagesController.dialogFilters.get(i)
                    f_id = int(f.id)
                    f_name = str(f.name) if f.name is not None else ""
                    if f_id != target_folder_id and f_id != 0 and "ALL_CHATS" not in f_name.upper():
                        for j in range(f.dialogs.size()):
                            other_folder_dialog_ids.add(f.dialogs.get(j).id)

            chats_len = original_list_copy.size()
            ChatDataArray = self.plugin.loader.ChatData * chats_len
            chats_data = ChatDataArray()

            dialogs_map = {}
            now = time.time()
            for i in range(chats_len):
                dialog = original_list_copy.get(i)
                dialog_id = dialog.id
                dialogs_map[dialog_id] = dialog

                # Cache chat type JNI lookups
                chat_type = self.plugin.chat_type_cache.get(dialog_id)
                if chat_type is None:
                    chat_type = 1
                    if dialog_id > 0:
                        user = messagesController.getUser(dialog_id)
                        if user and user.bot:
                            chat_type = 4
                        else:
                            chat_type = 1
                    else:
                        chat_type = 2
                        chat = messagesController.getChat(-dialog_id)
                        if chat:
                            ChatObject = find_class("org.telegram.messenger.ChatObject")
                            is_channel = ChatObject.isChannel(chat) and not chat.megagroup
                            if is_channel:
                                chat_type = 3
                    self.plugin.chat_type_cache[dialog_id] = chat_type

                # Cache mute JNI lookup with 3-second TTL
                mute_info = self.plugin.mute_cache.get(dialog_id)
                if mute_info is None or now - mute_info[1] > 3.0:
                    is_muted = bool(messagesController.isDialogMuted(dialog_id, 0))
                    self.plugin.mute_cache[dialog_id] = (is_muted, now)
                else:
                    is_muted = mute_info[0]

                in_other_folders = dialog_id in other_folder_dialog_ids

                is_pinned = dialog.pinned
                pin_order = i if is_pinned else 0

                chats_data[i] = self.plugin.loader.ChatData(
                    dialog_id=dialog_id,
                    last_message_date=dialog.last_message_date,
                    message_count=dialog.unread_count,
                    chat_type=chat_type,
                    is_muted=is_muted,
                    in_other_folders=in_other_folders,
                    is_local_pinned=is_pinned,
                    local_pin_order=pin_order
                )

            sort_type_val = 1
            if config["sort_type"] == "time_desc":
                sort_type_val = 1
            elif config["sort_type"] == "time_asc":
                sort_type_val = 2
            elif config["sort_type"] == "message_count":
                sort_type_val = 3

            rules = self.plugin.loader.SortFilterRules(
                sort_type=sort_type_val,
                filter_mask=config["filter_mask"],
                only_unmuted=bool(config["only_unmuted"]),
                exclude_other_folders=bool(config["exclude_other_folders"])
            )

            out_ids = (ctypes.c_int64 * chats_len)()
            new_len = self.plugin.loader.lib.filter_and_sort_chats(
                chats_data,
                chats_len,
                rules,
                out_ids
            )

            ArrayList = find_class("java.util.ArrayList")
            new_list = ArrayList(new_len)
            for i in range(new_len):
                did = out_ids[i]
                orig_dialog = dialogs_map.get(did)
                if orig_dialog:
                    new_list.add(orig_dialog)

            self.plugin.sorted_list_cache[cache_key] = (new_list, time.time(), current_fingerprint)
            self.plugin.log(f"[SmartFolder] Background sort finished for folder {target_folder_id} in {time.time() - start_time:.3f}s (output size: {new_len})")
            run_on_ui_thread(lambda: self.plugin.reload_dialogs())

        except Exception as e:
            self.plugin.log(f"[SmartFolder] Error in background sort worker: {e}\n{traceback.format_exc()}")
        finally:
            self.plugin.pending_sorts.discard(cache_key)


class ListTouchListener(dynamic_proxy(find_class("android.view.View$OnTouchListener"))):
    def __init__(self, sheet_wrapper):
        super().__init__()
        self.wrapper_ref = weakref.ref(sheet_wrapper)
    def onTouch(self, v, event):
        wrapper = self.wrapper_ref()
        if not wrapper or not wrapper.sheet:
            return False
        action = event.getAction()
        v_class = str(v.getClass().getName()) if v else ""
        is_interactive = ("Switch" in v_class or "SeekBar" in v_class)
        
        if action in (0, 2):  # ACTION_DOWN, ACTION_MOVE
            try:
                if is_interactive:
                    wrapper.sheet.setCanDismissWithSwipe(False)
                else:
                    scroll_at_top = True
                    if wrapper.scroll:
                        scroll_at_top = (wrapper.scroll.getScrollY() <= 0)
                    wrapper.sheet.setCanDismissWithSwipe(scroll_at_top)
            except Exception:
                pass
        elif action in (1, 3):  # ACTION_UP, ACTION_CANCEL
            try:
                wrapper.sheet.setCanDismissWithSwipe(True)
            except Exception:
                pass
        return False


class FolderManagerSheet:
    def __init__(self, plugin, activity):
        self.plugin = plugin
        self.activity = activity
        self.sheet = None
        self.resources_provider = self._get_provider()
        
        # Load actual folders
        self.load_folders()
        
        # UI components
        self.tab_views = []
        self.check_desc = None
        self.check_asc = None
        self.check_count = None
        
        self.switch_personal = None
        self.switch_groups = None
        self.switch_channels = None
        self.switch_bots = None
        self.switch_unmuted = None
        self.switch_exclude = None
        
        self.seek_days = None
        self.seek_engagement = None
        self.label_days = None
        self.label_engagement = None

    def load_folders(self):
        try:
            UserConfig = find_class("org.telegram.messenger.UserConfig")
            currentAccount = UserConfig.selectedAccount
            
            # Sync database first to make sure it has everything
            self.plugin.sync_folders_db(currentAccount)
            
            messagesController = find_class("org.telegram.messenger.MessagesController").getInstance(currentAccount)
            filters_list = messagesController.dialogFilters
            
            self.folders = []
            
            # 1. Default folder ("Все чаты", ID 0)
            self.folders.append({
                "id": 0,
                "name": self.plugin._get_string("all_chats"),
            })
            
            # 2. Custom filters
            for i in range(filters_list.size()):
                f = filters_list.get(i)
                fid = int(f.id)
                fname = str(f.name) if f.name is not None else ""
                fname_clean = fname.strip().upper()
                if fid == 0 or "ALL_CHATS" in fname_clean or fname_clean == "" or fname_clean == "NONE":
                    continue
                self.folders.append({
                    "id": fid,
                    "name": fname,
                })
            self.has_folders = len(self.folders) > 1
        except Exception as e:
            self.plugin.log(f"Error loading folders: {e}\n{traceback.format_exc()}")
            self.folders = [{"id": 0, "name": self.plugin._get_string("all_chats")}]
            self.has_folders = False
            
        self.folders_data = []
        UserConfig = find_class("org.telegram.messenger.UserConfig")
        currentAccount = UserConfig.selectedAccount
        for f in self.folders:
            config = self.plugin.get_folder_config(currentAccount, f["id"])
            mask = config["filter_mask"]
            types = {
                "personal": bool(mask & 1),
                "groups": bool(mask & 2),
                "channels": bool(mask & 4),
                "bots": bool(mask & 8),
            }
            self.folders_data.append({
                "id": f["id"],
                "name": f["name"],
                "sort_type": config["sort_type"],
                "types": types,
                "only_unmuted": bool(config["only_unmuted"]),
                "exclude_other": bool(config["exclude_other_folders"]),
                "archive_days": config["archive_days"],
                "archive_engagement": config["archive_engagement"]
            })
            
        # Select active folder by default
        active_fid = self.plugin.get_current_active_folder_id()
        self.selected_folder_index = 0
        for idx, folder in enumerate(self.folders_data):
            if folder["id"] == active_fid:
                self.selected_folder_index = idx
                break

    def save_folder(self, index):
        if len(self.folders_data) == 0:
            return
            
        UserConfig = find_class("org.telegram.messenger.UserConfig")
        currentAccount = UserConfig.selectedAccount
        
        folder = self.folders_data[index]
        mask = 0
        if folder["types"]["personal"]: mask |= 1
        if folder["types"]["groups"]: mask |= 2
        if folder["types"]["channels"]: mask |= 4
        if folder["types"]["bots"]: mask |= 8
        
        config = {
            "sort_type": folder["sort_type"],
            "filter_mask": mask,
            "only_unmuted": 1 if folder["only_unmuted"] else 0,
            "exclude_other_folders": 1 if folder["exclude_other"] else 0,
            "archive_days": folder["archive_days"],
            "archive_engagement": folder["archive_engagement"]
        }
        self.plugin.save_folder_config(currentAccount, folder["id"], config)
        self.plugin.reload_dialogs()

    def _get_provider(self):
        provider = None
        try:
            LaunchActivity = find_class("org.telegram.ui.LaunchActivity")
            fragment = LaunchActivity.getSafeLastFragment()
            if fragment:
                provider = get_private_field(fragment, "themeDelegate")
                if provider is None:
                    provider = fragment.getResourceProvider()
        except Exception:
            pass
        return provider

    def _setup_touch_listener(self, view, listener):
        if view is None:
            return
        view.setOnTouchListener(listener)
        ViewGroupClass = find_class("android.view.ViewGroup")
        if ViewGroupClass and isinstance(view, ViewGroupClass):
            for i in range(view.getChildCount()):
                self._setup_touch_listener(view.getChildAt(i), listener)

    def _signed_color(self, value):
        color = int(value) & 0xFFFFFFFF
        if color >= 0x80000000:
            color -= 0x100000000
        return color

    def _color(self, key, fallback=None):
        try:
            if self.resources_provider is not None:
                return self._signed_color(Theme.getColor(key, self.resources_provider))
        except Exception:
            pass
        try:
            return self._signed_color(Theme.getColor(key))
        except Exception:
            return self._signed_color(fallback if fallback is not None else 0xFF1F2329)

    def _dp(self, value):
        return AndroidUtilities.dp(int(value))

    def _alpha(self, color, alpha):
        alpha_value = max(0, min(255, int(float(alpha) * 255)))
        return self._signed_color((alpha_value << 24) | (int(color) & 0x00FFFFFF))

    def _card_bg(self, radius_dp=16, stroke_alpha=0.08):
        GradientDrawable = jclass("android.graphics.drawable.GradientDrawable")
        drawable = GradientDrawable()
        drawable.setCornerRadius(float(self._dp(radius_dp)))
        bg_col = self._color(Theme.key_windowBackgroundWhite, 0xFFFFFFFF)
        drawable.setColor(bg_col)
        stroke_color = self._alpha(self._color(Theme.key_listSelector, 0x33000000), stroke_alpha)
        drawable.setStroke(self._dp(1), stroke_color)
        return drawable

    def _tap_bg(self, fill_color=None, radius_dp=8, ripple_alpha=0.15, stroke_color=None, stroke_width_dp=1):
        GradientDrawable = jclass("android.graphics.drawable.GradientDrawable")
        RippleDrawable = jclass("android.graphics.drawable.RippleDrawable")
        ColorStateList = jclass("android.content.res.ColorStateList")
        Color = jclass("android.graphics.Color")
        
        base = GradientDrawable()
        base.setCornerRadius(float(self._dp(radius_dp)))
        base.setColor(fill_color if fill_color is not None else Color.TRANSPARENT)
        if stroke_color is not None:
            base.setStroke(self._dp(stroke_width_dp), stroke_color)
        try:
            return RippleDrawable(
                ColorStateList.valueOf(self._alpha(self._color(Theme.key_listSelector, 0x33000000), ripple_alpha)),
                base,
                None,
            )
        except Exception:
            return base

    def _avatar_drawable(self, color):
        GradientDrawable = jclass("android.graphics.drawable.GradientDrawable")
        drawable = GradientDrawable()
        drawable.setShape(GradientDrawable.OVAL)
        drawable.setColor(self._signed_color(color))
        return drawable

    def _create_avatar_view(self, initials, color_hex):
        FrameLayout = jclass("android.widget.FrameLayout")
        TextView = jclass("android.widget.TextView")
        ImageView = jclass("android.widget.ImageView")
        Gravity = jclass("android.view.Gravity")
        Typeface = jclass("android.graphics.Typeface")
        LayoutHelper = find_class("org.telegram.ui.Components.LayoutHelper")
        
        container = FrameLayout(self.activity)
        
        avatar_bg = ImageView(self.activity)
        avatar_bg.setBackground(self._avatar_drawable(color_hex))
        container.addView(avatar_bg, LayoutHelper.createFrame(36, 36))
        
        initials_text = TextView(self.activity)
        initials_text.setText(initials)
        initials_text.setTextColor(self._signed_color(0xFFFFFFFF))
        initials_text.setTextSize(1, 13.0)
        initials_text.setTypeface(Typeface.DEFAULT_BOLD)
        initials_text.setGravity(Gravity.CENTER)
        container.addView(initials_text, LayoutHelper.createFrame(36, 36, Gravity.CENTER))
        
        return container

    def _icon(self, name):
        try:
            R_drawable = find_class("org.telegram.messenger.R$drawable")
            if R_drawable:
                res_id = int(getattr(R_drawable, name, 0))
                if res_id != 0:
                    return res_id
        except Exception:
            pass
        try:
            ctx = ApplicationLoader.applicationContext
            res = ctx.getResources()
            res_id = int(res.getIdentifier(name, "drawable", ctx.getPackageName()) or 0)
            return res_id
        except Exception:
            return 0

    def _create_row(self, title, desc, drawable_name, control_type, on_click=None):
        LinearLayout = jclass("android.widget.LinearLayout")
        TextView = jclass("android.widget.TextView")
        ImageView = jclass("android.widget.ImageView")
        Gravity = jclass("android.view.Gravity")
        Typeface = jclass("android.graphics.Typeface")
        LayoutHelper = find_class("org.telegram.ui.Components.LayoutHelper")
        
        row = LinearLayout(self.activity)
        row.setOrientation(LinearLayout.HORIZONTAL)
        row.setGravity(Gravity.CENTER_VERTICAL)
        row.setPadding(self._dp(16), self._dp(12), self._dp(16), self._dp(12))
        row.setBackground(self._tap_bg(radius_dp=0))
        
        # Icon
        if drawable_name:
            icon_view = ImageView(self.activity)
            icon_view.setScaleType(ImageView.ScaleType.FIT_CENTER)
            res_id = self._icon(drawable_name)
            if res_id != 0:
                icon_view.setImageResource(res_id)
                icon_view.setColorFilter(self._color(Theme.key_windowBackgroundWhiteGrayIcon, 0xFF888888))
            row.addView(icon_view, LayoutHelper.createLinear(24, 24, 0.0, Gravity.CENTER_VERTICAL, 0, 0, 16, 0))
            
        # Text block
        text_block = LinearLayout(self.activity)
        text_block.setOrientation(LinearLayout.VERTICAL)
        
        title_view = TextView(self.activity)
        title_view.setText(title)
        title_view.setTextColor(self._color(Theme.key_windowBackgroundWhiteBlackText, 0xFFFFFFFF))
        title_view.setTextSize(1, 15.5)
        title_view.setTypeface(Typeface.DEFAULT)
        text_block.addView(title_view, LayoutHelper.createLinear(-1, -2))
        
        desc_view = None
        if desc:
            desc_view = TextView(self.activity)
            desc_view.setText(desc)
            desc_view.setTextColor(self._color(Theme.key_windowBackgroundWhiteGrayText2, 0xFF888888))
            desc_view.setTextSize(1, 12.5)
            text_block.addView(desc_view, LayoutHelper.createLinear(-1, -2, 0.0, 0, 2, 0, 0))
            
        row.addView(text_block, LayoutHelper.createLinear(0, -2, 1.0))
        
        control = None
        if control_type == "switch":
            SwitchClass = find_class("org.telegram.ui.Components.Switch")
            control = SwitchClass(self.activity)
            control.setColors(
                Theme.key_switchTrack, 
                Theme.key_switchTrackChecked, 
                Theme.key_windowBackgroundWhite, 
                Theme.key_windowBackgroundWhite
            )
            row.setClipChildren(False)
            row.setClipToPadding(False)
            row.addView(control, LayoutHelper.createLinear(44, 24, Gravity.CENTER_VERTICAL))
        elif control_type == "checkmark":
            control = ImageView(self.activity)
            control.setScaleType(ImageView.ScaleType.FIT_CENTER)
            res_id = self._icon("checkbig")
            if res_id == 0:
                res_id = self._icon("msg_check")
            if res_id != 0:
                control.setImageResource(res_id)
                control.setColorFilter(self._color(Theme.key_featuredStickers_addButton, 0xFF3390EC))
            control.setVisibility(8)
            row.addView(control, LayoutHelper.createLinear(24, 24, Gravity.CENTER_VERTICAL))
            
        if on_click:
            row.setOnClickListener(OnClickListener(on_click))
            
        return row, control

    def _create_slider_row(self, title, min_val, max_val, unit, current_val, on_change):
        LinearLayout = jclass("android.widget.LinearLayout")
        TextView = jclass("android.widget.TextView")
        SeekBar = jclass("android.widget.SeekBar")
        LayoutHelper = find_class("org.telegram.ui.Components.LayoutHelper")
        
        container = LinearLayout(self.activity)
        container.setOrientation(LinearLayout.VERTICAL)
        container.setPadding(self._dp(16), self._dp(12), self._dp(16), self._dp(12))
        
        label_view = TextView(self.activity)
        label_view.setText(f"{title}: {current_val} {unit}")
        label_view.setTextColor(self._color(Theme.key_dialogTextBlack, 0xFFFFFFFF))
        label_view.setTextSize(1, 14.5)
        container.addView(label_view, LayoutHelper.createLinear(-1, -2, 0.0, 0, 0, 0, 8))
        
        seekbar = SeekBar(self.activity)
        seekbar.setMax(max_val - min_val)
        seekbar.setProgress(current_val - min_val)
        
        SeekBarListener = jclass("android.widget.SeekBar$OnSeekBarChangeListener")
        class SlideListener(dynamic_proxy(SeekBarListener)):
            def __init__(self, label, seek, title_str, min_v, unit_str, cb):
                super().__init__()
                self.label = label
                self.seek = seek
                self.title_str = title_str
                self.min_v = min_v
                self.unit_str = unit_str
                self.cb = cb
            def onProgressChanged(self, sb, progress, fromUser):
                actual_val = self.min_v + progress
                self.label.setText(f"{self.title_str}: {actual_val} {self.unit_str}")
                if fromUser:
                    self.cb(actual_val)
            def onStartTrackingTouch(self, sb): pass
            def onStopTrackingTouch(self, sb): pass
            
        seekbar.setOnSeekBarChangeListener(SlideListener(label_view, seekbar, title, min_val, unit, on_change))
        container.addView(seekbar, LayoutHelper.createLinear(-1, -2))
        
        return container, label_view, seekbar

    def _checkbox_bg(self, checked):
        GradientDrawable = jclass("android.graphics.drawable.GradientDrawable")
        drawable = GradientDrawable()
        drawable.setShape(GradientDrawable.OVAL)
        if checked:
            drawable.setColor(self._signed_color(0xFF3390EC))
        else:
            drawable.setColor(self._signed_color(0x00000000))
            stroke_color = self._alpha(self._color(Theme.key_dialogTextHint, 0xFF888888), 0.5)
            drawable.setStroke(self._dp(2), stroke_color)
        return drawable

    def _create_custom_checkbox(self):
        FrameLayout = jclass("android.widget.FrameLayout")
        TextView = jclass("android.widget.TextView")
        Gravity = jclass("android.view.Gravity")
        Typeface = jclass("android.graphics.Typeface")
        LayoutHelper = find_class("org.telegram.ui.Components.LayoutHelper")
        
        box = FrameLayout(self.activity)
        
        bg_circle = FrameLayout(self.activity)
        bg_circle.setBackground(self._checkbox_bg(checked=False))
        box.addView(bg_circle, LayoutHelper.createFrame(22, 22))
        
        check_text = TextView(self.activity)
        check_text.setText("✓")
        check_text.setTextColor(self._signed_color(0xFFFFFFFF))
        check_text.setTextSize(1, 14.0)
        check_text.setTypeface(Typeface.DEFAULT_BOLD)
        check_text.setGravity(Gravity.CENTER)
        check_text.setVisibility(8)
        box.addView(check_text, LayoutHelper.createFrame(22, 22, Gravity.CENTER))
        
        def set_checked(is_checked):
            if is_checked:
                bg_circle.setBackground(self._checkbox_bg(checked=True))
                check_text.setVisibility(0)
            else:
                bg_circle.setBackground(self._checkbox_bg(checked=False))
                check_text.setVisibility(8)
                
        return box, set_checked

    def _build(self):
        LinearLayout = jclass("android.widget.LinearLayout")
        TextView = jclass("android.widget.TextView")
        ScrollView = jclass("android.widget.ScrollView")
        HorizontalScrollView = jclass("android.widget.HorizontalScrollView")
        Gravity = jclass("android.view.Gravity")
        Typeface = jclass("android.graphics.Typeface")
        View = jclass("android.view.View")
        LayoutHelper = find_class("org.telegram.ui.Components.LayoutHelper")
        
        # Root container
        root = LinearLayout(self.activity)
        root.setOrientation(LinearLayout.VERTICAL)
        root.setBackgroundColor(self._color(Theme.key_dialogBackground, 0xFF17212B))
        
        # 1. Top Drag Handle
        handle = View(self.activity)
        handle_drawable = jclass("android.graphics.drawable.GradientDrawable")()
        handle_drawable.setCornerRadius(float(self._dp(2)))
        handle_drawable.setColor(self._alpha(self._color(Theme.key_dialogTextHint, 0xFF888888), 0.25))
        handle.setBackground(handle_drawable)
        root.addView(handle, LayoutHelper.createLinear(36, 4, Gravity.CENTER_HORIZONTAL, 0, 8, 0, 0))
        
        # 2. Header
        header = LinearLayout(self.activity)
        header.setOrientation(LinearLayout.HORIZONTAL)
        header.setPadding(self._dp(20), self._dp(16), self._dp(20), self._dp(12))
        
        title_view = TextView(self.activity)
        title_view.setText(self.plugin._get_string("title_single_folder") if not self.has_folders else self.plugin._get_string("title_multi_folder"))
        title_view.setTextColor(self._color(Theme.key_dialogTextBlack, 0xFFFFFFFF))
        title_view.setTextSize(1, 24.0)
        title_view.setTypeface(Typeface.DEFAULT_BOLD)
        
        center_title = False
        try:
            ExteraConfig = find_class("com.exteragram.messenger.ExteraConfig")
            if ExteraConfig:
                center_title = bool(ExteraConfig.getCenterTitle())
        except Exception:
            pass
            
        if center_title:
            header.setGravity(Gravity.CENTER)
            title_view.setGravity(Gravity.CENTER)
            header.addView(title_view, LayoutHelper.createLinear(-2, -2))
        else:
            LocaleController = find_class("org.telegram.messenger.LocaleController")
            is_rtl = LocaleController.isRTL if LocaleController else False
            gravity = (Gravity.RIGHT if is_rtl else Gravity.LEFT) | Gravity.CENTER_VERTICAL
            header.setGravity(gravity)
            title_view.setGravity(gravity)
            header.addView(title_view, LayoutHelper.createLinear(-1, -2))
            
        root.addView(header, LayoutHelper.createLinear(-1, -2))
        
        # If there are no custom folders, show user-friendly message and return immediately
        if len(self.folders_data) == 0:
            no_folders_text = TextView(self.activity)
            no_folders_text.setText(self.plugin._get_string("no_folders_warning"))
            no_folders_text.setTextColor(self._color(Theme.key_dialogTextHint, 0xFF888888))
            no_folders_text.setTextSize(1, 16.0)
            no_folders_text.setGravity(Gravity.CENTER)
            no_folders_text.setPadding(self._dp(24), self._dp(48), self._dp(24), self._dp(48))
            root.addView(no_folders_text, LayoutHelper.createLinear(-1, -2))
            return root

        # 3. Horizontal Scroll of Folders (Tabs)
        self.tab_views = []
        if self.has_folders:
            tabs_scroll = HorizontalScrollView(self.activity)
            tabs_scroll.setHorizontalScrollBarEnabled(False)
            tabs_scroll.setPadding(self._dp(12), self._dp(4), self._dp(12), self._dp(8))
            
            tabs_container = LinearLayout(self.activity)
            tabs_container.setOrientation(LinearLayout.HORIZONTAL)
            
            for i, folder in enumerate(self.folders_data):
                tab = TextView(self.activity)
                tab.setText(folder["name"])
                tab.setTextSize(1, 14.5)
                tab.setTypeface(Typeface.DEFAULT_BOLD)
                tab.setPadding(self._dp(16), self._dp(8), self._dp(16), self._dp(8))
                
                tab.setOnClickListener(OnClickListener(lambda v, idx=i: self.select_folder(idx)))
                tabs_container.addView(tab, LayoutHelper.createLinear(-2, -2, 0.0, 0, 0, 8, 0))
                self.tab_views.append(tab)
                
            tabs_scroll.addView(tabs_container, LayoutHelper.createFrame(-2, -2))
            root.addView(tabs_scroll, LayoutHelper.createLinear(-1, -2))
        
        # 4. Scrollable settings content
        scroll = ScrollView(self.activity)
        scroll.setFillViewport(True)
        scroll.setVerticalScrollBarEnabled(False)
        
        content = LinearLayout(self.activity)
        content.setOrientation(LinearLayout.VERTICAL)
        content.setPadding(self._dp(16), self._dp(4), self._dp(16), self._dp(24))
        
        # --- CARD 1: SORTING ---
        sorting_card = LinearLayout(self.activity)
        sorting_card.setOrientation(LinearLayout.VERTICAL)
        sorting_card.setBackground(self._card_bg())
        sorting_card.setPadding(0, self._dp(4), 0, self._dp(4))
        sorting_card.setClipChildren(False)
        
        # Title of card
        lbl_sort = TextView(self.activity)
        lbl_sort.setText(self.plugin._get_string("sort_header"))
        lbl_sort.setTextColor(self._color(Theme.key_featuredStickers_addButton, 0xFF3390EC))
        lbl_sort.setTextSize(1, 12.0)
        lbl_sort.setTypeface(Typeface.DEFAULT_BOLD)
        lbl_sort.setPadding(self._dp(16), self._dp(8), self._dp(16), self._dp(4))
        sorting_card.addView(lbl_sort, LayoutHelper.createLinear(-1, -2))
        
        row_desc, self.check_desc = self._create_row(self.plugin._get_string("sort_time_desc"), None, "msg_retry", "checkmark", lambda v: self.set_sorting("time_desc"))
        row_asc, self.check_asc = self._create_row(self.plugin._get_string("sort_time_asc"), None, "msg_retry", "checkmark", lambda v: self.set_sorting("time_asc"))
        row_count, self.check_count = self._create_row(self.plugin._get_string("sort_unread_count"), None, "msg_stats", "checkmark", lambda v: self.set_sorting("message_count"))
        
        sorting_card.addView(row_desc, LayoutHelper.createLinear(-1, -2))
        sorting_card.addView(row_asc, LayoutHelper.createLinear(-1, -2))
        sorting_card.addView(row_count, LayoutHelper.createLinear(-1, -2))
        
        content.addView(sorting_card, LayoutHelper.createLinear(-1, -2, 0.0, 0, 0, 0, 10))
        
        # --- CARD 2: FILTERS ---
        filters_card = LinearLayout(self.activity)
        filters_card.setOrientation(LinearLayout.VERTICAL)
        filters_card.setBackground(self._card_bg())
        filters_card.setPadding(0, self._dp(4), 0, self._dp(4))
        filters_card.setClipChildren(False)
        
        lbl_filt = TextView(self.activity)
        lbl_filt.setText(self.plugin._get_string("filter_header"))
        lbl_filt.setTextColor(self._color(Theme.key_featuredStickers_addButton, 0xFF3390EC))
        lbl_filt.setTextSize(1, 12.0)
        lbl_filt.setTypeface(Typeface.DEFAULT_BOLD)
        lbl_filt.setPadding(self._dp(16), self._dp(8), self._dp(16), self._dp(4))
        filters_card.addView(lbl_filt, LayoutHelper.createLinear(-1, -2))
        
        row_pers, self.switch_personal = self._create_row(self.plugin._get_string("filter_personal"), None, "msg_folders_private", "switch", lambda v: self.toggle_filter("personal"))
        row_grps, self.switch_groups = self._create_row(self.plugin._get_string("filter_groups"), None, "msg_folders_groups", "switch", lambda v: self.toggle_filter("groups"))
        row_chans, self.switch_channels = self._create_row(self.plugin._get_string("filter_channels"), None, "msg_folders_channels", "switch", lambda v: self.toggle_filter("channels"))
        row_bots, self.switch_bots = self._create_row(self.plugin._get_string("filter_bots"), None, "msg_folders_bots", "switch", lambda v: self.toggle_filter("bots"))
        
        # Divider line
        div = View(self.activity)
        div.setBackgroundColor(self._alpha(self._color(Theme.key_dialogTextHint, 0xFF888888), 0.15))
        
        row_muted, self.switch_unmuted = self._create_row(self.plugin._get_string("filter_hide_muted"), None, "msg_folders_muted", "switch", lambda v: self.toggle_filter("only_unmuted"))
        row_excl, self.switch_exclude = self._create_row(self.plugin._get_string("filter_isolation"), None, "msg_folders", "switch", lambda v: self.toggle_filter("exclude_other"))
        
        filters_card.addView(row_pers, LayoutHelper.createLinear(-1, -2))
        filters_card.addView(row_grps, LayoutHelper.createLinear(-1, -2))
        filters_card.addView(row_chans, LayoutHelper.createLinear(-1, -2))
        filters_card.addView(row_bots, LayoutHelper.createLinear(-1, -2))
        filters_card.addView(div, LayoutHelper.createLinear(-1, 1, 0.0, 16, 6, 16, 6))
        filters_card.addView(row_muted, LayoutHelper.createLinear(-1, -2))
        filters_card.addView(row_excl, LayoutHelper.createLinear(-1, -2))
        
        content.addView(filters_card, LayoutHelper.createLinear(-1, -2, 0.0, 0, 0, 0, 10))
        
        # --- CARD 4: SMART ARCHIVER ---
        archiver_card = LinearLayout(self.activity)
        archiver_card.setOrientation(LinearLayout.VERTICAL)
        archiver_card.setBackground(self._card_bg())
        archiver_card.setPadding(0, self._dp(4), 0, self._dp(4))
        
        lbl_arch = TextView(self.activity)
        lbl_arch.setText(self.plugin._get_string("archiver_header"))
        lbl_arch.setTextColor(self._color(Theme.key_featuredStickers_addButton, 0xFF3390EC))
        lbl_arch.setTextSize(1, 12.0)
        lbl_arch.setTypeface(Typeface.DEFAULT_BOLD)
        lbl_arch.setPadding(self._dp(16), self._dp(8), self._dp(16), self._dp(4))
        archiver_card.addView(lbl_arch, LayoutHelper.createLinear(-1, -2))
        
        # Sliders
        row_days_seek, self.label_days, self.seek_days = self._create_slider_row(
            self.plugin._get_string("archiver_days_seek"), 10, 120, self.plugin._get_string("archiver_days_unit"), 30, 
            lambda val: self.update_value("archive_days", val)
        )
        row_eng_seek, self.label_engagement, self.seek_engagement = self._create_slider_row(
            self.plugin._get_string("archiver_eng_seek"), 0, 50, "%", 5, 
            lambda val: self.update_value("archive_engagement", val)
        )
        
        archiver_card.addView(row_days_seek, LayoutHelper.createLinear(-1, -2))
        archiver_card.addView(row_eng_seek, LayoutHelper.createLinear(-1, -2))
        
        # Button to run analysis
        analyze_btn = TextView(self.activity)
        analyze_btn.setText(self.plugin._get_string("archiver_analyze_btn"))
        analyze_btn.setTextColor(self._color(Theme.key_featuredStickers_buttonText, 0xFFFFFFFF))
        analyze_btn.setTextSize(1, 15.0)
        analyze_btn.setTypeface(Typeface.DEFAULT_BOLD)
        analyze_btn.setGravity(Gravity.CENTER)
        analyze_btn.setPadding(self._dp(16), self._dp(12), self._dp(16), self._dp(12))
        
        accent_col = self._color(Theme.key_featuredStickers_addButton, 0xFF3390EC)
        analyze_btn.setBackground(self._tap_bg(fill_color=accent_col, radius_dp=12))
        analyze_btn.setOnClickListener(OnClickListener(lambda v: self.show_archiver_results()))
        
        btn_container = LinearLayout(self.activity)
        btn_container.setPadding(self._dp(16), self._dp(8), self._dp(16), self._dp(12))
        btn_container.addView(analyze_btn, LayoutHelper.createLinear(-1, -2))
        
        archiver_card.addView(btn_container, LayoutHelper.createLinear(-1, -2))
        
        content.addView(archiver_card, LayoutHelper.createLinear(-1, -2, 0.0, 0, 0, 0, 20))
        
        # --- RESET BUTTON ---
        reset_btn = TextView(self.activity)
        reset_btn.setText(self.plugin._get_string("archiver_reset_btn"))
        reset_btn.setTextColor(self._signed_color(0xFFEC3A3A))
        reset_btn.setTextSize(1, 15.0)
        reset_btn.setGravity(Gravity.CENTER)
        reset_btn.setPadding(self._dp(16), self._dp(12), self._dp(16), self._dp(12))
        reset_btn.setBackground(self._tap_bg(radius_dp=12))
        reset_btn.setOnClickListener(OnClickListener(lambda v: self.reset_current_folder()))
        content.addView(reset_btn, LayoutHelper.createLinear(-1, -2))
        
        self.scroll = scroll
        self._setup_touch_listener(scroll, ListTouchListener(self))
        
        scroll.addView(content, LayoutHelper.createFrame(-1, -2))
        root.addView(scroll, LayoutHelper.createLinear(-1, 360))
        
        # Initialize initial UI values
        if len(self.folders_data) > 0:
            self.update_tabs_ui()
            self.update_controls_ui()
        
        return root

    def select_folder(self, index):
        self.selected_folder_index = index
        self.update_tabs_ui()
        self.update_controls_ui()

    def update_tabs_ui(self):
        for i, tab in enumerate(self.tab_views):
            if i == self.selected_folder_index:
                tab.setBackground(self._tap_bg(fill_color=self._signed_color(0xFF3390EC), radius_dp=10))
                tab.setTextColor(self._signed_color(0xFFFFFFFF))
            else:
                inactive_bg = self._alpha(self._color(Theme.key_dialogTextBlack, 0xFFFFFFFF), 0.06)
                tab.setBackground(self._tap_bg(fill_color=inactive_bg, radius_dp=18))
                tab.setTextColor(self._color(Theme.key_dialogTextBlack, 0xFFFFFFFF))

    def update_controls_ui(self):
        data = self.folders_data[self.selected_folder_index]
        
        # 1. Update sorting checkmarks
        self.check_desc.setVisibility(0 if data["sort_type"] == "time_desc" else 8)
        self.check_asc.setVisibility(0 if data["sort_type"] == "time_asc" else 8)
        self.check_count.setVisibility(0 if data["sort_type"] == "message_count" else 8)
        
        # 2. Update filter switches
        self.switch_personal.setChecked(data["types"]["personal"], True)
        self.switch_groups.setChecked(data["types"]["groups"], True)
        self.switch_channels.setChecked(data["types"]["channels"], True)
        self.switch_bots.setChecked(data["types"]["bots"], True)
        self.switch_unmuted.setChecked(data["only_unmuted"], True)
        self.switch_exclude.setChecked(data["exclude_other"], True)
        
        # 3. Update sliders
        self.seek_days.setProgress(data["archive_days"] - 10)
        self.seek_engagement.setProgress(data["archive_engagement"] - 0)
        self.label_days.setText(self.plugin._get_string("archiver_days_label").format(days=data['archive_days']))
        self.label_engagement.setText(self.plugin._get_string("archiver_eng_label").format(engagement=data['archive_engagement']))

    def set_sorting(self, sort_type):
        if len(self.folders_data) == 0:
            return
        self.folders_data[self.selected_folder_index]["sort_type"] = sort_type
        self.update_controls_ui()
        self.save_folder(self.selected_folder_index)

    def toggle_filter(self, key):
        if len(self.folders_data) == 0:
            return
        data = self.folders_data[self.selected_folder_index]
        if key in data["types"]:
            current_val = data["types"][key]
            # If we are turning off a filter, check if it's the last active one
            if current_val:
                active_count = sum(1 for k, v in data["types"].items() if v)
                if active_count <= 1:
                    # Last active filter, show error bulletin/toast and prevent action
                    try:
                        Toast = jclass("android.widget.Toast")
                        Toast.makeText(self.activity, self.plugin._get_string("archiver_error_toast"), Toast.LENGTH_SHORT).show()
                    except Exception as e:
                        self.plugin.log(f"Error showing toast: {e}")
                    self.update_controls_ui()
                    return
            data["types"][key] = not current_val
        elif key == "only_unmuted":
            data["only_unmuted"] = not data["only_unmuted"]
        elif key == "exclude_other":
            data["exclude_other"] = not data["exclude_other"]
        self.update_controls_ui()
        self.save_folder(self.selected_folder_index)

    def update_value(self, key, val):
        if len(self.folders_data) == 0:
            return
        self.folders_data[self.selected_folder_index][key] = val
        self.save_folder(self.selected_folder_index)

    def reset_current_folder(self):
        if len(self.folders_data) == 0:
            return
        defaults = {
            "sort_type": "time_desc",
            "types": {"personal": True, "groups": True, "channels": True, "bots": True},
            "only_unmuted": False,
            "exclude_other": False,
            "archive_days": 30,
            "archive_engagement": 5
        }
        self.folders_data[self.selected_folder_index].update(defaults)
        self.update_controls_ui()
        self.save_folder(self.selected_folder_index)

    def show_archiver_results(self):
        if len(self.folders_data) == 0:
            return
        data = self.folders_data[self.selected_folder_index]
        folder_id = data["id"]
        days = data["archive_days"]
        eng = data["archive_engagement"]
        
        results_sheet = SmartArchiverResultsSheet(self, self.activity, folder_id, days, eng)
        results_sheet.show()
        self.plugin.active_sheets.append(results_sheet)

    def show(self):
        from org.telegram.ui.ActionBar import BottomSheet
        try:
            self.sheet = BottomSheet(self.activity, True)
            self.sheet.setCustomView(self._build())
            
            if self.scroll:
                set_private_field(self.sheet, "nestedScrollChild", self.scroll)
                
            dismiss_listener_cls = find_class("android.content.DialogInterface$OnDismissListener")
            if dismiss_listener_cls:
                owner_ref = weakref.ref(self)
                class _DismissListener(dynamic_proxy(dismiss_listener_cls)):
                    def onDismiss(self, dialog):
                        owner = owner_ref()
                        if owner:
                            if owner.plugin.active_sheet is owner:
                                owner.plugin.active_sheet = None
                            if owner in owner.plugin.active_sheets:
                                owner.plugin.active_sheets.remove(owner)
                            owner.sheet = None
                            
                            # Break circular references in scroll touch listener
                            if owner.scroll:
                                try:
                                    owner.scroll.setOnTouchListener(None)
                                except Exception:
                                    pass
                                owner.scroll = None
                                
                            # Break circular references in seekbar change listeners
                            if owner.seek_days:
                                try:
                                    owner.seek_days.setOnSeekBarChangeListener(None)
                                except Exception:
                                    pass
                                owner.seek_days = None
                            if owner.seek_engagement:
                                try:
                                    owner.seek_engagement.setOnSeekBarChangeListener(None)
                                except Exception:
                                    pass
                                owner.seek_engagement = None
                                
                            # Break circular references and clear heavy views
                            owner.tab_views = []
                            owner.check_desc = None
                            owner.check_asc = None
                            owner.check_count = None
                            owner.switch_personal = None
                            owner.switch_groups = None
                            owner.switch_channels = None
                            owner.switch_bots = None
                            owner.switch_unmuted = None
                            owner.switch_exclude = None
                            owner.label_days = None
                            owner.label_engagement = None
                            owner.folders_data = []
                            owner.folders = []
                        try:
                            dialog.setOnDismissListener(None)
                        except Exception:
                            pass
                self.sheet.setOnDismissListener(_DismissListener())
                
            self.sheet.show()
        except Exception as e:
            self.plugin.log(f"Ошибка показа BottomSheet: {e}\n{traceback.format_exc()}")

    def dismiss(self):
        if self.sheet:
            self.sheet.dismiss()


class SmartArchiverResultsSheet:
    def __init__(self, parent_sheet, activity, folder_id, days, engagement):
        self.parent_sheet = parent_sheet
        self.activity = activity
        self.folder_id = folder_id
        self.days = days
        self.engagement = engagement
        self.sheet = None
        self.resources_provider = parent_sheet.resources_provider
        
        # Scan actual inactive chats
        self.items = self.parent_sheet.plugin.scan_inactive_chats(self.folder_id, self.days, self.engagement)
        self.checked_states = [True] * len(self.items)
        self.checkbox_setters = []
        
        # Views
        self.main_layout = None
        self.loading_layout = None
        self.archive_btn = None
        self.scroll = None
        self.is_expanded = False
        self.rows = []
        
    def _dp(self, val):
        return self.parent_sheet._dp(val)
        
    def _color(self, key, fallback=None):
        return self.parent_sheet._color(key, fallback)
        
    def _alpha(self, color, alpha):
        return self.parent_sheet._alpha(color, alpha)
        
    def _tap_bg(self, *args, **kwargs):
        return self.parent_sheet._tap_bg(*args, **kwargs)
        
    def _card_bg(self, *args, **kwargs):
        return self.parent_sheet._card_bg(*args, **kwargs)
        
    def _create_avatar_view(self, initials, color_hex):
        return self.parent_sheet._create_avatar_view(initials, color_hex)

    def _create_custom_checkbox(self):
        return self.parent_sheet._create_custom_checkbox()

    def _create_archiver_row(self, index, name, desc, initials, avatar_color):
        LinearLayout = jclass("android.widget.LinearLayout")
        TextView = jclass("android.widget.TextView")
        Gravity = jclass("android.view.Gravity")
        Typeface = jclass("android.graphics.Typeface")
        LayoutHelper = find_class("org.telegram.ui.Components.LayoutHelper")
        
        row = LinearLayout(self.activity)
        row.setOrientation(LinearLayout.HORIZONTAL)
        row.setGravity(Gravity.CENTER_VERTICAL)
        row.setPadding(self._dp(16), self._dp(12), self._dp(16), self._dp(12))
        row.setBackground(self._tap_bg(radius_dp=0))
        
        # Checkbox
        box, set_checked = self._create_custom_checkbox()
        set_checked(self.checked_states[index])
        self.checkbox_setters.append(set_checked)
        row.addView(box, LayoutHelper.createLinear(22, 22, 0.0, 0, 0, 12, 0))
        
        # Avatar
        avatar = self._create_avatar_view(initials, avatar_color)
        row.addView(avatar, LayoutHelper.createLinear(36, 36, 0.0, 0, 0, 12, 0))
        
        # Text block
        text_block = LinearLayout(self.activity)
        text_block.setOrientation(LinearLayout.VERTICAL)
        
        title_view = TextView(self.activity)
        title_view.setText(name)
        title_view.setTextColor(self._color(Theme.key_dialogTextBlack, 0xFFFFFFFF))
        title_view.setTextSize(1, 15.0)
        title_view.setTypeface(Typeface.DEFAULT_BOLD)
        text_block.addView(title_view, LayoutHelper.createLinear(-1, -2))
        
        desc_view = TextView(self.activity)
        desc_view.setText(desc)
        desc_view.setTextColor(self._color(Theme.key_dialogTextHint, 0xFF888888))
        desc_view.setTextSize(1, 12.5)
        text_block.addView(desc_view, LayoutHelper.createLinear(-1, -2, 0.0, 0, 2, 0, 0))
        
        row.addView(text_block, LayoutHelper.createLinear(0, -2, 1.0))
        
        # Row click action toggles checkbox
        row.setOnClickListener(OnClickListener(lambda v, idx=index: self.toggle_row(idx)))
        
        return row

    def toggle_row(self, index):
        self.checked_states[index] = not self.checked_states[index]
        self.checkbox_setters[index](self.checked_states[index])
        self.update_archive_button()

    def update_archive_button(self):
        count = sum(1 for x in self.checked_states if x)
        if self.archive_btn:
            self.archive_btn.setText(self.parent_sheet.plugin._get_string("archiver_results_archive_btn").format(count=count))
            if count > 0:
                self.archive_btn.setEnabled(True)
                self.archive_btn.setAlpha(1.0)
            else:
                self.archive_btn.setEnabled(False)
                self.archive_btn.setAlpha(0.4)

    def _build(self):
        LinearLayout = jclass("android.widget.LinearLayout")
        TextView = jclass("android.widget.TextView")
        FrameLayout = jclass("android.widget.FrameLayout")
        View = jclass("android.view.View")
        ProgressBar = jclass("android.widget.ProgressBar")
        Gravity = jclass("android.view.Gravity")
        Typeface = jclass("android.graphics.Typeface")
        LayoutHelper = find_class("org.telegram.ui.Components.LayoutHelper")
        
        # Parent layout which will swap content and loader
        container = FrameLayout(self.activity)
        container.setBackgroundColor(self._color(Theme.key_dialogBackground, 0xFF17212B))
        
        # --- LOADING LAYOUT ---
        self.loading_layout = LinearLayout(self.activity)
        self.loading_layout.setOrientation(LinearLayout.VERTICAL)
        self.loading_layout.setGravity(Gravity.CENTER)
        self.loading_layout.setPadding(self._dp(20), self._dp(40), self._dp(20), self._dp(40))
        self.loading_layout.setVisibility(8) # GONE initially
        
        progress = ProgressBar(self.activity)
        self.loading_layout.addView(progress, LayoutHelper.createLinear(-2, -2, 0.0, 0, 0, 0, 16))
        
        loading_text = TextView(self.activity)
        loading_text.setText(self.parent_sheet.plugin._get_string("archiver_results_loading"))
        loading_text.setTextColor(self._color(Theme.key_dialogTextBlack, 0xFFFFFFFF))
        loading_text.setTextSize(1, 16.0)
        loading_text.setTypeface(Typeface.DEFAULT_BOLD)
        loading_text.setGravity(Gravity.CENTER)
        self.loading_layout.addView(loading_text, LayoutHelper.createLinear(-1, -2))
        
        container.addView(self.loading_layout, LayoutHelper.createFrame(-1, -2))
        
        # --- MAIN CONTENT LAYOUT ---
        self.main_layout = LinearLayout(self.activity)
        self.main_layout.setOrientation(LinearLayout.VERTICAL)
        
        # Drag handle
        handle = View(self.activity)
        handle_drawable = jclass("android.graphics.drawable.GradientDrawable")()
        handle_drawable.setCornerRadius(float(self._dp(2)))
        handle_drawable.setColor(self._alpha(self._color(Theme.key_dialogTextHint, 0xFF888888), 0.25))
        handle.setBackground(handle_drawable)
        self.main_layout.addView(handle, LayoutHelper.createLinear(36, 4, Gravity.CENTER_HORIZONTAL, 0, 8, 0, 0))
        
        # Title
        title_view = TextView(self.activity)
        title_view.setText(self.parent_sheet.plugin._get_string("archiver_results_title"))
        title_view.setTextColor(self._color(Theme.key_dialogTextBlack, 0xFFFFFFFF))
        title_view.setTextSize(1, 18.0)
        title_view.setTypeface(Typeface.DEFAULT_BOLD)
        title_view.setPadding(self._dp(20), self._dp(12), self._dp(20), self._dp(4))
        self.main_layout.addView(title_view, LayoutHelper.createLinear(-1, -2))
        
        # Description
        desc_view = TextView(self.activity)
        desc_view.setText(self.parent_sheet.plugin._get_string("archiver_results_desc").format(count=len(self.items), days=self.days, engagement=self.engagement))
        desc_view.setTextColor(self._color(Theme.key_dialogTextHint, 0xFF888888))
        desc_view.setTextSize(1, 13.0)
        desc_view.setPadding(self._dp(20), 0, self._dp(20), self._dp(12))
        self.main_layout.addView(desc_view, LayoutHelper.createLinear(-1, -2))
        
        # Cards wrapper
        list_card = LinearLayout(self.activity)
        list_card.setOrientation(LinearLayout.VERTICAL)
        list_card.setBackground(self._card_bg())
        list_card.setPadding(0, self._dp(6), 0, self._dp(6))
        
        self.checkbox_setters = []
        self.rows = []
        if len(self.items) == 0:
            no_chats_text = TextView(self.activity)
            no_chats_text.setText(self.parent_sheet.plugin._get_string("archiver_results_no_chats"))
            no_chats_text.setTextColor(self._color(Theme.key_dialogTextHint, 0xFF888888))
            no_chats_text.setTextSize(1, 14.5)
            no_chats_text.setPadding(self._dp(20), self._dp(16), self._dp(20), self._dp(16))
            list_card.addView(no_chats_text, LayoutHelper.createLinear(-1, -2))
        else:
            for i, item in enumerate(self.items):
                row = self._create_archiver_row(i, item["name"], item["desc"], item["initials"], item["avatar_color"])
                if i >= 5:
                    row.setVisibility(8) # GONE initially
                list_card.addView(row, LayoutHelper.createLinear(-1, -2))
                self.rows.append(row)
                
            if len(self.items) > 5:
                self.toggle_btn = TextView(self.activity)
                self.toggle_btn.setGravity(Gravity.CENTER)
                self.toggle_btn.setTextSize(1, 14.0)
                self.toggle_btn.setTypeface(Typeface.DEFAULT_BOLD)
                self.toggle_btn.setTextColor(self._color(Theme.key_featuredStickers_addButton, 0xFF3390EC))
                self.toggle_btn.setPadding(0, self._dp(12), 0, self._dp(12))
                self.toggle_btn.setBackground(self._tap_bg(radius_dp=0))
                self.toggle_btn.setText(self.parent_sheet.plugin._get_string("archiver_results_show_more").format(count=len(self.items) - 5))
                self.toggle_btn.setOnClickListener(OnClickListener(lambda v: self.toggle_expand()))
                list_card.addView(self.toggle_btn, LayoutHelper.createLinear(-1, -2))
        
        card_container = LinearLayout(self.activity)
        card_container.setOrientation(LinearLayout.VERTICAL)
        card_container.setPadding(self._dp(16), 0, self._dp(16), self._dp(16))
        card_container.addView(list_card, LayoutHelper.createLinear(-1, -2))
        
        ScrollView = jclass("android.widget.ScrollView")
        scroll = ScrollView(self.activity)
        scroll.setFillViewport(True)
        scroll.setVerticalScrollBarEnabled(False)
        scroll.addView(card_container, LayoutHelper.createFrame(-1, -2))
        
        self.scroll = scroll
        self._setup_touch_listener(scroll, ListTouchListener(self))
        
        self.main_layout.addView(scroll, LayoutHelper.createLinear(-1, -2))
        
        # Bottom Buttons
        buttons_layout = LinearLayout(self.activity)
        buttons_layout.setOrientation(LinearLayout.HORIZONTAL)
        buttons_layout.setPadding(self._dp(16), 0, self._dp(16), self._dp(20))
        
        cancel_btn = TextView(self.activity)
        cancel_btn.setText(self.parent_sheet.plugin._get_string("archiver_results_cancel"))
        cancel_btn.setTextColor(self._color(Theme.key_dialogTextHint, 0xFF888888))
        cancel_btn.setTextSize(1, 15.0)
        cancel_btn.setTypeface(Typeface.DEFAULT_BOLD)
        cancel_btn.setGravity(Gravity.CENTER)
        cancel_btn.setPadding(self._dp(12), self._dp(12), self._dp(12), self._dp(12))
        cancel_btn.setBackground(self._tap_bg(radius_dp=12))
        cancel_btn.setOnClickListener(OnClickListener(lambda v: self.dismiss()))
        
        self.archive_btn = TextView(self.activity)
        self.archive_btn.setText(self.parent_sheet.plugin._get_string("archiver_results_archive_btn").format(count=len(self.items)))
        self.archive_btn.setTextColor(self._color(Theme.key_featuredStickers_buttonText, 0xFFFFFFFF))
        self.archive_btn.setTextSize(1, 15.0)
        self.archive_btn.setTypeface(Typeface.DEFAULT_BOLD)
        self.archive_btn.setGravity(Gravity.CENTER)
        self.archive_btn.setPadding(self._dp(16), self._dp(12), self._dp(16), self._dp(12))
        
        accent_col = self._color(Theme.key_featuredStickers_addButton, 0xFF3390EC)
        self.archive_btn.setBackground(self._tap_bg(fill_color=accent_col, radius_dp=12))
        self.archive_btn.setOnClickListener(OnClickListener(lambda v: self.start_archiving()))
        
        buttons_layout.addView(cancel_btn, LayoutHelper.createLinear(0, -2, 1.0, 0, 0, 8, 0))
        buttons_layout.addView(self.archive_btn, LayoutHelper.createLinear(0, -2, 2.0))
        
        self.main_layout.addView(buttons_layout, LayoutHelper.createLinear(-1, -2))
        
        container.addView(self.main_layout, LayoutHelper.createFrame(-1, -2))
        
        return container

    def toggle_expand(self):
        self.is_expanded = not self.is_expanded
        for i, row in enumerate(self.rows):
            if i >= 5:
                row.setVisibility(0 if self.is_expanded else 8)
        if self.is_expanded:
            self.toggle_btn.setText(self.parent_sheet.plugin._get_string("archiver_results_hide"))
        else:
            self.toggle_btn.setText(self.parent_sheet.plugin._get_string("archiver_results_show_more").format(count=len(self.items) - 5))

    def _setup_touch_listener(self, view, listener):
        if view is None:
            return
        view.setOnTouchListener(listener)
        ViewGroupClass = find_class("android.view.ViewGroup")
        if ViewGroupClass and isinstance(view, ViewGroupClass):
            for i in range(view.getChildCount()):
                self._setup_touch_listener(view.getChildAt(i), listener)

    def show(self):
        from org.telegram.ui.ActionBar import BottomSheet
        try:
            self.sheet = BottomSheet(self.activity, True)
            self.sheet.setCustomView(self._build())
            
            if self.scroll:
                set_private_field(self.sheet, "nestedScrollChild", self.scroll)
                
            dismiss_listener_cls = find_class("android.content.DialogInterface$OnDismissListener")
            if dismiss_listener_cls:
                owner_ref = weakref.ref(self)
                class _DismissListener(dynamic_proxy(dismiss_listener_cls)):
                    def onDismiss(self, dialog):
                        owner = owner_ref()
                        if owner:
                            owner.sheet = None
                            if owner in owner.parent_sheet.plugin.active_sheets:
                                owner.parent_sheet.plugin.active_sheets.remove(owner)
                            owner.parent_sheet = None
                            owner.items = []
                            owner.checked_states = []
                            owner.checkbox_setters = []
                            owner.main_layout = None
                            owner.loading_layout = None
                            owner.archive_btn = None
                            if owner.scroll:
                                try:
                                    owner.scroll.setOnTouchListener(None)
                                except Exception:
                                    pass
                                owner.scroll = None
                            owner.rows = []
                        try:
                            dialog.setOnDismissListener(None)
                        except Exception:
                            pass
                self.sheet.setOnDismissListener(_DismissListener())
                
            self.sheet.show()
        except Exception as e:
            self.parent_sheet.plugin.log(f"Ошибка при открытии листа архиватора: {e}")

    def dismiss(self):
        if self.sheet:
            self.sheet.dismiss()
            self.sheet = None

    def start_archiving(self):
        self.main_layout.setVisibility(8) # GONE
        self.loading_layout.setVisibility(0) # VISIBLE
        
        def run_archive():
            try:
                UserConfig = find_class("org.telegram.messenger.UserConfig")
                currentAccount = UserConfig.selectedAccount
                
                # Get list of checked dialog IDs
                dialog_ids_to_archive = []
                for i, item in enumerate(self.items):
                    if self.checked_states[i]:
                        dialog_ids_to_archive.append(item["id"])
                        
                total_to_archive = len(dialog_ids_to_archive)
                archived_count = 0
                
                # Process in batches of 3
                batch_size = 3
                for i in range(0, total_to_archive, batch_size):
                    batch = dialog_ids_to_archive[i : i + batch_size]
                    
                    # Schedule JNI calls for this batch on the UI thread
                    def process_batch(current_batch=batch):
                        try:
                            messagesController = find_class("org.telegram.messenger.MessagesController").getInstance(currentAccount)
                            for d_id in current_batch:
                                messagesController.addDialogToFolder(jlong(d_id), jint(1), jint(0), jlong(0))
                        except Exception as ex:
                            self.parent_sheet.plugin.log(f"Error archiving batch: {ex}")
                            
                    run_on_ui_thread(process_batch)
                    archived_count += len(batch)
                    time.sleep(0.15) # 150ms delay between batches
                    
                # Finalize JNI calls on the UI thread
                def finalize():
                    try:
                        self.parent_sheet.plugin.reload_dialogs()
                        self.complete_archiving(archived_count)
                    except Exception as ex:
                        self.parent_sheet.plugin.log(f"Error finalizing UI archiving: {ex}")
                        self.dismiss()
                        
                run_on_ui_thread(finalize)
            except Exception as e:
                self.parent_sheet.plugin.log(f"Error in archiving background thread: {e}\n{traceback.format_exc()}")
                run_on_ui_thread(self.dismiss)
                
        threading.Thread(target=run_archive).start()

    def complete_archiving(self, count):
        self.dismiss()
        try:
            Toast = jclass("android.widget.Toast")
            Toast.makeText(self.activity, self.parent_sheet.plugin._get_string("archiver_success_toast").format(count=count), Toast.LENGTH_SHORT).show()
        except Exception as e:
            self.parent_sheet.plugin.log(f"Error showing toast: {e}")
