import os
import time
import weakref
import traceback
import threading
import sqlite3
import ctypes
import base64
import zlib
from typing import Any, List

from base_plugin import BasePlugin, MethodHook
from hook_utils import find_class, get_private_field, set_private_field
from java import jclass, jint, jlong, dynamic_proxy
from android_utils import run_on_ui_thread, log, OnClickListener

__id__ = "smart_folder_manager"
__name__ = "Smart Folder Manager"
__description__ = "Умный сортировщик чатов с кастомными фильтрами и Умным Архиватором"
__author__ = "@anivdev & @mraniv"
__version__ = "1.0.0"
__icon__ = "ToxicDuck/49"
__min_version__ = "12.5.1"

FOLDER_PILL_ID = 2688
TAG_KEY = jint(0x53464D50) # 'SFMP'

AndroidUtilities = find_class("org.telegram.messenger.AndroidUtilities")
Theme = find_class("org.telegram.ui.ActionBar.Theme")
ApplicationLoader = find_class("org.telegram.messenger.ApplicationLoader")

SO_ARM64 = ""
SO_ARMV7 = ""

class NativeSorterLoader:
    def __init__(self, cache_dir: str):
        self.cache_dir = cache_dir
        self.lib = None
        self.ChatData = None
        self.SortFilterRules = None
        self._load_library()

    def _load_library(self):
        import platform
        arch = platform.machine().lower()
        log(f"[SmartFolder] Device architecture: {arch}")
        
        if not SO_ARM64 or not SO_ARMV7:
            log("[SmartFolder] Native library binaries are empty! Please pack the plugin.")
            return

        if "arm64" in arch or "aarch64" in arch:
            so_data = zlib.decompress(base64.b64decode(SO_ARM64))
            filename = "libsmart_sorter_arm64.so"
        elif "arm" in arch:
            so_data = zlib.decompress(base64.b64decode(SO_ARMV7))
            filename = "libsmart_sorter_armv7.so"
        else:
            log(f"[SmartFolder] Unknown architecture {arch}, falling back to arm64")
            so_data = zlib.decompress(base64.b64decode(SO_ARM64))
            filename = "libsmart_sorter_arm64.so"

        so_path = os.path.join(self.cache_dir, filename)
        if not os.path.exists(so_path) or os.path.getsize(so_path) != len(so_data):
            log(f"[SmartFolder] Extracting native library to {so_path}")
            with open(so_path, "wb") as f:
                f.write(so_data)

        log(f"[SmartFolder] Loading native library from {so_path}")
        self.lib = ctypes.CDLL(so_path)
        
        class ChatData(ctypes.Structure):
            _fields_ = [
                ("dialog_id", ctypes.c_int64),
                ("last_message_date", ctypes.c_int32),
                ("message_count", ctypes.c_int32),
                ("chat_type", ctypes.c_uint8),
                ("is_muted", ctypes.c_bool),
                ("in_other_folders", ctypes.c_bool),
                ("is_local_pinned", ctypes.c_bool),
                ("local_pin_order", ctypes.c_int32),
            ]
            
        class SortFilterRules(ctypes.Structure):
            _fields_ = [
                ("sort_type", ctypes.c_uint8),
                ("filter_mask", ctypes.c_uint8),
                ("only_unmuted", ctypes.c_bool),
                ("exclude_other_folders", ctypes.c_bool),
            ]
            
        self.lib.filter_and_sort_chats.argtypes = [
            ctypes.POINTER(ChatData),
            ctypes.c_int32,
            SortFilterRules,
            ctypes.POINTER(ctypes.c_int64),
        ]
        self.lib.filter_and_sort_chats.restype = ctypes.c_int32
        
        self.ChatData = ChatData
        self.SortFilterRules = SortFilterRules


class SmartFolderManagerPlugin(BasePlugin):
    def __init__(self):
        super().__init__()
        self.active_pills = weakref.WeakSet()
        self.active_sheet = None
        self.active_sheets = []
        self.db_path = ""
        self.loader = None
        self.last_sync_time = {}
        self.db_lock = threading.Lock()
        self.folder_configs_cache = {}
        self.chat_type_cache = {}
        self.mute_cache = {}
        self.excl_folders_cache = {}
        self.sorted_list_cache = {}
        self.pending_sorts = set()
        self.messages_controllers = {}
        self.dialogs_end_reached_cache = {}
        self.server_dialogs_end_reached_cache = {}
        self.loading_dialogs_cache = {}
        
        self.PillRegistry = find_class("com.exteragram.messenger.pillstack.core.PillRegistry")
        self.PillInfo = find_class("com.exteragram.messenger.pillstack.core.PillRegistry$PillInfo")
        self.PillCreator = find_class("com.exteragram.messenger.pillstack.core.PillRegistry$PillCreator")
        self.PillStackConfig = find_class("com.exteragram.messenger.pillstack.core.PillStackConfig")
        self.WeatherPill = find_class("com.exteragram.messenger.pillstack.ui.pills.weather.WeatherPill")

    def on_plugin_load(self):
        # 1. Initialize SQLite Database
        self.init_db()

        # 2. Load Native library
        cache_dir = "."
        try:
            cache_dir = str(ApplicationLoader.applicationContext.getCacheDir().getAbsolutePath())
        except Exception as e:
            self.log(f"Error getting cache dir: {e}")
        self.loader = NativeSorterLoader(cache_dir)

        # 3. Hook DialogsActivity.getDialogsArray
        try:
            DialogsActivity = find_class("org.telegram.ui.DialogsActivity")
            if DialogsActivity:
                self.hook_all_methods(DialogsActivity, "getDialogsArray", GetDialogsArrayHook(self))
                self.log("DialogsActivity.getDialogsArray hooked successfully")
        except Exception as e:
            self.log(f"Error hooking DialogsActivity: {e}")

        # 3.5 Hook LaunchActivity.onNewIntent to dismiss active sheets when notification clicked
        try:
            LaunchActivity = find_class("org.telegram.ui.LaunchActivity")
            if LaunchActivity:
                class LaunchActivityIntentHook(MethodHook):
                    def __init__(self, plugin):
                        super().__init__()
                        self.plugin = plugin
                    def before_hooked_method(self, param):
                        try:
                            if self.plugin.active_sheets:
                                def dismiss_all():
                                    try:
                                        for sheet in list(self.plugin.active_sheets):
                                            sheet.dismiss()
                                    except Exception as ex:
                                        self.plugin.log(f"Error dismissing sheet on intent: {ex}")
                                dismiss_all()
                        except Exception as e:
                            self.plugin.log(f"Error in LaunchActivityIntentHook: {e}")
                self.hook_all_methods(LaunchActivity, "onNewIntent", LaunchActivityIntentHook(self))
                self.log("LaunchActivity.onNewIntent hooked successfully")
        except Exception as e:
            self.log(f"Error hooking LaunchActivity: {e}")

        # 4. Register Header Widget (Pill)
        if not self.PillRegistry or not self.PillInfo:
            self.log("PillRegistry not found, skipping widget registration")
            return

        class FolderPillCreator(dynamic_proxy(self.PillCreator)):
            def __init__(self, plugin):
                super().__init__()
                self.plugin = plugin

            def create(self, context, resourcesProvider):
                try:
                    pill = self.plugin.WeatherPill(context, resourcesProvider)
                    pill.setTag(TAG_KEY, jint(FOLDER_PILL_ID))
                    self.plugin.active_pills.add(pill)
                    
                    # Set initial text
                    run_on_ui_thread(lambda: self.plugin.update_ui(pill))
                    return pill
                except Exception as e:
                    self.plugin.log(f"Ошибка создания виджета: {e}")
                    return None

        try:
            ctx = ApplicationLoader.applicationContext
            res = ctx.getResources()
            icon_res = res.getIdentifier("msg_folders", "drawable", ctx.getPackageName())
            if icon_res == 0:
                icon_res = res.getIdentifier("msg_settings", "drawable", ctx.getPackageName())
            
            pill_info = self.PillInfo(
                jint(FOLDER_PILL_ID), 
                "Smart Folders", 
                jint(icon_res), 
                jint(-11565578), 
                jint(-13276952), 
                FolderPillCreator(self)
            )
            self.PillRegistry.register(pill_info)
            
            class GetIdHook(MethodHook):
                def __init__(self, plugin):
                    super().__init__()
                    self.plugin = plugin
                def before_hooked_method(self, param):
                    tag = param.thisObject.getTag(TAG_KEY)
                    if tag and int(tag) == FOLDER_PILL_ID:
                        self.plugin.active_pills.add(param.thisObject)
                        param.setResult(jint(FOLDER_PILL_ID))

            class InteractionHook(MethodHook):
                def __init__(self, plugin):
                    super().__init__()
                    self.plugin = plugin
                def before_hooked_method(self, param):
                    tag = param.thisObject.getTag(TAG_KEY)
                    if tag and int(tag) == FOLDER_PILL_ID:
                        method_name = param.method.getName()
                        if method_name == "onPillClicked":
                            run_on_ui_thread(lambda: self.plugin.show_settings_sheet())
                            param.setResult(None)
                        elif method_name == "onPillLongClicked":
                            self.plugin.show_pill_menu(param.thisObject)
                            param.setResult(True)
                        elif method_name in ["onUpdateData", "setData"]:
                            self.plugin.update_ui(param.thisObject)
                            param.setResult(None)

            self.hook_all_methods(self.WeatherPill, "getPillId", GetIdHook(self))
            self.hook_all_methods(self.WeatherPill, "onPillClicked", InteractionHook(self))
            self.hook_all_methods(self.WeatherPill, "onPillLongClicked", InteractionHook(self))
            self.hook_all_methods(self.WeatherPill, "onUpdateData", InteractionHook(self))
            self.hook_all_methods(self.WeatherPill, "setData", InteractionHook(self))

            if self.PillStackConfig:
                active = self.PillStackConfig.activePills
                is_active = False
                for i in range(active.size()):
                    if int(active.get(i)) == FOLDER_PILL_ID:
                        is_active = True
                        break
                if not is_active:
                    active.add(jint(FOLDER_PILL_ID))
                    self.PillStackConfig.savePillsLayout()
                    run_on_ui_thread(self.PillStackConfig.notifySettingsChanged)

        except Exception as e:
            self.log(f"Ошибка регистрации виджета: {e}")

    def init_db(self):
        try:
            files_dir = ApplicationLoader.applicationContext.getFilesDir().getAbsolutePath()
            self.db_path = os.path.join(files_dir, "smart_folders.db")
            self.log(f"Using SQLite database at: {self.db_path}")
            
            with self.db_lock:
                conn = sqlite3.connect(self.db_path, timeout=15.0)
                cursor = conn.cursor()
                
                cursor.execute("PRAGMA table_info(folder_configs)")
                columns = [col[1] for col in cursor.fetchall()]
                
                if columns and "account_id" not in columns:
                    self.log("Upgrading database schema: dropping old folder_configs table")
                    cursor.execute("DROP TABLE folder_configs")
                    columns = []
                    
                if not columns:
                    cursor.execute("""
                        CREATE TABLE folder_configs (
                            account_id INTEGER,
                            folder_id INTEGER,
                            sort_type TEXT,
                            filter_mask INTEGER,
                            only_unmuted INTEGER,
                            exclude_other_folders INTEGER,
                            archive_days INTEGER,
                            archive_engagement INTEGER,
                            PRIMARY KEY (account_id, folder_id)
                        )
                    """)
                conn.commit()
                conn.close()
        except Exception as e:
            self.log(f"Error initializing database: {e}")

    def sync_folders_db(self, account_id):
        try:
            current_time = time.time()
            last_sync = self.last_sync_time.get(account_id, 0)
            if current_time - last_sync < 10.0:
                return
            self.last_sync_time[account_id] = current_time
            
            messagesController = find_class("org.telegram.messenger.MessagesController").getInstance(account_id)
            filters_list = messagesController.dialogFilters
            
            active_ids = set()
            for i in range(filters_list.size()):
                f = filters_list.get(i)
                fid = int(f.id)
                fname = str(f.name) if f.name is not None else ""
                fname_clean = fname.strip().upper()
                if fid == 0 or "ALL_CHATS" in fname_clean or fname_clean == "" or fname_clean == "NONE":
                    continue
                active_ids.add(fid)
                
            with self.db_lock:
                conn = sqlite3.connect(self.db_path, timeout=15.0)
                cursor = conn.cursor()
                
                cursor.execute("SELECT folder_id FROM folder_configs WHERE account_id = ? AND folder_id != 0", (account_id,))
                db_ids = {row[0] for row in cursor.fetchall()}
                
                for fid in active_ids:
                    if fid not in db_ids:
                        cursor.execute("""
                            INSERT OR IGNORE INTO folder_configs (account_id, folder_id, sort_type, filter_mask, only_unmuted, exclude_other_folders, archive_days, archive_engagement)
                            VALUES (?, ?, ?, ?, ?, ?, ?, ?)
                        """, (account_id, fid, "time_desc", 15, 0, 0, 30, 5))
                        
                for fid in db_ids:
                    if fid not in active_ids:
                        cursor.execute("DELETE FROM folder_configs WHERE account_id = ? AND folder_id = ?", (account_id, fid))
                        
                cursor.execute("SELECT 1 FROM folder_configs WHERE account_id = ? AND folder_id = 0", (account_id,))
                if not cursor.fetchone():
                    cursor.execute("""
                        INSERT OR IGNORE INTO folder_configs (account_id, folder_id, sort_type, filter_mask, only_unmuted, exclude_other_folders, archive_days, archive_engagement)
                        VALUES (?, 0, ?, ?, ?, ?, ?, ?)
                    """, (account_id, "time_desc", 15, 0, 0, 30, 5))
                    
                conn.commit()
                conn.close()
            self.log(f"Folders database synchronized for account {account_id}")
        except Exception as e:
            self.log(f"Error syncing folders database for account {account_id}: {e}")

    def get_folder_config(self, account_id, folder_id):
        cache_key = (account_id, folder_id)
        cached = self.folder_configs_cache.get(cache_key)
        if cached is not None:
            return cached
        try:
            with self.db_lock:
                conn = sqlite3.connect(self.db_path, timeout=15.0)
                cursor = conn.cursor()
                cursor.execute(
                    "SELECT sort_type, filter_mask, only_unmuted, exclude_other_folders, archive_days, archive_engagement FROM folder_configs WHERE account_id = ? AND folder_id = ?",
                    (account_id, folder_id)
                )
                row = cursor.fetchone()
                conn.close()
            if row:
                config = {
                    "sort_type": row[0],
                    "filter_mask": row[1],
                    "only_unmuted": row[2],
                    "exclude_other_folders": row[3],
                    "archive_days": row[4],
                    "archive_engagement": row[5]
                }
                self.folder_configs_cache[cache_key] = config
                self.update_dialog_flags(account_id, folder_id, config["filter_mask"] == 0)
                return config
        except Exception as e:
            self.log(f"Error loading config: {e}")
        # Default fallback
        fallback = {
            "sort_type": "time_desc",
            "filter_mask": 15,
            "only_unmuted": 0,
            "exclude_other_folders": 0,
            "archive_days": 30,
            "archive_engagement": 5
        }
        self.update_dialog_flags(account_id, folder_id, False)
        return fallback

    def update_dialog_flags(self, account_id, folder_id, end_reached):
        try:
            der = self.dialogs_end_reached_cache.get(account_id)
            sder = self.server_dialogs_end_reached_cache.get(account_id)
            ld = self.loading_dialogs_cache.get(account_id)
            
            if der is None or sder is None or ld is None:
                messagesController = self.messages_controllers.get(account_id)
                if messagesController is None:
                    messagesController = find_class("org.telegram.messenger.MessagesController").getInstance(account_id)
                    self.messages_controllers[account_id] = messagesController
                
                if der is None:
                    der = get_private_field(messagesController, "dialogsEndReached")
                    self.dialogs_end_reached_cache[account_id] = der
                if sder is None:
                    sder = get_private_field(messagesController, "serverDialogsEndReached")
                    self.server_dialogs_end_reached_cache[account_id] = sder
                if ld is None:
                    ld = get_private_field(messagesController, "loadingDialogs")
                    self.loading_dialogs_cache[account_id] = ld
            
            if der:
                der.put(folder_id, end_reached)
            if sder:
                sder.put(folder_id, end_reached)
            if ld and not end_reached:
                ld.put(folder_id, False)
            self.log(f"[SmartFolder] Updated dialog flags for folder {folder_id}: end_reached={end_reached}")
        except Exception as e:
            self.log(f"[SmartFolder] Error updating dialog flags: {e}")

    def save_folder_config(self, account_id, folder_id, config):
        cache_key = (account_id, folder_id)
        self.log(f"[SmartFolder] save_folder_config: account {account_id}, folder {folder_id}, config: {config}")
        self.folder_configs_cache[cache_key] = config
        self.sorted_list_cache.pop(cache_key, None)
        self.update_dialog_flags(account_id, folder_id, config["filter_mask"] == 0)
        try:
            with self.db_lock:
                conn = sqlite3.connect(self.db_path, timeout=15.0)
                cursor = conn.cursor()
                cursor.execute("""
                    INSERT INTO folder_configs (account_id, folder_id, sort_type, filter_mask, only_unmuted, exclude_other_folders, archive_days, archive_engagement)
                    VALUES (?, ?, ?, ?, ?, ?, ?, ?)
                    ON CONFLICT(account_id, folder_id) DO UPDATE SET
                        sort_type = excluded.sort_type,
                        filter_mask = excluded.filter_mask,
                        only_unmuted = excluded.only_unmuted,
                        exclude_other_folders = excluded.exclude_other_folders,
                        archive_days = excluded.archive_days,
                        archive_engagement = excluded.archive_engagement
                """, (
                    account_id,
                    folder_id,
                    config["sort_type"],
                    config["filter_mask"],
                    config["only_unmuted"],
                    config["exclude_other_folders"],
                    config["archive_days"],
                    config["archive_engagement"]
                ))
                conn.commit()
                conn.close()
        except Exception as e:
            self.log(f"Error saving config: {e}")

    def reload_dialogs(self):
        try:
            UserConfig = find_class("org.telegram.messenger.UserConfig")
            NotificationCenter = find_class("org.telegram.messenger.NotificationCenter")
            currentAccount = UserConfig.selectedAccount
            run_on_ui_thread(lambda: NotificationCenter.getInstance(currentAccount).postNotificationName(NotificationCenter.dialogsNeedReload))
        except Exception as e:
            self.log(f"Error reloading dialogs: {e}")

    def update_ui(self, pill):
        try:
            tv = get_private_field(pill, "textView")
            if tv:
                tv.setText(self._get_string("widget_folders_title"))
            
            iv = get_private_field(pill, "iconView")
            if iv:
                ctx = pill.getContext()
                res = ctx.getResources()
                icon_res = res.getIdentifier("msg_folders", "drawable", ctx.getPackageName())
                if icon_res == 0:
                    icon_res = res.getIdentifier("msg_settings", "drawable", ctx.getPackageName())
                if icon_res != 0:
                    iv.setImageResource(icon_res)
        except Exception as e:
            self.log(f"Ошибка обновления UI виджета: {e}")

    def show_pill_menu(self, pill):
        try:
            LaunchActivity = find_class("org.telegram.ui.LaunchActivity")
            fragment = LaunchActivity.getSafeLastFragment()
            if not fragment: return

            ItemOptions = find_class("org.telegram.ui.Components.ItemOptions")
            if not ItemOptions: return

            ctx = ApplicationLoader.applicationContext
            res = ctx.getResources()
            pkg = ctx.getPackageName()
            
            icon_settings = res.getIdentifier("msg_settings", "drawable", pkg)

            options = ItemOptions.makeOptions(fragment, pill)
            
            class OpenSettingsRunnable(dynamic_proxy(find_class("java.lang.Runnable"))):
                def __init__(self, plugin):
                    super().__init__()
                    self.plugin = plugin
                def run(self):
                    run_on_ui_thread(lambda: self.plugin.show_settings_sheet())

            options.add(jint(icon_settings), self._get_string("menu_sorting_settings"), OpenSettingsRunnable(self))
            options.setDrawScrim(False).setDimAlpha(jint(0)).show()
        except Exception as e:
            self.log(f"Ошибка отображения меню: {e}")

    def show_settings_sheet(self):
        try:
            LaunchActivity = find_class("org.telegram.ui.LaunchActivity")
            fragment = LaunchActivity.getSafeLastFragment()
            if not fragment:
                self.log("Не удалось найти последний фрагмент для открытия BottomSheet")
                return
            
            act = fragment.getParentActivity()
            if not act:
                self.log("Родительская активность отсутствует")
                return
            
            sheet = FolderManagerSheet(self, act)
            sheet.show()
            self.active_sheet = sheet
            self.active_sheets.append(sheet)
        except Exception as e:
            self.log(f"Ошибка при показе BottomSheet: {e}\n{traceback.format_exc()}")

    def get_current_active_folder_id(self):
        try:
            LaunchActivity = find_class("org.telegram.ui.LaunchActivity")
            fragment = LaunchActivity.getSafeLastFragment()
            if not fragment:
                self.log("[SmartFolder] get_current_active_folder_id: fragment is None")
                return 0
            
            frag_class_name = str(fragment.getClass().getName())
            self.log(f"[SmartFolder] get_current_active_folder_id: fragment class is {frag_class_name}")
            
            dialogs_activity = None
            if "MainTabsActivity" in frag_class_name:
                try:
                    dialogs_activity = fragment.getDialogsActivity()
                except Exception:
                    pass
                if not dialogs_activity:
                    dialogs_activity = get_private_field(fragment, "dialogsActivity")
            elif "DialogsActivity" in frag_class_name:
                dialogs_activity = fragment
                
            if not dialogs_activity:
                self.log("[SmartFolder] get_current_active_folder_id: dialogs_activity not found")
                return 0
                
            selected_type_val = None
            filterTabsView = get_private_field(dialogs_activity, "filterTabsView")
            if filterTabsView:
                try:
                    selected_type_val = filterTabsView.getCurrentTabId()
                    self.log(f"[SmartFolder] get_current_active_folder_id: got selected tab index from filterTabsView: {selected_type_val}")
                except Exception as ex:
                    self.log(f"[SmartFolder] get_current_active_folder_id: error calling getCurrentTabId: {ex}")
            
            if selected_type_val is None:
                viewPages = get_private_field(dialogs_activity, "viewPages")
                if viewPages:
                    view_page = None
                    try:
                        view_page = viewPages[0]
                    except Exception:
                        pass
                    if view_page:
                        selected_type_val = get_private_field(view_page, "selectedType")
                        self.log(f"[SmartFolder] get_current_active_folder_id: got selected tab index from viewPages[0]: {selected_type_val}")
            
            if selected_type_val is not None:
                idx = int(selected_type_val)
                UserConfig = find_class("org.telegram.messenger.UserConfig")
                currentAccount = UserConfig.selectedAccount
                messagesController = find_class("org.telegram.messenger.MessagesController").getInstance(currentAccount)
                filters = messagesController.getDialogFilters()
                if idx >= 0 and idx < filters.size():
                    dialogFilter = filters.get(idx)
                    fid = int(dialogFilter.id)
                    self.log(f"[SmartFolder] get_current_active_folder_id: resolved index {idx} to folder ID {fid}")
                    return fid
                else:
                    self.log(f"[SmartFolder] get_current_active_folder_id: index {idx} is out of bounds for filters size {filters.size()}")
                
        except Exception as e:
            self.log(f"Error getting current active folder ID: {e}\n{traceback.format_exc()}")
        return 0

    def scan_inactive_chats(self, folder_id, days_limit, engagement_limit):
        try:
            UserConfig = find_class("org.telegram.messenger.UserConfig")
            currentAccount = UserConfig.selectedAccount
            messagesController = find_class("org.telegram.messenger.MessagesController").getInstance(currentAccount)
            
            if folder_id == 0:
                dialogs = messagesController.getDialogs(0)
            else:
                dialogFilter = messagesController.dialogFiltersById.get(folder_id)
                dialogs = dialogFilter.dialogs if dialogFilter else messagesController.getDialogs(0)
                
            files_dir = str(ApplicationLoader.applicationContext.getFilesDir().getAbsolutePath())
            if currentAccount != 0:
                db_file = os.path.join(files_dir, f"account{currentAccount}", "cache4.db")
            else:
                db_file = os.path.join(files_dir, "cache4.db")
                
            self.log(f"[SmartFolder] Opening database: {db_file}")
            conn = sqlite3.connect(db_file)
            cursor = conn.cursor()
            
            current_time = time.time()
            inactive_list = []
            
            for i in range(dialogs.size()):
                dialog = dialogs.get(i)
                dialog_id = dialog.id
                
                # Skip archived dialogs
                if dialog.folder_id == 1:
                    continue
                    
                days_since = (current_time - dialog.last_message_date) / 86400.0
                
                if days_since >= days_limit:
                    try:
                        cursor.execute(
                            "SELECT out FROM messages_v2 WHERE uid = ? ORDER BY date DESC LIMIT 50",
                            (dialog_id,)
                        )
                        rows = cursor.fetchall()
                        total = len(rows)
                        if total > 0:
                            our_msgs = sum(1 for (out_val,) in rows if out_val == 1)
                            engagement = (our_msgs / total) * 100.0
                        else:
                            engagement = 0.0
                    except Exception:
                        engagement = 0.0
                        
                    if engagement <= engagement_limit:
                        name = ""
                        initials = ""
                        avatar_color = 0xFF5085B1
                        
                        if dialog_id > 0:
                            user = messagesController.getUser(dialog_id)
                            if user:
                                name = f"{user.first_name or ''} {user.last_name or ''}".strip()
                                if not name:
                                    name = user.username or "User"
                                initials = name[0].upper() if name else "U"
                        else:
                            chat = messagesController.getChat(-dialog_id)
                            if chat:
                                name = chat.title or "Group"
                                initials = name[0].upper() if name else "G"
                                avatar_color = 0xFFE57373
                                
                        inactive_list.append({
                            "id": dialog_id,
                            "name": name,
                            "desc": self._get_string("archiver_chat_desc").format(days=int(days_since), engagement=int(engagement)),
                            "initials": initials,
                            "avatar_color": avatar_color
                        })
            conn.close()
            return inactive_list
        except Exception as e:
            self.log(f"Error scanning inactive chats: {e}\n{traceback.format_exc()}")
            return []

    def create_settings(self) -> List[Any]:
        from ui.settings import Header, Switch, Divider, Text, Selector
        return [
            Header(self._get_string("settings_header")),
            Switch("enable_pill", self._get_string("enable_pill_text"), True, on_change=lambda v: self.set_setting("enable_pill", v)),
            Divider(),
	    Selector(
                key="lang",
                text=self._get_string("lang_select_text"),
                default=int(self.get_setting("lang", 0) or 0),
                icon="msg_language",
                items=["Авто (Auto)", "Русский", "English"],
                on_change=self._on_lang_change
            ),
            Divider(),
            Header(text=self._get_string("more_plugins_text")),
            Text(
                text=self._get_string("author_channel_text"),
                icon="msg_reactions_filled_solar",
                on_click=self._open_author_channel
            )
        ]

    def _on_lang_change(self, val):
        self.set_setting("lang", int(val), reload_settings=True)

    def _open_author_channel(self, _=None):
        try:
            Browser = find_class("org.telegram.messenger.browser.Browser")
            Browser.openUrl(ApplicationLoader.applicationContext, "https://anivdev.t.me")
        except Exception as e:
            self.log(f"open channel error: {e}")

    def _get_string(self, key):
        lang_pref = int(self.get_setting("lang", 0) or 0)
        if lang_pref == 0:
            try:
                LocaleController = find_class("org.telegram.messenger.LocaleController")
                lang = LocaleController.getInstance().getCurrentLocaleInfo().getLangCode().lower()
            except Exception:
                try:
                    Locale = find_class("java.util.Locale")
                    lang = Locale.getDefault().getLanguage().lower()
                except Exception:
                    lang = "en"
