CORE_EXTENSION = ".core"
CORE_FORMAT = "core"
CORE_FORMAT_VERSION = 1
LOADER_VERSION = 1
MIN_DEX_BYTES = 512
MAX_CORE_BYTES = 16 * 1024 * 1024
MAX_MANIFEST_BYTES = 128 * 1024
SHA256_HEX_LENGTH = 64
CORE_FILE_ICON = 16
FALLBACK_DEX_DIR_SUFFIX = "_dex"
CORE_STORE_MARKER = ".core-loader-store"
CORE_FILE_ALIASES = ("BotLogin", "Bot Login")

ENTRY_CLASS = "com.extera.plugins.botlogin.BotLoginCore"

CORE_ERROR_MESSAGES = {
    "app_too_old": "client version is too old for this core",
    "core_file_too_large": "core file is too large",
    "core_not_installed": "core is not installed",
    "core_version_mismatch": "core version does not match manifest",
    "invalid_dex_magic": "invalid DEX file",
    "invalid_sha256": "invalid DEX sha256 in manifest",
    "loader_too_old": "plugin loader is too old for this core",
    "missing_core_file": "core file is missing",
    "missing_dex": "core package does not contain DEX",
    "missing_manifest": "core package does not contain manifest",
    "plugin_too_old": "plugin version is too old for this core",
    "sha256_mismatch": "DEX sha256 mismatch",
    "wrong_core_format": "wrong core format",
    "wrong_entry_class": "core entry class does not match this plugin",
    "wrong_plugin_id": "core belongs to another plugin",
}

