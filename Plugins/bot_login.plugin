import base64
import zlib

from android_utils import run_on_ui_thread
from base_plugin import BasePlugin
from client_utils import get_last_fragment
from ui.bulletin import BulletinHelper
from ui.settings import Header, Text

from java import jclass
from org.telegram.messenger import ApplicationLoader

__id__ = "bot_login"
__name__ = "Bot Login"
__description__ = "Log in to bot accounts using their API token.\nUse plugin settings or open the login page, tap the three-dot menu, and choose \"Log in as bot\"."
__author__ = "@kvucoPlugins"
__version__ = "1.3"
__icon__ = "PISUN424242/9"
__app_version__ = ">= 12.5.1"
__sdk_version__ = ">=1.4.3.3"

ENTRY_CLASS = "com.extera.plugins.botlogin.BotLoginCore"
DEX_BEGIN = "__DEX_BEGIN__"
DEX_END = "__DEX_END__"


def show_error_ui(message):
    run_on_ui_thread(lambda: BulletinHelper.show_error(str(message)))


class Dex:
    def __init__(self, entry_class):
        self.entry_class = entry_class
        self.clazz = None

    def load(self):
        if self.clazz is not None:
            return
        ctx = ApplicationLoader.applicationContext
        if ctx is None:
            raise RuntimeError("application context is not ready")
        ByteBuffer = jclass("java.nio.ByteBuffer")
        InMemoryDexClassLoader = jclass("dalvik.system.InMemoryDexClassLoader")
        loader = InMemoryDexClassLoader(ByteBuffer.wrap(self._read_payload()), ctx.getClassLoader())
        self.clazz = loader.loadClass(self.entry_class)
        try:
            self.call("load")
        except Exception:
            try:
                self.call("unload")
            except Exception:
                pass
            self.clazz = None
            raise

    def unload(self):
        try:
            if self.clazz is not None:
                self.call("unload")
        except Exception:
            pass
        self.clazz = None

    def call(self, method_name, *args):
        if self.clazz is None:
            self.load()
        matches = []
        for method in self.clazz.getDeclaredMethods():
            if str(method.getName()) != method_name or len(method.getParameterTypes()) != len(args):
                continue
            method.setAccessible(True)
            matches.append(method)
        if len(matches) > 1:
            raise RuntimeError(f"ambiguous core method: {method_name}/{len(args)}")
        if matches:
            return matches[0].invoke(None, *args)
        raise RuntimeError(f"core method not found: {method_name}/{len(args)}")

    def _read_payload(self):
        try:
            text = open(__file__, "r", encoding="utf-8").read()
            block = text.split(f"# {DEX_BEGIN}", 1)[1].split(f"# {DEX_END}", 1)[0]
            payload = "".join(line.strip()[1:].strip() for line in block.splitlines() if line.strip().startswith("#"))
        except Exception as exc:
            raise RuntimeError(f"embedded dex read failed: {exc}")

        if not payload:
            raise RuntimeError("embedded dex payload not found")

        try:
            dex_bytes = zlib.decompress(base64.b64decode(payload))
        except Exception as exc:
            raise RuntimeError(f"embedded dex decode failed: {exc}")

        return dex_bytes


class BotLoginPlugin(BasePlugin):
    def __init__(self):
        super().__init__()
        self.dex = None

    def on_plugin_load(self):
        self.dex = Dex(ENTRY_CLASS)
        self._load_core(show_error=True)

    def on_plugin_unload(self):
        if self.dex:
            self.dex.unload()
            self.dex = None

    def open_bot_login(self, view=None):
        if not self._load_core(show_error=True):
            return
        fragment = get_last_fragment()
        if fragment is None:
            show_error_ui("No active screen to open Bot Login")
            return
        try:
            self.dex.call("openBotLogin", fragment)
        except Exception as exc:
            self.log(f"openBotLogin failed: {exc}")
            show_error_ui(f"Bot Login failed: {exc}")

    def create_settings(self):
        items = [
            Header(text="Bot Login"),
            Text(text="Log in as bot", icon="menu_bots_add", accent=True, on_click=self.open_bot_login),
        ]
        return items

    def _load_core(self, show_error=False):
        if self.dex is None:
            self.dex = Dex(ENTRY_CLASS)
        try:
            self.dex.load()
            return True
        except Exception as exc:
            self.log(f"Embedded DEX load failed: {exc}")
            if show_error:
                show_error_ui(f"Bot Login core load failed: {exc}")
            return False


