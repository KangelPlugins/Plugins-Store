        ]

    def _create_header_settings(self):
        return [
            Header(text="=== 🎩 ЗАГОЛОВОК ЧАТА ==="),
            Switch(key="h_md3_container", text="🏷️ Контейнер: Имя чата", default=True, on_change=self._on_setting_change),
            Switch(key="h_md3_avatar", text="👤 Контейнер: Аватарка", default=True, on_change=self._on_setting_change),
            Switch(key="h_md3_back", text="⬅️ Контейнер: Кнопка 'Назад'", default=True, on_change=self._on_setting_change),
            Divider(),
            Switch(key="h_full_profile_click", text="🪪 Открывать полный профиль по тапу", default=True, subtext="При нажатии на имя будет красиво раскрываться аватар", on_change=self._on_setting_change),
            Switch(key="h_long_press_search", text="🔍 Удержание: Открыть Поиск", default=True, subtext="Удерживайте палец на заголовке, чтобы начать поиск по чату", on_change=self._on_setting_change),
            Switch(key="h_online_badge", text="🟢 Индикатор 'В сети' (Вырез)", default=True, on_change=self._on_setting_change),
            Switch(key="h_online_badge_groups", text="👥 Онлайн индикатор в группах", default=False, subtext="Работает только тогда, когда кто то из группы замечен в сети", on_change=self._on_setting_change),
            Switch(key="h_static_back_icon", text="🛑 Статичная кнопка 'Назад'", default=True, subtext="Убирает лагающую анимацию стрелки", on_change=self._on_setting_change),
            Divider(),
            Header(text="🎨 Индивидуальные Цвета Заголовка"),
            Text(text="🏷️ Настроить: Имя чата", subtext="Цвет, прозрачность, обводка", create_sub_fragment=self._create_ht_settings),
            Text(text="👤 Настроить: Аватарка", subtext="Цвет, прозрачность, обводка", create_sub_fragment=self._create_ha_settings),
            Text(text="⬅️ Настроить: Кнопка 'Назад'", subtext="Цвет, прозрачность, обводка", create_sub_fragment=self._create_hb_settings),
            Divider(),
            Header(text="Размеры и Отступы Заголовка"),
            Input(key="h_corner_radius", text="📐 Скругление углов (в dp)", default="25", on_change=self._on_setting_change),
            Input(key="h_avatar_bg_size", text="🖼️ Размер контейнера Аватарки (в dp)", default="25", on_change=self._on_setting_change),
            Input(key="h_back_inset_v", text="↕️ Сжать контейнер Назад (По высоте)", default="10", on_change=self._on_setting_change),
            Input(key="h_back_inset_h", text="↔️ Сжать контейнер Назад (По ширине)", default="5", on_change=self._on_setting_change),
            Input(key="h_top_margin", text="🔝 Отступ всего заголовка сверху", default="0", on_change=self._on_setting_change),
        ]

    def _create_emoji_settings(self):
        return [
            Header(text="😈 Кнопка Эмодзи/стикеров"),
            Switch(key="e_md3_container", text="👁️ Включить контейнер", default=True, on_change=self._on_setting_change),
            Selector(key="e_color_preset", text="🎨 Цвет", items=COLOR_OPTIONS, default=0, on_change=self._on_setting_change),
            Selector(key="e_opacity_preset", text="💧 Насыщенность", items=TINT_OPTIONS, default=5, on_change=self._on_setting_change),
            Selector(key="e_alpha_preset", text="👻 Прозрачность", items=ALPHA_OPTIONS, default=2, on_change=self._on_setting_change),
            Input(key="e_custom_hex", text="✍️ Свой HEX", default="", on_change=self._on_setting_change),
            Divider(),
            Switch(key="e_stroke_enabled", text="✨ Включить обводку", default=True, on_change=self._on_setting_change),
            Selector(key="e_stroke_color", text="🖌️ Цвет обводки", items=COLOR_OPTIONS, default=0, on_change=self._on_setting_change),
            Selector(key="e_stroke_opacity", text="💦 Насыщенность обводки", items=TINT_OPTIONS, default=5, on_change=self._on_setting_change),
            Input(key="e_stroke_width", text="📏 Толщина (в dp)", default="1", on_change=self._on_setting_change),
            Input(key="e_btn_bg_size", text="🔲 Размер контейнера (в dp)", default="20", on_change=self._on_setting_change),
        ]

    def _create_panel_settings(self):
        return [
            Header(text="=== ⌨️ НИЖНЯЯ ПАНЕЛЬ И ВВОД ==="),
            Switch(key="p_stroke_enabled", text="💬 Обводка панели ввода", default=True, on_change=self._on_setting_change),
            Selector(key="p_stroke_color", text="🖌️ Цвет обводки", items=COLOR_OPTIONS, default=0, on_change=self._on_setting_change),
            Selector(key="p_stroke_opacity", text="💧 Насыщенность", items=TINT_OPTIONS, default=5, on_change=self._on_setting_change),
            Input(key="p_stroke_hex", text="✍️ Свой HEX", default="", on_change=self._on_setting_change),
            Input(key="p_stroke_width", text="📏 Толщина (в dp)", default="1", on_change=self._on_setting_change),
            Input(key="p_corner_radius", text="📐 Скругление углов (в dp)", default="25", on_change=self._on_setting_change),
            Divider(),
            Header(text="Отступы панели (Margins)"),
            Input(key="p_margin_left", text="⬅️ Слева (в dp)", default="0", on_change=self._on_setting_change),
            Input(key="p_margin_right", text="➡️ Справа (в dp)", default="0", on_change=self._on_setting_change),
            Input(key="p_margin_top", text="⬆️ Сверху (в dp)", default="10", on_change=self._on_setting_change),
            Input(key="p_margin_bottom", text="⬇️ Снизу (в dp)", default="0", on_change=self._on_setting_change),
            Divider(),
            Text(text="🙂 Настроить: Кнопка Эмодзи", subtext="Цвета, обводка, размер", create_sub_fragment=self._create_emoji_settings),
        ]

    def _create_system_settings(self):
        return [
            Header(text="Каналы"),
            Switch(key="channel_gifts_enabled", text="🎁 Показ подарка у каналов", default=True, subtext="Динамически показывает/скрывает кнопку подарка", on_change=self._on_setting_change),
            Divider(),
            Header(text="Сброс"),
            Input(key="reset_trigger", text="⚠️ Сброс настроек (введите 'да')", default="", subtext="Введите 'да' и выйдите из поля", on_change=self._on_setting_change)
        ]

    def get_settings(self):
        return [
            Header(text="=== 🌐 ГЛОБАЛЬНЫЕ НАСТРОЙКИ ==="),
            Switch(key="use_monet", text="🎨 Использовать цвета системы (Monet)", default=False, subtext="Авто-подстройка под обои (Android 12+). Игнорирует ручные цвета.", on_change=self._on_setting_change),
            Divider(),
            Header(text="=== РАЗДЕЛЫ ИНТЕРФЕЙСА ==="),
            Text(text="💬 Список чатов", subtext="Настройка списков и диалогов", create_sub_fragment=self._create_chatlist_settings),
            Text(text="🎩 Заголовок (Шапка)", subtext="Настройка шапки внутри чата", create_sub_fragment=self._create_header_settings),
            Text(text="⌨️ Нижняя панель и ввод", subtext="Панель ввода и кнопка эмодзи", create_sub_fragment=self._create_panel_settings),
            Divider(),
            Header(text="=== СИСТЕМА ==="),
            Text(text="⚙️ Прочее и Система", subtext="Доп. настройки и сброс плагина", create_sub_fragment=self._create_system_settings),
        ]

    def create_settings(self):
        return self.get_settings()
