    def get_cached_view(self, obj, field, default_name, obj_hash=None):
        if not obj: return None
        if obj_hash is None: obj_hash = obj.hashCode()
        cache_key = (obj_hash, default_name)
        cached = self._view_cache.get(cache_key)
        if cached is not None:
            view = cached() if type(cached) is weakref.ref else cached
            if view is not None: return view
        if len(self._view_cache) > 500: self._view_cache.clear()
        view = None
        if field is not None:
            try: view = field.get(obj)
            except: pass
        if view is None and default_name:
            try: view = get_private_field(obj, default_name)
            except: pass
        if view is not None:
            try: self._view_cache[cache_key] = weakref.ref(view)
            except TypeError: self._view_cache[cache_key] = view
        else: self._view_cache[cache_key] = None
        return view

    def fast_get(self, field, obj, default_name=None):
        if field is not None:
            try: return field.get(obj)
            except: pass
        if default_name:
            try: return get_private_field(obj, default_name)
            except: pass
        return None

    def _get_field(self, clazz, name):
        try:
            f = clazz.getDeclaredField(name)
            f.setAccessible(True)
            return f
        except: return None

