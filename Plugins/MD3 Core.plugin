_class_cache = {}

def safe_find_class(class_name):
    if class_name in _class_cache: return _class_cache[class_name]
    try:
        cls = find_class(class_name)
        _class_cache[class_name] = cls
        return cls
    except:
        _class_cache[class_name] = None
        return None

def _get_first_available_field(obj, *names):
    if not obj or not names: return None
    for name in names:
        try:
            v = getattr(obj, name, None)
            if v is not None: return v
        except: pass
        try:
            v = get_private_field(obj, name)
            if v is not None: return v
        except: pass
    return None

def _truthy_fragment_flag(raw):
    if raw is None: return False
    try:
        if callable(raw): raw = raw()
        return bool(raw)
    except: return False

def _safe_int(x, default=0):
    if x is None: return default
    if isinstance(x, int): return x
    try: return int(x)
    except (ValueError, TypeError): return default

def _is_me(plugin, parentFragment, container, UserConfig):
    if not parentFragment or not UserConfig: return False
    try:
        frag_hash = parentFragment.hashCode()
        res = plugin._is_me_cache.get(frag_hash)
        if res is not None: return res
        if len(plugin._is_me_cache) > 500: plugin._is_me_cache.clear()

        dialog_id = parentFragment.getDialogId()
        acc = -1
        if plugin.f_currentAccount:
            acc = _safe_int(plugin.f_currentAccount.get(container), -1)
        if acc < 0:
            acc = _safe_int(get_private_field(container, "currentAccount"), -1)
            
        if acc >= 0: me = UserConfig.getInstance(acc).getClientUserId()
        else:
            selected = _safe_int(UserConfig.selectedAccount, -1)
            me = UserConfig.getInstance(selected).getClientUserId() if selected >= 0 else -1
            
        res = (dialog_id == me)
        plugin._is_me_cache[frag_hash] = res
        return res
    except Exception: pass
    return False

def _is_search_active(plugin, action_bar):
    if not action_bar or not plugin.ActionBarMenuItemClass: return False
    try:
        ab_hash = action_bar.hashCode()
        cached = plugin._actionbar_search_item_cache.get(ab_hash)
        search_item = cached() if type(cached) is weakref.ref else (cached if cached is False else None)
        
        if search_item is None:
            for i in range(action_bar.getChildCount()):
                child = action_bar.getChildAt(i)
                if child and "Menu" in child.getClass().getSimpleName(): 
                    for j in range(child.getChildCount()):
                        item = child.getChildAt(j)
                        if isinstance(item, plugin.ActionBarMenuItemClass):
                            search_item = item
                            break
                if search_item: break
            
            if len(plugin._actionbar_search_item_cache) > 100: plugin._actionbar_search_item_cache.clear()
            if search_item:
                try: plugin._actionbar_search_item_cache[ab_hash] = weakref.ref(search_item)
                except TypeError: plugin._actionbar_search_item_cache[ab_hash] = search_item
            else: plugin._actionbar_search_item_cache[ab_hash] = False
            
        if search_item:
            try:
                res = search_item.isSearchFieldVisible() if hasattr(search_item, "isSearchFieldVisible") else getattr(search_item, "isSearchFieldVisible")
                if bool(res): return True
            except Exception: pass
            
            sf = plugin.fast_get(None, search_item, "searchField")
            if sf and sf.getVisibility() == 0: return True
    except Exception: pass
    return False

class _HeaderDispatchTouchHook(MethodHook):
    def __init__(self, plugin): 
        self.plugin = plugin
        self.down_time = 0
        self.down_x = 0
        self.down_y = 0
        self.long_clicked = False
        self.task_id = 0

    def before_hooked_method(self, param):
        try:
            event = param.args[0]
            if not event: return
            
            this = param.thisObject
            this_hash = this.hashCode()
            p = self.plugin
            
            if p.h_long_press_search:
                action = event.getActionMasked()
                x, y = event.getX(), event.getY()
                
                if action == 0:
                    self.down_time = time.time()
                    self.down_x = x
                    self.down_y = y
                    self.long_clicked = False
                    self.task_id += 1
                    current_task = self.task_id
                    
                    def trigger_search():
                        if self.task_id == current_task and self.down_time > 0:
                            self.long_clicked = True
                            try: this.performHapticFeedback(0)
                            except: pass
                            
                            ab = None
                            parent = this.getParent()
                            for _ in range(5):
                                if not parent: break
                                if isinstance(parent, p.ActionBar):
                                    ab = parent
                                    break
                                try: parent = parent.getParent()
                                except: break
                                
                            if ab:
                                search_item = None
                                cached = p._actionbar_search_item_cache.get(ab.hashCode())
                                if cached is not None:
                                    search_item = cached() if type(cached) is weakref.ref else (cached if cached is False else None)

                                if not search_item:
                                    for i in range(ab.getChildCount()):
                                        child = ab.getChildAt(i)
                                        if child and "Menu" in child.getClass().getSimpleName():
                                            for j in range(child.getChildCount()):
                                                item = child.getChildAt(j)
                                                if isinstance(item, p.ActionBarMenuItemClass):
                                                    search_item = item
                                                    break
                                        if search_item: break
                                    if search_item:
                                        try: p._actionbar_search_item_cache[ab.hashCode()] = weakref.ref(search_item)
                                        except TypeError: p._actionbar_search_item_cache[ab.hashCode()] = search_item
                                
                                if search_item:
                                    opened = False
                                    for method in ("openSearch", "toggleSearch"):
                                        try:
                                            meth = search_item.getClass().getMethod(method, jclass("boolean"))
                                            meth.invoke(search_item, True)
                                            opened = True
                                            break
                                        except:
                                            try:
                                                meth = search_item.getClass().getMethod(method)
                                                meth.invoke(search_item)
                                                opened = True
                                                break
                                            except: pass
                                    if not opened:
                                        try: search_item.callOnClick()
                                        except: pass

                    run_on_ui_thread(trigger_search, 400)
                    
                elif action == 2:
                    if self.down_time > 0:
                        dx = x - self.down_x
                        dy = y - self.down_y
                        if dx * dx + dy * dy > 2500:
                            self.down_time = 0
                            
                elif action == 1 or action == 3:
                    self.down_time = 0
                    if self.long_clicked:
                        self.long_clicked = False
                        param.setResult(True)
                        return

            avatar = p.get_cached_view(this, p.f_avatar, "avatarImageView", this_hash)
            if not avatar or avatar.getVisibility() == 8: return

            x, y = event.getX(), event.getY()
            a_left, a_right = avatar.getLeft(), avatar.getRight()
            a_top, a_bottom = avatar.getTop(), avatar.getBottom()
            
            if (a_left <= x <= a_right) and (a_top <= y <= a_bottom):
                if event.getAction() == 1: 
                    pf = p.get_cached_view(this, p.f_parentFragment, "parentFragment", this_hash)
                    if pf:
                        headerItem = get_private_field(pf, "headerItem")
                        if headerItem: headerItem.toggleSubMenu()
                param.setResult(True)
                return
            elif p.h_full_profile_click:
                event.setLocation(a_left + (a_right - a_left) * 0.5, a_top + (a_bottom - a_top) * 0.5)
        except Exception: pass

class _ThemeApplyHook(MethodHook):
    def __init__(self, plugin): self.plugin = plugin
    def after_hooked_method(self, param):
        self.plugin._force_recalc = True
        self.plugin._force_redraw()

class ChannelDynamicGiftHook(MethodHook):
    def __init__(self, plugin):
        super().__init__()
        self.plugin = plugin
        self.active_btns = {}  

    def before_hooked_method(self, param):
        if not self.plugin.channel_gifts_enabled or not param.args or len(param.args) < 2: return
        btn_id = param.args[0]
        self.active_btns[btn_id] = bool(param.args[1])
        if btn_id == 1:
            if self.active_btns.get(2, False): param.args[1] = False
            elif self.active_btns.get(0, False): param.args[1] = True

class ActionBarSetBackHook(MethodHook):
    def __init__(self, plugin): self.plugin = plugin
    def before_hooked_method(self, param):
        if not self.plugin.h_static_back_icon: return
        try:
            drawable = param.args[0]
            if drawable and "BackDrawable" in drawable.getClass().getSimpleName():
                p = self.plugin
                if not hasattr(p, 'ic_ab_back_id'):
                    p.ic_ab_back_id = getattr(find_class("org.telegram.messenger.R$drawable"), "ic_ab_back")
                static_drawable = param.thisObject.getContext().getResources().getDrawable(p.ic_ab_back_id).mutate()
                if static_drawable: param.args[0] = static_drawable
        except Exception: pass

class EnterViewDispatchDrawHook(MethodHook):
    def __init__(self, plugin): self.plugin = plugin
    def before_hooked_method(self, param):
        p = self.plugin
        if not p.e_md3_enabled and not p.e_stroke_enabled and not p.p_stroke_enabled: return

        try:
            this = param.thisObject
            canvas = param.args[0]
            if p._force_recalc: p._check_theme_colors()
            
            this_hash = this.hashCode()
            is_bot = p._bot_chat_cache.get(this_hash)
            
            if is_bot is None:
                is_bot = False
                try:
                    acc = _safe_int(p.fast_get(p.f_currentAccount, this, "currentAccount"), -1)
                    dialog_id = get_private_field(this, "dialog_id")
                    if acc >= 0 and dialog_id is not None:
                        did = int(dialog_id)
                        if did > 0 and p.MessagesController:
                            user = p.MessagesController.getInstance(acc).getUser(did)
                            if user and getattr(user, 'bot', False): is_bot = True
                except Exception: pass
                if len(p._bot_chat_cache) > 200: p._bot_chat_cache.clear()
                p._bot_chat_cache[this_hash] = is_bot

            w, h = this.getWidth(), this.getHeight()
            
            if is_bot or (p.p_stroke_enabled and p.p_border_paint):
                if w > 0 and h > 0:
                    has_top_panel = False
                    for field_name in ("replyLayout", "linkPreviewLayout", "topView"):
                        try:
                            panel_view = p.get_cached_view(this, None, field_name, this_hash)
                            if panel_view and panel_view.getVisibility() == 0 and panel_view.getHeight() > 0:
                                has_top_panel = True
                                break
                        except Exception: pass
                        
                    actual_top = p.p_m_top
                    try:
                        if hasattr(this, "getBackgroundTop"):
                            actual_top = max(p.p_m_top, float(this.getBackgroundTop()))
                    except Exception: pass

                    current_time = time.time()
                    state_val = h + actual_top
                    
                    if not hasattr(p, '_p_last_state'):
                        p._p_last_state = state_val
                        p._p_change_time = 0
                        
                    if abs(state_val - p._p_last_state) > 0.5:
                        p._p_last_state = state_val
                        p._p_change_time = current_time
                        this.invalidate()
                        
                    time_diff = current_time - p._p_change_time
                    draw_panel_border = False
                    
                    if p.p_stroke_enabled and p.p_border_paint and not has_top_panel:
                        if time_diff < 0.1: 
                            this.invalidate()
                        elif time_diff < 0.25:
                            draw_panel_border = True
                            alpha = int(255 * ((time_diff - 0.1) / 0.15))
                            p.p_border_paint.setAlpha(alpha)
                            this.invalidate()
                        else:
                            draw_panel_border = True
                            p.p_border_paint.setAlpha(255)
                            
                    if draw_panel_border:
                        p.p_rect.set(p.p_m_left, actual_top, w - p.p_m_right, h - p.p_m_bottom)
                        canvas.drawRoundRect(p.p_rect, p.p_dp_rad, p.p_dp_rad, p.p_border_paint)
                        
                if is_bot: return
            
            emoji_btn = p.get_cached_view(this, p.f_emojiBtn, "emojiButton", this_hash)
            if emoji_btn and emoji_btn.getVisibility() == 0 and emoji_btn.getAlpha() > 0.1:
                try:
                    if emoji_btn.getScaleX() < 0.1: return
                except Exception: pass

                ew, eh = emoji_btn.getWidth(), emoji_btn.getHeight()
                if ew > 0 and eh > 0:
                    current_left = emoji_btn.getLeft()
                    if p._emoji_last_w != w or p._emoji_last_h != h or p._emoji_last_left != current_left:
                        p._emoji_cx_offset = None
                        p._emoji_last_w, p._emoji_last_h, p._emoji_last_left = w, h, current_left
                        
                    if p._emoji_cx_offset is None:
                        cx_off, cy_off = 0.0, 0.0
                        view = emoji_btn
                        for _ in range(5):
                            if view == this or not view: break
                            cx_off += view.getLeft() + view.getTranslationX()
                            cy_off += view.getTop() + view.getTranslationY()
                            try: view = view.getParent()
                            except: break
                        p._emoji_cx_offset = cx_off
                        p._emoji_cy_offset = cy_off
                    
                    cx = (ew * 0.5) + p._emoji_cx_offset
                    cy = (eh * 0.5) + p._emoji_cy_offset

                    if p.e_md3_enabled and p.enter_paint:
                        canvas.drawCircle(cx, cy, p.e_dp_rad, p.enter_paint)
                    if p.e_stroke_enabled and p.e_border_paint:
                        canvas.drawCircle(cx, cy, p.e_dp_rad, p.e_border_paint)
        except Exception: pass

class ListViewDrawHook(MethodHook):
    def __init__(self, plugin): self.p = plugin

    def before_hooked_method(self, param):
        p = self.p
        if not p.l_enabled and not p.l_unpinned_enabled: return
            
        try:
            list_view = param.thisObject
            count = list_view.getChildCount()
            if count <= 0 or not p.DialogCellClass: return

            if p._active_list_view is None or p._active_list_view() is not list_view:
                child1 = list_view.getChildAt(0)
                if not isinstance(child1, p.DialogCellClass) and (count <= 1 or not isinstance(list_view.getChildAt(1), p.DialogCellClass)):
                    return 
                p._active_list_view = weakref.ref(list_view)

            if p._force_recalc: p._check_theme_colors()
                
            canvas = param.args[0]
            paint_pinned, paint_unpinned = p.paint_pinned, p.paint_unpinned
            l_dp_rad, l_dp_mx, l_dp_my = p.l_dp_rad, p.l_dp_mx, p.l_dp_my
            
            for i in range(count):
                child = list_view.getChildAt(i)
                if not child or child.getClass() != p.DialogCellClass: continue
                
                is_pinned = child.getIsPinned()
                if (is_pinned and not p.l_enabled) or (not is_pinned and not p.l_unpinned_enabled): continue
                
                paint = paint_pinned if is_pinned else paint_unpinned
                if not paint: continue
                    
                left = child.getLeft() + child.getTranslationX()
                top = child.getTop() + child.getTranslationY()
                w, h = child.getWidth(), child.getHeight()
                
                if p.l_md3 and p.list_rect:
                    p.list_rect.set(left + l_dp_mx, top + l_dp_my, left + w - l_dp_mx, top + h - l_dp_my)
                    canvas.drawRoundRect(p.list_rect, l_dp_rad, l_dp_rad, paint)
                    
                    border_paint = p.l_pinned_border_paint if is_pinned else p.l_unpinned_border_paint
                    if border_paint and ((is_pinned and p.l_stroke_enabled) or (not is_pinned and p.l_unpinned_stroke_enabled)):
                        canvas.drawRoundRect(p.list_rect, l_dp_rad, l_dp_rad, border_paint)
                else:
                    canvas.drawRect(left, top, left + w, top + h, paint)
        except Exception: pass

class _ActionBarLayoutHook(MethodHook):
    def __init__(self, plugin): self.plugin = plugin
    def after_hooked_method(self, param):
        try:
            this = param.thisObject
            this_hash = this.hashCode()
            p = self.plugin
            if p.h_md3_back:
                back_btn = p.get_cached_view(this, p.f_backBtn, "backButtonImageView", this_hash)
                if back_btn:
                    if p._force_recalc: p._check_theme_colors()
                    drawable = p.get_back_drawable()
                    if drawable and back_btn.getBackground() != drawable:
                        back_btn.setBackground(drawable)
                        pad_v = p.h_dp_back_v + p.dp_2
                        pad_h = p.h_dp_back_h + p.dp_2
                        back_btn.setPadding(pad_h, pad_v, pad_h, pad_v)

            if p.ActionBarMenuItemClass:
                for i in range(this.getChildCount()):
                    child = this.getChildAt(i)
                    if child and "Menu" in child.getClass().getSimpleName():
                        for j in range(child.getChildCount()):
                            item = child.getChildAt(j)
                            if isinstance(item, p.ActionBarMenuItemClass):
                                sf = get_private_field(item, "searchField")
                                if sf and sf.getVisibility() == 0:
                                    avatar_visible = any(
                                        "AvatarContainer" in cac.getClass().getSimpleName() and 
                                        p.get_cached_view(cac, p.f_avatar, "avatarImageView") and 
                                        p.get_cached_view(cac, p.f_avatar, "avatarImageView").getVisibility() == 0
                                        for k in range(this.getChildCount()) if (cac := this.getChildAt(k))
                                    )
                                    cb = get_private_field(item, "clearButton")
                                    if avatar_visible:
                                        offset = -p.f_dp_50
                                        if cb and cb.getTranslationX() != offset: cb.setTranslationX(offset)
                                        target_pad = p.dp_50 + p.dp_49
                                        if sf.getPaddingRight() != target_pad:
                                            sf.setPadding(sf.getPaddingLeft(), sf.getPaddingTop(), target_pad, sf.getPaddingBottom())
                                    else:
                                        if cb and cb.getTranslationX() != 0.0: cb.setTranslationX(0.0)
                                        if sf and sf.getPaddingRight() > p.dp_60:
                                            sf.setPadding(sf.getPaddingLeft(), sf.getPaddingTop(), p.dp_49, sf.getPaddingBottom())
        except Exception: pass

class _ActionBarDispatchDrawHook(MethodHook):
    def __init__(self, plugin): self.plugin = plugin
    def before_hooked_method(self, param):
        if self.plugin.h_md3_back and self.plugin._force_recalc: 
            self.plugin._check_theme_colors()

class _HeaderDispatchDrawHook(MethodHook):
    def __init__(self, plugin): self.plugin = plugin

    def _is_search_visible(self, this, this_hash):
        p = self.plugin
        try:
            if len(p._parent_actionbar_cache) > 100: p._parent_actionbar_cache.clear()
            cached = p._parent_actionbar_cache.get(this_hash)
            ab = cached() if type(cached) is weakref.ref else (cached if cached is False else None)

            if ab is None:
                parent = this.getParent()
                for _ in range(5): 
                    if not parent: break
                    if isinstance(parent, p.ActionBar):
                        ab = parent
                        break
                    try: parent = parent.getParent()
                    except Exception: break
                    
                if ab:
                    try: p._parent_actionbar_cache[this_hash] = weakref.ref(ab)
                    except TypeError: p._parent_actionbar_cache[this_hash] = ab
                else: p._parent_actionbar_cache[this_hash] = False
            
            if ab: return _is_search_active(p, ab)
        except Exception: pass
        return False

    def before_hooked_method(self, param):
        p = self.plugin
        if not p.h_md3_enabled and not p.h_md3_avatar: return

        try:
            this = param.thisObject
            this_hash = this.hashCode()
            canvas = param.args[0]
            if p._force_recalc: p._check_theme_colors()
            
            hide_title_bg = False
            pf = p.get_cached_view(this, p.f_parentFragment, "parentFragment", this_hash)
            
            if pf:
                pf_hash = pf.hashCode()
                is_thread = p._thread_chat_cache.get(pf_hash)
                
                if is_thread is None:
                    if p._meth_isThreadChat is False:
                        try:
                            p._meth_isThreadChat = pf.getClass().getDeclaredMethod("isThreadChat")
                            p._meth_isThreadChat.setAccessible(True)
                        except Exception: p._meth_isThreadChat = None
                            
                    is_thread = False
                    if p._meth_isThreadChat:
                        try:
                            res = p._meth_isThreadChat.invoke(pf)
                            if isinstance(res, bool): is_thread = res
                        except Exception: pass
                        
                    if len(p._thread_chat_cache) > 200: p._thread_chat_cache.clear()
                    p._thread_chat_cache[pf_hash] = is_thread

                if is_thread: hide_title_bg = True

            if not hide_title_bg and self._is_search_visible(this, this_hash): hide_title_bg = True

            h_dp_rad = p.h_dp_rad
            h_dp_avatar_bg = p.h_dp_avatar_bg

            if p.h_md3_avatar:
                avatar = p.get_cached_view(this, p.f_avatar, "avatarImageView", this_hash)
                if avatar and avatar.getVisibility() != 8:
                    a_l, a_t = avatar.getLeft(), avatar.getTop()
                    a_r, a_b = avatar.getRight(), avatar.getBottom()
                    if a_r > a_l:
                        cx, cy = (a_l + a_r) * 0.5, (a_t + a_b) * 0.5
                        if getattr(p, 'ha_paint', None):
                            canvas.drawCircle(cx, cy, h_dp_avatar_bg, p.ha_paint)
                        if getattr(p, 'h_avatar_stroke', False) and getattr(p, 'ha_border_paint', None):
                            canvas.drawCircle(cx, cy, h_dp_avatar_bg, p.ha_border_paint)

            if p.h_md3_enabled and not hide_title_bg and getattr(p, 'ht_paint', None):
                title = p.get_cached_view(this, p.f_title, "titleTextView", this_hash)
                if title and title.getVisibility() != 8:
                    subtitle = p.get_cached_view(this, p.f_subtitle, "subtitleTextView", this_hash)
                    
                    t_left, t_right = title.getLeft(), title.getRight()
                    top, bottom = title.getTop(), title.getBottom()
                    
                    s_left, s_right = t_left, t_right
                    if subtitle and subtitle.getVisibility() != 8:
                        bottom = max(bottom, subtitle.getBottom())
                        s_left = subtitle.getLeft()
                        s_right = subtitle.getRight()
                        
                    left = min(t_left, s_left)
                    right = max(t_right, s_right)

                    for raw_view in (p.get_cached_view(this, p.f_titleCopy, "titleTextLargerCopyView", this_hash), 
                                     p.get_cached_view(this, p.f_subtitleCopy, "subtitleTextLargerCopyView", this_hash)):
                        try:
                            vc = raw_view.get() if hasattr(raw_view, 'get') else raw_view
                            if vc and vc.getVisibility() != 8:
                                left = min(left, vc.getLeft())
                                right = max(right, vc.getRight())
                        except Exception: pass
                    
                    pad = p.f_dp_12
                    left -= pad
                    right += pad
                    
                    if left < right and p.header_rect: 
                        p.header_rect.set(left, top - p.f_dp_4, right, bottom + p.f_dp_4)
                        canvas.drawRoundRect(p.header_rect, h_dp_rad, h_dp_rad, p.ht_paint)
                        
                        if getattr(p, 'h_text_stroke', False) and getattr(p, 'ht_border_paint', None):
                            canvas.drawRoundRect(p.header_rect, h_dp_rad, h_dp_rad, p.ht_border_paint)
        except Exception: pass

    def after_hooked_method(self, param):
        p = self.plugin
        if not getattr(p, 'h_online_badge', False): return
        try:
            this = param.thisObject
            this_hash = this.hashCode()
            canvas = param.args[0]
            
            is_group = False
            pf = p.get_cached_view(this, p.f_parentFragment, "parentFragment", this_hash)
            if pf:
                try:
                    if pf.getDialogId() < 0: is_group = True
                except Exception: pass

            if is_group and not getattr(p, 'h_online_badge_groups', False): return
            
            def check_online_text(view):
                if not view: return False
                try:
                    text = str(view.getText() or "").strip().lower()
                    if not text or any(word in text for word in ["был", "was", "seen", "недавно"]): return False
                    return any(word in text for word in ["в сети", "online", "печат", "typing", "записыв", "отправля", "играет"])
                except Exception: return False
            
            subtitle = p.get_cached_view(this, p.f_subtitle, "subtitleTextView", this_hash)
            is_online = check_online_text(subtitle)
            
            if not is_online:
                try:
                    subtitle_copy_raw = p.get_cached_view(this, p.f_subtitleCopy, "subtitleTextLargerCopyView", this_hash)
                    if subtitle_copy_raw:
                        sc = subtitle_copy_raw.get() if hasattr(subtitle_copy_raw, 'get') else subtitle_copy_raw
                        is_online = check_online_text(sc)
                except Exception: pass
            
            if not is_online: return
            
            avatar = p.get_cached_view(this, p.f_avatar, "avatarImageView", this_hash)
            if not avatar or avatar.getVisibility() == 8: return
            
            a_l, a_t, a_r, a_b = avatar.getLeft(), avatar.getTop(), avatar.getRight(), avatar.getBottom()
            if a_r <= a_l: return
            
            cx, cy = (a_l + a_r) * 0.5, (a_t + a_b) * 0.5
            offset = ((a_r - a_l) * 0.5) * 0.75 
            badge_cx, badge_cy = cx + offset, cy + offset
            
            if p.online_stroke_paint: canvas.drawCircle(badge_cx, badge_cy, p.dp_7_f, p.online_stroke_paint)
            if p.online_paint: canvas.drawCircle(badge_cx, badge_cy, p.dp_5_f, p.online_paint)
        except Exception: pass

class _UpdateSubtitleHook(MethodHook):
    def __init__(self, plugin): self.plugin = plugin
    def after_hooked_method(self, param):
        try:
            this = param.thisObject
            this_hash = this.hashCode()
            this.requestLayout()
            this.invalidate()
            
            p = self.plugin
            parentFragment = p.get_cached_view(this, p.f_parentFragment, "parentFragment", this_hash)
            if not parentFragment: return

            subtitle = p.get_cached_view(this, p.f_subtitle, "subtitleTextView", this_hash)
            
            currentAccount = -1
            if p.f_currentAccount:
                try: currentAccount = _safe_int(p.f_currentAccount.get(this), -1)
                except: pass
            if currentAccount < 0:
                try:
                    acc_field = this.getClass().getDeclaredField("currentAccount")
                    acc_field.setAccessible(True)
                    p.f_currentAccount = acc_field
                    currentAccount = _safe_int(acc_field.get(this), -1)
                except:
                    currentAccount = _safe_int(get_private_field(this, "currentAccount"), -1)
                
            if not subtitle or currentAccount < 0 or not getattr(p, 'MessagesController', None): return

            MessagesController = p.MessagesController
            dialog_id = parentFragment.getDialogId()
            thread_id = parentFragment.getThreadId()
            
            mc_instance = MessagesController.getInstance(currentAccount)
            print_string = mc_instance.getPrintingString(dialog_id, thread_id, False)
            if not print_string or len(str(print_string)) == 0: return

            type_idx = mc_instance.getPrintingStringType(dialog_id, thread_id)
            if type_idx is None or type_idx < 0: return

            subtitle.setLeftDrawable(None)
            try: subtitle.replaceTextWithDrawable(None, None)
            except Exception: pass
            try: subtitle.setPadding(0, 0, 0, 0)
            except Exception: pass
            subtitle.setText(f"{str(print_string).replace('.', '').strip()}...")
        except Exception: pass

class _RefreshHook(MethodHook):
    def __init__(self, plugin): self.plugin = plugin
    def after_hooked_method(self, param):
        try:
            this = param.thisObject
            this.requestLayout()
            this.invalidate()
        except Exception: pass

class _CtorHook(MethodHook):
    def __init__(self, plugin): self.plugin = plugin
    def after_hooked_method(self, param):
        try:
            this = param.thisObject
            this_hash = this.hashCode()
            p = self.plugin
            if not p.Gravity: return

            title = p.get_cached_view(this, p.f_title, "titleTextView", this_hash)
            subtitle = p.get_cached_view(this, p.f_subtitle, "subtitleTextView", this_hash)
            
            if title:
                title.setGravity(3) 
                for setter in ('setLines', 'setSingleLine', 'setScrolling', 'setScrollNonFitText'):
                    try: getattr(title, setter)(True if 'SingleLine' in setter or 'Scroll' in setter else 1 if 'Lines' in setter else False)
                    except: pass
                try: title.setRightDrawableOutside(True) 
                except: pass
                try: title.setLeftDrawableOutside(True) 
                except: pass
                for setter in ('setRightDrawable', 'setLeftDrawable'):
                    try: getattr(title, setter)(None)
                    except: pass
                try: title.setCompoundDrawablesWithIntrinsicBounds(0, 0, 0, 0)
                except: pass
                if p.TextUtils:
                    try:
                        title.setEllipsize(p.TextUtils.TruncateAt.MARQUEE)
                        title.setMarqueeRepeatLimit(-1)
                        title.setSelected(True)
                        title.setHorizontallyScrolling(True)
                    except Exception: pass
            
            if subtitle:
                subtitle.setGravity(3) 
                try: subtitle.setLines(1)
                except Exception: pass
                try: subtitle.setSingleLine(True)
                except Exception: pass
                try: subtitle.setPadding(0, 0, 0, 0)
                except Exception: pass
        except Exception: pass

class _OnMeasureReplacement(MethodReplacement):
    def __init__(self, plugin): self.plugin = plugin
    def replace_hooked_method(self, param):
        p = self.plugin
        try:
            this = param.thisObject
            this_hash = this.hashCode()
            if not p.MeasureSpec or not p.AndroidUtilities: return None

            widthBase = p.MeasureSpec.getSize(param.args[0])
            height = p.MeasureSpec.getSize(param.args[1])

            avatar = p.get_cached_view(this, p.f_avatar, "avatarImageView", this_hash)
            title = p.get_cached_view(this, p.f_title, "titleTextView", this_hash)
            subtitle = p.get_cached_view(this, p.f_subtitle, "subtitleTextView", this_hash)
            parentFragment = p.get_cached_view(this, p.f_parentFragment, "parentFragment", this_hash)
            timeItem = p.get_cached_view(this, p.f_timeItem, "timeItem", this_hash)

            dp42 = p.dp_42
            ms_exact = p.MS_EXACTLY
            ms_at_most = p.MS_AT_MOST

            if not parentFragment:
                leftPadding = _safe_int(p.get_cached_view(this, p.f_leftPadding, "leftPadding", this_hash), p.dp_8)
                width0 = widthBase + (_safe_int(title.getPaddingRight()) if title else 0)
                avatarRightBound = 0
                if avatar and avatar.getVisibility() != 8:
                    avatar.measure(p.MeasureSpec.makeMeasureSpec(dp42, ms_exact), p.MeasureSpec.makeMeasureSpec(dp42, ms_exact))
                    avatarRightBound = leftPadding + dp42 + p.dp_12

                regionWidth = max(0, widthBase - avatarRightBound - p.dp_16)

                if title: title.measure(p.MeasureSpec.makeMeasureSpec(regionWidth, ms_exact), p.MeasureSpec.makeMeasureSpec(p.dp_32 + _safe_int(title.getPaddingRight()), ms_at_most))
                if subtitle: subtitle.measure(p.MeasureSpec.makeMeasureSpec(regionWidth, ms_exact), p.MeasureSpec.makeMeasureSpec(p.dp_20, ms_at_most))
                if timeItem: timeItem.measure(p.MeasureSpec.makeMeasureSpec(p.dp_34, ms_exact), p.MeasureSpec.makeMeasureSpec(p.dp_34, ms_exact))
                
                this.setMeasuredDimension(width0, height)
                return None

            if avatar:
                if parentFragment and _is_me(p, parentFragment, this, getattr(p, 'UserConfig', None)):
                    avatar.setVisibility(0)
                if avatar.getVisibility() != 8:
                    avatar.measure(p.MeasureSpec.makeMeasureSpec(dp42, ms_exact), p.MeasureSpec.makeMeasureSpec(dp42, ms_exact))

            maxHalfWidth = max(0, (widthBase * 0.5) - p.dp_90)
            regionWidth = int(maxHalfWidth * 2)

            if title: title.measure(p.MeasureSpec.makeMeasureSpec(regionWidth, ms_exact), p.MeasureSpec.makeMeasureSpec(p.dp_32 + _safe_int(title.getPaddingRight()), ms_at_most))
            if subtitle: subtitle.measure(p.MeasureSpec.makeMeasureSpec(regionWidth, ms_exact), p.MeasureSpec.makeMeasureSpec(p.dp_20, ms_at_most))

            this.setMeasuredDimension(widthBase, height)
            return None
        except Exception: return None

class _OnLayoutReplacement(MethodReplacement):
    def __init__(self, plugin): self.plugin = plugin
    def _get_text_w(self, view):
        if not view: return 0.0
        p = self.plugin
        try:
            get_vis = getattr(view, 'getVisibility', None)
            if get_vis and get_vis() == 8: return 0.0
            get_tw = getattr(view, 'getTextWidth', None)
            if get_tw:
                tw = get_tw()
                if tw > 0:
                    w = tw + view.getPaddingLeft() + view.getPaddingRight()
                    dp_val = 0.0
                    get_dp = getattr(view, "getDrawablePadding", None)
                    if get_dp: dp_val = get_dp()
                    else:
                        val = p.fast_get(p.f_drawablePadding, view, "drawablePadding")
                        if val is not None: dp_val = val
                    
                    if dp_val <= 0: dp_val = p.f_dp_4
                    
                    for field, fname, getter in ((p.f_leftDrawable, "leftDrawable", "getLeftDrawable"), (p.f_rightDrawable, "rightDrawable", "getRightDrawable"), (p.f_rightDrawable2, "rightDrawable2", "getRightDrawable2")):
                        d = None
                        get_meth = getattr(view, getter, None)
                        if get_meth: d = get_meth()
                        if not d: d = p.fast_get(field, view, fname)
                        if d:
                            get_iw = getattr(d, 'getIntrinsicWidth', None)
                            if get_iw:
                                iw = get_iw()
                                if iw > 0: w += iw + dp_val
                    return float(w + p.f_dp_2)
            return float(view.getMeasuredWidth())
        except Exception: pass
        return 0.0

    def replace_hooked_method(self, param):
        p = self.plugin
        try:
            this = param.thisObject
            this_hash = this.hashCode()
            if not p.AndroidUtilities or not p.ActionBar: return None

            occupyStatusBar = p.get_cached_view(this, p.f_occupyStatusBar, "occupyStatusBar", this_hash)
            occupyStatusBar = bool(occupyStatusBar) if occupyStatusBar is not None else True

            avatar = p.get_cached_view(this, p.f_avatar, "avatarImageView", this_hash)
            title = p.get_cached_view(this, p.f_title, "titleTextView", this_hash)
            subtitle = p.get_cached_view(this, p.f_subtitle, "subtitleTextView", this_hash)
            timeItem = p.get_cached_view(this, p.f_timeItem, "timeItem", this_hash)
            titleCopy = p.get_cached_view(this, p.f_titleCopy, "titleTextLargerCopyView", this_hash)
            subtitleCopy = p.get_cached_view(this, p.f_subtitleCopy, "subtitleTextLargerCopyView", this_hash)
            parentFragment = p.get_cached_view(this, p.f_parentFragment, "parentFragment", this_hash)

            w = this.getWidth()
            actionBarHeight = p.ActionBar.getCurrentActionBarHeight()
            viewTop = int((actionBarHeight - p.dp_42) * 0.5) + (p.AndroidUtilities.statusBarHeight if occupyStatusBar else 0)
            dp42 = p.dp_42
            ms_exact = p.MS_EXACTLY
            ms_at_most = p.MS_AT_MOST

            if not parentFragment:
                leftPadding = _safe_int(p.get_cached_view(this, p.f_leftPadding, "leftPadding", this_hash), p.dp_8)
                avatarRightBound = 0

                if avatar and avatar.getVisibility() != 8:
                    avatar.layout(leftPadding, viewTop + 1, leftPadding + dp42, viewTop + 1 + dp42)
                    avatarRightBound = leftPadding + dp42 + p.dp_12

                regionLeft = max(avatarRightBound, min(avatarRightBound, w - p.dp_16))
                regionRight = min(w, w - p.dp_16)
                regionWidth = max(0, regionRight - regionLeft)
                
                pad = p.dp_12
                max_text_region = max(0, regionWidth - pad * 2)
                has_visible_subtitle = subtitle and subtitle.getVisibility() != 8

                if title:
                    actual_w = self._get_text_w(title)
                    t_w = min(int(actual_w), max_text_region)
                    t_left = regionLeft + pad
                    t_right = t_left + t_w

                    title.setGravity(3) 
                    try: title.setRightDrawableOutside(True)
                    except Exception: pass
                    try: title.setLeftDrawableOutside(True)
                    except Exception: pass
                    try: title.setTranslationX(0.0)
                    except Exception: pass

                    t_top = viewTop + (p.dp_1_3 if has_visible_subtitle else p.dp_11) - title.getPaddingTop()
                    title.layout(t_left, t_top, t_right, t_top + title.getTextHeight() - title.getPaddingTop() + title.getPaddingBottom())
                    try:
                        if titleCopy:
                            tc = titleCopy.get() if hasattr(titleCopy, 'get') else titleCopy
                            if tc: tc.layout(t_left, t_top + title.getPaddingTop(), t_left + tc.getMeasuredWidth(), t_top + title.getPaddingTop() + tc.getTextHeight())
                    except Exception: pass
                
                if has_visible_subtitle:
                    actual_sw = self._get_text_w(subtitle)
                    s_w = min(int(actual_sw), max_text_region)
                    s_left = regionLeft + pad
                    s_right = s_left + s_w

                    subtitle.setGravity(3) 
                    try:
                        subtitle.setPadding(0, 0, 0, 0)
                        subtitle.setTranslationX(0.0)
                    except Exception: pass

                    sTop = viewTop + p.dp_24
                    subtitle.layout(s_left, sTop, s_right, sTop + subtitle.getTextHeight())
                    try:
                        if subtitleCopy:
                            sc = subtitleCopy.get() if hasattr(subtitleCopy, 'get') else subtitleCopy
                            if sc: sc.layout(s_left, sTop, s_left + sc.getMeasuredWidth(), sTop + sc.getTextHeight())
                    except Exception: pass
                        
                if timeItem: timeItem.layout(leftPadding + p.dp_16, viewTop + p.dp_15, leftPadding + p.dp_50, viewTop + p.dp_49)
                return None

            if timeItem:
                try:
                    timeItem.layout(0, 0, 0, 0)
                    timeItem.setVisibility(8)
                except Exception: pass

            leftInParent = param.args[1] if param.args and len(param.args) >= 5 else 0
            parentW = w
            
            try:
                pa = this.getParent()
                if pa:
                    parentW = pa.getWidth()
                    this.setClipChildren(False)
                    this.setClipToPadding(False)
                    pa.setClipChildren(False)
                    pa.setClipToPadding(False)
            except Exception: pass

            absoluteRight = parentW - leftInParent
            
            if avatar:
                if parentFragment and _is_me(p, parentFragment, this, getattr(p, 'UserConfig', None)):
                    avatar.setVisibility(0)

                if avatar.getVisibility() != 8:
                    avatarRight = absoluteRight - p.dp_6
                    avatar.layout(avatarRight - dp42, viewTop + 1, avatarRight, viewTop + 1 + dp42)

            headerCenterLocal = (parentW * 0.5) - leftInParent
            maxHalfWidth = max(0, (parentW * 0.5) - p.dp_90)
            regionLeft = int(headerCenterLocal - maxHalfWidth)
            regionRight = int(headerCenterLocal + maxHalfWidth)

            min_left = 0
            max_right = w
            
            if avatar and avatar.getVisibility() != 8:
                a_l = avatar.getLeft()
                a_r = avatar.getRight()
                if a_l < w / 2: min_left = max(min_left, a_r + p.dp_12)
                else: max_right = min(max_right, a_l - p.dp_12)

            if regionLeft < min_left: regionLeft = min_left
            if regionRight > max_right: regionRight = max_right
            regionWidth = max(0, regionRight - regionLeft)

            pad = p.dp_12
            max_text_region = max(0, regionWidth - pad * 2)
            has_visible_subtitle = subtitle and subtitle.getVisibility() != 8

            if title:
                if p.MeasureSpec:
                    try: title.measure(p.MeasureSpec.makeMeasureSpec(max_text_region, ms_exact), p.MeasureSpec.makeMeasureSpec(p.dp_32 + _safe_int(title.getPaddingRight()), ms_at_most))
                    except: pass

                actual_w = self._get_text_w(title)
                t_w = min(int(actual_w), max_text_region)
                t_left = regionLeft + int((regionWidth - t_w) / 2)
                t_right = t_left + t_w

                title.setGravity(3) 
                try: title.setRightDrawableOutside(True)
                except Exception: pass
                try: title.setLeftDrawableOutside(True)
                except Exception: pass
                try: title.setTranslationX(0.0)
                except Exception: pass

                titleTop = viewTop + (p.dp_1_3 if has_visible_subtitle else p.dp_11) - title.getPaddingTop()
                title.layout(t_left, titleTop, t_right, titleTop + title.getTextHeight() - title.getPaddingTop() + title.getPaddingBottom())

                try:
                    if titleCopy:
                        tc = titleCopy.get() if hasattr(titleCopy, 'get') else titleCopy
                        if tc:
                            tc_top = viewTop + (p.dp_1_3 if has_visible_subtitle else p.dp_11)
                            tc.layout(t_left, tc_top, t_left + tc.getMeasuredWidth(), tc_top + tc.getTextHeight())
                except Exception: pass

            if subtitle:
                if p.MeasureSpec and has_visible_subtitle:
                    try: subtitle.measure(p.MeasureSpec.makeMeasureSpec(max_text_region, ms_exact), p.MeasureSpec.makeMeasureSpec(p.dp_20, ms_at_most))
                    except: pass

                if has_visible_subtitle:
                    actual_sw = self._get_text_w(subtitle)
                    s_w = min(int(actual_sw), max_text_region)
                    s_left = regionLeft + int((regionWidth - s_w) / 2)
                    s_right = s_left + s_w

                    subtitle.setGravity(3) 
                    try:
                        subtitle.setPadding(0, 0, 0, 0)
                        subtitle.setTranslationX(0.0)
                    except Exception: pass

                    sTop = viewTop + p.dp_24
                    subtitle.layout(s_left, sTop, s_right, sTop + subtitle.getTextHeight())
                    try:
                        if subtitleCopy:
                            sc = subtitleCopy.get() if hasattr(subtitleCopy, 'get') else subtitleCopy
                            if sc: sc.layout(s_left, sTop, s_left + sc.getMeasuredWidth(), sTop + sc.getTextHeight())
                    except Exception: pass

            try:
                if parentFragment:
                    headerItem = get_private_field(parentFragment, "headerItem")
                    if headerItem: headerItem.setAlpha(0.0)
                        
                parent_ab = this.getParent()
                if parent_ab and p.ActionBarMenuItemClass:
                    for i in range(parent_ab.getChildCount()):
                        child = parent_ab.getChildAt(i)
                        if child and "Menu" in child.getClass().getSimpleName():
                            for j in range(child.getChildCount()):
                                item = child.getChildAt(j)
                                if isinstance(item, p.ActionBarMenuItemClass):
                                    try:
                                        if item.hasSubMenu():
                                            item.setAlpha(0.0)
                                            continue
                                    except Exception: pass
            except Exception: pass
            return None
        except Exception: return None

class _ChatActivityCreateViewHook(MethodHook):
    def __init__(self, plugin): self.plugin = plugin
    def after_hooked_method(self, param):
        try:
            this = param.thisObject
            this_hash = this.hashCode()
            p = self.plugin
            avatarContainer = p.get_cached_view(this, p.f_avatarContainer, "avatarContainer", this_hash)
            if not avatarContainer: return
            lp = avatarContainer.getLayoutParams()
            if not lp: return
            lp.rightMargin = 0
            if p.AndroidUtilities: lp.topMargin = p.AndroidUtilities.dp(p.h_top_margin)
            avatarContainer.setLayoutParams(lp)
        except Exception: pass

class _SearchFieldVisibilityHook(MethodHook):
    def __init__(self, plugin): self.plugin = plugin
    def _invalidate_avatar_containers(self, action_bar):
        p = self.plugin
        if not action_bar or not p.ChatAvatarContainerClass: return
        try:
            for i in range(action_bar.getChildCount()):
                child = action_bar.getChildAt(i)
                if isinstance(child, p.ChatAvatarContainerClass): child.invalidate()
        except Exception: pass

    def after_hooked_method(self, param):
        try:
            parent = param.thisObject.getParent()
            for _ in range(6):
                if not parent: break
                if isinstance(parent, self.plugin.ActionBar):
                    self._invalidate_avatar_containers(parent)
                    def force_redraw_later():
                        try:
                            if parent: self._invalidate_avatar_containers(parent)
                        except Exception: pass
                    run_on_ui_thread(force_redraw_later, 250)
                    break
                try: parent = parent.getParent()
                except Exception: break
        except Exception: pass

class MD3Core(BasePlugin):
    def __init__(self):
        super().__init__()
        self._default_settings = {
