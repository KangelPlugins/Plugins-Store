    def _get_signed_color(self, key):
        if not self._theme_get_color_method or key is None: return None
        try:
            c = int(self._theme_get_color_method.invoke(None, key)) & 0xFFFFFFFF
            return c - 0x100000000 if c >= 0x80000000 else c
        except Exception: return None

    def _get_monet_color(self):
        try:
            if not self.ApplicationLoader or not self.ApplicationLoader.applicationContext: return None
            ctx = self.ApplicationLoader.applicationContext
            if self.Build and self.Build.SDK_INT >= 31:
                color_id = ctx.getResources().getIdentifier("system_accent1_500", "color", "android")
                if color_id != 0: return ctx.getColor(color_id)
        except Exception: pass
        return None

    def _check_theme_colors(self):
        if not self._force_recalc: return
        bg_color = self._get_signed_color(self.jint_bg_key)
        if bg_color is None: return
        self._last_bg_color = bg_color
        self._last_acc_color = self._get_signed_color(self.jint_acc_key)
        self._last_online_color = self._get_signed_color(self.jint_online_key) or -11433022
        self._force_recalc = False
        self._update_paints()

    def _parse_hex(self, hex_str):
        if not hex_str: return None
        hex_str = str(hex_str).strip().lstrip('#')
        if len(hex_str) != 6: return None
        try: return int(hex_str[0:2], 16), int(hex_str[2:4], 16), int(hex_str[4:6], 16)
        except Exception: return None

    def _get_blended_rgb(self, bg_color, acc_color, color_preset, opacity_preset, custom_hex, default_mix_index):
        bg_r, bg_g, bg_b = (bg_color >> 16) & 0xFF, (bg_color >> 8) & 0xFF, bg_color & 0xFF
        is_light_theme = (bg_r * 299 + bg_g * 587 + bg_b * 114) / 1000 > 127
        base_r = base_g = base_b = 0
        use_custom = False

        if self.use_monet:
            monet_c = self._get_monet_color()
            if monet_c is not None:
                base_r, base_g, base_b = (monet_c >> 16) & 0xFF, (monet_c >> 8) & 0xFF, monet_c & 0xFF
                use_custom = True

        if not use_custom:
            if color_preset == 1:
                parsed = self._parse_hex(custom_hex)
                if parsed:
                    base_r, base_g, base_b = parsed
                    use_custom = True
            elif 2 <= color_preset < len(COLORS_DATA) + 2:
                base_r, base_g, base_b = COLORS_DATA[color_preset - 2][1]
                use_custom = True

        if not use_custom:
            if acc_color is not None: base_r, base_g, base_b = (acc_color >> 16) & 0xFF, (acc_color >> 8) & 0xFF, acc_color & 0xFF
            else: base_r, base_g, base_b = 51, 144, 236

        mix_ratio = MIX_RATIOS[opacity_preset if opacity_preset < len(MIX_RATIOS) else default_mix_index]
        out_r, out_g, out_b = int(bg_r + (base_r - bg_r) * mix_ratio), int(bg_g + (base_g - bg_g) * mix_ratio), int(bg_b + (base_b - bg_b) * mix_ratio)

        if mix_ratio < 1.0:
            weight = 0.96 if is_light_theme else 1.04
            out_r, out_g, out_b = min(255, int(out_r * weight)), min(255, int(out_g * weight)), min(255, int(out_b * weight))
        return out_r, out_g, out_b

    def _create_paint_obj(self, bg_color, acc_color, color_preset, opacity_preset, custom_hex, alpha_preset):
        out_r, out_g, out_b = self._get_blended_rgb(bg_color, acc_color, color_preset, opacity_preset, custom_hex, 2)
        alpha = ALPHA_VALUES[alpha_preset if alpha_preset < len(ALPHA_VALUES) else 1]
        final_c = (alpha << 24) | (out_r << 16) | (out_g << 8) | out_b
        if final_c >= 0x80000000: final_c -= 0x100000000
        final_jint = self.jint(final_c)
        p = self.PaintClass()
        p.setAntiAlias(True)
        p.setColor(final_jint)
        return p, final_c, final_jint

    def _create_border_paint_obj(self, bg_color, acc_color, color_preset, opacity_preset, custom_hex, width_dp):
        out_r, out_g, out_b = self._get_blended_rgb(bg_color, acc_color, color_preset, opacity_preset, custom_hex, 7)
        final_c = (255 << 24) | (out_r << 16) | (out_g << 8) | out_b
        if final_c >= 0x80000000: final_c -= 0x100000000
        p = self.PaintClass()
        if self.StyleClass: p.setStyle(self.StyleClass.STROKE)
        p.setAntiAlias(True)
        p.setColor(self.jint(final_c))
        p.setStrokeWidth(float(width_dp))
        return p

    def _update_paints(self):
        bg_color, acc_color = self._last_bg_color, self._last_acc_color
        self.ht_paint, _, _ = self._create_paint_obj(bg_color, acc_color, self.ht_color_preset, self.ht_opacity_preset, self.ht_custom_hex, self.ht_alpha)
        self.ht_border_paint = self._create_border_paint_obj(bg_color, acc_color, self.ht_stroke_color, self.ht_stroke_opacity, self.ht_stroke_hex, self.ht_dp_stroke) if self.h_text_stroke else None
        self.ha_paint, _, _ = self._create_paint_obj(bg_color, acc_color, self.ha_color_preset, self.ha_opacity_preset, self.ha_custom_hex, self.ha_alpha)
        self.ha_border_paint = self._create_border_paint_obj(bg_color, acc_color, self.ha_stroke_color, self.ha_stroke_opacity, self.ha_stroke_hex, self.ha_dp_stroke) if self.h_avatar_stroke else None
        self.hb_paint, _, hb_jint = self._create_paint_obj(bg_color, acc_color, self.hb_color_preset, self.hb_opacity_preset, self.hb_custom_hex, self.hb_alpha)
        self.hb_border_paint = self._create_border_paint_obj(bg_color, acc_color, self.hb_stroke_color, self.hb_stroke_opacity, self.hb_stroke_hex, self.hb_dp_stroke) if self.h_back_stroke else None
        self.hb_jint_color = hb_jint

        if self.cached_back_drawable:
            try:
                inner = self.cached_back_drawable.getDrawable() if hasattr(self.cached_back_drawable, 'getDrawable') else self.cached_back_drawable
                if hasattr(inner, 'setColor'): inner.setColor(self.hb_jint_color)
                if self.h_back_stroke and self.hb_border_paint: inner.setStroke(int(self.hb_dp_stroke), self.hb_border_paint.getColor())
                elif hasattr(inner, 'setStroke'): inner.setStroke(0, 0)
            except Exception: self.cached_back_drawable = None

        self.online_stroke_paint = self.PaintClass()
        self.online_stroke_paint.setAntiAlias(True)
        self.online_stroke_paint.setColor(self.jint(bg_color))
        self.online_paint = self.PaintClass()
        self.online_paint.setAntiAlias(True)
        self.online_paint.setColor(self.jint(self._last_online_color))
        
        if self.l_enabled:
            self.paint_pinned, _, _ = self._create_paint_obj(bg_color, acc_color, self.l_pin_color, self.l_pin_opacity, self.l_pin_hex, self.l_pin_alpha)
            self.l_pinned_border_paint = self._create_border_paint_obj(bg_color, acc_color, self.l_stroke_color, self.l_stroke_opacity, self.l_stroke_hex, self.l_dp_stroke) if self.l_stroke_enabled else None
        else:
            self.paint_pinned = self.l_pinned_border_paint = None
            
        if self.l_unpinned_enabled:
            self.paint_unpinned, _, _ = self._create_paint_obj(bg_color, acc_color, self.l_unpin_color, self.l_unpin_opacity, self.l_unpin_hex, self.l_unpin_alpha)
            self.l_unpinned_border_paint = self._create_border_paint_obj(bg_color, acc_color, self.l_unpinned_stroke_color, self.l_unpinned_stroke_opacity, self.l_unpinned_stroke_hex, self.l_unpinned_dp_stroke) if self.l_unpinned_stroke_enabled else None
        else:
            self.paint_unpinned = self.l_unpinned_border_paint = None
            
        self.p_border_paint = self._create_border_paint_obj(bg_color, acc_color, self.p_stroke_color, self.p_stroke_opacity, self.p_stroke_hex, self.p_dp_stroke) if getattr(self, 'p_stroke_enabled', False) else None
        if self.e_md3_enabled:
            self.enter_paint, _, _ = self._create_paint_obj(bg_color, acc_color, self.e_color_preset, self.e_opacity_preset, self.e_custom_hex, self.e_alpha_preset)
            self.e_border_paint = self._create_border_paint_obj(bg_color, acc_color, self.e_stroke_color, self.e_stroke_opacity, self.e_stroke_hex, self.e_dp_stroke) if self.e_stroke_enabled else None
        else:
            self.enter_paint = self.e_border_paint = None

    def get_back_drawable(self):
        if self.cached_back_drawable: return self.cached_back_drawable
        if not getattr(self, 'GradientDrawable', None) or not getattr(self, 'hb_paint', None): return None
        bg = self.GradientDrawable()
        bg.setShape(0)
        bg.setCornerRadius(self.h_dp_rad)
        bg.setColor(self.hb_paint.getColor())
        if getattr(self, 'h_back_stroke', False) and getattr(self, 'hb_border_paint', None):
            bg.setStroke(int(self.hb_dp_stroke), self.hb_border_paint.getColor())
        if getattr(self, 'InsetDrawable', None):
            self.cached_back_drawable = self.InsetDrawable(bg, self.h_dp_back_h, self.h_dp_back_v, self.h_dp_back_h, self.h_dp_back_v)
        else:
            self.cached_back_drawable = bg
        return self.cached_back_drawable

    def _force_redraw(self):
        def redraw():
            if self._active_list_view:
                lv = self._active_list_view()
                if lv:
                    try:
                        lv.invalidate()
                        for i in range(lv.getChildCount()):
                            child = lv.getChildAt(i)
                            if child: child.invalidate()
                    except Exception: pass
        run_on_ui_thread(redraw, 0)

    def on_plugin_unload(self):
        self._loaded = False
        for ref in self._hooks:
            try: self.unhook_method(ref)
            except: pass
        self._hooks.clear()
        _class_cache.clear()
        self._thread_chat_cache.clear()

    def _register_hook(self, ref):
        if ref and ref not in self._hooks: self._hooks.append(ref)

    def _get_attr(self, obj, name):
        if obj is None: return None
        try: return getattr(obj, name)
        except:
            try: return get_private_field(obj, name)
            except: return None

    def _set_attr(self, obj, name, value):
        if obj is None: return False
        try:
            setattr(obj, name, value)
            return True
        except:
            try: return bool(set_private_field(obj, name, value))
            except: return False

    def on_plugin_load(self):
        self.ApplicationLoader = find_class("org.telegram.messenger.ApplicationLoader")
        self.Build = find_class("android.os.Build$VERSION")
        self.AndroidUtilities = find_class("org.telegram.messenger.AndroidUtilities")
        self.ActionBar = find_class("org.telegram.ui.ActionBar.ActionBar")
        self.MeasureSpec = find_class("android.view.View$MeasureSpec")
        self.Theme = find_class("org.telegram.ui.ActionBar.Theme")
        self.Gravity = find_class("android.view.Gravity")
        self.RectF = find_class("android.graphics.RectF")
        self.GradientDrawable = find_class("android.graphics.drawable.GradientDrawable")
        self.InsetDrawable = find_class("android.graphics.drawable.InsetDrawable")
        self.TextUtils = jclass("android.text.TextUtils")
        self.UserConfig = find_class("org.telegram.messenger.UserConfig")
        self.MessagesController = find_class("org.telegram.messenger.MessagesController")

        self.SimpleTextViewClass = safe_find_class("org.telegram.ui.ActionBar.SimpleTextView")
        if self.SimpleTextViewClass:
            self.f_drawablePadding = self._get_field(self.SimpleTextViewClass, "drawablePadding")
            self.f_leftDrawable = self._get_field(self.SimpleTextViewClass, "leftDrawable")
            self.f_rightDrawable = self._get_field(self.SimpleTextViewClass, "rightDrawable")
            self.f_rightDrawable2 = self._get_field(self.SimpleTextViewClass, "rightDrawable2")

        try:
            self.PaintClass = find_class("android.graphics.Paint")
            self.StyleClass = jclass("android.graphics.Paint$Style")
        except Exception: pass

        if self.RectF:
            self.header_rect = self.RectF(0.0, 0.0, 0.0, 0.0)
            self.list_rect = self.RectF(0.0, 0.0, 0.0, 0.0)
            self.p_rect = self.RectF(0.0, 0.0, 0.0, 0.0)

        self.ChatAvatarContainerClass = find_class("org.telegram.ui.Components.ChatAvatarContainer")
        if self.ChatAvatarContainerClass:
            self.f_title = self._get_field(self.ChatAvatarContainerClass, "titleTextView")
            self.f_subtitle = self._get_field(self.ChatAvatarContainerClass, "subtitleTextView")
            self.f_avatar = self._get_field(self.ChatAvatarContainerClass, "avatarImageView")
            self.f_titleCopy = self._get_field(self.ChatAvatarContainerClass, "titleTextLargerCopyView")
            self.f_subtitleCopy = self._get_field(self.ChatAvatarContainerClass, "subtitleTextLargerCopyView")
            self.f_timeItem = self._get_field(self.ChatAvatarContainerClass, "timeItem")
            self.f_parentFragment = self._get_field(self.ChatAvatarContainerClass, "parentFragment")
            self.f_leftPadding = self._get_field(self.ChatAvatarContainerClass, "leftPadding")
            self.f_occupyStatusBar = self._get_field(self.ChatAvatarContainerClass, "occupyStatusBar")
            self.f_currentAccount = self._get_field(self.ChatAvatarContainerClass, "currentAccount")
            
        ChatActivity = find_class("org.telegram.ui.ChatActivity")
        if ChatActivity: self.f_avatarContainer = self._get_field(ChatActivity, "avatarContainer")
            
        if self.ActionBar: self.f_backBtn = self._get_field(self.ActionBar, "backButtonImageView")
            
        ChatActivityEnterView = find_class("org.telegram.ui.Components.ChatActivityEnterView")
        if ChatActivityEnterView: self.f_emojiBtn = self._get_field(ChatActivityEnterView, "emojiButton")

        try:
            from java import jint
            self.jint = jint
        except Exception: self.jint = int

        if self.MeasureSpec:
            try:
                self.MS_EXACTLY = self.MeasureSpec.EXACTLY
                self.MS_AT_MOST = self.MeasureSpec.AT_MOST
            except: pass

        try:
            self.DialogCellClass = find_class("org.telegram.ui.Cells.DialogCell")
            ThemeJavaClass = self.Theme.getClass()
            self._theme_get_color_method = ThemeJavaClass.getMethod("getColor", Integer.TYPE)
            self.jint_bg_key = self.jint(ThemeJavaClass.getField("key_windowBackgroundWhite").getInt(None))
            try: self.jint_acc_key = self.jint(ThemeJavaClass.getField("key_chats_actionBackground").getInt(None))
            except Exception: self.jint_acc_key = None
            self.jint_online_key = self.jint(ThemeJavaClass.getField("key_chats_onlineCircle").getInt(None))
        except Exception as e: self.log(f"Theme init error: {e}")

        self._load_settings_cache()
        self._check_theme_colors()
        self._warned = False
        self._loaded = True

        try:
            if self.Theme:
                for method in ("applyTheme", "applyPreviousTheme", "applyThemeFile", "checkAutoNightThemeConditions"):
                    try: self.hook_all_methods(self.Theme, method, _ThemeApplyHook(self), priority=50)
                    except: pass

            if self.ChatAvatarContainerClass:
                try: self.hook_all_methods(self.ChatAvatarContainerClass, "dispatchDraw", _HeaderDispatchDrawHook(self), priority=50)
                except: pass
                try: self.hook_all_methods(self.ChatAvatarContainerClass, "dispatchTouchEvent", _HeaderDispatchTouchHook(self), priority=50)
                except: pass
                self.hook_all_constructors(self.ChatAvatarContainerClass, _CtorHook(self), priority=50)
                self.hook_all_methods(self.ChatAvatarContainerClass, "onMeasure", _OnMeasureReplacement(self), priority=50)
                self.hook_all_methods(self.ChatAvatarContainerClass, "onLayout", _OnLayoutReplacement(self), priority=50)
                try: self.hook_all_methods(self.ChatAvatarContainerClass, "updateSubtitle", _UpdateSubtitleHook(self), priority=50)
                except: pass
                try: self.hook_all_methods(self.ChatAvatarContainerClass, "updateOnlineCount", _RefreshHook(self), priority=50)
                except: pass
                
            if self.ActionBar:
                for method, hook_cls in (("onLayout", _ActionBarLayoutHook), ("setBackButtonDrawable", ActionBarSetBackHook)):
                    try: self.hook_all_methods(self.ActionBar, method, hook_cls(self), priority=50)
                    except: pass

            if ChatActivity:
                self.hook_all_methods(ChatActivity, "createView", _ChatActivityCreateViewHook(self), priority=50)

            RecyclerListViewClass = find_class("org.telegram.ui.Components.RecyclerListView")
            CanvasClass = find_class("android.graphics.Canvas")
            if RecyclerListViewClass and CanvasClass:
                method = RecyclerListViewClass.getClass().getDeclaredMethod("dispatchDraw", CanvasClass)
                method.setAccessible(True)
                self.hook_method(method, ListViewDrawHook(self))
                
            ChatActivityEnterView = find_class("org.telegram.ui.Components.ChatActivityEnterView")
            if ChatActivityEnterView:
                try: self.hook_all_methods(ChatActivityEnterView, "dispatchDraw", EnterViewDispatchDrawHook(self), priority=50)
                except: pass

            ChatActivityChannelButtonsLayout = find_class("org.telegram.ui.Components.chat.layouts.ChatActivityChannelButtonsLayout")
            if ChatActivityChannelButtonsLayout:
                try: self.hook_all_methods(ChatActivityChannelButtonsLayout, "showButton", ChannelDynamicGiftHook(self), priority=50)
                except: pass

            self.ActionBarMenuItemClass = find_class("org.telegram.ui.ActionBar.ActionBarMenuItem")
            if self.ActionBarMenuItemClass:
                search_hook = _SearchFieldVisibilityHook(self)
                for method_name in ("toggleSearch", "openSearch", "setSearchFieldVisible", "showSearchField", "closeSearchField", "collapseSubMenu"):
                    try: self.hook_all_methods(self.ActionBarMenuItemClass, method_name, search_hook, priority=50)
                    except: pass
        except Exception as e: self.log(f"Load error: {traceback.format_exc()}")

    def _on_setting_change(self, val=None):
        reset_trig = str(self.get_setting("reset_trigger", "")).strip().lower()
        if reset_trig == "да":
            for k, v in self._default_settings.items(): self.set_setting(k, v)
            self.set_setting("reset_trigger", "")
            try:
                from android.widget import Toast
                if self.ApplicationLoader: Toast.makeText(self.ApplicationLoader.applicationContext, "Настройки сброшены!\nПерезайдите в меню.", 0).show()
            except Exception: pass
        self._load_settings_cache()
        self._check_theme_colors()
        self._force_redraw()

    def _create_ht_settings(self):
        return [
            Header(text="Фон: Имя чата"),
            Selector(key="ht_color_preset", text="🎨 Цвет", items=COLOR_OPTIONS, default=0, on_change=self._on_setting_change),
            Selector(key="ht_opacity_preset", text="💧 Насыщенность (Mix)", items=TINT_OPTIONS, default=5, on_change=self._on_setting_change),
            Selector(key="ht_alpha_preset", text="👻 Прозрачность (Alpha)", items=ALPHA_OPTIONS, default=2, on_change=self._on_setting_change),
            Input(key="ht_custom_hex", text="✍️ Свой HEX", default="", on_change=self._on_setting_change),
            Divider(),
            Header(text="Обводка: Имя чата"),
            Switch(key="h_text_stroke", text="✨ Включить обводку", default=True, on_change=self._on_setting_change),
            Selector(key="ht_stroke_color", text="🖌️ Цвет обводки", items=COLOR_OPTIONS, default=0, on_change=self._on_setting_change),
            Selector(key="ht_stroke_opacity", text="💦 Насыщенность обводки", items=TINT_OPTIONS, default=5, on_change=self._on_setting_change),
            Input(key="ht_stroke_hex", text="✍️ Свой HEX обводки", default="", on_change=self._on_setting_change),
            Input(key="ht_stroke_width", text="📏 Толщина (в dp)", default="1", on_change=self._on_setting_change),
        ]

