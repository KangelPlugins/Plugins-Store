def _reply_topic_id(reply_to):
    if reply_to is None:
        return 0
    for attr_name in ("reply_to_top_id", "reply_to_msg_id"):
        try:
            value = int(getattr(reply_to, attr_name, 0) or 0)
        except Exception:
            value = 0
        if value != 0:
            return value
    return 0

def _msg_topic_id(message_obj, peer_id):
    try:
        if peer_id > 0:
            return 0
        chat_id = abs(int(peer_id or 0))
        chat = get_messages_controller().getChat(chat_id)
        if not chat or not ChatObject.isForum(chat):
            return 0
        msg_owner = getattr(message_obj, "messageOwner", None)
        topic_id = _reply_topic_id(getattr(msg_owner, "reply_to", None))
        if topic_id:
            return topic_id
        try:
            account = get_user_config().selectedAccount
            topic_source = msg_owner or message_obj
            topic_id = MessageObject.getTopicId(account, topic_source, True)
            return topic_id if topic_id != 0 else 0
        except Exception as e:
            log(f"[QuoteCreate] Error getting topic ID: {e}")
            return 0
    except Exception as e:
        log(f"[QuoteCreate] Error in _msg_topic_id: {e}")
        return 0

def _make_top_reply(topic_id, peer_id):
    try:
        if topic_id <= 0:
            return None
        reply_message = TLRPC.TL_message()
        reply_message.message = ""
        reply_message.id = topic_id
        reply_message.peer_id = get_messages_controller().getPeer(peer_id)
        account = get_user_config().selectedAccount
        reply_to_top_msg = MessageObject(account, reply_message, False, False)
        return reply_to_top_msg
    except Exception as e:
        log(f"[QuoteCreate] Error creating replyToTopMsg: {e}")
        return None

def init_java():
    if J: return True
    try:
        cls = {'CA':"org.telegram.ui.ChatActivity", 'Cell':"org.telegram.ui.Cells.ChatMessageCell",
               'Res':"org.telegram.messenger.ChatMessageSharedResources", 'MO':"org.telegram.messenger.MessageObject",
               'Send':"org.telegram.messenger.SendMessagesHelper", 'MC':"org.telegram.messenger.MessagesController",
               'SD':"org.telegram.tgnet.SerializedData", 'Bool':"java.lang.Boolean",
               'Float':"java.lang.Float", 'Double':"java.lang.Double"}
        for k,v in cls.items(): J[k] = find_class(v)
        from android.widget import ImageView, FrameLayout
        from android.graphics import Bitmap, BitmapFactory, Canvas, Color, Paint, Rect, RectF, Path, PorterDuff, PorterDuffXfermode
        from android.view import View, Gravity
        from android.content import Context, ClipData
        from java.io import File, ByteArrayOutputStream
        from androidx.core.content import FileProvider
        J.update({'IV':ImageView, 'FL':FrameLayout, 'Bmp':Bitmap, 'BmpF':BitmapFactory, 'Canvas':Canvas,
                  'Color':Color, 'Paint':Paint, 'Rect':Rect, 'RectF':RectF, 'View':View, 'Grav':Gravity, 'Ctx':Context,
                  'Clip':ClipData, 'File':File, 'BAO':ByteArrayOutputStream, 'FP':FileProvider,
                  'Mode': PorterDuff.Mode, 'Xfermode': PorterDuffXfermode, 'Path': Path})
        action_cell_cls = find_class("org.telegram.ui.Cells.ChatActionCell")
        if action_cell_cls:
            J['ActionCell'] = action_cell_cls
        spoiler_cls = find_class("org.telegram.ui.Components.spoilers.SpoilerEffect")
        if spoiler_cls:
            J['Spoiler'] = spoiler_cls
        return all(J.values())
    except Exception as e: return False

class Delegate(dynamic_proxy(find_class("org.telegram.ui.Cells.ChatMessageCell$ChatMessageCellDelegate"))):
    def __init__(self, chat):
        super().__init__()
        self.chat, self.did = chat, chat.getDialogId()
        self.acc, self.sel = get_private_field(chat, "currentAccount"), get_private_field(chat, "selectedMessagesIds")
        self.mode = get_private_field(chat, "chatMode") or 0
        self.res, self.theme = get_private_field(chat, "sharedResources"), get_private_field(chat, "themeDelegate")
        self.mc = J['MC'].getInstance(self.acc)
        self.chat_obj = self.mc.getChat(-self.did) if self.did < 0 else None
        try: self.current_chat = get_private_field(chat, "currentChat")
        except: self.current_chat = None
        try: self.current_user = get_private_field(chat, "currentUser")
        except: self.current_user = None
        try: self.forum_topic = get_private_field(chat, "forumTopic")
        except: self.forum_topic = None
        self.is_ch = bool(self.chat_obj and getattr(self.chat_obj, 'broadcast', False))
        try: self.pin = chat.getPinnedMessageId()
        except: self.pin = 0

    def getDialogId(self): return self.did
    def getSelectedMessages(self): return self.sel
    def getChatMode(self): return self.mode
    def canDrawOutboundsContent(self): return True
    def getTopPinnedMessageId(self): return self.pin
    def getBottomPinnedMessageId(self): return self.pin
    def isLandscape(self): return AndroidUtilities.displaySize.x > AndroidUtilities.displaySize.y
    def isPinnedMessage(self, m): return self.pin > 0 and m and m.messageOwner and m.getId() == self.pin
    def getResourcesProvider(self): return self.theme
    def getSharedResources(self): return self.res
    def getChatActivity(self): return self.chat
    def isChannel(self): return self.is_ch
    def isGroup(self): return not self.is_ch and self.did < 0
    def isSupergroup(self): return getattr(self.chat_obj, 'megagroup', False)
    def isAdmin(self, uid):
        try:
            return bool(self.current_chat and not ChatObject.isChannelAndNotMegaGroup(self.current_chat) and self.mc.isAdmin(self.current_chat.id, uid))
        except Exception:
            return False
    def isOwner(self, uid):
        try:
            return bool(self.current_chat and not ChatObject.isChannelAndNotMegaGroup(self.current_chat) and self.mc.isOwner(self.current_chat.id, uid))
        except Exception:
            return False
    def getAdminRank(self, uid):
        try:
            if self.current_user and UserObject.isBotForum(self.current_user):
                return None
        except Exception:
            pass
        try:
            if self.current_chat and not ChatObject.isChannelAndNotMegaGroup(self.current_chat):
                rank = self.mc.getAdminRank(self.current_chat.id, uid)
                if rank is not None:
                    return rank
        except Exception:
            pass
        try:
            from_id = getattr(self.forum_topic, "from_id", None)
            if from_id and (getattr(from_id, "user_id", 0) == uid or getattr(from_id, "channel_id", 0) == uid or getattr(from_id, "chat_id", 0) == uid):
                return LocaleController.getString(R.string.TopicCreator)
        except Exception:
            pass
        return None
    def shouldRepeatSticker(self, m): return True
    def doNotShowLoadingReply(self, m): return m and m.getDialogId() == UserObject.REPLY_BOT
    def getTopicId(self): return 0

    for m in "getThreadMessage getTopPinnedMessage getBottomPinnedMessage getChatStyle getInstantVideoPlayer getPinchToZoomHelper getPhotoPreviewPinchToZoomHelper getFlickerLoadingView getChatListView getPatternProvider getTextSelectionHelper getProgressLoadingBotButtonUrl getProgressLoadingLink didPressExtendedMediaPreview didPressUserStatus didPressUserAvatar didPressHiddenForward didPressViaBotNotInline didPressViaBot didPressBoostCounter didPressChannelAvatar didPressCancelSendButton didLongPress didPressReplyMessage didPressUrl didPressCodeCopy didPressChannelRecommendation didPressMoreChannelRecommendations didPressChannelRecommendationsClose needOpenWebView didPressWebPage didPressImage didPressGroupImage didPressSideButton didQuickShareStart didQuickShareMove didQuickShareEnd didPressOther didPressSponsoredClose didPressSummarize didPressSponsoredInfo didPressTime didPressBotButton didLongPressBotButton didPressCustomBotButton didLongPressCustomBotButton didPressReaction didPressVoteButtons didPressInstantButton didPressGiveawayChatButton didPressCommentButton didPressHint needShowPremiumFeatures needShowPremiumBulletin videoTimerReached didStartVideoStream setShouldNotRepeatSticker needReloadPolls onDiceFinished invalidateBlur didPressTopicButton didPressDialogButton didPressEmojiStatus didPressAboutRevenueSharingAds didPressRevealSensitiveContent didPressEffect didPressFactCheckWhat didPressFactCheck forceUpdate forceUpdateNoAnimation didPressAdmin".split():
        locals()[m] = lambda self,*a: None

    for m in "canPerformActions isTopPinnedMessageVisible isBottomPinnedMessageVisible isFirstMessage isLastMessage didLongPressUserAvatar didLongPressChannelAvatar isProgressLoading didPressToDoButton didLongPressToDoButton needPlayMessage drawingVideoPlayerContainer canPerformReply onAccessibilityAction hasSelectedMessages keyboardIsOpened didPressAnimatedEmoji shouldShowTopicButton shouldShowDialogButton shouldDrawThreadProgress isReplyOrSelf".split():
        locals()[m] = lambda self,*a: False

    for m in "getProgressToNext getProgressToPrev".split():
        locals()[m] = lambda self,*a: 1.0

class QuotePreviewSheet:
    def __init__(self, plugin, activity, chat, data, msgs, first_msg, reply_to_top_msg):
        self.plugin = plugin
        self.activity = activity
        self.chat = chat
        self.data = data
        self.msgs = list(msgs or [])
        self.first_msg = first_msg
        self.reply_to_top_msg = reply_to_top_msg
        self.dialog_id = chat.getDialogId() if chat else 0
        self.resources_provider = self._get_provider()
        self.sheet = None
        self.preview_bitmap = None
        self.preview_view = None
        self._dismiss_listener = None
        self._anonymize_button = None
        self._anonymize_title = None
        self._anonymize_subtitle = None
        self._anonymize_rendering = False
        self.anonymize_enabled = False

        from org.telegram.ui.ActionBar import BottomSheet
        from org.telegram.ui.Components import LayoutHelper
        from android.widget import LinearLayout, TextView, ImageView, FrameLayout, ScrollView
        from android.view import Gravity
        from android.util import TypedValue
        from android.graphics import Color, Typeface
        from android.graphics.drawable import GradientDrawable, RippleDrawable
        from android.content.res import ColorStateList

        self.BottomSheet = BottomSheet
        self.LayoutHelper = LayoutHelper
        self.LinearLayout = LinearLayout
        self.TextView = TextView
        self.ImageView = ImageView
        self.FrameLayout = FrameLayout
        self.ScrollView = ScrollView
        self.Gravity = Gravity
        self.TypedValue = TypedValue
        self.Color = Color
        self.Typeface = Typeface
        self.GradientDrawable = GradientDrawable
        self.RippleDrawable = RippleDrawable
        self.ColorStateList = ColorStateList

    def _get_provider(self):
        provider = None
        if self.chat is not None:
            try:
                provider = get_private_field(self.chat, "themeDelegate")
            except Exception:
                provider = None
            if provider is None:
                try:
                    provider = self.chat.getResourceProvider()
                except Exception:
                    provider = None
        return provider

    def _signed_color(self, value):
        color = int(value) & 0xFFFFFFFF
        if color >= 0x80000000:
            color -= 0x100000000
        return color

    def _color(self, key, fallback=None):
        try:
            if self.resources_provider is not None:
                return self._signed_color(Theme.getColor(key, self.resources_provider))
        except Exception:
            pass
        try:
            return self._signed_color(Theme.getColor(key))
        except Exception:
            return self._signed_color(fallback if fallback is not None else 0xFF1F2329)

    def _alpha(self, color, alpha):
        alpha_value = max(0, min(255, int(float(alpha) * 255)))
        return self._signed_color((alpha_value << 24) | (int(color) & 0x00FFFFFF))

    def _dp(self, value):
        return AndroidUtilities.dp(int(value))

    def _accent_color(self):
        return self._color(Theme.key_featuredStickers_addButton, 0xFF3390EC)

    def _accent_text(self):
        return self._color(
            Theme.key_featuredStickers_buttonText,
            self._fill_text(self._accent_color()),
        )

    def _subtle_fill(self):
        return self._color(Theme.key_buttonNeutral, 0xFFE4E4E4)

    def _subtle_text(self):
        return self._color(
            Theme.key_buttonNeutralText,
            self._fill_text(self._subtle_fill()),
        )

    def _subtle_stroke(self):
        return self._color(Theme.key_listSelector, 0x33000000)

    def _soft_surface_color(self):
        return self._alpha(self._color(Theme.key_windowBackgroundWhite, 0xFFFFFFFF), 0.03)

    def _muted_text_color(self):
        return self._color(Theme.key_dialogTextGray2, 0xFF8D98A5)

    def _is_light(self, color):
        value = int(color) & 0xFFFFFFFF
        r = (value >> 16) & 0xFF
        g = (value >> 8) & 0xFF
        b = value & 0xFF
        return ((r * 299) + (g * 587) + (b * 114)) >= 186000

    def _fill_text(self, fill_color):
        return self._signed_color(0xFF101318 if self._is_light(fill_color) else 0xFFFFFFFF)

    def _muted_fill_text(self, fill_color, alpha=0.72):
        return self._alpha(self._fill_text(fill_color), alpha)

    def _has_anonymize_targets(self):
        return bool(
            self.plugin.get_setting("anonymize_nickname", False)
            or self.plugin.get_setting("anonymize_avatar", False)
        )

    def _anonymize_text(self):
        parts = []
        if bool(self.plugin.get_setting("anonymize_nickname", False)):
            parts.append("ะฝะธะบะฝะตะนะผ")
        if bool(self.plugin.get_setting("anonymize_avatar", False)):
            parts.append("ะฐะฒะฐัะฐั")
        if not parts:
            return "ะฝะธัะตะณะพ ะฝะต ะฒัะฑัะฐะฝะพ"
        if len(parts) == 2:
            return "ะฝะธะบะฝะตะนะผ ะธ ะฐะฒะฐัะฐั"
        return parts[0]

    def _swap_preview(self, data):
        new_bitmap = J['BmpF'].decodeByteArray(data, 0, len(data))
        if new_bitmap is None:
            raise Exception("Preview decode failed")

        if self.sheet is None:
            try:
                new_bitmap.recycle()
            except Exception:
                pass
            return False

        old_bitmap = self.preview_bitmap
        self.preview_bitmap = new_bitmap
        self.data = data

        if self.preview_view is not None:
            try:
                self.preview_view.setImageBitmap(new_bitmap)
            except Exception:
                pass

        if old_bitmap is not None and old_bitmap is not new_bitmap:
            try:
                old_bitmap.recycle()
            except Exception:
                pass
        return True

    def _decode_preview(self):
        if self.preview_bitmap is None:
            self.preview_bitmap = J['BmpF'].decodeByteArray(self.data, 0, len(self.data))
        if self.preview_bitmap is None:
            raise Exception("Preview decode failed")
        self.anonymize_enabled = self._has_anonymize_targets()
        return self.preview_bitmap

    def _card_bg(self, radius_dp=24, stroke_alpha=0.07):
        drawable = self.GradientDrawable()
        drawable.setCornerRadius(float(self._dp(radius_dp)))
        drawable.setColor(self._soft_surface_color())
        drawable.setStroke(self._dp(1), self._alpha(self._subtle_stroke(), stroke_alpha))
        return drawable

    def _tap_bg(self, fill_color=None, radius_dp=18, ripple_alpha=0.18, stroke_color=None, stroke_width_dp=1):
        base = self.GradientDrawable()
        base.setCornerRadius(float(self._dp(radius_dp)))
        base.setColor(fill_color if fill_color is not None else self.Color.TRANSPARENT)
        if stroke_color is not None:
            try:
                base.setStroke(self._dp(stroke_width_dp), stroke_color)
            except Exception:
                pass
        try:
            return self.RippleDrawable(
                self.ColorStateList.valueOf(self._alpha(self._color(Theme.key_listSelector, 0x33000000), ripple_alpha)),
                base,
                None,
            )
        except Exception:
            return base

    def _set_tap_bg(self, view, fill_color=None, radius_dp=18, ripple_alpha=0.18, stroke_color=None, stroke_width_dp=1):
        try:
            view.setBackground(self._tap_bg(fill_color, radius_dp, ripple_alpha, stroke_color, stroke_width_dp))
        except Exception:
            pass

    def _icon(self, *names):
        resources = None
        package_name = None
        try:
            resources = self.activity.getResources()
            package_name = self.activity.getPackageName()
        except Exception:
            pass
        for name in names:
            if not name:
                continue
            try:
                res_id = int(getattr(R.drawable, name))
                if res_id:
                    return res_id
            except Exception:
                pass
            if resources is not None and package_name:
                try:
                    res_id = int(resources.getIdentifier(name, "drawable", package_name) or 0)
                    if res_id:
                        return res_id
                except Exception:
                    pass
        return 0

    def _make_sheet(self):
        try:
            sheet = self.BottomSheet(self.activity, False)
        except Exception:
            sheet = self.BottomSheet(self.activity, False)
        try:
            sheet.fixNavigationBar(self._color(Theme.key_dialogBackground, 0xFF101318))
        except Exception:
            pass
        return sheet

    def _bind_dismiss(self):
        dismiss_listener_cls = find_class("android.content.DialogInterface$OnDismissListener")
        if dismiss_listener_cls is None or self.sheet is None:
            return
        owner = self

        class _DismissListener(dynamic_proxy(dismiss_listener_cls)):
            def __init__(self):
                super().__init__()

            def onDismiss(self, _dialog):
                owner._free_preview()
                owner.sheet = None

        self._dismiss_listener = _DismissListener()
        try:
            self.sheet.setOnHideListener(self._dismiss_listener)
        except Exception:
            try:
                self.sheet.setOnDismissListener(self._dismiss_listener)
            except Exception:
                pass

    def _free_preview(self):
        try:
            if self.preview_view is not None:
                try:
                    self.preview_view.setImageBitmap(None)
                except Exception:
                    try:
                        self.preview_view.setImageDrawable(None)
                    except Exception:
                        pass
        finally:
            self.preview_view = None
        if self.preview_bitmap is not None:
            try:
                self.preview_bitmap.recycle()
            except Exception:
                pass
            self.preview_bitmap = None

    def dismiss(self):
        if self.sheet is not None:
            try:
                self.sheet.dismiss()
            except Exception:
                pass

    def show(self):
        try:
            self._decode_preview()
            self.sheet = self._make_sheet()
            self._bind_dismiss()
            self.sheet.setCustomView(self._build())
            self.sheet.show()
        except Exception:
            self._free_preview()
            raise

    def _build(self):
        root = self.LinearLayout(self.activity)
        root.setOrientation(self.LinearLayout.VERTICAL)
        try:
            root.setBackgroundColor(self._color(Theme.key_dialogBackground, 0xFF101318))
        except Exception:
            pass

        scroll = self.ScrollView(self.activity)
        scroll.setFillViewport(True)
        scroll.setVerticalScrollBarEnabled(False)
        try:
            scroll.setClipToPadding(False)
        except Exception:
            pass

        content = self.LinearLayout(self.activity)
        content.setOrientation(self.LinearLayout.VERTICAL)
        content.setPadding(self._dp(12), self._dp(12), self._dp(12), self._dp(12))
        try:
            content.setBackgroundColor(self._color(Theme.key_dialogBackground, 0xFF101318))
        except Exception:
            pass

        content.addView(self._header(), self.LayoutHelper.createLinear(-1, -2))
        content.addView(self._preview_card(), self.LayoutHelper.createLinear(-1, -2, 0, 0, 8, 0, 0))
        content.addView(self._anon_toggle(), self.LayoutHelper.createLinear(-1, -2, 0, 0, 8, 0, 0))
        content.addView(self._primary_btn(), self.LayoutHelper.createLinear(-1, -2, 0, 0, 8, 0, 6))
        content.addView(self._secondary_row(), self.LayoutHelper.createLinear(-1, -2, 0, 0, 0, 0, 6))
        content.addView(self._utility_row(), self.LayoutHelper.createLinear(-1, -2))

        scroll.addView(content, self.LayoutHelper.createFrame(-1, -2))
        root.addView(scroll, self.LayoutHelper.createLinear(-1, -1))
        return root

    def _header(self):
        row = self.LinearLayout(self.activity)
        row.setOrientation(self.LinearLayout.HORIZONTAL)
        row.setGravity(self.Gravity.CENTER_VERTICAL)

        title_view = self.TextView(self.activity)
        title_view.setText(f"ะฆะธัะฐัะฐ ยท {len(self.msgs)} ัะพะพะฑั.")
        title_view.setTextColor(self._color(Theme.key_dialogTextBlack, 0xFFFFFFFF))
        title_view.setTextSize(self.TypedValue.COMPLEX_UNIT_DIP, 15)
        title_view.setTypeface(self.Typeface.DEFAULT_BOLD)
        title_view.setSingleLine(True)
        row.addView(title_view, self.LinearLayout.LayoutParams(0, self.LinearLayout.LayoutParams.WRAP_CONTENT, 1.0))

        close_button = self.FrameLayout(self.activity)
        close_button.setClickable(True)
        close_button.setFocusable(True)
        close_fill = self._subtle_fill()
        self._set_tap_bg(
            close_button,
            close_fill,
            radius_dp=16,
        )
        close_button.setOnClickListener(OnClickListener(lambda *_: self.dismiss()))

        close_icon = self.ImageView(self.activity)
        close_icon.setImageResource(R.drawable.msg_close)
        try:
            close_icon.setColorFilter(self._subtle_text())
        except Exception:
            pass
        close_button.addView(close_icon, self.LayoutHelper.createFrame(16, 16, self.Gravity.CENTER))
        close_lp = self.LinearLayout.LayoutParams(self._dp(32), self._dp(32))
        close_lp.leftMargin = self._dp(8)
        row.addView(close_button, close_lp)
        return row

    def _preview_card(self):
        card = self.LinearLayout(self.activity)
        card.setOrientation(self.LinearLayout.VERTICAL)
        card.setPadding(self._dp(10), self._dp(10), self._dp(10), self._dp(10))
        card.setBackground(self._card_bg(radius_dp=20, stroke_alpha=0.08))

        preview_shell = self.FrameLayout(self.activity)
        preview_shell.setPadding(self._dp(8), self._dp(8), self._dp(8), self._dp(8))
        preview_bg = self.GradientDrawable()
        preview_bg.setCornerRadius(float(self._dp(16)))
        preview_bg.setColor(self._soft_surface_color())
        preview_shell.setBackground(preview_bg)

        preview_view = self.ImageView(self.activity)
        preview_view.setAdjustViewBounds(True)
        preview_view.setScaleType(self.ImageView.ScaleType.FIT_CENTER)
        preview_view.setImageBitmap(self.preview_bitmap)
        self.preview_view = preview_view
        preview_shell.addView(preview_view, self.LayoutHelper.createFrame(-1, -2, self.Gravity.CENTER))
        card.addView(preview_shell, self.LayoutHelper.createLinear(-1, -2))
        return card

    def _sync_anonymize(self):
        if self._anonymize_button is None or self._anonymize_title is None or self._anonymize_subtitle is None:
            return

        has_targets = self._has_anonymize_targets()
        can_toggle = has_targets and not self._anonymize_rendering
        fill_color = self._subtle_fill()
        title_color = self._subtle_text()
        subtitle_color = self._alpha(title_color, 0.72)

        if self._anonymize_rendering:
            title_color = self._subtle_text()
            subtitle_color = self._alpha(title_color, 0.72)
            subtitle = "ะะฑะฝะพะฒะปัั ะฟัะตะฒัั..."
        elif not has_targets:
            title_color = self._subtle_text()
            subtitle_color = self._alpha(title_color, 0.72)
            subtitle = "ะกะฝะฐัะฐะปะฐ ะฒัะฑะตัะธัะต, ััะพ ัะบััะฒะฐัั ะฒ ะฝะฐัััะพะนะบะฐั"
        elif self.anonymize_enabled:
            fill_color = self._accent_color()
            title_color = self._accent_text()
            subtitle_color = self._alpha(title_color, 0.78)
            subtitle = f"ะะบะปััะตะฝะฐ: {self._anonymize_text()}"
        else:
            title_color = self._subtle_text()
            subtitle_color = self._alpha(title_color, 0.72)
            subtitle = f"ะัะบะปััะตะฝะฐ: {self._anonymize_text()}"

        self._set_tap_bg(
            self._anonymize_button,
            fill_color,
            radius_dp=18,
            ripple_alpha=0.22,
        )
        try:
            self._anonymize_button.setClickable(can_toggle)
            self._anonymize_button.setFocusable(can_toggle)
            self._anonymize_button.setAlpha(1.0 if has_targets else 0.72)
        except Exception:
            pass

        self._anonymize_title.setTextColor(title_color)
        self._anonymize_subtitle.setText(subtitle)
        self._anonymize_subtitle.setTextColor(subtitle_color)

    def _toggle_anon(self):
        if self._anonymize_rendering:
            return
        if not self._has_anonymize_targets():
            BulletinHelper.show_info("ะะบะปััะธัะต ัะบัััะธะต ะฝะธะบะฝะตะนะผะฐ ะธะปะธ ะฐะฒะฐัะฐัะฐ ะฒ ะฝะฐัััะพะนะบะฐั ะฟะปะฐะณะธะฝะฐ")
            return

        target_state = not self.anonymize_enabled
        self._anonymize_rendering = True
        self._sync_anonymize()

        def render_preview():
            bg_bmp = None
            try:
                bg_bmp = self.plugin._render_bg(self.chat)
                data = self.plugin._render_bytes(
                    self.msgs,
                    self.chat,
                    bg_bmp=bg_bmp,
                    anonymize_enabled=target_state,
                )
                if not data:
                    raise Exception("Render failed")

                def apply_preview():
                    try:
                        if self._swap_preview(data):
                            self.anonymize_enabled = target_state
                    except Exception as e:
                        BulletinHelper.show_error(f"ะะต ัะดะฐะปะพัั ะพะฑะฝะพะฒะธัั ะฟัะตะฒัั: {str(e)[:80]}")
                    finally:
                        self._anonymize_rendering = False
                        self._sync_anonymize()

                run_on_ui_thread(apply_preview)
            except Exception as e:
                err = str(e)

                def show_error():
                    self._anonymize_rendering = False
                    self._sync_anonymize()
                    BulletinHelper.show_error(f"ะะต ัะดะฐะปะพัั ะพะฑะฝะพะฒะธัั ะฟัะตะฒัั: {err[:80]}")

                run_on_ui_thread(show_error)
            finally:
                if bg_bmp is not None:
                    try:
                        bg_bmp.recycle()
                    except Exception:
                        pass

        threading.Thread(target=render_preview).start()

    def _anon_toggle(self):
        button = self.FrameLayout(self.activity)
        button.setMinimumHeight(self._dp(54))
        button.setClickable(True)
        button.setFocusable(True)
        button.setOnClickListener(OnClickListener(lambda *_: self._toggle_anon()))

        content = self.LinearLayout(self.activity)
        content.setOrientation(self.LinearLayout.VERTICAL)
        content.setPadding(self._dp(14), self._dp(12), self._dp(14), self._dp(12))

        title_view = self.TextView(self.activity)
        title_view.setText("ะะฝะพะฝะธะผะธะทะฐัะธั")
        title_view.setTextSize(self.TypedValue.COMPLEX_UNIT_DIP, 14)
        title_view.setTypeface(self.Typeface.DEFAULT_BOLD)
        content.addView(title_view, self.LayoutHelper.createLinear(-1, -2))

        subtitle_view = self.TextView(self.activity)
        subtitle_view.setTextSize(self.TypedValue.COMPLEX_UNIT_DIP, 11.5)
        content.addView(subtitle_view, self.LayoutHelper.createLinear(-1, -2, 0, 0, 4, 0, 0))

        button.addView(content, self.LayoutHelper.createFrame(-1, -2, self.Gravity.CENTER))
        self._anonymize_button = button
        self._anonymize_title = title_view
        self._anonymize_subtitle = subtitle_view
        self._sync_anonymize()
        return button

    def _action_btn(self, title, on_click, *, fill_color, text_color, subtitle=None, radius_dp=16, min_height_dp=46, icon_res=None, icon_size_dp=20, stroke_color=None, stroke_width_dp=1):
        button = self.FrameLayout(self.activity)
        button.setClickable(True)
        button.setFocusable(True)
        button.setMinimumHeight(self._dp(min_height_dp))
        if title:
            try:
                button.setContentDescription(title)
            except Exception:
                pass
        self._set_tap_bg(
            button,
            fill_color,
            radius_dp=radius_dp,
            ripple_alpha=0.22,
            stroke_color=stroke_color,
            stroke_width_dp=stroke_width_dp,
        )

        content = self.LinearLayout(self.activity)
        content.setOrientation(self.LinearLayout.VERTICAL)
        content.setGravity(self.Gravity.CENTER)
        has_icon = bool(icon_res)
        show_title = bool(title) and not has_icon
        vertical_padding = 7 if has_icon and not show_title and not subtitle else 9
        content.setPadding(self._dp(12), self._dp(vertical_padding), self._dp(12), self._dp(vertical_padding))

        if has_icon:
            icon_view = self.ImageView(self.activity)
            icon_view.setScaleType(self.ImageView.ScaleType.CENTER_INSIDE)
            icon_view.setImageResource(icon_res)
            try:
                icon_view.setColorFilter(text_color)
            except Exception:
                pass
            icon_params = self.LinearLayout.LayoutParams(self._dp(icon_size_dp), self._dp(icon_size_dp))
            content.addView(icon_view, icon_params)

        if show_title:
            title_view = self.TextView(self.activity)
            title_view.setText(title)
            title_view.setGravity(self.Gravity.CENTER)
            title_view.setTextColor(text_color)
            title_view.setTextSize(self.TypedValue.COMPLEX_UNIT_DIP, 14)
            title_view.setTypeface(self.Typeface.DEFAULT_BOLD)
            title_view.setSingleLine(True)
            content.addView(title_view)

        if subtitle:
            subtitle_view = self.TextView(self.activity)
            subtitle_view.setText(subtitle)
            subtitle_view.setGravity(self.Gravity.CENTER)
            subtitle_view.setTextColor(self._alpha(text_color, 0.72))
            subtitle_view.setTextSize(self.TypedValue.COMPLEX_UNIT_DIP, 11.5)
            content.addView(subtitle_view, self.LayoutHelper.createLinear(-1, -2, 0, 0, 3, 0, 0))

        button.addView(content, self.LayoutHelper.createFrame(-1, -2, self.Gravity.CENTER))
        button.setOnClickListener(OnClickListener(lambda *args: on_click(args[0] if args else button)))
        return button

    def _primary_btn(self):
        fill_color = self._accent_color()
        return self._action_btn(
            "ะคะพัะพ",
            self._send_photo,
            fill_color=fill_color,
            text_color=self._accent_text(),
            radius_dp=18,
        )

    def _secondary_row(self):
        row = self.LinearLayout(self.activity)
        row.setOrientation(self.LinearLayout.HORIZONTAL)
