            Divider("ะัะปะธ ัะฟะพะนะปะตั ะฝะตะดะพัััะฟะตะฝ, ะธัะฟะพะปัะทัะตััั ะทะฐะผะฐะทะบะฐ."),
            Switch("anonymize_nickname", "ะกะบััะฒะฐัั ะฝะธะบะฝะตะนะผ", False, icon="menu_feature_transparent"),
            Switch("anonymize_avatar", "ะกะบััะฒะฐัั ะฐะฒะฐัะฐั", False, icon="msg_openprofile"),
