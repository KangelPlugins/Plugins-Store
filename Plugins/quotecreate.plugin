        row.addView(sticker_button, self.LayoutHelper.createLinear(0, -2, 1.0, 4, 0, 0, 0))
        return row

    def _utility_row(self):
        row = self.LinearLayout(self.activity)
        row.setOrientation(self.LinearLayout.HORIZONTAL)
        row.setGravity(self.Gravity.CENTER_VERTICAL)

        subtle_fill = self._subtle_fill()
        subtle_text = self._subtle_text()

        copy_button = self._action_btn(
            "ะะพะฟะธัะพะฒะฐัั",
            self._copy_out,
            fill_color=subtle_fill,
            text_color=subtle_text,
            radius_dp=14,
            min_height_dp=40,
            icon_res=self._icon("msg_copy_solar", "msg_copy", "menu_copy_s"),
            icon_size_dp=18,
        )
        save_button = self._action_btn(
            "ะ ะณะฐะปะตัะตั",
            self._save_out,
            fill_color=subtle_fill,
            text_color=subtle_text,
            radius_dp=14,
            min_height_dp=40,
            icon_res=R.drawable.msg_gallery_solar,
            icon_size_dp=18,
        )
        share_button = self._action_btn(
            "ะะพะดะตะปะธัััั",
            self._share_out,
            fill_color=subtle_fill,
            text_color=subtle_text,
            radius_dp=14,
            min_height_dp=40,
            icon_res=self._icon("msg_share_solar", "msg_share", "share"),
            icon_size_dp=18,
        )

        row.addView(copy_button, self.LayoutHelper.createLinear(0, -2, 1.0, 0, 0, 4, 0))
        row.addView(save_button, self.LayoutHelper.createLinear(0, -2, 1.0, 4, 0, 4, 0))
        row.addView(share_button, self.LayoutHelper.createLinear(0, -2, 1.0, 4, 0, 0, 0))
        return row

    def _send_photo(self, view=None):
        self.dismiss()
        self.plugin._send(self.data, self.dialog_id, self.reply_to_top_msg, send_mode="photo")

    def _send_file(self, view=None):
        self.dismiss()
        self.plugin._send(self.data, self.dialog_id, self.reply_to_top_msg, send_mode="file")

    def _send_sticker(self, view=None):
        self.dismiss()
        self.plugin._send_sticker(
            self.msgs,
            self.chat,
            self.dialog_id,
            self.reply_to_top_msg,
            anonymize_enabled=self.anonymize_enabled,
        )

    def _copy_out(self, view=None):
        self.dismiss()
        self.plugin._copy(self.data, self.activity, view)

    def _save_out(self, view=None):
        self.dismiss()
        self.plugin._save_gallery(self.data, self.activity, view)

    def _share_out(self, view=None):
        self.dismiss()
        self.plugin._share(self.data, self.activity, view)

class ExteraShotPlugin(BasePlugin):
    def __init__(self):
        super().__init__()
        self.btn, self.tmp = None, None
        self._bg_color_picker_sheet = None
        self._bg_color_picker_consumer = None
        self._bg_color_picker_pipette_delegate = None
        self._bg_color_picker_delegate = None
        self._action_selected_fill_paint = None

    def _action_bar(self, chat):
        try:
            return chat.getActionBar() if chat else None
        except Exception:
            return None

    def _action_mode_on(self, chat):
        action_bar = self._action_bar(chat)
        try:
            return bool(action_bar and action_bar.isActionModeShowed())
        except Exception:
            return False

    def _is_action_cell(self, view):
        action_cls = J.get('ActionCell')
        if action_cls is None or view is None:
            return False
        try:
            return bool(action_cls.isInstance(view))
        except Exception:
            return False

    def _view_msg(self, view):
        try:
            return view.getMessageObject() if view is not None else None
        except Exception:
            return None

    def _call_chat(self, chat, method_name, arg_types=(), args=(), required=False):
        try:
            method = chat.getClass().getDeclaredMethod(method_name, *arg_types)
            method.setAccessible(True)
            return method.invoke(chat, *args)
        except Exception:
            if required:
                raise
            return None

    def _action_cells(self, chat):
        try:
            list_view = chat.getChatListView() if chat else None
        except Exception:
            list_view = None
        if not list_view:
            return

        try:
            total = int(list_view.getChildCount())
        except Exception:
            return

        for index in range(total):
            child = list_view.getChildAt(index)
            if self._is_action_cell(child):
                yield child

    def _cell_chat(self, cell):
        delegate = None
        try:
            delegate = get_private_field(cell, "delegate")
        except Exception:
            delegate = None
        if delegate is None:
            try:
                delegate = getattr(cell, "delegate", None)
            except Exception:
                delegate = None
        if delegate is None:
            return None
        try:
            return delegate.getBaseFragment()
        except Exception:
            return None

    def _clear_hook(self, param):
        try:
            param.setResult(None)
            return
        except Exception:
            pass
        try:
            param.result = None
        except Exception:
            pass

    def _is_service_msg(self, msg):
        try:
            if not msg:
                return False
            owner = getattr(msg, "messageOwner", None)
            if owner is None:
                return False
            return getattr(owner, "action", None) is not None
        except Exception:
            return False

    def _on_action_row(self, param):
        try:
            chat = getattr(param, "thisObject", None)
            if not chat:
                return
            if not self._action_mode_on(chat):
                return

            view = param.args[0] if param.args and len(param.args) > 0 else None
            if view is None:
                return

            action_cls = J.get('ActionCell')
            if action_cls is not None and not self._is_action_cell(view):
                return

            msg = self._view_msg(view)
            if not self._is_service_msg(msg):
                return

            outside = False
            try:
                outside = bool(param.args[1])
            except Exception:
                outside = False

            self._call_chat(
                chat,
                "addToSelectedMessages",
                (J['MO'], J['Bool'].TYPE),
                (msg, outside),
                required=True,
            )
            self._call_chat(chat, "updateActionModeTitle")
            self._call_chat(chat, "updateVisibleRows")

            self._sync_action_cells(chat)
            self._clear_hook(param)
        except Exception as e:
            log(f"[QuoteCreate] processRowSelect hook error: {e}")

    def _is_sel_msg(self, chat, msg):
        try:
            if chat is None or msg is None:
                return False
            sel = get_private_field(chat, "selectedMessagesIds")
            if not sel:
                return False
            idx = 0
            try:
                idx = 0 if msg.getDialogId() == chat.getDialogId() else 1
            except Exception:
                idx = 0
            arr = sel[idx]
            return arr is not None and arr.indexOfKey(msg.getId()) >= 0
        except Exception:
            return False

    def _sync_action_cells(self, chat):
        try:
            if chat is None:
                return
            action_mode = self._action_mode_on(chat)
            for child in self._action_cells(chat):
                msg = self._view_msg(child)
                selected = action_mode and self._is_service_msg(msg) and self._is_sel_msg(chat, msg)
                try:
                    if not action_mode:
                        child.setOverrideColor(-1, -1)
                    elif selected:
                        child.setOverrideColor(Theme.key_chat_serviceBackgroundSelected, Theme.key_chat_serviceText)
                    else:
                        child.setOverrideColor(Theme.key_chat_serviceBackground, Theme.key_chat_serviceText)
                    child.invalidate()
                except Exception:
                    pass
        except Exception as e:
            log(f"[QuoteCreate] action cell visual update error: {e}")

    def _on_action_sel(self, chat):
        self._upd(chat)
        self._sync_action_cells(chat)

    def _on_action_hide(self, chat):
        self._rm()
        self._sync_action_cells(chat)

    def _is_cell_sel(self, cell):
        try:
            if cell is None:
                return False
            msg = self._view_msg(cell)
            if not self._is_service_msg(msg):
                return False

            chat = self._cell_chat(cell)
            if chat is None:
                return False

            if not self._action_mode_on(chat):
                return False

            return self._is_sel_msg(chat, msg)
        except Exception:
            return False

    def _draw_cell_sel(self, param):
        try:
            cell = getattr(param, "thisObject", None)
            if not self._is_cell_sel(cell):
                return
            canvas = param.args[0] if param.args and len(param.args) > 0 else None
            if canvas is None:
                return

            if self._action_selected_fill_paint is None:
                self._action_selected_fill_paint = J['Paint'](J['Paint'].ANTI_ALIAS_FLAG)
                self._action_selected_fill_paint.setStyle(J['Paint'].Style.FILL)

            fill_color = Theme.getColor(Theme.key_chat_serviceBackgroundSelected)
            fr, fg, fb = (fill_color >> 16) & 0xFF, (fill_color >> 8) & 0xFF, fill_color & 0xFF
            self._action_selected_fill_paint.setARGB(118, int(fr), int(fg), int(fb))

            left = 0
            right = int(cell.getWidth())
            top = 0
            bottom = int(cell.getHeight())
            if right <= left or bottom <= top:
                return

            canvas.drawRect(float(left), float(top), float(right), float(bottom), self._action_selected_fill_paint)
        except Exception:
            pass

    def on_plugin_load(self):
        if not init_java(): return BulletinHelper.show_error("KomaruQuote: Java load failed")
        self.tmp = self._tmp_dir()
        cl = J['CA'].getClass()
        self.hook_method(cl.getDeclaredMethod("addToSelectedMessages", J['MO'], J['Bool'].TYPE, J['Bool'].TYPE),
                         type("H", (MethodHook,), {"after_hooked_method": lambda s,p: run_on_ui_thread(lambda: self._on_action_sel(p.thisObject))})())
        try:
            row_select_method = None
            for num_cls in (J.get('Float'), J.get('Double')):
                try:
                    if num_cls:
                        row_select_method = cl.getDeclaredMethod("processRowSelect", J['View'], J['Bool'].TYPE, num_cls.TYPE, num_cls.TYPE)
                        break
                except Exception:
                    pass
            if row_select_method:
                self.hook_method(
                    row_select_method,
                    type("H2", (MethodHook,), {"before_hooked_method": lambda s,p: self._on_action_row(p)})()
                )
            else:
                raise Exception("processRowSelect signature not found")
        except Exception as e:
            log(f"[QuoteCreate] processRowSelect hook skipped: {e}")
        try:
            action_cls = J.get('ActionCell')
            if action_cls:
                on_draw_method = None
                candidates = []
                try:
                    candidates.append(action_cls)
                except Exception:
                    pass
                try:
                    candidates.append(action_cls.getClass())
                except Exception:
                    pass
                for c in candidates:
                    if not c:
                        continue
                    try:
                        on_draw_method = c.getDeclaredMethod("onDraw", J['Canvas'])
                        break
                    except Exception:
                        try:
                            on_draw_method = c.getMethod("onDraw", J['Canvas'])
                            break
                        except Exception:
                            pass
                if on_draw_method:
                    try:
                        on_draw_method.setAccessible(True)
                    except Exception:
                        pass
                    self.hook_method(
                        on_draw_method,
                        type("H3", (MethodHook,), {"after_hooked_method": lambda s,p: self._draw_cell_sel(p)})()
                    )
                else:
                    raise Exception("onDraw method not found")
        except Exception as e:
            log(f"[QuoteCreate] onDraw action hook skipped: {e}")
        self.hook_method(cl.getDeclaredMethod("hideActionMode"),
                         type("H", (MethodHook,), {"after_hooked_method": lambda s,p: run_on_ui_thread(lambda: self._on_action_hide(p.thisObject))})())

        if not self.get_setting("_first_run_done", False):
            self._blink_flash()
            self.set_setting("_first_run_done", True)

    def on_plugin_unload(self):
        self._rm()
        if self.tmp and os.path.exists(self.tmp): shutil.rmtree(self.tmp, ignore_errors=True)

