# ── helpers ───────────────────────────────────────────────────────────────────

def dp(v):
    return AndroidUtilities.dp(v)


def _rounded_bg(color_hex: str, radius_dp: int = 12):
    bg = GradientDrawable()
    bg.setShape(GradientDrawable.RECTANGLE)
    bg.setCornerRadius(dp(radius_dp))
    bg.setColor(Color.parseColor(color_hex))
    return bg


def _make_button(ctx, text: str, color_hex: str, on_click) -> Button:
    btn = Button(ctx)
    btn.setText(text)
    btn.setTextColor(Color.WHITE)
    btn.setTextSize(14)
    btn.setAllCaps(False)
    btn.setBackground(_rounded_bg(color_hex))
    btn.setOnClickListener(OnClickListener(on_click))
    return btn


def _fmt_seconds(total_seconds: int) -> str:
    d = total_seconds // 86400
    h = (total_seconds % 86400) // 3600
    m = (total_seconds % 3600) // 60
    s = total_seconds % 60
    if d > 0:
        return f"{d}d {h:02d}:{m:02d}:{s:02d}"
    return f"{h:02d}:{m:02d}:{s:02d}"


def _lerp_color(c1: str, c2: str, t: float) -> str:
    """Interpolate between two hex colors."""
    def parse(c):
        c = c.lstrip("#")
        return int(c[0:2], 16), int(c[2:4], 16), int(c[4:6], 16)
    r1, g1, b1 = parse(c1)
    r2, g2, b2 = parse(c2)
    t = max(0.0, min(1.0, t))
    r = int(r1 + (r2 - r1) * t)
    g = int(g1 + (g2 - g1) * t)
    b = int(b1 + (b2 - b1) * t)
    return f"#{r:02X}{g:02X}{b:02X}"


# Gradient stops: ratio 1.0 → 0.0 (full → empty)
_COLOR_STOPS = [
    (1.00, "#00E676"),  # bright green
    (0.75, "#69F000"),  # lime
    (0.50, "#FFD600"),  # yellow
    (0.30, "#FF9100"),  # orange
    (0.15, "#FF3D00"),  # deep orange
    (0.05, "#D50000"),  # red
    (0.00, "#B71C1C"),  # dark red
]


def _progress_color(ratio: float) -> str:
    ratio = max(0.0, min(1.0, ratio))
    for i in range(len(_COLOR_STOPS) - 1):
        r_hi, c_hi = _COLOR_STOPS[i]
        r_lo, c_lo = _COLOR_STOPS[i + 1]
        if ratio >= r_lo:
            if r_hi == r_lo:
                return c_hi
            t = (ratio - r_lo) / (r_hi - r_lo)
            return _lerp_color(c_lo, c_hi, t)
    return _COLOR_STOPS[-1][1]


def _create_reply_to_top_msg(topic_id, peer_id):
    try:
        if not topic_id or topic_id <= 0:
            return None
        reply_message = TLRPC.TL_message()
        reply_message.message = ""
        reply_message.id = topic_id
        reply_message.peer_id = get_messages_controller().getPeer(peer_id)
        account = get_user_config().selectedAccount
        return MessageObject(account, reply_message, False, False)
    except Exception:
        log(f"[{__id__}] _create_reply_to_top_msg error: {traceback.format_exc()}")
        return None


def _get_topic_reply_msg(fragment, dialog_id):
    reply_to_top_msg = None
    try:
        reply_to_top_msg = fragment.getThreadMessage()
    except Exception:
        pass
    if not reply_to_top_msg:
        try:
            topic_id = fragment.getTopicId()
            if topic_id and topic_id > 0:
                reply_to_top_msg = _create_reply_to_top_msg(topic_id, dialog_id)
        except Exception:
            pass
    return reply_to_top_msg


# ── data classes ──────────────────────────────────────────────────────────────

class TimerEntry:
    _counter = 0

    def __init__(self, name: str, total_seconds: int, notify_chat: bool = False):
        TimerEntry._counter += 1
        self.id = TimerEntry._counter
        self.name = name or str(self.id)
        self.total_seconds = total_seconds
        self.remaining = total_seconds
        self.running = True
        self.is_timer = True
        self.notify_chat = notify_chat
        self.finished = False
        self.overtime = 0

    def display(self) -> str:
        if self.finished:
            return f"⏱ {self.name}  [+{_fmt_seconds(self.overtime)}]"
        return f"⏱ {self.name}  [{_fmt_seconds(max(0, self.remaining))}]"

    def progress_ratio(self) -> float:
        if self.finished or self.total_seconds <= 0:
            return 0.0
        return max(0.0, min(1.0, self.remaining / self.total_seconds))


class StopwatchEntry:
    _counter = 0

    def __init__(self, name: str, notify_chat: bool = False):
        StopwatchEntry._counter += 1
        self.id = StopwatchEntry._counter
        self.name = name or str(self.id)
        self.elapsed = 0
        self.running = True
        self.is_timer = False
        self.notify_chat = notify_chat

    def display(self) -> str:
        return f"⏲ {self.name}  [{_fmt_seconds(self.elapsed)}]"


# ── plugin ────────────────────────────────────────────────────────────────────

class TimersPlugin(BasePlugin):

    def __init__(self):
        super().__init__()
        self._entries: list = []
        self._tick_thread: Optional[threading.Thread] = None
        self._running = False
        self._lock = threading.Lock()
        self._list_dialog = None
        self._list_layout: Optional[LinearLayout] = None
        self._list_activity = None
        self._current_dialog_id = None
        self._reply_to_top_msg = None
        self._topic_id = 0

    # ── i18n ──────────────────────────────────────────────────────────────

    def _t(self, key: str) -> str:
        lang = self.get_setting("language", 0)
        return STRINGS.get(lang, STRINGS[0]).get(key, key)

    # ── settings ──────────────────────────────────────────────────────────

    def create_settings(self):
        return [
            Header(text=self._t("settings_header")),
            Selector(
                key="language",
                text=self._t("lang_label"),
                default=0,
                items=["English", "Русский"],
                icon="msg_language",
            ),
            Divider(),
            Input(
                key="command",
                text=self._t("cmd_label"),
                default=".tm",
                subtext=self._t("cmd_hint"),
                icon="msg_input",
            ),
        ]

    # ── lifecycle ─────────────────────────────────────────────────────────

    def on_plugin_load(self):
        self.add_menu_item(
            MenuItemData(
                menu_type=MenuItemType.CHAT_ACTION_MENU,
                text="Timers & Stopwatches",
                icon="sPluginIDE/10",
                on_click=self._open_main_menu,
            )
        )
        self.add_on_send_message_hook()
        self._load_entries()
        self._start_tick()

    def on_plugin_unload(self):
        self._running = False

    # ── command hook ──────────────────────────────────────────────────────

    def on_send_message_hook(self, account: int, params: Any) -> HookResult:
        if not isinstance(params.message, str):
            return HookResult()
        cmd = self.get_setting("command", ".tm").strip()
        if params.message.strip() == cmd:
            self._current_dialog_id = getattr(params, "peer", None) or self._current_dialog_id
            run_on_ui_thread(self._show_main_menu)
            return HookResult(strategy=HookStrategy.CANCEL)
        return HookResult()

    # ── persistence ───────────────────────────────────────────────────────

    def _save_entries(self):
        now = time.time()
        data = []
        with self._lock:
            for e in self._entries:
                if e.is_timer:
                    data.append({
                        "type": "timer",
                        "name": e.name,
                        "total": e.total_seconds,
                        "remaining": e.remaining,
                        "running": e.running,
                        "finished": e.finished,
                        "overtime": e.overtime,
                        "notify_chat": e.notify_chat,
                        "saved_at": now,
                    })
                else:
                    data.append({
                        "type": "stopwatch",
                        "name": e.name,
                        "elapsed": e.elapsed,
                        "running": e.running,
                        "notify_chat": e.notify_chat,
                        "saved_at": now,
                    })
        try:
            with open(_SAVE_PATH, "w", encoding="utf-8") as f:
                json.dump(data, f)
        except Exception:
            log(f"[{__id__}] save error: {traceback.format_exc()}")

    def _load_entries(self):
        if not os.path.exists(_SAVE_PATH):
            return
        try:
            with open(_SAVE_PATH, "r", encoding="utf-8") as f:
                data = json.load(f)
        except Exception:
            log(f"[{__id__}] load read error: {traceback.format_exc()}")
            return
        now = time.time()
        for d in data:
            try:
                elapsed_since_save = now - d.get("saved_at", now)
                if d["type"] == "timer":
                    e = TimerEntry(d["name"], d["total"], d.get("notify_chat", False))
                    e.finished = d.get("finished", False)
                    e.overtime = d.get("overtime", 0)
                    e.running = d.get("running", True)
                    if e.finished:
                        e.overtime += int(elapsed_since_save)
                        e.remaining = 0
                    elif e.running:
                        e.remaining = max(0, d.get("remaining", d["total"]) - int(elapsed_since_save))
                        if e.remaining == 0:
                            e.finished = True
                            e.running = False
                    else:
                        e.remaining = d.get("remaining", d["total"])
                    with self._lock:
                        self._entries.append(e)
                else:
                    e = StopwatchEntry(d["name"], d.get("notify_chat", False))
                    e.running = d.get("running", True)
                    e.elapsed = d.get("elapsed", 0) + (int(elapsed_since_save) if e.running else 0)
                    with self._lock:
                        self._entries.append(e)
            except Exception:
                log(f"[{__id__}] load entry error: {traceback.format_exc()}")

    # ── tick thread ───────────────────────────────────────────────────────

    def _start_tick(self):
        self._running = True
        self._tick_thread = threading.Thread(target=self._tick_loop, daemon=True)
        self._tick_thread.start()

    def _tick_loop(self):
        while self._running:
            time.sleep(1)
            finished_notify = []
            with self._lock:
                for e in self._entries:
                    if not e.running:
                        if e.is_timer and e.finished:
                            e.overtime += 1
                        continue
                    if e.is_timer:
                        e.remaining -= 1
                        if e.remaining <= 0:
                            e.remaining = 0
                            e.running = False
                            e.finished = True
                            finished_notify.append(e)
                    else:
                        e.elapsed += 1
            for e in finished_notify:
                msg = self._t("timer_finished_bul").format(name=e.name)
                run_on_ui_thread(lambda m=msg: BulletinHelper.show_info(m))
                if e.notify_chat and self._current_dialog_id is not None:
                    try:
                        send_text(self._current_dialog_id, msg,
                                  replyToMsg=self._reply_to_top_msg)
                    except Exception:
                        log(f"[{__id__}] finish notify error: {traceback.format_exc()}")
            # Сохраняем каждую секунду
            self._save_entries()
            if self._list_layout and self._list_activity:
                run_on_ui_thread(self._refresh_list_ui)

    # ── main menu ─────────────────────────────────────────────────────────

    def _open_main_menu(self, context: dict[str, Any]):
        fragment = get_last_fragment()
        # dialog_id: try getDialogId() first (works with Java Long)
        did = None
        try:
            did = fragment.getDialogId()
        except Exception:
            pass
        if not did:
            did = context.get("dialog_id")
        self._current_dialog_id = did

        # topic_id for forum support
        self._topic_id = 0
        try:
            tid = fragment.getTopicId() if hasattr(fragment, "getTopicId") else 0
            if tid:
                self._topic_id = int(str(tid))
        except Exception:
            pass

        if fragment and self._current_dialog_id:
            self._reply_to_top_msg = _get_topic_reply_msg(fragment, self._current_dialog_id)
        else:
            self._reply_to_top_msg = None
        run_on_ui_thread(self._show_main_menu)

    def _show_main_menu(self):
        fragment = get_last_fragment()
        activity = fragment and fragment.getParentActivity()
        if not activity:
            return

        builder = AlertDialogBuilder(activity)
        builder.set_title(self._t("title"))

        layout = LinearLayout(activity)
        layout.setOrientation(LinearLayout.VERTICAL)
        pad = dp(16)
        layout.setPadding(pad, pad, pad, pad)

        dialog_holder = [None]

        def close_and(fn):
            def inner(*a):
                if dialog_holder[0]:
                    try:
                        dialog_holder[0].dismiss()
                    except Exception:
                        pass
                fn()
            return inner

        btn1 = _make_button(activity, self._t("all_entries"), "#2196F3",
                             close_and(self._show_all_entries))
        btn2 = _make_button(activity, self._t("start_timer"), "#4CAF50",
                             close_and(lambda: self._show_start_timer(activity)))
        btn3 = _make_button(activity, self._t("start_stopwatch"), "#FF9800",
                             close_and(lambda: self._show_start_stopwatch(activity)))

        for btn in [btn1, btn2, btn3]:
            lp = LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.MATCH_PARENT, dp(48)
            )
            lp.setMargins(0, 0, 0, dp(8))
            btn.setLayoutParams(lp)
            layout.addView(btn)

        # Close button centered at bottom
        lp_close = LinearLayout.LayoutParams(dp(160), dp(44))
        lp_close.gravity = Gravity.CENTER_HORIZONTAL
        lp_close.setMargins(0, dp(4), 0, 0)
        btn_close = _make_button(activity, self._t("close"), "#37474F",
                                  lambda *a: dialog_holder[0] and dialog_holder[0].dismiss())
        btn_close.setLayoutParams(lp_close)
        layout.addView(btn_close)

        builder.set_view(layout)
        # Tap outside → just close
        builder.set_on_cancel_listener(lambda b: None)
        dialog = builder.show()
        dialog_holder[0] = dialog

    # ── all entries dialog ────────────────────────────────────────────────

    def _show_all_entries(self):
        fragment = get_last_fragment()
        activity = fragment and fragment.getParentActivity()
        if not activity:
            return

        self._list_activity = activity

        builder = AlertDialogBuilder(activity)
        builder.set_title(self._t("all_entries"))

        scroll = ScrollView(activity)
        inner = LinearLayout(activity)
        inner.setOrientation(LinearLayout.VERTICAL)
        pad = dp(8)
        inner.setPadding(pad, pad, pad, pad)
        scroll.addView(inner)

        self._list_layout = inner
        self._refresh_list_ui()

        btn_pressed = [False]

        builder.set_view(scroll)

        def _on_back(b, w):
            btn_pressed[0] = True
            self._on_list_closed(b, reopen=True)

        builder.set_negative_button(self._t("back"), _on_back)

        def _on_cancel(b):
            if btn_pressed[0]:
                btn_pressed[0] = False
                return
            self._on_list_closed_silent()
            run_on_ui_thread(self._show_main_menu)

        builder.set_on_cancel_listener(_on_cancel)
        self._list_dialog = builder.show()

    def _on_list_closed_silent(self):
        self._list_layout = None
        self._list_dialog = None
        self._list_activity = None

    def _on_list_closed(self, dialog, reopen: bool = False):
        self._list_layout = None
        self._list_dialog = None
        self._list_activity = None
        try:
            dialog.dismiss()
        except Exception:
            pass
        if reopen:
            run_on_ui_thread(self._show_main_menu)

    def _refresh_list_ui(self):
        layout = self._list_layout
        activity = self._list_activity
        if not layout or not activity:
            return
        try:
            layout.removeAllViews()
            with self._lock:
                entries = list(self._entries)

            if not entries:
                tv = TextView(activity)
                tv.setText(self._t("no_entries"))
                tv.setTextColor(Color.parseColor("#AAAAAA"))
                tv.setGravity(Gravity.CENTER)
                lp = LinearLayout.LayoutParams(
                    LinearLayout.LayoutParams.MATCH_PARENT, dp(48)
                )
                tv.setLayoutParams(lp)
                layout.addView(tv)
                return

            for entry in entries:
                self._add_entry_row(layout, activity, entry)
        except Exception:
            log(f"[{__id__}] refresh error: {traceback.format_exc()}")

    def _add_entry_row(self, layout: LinearLayout, activity, entry):
        # Outer card
        card = LinearLayout(activity)
        card.setOrientation(LinearLayout.VERTICAL)
        card_lp = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT,
            LinearLayout.LayoutParams.WRAP_CONTENT
        )
        card_lp.setMargins(0, 0, 0, dp(8))
        card.setLayoutParams(card_lp)
        is_finished = entry.is_timer and getattr(entry, 'finished', False)
        row_bg = "#1A3A1A" if is_finished else "#2A2A2A"
        card.setBackground(_rounded_bg(row_bg))
        card.setPadding(dp(10), dp(8), dp(8), dp(8))

        # Row: label + buttons
        row = LinearLayout(activity)
        row.setOrientation(LinearLayout.HORIZONTAL)
        row.setGravity(Gravity.CENTER_VERTICAL)
        row_lp = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT,
            LinearLayout.LayoutParams.WRAP_CONTENT
        )
        row.setLayoutParams(row_lp)

        label = TextView(activity)
        label.setText(entry.display())
        label.setTextColor(Color.parseColor("#88FF88") if is_finished else Color.WHITE)
        label.setTextSize(13)
        lp_label = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1.0)
        label.setLayoutParams(lp_label)
        row.addView(label)
        entry._label_view = label

        btn_lp = LinearLayout.LayoutParams(dp(72), dp(36))
        btn_lp.setMargins(dp(4), 0, 0, 0)

        def make_delete(e):
            def delete(*a):
                with self._lock:
                    if e in self._entries:
                        self._entries.remove(e)
                self._save_entries()
                run_on_ui_thread(self._refresh_list_ui)
            return delete

        def make_to_chat(e):
            def to_chat(*a):
                if self._current_dialog_id is None:
                    BulletinHelper.show_error(self._t("no_chat_err"))
                    return
                try:
                    if e.is_timer:
                        if getattr(e, 'finished', False):
                            msg = self._t("timer_finished_ago").format(
                                name=e.name, time=_fmt_seconds(e.overtime))
                        else:
                            msg = self._t("timer_remaining").format(
                                name=e.name, time=_fmt_seconds(max(0, e.remaining)))
                    else:
                        msg = self._t("stopwatch_running").format(
                            name=e.name, time=_fmt_seconds(e.elapsed))
                    send_text(self._current_dialog_id, msg,
                              replyToMsg=self._reply_to_top_msg)
                except Exception:
                    log(f"[{__id__}] to_chat error: {traceback.format_exc()}")
            return to_chat

        if not is_finished:
            pause_text = self._t("resume") if not entry.running else self._t("pause")
            pause_color = "#4CAF50" if not entry.running else "#FF9800"

            def make_toggle(e):
                def toggle(*a):
                    with self._lock:
                        e.running = not e.running
                    self._save_entries()
                    run_on_ui_thread(self._refresh_list_ui)
                return toggle

            btn_toggle = _make_button(activity, pause_text, pause_color, make_toggle(entry))
            btn_toggle.setLayoutParams(btn_lp)
            btn_toggle.setTextSize(11)
            row.addView(btn_toggle)

        btn_chat_lp = LinearLayout.LayoutParams(dp(64), dp(36))
        btn_chat_lp.setMargins(dp(4), 0, 0, 0)
        btn_chat = _make_button(activity, "📤", "#607D8B", make_to_chat(entry))
        btn_chat.setLayoutParams(btn_chat_lp)
        btn_chat.setTextSize(13)
        row.addView(btn_chat)

        btn_del_lp = LinearLayout.LayoutParams(dp(60), dp(36))
        btn_del_lp.setMargins(dp(4), 0, 0, 0)
        btn_del = _make_button(activity, self._t("delete"), "#F44336", make_delete(entry))
        btn_del.setLayoutParams(btn_del_lp)
        btn_del.setTextSize(11)
        row.addView(btn_del)

        card.addView(row)

        # ── Progress bar (timers only, not finished) ──────────────────────
        if entry.is_timer and not is_finished:
            ratio = entry.progress_ratio()
            bar_lp = LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.MATCH_PARENT, dp(6)
            )
            bar_lp.setMargins(0, dp(6), dp(4), 0)

            bar_bg = GradientDrawable()
            bar_bg.setShape(GradientDrawable.RECTANGLE)
            bar_bg.setCornerRadius(dp(3))
            bar_bg.setColor(Color.parseColor("#444444"))

            bar_container = LinearLayout(activity)
            bar_container.setOrientation(LinearLayout.HORIZONTAL)
            bar_container.setLayoutParams(bar_lp)
            bar_container.setBackground(bar_bg)

            fill_color = _progress_color(ratio)
            fill_weight = max(0.001, ratio)
            empty_weight = max(0.001, 1.0 - ratio)

            fill_bg = GradientDrawable()
            fill_bg.setShape(GradientDrawable.RECTANGLE)
            fill_bg.setCornerRadius(dp(3))
            fill_bg.setColor(Color.parseColor(fill_color))

            fill_view = View(activity)
            fill_view.setBackground(fill_bg)
            fill_view.setLayoutParams(
                LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.MATCH_PARENT, fill_weight)
            )

            empty_view = View(activity)
            empty_view.setLayoutParams(
                LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.MATCH_PARENT, empty_weight)
            )

            bar_container.addView(fill_view)
            bar_container.addView(empty_view)
            card.addView(bar_container)

        layout.addView(card)

    # ── start timer dialog ────────────────────────────────────────────────

    def _show_start_timer(self, activity, prefill: dict = None):
        builder = AlertDialogBuilder(activity)
        builder.set_title(self._t("start_timer"))

        layout = LinearLayout(activity)
        layout.setOrientation(LinearLayout.VERTICAL)
        pad = dp(16)
        layout.setPadding(pad, dp(8), pad, dp(8))

        fields = {}
        specs = [
            ("Name", self._t("name_label"), self._t("name_hint"), False),
            ("D",    self._t("days"),        self._t("days_hint"),    True),
            ("H",    self._t("hours"),       self._t("hours_hint"),   True),
            ("M",    self._t("minutes"),     self._t("minutes_hint"), True),
            ("S",    self._t("seconds"),     self._t("seconds_hint"), True),
        ]
        for key, label_text, hint, numeric in specs:
            tv = TextView(activity)
            tv.setText(label_text)
            tv.setTextColor(Color.parseColor("#AAAAAA"))
            tv.setTextSize(12)
            tv.setPadding(0, dp(6), 0, dp(2))
            layout.addView(tv)

            et = EditText(activity)
            et.setHint(hint)
            if numeric:
                et.setInputType(InputType.TYPE_CLASS_NUMBER)
            et.setTextColor(Color.WHITE)
            et.setHintTextColor(Color.parseColor("#666666"))
            et.setBackground(_rounded_bg("#2A2A2A", 8))
            et.setPadding(dp(10), dp(8), dp(10), dp(8))
            lp = LinearLayout.LayoutParams(
                LinearLayout.LayoutParams.MATCH_PARENT, dp(42)
            )
            lp.setMargins(0, 0, 0, dp(4))
            et.setLayoutParams(lp)
            layout.addView(et)
            fields[key] = et
            if prefill and key in prefill and prefill[key]:
                et.setText(str(prefill[key]))

        dialog_holder = [None]

        def _parse_int(et_widget):
            try:
                return max(0, int(et_widget.getText().toString().strip() or "0"))
            except Exception:
                return 0

        def _do_start(send_msg: bool, *a):
            name = fields["Name"].getText().toString().strip()
            d = _parse_int(fields["D"])
            h = _parse_int(fields["H"])
            m = _parse_int(fields["M"])
            s = _parse_int(fields["S"])
            total = d * 86400 + h * 3600 + m * 60 + s
            if total <= 0:
                BulletinHelper.show_error(self._t("enter_time_err"))
                return
            entry = TimerEntry(name, total, notify_chat=send_msg)
            with self._lock:
                self._entries.append(entry)
            self._save_entries()
            if send_msg:
                self._send_message(
                    self._t("timer_started_msg").format(name=entry.name, time=_fmt_seconds(total))
                )
            else:
                BulletinHelper.show_info(self._t("timer_started_bul").format(name=entry.name))
            if dialog_holder[0]:
                try:
                    dialog_holder[0].dismiss()
                except Exception:
                    pass
            run_on_ui_thread(self._show_main_menu)

        btn_row = LinearLayout(activity)
        btn_row.setOrientation(LinearLayout.HORIZONTAL)
        lp_row = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT,
            LinearLayout.LayoutParams.WRAP_CONTENT
        )
        lp_row.setMargins(0, dp(12), 0, 0)
        btn_row.setLayoutParams(lp_row)

        lp_btn = LinearLayout.LayoutParams(0, dp(44), 1.0)
        lp_btn.setMargins(0, 0, dp(6), 0)
        btn_start = _make_button(activity, self._t("start"), "#4CAF50",
                                  lambda *a: _do_start(False))
        btn_start.setLayoutParams(lp_btn)
        btn_row.addView(btn_start)

        lp_btn2 = LinearLayout.LayoutParams(0, dp(44), 1.0)
        btn_start_msg = _make_button(activity, self._t("start_with_msg"), "#2196F3",
                                      lambda *a: _do_start(True))
        btn_start_msg.setLayoutParams(lp_btn2)
        btn_row.addView(btn_start_msg)

        layout.addView(btn_row)
        builder.set_view(layout)

        builder.set_negative_button(self._t("back"), lambda b, w: b.dismiss())
        builder.set_on_cancel_listener(lambda b: run_on_ui_thread(self._show_main_menu))
        dialog_holder[0] = builder.show()

    # ── start stopwatch dialog ────────────────────────────────────────────

    def _show_start_stopwatch(self, activity, prefill: dict = None):
        builder = AlertDialogBuilder(activity)
        builder.set_title(self._t("start_stopwatch"))

        layout = LinearLayout(activity)
        layout.setOrientation(LinearLayout.VERTICAL)
        pad = dp(16)
        layout.setPadding(pad, dp(8), pad, dp(8))

        tv = TextView(activity)
        tv.setText(self._t("name_label"))
        tv.setTextColor(Color.parseColor("#AAAAAA"))
        tv.setTextSize(12)
        tv.setPadding(0, dp(6), 0, dp(2))
        layout.addView(tv)

        name_et = EditText(activity)
        name_et.setHint(self._t("name_hint"))
        name_et.setTextColor(Color.WHITE)
        name_et.setHintTextColor(Color.parseColor("#666666"))
        name_et.setBackground(_rounded_bg("#2A2A2A", 8))
        name_et.setPadding(dp(10), dp(8), dp(10), dp(8))
        lp_et = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT, dp(42)
        )
        lp_et.setMargins(0, 0, 0, dp(12))
        name_et.setLayoutParams(lp_et)
        layout.addView(name_et)
        if prefill and prefill.get("Name"):
            name_et.setText(prefill["Name"])

        dialog_holder = [None]

        def _do_start(send_msg: bool, *a):
            name = name_et.getText().toString().strip()
            entry = StopwatchEntry(name, notify_chat=send_msg)
            with self._lock:
                self._entries.append(entry)
            self._save_entries()
            if send_msg:
                self._send_message(self._t("stopwatch_started_msg").format(name=entry.name))
            else:
                BulletinHelper.show_info(self._t("stopwatch_started_bul").format(name=entry.name))
            if dialog_holder[0]:
                try:
                    dialog_holder[0].dismiss()
                except Exception:
                    pass
            run_on_ui_thread(self._show_main_menu)

        btn_row = LinearLayout(activity)
        btn_row.setOrientation(LinearLayout.HORIZONTAL)
        lp_row = LinearLayout.LayoutParams(
            LinearLayout.LayoutParams.MATCH_PARENT,
            LinearLayout.LayoutParams.WRAP_CONTENT
        )
        btn_row.setLayoutParams(lp_row)

        lp_btn = LinearLayout.LayoutParams(0, dp(44), 1.0)
        lp_btn.setMargins(0, 0, dp(6), 0)
        btn_start = _make_button(activity, self._t("start"), "#FF9800",
                                  lambda *a: _do_start(False))
        btn_start.setLayoutParams(lp_btn)
        btn_row.addView(btn_start)

        lp_btn2 = LinearLayout.LayoutParams(0, dp(44), 1.0)
        btn_start_msg = _make_button(activity, self._t("start_with_msg"), "#2196F3",
                                      lambda *a: _do_start(True))
        btn_start_msg.setLayoutParams(lp_btn2)
        btn_row.addView(btn_start_msg)

        layout.addView(btn_row)
        builder.set_view(layout)

        builder.set_negative_button(self._t("back"), lambda b, w: b.dismiss())
        builder.set_on_cancel_listener(lambda b: run_on_ui_thread(self._show_main_menu))
        dialog_holder[0] = builder.show()

    # ── helpers ───────────────────────────────────────────────────────────

    def _send_message(self, text: str):
        try:
            if self._current_dialog_id is None:
                BulletinHelper.show_error(self._t("no_chat_err"))
                return
            if self._topic_id and self._topic_id > 0:
                from org.telegram.messenger import AccountInstance, SendMessagesHelper
                fragment = get_last_fragment()
                acc = 0
                try:
                    acc = int(str(fragment.getCurrentAccount())) if hasattr(fragment, "getCurrentAccount") else 0
                except Exception:
                    pass
                did = self._current_dialog_id
                tid = self._topic_id
                run_on_ui_thread(lambda: SendMessagesHelper.prepareSendingText(
                    AccountInstance.getInstance(acc), text, did, tid, True, 0, 0, 0
                ))
            else:
                send_text(self._current_dialog_id, text,
                          replyToMsg=self._reply_to_top_msg)
        except Exception:
            log(f"[{__id__}] send_message error: {traceback.format_exc()}")
