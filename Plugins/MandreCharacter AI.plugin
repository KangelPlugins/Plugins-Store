def t(key: str, **kwargs):
    lang = Locale.getDefault().getLanguage()
    loc = getattr(Locales, lang, Locales.default)
    txt = loc.get(key, key)
    return txt.format(**kwargs) if kwargs else txt


class OpenRouterCharacterPlugin(BasePlugin):
    def __init__(self):
        super().__init__()
        self._history = {}
        if not MANDRELIB_AVAILABLE:
            raise ImportError("MandreLib is required for this plugin to function.")

    def on_plugin_load(self):
        Mandre.use_persistent_storage(self)
        self.add_on_send_message_hook()
        self._validate_and_fix_personalities()
        
        # --- ИНТЕГРАЦИЯ BOTTOM BAR ---
        bar_items = [
            {"text": t("tab_main"), "icon": "msg_settings", "on_click": lambda: self._handle_tab_click(0)},
            {"text": t("tab_personas"), "icon": "chats_replies", "on_click": lambda: self._handle_tab_click(1)}
        ]
        
        Mandre.UI.setup_settings_bottom_bar(
            plugin_instance=self,
            items=bar_items,
            active_index_key="active_settings_tab"
        )
        # -----------------------------

    def on_plugin_unload(self): self._history.clear()

    def _handle_tab_click(self, index: int):
        self.set_setting("active_settings_tab", index)
        Mandre.UI.update_bottom_bar(self.id, index)
        Mandre.apply_and_refresh_settings(self)

    def create_settings(self):
        active_tab = self.get_setting("active_settings_tab", 0)
        
        if active_tab == 0:
            return self._create_main_settings_tab()
        elif active_tab == 1:
            return self._create_personalities_list_tab()
        
        return [Header(text="Ошибка")]

    def _create_main_settings_tab(self):
        self._validate_and_fix_personalities()
        p = self._get_personalities()
        current_id = self.get_setting("current_personality", "")
        if not current_id or current_id not in p:
            current_id = next(iter(p), "")
            self.set_setting("current_personality", current_id)
        current_name = p.get(current_id, {}).get("name", "N/A")
        _, all_display = self._get_all_models()
        
        return [
            Header(text=t("settings_header")),
            Input(key="api_key", text=t("api_key"), subtext=t("api_key_sub"), icon="msg2_permissions"),
            Selector(key="model", text=t("model"), items=all_display, default=0, icon="msg_bots"),
            Input(key="custom_models", text=t("custom_models"), subtext=t("custom_models_sub"), icon="msg_add", on_change=lambda v: Mandre.apply_and_refresh_settings(self)),
            
            Header(text=t("personalities_header")),
            Text(text=t("current_personality", name=current_name), icon="msg_bot", on_click=lambda v: self._show_quick_switch_dialog()),
            
            Header(text=t("memory_header")),
            Switch(key="remember_history", text=t("remember"), default=True, icon="chats_saved"),
            Input(key="history_depth", text=t("turns"), default="10", icon="msg_log"),
            
            Divider(text=t("usage")),
            Text(text=t("api_help_button"), accent=False, on_click=lambda v: self._show_api_help(), icon="msg_info"),
        ]

    def _create_personalities_list_tab(self):
        p = self._get_personalities()
        current_id = self.get_setting("current_personality", "")
        items = [Header(text=t("personalities_header"))]
        
        for pid, pdata in p.items():
            name = pdata.get("name", "Unnamed")
            is_current = pid == current_id
            display_name = f"• {name}" + (" (текущая)" if is_current and Locale.getDefault().getLanguage().startswith("ru") else " (current)" if is_current else "")
            items.append(Text(text=display_name, accent=is_current, icon="msg_contacts", create_sub_fragment=lambda p_id=pid: self._create_personality_settings(p_id)))
        
        items.extend([
            Divider(),
            Text(text=t("generate_personality"), accent=True, icon="ai_chat_solar", on_click=lambda v: self._show_generate_personality_dialog()),
            Text(text=t("new_personality"), accent=True, icon="msg_add", on_click=lambda v: self._create_new_personality())
        ])
        return items

    def _get_personalities(self): return MandreData.read_persistent_json(self.id, "personalities.json", {})
    def _save_personalities(self, p): MandreData.write_persistent_json(self.id, "personalities.json", p)

    def _validate_and_fix_personalities(self):
        personalities = self._get_personalities()
        if not personalities:
            log("[MandreCharacter AI] Personalities is empty, resetting.")
            p, default_id = {}, str(uuid.uuid4())
            is_ru = Locale.getDefault().getLanguage().startswith("ru")
            p[default_id] = {
                "name": "Extera AI", "bot_name": "Extera AI", "user_name": "Пользователь" if is_ru else "User",
                "greeting": "Привет! Чем могу помочь?" if is_ru else "Hello! How can I help you?",
                "personality_sys_main": "Помощник в exteraGram, дружелюбный, остроумный, эмпатичный." if is_ru else "An assistant in exteraGram, friendly, witty, empathetic.",
                "scenario": "", "example_dialogues": "", "nsfw": False
            }
            self._save_personalities(p); self.set_setting("current_personality", default_id)

    def _get_all_models(self):
        custom = [m.strip() for m in self.get_setting("custom_models", "").split(',') if m.strip()]
        return AVAILABLE_MODELS + custom, AVAILABLE_MODELS_DISPLAY + [f"Custom: {m}" for m in custom]

    def _update_personality_field(self, pid, field, value):
        p = self._get_personalities()
        if pid in p: p[pid][field] = value; self._save_personalities(p)

    def _create_personality_settings(self, pid):
        p = self._get_personalities().get(pid, {})
        return [
            Header(text=t("personality_settings_header")),
            Input(key=f"p_{pid}_name", text=t("personality_name"), subtext=t("personality_name_sub"), default=p.get("name", ""), icon="msg_edit", on_change=lambda v, i=pid: self._update_personality_field(i, "name", v)),
            Input(key=f"p_{pid}_bot_name", text=t("bot_name"), subtext=t("bot_name_sub"), default=p.get("bot_name", ""), icon="msg_bot", on_change=lambda v, i=pid: self._update_personality_field(i, "bot_name", v)),
            Input(key=f"p_{pid}_greeting", text=t("greeting"), subtext=t("greeting_sub"), default=p.get("greeting", ""), icon="msg_channel", on_change=lambda v, i=pid: self._update_personality_field(i, "greeting", v)),
            Input(key=f"p_{pid}_personality_sys_main", text=t("personality_sys_main"), subtext=t("personality_sys_main_sub"), default=p.get("personality_sys_main", ""), icon="msg_reactions", on_change=lambda v, i=pid: self._update_personality_field(i, "personality_sys_main", v)),
            Input(key=f"p_{pid}_scenario", text=t("scenario"), subtext=t("scenario_sub"), default=p.get("scenario", ""), icon="msg_map", on_change=lambda v, i=pid: self._update_personality_field(i, "scenario", v)),
            Input(key=f"p_{pid}_example_dialogues", text=t("example_dialogues"), subtext=t("example_dialogues_sub"), default=p.get("example_dialogues", ""), icon="msg_discussion", on_change=lambda v, i=pid: self._update_personality_field(i, "example_dialogues", v)),
            Input(key=f"p_{pid}_user_name", text=t("user_name"), default=p.get("user_name", ""), icon="msg_contacts", on_change=lambda v, i=pid: self._update_personality_field(i, "user_name", v)),
            Divider(),
            Switch(key=f"p_{pid}_nsfw", text=t("nsfw_toggle"), subtext=t("nsfw_toggle_sub"), default=p.get("nsfw", False), icon="msg_report_xxx_solar", on_change=lambda v, i=pid: self._update_personality_field(i, "nsfw", v)),
            Divider(),
            Text(text=t("make_active"), accent=True, icon="msg_select", on_click=lambda v: self._switch_personality(pid)),
            Text(text=t("export_this"), icon="msg_share", on_click=lambda v: self._export_personality_settings(pid)),
            Text(text=t("delete_this"), icon="msg_delete", on_click=lambda v: self._delete_personality(pid)),
        ]

    def _create_new_personality(self):
        p = self._get_personalities(); new_id = str(uuid.uuid4())
        name = f"Личность {len(p) + 1}" if Locale.getDefault().getLanguage().startswith("ru") else f"Personality {len(p) + 1}"
        p[new_id] = {"name": name, "bot_name": "New AI", "user_name": "User", "greeting": "Hello", "personality_sys_main": "friendly, helpful", "scenario": "", "example_dialogues": "", "nsfw": False}
        self._save_personalities(p); BulletinHelper.show_success(t("new_personality")); Mandre.apply_and_refresh_settings(self); MandreUI.ripple()

    def _add_new_personality_from_data(self, data: dict):
        p = self._get_personalities(); new_id = str(uuid.uuid4())
        p[new_id] = data
        self._save_personalities(p)
        BulletinHelper.show_success(t("personality_generated", name=data.get("name", "N/A")))
        MandreUI.ripple()
        Mandre.apply_and_refresh_settings(self)

    def _switch_personality(self, pid):
        p = self._get_personalities()
        if pid in p: self.set_setting("current_personality", pid); BulletinHelper.show_success(t("personality_switched", name=p[pid].get("name", "Unnamed")))
        else: BulletinHelper.show_error(t("personality_not_found"))
        Mandre.apply_and_refresh_settings(self)

    def _delete_personality(self, pid):
        p = self._get_personalities()
        if len(p) <= 1: BulletinHelper.show_error(t("last_one_error")); return
        name = p.get(pid, {}).get("name", "Unnamed")
        def on_confirm(confirmed):
            if confirmed:
                p_after_del = self._get_personalities(); p_after_del.pop(pid, None); self._save_personalities(p_after_del)
                if self.get_setting("current_personality", "") == pid: self.set_setting("current_personality", next(iter(p_after_del.keys()), None))
                BulletinHelper.show_success(t("personality_deleted")); Mandre.apply_and_refresh_settings(self)
        MandreUI.show(title=t("delete_personality"), message=t("confirm_delete", name=name), items=["Да, удалить", "Нет"], on_select=lambda i, txt: on_confirm(i == 0))

    def _show_quick_switch_dialog(self):
        p = self._get_personalities()
        if not p:
            BulletinHelper.show_error(t("personality_not_found"))
            return
        p_items = list(p.items())
        p_names = [pd.get("name", "Unnamed") for _, pd in p_items]
        
        def on_select_handler(index, name):
            pid_to_switch = p_items[index][0]
            self._switch_personality(pid_to_switch)
        
        MandreUI.show(
            title=t("switch_personality_title"),
            items=p_names,
            on_select=on_select_handler
        )

    # --- Код ниже в основном без изменений ---
    def on_send_message_hook(self, account, params):
        if not hasattr(params, "message") or not isinstance(params.message, str): return HookResult()
        text = params.message.strip()
        if text.startswith(".gsetexport"):
            target = text.split(maxsplit=1)[1] if len(text.split(maxsplit=1)) > 1 else None
            if target: self._export_personality_by_id_or_name(target)
            else: self._show_export_personality_dialog()
            return HookResult(strategy=HookStrategy.CANCEL)
        if text.startswith(".gsetimport ") or text.strip() == ".gsetimport":
            payload = text[len(".gsetimport "):].strip() if text.startswith(".gsetimport ") else ""
            if not payload and hasattr(params, "replyToMsg") and params.replyToMsg:
                try: payload = str(getattr(params.replyToMsg, "messageText", "") or "").strip()
                except Exception: payload = ""
            ok, msg = self._import_personality_settings(payload) if payload else (False, t("bad_import"))
            BulletinHelper.show_success(t("import_ok")) if ok else BulletinHelper.show_error(msg)
            return HookResult(strategy=HookStrategy.CANCEL)
        if text.strip() == ".gswitch": self._show_switch_personality_dialog(); return HookResult(strategy=HookStrategy.CANCEL)
        if text.startswith(".gswitch "): self._find_and_switch_personality(text[len(".gswitch "):].strip()); return HookResult(strategy=HookStrategy.CANCEL)
        if text.strip() == ".ghist": self._show_history_dialog(getattr(params, "peer", None)); return HookResult(strategy=HookStrategy.CANCEL)
        if not text.startswith(".gchat "): return HookResult()
        prompt = text[6:].strip()
        if not prompt: BulletinHelper.show_error(t("empty")); return HookResult(strategy=HookStrategy.CANCEL)
        api_key = self.get_setting("api_key", "").strip()
        if not api_key: BulletinHelper.show_error(t("no_api")); return HookResult(strategy=HookStrategy.CANCEL)
        try:
            progress_dialog = AlertDialogBuilder(get_last_fragment().getParentActivity(), AlertDialogBuilder.ALERT_TYPE_SPINNER)
            progress_dialog.set_message(t("thinking")).show()
        except Exception: progress_dialog = None
        peer, model_idx = getattr(params, "peer", None), self.get_setting("model", 0)
        all_model_ids, _ = self._get_all_models()
        model = all_model_ids[model_idx] if (0 <= model_idx < len(all_model_ids)) else AVAILABLE_MODELS[0]
        persona_data = self._get_current_personality()
        if persona_data.get("nsfw", False): model = "cognitivecomputations/dolphin-mistral-24b-venice-edition:free"
        persona_prompt, history, history_for_api, bot_name = self._build_persona(), self._get_history(peer), self._normalize_history_for_api(self._get_history(peer)), persona_data.get("bot_name", "AI")
        def worker():
            try:
                prompt_for_api = self._normalize_user_actions(prompt)
                reply = self._call_openrouter(api_key, model, persona_prompt, prompt_for_api, history_for_api)
                if reply:
                    reply_display = self._normalize_assistant_actions(reply)
                    if self.get_setting("remember_history", True):
                        self._append_history(peer, ("user", self._normalize_user_actions(prompt)))
                        self._append_history(peer, ("assistant", reply_display))
                    formatted, entities = self._build_tg_formatted_message(prompt, reply_display, bot_name)
                    send_params = {"peer": peer, "message": formatted}
                    if entities: send_params["entities"] = entities
                    if hasattr(params, "replyToMsg") and params.replyToMsg: send_params["replyToMsg"] = params.replyToMsg.id
                    if hasattr(params, "replyToTopMsg") and params.replyToTopMsg: send_params["replyToTopMsg"] = params.replyToTopMsg.id
                    send_message(send_params)
                else: BulletinHelper.show_error(t("empty_response"))
            except ValueError as e: log(f"[MandreCharacter AI] worker auth error: {e}"); BulletinHelper.show_error(str(e))
            except Exception as e: log(f"[MandreCharacter AI] worker error: {e}"); BulletinHelper.show_error(t("network_error", e=str(e)))
            finally:
                if progress_dialog: run_on_ui_thread(progress_dialog.dismiss)
        run_on_queue(worker)
        return HookResult(strategy=HookStrategy.CANCEL)

    def _find_and_switch_personality(self, target):
        p, target_lower = self._get_personalities(), target.lower()
        if target in p: self._switch_personality(target); return
        for pid, pdata in p.items():
            if pdata.get("name", "").lower() == target_lower: self._switch_personality(pid); return
        BulletinHelper.show_error(t("personality_not_found"))

    def _show_api_help(self):
        MandreUI.show(title=t("api_help_title"), message=t("api_help_text"), items=[t("ok_button")], on_select=lambda i, t: None, cancel_text=None)

    def _show_history_dialog(self, peer):
        hist, p = self._get_history(peer), self._get_current_personality()
        greeting, bot_name = p.get("greeting", ""), p.get("bot_name", "AI")
        if not hist: message_content = f"_{greeting}_\n\n" + t("history_empty")
        else:
            parts = [f"_{greeting}_"]
            for role, text in hist:
                if role == "user": parts.append(f"**{t('you_label')}**\n{text}")
                elif role == "assistant": parts.append(f"**{t('ai_label', bot_name=bot_name)}**\n{self._quote_block(text)}")
            message_content = "\n\n".join(parts)
        fragment = get_last_fragment()
        if not fragment or not fragment.getParentActivity(): return
        ctx = fragment.getParentActivity(); builder = AlertDialogBuilder(ctx); builder.set_title(t("history_dialog_title"))
        builder.set_message(AndroidUtilities.replaceTags(message_content))
        builder.set_positive_button(t("clear_chat_button"), lambda d, w: (self._clear_history(peer), d.dismiss()))
        builder.set_negative_button(t("exit_button"), lambda d, w: d.dismiss())
        run_on_ui_thread(builder.show)

    def _show_export_personality_dialog(self):
        p = self._get_personalities()
        if not p: BulletinHelper.show_error(t("personality_not_found")); return
        p_items = list(p.items()); p_names = [pd.get("name", "Unnamed") for _, pd in p_items]
        MandreUI.show(t("export_settings"), p_names, lambda i, name: self._export_personality_settings(p_items[i][0]))

    def _clear_history(self, peer): self._history.pop(self._peer_key(peer), None)
    def _get_current_personality(self): self._validate_and_fix_personalities(); return self._get_personalities().get(self.get_setting("current_personality", ""), {})
    def _build_persona(self): p = self._get_current_personality(); prompt = t("persona_sys_v2", **p); return prompt + t("nsfw_prompt_addition") if p.get("nsfw", False) else prompt
    def _peer_key(self, peer): return f"{getattr(peer, 'channel_id', getattr(peer, 'chat_id', getattr(peer, 'user_id', 0)))}_{self.get_setting('current_personality', '')}"
    def _get_history(self, peer): return self._history.get(self._peer_key(peer), []) if self.get_setting("remember_history", True) else []

    def _append_history(self, peer, turn):
        if not self.get_setting("remember_history", True): return
        key = self._peer_key(peer)
        try: depth = int(self.get_setting("history_depth", "10")) * 2
        except: depth = 20
        self._history.setdefault(key, []).append(turn)
        if len(self._history[key]) > depth: self._history[key] = self._history[key][-depth:]

    def _export_personality_by_id_or_name(self, target):
        p, target_lower = self._get_personalities(), target.lower()
        if target in p: self._export_personality_settings(target); return
        for pid, pdata in p.items():
            if pdata.get("name", "").lower() == target_lower: self._export_personality_settings(pid); return
        BulletinHelper.show_error(t("personality_not_found"))

    def _export_personality_settings(self, pid):
        p = self._get_personalities().get(pid)
        if not p: BulletinHelper.show_error(t("personality_not_found")); return
        if AndroidUtilities.addToClipboard(json.dumps(p, ensure_ascii=False, indent=2)): BulletinHelper.show_success(t("copied"))

    def _import_personality_settings(self, payload: str):
        try:
            data = json.loads(payload.strip())
            if not all(k in data for k in ["name", "bot_name"]): return False, t("bad_import")
            p, new_id = self._get_personalities(), str(uuid.uuid4())
            p[new_id] = {
                "name": data.get("name"), "bot_name": data.get("bot_name"), "user_name": data.get("user_name", "User"),
                "greeting": data.get("greeting", ""), "personality_sys_main": data.get("personality_sys_main", data.get("traits", "")),
                "scenario": data.get("scenario", ""), "example_dialogues": data.get("example_dialogues", ""), "nsfw": data.get("nsfw", False),
            }
            self._save_personalities(p); Mandre.apply_and_refresh_settings(self); return True, "ok"
        except Exception as e: log(f"[MandreCharacter AI] import error: {e}"); return False, t("bad_import")

    def _show_generate_personality_dialog(self):
        def on_input(description: str):
            if description and description.strip(): self._generate_personality_with_ai(description.strip())
        
        fragment = get_last_fragment();
        if not fragment or not fragment.getParentActivity(): return
        context = fragment.getParentActivity(); container = FrameLayout(context); edit_text = EditText(context)
        edit_text.setHint(t("generate_prompt_hint")); container.addView(edit_text)
        padding = AndroidUtilities.dp(20); container.setPadding(padding, AndroidUtilities.dp(10), padding, AndroidUtilities.dp(10))
        builder = AlertDialogBuilder(context); builder.set_title(t("generate_prompt_title")); builder.set_view(container)
        builder.set_positive_button("OK", lambda d, w: on_input(edit_text.getText().toString()))
        builder.set_negative_button(t("exit_button"), None); run_on_ui_thread(builder.show)

    def _generate_personality_with_ai(self, user_description: str):
        api_key = self.get_setting("api_key", "").strip()
        if not api_key: BulletinHelper.show_error(t("no_api")); return
        try:
            progress = AlertDialogBuilder(get_last_fragment().getParentActivity(), AlertDialogBuilder.ALERT_TYPE_SPINNER)
            progress.set_message(t("generating_personality")).show()
        except: progress = None
        
        def worker():
            try:
                prompt = (
                    f"You are an assistant for creating chatbot personalities. Based on the user's description: '{user_description}', "
                    f"generate a valid JSON object with these keys: name, bot_name, greeting, personality_sys_main, scenario, example_dialogues, user_name. "
                    f"Make the personality detailed and creative. Ensure the output is ONLY a valid JSON object without any other text or markdown."
                )
                model_idx = self.get_setting("model", 0); all_ids, _ = self._get_all_models()
                model = all_ids[model_idx] if 0 <= model_idx < len(all_ids) else AVAILABLE_MODELS[0]
                
                ai_response = self._call_openrouter(api_key, model, "You are a JSON generation assistant.", prompt, [])
                
                if ai_response:
                    try:
                        # Clean the response just in case
                        json_str = ai_response.strip()
                        if json_str.startswith("```json"): json_str = json_str[7:]
                        if json_str.endswith("```"): json_str = json_str[:-3]
                        
                        data = json.loads(json_str)
                        # Add default nsfw field
                        data["nsfw"] = False
                        run_on_ui_thread(lambda: self._add_new_personality_from_data(data))
                    except json.JSONDecodeError:
                        log(f"[MandreCharacter AI] Invalid JSON from AI: {ai_response}")
                        BulletinHelper.show_error(t("generation_failed"))
                else:
                    BulletinHelper.show_error(t("empty_response"))
            except Exception as e:
                log(f"[MandreCharacter AI] Generation worker error: {e}"); BulletinHelper.show_error(str(e))
            finally:
                if progress: run_on_ui_thread(progress.dismiss)
        run_on_queue(worker)

    def _call_openrouter(self, api_key, model, system_prompt, user_prompt, history_turns):
        headers = {"Authorization": f"Bearer {api_key}", "Content-Type": "application/json", "User-Agent": "exteraGram-MandreCAI/1.4"}
        messages = [{"role": "system", "content": system_prompt}]
        for role, text in history_turns: messages.append({"role": "assistant" if role == "assistant" else "user", "content": text})
        messages.append({"role": "user", "content": user_prompt})
        payload = {"model": model, "messages": messages}
        if self.get_setting("enable_logs", True): log(f"[MandreCharacter AI] POST {model}; messages_count={len(messages)}")
        try:
            r = requests.post(OPENROUTER_ENDPOINT, json=payload, headers=headers, timeout=60)
            if r.status_code == 401: raise ValueError(t("auth_error_401"))
            elif r.status_code == 403: raise ValueError(t("auth_error_403"))
            elif r.status_code == 429: raise ValueError(t("rate_limit_error"))
            elif r.status_code == 422: raise ValueError(t("model_not_available"))
            r.raise_for_status(); data = r.json()
            if self.get_setting("enable_logs", True): log(f"[MandreCharacter AI] response keys={list(data.keys())}")
            choices = data.get("choices", [])
            if not choices: return None
            message = choices[0].get("message", {}); result = message.get("content", "").strip() or None
            if self.get_setting("enable_logs", True): log(f"[MandreCharacter AI] result_len={len(result) if result else 0}")
            return result
        except requests.exceptions.HTTPError as e:
            if hasattr(e, 'response') and e.response:
                try: error_data = e.response.json(); error_msg = error_data.get("error", {}).get("message", str(e)); log(f"[MandreCharacter AI] HTTP error: {e.response.status_code} - {error_msg}")
                except: log(f"[MandreCharacter AI] HTTP error: {e}")
            raise
        except Exception as e: log(f"[MandreCharacter AI] Error calling API: {e}"); raise

    def _utf16_len(self, s: str) -> int:
        try: return len((s or "").encode("utf-16-le")) // 2
        except Exception: return len(s or "")

    def _supports_blockquote(self) -> bool: return hasattr(TLRPC, "TL_messageEntityBlockquote")
    def _make_bold(self, o: int, l: int): e = TLRPC.TL_messageEntityBold(); e.offset=o; e.length=l; return e
    def _make_italic(self, o: int, l: int): e = TLRPC.TL_messageEntityItalic(); e.offset=o; e.length=l; return e
    def _make_blockquote(self, o: int, l: int): e = TLRPC.TL_messageEntityBlockquote(); e.offset=o; e.length=l; return e

    def _actions_to_italics(self, text: str):
        if not text: return "", []
        p = re.compile(r'__(.+?)__', flags=re.S); parts, italics, pos, units = [], [], 0, 0
        for m in p.finditer(text):
            prefix = text[pos:m.start()]; parts.append(prefix); units += self._utf16_len(prefix)
            content = m.group(1)
            if content: italics.append((units, self._utf16_len(content))); parts.append(content); units += self._utf16_len(content)
            pos = m.end()
        parts.append(text[pos:])
        return "".join(parts), italics

    def _build_tg_formatted_message(self, user_text, ai_text, bot_name):
        you, ai = t("you_label").strip(), t("ai_label", bot_name=bot_name).strip()
        user_clean, user_italics = self._actions_to_italics(user_text)
        ai_clean, ai_italics = self._actions_to_italics(ai_text)
        sep = "\n\n"; text = f"{you}\n{user_clean}{sep}{ai}\n{ai_clean}"; entities = []
        if self._supports_blockquote():
            entities.append(self._make_bold(0, self._utf16_len(you)))
            user_off, user_len = self._utf16_len(you) + 1, self._utf16_len(user_clean)
            if user_len > 0:
                entities.append(self._make_blockquote(user_off, user_len))
                for o, l in user_italics: entities.append(self._make_italic(user_off + o, l))
            ai_off = user_off + user_len + self._utf16_len(sep)
            entities.append(self._make_bold(ai_off, self._utf16_len(ai)))
            ai_block_off, ai_block_len = ai_off + self._utf16_len(ai) + 1, self._utf16_len(ai_clean)
            if ai_block_len > 0:
                entities.append(self._make_blockquote(ai_block_off, ai_block_len))
                for o, l in ai_italics: entities.append(self._make_italic(ai_block_off + o, l))
        else: text = f"**{you}**\n> {user_text}\n\n**{ai}**\n> {ai_text}"
        return text, entities

    def _normalize_user_actions(self, text: str) -> str:
        if not text: return text
        try: return re.sub(r'\*(.+?)\*', r'__\1__', text, flags=re.S)
        except Exception: return text

    def _normalize_assistant_actions(self, text: str) -> str:
        if not text: return text
        try: return re.sub(r'\*(.+?)\*', r'__\1__', text, flags=re.S)
        except Exception: return text

    def _normalize_history_for_api(self, history_turns):
        norm = []
        for role, txt in (history_turns or []):
            if role == "user": norm.append((role, self._normalize_user_actions(txt)))
            elif role == "assistant": norm.append((role, self._normalize_assistant_actions(txt)))
            else: norm.append((role, txt))
        return norm

    def _quote_block(self, text: str) -> str:
        s = text if text is not None else ""; return "> " + s.replace("\n", "\n> ")