class _DownloadObserver(dynamic_proxy(NotificationCenter.NotificationCenterDelegate)):
    def __init__(self):
        super().__init__()
        self.plugin = None

    def didReceivedNotification(self, notif_id: int, account: int, args):
        plugin = self.plugin
        if plugin is None:
            return
        try:
            plugin._on_file_notification(notif_id, account, args)
        except Exception as e:
            log(f"[Playlist Downloader] observer error: {e}")


class PlaylistDownloaderPlugin(BasePlugin):
    PAGE_LIMIT = 100

    def on_plugin_load(self):
        self._running = False
        self._cancel_requested = False
        self._cancel_lock = False
        self._scan_request_offset_id = 0
        self._scan_request_offset_date = 0
        self._scan_pages = 0
        self._found_messages: List[Any] = []
        self._download_total = 0
        self._download_done = 0
        self._cached_skipped = 0
        self._failed = 0
        self._progress_dialog = None
        self._menu_item_id = None

        self._current_account = 0
        self._current_file_name: Optional[str] = None
        self._current_document = None
        self._current_title: str = ""
        self._observers_added = False

        self._observer = _DownloadObserver()
        self._observer.plugin = self
        
        self._menu_item_id = self.add_menu_item(
            MenuItemData(
                menu_type=MenuItemType.CHAT_ACTION_MENU,
                text=self._t("menu_title"),
                subtext=self._t("menu_subtitle"),
                on_click=self._on_menu_click,
                icon="msg_download",
                priority=90,
            )
        )

    def on_plugin_unload(self):
        self._cancel_requested = True
        self._remove_observers()
        if self._menu_item_id:
            try:
                self.remove_menu_item(self._menu_item_id)
            except Exception:
                pass
        self._hide_progress_dialog()

    def create_settings(self):
        return [
            Header(text=self._t("settings_header")),
            Text(
                text=self._t("settings_clear_cache"),
                subtext=self._t("settings_clear_cache_subtext"),
                icon="msg_delete",
                red=True,
                on_click=self._clear_cache_click,
            ),
            Divider(
                text=self._t("settings_run_subtext"),
            ),
        ]

    def _lang(self) -> str:
        candidates = []
        try:
            candidates.append(LocaleController.getInstance().getCurrentLocaleInfo().getLangCode())
        except Exception:
            pass
        try:
            candidates.append(LocaleController.getInstance().getCurrentLocale().getLanguage())
        except Exception:
            pass
        try:
            from java.util import Locale as JavaLocale
            candidates.append(JavaLocale.getDefault().getLanguage())
        except Exception:
            pass

        for code in candidates:
            if code and str(code).lower().startswith("ru"):
                return "ru"
        return "en"

    def _t(self, key: str, **kwargs) -> str:
        table = STRINGS.get(self._lang(), STRINGS["en"])
        template = table.get(key, STRINGS["en"].get(key, key))
        return template.format(**kwargs) if kwargs else template

    def _on_menu_click(self, context: Dict[str, Any]):
        

        if self._running:
            self._show_bulletin(self._t("bulletin_already_running"))
            return

        dialog_id = self._extract_dialog_id(context)
        if not dialog_id:
            self._show_bulletin(self._t("bulletin_no_chat"))
            return

        self._running = True
        self._cancel_requested = False
        self._cancel_lock = False
        self._scan_request_offset_id = 0
        self._scan_request_offset_date = 0
        self._scan_pages = 0
        self._found_messages = []
        self._download_total = 0
        self._download_done = 0
        self._cached_skipped = 0
        self._failed = 0

        self._show_progress_dialog(
            title=self._t("dialog_title"),
            message=self._t("dialog_scanning"),
            progress=0,
            cancelable=True,
        )
        self._scan_next_page(dialog_id)

    def _clear_cache_click(self, _view):
        self._found_messages = []
        self._download_total = 0
        self._download_done = 0
        self._cached_skipped = 0
        self._failed = 0
        self._show_bulletin(self._t("bulletin_cache_cleared"))

    def _scan_next_page(self, dialog_id: int):
        if self._cancel_requested:
            self._finish_with_cancel()
            return

        try:
            controller = get_messages_controller()
            if controller is None:
                self._fail(self._t("bulletin_no_controller"))
                return

            input_peer = self._get_input_peer(controller, dialog_id)
            if input_peer is None:
                self._fail(self._t("bulletin_no_peer"))
                return

            req = TLRPC.TL_messages_getHistory()
            req.peer = input_peer
            req.offset_id = int(self._scan_request_offset_id)
            req.offset_date = int(self._scan_request_offset_date)
            req.add_offset = 0
            req.limit = int(self.PAGE_LIMIT)
            req.max_id = 0
            req.min_id = 0
            req.hash = 0

            def _callback(response, error):
                try:
                    if self._cancel_requested:
                        self._finish_with_cancel()
                        return

                    if error:
                        self._fail(self._t("bulletin_request_failed", error=getattr(error, "text", error)))
                        return

                    messages = getattr(response, "messages", None)
                    if messages is None:
                        self._begin_download_phase(controller)
                        return

                    try:
                        msg_count = int(messages.size())
                    except Exception:
                        msg_count = 0

                    if msg_count <= 0:
                        self._begin_download_phase(controller)
                        return

                    i = 0
                    while i < msg_count:
                        try:
                            raw_msg = messages.get(i)
                            if MessageObject.isMusicMessage(raw_msg):
                                self._found_messages.append(raw_msg)
                        except Exception as e:
                            log(f"[Playlist Downloader] message parse error index={i}: {e}")
                        i += 1

                    self._scan_pages += 1

                    oldest = messages.get(msg_count - 1)
                    oldest_id = int(getattr(oldest, "id", 0) or 0)
                    oldest_date = int(getattr(oldest, "date", 0) or 0)

                    self._update_progress_dialog(
                        progress=min(95, self._scan_pages * 3),
                        message=self._t("dialog_scanning_progress", found=len(self._found_messages)),
                    )

                    if msg_count < self.PAGE_LIMIT or oldest_id <= 0:
                        self._begin_download_phase(controller)
                        return

                    if oldest_id == self._scan_request_offset_id and oldest_date == self._scan_request_offset_date:
                        self._begin_download_phase(controller)
                        return

                    self._scan_request_offset_id = oldest_id
                    self._scan_request_offset_date = oldest_date
                    self._scan_next_page(dialog_id)
                except Exception as e:
                    self._fail(self._t("bulletin_scan_error", error=e))

            send_request(req, _callback)

        except Exception as e:
            self._fail(self._t("bulletin_scan_error", error=e))

    def _begin_download_phase(self, controller):
        def _ui():
            if self._cancel_requested:
                self._finish_with_cancel()
                return

            self._download_total = len(self._found_messages)
            self._download_done = 0

            if self._download_total <= 0:
                self._show_bulletin(self._t("bulletin_no_tracks"))
                self._finish()
                return

            self._current_account = self._get_account(controller)
            self._add_observers()

            self._update_progress_dialog(
                progress=0,
                message=self._t("dialog_found", total=self._download_total),
                title=self._t("dialog_title"),
            )
            self._download_next(controller)

        run_on_ui_thread(_ui)

    def _download_next(self, controller):
        if self._cancel_requested:
            self._finish_with_cancel()
            return

        if self._download_done >= self._download_total:
            self._remove_observers()
            downloaded = self._download_total - self._cached_skipped - self._failed
            summary = self._t(
                "bulletin_summary",
                downloaded=downloaded,
                skipped=self._cached_skipped,
                failed=self._failed,
            )
            self._update_progress_dialog(progress=100, message=summary)
            self._show_bulletin(summary)
            self._finish()
            return

        raw_msg = self._found_messages[self._download_done]

        try:
            msg_obj = self._make_message_object_by_account(self._current_account, raw_msg)
            if msg_obj is None:
                self._advance(controller, cached=False, failed=True)
                return

            document = self._get_document(msg_obj, raw_msg)
            if document is None:
                self._advance(controller, cached=False, failed=True)
                return

            file_name = self._safe_attach_file_name(document)
            if not file_name or "0_0" in file_name[:3] or self._looks_like_min_int(file_name):
                self._advance(controller, cached=False, failed=True)
                return

            if self._is_music_already_cached(self._current_account, raw_msg, msg_obj=msg_obj):
                self._cached_skipped += 1
                self._advance(controller, cached=True, failed=False)
                return

            file_loader = get_file_loader()
            if file_loader is None:
                self._fail(self._t("bulletin_loader_unavailable"))
                return

            self._current_file_name = file_name
            self._current_document = document
            self._current_title = self._describe_track(msg_obj)

            self._update_progress_dialog(
                progress=0,
                message=self._format_download_message(),
                title=self._t("dialog_title"),
            )

            file_loader.loadFile(document, msg_obj, FileLoader.PRIORITY_HIGH, 0)

        except Exception as e:
            self._fail(self._t("bulletin_download_error", error=e))

    def _advance(self, controller, cached: bool, failed: bool):
        self._download_done += 1
        self._current_file_name = None
        self._current_document = None
        self._current_title = ""
        self._update_progress_dialog(
            progress=0,
            message=self._format_checking_message(),
            title=self._t("dialog_title"),
        )
        self._download_next(controller)

    def _on_file_notification(self, notif_id: int, account: int, args):
        if account != self._current_account:
            return
        if self._current_file_name is None:
            return

        if notif_id == NotificationCenter.fileLoaded:
            file_name = self._arg_str(args, 0)
            if file_name != self._current_file_name:
                return
            controller = get_messages_controller()
            self._advance(controller, cached=False, failed=False)

        elif notif_id == NotificationCenter.fileLoadFailed:
            file_name = self._arg_str(args, 0)
            if file_name != self._current_file_name:
                return
            self._failed += 1
            controller = get_messages_controller()
            self._advance(controller, cached=False, failed=True)

        elif notif_id == NotificationCenter.fileLoadProgressChanged:
            file_name = self._arg_str(args, 0)
            if file_name != self._current_file_name:
                return
            loaded, total = self._arg_progress(args)
            per_file_pct = int((loaded * 100) / total) if total else 0
            self._set_progress_only(per_file_pct)

    @staticmethod
    def _arg_str(args, index: int) -> Optional[str]:
        try:
            value = args[index]
            return str(value) if value is not None else None
        except Exception:
            return None

    @staticmethod
    def _arg_progress(args):
        try:
            loaded = int(args[1])
            total = int(args[2])
            return loaded, total
        except Exception:
            return 0, 0

    def _add_observers(self):
        if self._observers_added:
            return
        nc = get_notification_center()
        if nc is None:
            return
        nc.addObserver(self._observer, NotificationCenter.fileLoaded)
        nc.addObserver(self._observer, NotificationCenter.fileLoadFailed)
        nc.addObserver(self._observer, NotificationCenter.fileLoadProgressChanged)
        self._observers_added = True

    def _remove_observers(self):
        if not self._observers_added:
            return
        try:
            nc = get_notification_center()
            if nc is not None:
                nc.removeObserver(self._observer, NotificationCenter.fileLoaded)
                nc.removeObserver(self._observer, NotificationCenter.fileLoadFailed)
                nc.removeObserver(self._observer, NotificationCenter.fileLoadProgressChanged)
        except Exception:
            pass
        self._observers_added = False

    def _get_account(self, controller) -> int:
        try:
            value = get_private_field(controller, "currentAccount")
            if value is not None:
                return int(value)
        except Exception:
            pass
        try:
            user_cfg = controller.getUserConfig()
            if user_cfg is not None and hasattr(user_cfg, "selectedAccount"):
                return int(user_cfg.selectedAccount)
        except Exception:
            pass
        return 0

    def _get_input_peer(self, controller, dialog_id: int):
        for name in ("getInputPeer", "get_input_peer"):
            try:
                fn = getattr(controller, name, None)
                if fn is not None:
                    return fn(int(dialog_id))
            except Exception:
                pass
        return None

    def _get_document(self, msg_obj, raw_msg):
        document = None
        try:
            document = msg_obj.getDocument()
        except Exception:
            document = None
        if document is None:
            try:
                document = MessageObject.getDocument(raw_msg)
            except Exception:
                document = None
        return document

    def _safe_attach_file_name(self, document) -> Optional[str]:
        try:
            return FileLoader.getAttachFileName(document)
        except Exception as e:
            log(f"[Playlist Downloader] getAttachFileName failed: {e}")
            return None

    @staticmethod
    def _looks_like_min_int(file_name: str) -> bool:
        try:
            return str(-2147483648) in file_name
        except Exception:
            return False

    def _describe_track(self, msg_obj) -> str:
        try:
            title = msg_obj.getMusicTitle() or ""
            author = msg_obj.getMusicAuthor() or ""
            if author and title:
                return f"{author} - {title}"
            return title or author or self._t("dialog_unknown_track")
        except Exception:
            return self._t("dialog_unknown_track")

    def _format_download_message(self) -> str:
        return self._t(
            "dialog_downloading",
            title=self._current_title or self._t("dialog_unknown_track"),
            done=self._download_done + 1,
            total=self._download_total,
            counts=self._format_counts_block(),
        )

    def _format_checking_message(self) -> str:
        return self._t(
            "dialog_checking",
            done=self._download_done,
            total=self._download_total,
            counts=self._format_counts_block(),
        )

    def _format_counts_block(self) -> str:
        downloaded = max(self._download_done - self._cached_skipped - self._failed, 0)
        return self._t(
            "dialog_counts",
            downloaded=downloaded,
            skipped=self._cached_skipped,
            failed=self._failed,
        )

    def _resolve_sparse_map(self, controller, names):
        for field_name in names:
            try:
                value = get_private_field(controller, field_name)
                if value is not None:
                    return value
            except Exception:
                continue
        return None

    def _new_long_sparse_array(self):
        try:
            from hook_utils import find_class
            cls = find_class("androidx.collection.LongSparseArray")
            return cls()
        except Exception:
            return None

    def _is_music_already_cached(self, account: int, raw_msg, msg_obj=None) -> bool:
        try:
            file_loader = FileLoader.getInstance(int(account))
        except Exception as e:
            log(f"[Playlist Downloader] FileLoader getInstance failed: {e}")
            return False

        try:
            path = None
            try:
                path = file_loader.getPathToMessage(raw_msg)
            except Exception:
                path = None

            if path is not None:
                try:
                    if path.exists():
                        return True
                except Exception:
                    pass

            if msg_obj is None:
                msg_obj = self._make_message_object_by_account(account, raw_msg)

            document = self._get_document(msg_obj, raw_msg) if msg_obj is not None else None

            if document is None:
                return False

            try:
                file_name = FileLoader.getAttachFileName(document)
                if file_name and file_loader.isLoadingFile(file_name):
                    return True
            except Exception:
                pass
        except Exception as e:
            log(f"[Playlist Downloader] cache check failed: {e}")

        return False

    def _make_message_object_by_account(self, account: int, raw_msg):
        try:
            users_map = None
            chats_map = None

            controller = get_messages_controller()
            if controller is not None:
                users_map = self._resolve_sparse_map(controller, ("users", "allUsers", "usersMap", "usersDict"))
                chats_map = self._resolve_sparse_map(controller, ("chats", "allChats", "chatsMap", "chatsDict"))

            if users_map is None:
                users_map = self._new_long_sparse_array()
            if chats_map is None:
                chats_map = self._new_long_sparse_array()

            return MessageObject(int(account), raw_msg, users_map, chats_map, False, False)
        except Exception as e:
            log(f"[Playlist Downloader] MessageObject build failed: {e}")
            return None

    def _extract_dialog_id(self, context: Dict[str, Any]) -> int:
        for key in ("dialog_id", "dialogId", "chatId", "chat_id"):
            value = context.get(key)
            if value:
                try:
                    return int(value)
                except Exception:
                    pass

        try:
            chat = context.get("chat")
            if chat is not None and hasattr(chat, "id"):
                return int(chat.id) * -1 if int(chat.id) > 0 else int(chat.id)
        except Exception:
            pass

        try:
            message = context.get("message")
            if message is not None and hasattr(message, "getDialogId"):
                return int(message.getDialogId())
        except Exception:
            pass

        return 0

    def _show_bulletin(self, text: str):
        try:
            fragment = get_last_fragment()
        except Exception:
            fragment = None
        try:
            BulletinHelper.show_info(text, fragment)
        except Exception:
            log(text)

    def _show_progress_dialog(self, title: str, message: str, progress: int = 0, cancelable: bool = True):
        def _ui():
            try:
                if self._progress_dialog is not None:
                    self._apply_dialog_content(title, message, progress)
                    return

                fragment = get_last_fragment()
                activity = fragment.getParentActivity() if fragment else None
                if activity is None:
                    self._show_bulletin(self._t("bulletin_no_screen"))
                    return

                dialog = AlertDialogBuilder(activity, AlertDialogBuilder.ALERT_TYPE_LOADING)
                dialog.set_title(title)
                dialog.set_message(message)

                if cancelable:
                    dialog.set_negative_button(self._t("dialog_cancel"), lambda *_: self._cancel_scan())

                dialog.create()
                dialog.set_progress(int(progress))
                dialog.set_cancelable(cancelable)
                dialog.set_canceled_on_touch_outside(False)

                if cancelable:
                    def _on_dismiss(*_args, this_dialog=dialog):
                        if self._progress_dialog is this_dialog:
                            self._cancel_scan()

                    dialog.set_on_dismiss_listener(_on_dismiss)
                    dialog.set_on_cancel_listener(_on_dismiss)

                self._progress_dialog = dialog
                dialog.show()
            except Exception as e:
                log(f"[Playlist Downloader] show dialog failed: {e}")
                self._show_bulletin(self._t("bulletin_show_failed", error=e))

        run_on_ui_thread(_ui)

    def _apply_dialog_content(self, title: Optional[str], message: Optional[str], progress: Optional[int]):
        try:
            if self._progress_dialog is None:
                return
            raw_dialog = self._progress_dialog.get_dialog()
            if raw_dialog is not None:
                if title is not None:
                    raw_dialog.setTitle(title)
                if message is not None:
                    raw_dialog.setMessage(message)
            elif title is not None or message is not None:
                if title is not None:
                    self._progress_dialog.set_title(title)
                if message is not None:
                    self._progress_dialog.set_message(message)

            if progress is not None:
                self._progress_dialog.set_progress(int(max(0, min(progress, 100))))
        except Exception as e:
            log(f"[Playlist Downloader] in-place dialog update failed: {e}")

    def _update_progress_dialog(self, progress: int, message: Optional[str] = None, title: Optional[str] = None):
        self._show_progress_dialog(
            title=title or self._t("dialog_title"),
            message=message or "",
            progress=progress,
            cancelable=True,
        )

    def _set_progress_only(self, progress: int):
        def _ui():
            try:
                if self._progress_dialog is None:
                    return
                self._progress_dialog.set_progress(int(max(0, min(progress, 100))))
            except Exception as e:
                log(f"[Playlist Downloader] set progress failed: {e}")

        run_on_ui_thread(_ui)

    def _hide_progress_dialog(self):
        def _ui():
            dialog = self._progress_dialog
            self._progress_dialog = None
            try:
                if dialog is not None:
                    dialog.dismiss()
            except Exception:
                pass

        run_on_ui_thread(_ui)

    def _cancel_scan(self):
        def _do_cancel():
            if self._cancel_lock:
                return
            self._cancel_lock = True

            self._cancel_requested = True
            if self._current_document is not None:
                try:
                    get_file_loader().cancelLoadFile(self._current_document)
                except Exception:
                    pass
            self._remove_observers()
            self._show_bulletin(self._t("bulletin_cancelled"))
            self._hide_progress_dialog()
            self._running = False

        run_on_ui_thread(_do_cancel)

    def _finish_with_cancel(self):
        self._running = False
        self._remove_observers()
        self._hide_progress_dialog()

    def _finish(self):
        self._running = False
        self._remove_observers()
        self._hide_progress_dialog()

    def _fail(self, text: str):
        log(f"[Playlist Downloader] fail: {text}")
        self._show_bulletin(text)
        self._running = False
        self._remove_observers()
        self._hide_progress_dialog()
        self._cancel_requested = True


PlaylistDownloader = PlaylistDownloaderPlugin