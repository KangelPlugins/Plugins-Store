__id__ = "playlist_downloader"
__name__ = "Playlist Downloader"
__description__ = """
Загружает каждый трек из плейлиста чата в один клик с помощью встроенного загрузчика файлов Telegram.

Downloads every track from a chat's playlist in one tap, through Telegram's own file loader.
"""
__author__ = "@ameerchik6"
__version__ = "1.0"
__icon__ = "litsouls/16"
__app_version__ = ">=12.8.1"
__sdk_version__ = ">=1.4.0"


