ACHIEVEMENTS: Dict[str, Achievement] = {
    # === СООБЩЕНИЯ ===
    'first_message': Achievement('first_message', 'ach_first_message', 'ach_first_message_desc', AchievementCategory.MESSAGES, '💬', Rarity.COMMON),
    'getting_started': Achievement('getting_started', 'ach_getting_started', 'ach_getting_started_desc', AchievementCategory.MESSAGES, '🚀', Rarity.COMMON, target=10),
