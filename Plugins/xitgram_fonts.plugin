    CIRCLED[chr(97 + i)] = chr(0x24D0 + i)
    CIRCLED_NEG[chr(65 + i)] = chr(0x1F150 + i)
    CIRCLED_NEG[chr(97 + i)] = chr(0x1F150 + i)
    SQUARED[chr(65 + i)] = chr(0x1F130 + i)
    SQUARED[chr(97 + i)] = chr(0x1F130 + i)
    SQUARED_NEG[chr(65 + i)] = chr(0x1F170 + i)
    SQUARED_NEG[chr(97 + i)] = chr(0x1F170 + i)
    FULLWIDTH[chr(65 + i)] = chr(0xFF21 + i)
    FULLWIDTH[chr(97 + i)] = chr(0xFF41 + i)
CIRCLED['0'] = '\u24EA'
for i in range(1, 10):
    CIRCLED[str(i)] = chr(0x2460 + (i - 1))
CIRCLED_NEG['0'] = '\u24FF'
for i in range(1, 10):
    CIRCLED_NEG[str(i)] = chr(0x2775 + i)
for i in range(10):
    FULLWIDTH[str(i)] = chr(0xFF10 + i)
FULLWIDTH[' '] = '\u3000'

