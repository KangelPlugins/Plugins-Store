FONTS_BY_ID = {f["id"]: f for f in FONTS}

PREVIEW_TEXT = "XitGram Шрифт"


def _preview(font: Dict[str, Any]) -> str:
    try:
        return font["fn"](PREVIEW_TEXT)
    except Exception:
        return font["name"]


def _cyr_note(cyr: Any) -> str:
    if cyr is True:
        return ""
    if cyr == "partial":
        return " (рус. частично)"
    return " (лат./цифры)"


# ---------------------------------------------------------------------------
# 3. Развлекательные команды (в духе бота Iris) — .hug, .kiss, .rate и т.д.
#    Все действия отправляются от лица "Вы" (форма вежливого "вы", чтобы не
#    зависеть от рода/пола) с несколькими случайными вариантами фраз и
#    эмодзи-оформлением. Никакой реальной агрессии — команды вроде .kill
#    или .slap оформлены как безобидная шутка без сцен насилия.
# ---------------------------------------------------------------------------

def _warm_self(verb: str, emoji: str) -> str:
    return f"Вы {verb} сами себя — иногда и это нужно! {emoji}"


def _avoid_self(emoji: str) -> str:
    return f"Рядом никого не нашлось — вы великодушно всех пощадили {emoji}😅"


# cmd -> {emoji, templates (с {t} для цели), self: (глагол, "warm"/"avoid")}
