# Кириллица/латиница "confusables" — буквы, которые официально считаются
# визуально неотличимыми в разных алфавитах (используются, например, в
# Unicode Technical Standard #39 про "confusable" символы).
RU_LATIN_LOOKALIKE = {
    'А': 'A', 'В': 'B', 'Е': 'E', 'К': 'K', 'М': 'M', 'Н': 'H',
    'О': 'O', 'Р': 'P', 'С': 'C', 'Т': 'T', 'У': 'Y', 'Х': 'X',
    'а': 'a', 'е': 'e', 'к': 'k', 'м': 'm', 'о': 'o', 'р': 'p',
    'с': 'c', 'у': 'y', 'х': 'x',
}


def _with_ru_lookalikes(base_table: Dict[str, str]) -> Dict[str, str]:
    """Расширяет латинскую таблицу стилизации похожими кириллическими буквами."""
    combined = dict(base_table)
    for cyr, latin in RU_LATIN_LOOKALIKE.items():
        if latin in base_table:
            combined[cyr] = base_table[latin]
    return combined


BOLD_RU = _with_ru_lookalikes(BOLD)
ITALIC_RU = _with_ru_lookalikes(ITALIC)
SANS_BOLD_RU = _with_ru_lookalikes(SANS_BOLD)
MONOSPACE_RU = _with_ru_lookalikes(MONOSPACE)
DOUBLE_STRUCK_RU = _with_ru_lookalikes(DOUBLE_STRUCK)

LEET = {
    'a': '4', 'e': '3', 'i': '1', 'o': '0', 's': '5', 't': '7', 'l': '1',
    'b': '8', 'g': '9',
    'A': '4', 'E': '3', 'I': '1', 'O': '0', 'S': '5', 'T': '7', 'L': '1',
    'B': '8', 'G': '9',
    'з': '3', 'З': '3', 'о': '0', 'О': '0', 'ч': '4', 'Ч': '4',
    'е': '3', 'Е': '3',
}


def _table_transform(table: Dict[str, str]) -> Callable[[str], str]:
    trans = str.maketrans(table)
    return lambda text: text.translate(trans)


def _upside_down_transform(text: str) -> str:
    trans = str.maketrans(UPSIDE_DOWN)
    return text.translate(trans)[::-1]


def _combining_transform(mark: str) -> Callable[[str], str]:
    def _fn(text: str) -> str:
        out = []
        for ch in text:
            out.append(ch)
            if not ch.isspace():
                out.append(mark)
        return "".join(out)
    return _fn


def _double_combining_transform(mark1: str, mark2: str) -> Callable[[str], str]:
    def _fn(text: str) -> str:
        out = []
        for ch in text:
            out.append(ch)
            if not ch.isspace():
                out.append(mark1)
                out.append(mark2)
        return "".join(out)
    return _fn


# --- Структурные "мемные" эффекты — работают с любым языком без ограничений ---

def _alternating_case(text: str) -> str:
    out = []
    upper = False
    for ch in text:
        if ch.isspace():
            out.append(ch)
            continue
        out.append(ch.upper() if upper else ch.lower())
        upper = not upper
    return "".join(out)


def _reverse_transform(text: str) -> str:
    return text[::-1]


def _spaced_out(text: str) -> str:
    words = text.split(" ")
    return "   ".join(" ".join(w) for w in words)


def _clap_words(text: str) -> str:
    words = text.split(" ")
    return " 👏 ".join(words) if len(words) > 1 else text + " 👏"


def _sparkle_words(text: str) -> str:
    words = [w for w in text.split(" ") if w]
    return " ".join(f"✨{w}✨" for w in words) if words else text


def _fire_words(text: str) -> str:
    words = [w for w in text.split(" ") if w]
    return " ".join(f"🔥{w}🔥" for w in words) if words else text


_ZALGO_MARKS = ['\u0300', '\u0301', '\u0304', '\u0306', '\u0308', '\u030c',
                '\u0316', '\u0317', '\u0318', '\u0319', '\u0323', '\u0325']


def _zalgo_mild(text: str) -> str:
    out = []
    for ch in text:
        out.append(ch)
        if not ch.isspace():
            for _ in range(random.randint(1, 3)):
                out.append(random.choice(_ZALGO_MARKS))
    return "".join(out)


# --- Новые эффекты v4 — работают с любым языком без ограничений -----------

def _invisible_transform(text: str) -> str:
    return "\u200b".join(text)


def _scream_transform(text: str) -> str:
    return text.upper() + " !!!"


def _whisper_transform(text: str) -> str:
    return f"( {text.lower()} )"


def _shrug_transform(text: str) -> str:
    return f"{text} ¯\\_(ツ)_/¯"


def _clown_transform(text: str) -> str:
    words = [w for w in text.split(" ") if w]
    if not words:
        return text + " 🤡"
    out = []
    for w in words:
        out.append(w)
        if random.random() < 0.4:
            out.append("🤡")
    return " ".join(out)


def _word_wrap_transform(mark: str) -> Callable[[str], str]:
    def _fn(text: str) -> str:
        words = [w for w in text.split(" ") if w]
        return " ".join(f"{mark}{w}{mark}" for w in words) if words else text + f" {mark}"
    return _fn


_RAINBOW_DOTS = ["🔴", "🟠", "🟡", "🟢", "🔵", "🟣"]


def _rainbow_dots_transform(text: str) -> str:
    words = [w for w in text.split(" ") if w]
    if not words:
        return text
    return " ".join(f"{_RAINBOW_DOTS[i % len(_RAINBOW_DOTS)]}{w}" for i, w in enumerate(words))


