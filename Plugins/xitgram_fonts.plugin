def _notify(plugin: "XitGramFontsPlugin", text: str) -> None:
    if HAS_BULLETIN:
        try:
            BulletinHelper.show_info(text)
            return
        except Exception:
            pass
    try:
        plugin.log(text)
    except Exception:
        pass


# ---------------------------------------------------------------------------
# 1. Таблицы символов
#    Оптимизация: каждая таблица один раз компилируется в str.maketrans(...),
#    а сама замена в тексте идёт через str.translate() — это встроенная
#    C-функция, она на порядок быстрее ручного цикла "for ch in text".
# ---------------------------------------------------------------------------

def _range_map(upper_start: int, lower_start: int, digit_start: int = None,
               upper_holes: Dict[str, str] = None, lower_holes: Dict[str, str] = None) -> Dict[str, str]:
    m: Dict[str, str] = {}
    for i in range(26):
        m[chr(ord('A') + i)] = chr(upper_start + i)
        m[chr(ord('a') + i)] = chr(lower_start + i)
    if digit_start is not None:
        for i in range(10):
            m[chr(ord('0') + i)] = chr(digit_start + i)
    if upper_holes:
        m.update(upper_holes)
    if lower_holes:
        m.update(lower_holes)
    return m


BOLD = _range_map(0x1D400, 0x1D41A, 0x1D7CE)
ITALIC = _range_map(0x1D434, 0x1D44E, None, lower_holes={'h': '\u210E'})
BOLD_ITALIC = _range_map(0x1D468, 0x1D482)
SCRIPT = _range_map(
    0x1D49C, 0x1D4B6, None,
    upper_holes={'B': '\u212C', 'E': '\u2130', 'F': '\u2131', 'H': '\u210B',
                 'I': '\u2110', 'L': '\u2112', 'M': '\u2133', 'R': '\u211B'},
    lower_holes={'e': '\u212F', 'g': '\u210A', 'o': '\u2134'},
)
BOLD_SCRIPT = _range_map(0x1D4D0, 0x1D4EA)
FRAKTUR = _range_map(
    0x1D504, 0x1D51E, None,
    upper_holes={'C': '\u212D', 'H': '\u210C', 'I': '\u2111', 'R': '\u211C', 'Z': '\u2128'},
)
DOUBLE_STRUCK = _range_map(
    0x1D538, 0x1D552, 0x1D7D8,
    upper_holes={'C': '\u2102', 'H': '\u210D', 'N': '\u2115', 'P': '\u2119',
                 'Q': '\u211A', 'R': '\u211D', 'Z': '\u2124'},
)
BOLD_FRAKTUR = _range_map(0x1D56C, 0x1D586)
SANS = _range_map(0x1D5A0, 0x1D5BA, 0x1D7E2)
SANS_BOLD = _range_map(0x1D5D4, 0x1D5EE, 0x1D7EC)
SANS_ITALIC = _range_map(0x1D608, 0x1D622)
SANS_BOLD_ITALIC = _range_map(0x1D63C, 0x1D656)
MONOSPACE = _range_map(0x1D670, 0x1D68A, 0x1D7F6)

CIRCLED: Dict[str, str] = {}
