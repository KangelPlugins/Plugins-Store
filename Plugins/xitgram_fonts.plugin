KILL_METHODS = [
    "закидал(а) тапками", "защекотал(а) до икоты", "закидал(а) подушками",
    "обыграл(а) в шахматы", "переиграл(а) в самой скучной настолке",
    "заболтал(а) до потери сознания", "затанцевал(а) в конкурсе",
]

COMPLIMENTS = [
    "у тебя потрясающая улыбка 😊",
    "с тобой всегда легко и весело 🌟",
    "ты умеешь поднять настроение в любой момент 💫",
    "твоя доброта вдохновляет 💛",
    "ты справляешься лучше, чем сам(а) думаешь 💪",
    "с тобой хочется общаться ещё и ещё 🥰",
]

FACEPALM_PHRASES = ["🤦 Facepalm. Просто facepalm.", "🤦‍♂️ Ладно, бывает и так."]

STARE_TEMPLATES = ["Вы засмотрелись на {t} 👀", "Вы не могли отвести взгляд от {t} 👀💭"]
LOVE_TEMPLATES = ["Вы признались {t} в любви 💞", "Сердце ёкнуло — вы признались {t} в чувствах 💞😳"]


def _rate_comment(n: int) -> str:
    if n >= 90:
        return "идеал, дальше некуда 👑"
    if n >= 70:
        return "очень достойно 🌟"
    if n >= 50:
        return "неплохо, есть куда расти 🙂"
    if n >= 25:
        return "бывало и получше 😅"
    return "ну... по крайней мере честно 🙈"


def _percent_for(text: str) -> int:
    h = 0
    for ch in text.lower():
        h = (h * 31 + ord(ch)) % 100000
    return h % 101


def _bar(percent: int, length: int = 10) -> str:
    filled = round(percent / 100 * length)
    return "█" * filled + "░" * (length - filled)


FUN_COMMAND_HELP = [
    ("hug", "🤗", "обнять"), ("kiss", "😘", "поцеловать"), ("pat", "🥰", "погладить"),
    ("slap", "👋", "шлёпнуть (шуточно)"), ("poke", "👉", "ткнуть"), ("bite", "😈", "укусить"),
    ("cuddle", "🥺", "прижать"), ("tickle", "🤭", "пощекотать"), ("highfive", "🙌", "дать пять"),
    ("punch", "👊", "стукнуть (шуточно)"), ("feed", "🍰", "покормить"), ("dance", "💃", "потанцевать"),
    ("wave", "👋", "помахать"), ("wink", "😉", "подмигнуть"), ("kill", "🔪", "'убить' (шуточно)"),
    ("love", "💞", "признаться в любви"), ("marry", "💍", "сделать предложение"),
    ("divorce", "💔", "развестись"), ("stare", "👀", "засмотреться"), ("facepalm", "🤦", "фейспалм"),
    ("compliment", "💐", "сделать комплимент"), ("rate", "⭐", "оценить (0-100)"),
    ("ship", "💘", "совместимость двух имён"),
]


class XitGramFontsPlugin_FunMixin:
    """Логика развлекательных команд, подмешивается в основной класс плагина."""

    def _fun_list_text(self) -> str:
        lines = ["🎉 Развлекательные команды XitGram:"]
        for cmd, emoji, desc in FUN_COMMAND_HELP:
            lines.append(f"{emoji} .{cmd} <имя> — {desc}")
        lines.append("")
        lines.append("Примеры: .hug Аня  |  .rate  |  .ship Аня Вася")
        lines.append("Отключить эти команды можно в настройках плагина.")
        return "\n".join(lines)

    def _handle_fun_command(self, body: str) -> Tuple[bool, str]:
        if not self.get_setting("fun_enabled", True):
            return False, ""

        stripped = body.strip()
        if not stripped.startswith("."):
            return False, ""

        token, _, rest = stripped[1:].partition(" ")
        token = token.lower().strip()
        target = rest.strip()

        if token in ("fun", "fl"):
            return True, self._fun_list_text()

        if token in FUN_SIMPLE:
            data = FUN_SIMPLE[token]
            if target:
                phrase = random.choice(data["templates"]).format(t=target)
                return True, phrase
            verb, kind = data["self"]
            if kind == "avoid":
                return True, _avoid_self(data["emoji"])
            return True, _warm_self(verb, data["emoji"])

        if token == "kill":
            if target:
                method = random.choice(KILL_METHODS)
                return True, f"Вы «убили» {target}: {method} 🔪😅"
            return True, "Никого не нашлось под руку — все спасены! 🔪😅"

        if token in ("love", "recognise"):
            if not target:
                return True, "Формат: .love <имя>"
            return True, random.choice(LOVE_TEMPLATES).format(t=target)

        if token == "marry":
            if not target:
                return True, "Формат: .marry <имя>"
            return True, f"💍 Вы сделали предложение {target}! Совет да любовь! 💍👰🤵"

        if token == "divorce":
            if not target:
                return True, "Формат: .divorce <имя>"
            return True, f"💔 Вы развелись с {target}. Бывает и так..."

        if token == "stare":
            if target:
                return True, random.choice(STARE_TEMPLATES).format(t=target)
            return True, "Вы засмотрелись в зеркало на себя 👀✨"

        if token == "facepalm":
            return True, random.choice(FACEPALM_PHRASES)

        if token in ("compliment", "com"):
            if target:
                return True, f"Эй, {target}, {random.choice(COMPLIMENTS)} 💐"
            return True, f"Вы сделали комплимент себе: {random.choice(COMPLIMENTS)} 💐"

        if token == "rate":
            who = target if target else "вас"
            percent = _percent_for(target.lower() if target else "себя")
            return True, f"⭐ Оценка «{who}»: {percent}/100\n{_bar(percent)}\n{_rate_comment(percent)}"

        if token == "ship":
            names: List[str] = []
            if " и " in target:
                names = [p.strip() for p in target.split(" и ", 1)]
            elif "+" in target:
                names = [p.strip() for p in target.split("+", 1)]
            else:
                parts = target.split()
                if len(parts) >= 2:
                    names = [parts[0], " ".join(parts[1:])]
            names = [n for n in names if n]
            if len(names) < 2:
                return True, "Формат: .ship Имя1 Имя2"
            name1, name2 = names[0], names[1]
            percent = _percent_for((name1 + name2).lower())
            return True, f"💘 Совместимость {name1} и {name2}: {percent}%\n{_bar(percent)}\n{_rate_comment(percent)}"

        return False, ""


# ---------------------------------------------------------------------------
# 4. Сам плагин
# ---------------------------------------------------------------------------

class XitGramFontsPlugin(XitGramFontsPlugin_FunMixin, BasePlugin):

    def on_plugin_load(self):
        self.menu_item_id = None
        self.info_menu_item_id = None
        self.fun_menu_item_id = None

        if HAS_MENU_API:
            try:
                menu_type = getattr(MenuItemType, "CHAT_ACTION_MENU", None) \
                    or getattr(MenuItemType, "DRAWER_MENU", None)
                if menu_type is not None:
                    self.menu_item_id = self.add_menu_item(
                        MenuItemData(
                            menu_type=menu_type,
                            text="Шрифт XitGram",
                            on_click=self.open_font_picker,
                            icon="msg_text",
                            subtext="Сменить стиль текста",
                            priority=50,
                        )
                    )
                    self.fun_menu_item_id = self.add_menu_item(
                        MenuItemData(
                            menu_type=menu_type,
                            text="Развлечения XitGram",
                            on_click=self.open_fun_dialog,
                            icon="msg_emoji",
                            subtext="Обнять, поцеловать, оценить и т.д.",
                            priority=45,
                        )
                    )
                    self.info_menu_item_id = self.add_menu_item(
                        MenuItemData(
                            menu_type=menu_type,
                            text="О плагине XitGram",
                            on_click=self.show_info_dialog,
                            icon="msg_info",
                            subtext=CREATOR_CHANNEL,
                            priority=40,
                        )
                    )
            except Exception as e:
                try:
                    self.log(f"XitGram Fonts: меню недоступно в этой версии ({e}), работаю через команды .xf/.info")
                except Exception:
                    pass

        try:
            self.add_on_send_message_hook()
        except Exception as e:
            try:
                self.log(f"XitGram Fonts: не удалось подключить хук отправки сообщений: {e}")
            except Exception:
                pass

    def on_plugin_unload(self):
        for item_id in (getattr(self, "menu_item_id", None), getattr(self, "fun_menu_item_id", None),
                        getattr(self, "info_menu_item_id", None)):
            if item_id:
                try:
                    self.remove_menu_item(item_id)
                except Exception:
                    pass

    # --- UI: диалог выбора шрифта ------------------------------------------

    def open_font_picker(self, context: Dict[str, Any] = None):
        if not (HAS_ALERT_UI and get_last_fragment):
            _notify(self, "Меню недоступно в этой версии. Используйте команду .xf list в чате.")
            return

        fragment = get_last_fragment()
        if not fragment:
            return
        activity = fragment.getParentActivity()
        if not activity:
            return

        labels = [f"{_preview(f)}   —   {f['name']}" for f in FONTS]
        labels.append("Обычный текст (выключить шрифт)")

        builder = AlertDialogBuilder(activity)
        builder.set_title("XitGram — выбор шрифта")

        def on_pick(bld, which):
            if which == len(FONTS):
                self.set_setting("active_font", "", reload_settings=True)
                _notify(self, "Обычный текст включён")
            else:
                font = FONTS[which]
                self.set_setting("active_font", font["id"], reload_settings=True)
                _notify(self, f"Шрифт «{font['name']}»{_cyr_note(font['cyr'])} включён")
            bld.dismiss()

        builder.set_items(labels, on_pick)
        builder.set_negative_button("Отмена", lambda b, w: b.dismiss())
        builder.show()

    def show_info_dialog(self, context: Dict[str, Any] = None):
        if not (HAS_ALERT_UI and get_last_fragment):
            _notify(self, self._info_text())
            return
        fragment = get_last_fragment()
        if not fragment:
            return
        activity = fragment.getParentActivity()
        if not activity:
            return
        builder = AlertDialogBuilder(activity)
        builder.set_title(f"ℹ️ {__name__}")
        builder.set_message(self._info_text())
        builder.set_positive_button("OK", lambda b, w: b.dismiss())
        builder.show()

    def open_fun_dialog(self, context: Dict[str, Any] = None):
        if not (HAS_ALERT_UI and get_last_fragment):
            _notify(self, self._fun_list_text())
            return
        fragment = get_last_fragment()
        if not fragment:
            return
        activity = fragment.getParentActivity()
        if not activity:
            return
        builder = AlertDialogBuilder(activity)
        builder.set_title("🎉 Развлечения XitGram")
        builder.set_message(self._fun_list_text())
        builder.set_positive_button("OK", lambda b, w: b.dismiss())
        builder.show()

    # --- Команды в чате -------------------------------------------------------

    def _info_text(self) -> str:
        return (
            f"XitGram Fonts v{__version__}\n"
            f"Автор: {CREATOR_CHANNEL}\n"
            f"Стилей доступно: {len(FONTS)}\n"
            f"Развлекательных команд: {len(FUN_COMMAND_HELP)}\n\n"
            "Смена шрифта сообщений: юникод-начертания, эффекты для кириллицы "
            "и мемные преобразования текста. Плюс развлекательные команды в "
            "стиле Iris — обнять, поцеловать, оценить и т.д.\n\n"
            "Команды:\n"
            ".info — эта справка\n"
            ".xf list — список всех стилей\n"
            ".xf on <номер> — включить стиль насовсем\n"
            ".xf off — обычный текст\n"
            ".xf rand <текст> — случайный стиль\n"
            ".xf <номер> <текст> — разово применить стиль\n"
            ".xf ping — проверить отклик плагина\n"
            ".fun — список развлекательных команд\n\n"
            f"По вопросам и предложениям — {CREATOR_CHANNEL}"
        )

    def _help_text(self) -> str:
        return (
            "🎨 XitGram Fonts — команды\n\n"
            ".xf list — список стилей с номерами\n"
            ".xf on <номер> — включить стиль насовсем\n"
            ".xf off — вернуть обычный текст\n"
            ".xf rand <текст> — отправить случайным стилем\n"
            ".xf <номер> <текст> — отправить конкретным стилем\n"
            ".xf ping — проверить отклик плагина\n"
            ".fun — список развлекательных команд (.hug, .kiss, .rate...)\n"
            ".info — информация о плагине и авторе"
        )

    def _font_list_text(self) -> str:
        lines = [f"🎨 Стили XitGram Fonts ({len(FONTS)}):"]
        for i, f in enumerate(FONTS, start=1):
            lines.append(f"{i}. {f['name']}{_cyr_note(f['cyr'])}")
        lines.append("")
        lines.append("Использование: .xf on <номер> | .xf off | .xf rand <текст> | .xf <номер> <текст>")
        return "\n".join(lines)

    def _resolve_font(self, token: str) -> Any:
        token = token.strip()
        if token.isdigit():
            idx = int(token) - 1
            if 0 <= idx < len(FONTS):
                return FONTS[idx]
            return None
        return FONTS_BY_ID.get(token)

    def _handle_command(self, message: str) -> Tuple[bool, str]:
        """Возвращает (обработано_как_команда, новый_текст_или_пусто)."""
        body = message.strip()
        low = body.lower()

        if low == ".info" or low.startswith(".info "):
            return True, self._info_text()

        fun_handled, fun_text = self._handle_fun_command(body)
        if fun_handled:
            return True, fun_text

        if not low.startswith(".xf"):
            return False, ""

        rest = body[3:].strip()
        parts = rest.split(None, 1)
        if not parts:
            return True, self._help_text()

        sub = parts[0].lower()
        arg = parts[1] if len(parts) > 1 else ""

        if sub in ("list", "help"):
            return True, self._font_list_text() if sub == "list" else self._help_text()

        if sub == "off":
            self.set_setting("active_font", "")
            _notify(self, "Обычный текст включён")
            return True, ""

        if sub == "on":
            font = self._resolve_font(arg.strip())
            if not font:
                return True, "Не нашёл такой стиль. Наберите .xf list, чтобы увидеть номера."
            self.set_setting("active_font", font["id"])
            _notify(self, f"Шрифт «{font['name']}» включён насовсем")
            return True, ""

        if sub == "rand":
            if not arg:
                return True, "Формат: .xf rand текст"
            font = random.choice(FONTS)
            return True, font["fn"](arg)

        if sub == "ping":
            start = time.perf_counter()
            _ = _table_transform(BOLD)("ping test")
            elapsed_ms = (time.perf_counter() - start) * 1000
            return True, f"🏓 Понг! Плагин отвечает за {elapsed_ms:.2f} мс"

        # .xf <номер или id> <текст>
        num_part, _, text_part = rest.partition(" ")
        font = self._resolve_font(num_part)
        if font and text_part:
            return True, font["fn"](text_part)

        return True, self._help_text()

    # --- Хук исходящих сообщений --------------------------------------------

    def on_send_message_hook(self, account: int, params: Any) -> HookResult:
        result = HookResult()
        if not (hasattr(params, "message") and isinstance(params.message, str) and params.message):
            return result

        handled, new_text = self._handle_command(params.message)
        if handled:
            if not new_text:
                return HookResult(strategy=HookStrategy.CANCEL)
            params.message = new_text
            return HookResult(strategy=HookStrategy.MODIFY, params=params)

        font_id = self.get_setting("active_font", "")
        if font_id:
            font = FONTS_BY_ID.get(font_id)
            if font:
                params.message = font["fn"](params.message)
                result.strategy = HookStrategy.MODIFY
                result.params = params
                if not self.get_setting("sticky_mode", True):
                    self.set_setting("active_font", "")
        return result

    # --- Настройки плагина ---------------------------------------------------

    def create_settings(self) -> List[Any]:
        if not HAS_SETTINGS_UI:
            return []

        active_id = self.get_setting("active_font", "")
        active_name = next((f["name"] for f in FONTS if f["id"] == active_id), "Обычный текст")

        items: List[Any] = [
            Header(text=f"XitGram Fonts v{__version__}"),
            Text(text=f"Автор: {CREATOR_CHANNEL}", subtext="Написать по вопросам и предложениям", icon="msg_info"),
        ]

        if HAS_ALERT_UI and get_last_fragment:
            items.append(
                Text(
                    text="Открыть выбор шрифта",
                    subtext=f"Сейчас активен: {active_name}",
                    icon="msg_text",
                    on_click=lambda view: self.open_font_picker(),
                )
            )
        else:
            items.append(Text(
                text=f"Сейчас активен: {active_name}",
                subtext="Меняйте через команду .xf list в чате — меню недоступно в этой версии",
            ))

        items.append(
            Switch(
                key="sticky_mode",
                text="Применять ко всем сообщениям",
                subtext="Выключите, чтобы шрифт применился только к одному следующему сообщению",
                default=True,
            )
        )
        items.append(Divider(
            text=f"{len(FONTS)} стилей: гибридные RU+EN начертания, эффекты для кириллицы "
                 "и мемные преобразования текста. Полный список — .xf list, справка — .info"
        ))

        items.append(Header(text="Развлекательные команды"))
        if HAS_ALERT_UI and get_last_fragment:
            items.append(
                Text(
                    text="Список команд (.hug, .kiss, .rate...)",
                    subtext=f"Всего доступно: {len(FUN_COMMAND_HELP)}",
                    icon="msg_emoji",
                    on_click=lambda view: self.open_fun_dialog(),
                )
            )
        items.append(
            Switch(
                key="fun_enabled",
                text="Включить развлекательные команды",
                subtext="Обнять, поцеловать, оценить, ship и другие — см. .fun в чате",
                default=True,
            )
        )
        items.append(Divider(
            text="Команды вроде .kill или .slap — это безобидная шутка без "
                 "реального насилия. Полный список — команда .fun в чате."
        ))
        return items
