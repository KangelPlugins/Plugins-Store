            ),
        ]

    def _install(self) -> None:
        photo_viewer = _to_class(find_class("org.telegram.ui.PhotoViewer"))
        if photo_viewer is None:
            self.log("PhotoViewer class not found")
            return

        index_hook = _IndexHook(self)
        for signature in (
            (Integer.TYPE,),
            (Integer.TYPE, Boolean.TYPE, Boolean.TYPE),
            (Integer.TYPE, Boolean.TYPE, Boolean.TYPE, Boolean.TYPE),
        ):
            try:
                method = photo_viewer.getDeclaredMethod("setImageIndex", *signature)
                method.setAccessible(True)
                ref = self.hook_method(method, index_hook)
                if ref is not None:
                    self._hooks.append(ref)
            except Exception:
                pass

        try:
            close_method = photo_viewer.getDeclaredMethod("closePhoto", Boolean.TYPE, Boolean.TYPE)
            close_method.setAccessible(True)
            ref = self.hook_method(close_method, _CloseHook(self))
            if ref is not None:
                self._hooks.append(ref)
        except Exception:
            pass

        try:
            canvas_class = _to_class(find_class("android.graphics.Canvas"))
            if canvas_class is None:
                self.log("Canvas class not found")
                return
            draw_method = photo_viewer.getDeclaredMethod("onDraw", canvas_class)
            draw_method.setAccessible(True)
            ref = self.hook_method(draw_method, _DrawHook(self), priority=100)
            if ref is not None:
                self._hooks.append(ref)
        except Exception as error:
            self.log(f"onDraw hook failed: {error}")

        try:
            methods = photo_viewer.getDeclaredMethods()
            for index in range(int(len(methods))):
                method = methods[index]
                method_name = str(method.getName())
                if method_name not in ("createVideoTextureView", "preparePlayer"):
                    continue
                method.setAccessible(True)
                hook = _TextureHook(self) if method_name == "createVideoTextureView" else _PrepareHook(self)
                ref = self.hook_method(method, hook)
                if ref is not None:
                    self._hooks.append(ref)
        except Exception:
            pass

    def force_texture(self, viewer: Any) -> None:
        if viewer is None:
            return
        try:
            set_private_field(viewer, "ALLOW_USE_SURFACE", Boolean.FALSE)
        except Exception:
            pass

    def schedule(self, viewer: Any) -> None:
        if self._disposed:
            return
        if not self.get_setting(SETTING_ENABLED, True):
            self.clear(viewer)
            return

        is_video = self._should_poll(viewer)
        apply_photo = self.get_setting(SETTING_APPLY_PHOTO, True)
        apply_video = self.get_setting(SETTING_APPLY_VIDEO, True)
        if (is_video and not apply_video) or (not is_video and not apply_photo):
            self.clear(viewer)
            return

        key = _key(viewer)
        if key == 0:
            return
        with self._lock:
            generation = self._jobs.get(key, 0) + 1
            self._jobs[key] = generation

        viewer_ref = WeakReference(viewer)
        for delay in (40, 260, 850, 1500):
            run_on_ui_thread(lambda r=viewer_ref, g=generation: self._capture_ref(r, g), delay)
        run_on_ui_thread(lambda r=viewer_ref: self._poll_ref(r, self._video_delay_ms()), MIN_VIDEO_DELAY_MS)

    def _capture_ref(self, viewer_ref: Any, generation: int) -> None:
        if self._disposed:
            return
        try:
            viewer = viewer_ref.get()
        except Exception:
            viewer = None
        if viewer is not None:
            self._capture(viewer, generation)

    def _capture(self, viewer: Any, generation: int) -> None:
        if self._disposed:
            return
        key = _key(viewer)
        with self._lock:
            if self._jobs.get(key) != generation:
                return
            if self._capture_pending.get(key):
                return
            self._capture_pending[key] = True

        if not self.get_setting(SETTING_ENABLED, True):
            with self._lock:
                self._capture_pending.pop(key, None)
            self.clear(viewer)
            return

        is_video = self._should_poll(viewer)
        apply_photo = self.get_setting(SETTING_APPLY_PHOTO, True)
        apply_video = self.get_setting(SETTING_APPLY_VIDEO, True)
        if (is_video and not apply_video) or (not is_video and not apply_photo):
            with self._lock:
                self._capture_pending.pop(key, None)
            self.clear(viewer)
            return

        if self._container(viewer) is None:
            with self._lock:
                self._capture_pending.pop(key, None)
            return

        source = self._grab_source(viewer)
        if source is None:
            with self._lock:
                self._capture_pending.pop(key, None)
            if self._should_poll(viewer):
                self.poll_video(viewer, self._video_delay_ms())
            return

        if self._should_poll(viewer):
            signature = f"video:{generation}"
        else:
            signature = self._signature(source)
        with self._lock:
            if self._last_signature.get(key) == signature:
                self._capture_pending.pop(key, None)
                self._pool_bitmap(source)
                return
            self._last_signature[key] = signature

        viewer_ref = WeakReference(viewer)
        radius = self._radius()
        run_on_queue(lambda: self._blur_async(viewer_ref, key, generation, source, radius), PLUGINS_QUEUE)

    def _blur_async(self, viewer_ref: Any, key: int, generation: int, bitmap: Any, blur_radius: int) -> None:
        try:
            if self._disposed:
                self._pool_bitmap(bitmap)
                return
            dimming = self._dimming_alpha()
            result = _make_glow(bitmap, blur_radius, dimming)
            if result is None:
                with self._lock:
                    self._capture_pending.pop(key, None)
                return
            run_on_ui_thread(lambda r=viewer_ref, b=result: self._apply_ref(r, key, generation, b))
        except Exception:
            with self._lock:
                self._capture_pending.pop(key, None)
            pass

    def _apply_ref(self, viewer_ref: Any, key: int, generation: int, bitmap: Any) -> None:
        if self._disposed:
            with self._lock:
                self._capture_pending.pop(key, None)
            self._pool_bitmap(bitmap)
            return
        try:
            viewer = viewer_ref.get()
        except Exception:
            viewer = None
        if viewer is None:
            with self._lock:
                self._capture_pending.pop(key, None)
            self._pool_bitmap(bitmap)
            return
        self._apply(viewer, key, generation, bitmap)

    def _apply(self, viewer: Any, key: int, generation: int, bitmap: Any) -> None:
        if self._disposed:
            self._pool_bitmap(bitmap)
            return
        with self._lock:
            self._capture_pending.pop(key, None)
            if self._jobs.get(key) != generation:
                self._pool_bitmap(bitmap)
                return

        try:
            old = None
            recycle_after = []
            is_video = self._should_poll(viewer)
            with self._lock:
                old = self._bitmaps.get(key)
                if old is not None and is_video:
                    old_previous = self._previous_bitmaps.pop(key, None)
                    previous = old
                    if old_previous is not None:
                        if self._use_video_crossfade():
                            started_at = self._fade_started_at.get(key)
                            if started_at is not None:
                                linear = (time.monotonic() - started_at) / self._video_fade()
                                mixed = _blend_glows(old_previous, old, _ease_in_out(linear), self._get_bitmap_from_pool)
                                if mixed is not None:
                                    previous = mixed
                                    recycle_after.append(old)
                        recycle_after.append(old_previous)

                    target = _blend_glows(previous, bitmap, self._video_blend_alpha(), self._get_bitmap_from_pool)
                    if target is not None:
                        self._bitmaps[key] = target
                        recycle_after.append(bitmap)
                    else:
                        self._bitmaps[key] = bitmap
                    if self._use_video_crossfade():
                        self._previous_bitmaps[key] = previous
                        self._fade_started_at[key] = time.monotonic()
                    else:
                        recycle_after.append(previous)
                        self._fade_started_at.pop(key, None)
                        previous = None
                else:
                    self._bitmaps[key] = bitmap
                if old is not None and not is_video:
                    previous = old
                    old_previous = self._previous_bitmaps.pop(key, None)
                    started_at = self._fade_started_at.get(key)
                    if old_previous is not None and started_at is not None:
                        duration = self._fade(viewer)
                        linear = (time.monotonic() - started_at) / duration
                        mixed = _blend_glows(old_previous, old, _ease_in_out(linear), self._get_bitmap_from_pool)
                        if mixed is not None:
                            previous = mixed
                            recycle_after.append(old)
                        recycle_after.append(old_previous)
                    elif old_previous is not None:
                        recycle_after.append(old_previous)
                    self._previous_bitmaps[key] = previous
                    self._fade_started_at[key] = time.monotonic()
                elif old is None:
                    previous = self._previous_bitmaps.pop(key, None)
                    if previous is not None:
                        self._previous_bitmaps[key] = previous
                    self._fade_started_at[key] = time.monotonic()
                active_bitmap = self._bitmaps.get(key)
            for item in recycle_after:
                if item is not None and item is not active_bitmap and item is not previous:
                    self._pool_bitmap(item)
            target = self._container(viewer) or self._window(viewer)
            if target is not None:
                target.invalidate()
            if self._should_poll(viewer):
                self.poll_video(viewer, self._video_delay_ms())
        except Exception:
            pass

    def clear(self, viewer: Any) -> None:
        key = _key(viewer)
        with self._lock:
            bitmap = self._bitmaps.pop(key, None)
            previous = self._previous_bitmaps.pop(key, None)
            self._fade_started_at.pop(key, None)
            self._last_signature.pop(key, None)
            self._poll_pending.pop(key, None)
            self._capture_pending.pop(key, None)
            self._jobs.pop(key, None)
        for item in (bitmap, previous):
            self._pool_bitmap(item)

    def draw(self, viewer: Any, canvas: Any) -> None:
        if self._disposed:
            return
        if not self.get_setting(SETTING_ENABLED, True):
            return

        is_video = self._should_poll(viewer)
        apply_photo = self.get_setting(SETTING_APPLY_PHOTO, True)
        apply_video = self.get_setting(SETTING_APPLY_VIDEO, True)
        if (is_video and not apply_video) or (not is_video and not apply_photo):
            return

        key = _key(viewer)
        with self._lock:
            bitmap = self._bitmaps.get(key)
            previous = self._previous_bitmaps.get(key)
            started_at = self._fade_started_at.get(key)
        if bitmap is None:
            return
        try:
            progress = 1.0
            if started_at is not None:
                duration = self._fade(viewer)
                progress = _ease_in_out((time.monotonic() - started_at) / duration)
            canvas_w = int(canvas.getWidth())
            canvas_h = int(canvas.getHeight())
            if canvas_w <= 0 or canvas_h <= 0:
                return
            base_alpha = self._alpha()
            if previous is not None and progress < 1.0:
                self._draw_cover(canvas, previous, canvas_w, canvas_h, base_alpha * (1.0 - progress))
            self._draw_cover(canvas, bitmap, canvas_w, canvas_h, base_alpha * progress)
            if started_at is not None:
                target = self._container(viewer) or self._window(viewer)
                if progress >= 1.0:
                    with self._lock:
                        if self._fade_started_at.get(key) == started_at:
                            old_previous = self._previous_bitmaps.pop(key, None)
                            self._fade_started_at.pop(key, None)
                        else:
                            old_previous = None
                    if old_previous is not None:
                        self._pool_bitmap(old_previous)
                elif target is not None:
                    target.invalidate()
        except Exception:
            pass

    def _draw_cover(self, canvas: Any, bitmap: Any, canvas_w: int, canvas_h: int, alpha: float) -> None:
        bitmap_w = int(bitmap.getWidth())
        bitmap_h = int(bitmap.getHeight())
        if bitmap_w <= 0 or bitmap_h <= 0 or alpha <= 0:
            return
        scale = max(float(canvas_w) / float(bitmap_w), float(canvas_h) / float(bitmap_h))
        zoom = self._zoom_multiplier()
        scale *= zoom
        draw_w = bitmap_w * scale
        draw_h = bitmap_h * scale
        left = (canvas_w - draw_w) / 2.0
        top = (canvas_h - draw_h) / 2.0
        paint = self._draw_paint
        if paint is None:
            paint = Paint()
            self._draw_paint = paint
        paint.setAntiAlias(True)
        paint.setFilterBitmap(True)
        paint.setAlpha(max(0, min(255, int(255 * alpha))))
        
        saturation = self._saturation_multiplier()
        if saturation != 1.0:
            matrix = ColorMatrix()
            matrix.setSaturation(saturation)
            paint.setColorFilter(ColorMatrixColorFilter(matrix))
        else:
            paint.setColorFilter(None)

        src = self._draw_src_rect
        if src is None:
            src = Rect()
            self._draw_src_rect = src
        src.set(0, 0, bitmap_w, bitmap_h)
        dst = self._draw_dst_rect
        if dst is None:
            dst = RectF()
            self._draw_dst_rect = dst
        dst.set(float(left), float(top), float(left + draw_w), float(top + draw_h))
        canvas.drawBitmap(bitmap, src, dst, paint)

    def poll_video(self, viewer: Any, delay_ms: int = 450) -> None:
        if self._disposed:
            return
        if not self.get_setting(SETTING_ENABLED, True):
            return
        is_video = self._should_poll(viewer)
        apply_video = self.get_setting(SETTING_APPLY_VIDEO, True)
        if is_video and not apply_video:
            return
        if not is_video:
            return
        key = _key(viewer)
        if key == 0:
            return
        with self._lock:
            if self._poll_pending.get(key):
                return
            self._poll_pending[key] = True
        viewer_ref = WeakReference(viewer)
        run_on_ui_thread(lambda r=viewer_ref, k=key: self._run_poll(r, k), max(MIN_VIDEO_DELAY_MS, int(delay_ms)))

    def _poll_ref(self, viewer_ref: Any, delay_ms: int) -> None:
        if self._disposed:
            return
        try:
            viewer = viewer_ref.get()
        except Exception:
            viewer = None
        if viewer is not None:
            self.poll_video(viewer, delay_ms)

    def _run_poll(self, viewer_ref: Any, key: int) -> None:
        with self._lock:
            self._poll_pending.pop(key, None)
        if self._disposed:
            return
        try:
            viewer = viewer_ref.get()
        except Exception:
            viewer = None
        if viewer is None:
            return
        if not self.get_setting(SETTING_ENABLED, True):
            return
        if not self._should_poll(viewer):
            return
        retry_delay = None
        with self._lock:
            if self._capture_pending.get(key):
                retry_delay = self._video_delay_ms()
            else:
                generation = self._jobs.get(key, 0) + 1
                self._jobs[key] = generation
        if retry_delay is not None:
            self.poll_video(viewer, retry_delay)
            return
        self._capture(viewer, generation)

    def _grab_source(self, viewer: Any) -> Optional[Any]:
        bitmap = self._grab_video(viewer)
        if bitmap is not None:
            return bitmap
        if self._should_poll(viewer):
            return None
        return self._grab_image(viewer)

    def _grab_video(self, viewer: Any) -> Optional[Any]:
        try:
            texture_view = self._texture_view(viewer)
            if texture_view is None or not self._view_ready(texture_view):
                return None
            width = int(texture_view.getWidth())
            height = int(texture_view.getHeight())
            
            max_side = self._glow_resolution()
            scale = min(1.0, float(max_side) / float(max(width, height)))
            target_w = max(16, int(width * scale))
            target_h = max(16, int(height * scale))
            
            return texture_view.getBitmap(target_w, target_h)
        except Exception:
            return None

    def _video_visible(self, viewer: Any) -> bool:
        try:
            return self._view_ready(self._texture_view(viewer))
        except Exception:
            return False

    def _should_poll(self, viewer: Any) -> bool:
        if self._video_visible(viewer):
            return True
        return self._video_active(viewer)

    def _texture_view(self, viewer: Any) -> Optional[Any]:
        for field_name in ("changedTextureView", "videoTextureView"):
            try:
                texture_view = get_private_field(viewer, field_name)
                if self._view_ready(texture_view):
                    return texture_view
            except Exception:
                pass
        try:
            texture_view = viewer.getVideoTextureView()
            if self._view_ready(texture_view):
                return texture_view
        except Exception:
            pass
        return None

    def _video_active(self, viewer: Any) -> bool:
        for field_name in ("isCurrentVideo", "videoSizeSet", "textureUploaded"):
            try:
                if not bool(get_private_field(viewer, field_name)):
                    return False
            except Exception:
                pass
        try:
            layout = get_private_field(viewer, "aspectRatioFrameLayout")
            if layout is not None and layout.getVisibility() != View.VISIBLE:
                return False
        except Exception:
            pass
        return True

    def _view_ready(self, view: Any) -> bool:
        if view is None:
            return False
        try:
            if int(view.getWidth()) <= 0 or int(view.getHeight()) <= 0:
                return False
        except Exception:
            return False
        try:
            if view.getVisibility() == View.VISIBLE:
                return True
        except Exception:
            pass
        try:
            return bool(view.isAvailable())
        except Exception:
            return False

    def _grab_image(self, viewer: Any) -> Optional[Any]:
        try:
            image = get_private_field(viewer, "centerImage")
            if image is None:
                return None
            bitmap = None
            for method_name in ("getBitmap", "getBitmapSafe"):
                try:
                    candidate = getattr(image, method_name)()
                    if candidate is not None:
                        bitmap = candidate
                        break
                except Exception:
                    continue
            return _copy_bitmap(bitmap, self._glow_resolution())
        except Exception:
            return None

    def _window(self, viewer: Any) -> Optional[Any]:
        if viewer is None:
            return None
        try:
            window_view = getattr(viewer, "windowView", None)
            if window_view is not None:
                return window_view
        except Exception:
            pass
        try:
            return get_private_field(viewer, "windowView")
        except Exception:
            return None

    def _container(self, viewer: Any) -> Optional[Any]:
        if viewer is None:
            return None
        try:
            container_view = getattr(viewer, "containerView", None)
            if container_view is not None:
                return container_view
        except Exception:
            pass
        try:
            return get_private_field(viewer, "containerView")
        except Exception:
            return None

    def _refresh(self) -> None:
        if self._disposed:
            return
        viewer = self._viewer()
        if viewer is not None:
            key = _key(viewer)
            with self._lock:
                self._last_signature.pop(key, None)
                self._poll_pending.pop(key, None)
            self.schedule(viewer)

    def _clear_current(self) -> None:
        viewer = self._viewer()
        if viewer is not None:
            self.clear(viewer)

    def _viewer(self) -> Optional[Any]:
        try:
            photo_viewer = _to_class(find_class("org.telegram.ui.PhotoViewer"))
            if photo_viewer is None:
                return None
            method = photo_viewer.getDeclaredMethod("getInstance")
            method.setAccessible(True)
            return method.invoke(None)
        except Exception:
            return None

    def _drop_bitmaps(self) -> None:
        with self._lock:
            bitmaps = list(self._bitmaps.values()) + list(self._previous_bitmaps.values()) + list(self._bitmap_pool)
            self._bitmaps.clear()
            self._previous_bitmaps.clear()
            self._bitmap_pool.clear()
            self._fade_started_at.clear()
        for bitmap in bitmaps:
            self._pool_bitmap(bitmap)

    def _signature(self, bitmap: Any) -> str:
        try:
            width = int(bitmap.getWidth())
            height = int(bitmap.getHeight())
            points = [
                (width // 2, height // 2),
                (max(0, width // 6), max(0, height // 6)),
                (max(0, width - width // 6 - 1), max(0, height // 6)),
                (max(0, width // 6), max(0, height - height // 6 - 1)),
                (max(0, width - width // 6 - 1), max(0, height - height // 6 - 1)),
            ]
            colors = []
            for x, y in points:
                try:
                    colors.append(str(bitmap.getPixel(x, y)))
                except Exception:
                    colors.append("0")
            return f"{width}x{height}:{':'.join(colors)}"
        except Exception:
            return str(id(bitmap))

    def _alpha(self) -> float:
        index = _as_int(self.get_setting(SETTING_STRENGTH, DEFAULT_STRENGTH), DEFAULT_STRENGTH)
        return [0.42, 0.62, 0.82][max(0, min(index, 2))]

    def _radius(self) -> int:
        index = _as_int(self.get_setting(SETTING_BLUR, DEFAULT_BLUR), DEFAULT_BLUR)
        return [22, 36, 52][max(0, min(index, 2))]

    def _glow_resolution(self) -> int:
        index = _as_int(self.get_setting(SETTING_GLOW_RESOLUTION, DEFAULT_RESOLUTION), DEFAULT_RESOLUTION)
        return [64, 128, 256, 420][max(0, min(index, 3))]

    def _saturation_multiplier(self) -> float:
        index = _as_int(self.get_setting(SETTING_SATURATION, DEFAULT_SATURATION), DEFAULT_SATURATION)
        return [1.0, 1.35, 1.75][max(0, min(index, 2))]

    def _zoom_multiplier(self) -> float:
        index = _as_int(self.get_setting(SETTING_ZOOM, DEFAULT_ZOOM), DEFAULT_ZOOM)
        return [1.0, 1.1, 1.25][max(0, min(index, 2))]

    def _dimming_alpha(self) -> int:
        index = _as_int(self.get_setting(SETTING_DIMMING, DEFAULT_DIMMING), DEFAULT_DIMMING)
        return [40, 72, 110][max(0, min(index, 2))]

    def _fade(self, viewer: Any = None) -> float:
        index = _as_int(self.get_setting(SETTING_TRANSITION, DEFAULT_TRANSITION), DEFAULT_TRANSITION)
        duration = [0.18, 0.35, 0.65][max(0, min(index, 2))]
        if viewer is not None and self._should_poll(viewer):
            return self._video_fade()
        return duration

    def _video_delay_ms(self) -> int:
        value = _as_int(self.get_setting(SETTING_VIDEO_DELAY, DEFAULT_VIDEO_DELAY_MS), DEFAULT_VIDEO_DELAY_MS)
        return max(MIN_VIDEO_DELAY_MS, value)

    def _video_blend_alpha(self) -> float:
        delay = float(self._video_delay_ms())
        if self._use_video_crossfade():
            return max(0.16, min(0.34, delay / 900.0))
        return max(0.08, min(0.22, delay / 640.0))

    def _video_fade(self) -> float:
        delay = float(self._video_delay_ms()) / 1000.0
        return max(0.10, min(0.28, delay * 1.6))

    def _use_video_crossfade(self) -> bool:
        return self._video_delay_ms() >= VIDEO_CROSSFADE_MIN_MS
