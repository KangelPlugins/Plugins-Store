VIDEO_CROSSFADE_MIN_MS = 120


def _as_int(value: Any, default: int = 0) -> int:
    try:
        return int(value)
    except Exception:
        return default


def _key(viewer: Any) -> int:
    try:
        return int(viewer.hashCode())
    except Exception:
        try:
            return id(viewer)
        except Exception:
            return 0


def _to_class(value: Any) -> Optional[Any]:
    if value is None:
        return None
    try:
        if hasattr(value, "getDeclaredMethod"):
            return value
    except Exception:
        pass
    try:
        return value.getClass()
    except Exception:
        return None


def _copy_bitmap(bitmap: Any, max_side: int = 420) -> Optional[Any]:
    if bitmap is None:
        return None
    try:
        width = int(bitmap.getWidth())
        height = int(bitmap.getHeight())
        if width <= 0 or height <= 0:
            return None

        scale = min(1.0, float(max_side) / float(max(width, height)))
        target_w = max(16, int(width * scale))
        target_h = max(16, int(height * scale))

        if target_w != width or target_h != height:
            result = Bitmap.createScaledBitmap(bitmap, target_w, target_h, True)
        else:
            result = bitmap.copy(Bitmap.Config.ARGB_8888, True)

        if result is not None and (result.getConfig() != Bitmap.Config.ARGB_8888 or not result.isMutable()):
            mutable = result.copy(Bitmap.Config.ARGB_8888, True)
            try:
                result.recycle()
            except Exception:
                pass
            result = mutable
        return result
    except Exception:
        return None


def _make_glow(bitmap: Any, blur_radius: int, dimming_alpha: int = 72) -> Optional[Any]:
    if bitmap is None:
        return None
    try:
        width = int(bitmap.getWidth())
        height = int(bitmap.getHeight())
        if width <= 0 or height <= 0:
            return None

        canvas = Canvas(bitmap)
        paint = Paint()
        paint.setColor(Color.argb(max(0, min(255, dimming_alpha)), 0, 0, 0))
        canvas.drawRect(0.0, 0.0, float(width), float(height), paint)

        Utilities.stackBlurBitmap(bitmap, max(1, min(blur_radius, 60)))
        return bitmap
    except Exception:
        try:
            bitmap.recycle()
        except Exception:
            pass
        return None


def _ease_in_out(value: float) -> float:
    value = max(0.0, min(1.0, value))
    return value * value * (3.0 - 2.0 * value)


def _blend_glows(previous: Any, current: Any, current_alpha: float, pool_provider: Any = None) -> Optional[Any]:
    if previous is None or current is None:
        return None
    result = None
    try:
        width = int(current.getWidth())
        height = int(current.getHeight())
        if width <= 0 or height <= 0:
            return None

        if pool_provider is not None:
            result = pool_provider(width, height)
        if result is None:
            result = Bitmap.createBitmap(width, height, Bitmap.Config.ARGB_8888)
            
        canvas = Canvas(result)
        canvas.drawColor(0, PorterDuff.Mode.CLEAR)
        paint = Paint()
        paint.setAntiAlias(True)
        paint.setFilterBitmap(True)

        previous_w = int(previous.getWidth())
        previous_h = int(previous.getHeight())
        if previous_w > 0 and previous_h > 0:
            scale = max(float(width) / float(previous_w), float(height) / float(previous_h))
            draw_w = previous_w * scale
            draw_h = previous_h * scale
            left = (width - draw_w) / 2.0
            top = (height - draw_h) / 2.0
            src = Rect(0, 0, previous_w, previous_h)
            dst = RectF(float(left), float(top), float(left + draw_w), float(top + draw_h))
            paint.setAlpha(max(0, min(255, int(255 * (1.0 - current_alpha)))))
            canvas.drawBitmap(previous, src, dst, paint)

        paint.setAlpha(max(0, min(255, int(255 * current_alpha))))
        canvas.drawBitmap(current, 0.0, 0.0, paint)
        return result
    except Exception:
        try:
            if result is not None:
                result.recycle()
        except Exception:
            pass
        return None


class _IndexHook(MethodHook):
    def __init__(self, plugin: "MediaGlowPlugin") -> None:
        self.plugin = plugin

    def before_hooked_method(self, param: Any) -> None:
        try:
            self.plugin.force_texture(param.thisObject)
        except Exception:
            pass

    def after_hooked_method(self, param: Any) -> None:
        try:
            self.plugin.schedule(param.thisObject)
        except Exception:
            pass


class _CloseHook(MethodHook):
    def __init__(self, plugin: "MediaGlowPlugin") -> None:
        self.plugin = plugin

    def before_hooked_method(self, param: Any) -> None:
        try:
            self.plugin.clear(param.thisObject)
        except Exception:
            pass


class _DrawHook(MethodHook):
    def __init__(self, plugin: "MediaGlowPlugin") -> None:
        self.plugin = plugin

    def before_hooked_method(self, param: Any) -> None:
        try:
            if param.args is None or len(param.args) < 1:
                return
            self.plugin.draw(param.thisObject, param.args[0])
        except Exception:
            pass


class _TextureHook(MethodHook):
    def __init__(self, plugin: "MediaGlowPlugin") -> None:
        self.plugin = plugin

    def before_hooked_method(self, param: Any) -> None:
        try:
            self.plugin.force_texture(param.thisObject)
        except Exception:
            pass

    def after_hooked_method(self, param: Any) -> None:
        try:
            self.plugin.poll_video(param.thisObject, self.plugin._video_delay_ms())
        except Exception:
            pass


class _PrepareHook(MethodHook):
    def __init__(self, plugin: "MediaGlowPlugin") -> None:
        self.plugin = plugin

    def before_hooked_method(self, param: Any) -> None:
        try:
            self.plugin.force_texture(param.thisObject)
        except Exception:
            pass

    def after_hooked_method(self, param: Any) -> None:
        try:
            self.plugin.schedule(param.thisObject)
            self.plugin.poll_video(param.thisObject, self.plugin._video_delay_ms())
        except Exception:
            pass


class MediaGlowPlugin(BasePlugin):
    def __init__(self) -> None:
        super().__init__()
        self._hooks: List[Any] = []
        self._jobs: Dict[int, int] = {}
        self._bitmaps: Dict[int, Any] = {}
        self._previous_bitmaps: Dict[int, Any] = {}
        self._bitmap_pool: List[Any] = []
        self._fade_started_at: Dict[int, float] = {}
        self._last_signature: Dict[int, str] = {}
        self._poll_pending: Dict[int, bool] = {}
        self._capture_pending: Dict[int, bool] = {}
        self._disposed = False
        self._draw_paint: Optional[Any] = None
        self._draw_src_rect: Optional[Any] = None
        self._draw_dst_rect: Optional[Any] = None
        self._lock = threading.RLock()

    def _pool_bitmap(self, bitmap: Any) -> None:
        if bitmap is None:
            return
        try:
            if not bitmap.isMutable() or bitmap.isRecycled():
                bitmap.recycle()
                return
            with self._lock:
                if len(self._bitmap_pool) < 4:
                    self._bitmap_pool.append(bitmap)
                    return
            bitmap.recycle()
        except Exception:
            try:
                bitmap.recycle()
            except Exception:
                pass

    def _get_bitmap_from_pool(self, width: int, height: int) -> Optional[Any]:
        with self._lock:
            for i in range(len(self._bitmap_pool) - 1, -1, -1):
                bmp = self._bitmap_pool[i]
                try:
                    if int(bmp.getWidth()) == width and int(bmp.getHeight()) == height:
                        return self._bitmap_pool.pop(i)
                    if bmp.isRecycled():
                        self._bitmap_pool.pop(i)
                except Exception:
                    self._bitmap_pool.pop(i)
        return None

    def on_plugin_load(self) -> None:
        self._disposed = False
        self._install()

    def on_plugin_unload(self) -> None:
        self._disposed = True
        for ref in list(self._hooks):
            try:
                self.unhook_method(ref)
            except Exception:
                pass
        self._hooks = []
        self._jobs = {}
        self._last_signature = {}
        self._poll_pending = {}
        self._capture_pending = {}
        self._drop_bitmaps()
        self._draw_paint = None
        self._draw_src_rect = None
        self._draw_dst_rect = None
        run_on_ui_thread(self._clear_current)

