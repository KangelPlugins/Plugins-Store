    def _prepare_plugin_temp_dir(self) -> Optional[str]:
        try:
            base_dir = ApplicationLoader.getFilesDirFixed()
            if not base_dir:
                return None

            temp_folder = File(base_dir, "FileEditorTemp")
            if not temp_folder.exists():
                temp_folder.mkdirs()

            for old_file in temp_folder.listFiles():
                try:
                    old_file.delete()
                except Exception:
                    pass

            return temp_folder.getAbsolutePath()
        except Exception as e:
            self._show_error_dialog_with_copy(
                self.get_string("error_temp_dir_create"),
                f"{self.get_string('error_temp_dir_create')}: {e}\n{traceback.format_exc()}"
            )
            return None

    def _ensure_defaults(self):
        for key, value in DEFAULT_PLUGIN_SETTINGS.items():
            try:
                current = self.get_setting(key, None)
                if current is None:
                    self.set_setting(key, value)
            except Exception:
                pass

    def _get_font_size_label(self, index: int) -> str:
        labels = [self.get_string("small"), self.get_string("medium"), self.get_string("large"), self.get_string("x_large")]
        try:
            return labels[int(index)]
        except Exception:
            return labels[1]

    def _get_default_encoding_name(self) -> str:
        value = self.get_setting("default_encoding_name", DEFAULT_PLUGIN_SETTINGS["default_encoding_name"])
        if value in ENCODING_OPTIONS:
            return value
        try:
            idx = int(value)
            if 0 <= idx < len(ENCODING_OPTIONS):
                return ENCODING_OPTIONS[idx]
        except Exception:
            pass
        return DEFAULT_PLUGIN_SETTINGS["default_encoding_name"]

    def _get_default_encoding_index(self) -> int:
        name = self._get_default_encoding_name()
        try:
            return ENCODING_OPTIONS.index(name)
        except Exception:
            return 0

    def _get_editor_font_size_index(self) -> int:
        try:
            idx = int(self.get_setting("editor_font_size", DEFAULT_PLUGIN_SETTINGS["editor_font_size"]))
        except Exception:
            idx = DEFAULT_PLUGIN_SETTINGS["editor_font_size"]
        return max(0, min(idx, 3))

    def _normalize_dp_setting_value(self, value: Any, default_key: str) -> str:
        fallback = str(DEFAULT_PLUGIN_SETTINGS.get(default_key, "0"))
        raw_value = value if value is not None else fallback
        raw_text = str(raw_value).strip().replace(",", ".")
        if not raw_text:
            raw_text = fallback
        try:
            dp_value = int(float(raw_text))
        except Exception:
            try:
                dp_value = int(float(fallback))
            except Exception:
                dp_value = 0
        dp_value = max(0, min(dp_value, 160))
        return str(dp_value)

    def _get_overlay_inset_dp(self, key: str) -> int:
        try:
            return int(self._normalize_dp_setting_value(self.get_setting(key, DEFAULT_PLUGIN_SETTINGS.get(key, "0")), key))
        except Exception:
            return 0

    def _get_overlay_top_inset_dp(self) -> int:
        return self._get_overlay_inset_dp("overlay_top_inset_dp")

    def _get_overlay_bottom_inset_dp(self) -> int:
        return self._get_overlay_inset_dp("overlay_bottom_inset_dp")

    def _get_max_open_file_bytes(self) -> int:
        try:
            mb = float(str(self.get_setting("max_open_file_mb", DEFAULT_PLUGIN_SETTINGS["max_open_file_mb"])).replace(",", "."))
        except Exception:
            mb = 3.0
        mb = max(0.25, min(mb, 25.0))
        return int(mb * 1024 * 1024)

    def _mime_looks_text(self, mime_type: str) -> bool:
        mime = (mime_type or "").lower()
        return any(part in mime for part in TEXTISH_MIME_PARTS)

    def _matches_text_file_name(self, file_name: str) -> bool:
        if not file_name:
            return False
        lowered = file_name.lower()
        if lowered in TEXT_FILE_NAMES:
            return True
        return os.path.splitext(lowered)[1] in TEXT_FILE_EXTENSIONS

    def _is_likely_text_bytes(self, raw: bytes) -> bool:
        if not raw:
            return True
        sample = raw[:8192]
        if b"\x00" in sample:
            return False
        suspicious = 0
        allowed_controls = {9, 10, 13}
        for b in sample:
            if b < 32 and b not in allowed_controls:
                suspicious += 1
        return suspicious <= max(2, len(sample) // 80)

    def _decode_bytes_with_preferences(self, raw: bytes):
        tried = []
        preferred = self._get_default_encoding_name()
        for enc in [preferred] + [e for e in ENCODING_OPTIONS if e != preferred]:
            try:
                return raw.decode(enc.lower()), enc
            except Exception:
                tried.append(enc)
        raise UnicodeDecodeError("text", b"", 0, 1, "all supported decoders failed: " + ", ".join(tried))

    def _can_open_text_file(self, file_path: str, file_name: str, mime_type: str) -> bool:
        if self._matches_text_file_name(file_name) or self._mime_looks_text(mime_type):
            return True
        if not self.get_setting("allow_unknown_text_files", DEFAULT_PLUGIN_SETTINGS["allow_unknown_text_files"]):
            return False
        try:
            if os.path.getsize(file_path) > self._get_max_open_file_bytes():
                return False
            with open(file_path, "rb") as f:
                raw = f.read(8192)
            return self._is_likely_text_bytes(raw)
        except Exception:
            return False

    def _get_supported_extensions_text(self) -> str:
        ordered = sorted(TEXT_FILE_EXTENSIONS)
        return ", ".join(ordered[:80]) + (" ..." if len(ordered) > 80 else "")

    def _get_supported_extensions_summary(self) -> str:
        count = len(TEXT_FILE_EXTENSIONS)
        is_ru = LocaleController.getInstance().getCurrentLocale().getLanguage().startswith("ru")
        return f"{count} форматов" if is_ru else f"{count} formats"

    def on_send_message_hook(self, account: int, params: Any) -> HookResult:
        if not self.get_setting("enable_file_editor", True):
            return HookResult()

        command_prefix = self.get_setting("command_prefix", ".openfile").lower()
        new_file_command_prefix = self.get_setting("cmd_new_file", ".newfile").lower()
        message_text = params.message.strip()
        lower_text = message_text.lower()

        if lower_text in (f"{command_prefix} settings", f"{command_prefix} config"):
            run_on_ui_thread(self._show_plugin_settings_overlay)
            return HookResult(strategy=HookStrategy.CANCEL)

        if lower_text.startswith(new_file_command_prefix):
            filename_arg = message_text[len(new_file_command_prefix):].strip()
            if not filename_arg:
                run_on_ui_thread(lambda: BulletinHelper.show_error(self.get_string("error_invalid_filename")))
                return HookResult(strategy=HookStrategy.CANCEL)

            if not re.fullmatch(r"[\w\.\-]+", filename_arg):
                run_on_ui_thread(lambda: BulletinHelper.show_error(self.get_string("error_invalid_filename")))
                return HookResult(strategy=HookStrategy.CANCEL)

            pg_peer_id = params.peer
            self.pg_current_dialog_id = pg_peer_id

            run_on_queue(lambda: self._create_new_file_and_open_editor(filename_arg, pg_peer_id))
            return HookResult(strategy=HookStrategy.CANCEL)

        elif lower_text.startswith(command_prefix):
            if not hasattr(params, 'replyToMsg') or not params.replyToMsg:
                run_on_ui_thread(lambda: BulletinHelper.show_error(self.get_string("error_cmd_reply_needed")))
                return HookResult(strategy=HookStrategy.CANCEL)

            replied_message: MessageObject = params.replyToMsg

            if not replied_message.isDocument():
                run_on_ui_thread(lambda: BulletinHelper.show_error(self.get_string("error_not_document")))
                return HookResult(strategy=HookStrategy.CANCEL)

            document: TLRPC.Document = replied_message.getDocument()
            if not document:
                run_on_ui_thread(lambda: BulletinHelper.show_error(self.get_string("error_doc_info_failed")))
                return HookResult(strategy=HookStrategy.CANCEL)

            file_name = getattr(document, 'file_name_fixed', None) or "file.txt"
            file_extension = os.path.splitext(file_name)[1].lower()

            pg_file_loader = FileLoader.getInstance(account)
            file_path_obj = pg_file_loader.getPathToMessage(replied_message.messageOwner)

            if not file_path_obj or not os.path.exists(file_path_obj.toString()):
                run_on_ui_thread(lambda: BulletinHelper.show_error(self.get_string("error_file_not_on_device")))
                return HookResult(strategy=HookStrategy.CANCEL)

            file_path = file_path_obj.toString()
            mime_type = getattr(document, 'mime_type', '')
            if not self._can_open_text_file(file_path, file_name, mime_type):
                run_on_ui_thread(lambda: BulletinHelper.show_error(self.get_string("error_unsupported_type").format(ext=file_extension or file_name)))
                return HookResult(strategy=HookStrategy.CANCEL)

            pg_peer_id = params.peer
            pg_reply_to_msg_id = replied_message.messageOwner.id if replied_message.messageOwner else 0
            pg_original_file_name = file_name

            self.pg_current_dialog_id = pg_peer_id

            run_on_queue(lambda: self._read_and_show_file(file_path, pg_peer_id, pg_reply_to_msg_id, pg_original_file_name, replied_message))

            return HookResult(strategy=HookStrategy.CANCEL)

        return HookResult()

    def _create_new_file_and_open_editor(self, filename: str, peer_id: int):
        if not self.pg_temp_dir:
            run_on_ui_thread(lambda: BulletinHelper.show_error(self.get_string("error_temp_dir_create")))
            return

        temp_new_file_path = os.path.join(self.pg_temp_dir, f"new_{uuid.uuid4()}_{filename}")

        try:
            with open(temp_new_file_path, 'w', encoding='utf-8') as f:
                f.write("")

            run_on_ui_thread(lambda: BulletinHelper.show_info(self.get_string("info_creating_new_file").format(file_name=filename)))
            run_on_ui_thread(lambda: self._show_file_editor_dialog(
                "",
                temp_new_file_path,
                peer_id,
                0,
                filename,
                None,
                self.get_string("default_encoding"),
                is_new_file=True
            ))

        except Exception as e:
            run_on_ui_thread(lambda: self._show_error_dialog_with_copy(
                self.get_string("error_file_creation_failed").format(error=type(e).__name__),
                f"{self.get_string('error_file_creation_failed').format(error=e)}\n{traceback.format_exc()}"
            ))

    def _read_and_show_file(self, file_path: str, peer_id: int, reply_to_msg_id: int, original_file_name: str, original_message_object: MessageObject):
        run_on_ui_thread(lambda: BulletinHelper.show_info(self.get_string("info_loading_file")))
        file_content: Optional[str] = None
        current_encoding: str = self._get_default_encoding_name()

        try:
            with open(file_path, 'rb') as f:
                raw_content = f.read()
            file_content, current_encoding = self._decode_bytes_with_preferences(raw_content)

        except Exception as e:
            run_on_ui_thread(lambda: self._show_error_dialog_with_copy(
                self.get_string("error_file_read").format(error=type(e).__name__),
                f"{self.get_string('error_file_read').format(error=e)}\n{traceback.format_exc()}"
            ))
            return

        if file_content is None:
            return

        run_on_ui_thread(lambda: self._show_file_editor_dialog(
            file_content,
            file_path,
            peer_id,
            reply_to_msg_id,
            original_file_name,
            original_message_object,
            current_encoding,
            is_new_file=False
        ))

    def _make_click_listener(self, fn):
        class _L(dynamic_proxy(View.OnClickListener)):
            def onClick(self, v):
                try:
                    fn()
                except Exception as e:
                    log(f"[FileEditor] Click error: {e}")
        return _L()

    def _show_plugin_settings_overlay(self):
        try:
            fragment = get_last_fragment()
            if not fragment:
                return
            activity = fragment.getParentActivity()
            if not activity:
                return

            self._close_settings_overlay()

            root = FrameLayout(activity)
            root.setLayoutParams(FrameLayout.LayoutParams(
                ViewGroup.LayoutParams.MATCH_PARENT,
                ViewGroup.LayoutParams.MATCH_PARENT
            ))
            if Theme:
                try:
                    root.setBackgroundColor(Theme.getColor(Theme.key_windowBackgroundWhite))
                except Exception:
                    root.setBackgroundColor(Color.parseColor("#1E1E1E"))
            else:
                root.setBackgroundColor(Color.parseColor("#1E1E1E"))
            is_ru = LocaleController.getInstance().getCurrentLocale().getLanguage().startswith("ru")
            overlay_top_inset_dp = self._get_overlay_top_inset_dp()
            overlay_bottom_inset_dp = self._get_overlay_bottom_inset_dp()

            container = LinearLayout(activity)
            container.setOrientation(LinearLayout.VERTICAL)
            container.setLayoutParams(FrameLayout.LayoutParams(
                ViewGroup.LayoutParams.MATCH_PARENT,
                ViewGroup.LayoutParams.MATCH_PARENT
            ))
            container.setPadding(
                0,
                AndroidUtilities.dp(overlay_top_inset_dp),
                0,
                AndroidUtilities.dp(overlay_bottom_inset_dp)
            )

            title_bar = LinearLayout(activity)
            title_bar.setOrientation(LinearLayout.HORIZONTAL)
            title_bar.setGravity(Gravity.CENTER_VERTICAL)
            title_bar.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(12), AndroidUtilities.dp(10), AndroidUtilities.dp(12))
            if Theme:
                try:
                    bg = _GradientDrawable()
                    bg.setColor(Theme.getColor(Theme.key_actionBarDefault))
                    title_bar.setBackground(bg)
                except Exception:
                    pass

            title_wrap = LinearLayout(activity)
            title_wrap.setOrientation(LinearLayout.VERTICAL)

            title_tv = TextView(activity)
            title_tv.setText(self.get_string("plugin_settings"))
            title_tv.setTypeface(Typeface.DEFAULT_BOLD)
            title_tv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 17)
            if Theme:
                try:
                    title_tv.setTextColor(Theme.getColor(Theme.key_actionBarDefaultTitle))
                except Exception:
                    title_tv.setTextColor(Color.WHITE)
            else:
                title_tv.setTextColor(Color.WHITE)
            title_wrap.addView(title_tv)

            subtitle_tv = TextView(activity)
            subtitle_tv.setText("Команды, редактор и отправка" if is_ru else "Commands, editor and sending")
            subtitle_tv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
            if Theme:
                try:
                    subtitle_tv.setTextColor(Theme.getColor(Theme.key_actionBarDefaultSubtitle))
                except Exception:
                    subtitle_tv.setTextColor(Color.parseColor("#CCFFFFFF"))
            else:
                subtitle_tv.setTextColor(Color.parseColor("#CCFFFFFF"))
            title_wrap.addView(subtitle_tv)
            title_bar.addView(title_wrap, LinearLayout.LayoutParams(0, ViewGroup.LayoutParams.WRAP_CONTENT, 1.0))

            close_btn = self._create_control_button(activity, "✕")
            close_btn.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 18)
            if Theme:
                try:
                    close_btn.setTextColor(Theme.getColor(Theme.key_actionBarDefaultTitle))
                except Exception:
                    pass

            scroll = ScrollView(activity)
            scroll.setLayoutParams(LinearLayout.LayoutParams(
                ViewGroup.LayoutParams.MATCH_PARENT, 0, 1.0
            ))
            list_layout = LinearLayout(activity)
            list_layout.setOrientation(LinearLayout.VERTICAL)
            list_layout.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(14), AndroidUtilities.dp(12), AndroidUtilities.dp(24))
            scroll.addView(list_layout)

            rows = []
            current_section = {"card": None, "count": 0}

            def _dismiss():
                self._close_settings_overlay()

            def _card_bg(fill_color):
                bg = _GradientDrawable()
                bg.setCornerRadius(AndroidUtilities.dp(18))
                bg.setColor(fill_color)
                return bg

            def _resolve_color(theme_key, fallback):
                if Theme:
                    try:
                        return Theme.getColor(theme_key)
                    except Exception:
                        return fallback
                return fallback

            def _value_chip_bg():
                bg = _GradientDrawable()
                bg.setCornerRadius(AndroidUtilities.dp(999))
                bg.setColor(_resolve_color(getattr(Theme, "key_featuredStickers_addButton", 0), Color.parseColor("#4E2E40")))
                return bg

            def _section_separator(host):
                sep = View(activity)
                sep.setLayoutParams(LinearLayout.LayoutParams(
                    ViewGroup.LayoutParams.MATCH_PARENT, AndroidUtilities.dp(1)
                ))
                sep.setBackgroundColor(_resolve_color(getattr(Theme, "key_divider", 0), Color.parseColor("#22FFFFFF")))
                host.addView(sep)

            def _hero_card():
                hero = LinearLayout(activity)
                hero.setOrientation(LinearLayout.VERTICAL)
                hero.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(16), AndroidUtilities.dp(16), AndroidUtilities.dp(16))
                hero.setBackground(_card_bg(_resolve_color(getattr(Theme, "key_dialogBackground", 0), Color.parseColor("#2A1F27"))))
                lp = LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.WRAP_CONTENT)
                lp.bottomMargin = AndroidUtilities.dp(14)
                hero.setLayoutParams(lp)

                hero_title = TextView(activity)
                hero_title.setText("Быстрые настройки редактора" if is_ru else "Quick editor settings")
                hero_title.setTypeface(Typeface.DEFAULT_BOLD)
                hero_title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 16)
                hero_title.setTextColor(_resolve_color(getattr(Theme, "key_windowBackgroundWhiteBlackText", 0), Color.WHITE))
                hero.addView(hero_title)

                hero_sub = TextView(activity)
                hero_sub.setText(
                    "Здесь можно быстро настроить команды, внешний вид редактора и поведение отправки."
                    if is_ru else
                    "Adjust commands, editor look and sending behavior from one place."
                )
                hero_sub.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 13)
                hero_sub.setTextColor(_resolve_color(getattr(Theme, "key_windowBackgroundWhiteGrayText", 0), Color.parseColor("#C7C7C7")))
                hero_sub.setPadding(0, AndroidUtilities.dp(6), 0, AndroidUtilities.dp(10))
                hero.addView(hero_sub)

                hint_chip = TextView(activity)
                hint_chip.setText(".openfile settings")
                hint_chip.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
                hint_chip.setTypeface(Typeface.MONOSPACE, Typeface.BOLD)
                hint_chip.setTextColor(Color.WHITE)
                hint_chip.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(6), AndroidUtilities.dp(12), AndroidUtilities.dp(6))
                hint_chip.setBackground(_value_chip_bg())
                hero.addView(hint_chip)
                list_layout.addView(hero)

            def _start_section(title, subtitle=None):
                current_section["count"] = 0

                header_wrap = LinearLayout(activity)
                header_wrap.setOrientation(LinearLayout.VERTICAL)
                header_lp = LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.WRAP_CONTENT)
                header_lp.topMargin = AndroidUtilities.dp(2)
                header_lp.bottomMargin = AndroidUtilities.dp(8)
                header_wrap.setLayoutParams(header_lp)

                header_tv = TextView(activity)
                header_tv.setText(title)
                header_tv.setTypeface(Typeface.DEFAULT_BOLD)
                header_tv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
                header_tv.setTextColor(_resolve_color(getattr(Theme, "key_windowBackgroundWhiteBlackText", 0), Color.WHITE))
                header_wrap.addView(header_tv)

                if subtitle:
                    sub_tv = TextView(activity)
                    sub_tv.setText(subtitle)
                    sub_tv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
                    sub_tv.setTextColor(_resolve_color(getattr(Theme, "key_windowBackgroundWhiteGrayText", 0), Color.parseColor("#BDBDBD")))
                    sub_tv.setPadding(0, AndroidUtilities.dp(2), 0, 0)
                    header_wrap.addView(sub_tv)

                list_layout.addView(header_wrap)

                card = LinearLayout(activity)
                card.setOrientation(LinearLayout.VERTICAL)
                card.setBackground(_card_bg(_resolve_color(getattr(Theme, "key_dialogBackground", 0), Color.parseColor("#241A21"))))
                card_lp = LinearLayout.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.WRAP_CONTENT)
                card_lp.bottomMargin = AndroidUtilities.dp(14)
                card.setLayoutParams(card_lp)
                list_layout.addView(card)
                current_section["card"] = card

            def _show_choice_popup(title_text, items, on_pick):
                dim = FrameLayout(activity)
                dim.setBackgroundColor(Color.parseColor("#99000000"))
                dim.setLayoutParams(FrameLayout.LayoutParams(
                    ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.MATCH_PARENT
                ))

                card = LinearLayout(activity)
                card.setOrientation(LinearLayout.VERTICAL)
                card_bg = _GradientDrawable()
                card_bg.setCornerRadius(AndroidUtilities.dp(14))
                if Theme:
                    try:
                        card_bg.setColor(Theme.getColor(Theme.key_dialogBackground))
                    except Exception:
                        card_bg.setColor(Color.parseColor("#2B2B2B"))
                else:
                    card_bg.setColor(Color.parseColor("#2B2B2B"))
                card.setBackground(card_bg)
                card.setPadding(0, AndroidUtilities.dp(8), 0, AndroidUtilities.dp(8))
                card_lp = FrameLayout.LayoutParams(
                    ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.WRAP_CONTENT
                )
                card_lp.gravity = Gravity.CENTER
                card_lp.setMargins(AndroidUtilities.dp(28), 0, AndroidUtilities.dp(28), 0)
                card.setLayoutParams(card_lp)

                header_tv = TextView(activity)
                header_tv.setText(title_text)
                header_tv.setTypeface(Typeface.DEFAULT_BOLD)
                header_tv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
                header_tv.setGravity(Gravity.CENTER)
                if Theme:
                    try:
                        header_tv.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
                    except Exception:
                        header_tv.setTextColor(Color.WHITE)
                else:
                    header_tv.setTextColor(Color.WHITE)
                header_tv.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(12), AndroidUtilities.dp(16), AndroidUtilities.dp(12))
                card.addView(header_tv)

                def _close():
                    try:
                        root.removeView(dim)
                    except Exception:
                        pass

                for idx, item in enumerate(items):
                    row = TextView(activity)
                    row.setText(item)
                    row.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
                    row.setPadding(AndroidUtilities.dp(18), AndroidUtilities.dp(14), AndroidUtilities.dp(18), AndroidUtilities.dp(14))
                    if Theme:
                        try:
                            row.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
                            row.setBackground(Theme.createSelectorDrawable(Theme.getColor(Theme.key_listSelector), 1))
                        except Exception:
                            row.setTextColor(Color.WHITE)
                    else:
                        row.setTextColor(Color.WHITE)
                    row.setOnClickListener(self._make_click_listener(lambda i=idx: (_close(), on_pick(i))))
                    card.addView(row)

                cancel_row = TextView(activity)
                cancel_row.setText(self.get_string("cancel"))
                cancel_row.setGravity(Gravity.CENTER)
                cancel_row.setPadding(AndroidUtilities.dp(18), AndroidUtilities.dp(14), AndroidUtilities.dp(18), AndroidUtilities.dp(14))
                if Theme:
                    try:
                        cancel_row.setTextColor(Theme.getColor(Theme.key_dialogTextLink))
                        cancel_row.setBackground(Theme.createSelectorDrawable(Theme.getColor(Theme.key_listSelector), 1))
                    except Exception:
                        cancel_row.setTextColor(Color.parseColor("#4DAAFF"))
                else:
                    cancel_row.setTextColor(Color.parseColor("#4DAAFF"))
                cancel_row.setOnClickListener(self._make_click_listener(_close))
                card.addView(cancel_row)

                dim.addView(card)
                dim.setOnClickListener(self._make_click_listener(_close))
                card.setOnClickListener(self._make_click_listener(lambda: None))
                card.setClickable(True)
                root.addView(dim)

            def _show_input_popup(title_text, initial_text, on_submit):
                dim = FrameLayout(activity)
                dim.setBackgroundColor(Color.parseColor("#99000000"))
                dim.setLayoutParams(FrameLayout.LayoutParams(
                    ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.MATCH_PARENT
                ))

                card = LinearLayout(activity)
                card.setOrientation(LinearLayout.VERTICAL)
                card_bg = _GradientDrawable()
                card_bg.setCornerRadius(AndroidUtilities.dp(14))
                if Theme:
                    try:
                        card_bg.setColor(Theme.getColor(Theme.key_dialogBackground))
                    except Exception:
                        card_bg.setColor(Color.parseColor("#2B2B2B"))
                else:
                    card_bg.setColor(Color.parseColor("#2B2B2B"))
                card.setBackground(card_bg)
                card.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(16), AndroidUtilities.dp(16), AndroidUtilities.dp(16))
                card_lp = FrameLayout.LayoutParams(
                    ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.WRAP_CONTENT
                )
                card_lp.gravity = Gravity.CENTER
                card_lp.setMargins(AndroidUtilities.dp(28), 0, AndroidUtilities.dp(28), 0)
                card.setLayoutParams(card_lp)

                header_tv = TextView(activity)
                header_tv.setText(title_text)
                header_tv.setTypeface(Typeface.DEFAULT_BOLD)
                header_tv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
                if Theme:
                    try:
                        header_tv.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
                    except Exception:
                        header_tv.setTextColor(Color.WHITE)
                else:
                    header_tv.setTextColor(Color.WHITE)
                card.addView(header_tv)

                input_cls = EditTextBoldCursor if EditTextBoldCursor else find_class("android.widget.EditText")
                input_field = input_cls(activity)
                input_field.setSingleLine(True)
                input_field.setInputType(InputType.TYPE_CLASS_TEXT)
                input_field.setText(str(initial_text))
                try:
                    input_field.setSelection(len(str(initial_text)))
                except Exception:
                    pass
                card.addView(input_field, LinearLayout.LayoutParams(
                    ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.WRAP_CONTENT
                ))

                buttons = LinearLayout(activity)
                buttons.setOrientation(LinearLayout.HORIZONTAL)
                buttons.setPadding(0, AndroidUtilities.dp(12), 0, 0)

                def _close():
                    try:
                        root.removeView(dim)
                    except Exception:
                        pass

                cancel_btn = self._create_control_button(activity, self.get_string("cancel"))
                cancel_btn.setOnClickListener(self._make_click_listener(_close))
                buttons.addView(cancel_btn, LinearLayout.LayoutParams(0, ViewGroup.LayoutParams.WRAP_CONTENT, 1.0))
                self._add_spacer(buttons, AndroidUtilities.dp(6))

                ok_btn = self._create_primary_button(activity, self.get_string("ok"))
                ok_btn.setOnClickListener(self._make_click_listener(lambda: (_close(), on_submit(input_field.getText().toString().strip()))))
                buttons.addView(ok_btn, LinearLayout.LayoutParams(0, ViewGroup.LayoutParams.WRAP_CONTENT, 1.0))
                card.addView(buttons)

                dim.addView(card)
                dim.setOnClickListener(self._make_click_listener(_close))
                card.setOnClickListener(self._make_click_listener(lambda: None))
                card.setClickable(True)
                root.addView(dim)

            def _bool_label(value):
                return "Вкл" if value and is_ru else ("Выкл" if is_ru else ("On" if value else "Off"))

            def _add_row(title, value_getter, on_click, subtext=None, accent=False):
                host = current_section["card"] or list_layout
                if current_section["count"] > 0:
                    _section_separator(host)

                row = LinearLayout(activity)
                row.setOrientation(LinearLayout.HORIZONTAL)
                row.setGravity(Gravity.CENTER_VERTICAL)
                row.setPadding(AndroidUtilities.dp(14), AndroidUtilities.dp(14), AndroidUtilities.dp(14), AndroidUtilities.dp(14))
                if Theme:
                    try:
                        row.setBackground(Theme.createSelectorDrawable(Theme.getColor(Theme.key_listSelector), AndroidUtilities.dp(14)))
                    except Exception:
                        pass

                left = LinearLayout(activity)
                left.setOrientation(LinearLayout.VERTICAL)

                title_tv = TextView(activity)
                title_tv.setText(title)
                title_tv.setTypeface(Typeface.DEFAULT_BOLD)
                title_tv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
                title_tv.setTextColor(_resolve_color(getattr(Theme, "key_windowBackgroundWhiteBlackText", 0), Color.WHITE))
                if accent:
                    title_tv.setTextColor(Color.parseColor("#4DAAFF"))
                left.addView(title_tv)

                if subtext:
                    sub_tv = TextView(activity)
                    sub_tv.setText(subtext)
                    sub_tv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
                    sub_tv.setTextColor(_resolve_color(getattr(Theme, "key_windowBackgroundWhiteGrayText", 0), Color.parseColor("#BDBDBD")))
                    sub_tv.setPadding(0, AndroidUtilities.dp(4), 0, 0)
                    left.addView(sub_tv)

                value_tv = TextView(activity)
                value_tv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
                value_tv.setTypeface(Typeface.DEFAULT_BOLD)
                value_tv.setTextColor(Color.WHITE)
                value_tv.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(6), AndroidUtilities.dp(12), AndroidUtilities.dp(6))
                value_tv.setBackground(_value_chip_bg())

                chevron_tv = TextView(activity)
                chevron_tv.setText("›")
                chevron_tv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 18)
                chevron_tv.setTextColor(_resolve_color(getattr(Theme, "key_windowBackgroundWhiteGrayText", 0), Color.parseColor("#9E9E9E")))
                chevron_tv.setPadding(AndroidUtilities.dp(10), 0, 0, 0)

                row.addView(left, LinearLayout.LayoutParams(0, ViewGroup.LayoutParams.WRAP_CONTENT, 1.0))
                row.addView(value_tv)
                row.addView(chevron_tv)

                row.setOnClickListener(self._make_click_listener(on_click))
                host.addView(row)
                rows.append((value_tv, value_getter))
                current_section["count"] += 1

            def _save(key, value):
                self.set_setting(key, value)
                BulletinHelper.show_success(self.get_string("settings_saved"))
                _refresh()

            def _toggle(key, fallback):
                current = bool(self.get_setting(key, fallback))
                self.set_setting(key, not current)
                BulletinHelper.show_success(self.get_string("settings_saved"))
                _refresh()

            def _refresh():
                for value_tv, getter in rows:
                    try:
                        text_value = str(getter() or "")
                        value_tv.setText(text_value)
                        value_tv.setVisibility(View.GONE if not text_value.strip() else View.VISIBLE)
                    except Exception:
                        value_tv.setText("")
                        value_tv.setVisibility(View.GONE)

            _hero_card()
            _start_section(
                "Основное" if is_ru else "General",
                "Команды и базовое поведение плагина" if is_ru else "Commands and core plugin behavior"
            )
            _add_row(
                self.get_string("enable_plugin"),
                lambda: _bool_label(self.get_setting("enable_file_editor", True)),
                lambda: _toggle("enable_file_editor", True),
                self.get_string("enable_plugin_sub")
            )
            _add_row(
                self.get_string("cmd_prefix"),
                lambda: self.get_setting("command_prefix", DEFAULT_PLUGIN_SETTINGS["command_prefix"]),
                lambda: _show_input_popup(self.get_string("cmd_prefix"), self.get_setting("command_prefix", DEFAULT_PLUGIN_SETTINGS["command_prefix"]), lambda v: _save("command_prefix", v or DEFAULT_PLUGIN_SETTINGS["command_prefix"])),
                self.get_string("cmd_prefix_sub")
            )
            _add_row(
                self.get_string("cmd_new_file"),
                lambda: self.get_setting("cmd_new_file", DEFAULT_PLUGIN_SETTINGS["cmd_new_file"]),
                lambda: _show_input_popup(self.get_string("cmd_new_file"), self.get_setting("cmd_new_file", DEFAULT_PLUGIN_SETTINGS["cmd_new_file"]), lambda v: _save("cmd_new_file", v or DEFAULT_PLUGIN_SETTINGS["cmd_new_file"])),
                self.get_string("cmd_new_file_sub")
            )
            _start_section(
                "Редактор" if is_ru else "Editor",
                "Внешний вид и режим открытия файлов" if is_ru else "Appearance and file opening behavior"
            )
            _add_row(
                self.get_string("default_encoding_setting"),
                lambda: self._get_default_encoding_name(),
                lambda: _show_choice_popup(self.get_string("default_encoding_setting"), ENCODING_OPTIONS, lambda i: _save("default_encoding_name", ENCODING_OPTIONS[i])),
                self.get_string("select_encoding")
            )
            _add_row(
                self.get_string("font_size"),
                lambda: self._get_font_size_label(self._get_editor_font_size_index()),
                lambda: _show_choice_popup(self.get_string("font_size"), [self.get_string("small"), self.get_string("medium"), self.get_string("large"), self.get_string("x_large")], lambda i: _save("editor_font_size", i)),
                "Размер текста в редакторе" if is_ru else "Text size inside the editor"
            )
            _add_row(
                self.get_string("enable_syntax_highlighting"),
                lambda: _bool_label(self.get_setting("enable_syntax_highlighting", True)),
                lambda: _toggle("enable_syntax_highlighting", True),
                self.get_string("enable_syntax_highlighting_sub")
            )
            _add_row(
                self.get_string("line_numbers"),
                lambda: _bool_label(self.get_setting("show_line_numbers", True)),
                lambda: _toggle("show_line_numbers", True),
                self.get_string("line_numbers_sub")
            )
            _add_row(
                self.get_string("default_word_wrap"),
                lambda: _bool_label(self.get_setting("default_word_wrap", True)),
                lambda: _toggle("default_word_wrap", True),
                self.get_string("default_word_wrap_sub")
            )
            _add_row(
                self.get_string("default_read_only"),
                lambda: _bool_label(self.get_setting("default_read_only", False)),
                lambda: _toggle("default_read_only", False),
                "Открывать без возможности редактирования" if is_ru else "Open files without allowing edits"
            )
            _start_section(
                "Интерфейс" if is_ru else "Interface",
                "Защитные отступы от верхней шторки и нижней системной области" if is_ru else "Safe offsets from the top shade and the bottom system area"
            )
            _add_row(
                self.get_string("overlay_top_inset"),
                lambda: f"{self._get_overlay_top_inset_dp()} dp",
                lambda: _show_input_popup(
                    self.get_string("overlay_top_inset"),
                    self._normalize_dp_setting_value(self.get_setting("overlay_top_inset_dp", DEFAULT_PLUGIN_SETTINGS["overlay_top_inset_dp"]), "overlay_top_inset_dp"),
                    lambda v: _save("overlay_top_inset_dp", self._normalize_dp_setting_value(v, "overlay_top_inset_dp"))
                ),
                self.get_string("overlay_top_inset_sub")
            )
            _add_row(
                self.get_string("overlay_bottom_inset"),
                lambda: f"{self._get_overlay_bottom_inset_dp()} dp",
                lambda: _show_input_popup(
                    self.get_string("overlay_bottom_inset"),
                    self._normalize_dp_setting_value(self.get_setting("overlay_bottom_inset_dp", DEFAULT_PLUGIN_SETTINGS["overlay_bottom_inset_dp"]), "overlay_bottom_inset_dp"),
                    lambda v: _save("overlay_bottom_inset_dp", self._normalize_dp_setting_value(v, "overlay_bottom_inset_dp"))
                ),
                self.get_string("overlay_bottom_inset_sub")
            )
            _start_section(
                "Отправка" if is_ru else "Sending",
                "Что делать перед и после отправки файла" if is_ru else "What happens before and after sending"
            )
            _add_row(
                self.get_string("confirm_before_send"),
                lambda: _bool_label(self.get_setting("confirm_before_send", True)),
                lambda: _toggle("confirm_before_send", True),
                "Показывать подтверждение перед отправкой" if is_ru else "Ask for confirmation before sending"
            )
            _add_row(
                self.get_string("auto_close_after_send"),
                lambda: _bool_label(self.get_setting("auto_close_after_send", True)),
                lambda: _toggle("auto_close_after_send", True),
                self.get_string("auto_close_after_send_sub")
            )
            _add_row(
                self.get_string("trim_spaces_on_save"),
                lambda: _bool_label(self.get_setting("trim_trailing_spaces_on_save", False)),
                lambda: _toggle("trim_trailing_spaces_on_save", False),
                "Убирать пробелы и хвосты строк перед отправкой" if is_ru else "Trim line endings and trailing spaces before sending"
            )
            _start_section(
                "Совместимость" if is_ru else "Compatibility",
                "Редкие расширения и ограничения на размер" if is_ru else "Rare extensions and file size limits"
            )
            _add_row(
                self.get_string("allow_unknown_text_files"),
                lambda: _bool_label(self.get_setting("allow_unknown_text_files", True)),
                lambda: _toggle("allow_unknown_text_files", True),
                self.get_string("allow_unknown_text_files_sub")
            )
            _add_row(
                self.get_string("max_open_file_mb"),
                lambda: self.get_setting("max_open_file_mb", DEFAULT_PLUGIN_SETTINGS["max_open_file_mb"]),
                lambda: _show_input_popup(self.get_string("max_open_file_mb"), self.get_setting("max_open_file_mb", DEFAULT_PLUGIN_SETTINGS["max_open_file_mb"]), lambda v: _save("max_open_file_mb", v or DEFAULT_PLUGIN_SETTINGS["max_open_file_mb"])),
                "Лимит для открытия больших файлов" if is_ru else "Limit for opening large files"
            )
            _add_row(
                self.get_string("supported_extensions"),
                lambda: self._get_supported_extensions_summary(),
                lambda: self._show_error_dialog_with_copy(self.get_string("supported_extensions"), self._get_supported_extensions_text()),
                "Полный список расширений, которые умеет редактор" if is_ru else "Full list of supported extensions"
            )
            _start_section(
                "Сервис" if is_ru else "Maintenance",
                "Сброс и служебные действия" if is_ru else "Reset and maintenance actions"
            )
            _add_row(
                self.get_string("reset_defaults"),
                lambda: "",
                lambda: (self._reset_plugin_defaults(), BulletinHelper.show_success(self.get_string("settings_reset_done")), _refresh()),
                "Вернуть рекомендуемые параметры по умолчанию" if is_ru else "Restore the recommended default setup",
                accent=True
            )

            close_btn.setOnClickListener(self._make_click_listener(_dismiss))

            title_bar.addView(close_btn, LinearLayout.LayoutParams(AndroidUtilities.dp(44), AndroidUtilities.dp(44)))
            container.addView(title_bar)
            container.addView(scroll)
            root.addView(container)
            self._settings_overlay_view = root

            decor = activity.getWindow().getDecorView()
            decor.addView(root, FrameLayout.LayoutParams(
                ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.MATCH_PARENT
            ))
            _refresh()
        except Exception as e:
            self._show_error_dialog_with_copy(self.get_string("error_dialog_ui"), f"{e}\n{traceback.format_exc()}")

    def _reset_plugin_defaults(self):
        for key, value in DEFAULT_PLUGIN_SETTINGS.items():
            try:
                self.set_setting(key, value)
            except Exception:
                pass

    def _show_file_editor_dialog(self, content: str, file_path: str, peer_id: int, reply_to_msg_id: int, original_file_name: str, original_message_object: Optional[MessageObject], initial_encoding: str, is_new_file: bool = False):
        try:
            fragment = get_last_fragment()
            if not fragment:
                self._show_error_dialog_with_copy(self.get_string("error_dialog_ui"), "No fragment available.")
                return

            activity = fragment.getParentActivity()
            if not activity:
                self._show_error_dialog_with_copy(self.get_string("error_dialog_ui"), "No activity available.")
                return

            pg_current_encoding = initial_encoding
            pg_is_read_only = bool(self.get_setting("default_read_only", DEFAULT_PLUGIN_SETTINGS["default_read_only"]))
            word_wrap_enabled = {"value": bool(self.get_setting("default_word_wrap", True))}
            original_content_box = {"text": content}
            editor_dirty = {"modified": False}
            current_file_name_box = {"name": original_file_name}
            pg_current_font_size_index = self._get_editor_font_size_index()
            show_line_numbers = self.get_setting("show_line_numbers", True)
            overlay_top_inset_dp = self._get_overlay_top_inset_dp()
            overlay_bottom_inset_dp = self._get_overlay_bottom_inset_dp()

            font_sizes_dp = [12, 14, 16, 18]

            main_layout = LinearLayout(activity)
            main_layout.setOrientation(LinearLayout.VERTICAL)
            main_layout.setLayoutParams(ViewGroup.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.MATCH_PARENT))
            main_layout.setPadding(
                AndroidUtilities.dp(8),
                AndroidUtilities.dp(8 + overlay_top_inset_dp),
                AndroidUtilities.dp(8),
                AndroidUtilities.dp(8 + overlay_bottom_inset_dp)
            )

            pg_text_editor: Optional[Any] = None
            title_tv = None
            meta_tv = None
            if EditTextBoldCursor:
                pg_text_editor = EditTextBoldCursor(activity)
            else:
                pg_text_editor = TextView(activity)
                pg_text_editor.setTextIsSelectable(True)

            file_extension = os.path.splitext(current_file_name_box["name"])[1].lower()
            highlighted_content = self._apply_syntax_highlighting(content, file_extension, activity)
            pg_text_editor.setText(highlighted_content)

            pg_text_editor.setHint(self.get_string("edit_file"))
            pg_text_editor.setInputType(InputType.TYPE_CLASS_TEXT | InputType.TYPE_TEXT_FLAG_MULTI_LINE)
            pg_text_editor.setSingleLine(False)
            current_font_dp = font_sizes_dp[pg_current_font_size_index]
            pg_text_editor.setTextSize(TypedValue.COMPLEX_UNIT_DIP, current_font_dp)
            pg_text_editor.setTypeface(Typeface.MONOSPACE)
            pg_text_editor.setHorizontallyScrolling(not word_wrap_enabled["value"])
            if Theme:
                pg_text_editor.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
                pg_text_editor.setHintTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteHintText))
            else:
                pg_text_editor.setTextColor(Color.WHITE)
                pg_text_editor.setHintTextColor(Color.GRAY)

            pg_text_editor.setBackground(None)
            if EditTextBoldCursor and Theme:
                pg_text_editor.setCursorColor(Theme.getColor(Theme.key_dialogTextLink))
                pg_text_editor.setCursorWidth(1.5)
            pg_text_editor.setPadding(AndroidUtilities.dp(6), AndroidUtilities.dp(4), AndroidUtilities.dp(6), AndroidUtilities.dp(4))

            line_numbers_tv = TextView(activity)
            line_numbers_tv.setTypeface(Typeface.MONOSPACE)
            line_numbers_tv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, current_font_dp)
            if Theme:
                line_numbers_tv.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
            else:
                line_numbers_tv.setTextColor(Color.GRAY)
            line_numbers_tv.setGravity(Gravity.TOP | Gravity.END)
            line_numbers_tv.setPadding(AndroidUtilities.dp(4), AndroidUtilities.dp(4), AndroidUtilities.dp(8), AndroidUtilities.dp(4))
            line_numbers_tv.setBackground(None)

            def _build_line_numbers(text: str) -> str:
                count = text.count('\n') + 1
                return '\n'.join(str(i + 1) for i in range(count))

            def _update_editor_meta():
                try:
                    if meta_tv is None:
                        return
                    ext = os.path.splitext(current_file_name_box["name"])[1].lower() or "text"
                    mode = self.get_string('read_only_on') if pg_is_read_only else self.get_string('read_only_off')
                    wrap = self.get_string('word_wrap_on') if word_wrap_enabled["value"] else self.get_string('word_wrap_off')
                    dirty = f" • {self.get_string('modified_mark')}" if editor_dirty["modified"] else ""
                    meta_tv.setText(f"{ext} • {pg_current_encoding} • {mode} • {wrap}{dirty}")
                except Exception:
                    pass

            def _update_editor_title():
                try:
                    if title_tv is None:
                        return
                    prefix = "● " if editor_dirty["modified"] else ""
                    base = self.get_string("new_file_title").format(file_name=current_file_name_box["name"]) if is_new_file else current_file_name_box["name"]
                    title_tv.setText(prefix + base)
                    _update_editor_meta()
                except Exception:
                    pass

            line_numbers_tv.setText(_build_line_numbers(content))

            divider_line = TextView(activity)
            divider_lp = LinearLayout.LayoutParams(AndroidUtilities.dp(1), ViewGroup.LayoutParams.MATCH_PARENT)
            if Theme:
                divider_line.setBackgroundColor(Theme.getColor(Theme.key_divider))
            else:
                divider_line.setBackgroundColor(Color.DKGRAY)

            editor_row = LinearLayout(activity)
            editor_row.setOrientation(LinearLayout.HORIZONTAL)
            editor_row.setLayoutParams(ViewGroup.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.WRAP_CONTENT))

            if show_line_numbers:
                editor_row.addView(line_numbers_tv, LinearLayout.LayoutParams(ViewGroup.LayoutParams.WRAP_CONTENT, ViewGroup.LayoutParams.WRAP_CONTENT))
                editor_row.addView(divider_line, divider_lp)

            editor_row.addView(pg_text_editor, LinearLayout.LayoutParams(0, ViewGroup.LayoutParams.WRAP_CONTENT, 1.0))

            search_matches = []
            search_current_idx = [0]

            SEARCH_HIGHLIGHT_COLOR = Color.parseColor("#FFFF00")
            SEARCH_CURRENT_COLOR   = Color.parseColor("#FF8C00")

            search_panel = LinearLayout(activity)
            search_panel.setOrientation(LinearLayout.HORIZONTAL)
            search_panel.setLayoutParams(LinearLayout.LayoutParams(
                ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.WRAP_CONTENT))
            search_panel.setGravity(Gravity.CENTER_VERTICAL)
            search_panel.setPadding(AndroidUtilities.dp(8), AndroidUtilities.dp(10), AndroidUtilities.dp(8), AndroidUtilities.dp(10))
            if Theme:
                try:
                    bg = _GradientDrawable()
                    bg.setColor(Theme.getColor(Theme.key_windowBackgroundGray))
                    bg.setCornerRadius(AndroidUtilities.dp(8))
                    search_panel.setBackground(bg)
                except Exception:
                    pass

            if EditTextBoldCursor:
                search_field = EditTextBoldCursor(activity)
            else:
                search_field = TextView(activity)

            search_field.setHint(self.get_string("search_hint"))
            search_field.setSingleLine(True)
            search_field.setInputType(InputType.TYPE_CLASS_TEXT)
            search_field.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 15)
            if Theme:
                search_field.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
                search_field.setHintTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteHintText))
            else:
                search_field.setTextColor(Color.WHITE)
                search_field.setHintTextColor(Color.GRAY)
            search_field.setBackground(None)
            search_field.setPadding(AndroidUtilities.dp(6), AndroidUtilities.dp(8), AndroidUtilities.dp(6), AndroidUtilities.dp(8))

            search_counter_tv = TextView(activity)
            search_counter_tv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 12)
            search_counter_tv.setMinWidth(AndroidUtilities.dp(60))
            search_counter_tv.setGravity(Gravity.CENTER)
            if Theme:
                search_counter_tv.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
            else:
