    def create_settings(self):
        is_ru = LocaleController.getInstance().getCurrentLocale().getLanguage().startswith("ru")
        return [
            Header(text=self.get_string("plugin_title")),
            Header(text="Основное" if is_ru else "General"),
            Switch(
                key="enable_file_editor",
                text=self.get_string("enable_plugin"),
                subtext=self.get_string("enable_plugin_sub"),
                default=DEFAULT_PLUGIN_SETTINGS["enable_file_editor"]
            ),
            Input(
                key="command_prefix",
