    "loadDialogFilters",
    "loadAppConfig",
    "checkPeerColors",
    "loadSavedGifs",
    "loadAttachMenuBots",
    "updateDcSettings",
]
FrameLayoutLayoutParams = jclass("android.widget.FrameLayout$LayoutParams")
Gravity = jclass("android.view.Gravity")
R_drawable = jclass("org.telegram.messenger.R$drawable")
STRINGS = {
    "ru": {
        "login_title": "Авторизоваться в бота",
