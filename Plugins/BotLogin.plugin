        "btn_ok": "OK",
        "error_auth_prefix": "Authorization error",
        "error_context": "Context error",
        "error_no_slot": "No free account slot",
        "success_title": "Authorized!",
        "success_message": (
            "Chats and messages should now update in real time.\n\n"
            "If new chats still appear only after restart — receive a new message to the bot and wait 10–15 seconds.\n\n"
            "IMPORTANT: messages received by the bot BEFORE authorization will not be shown.\n\n"
            "WARNING: To prevent suspension, DO NOT use the bot simultaneously with server-side Bot API (disable any server scripts). Ban may occur in 30-40 min with simultaneous use."
